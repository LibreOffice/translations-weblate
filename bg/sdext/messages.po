#. DBh7w
#. %IMAGES will be replaced with the number of images to optimize. It will only be used in the plural.
#: sdext/inc/strings.hrc:26
msgctxt "STR_OPTIMIZE_IMAGES"
msgid "Optimize 1 image to %QUALITY% JPEG quality at %RESOLUTION DPI."
msgid_plural "Optimize %IMAGES images to %QUALITY% JPEG quality at %RESOLUTION DPI."
msgstr[0] "Оптимизиране на 1 изображение до JPEG с качество %QUALITY% и %RESOLUTION т./инч."
msgstr[1] "Оптимизиране на %IMAGES изображения до JPEG с качество %QUALITY% и %RESOLUTION т./инч."

