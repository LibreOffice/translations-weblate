msgid "The amount to increment each subsequent value in the array."
msgstr "Beløpet som skal økes for hver påfølgende verdi i matrisen."

#. LbVEK
#: sc/inc/scfuncs.hrc:4241
msgctxt "ocRANDARRAY"
msgid "Generates an array of random numbers between two limit values."
msgstr "Genererer en rekke tilfeldige tall mellom to grenseverdier."

#. FkAEX
#: sc/inc/scfuncs.hrc:4242
msgctxt "ocRANDARRAY"
msgid "Rows"
msgstr "Rader"

#. MAEDm
#: sc/inc/scfuncs.hrc:4243
msgctxt "ocRANDARRAY"
msgid "The number of rows to return."
msgstr "Antall rader som skal returneres."

#. KEjFn
#: sc/inc/scfuncs.hrc:4244
msgctxt "ocRANDARRAY"
msgid "Columns"
msgstr "Kolonner"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Antall kolonner som skal returneres."

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
msgctxt "ocRANDARRAY"
msgid "Min"
msgstr "Min"

#. gEAsz
#: sc/inc/scfuncs.hrc:4247
msgctxt "ocRANDARRAY"
msgid "The lower limit of the generated numbers."
msgstr "Den nedre grensen for de genererte tallene."

#. zBinA
#: sc/inc/scfuncs.hrc:4248
msgctxt "ocRANDARRAY"
msgid "Max"
msgstr "Maks"

