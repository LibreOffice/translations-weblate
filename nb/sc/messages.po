msgid "Integers"
msgstr "Heltall"

#. RM5HL
#: sc/inc/scfuncs.hrc:4251
msgctxt "ocRANDARRAY"
msgid "Return integer (TRUE) or decimal (FALSE) values."
msgstr "Returner heltall (SANN) eller desimal (USANN) verdier."

#. 6xiFb
#: sc/inc/scfuncs.hrc:4257
msgctxt "ocCHOOSECOLS"
msgid "Returns the specified columns from an array."
msgstr "Returnerer de angitte kolonnene fra en matrise."

