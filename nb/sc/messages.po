msgstr "Legger til matriser horisontalt for å lage en større matrise."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Matrise"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Den første matrisen som legges til."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Matrise 1, Matrise 2,... Følgende matriser som skal legges til. Hvis en matrise har færre rader, vil en #N/A feil returneres i de ekstra radene."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Legger til matriser vertikalt for å lage en større matrise."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Matrise"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Den første matrisen som legges til."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Matrise 1, Matrise 2,... Følgende matriser som skal legges til. Hvis en matrise har færre kolonner, vil en #N/A feil returneres i de ekstra kolonnene."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Returnerer et spesifisert antall sammenhengende rader eller kolonner fra starten eller slutten av en matrise."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Matrise"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
