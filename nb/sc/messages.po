#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Matchmodus"

#. pjYxd
#: sc/inc/scfuncs.hrc:4381
msgctxt "ocTEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Sett til 1 for å utføre et treff som ikke skiller mellom store og små bokstaver. Standardinnstillingen er 0."

#. LsoKk
#: sc/inc/scfuncs.hrc:4382
msgctxt "ocTEXTSPLIT"
msgid "Pad with"
msgstr "Pad med"

#. niX3W
#: sc/inc/scfuncs.hrc:4383
msgctxt "ocTEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "Verdien som skal fylles ut med. Standardverdien er #N/A."

#. dv6gP
#: sc/inc/scfuncs.hrc:4389
msgctxt "ocTOCOL"
msgid "Transforms an array into a single column."
msgstr "Transformerer en matrise til en enkelt kolonne."

#. A9zBS
#: sc/inc/scfuncs.hrc:4390
msgctxt "ocTOCOL"
msgid "Array"
msgstr "Matrise"

#. x95Ef
#: sc/inc/scfuncs.hrc:4391
msgctxt "ocTOCOL"
msgid "The range or array to return as a single column."
msgstr "Området eller matrisen som skal returneres som en enkelt kolonne."

#. weBya
#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Ignorer"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Om man skal ignorere visse typer verdier. 0 eller utelatt - behold alle verdier (standard). 1 - ignorer tomme celler. 2 - ignorer celler med feil. 3 - ignorer tomme celler og celler med feil."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Skann etter kolonne"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Skann matrisen etter kolonne. USANN eller utelatt (standard) - matrisen skannes etter rad. SANN - matrisen skannes etter kolonne."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "transformerer en matrise til én enkelt rad."

#. GAbkQ
#: sc/inc/scfuncs.hrc:4402
msgctxt "ocTOROW"
msgid "Array"
msgstr "Matrise"

#. w7WXB
#: sc/inc/scfuncs.hrc:4403
msgctxt "ocTOROW"
msgid "The range or array to return as a single row."
msgstr "Området eller matrisen som skal returneres som en enkelt rad."

#. GCfA2
#: sc/inc/scfuncs.hrc:4404
msgctxt "ocTOROW"
msgid "Ignore"
msgstr "Ignorer"

#. AnEDD
#: sc/inc/scfuncs.hrc:4405
msgctxt "ocTOROW"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Om man skal ignorere visse typer verdier. 0 eller de som er utelatt - behold alle verdier (standard). 1 - ignorer tomme celler. 2 - ignorer celler med feil. 3 - ignorer tomme celler og celler med feil."

#. pDD7V
#: sc/inc/scfuncs.hrc:4406
msgctxt "ocTOROW"
msgid "Scan by column"
msgstr "Skann etter kolonne"

#. qxY7a
#: sc/inc/scfuncs.hrc:4407
msgctxt "ocTOROW"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Skann matrisen etter kolonne. USANN eller utelatt (standard) - matrisen skannes etter rad. SANN - matrisen skannes etter kolonne."

#. 8p5AW
#: sc/inc/scfuncs.hrc:4413
msgctxt "ocUNIQUE"
msgid "Returns a list of unique values from a range or array."
msgstr "Returnerer en liste over unike verdier fra et område eller en matrise."

#. LAeWQ
#: sc/inc/scfuncs.hrc:4414
msgctxt "ocUNIQUE"
msgid "Array"
msgstr "Matrise"

#. LHrXJ
#: sc/inc/scfuncs.hrc:4415
msgctxt "ocUNIQUE"
msgid "The range or array from which to return unique values."
msgstr "Området eller matrisen som unike verdier skal returneres fra."

#. TBfHR
#: sc/inc/scfuncs.hrc:4416
msgctxt "ocUNIQUE"
msgid "By col"
msgstr "Etter kolonne"

#. xiVEn
#: sc/inc/scfuncs.hrc:4417
msgctxt "ocUNIQUE"
msgid "Logical value indicating how to compare data: TRUE - compares data across columns. FALSE or omitted (default) - compares data across rows."
msgstr "Logisk verdi som indikerer hvordan data skal sammenlignes: SANN – sammenligner data på tvers av kolonner. USANN eller utelatt (standard) - sammenligner data på tvers av rader."

#. GLsJf
#: sc/inc/scfuncs.hrc:4418
msgctxt "ocUNIQUE"
msgid "Uniqueness"
msgstr "Unikhet"

#. ubRgX
#: sc/inc/scfuncs.hrc:4419
msgctxt "ocUNIQUE"
msgid "Logical value that defines what values are considered unique: TRUE - returns values that occur only once. FALSE or omitted (default) - returns all distinct (different) values in the range or array."
msgstr "Logisk verdi som definerer hvilke verdier som anses som unike: SANN – returnerer verdier som bare forekommer én gang. USANN eller utelatt (standard) - returnerer alle distinkte (forskjellige) verdier i området eller matrisen."

#. 5Aaqr
#: sc/inc/scfuncs.hrc:4425
msgctxt "ocLET"
msgid "The LET function assigns names to calculation results. This allows storing intermediate calculations, values, or defining names inside a formula. These names only apply within the scope of the LET function."
msgstr "LET-funksjonen tildeler navn til beregningsresultater. Dette gjør det mulig å lagre mellomliggende beregninger, verdier eller definere navn i en formel. Disse navnene gjelder kun innenfor rammen av LET-funksjonen."

#. GTBCS
#: sc/inc/scfuncs.hrc:4426
msgctxt "ocLET"
msgid "Name 1"
msgstr "Navn 1"

#. BXEhz
#: sc/inc/scfuncs.hrc:4427
msgctxt "ocLET"
msgid "The first name to assign. Must start with a letter. Cannot be the output of a formula or conflict with range syntax."
msgstr "Det første navnet som skal tildeles. Må starte med en bokstav. Kan ikke være utdata fra en formel eller konflikt med områdesyntaks."

#. agD98
#: sc/inc/scfuncs.hrc:4428
msgctxt "ocLET"
msgid "Name value "
msgstr "Navneverdi "

#. CjEiH
#: sc/inc/scfuncs.hrc:4429
msgctxt "ocLET"
msgid "Name value 1, Name value 2,... The value or calculation to assign to Name."
msgstr "Navneverdi 1, Navneverdi 2,... Verdien eller beregningen som skal tildeles til Navn."

#. GCAQK
#: sc/inc/scfuncs.hrc:4430
msgctxt "ocLET"
msgid "Calculation or Name "
msgstr "Beregning eller navn "

#. uzEFm
#: sc/inc/scfuncs.hrc:4431
msgctxt "ocLET"
msgid "A calculation that uses all names within the LET function. This must be the last argument in the LET function. Or a second Name to assign to a second Name value. If a second Name is specified, Name value 2 and Calculation or Name 3 become required."
msgstr "En beregning som bruker alle navn i LET-funksjonen. Dette må være det siste argumentet i LET-funksjonen. Eller et annet navn for å tilordne en andre navnverdi. Hvis et annet navn er spesifisert, kreves Navnverdi 2 og Beregning eller Navn 3."

#. HbPvG
