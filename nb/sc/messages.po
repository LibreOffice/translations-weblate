msgctxt "ocTAKE"
msgid "Rows"
msgstr "Rader"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Antall rader som skal hentes. En negativ verdi hentes fra slutten av matrisen."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Kolonner"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Antall kolonner som skal hentes. En negativ verdi hentes fra slutten av matrisen."

#. okoEs
