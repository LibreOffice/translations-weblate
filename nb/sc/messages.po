msgid "Rows"
msgstr "Rader"

#. QJTBL
#: sc/inc/scfuncs.hrc:4229
msgctxt "ocMAT_SEQUENCE"
msgid "The number of rows to return."
msgstr "Lar deg generere en liste over sekvensielle tall i en matrise, for eksempel 1, 2, 3, 4."

#. GEC8c
#: sc/inc/scfuncs.hrc:4230
msgctxt "ocMAT_SEQUENCE"
msgid "Columns"
msgstr "Kolonner"

