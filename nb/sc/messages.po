msgctxt "ocDROP"
msgid "Excludes a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Ekskluderer et spesifisert antall sammenhengende rader eller kolonner fra starten eller slutten av en matrise."

#. qqDwt
#: sc/inc/scfuncs.hrc:4278
msgctxt "ocDROP"
msgid "Array"
msgstr "Matrise"

#. 6hEEw
#: sc/inc/scfuncs.hrc:4279
msgctxt "ocDROP"
msgid "The array from which to drop rows or columns."
msgstr "Matrisen som rader eller kolonner skal droppes fra."

#. CCEFR
#: sc/inc/scfuncs.hrc:4280
msgctxt "ocDROP"
msgid "Rows"
msgstr "Rader"

#. 6afd9
#: sc/inc/scfuncs.hrc:4281
msgctxt "ocDROP"
msgid "The number of rows to drop. A negative value drops from the end of the array."
msgstr "Antall rader som skal droppes. En negativ verdi droppes fra slutten av matrisen."

#. 4NBh4
#: sc/inc/scfuncs.hrc:4282
msgctxt "ocDROP"
msgid "Columns"
msgstr "Kolonner"

#. Smjhs
#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Antall kolonner som skal droppes. En negativ verdi droppes slutten av matrisen."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Utvider eller utfyller en matrise med spesifiserte rad- og kolonnedimensjoner."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Matrise"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "Matrisen som skal utvides."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Rader"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Antall rader i den utvidede matrisen. Hvis den mangler, vil ikke rader bli lagt til."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Kolonner"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Antall rader i den utvidede matrisen. Hvis den mangler, vil ikke rader bli lagt til."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "Polstre med"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "Verdien som skal fylles med. Standard er #N/A."

#. VuRi8
