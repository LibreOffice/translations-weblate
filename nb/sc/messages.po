msgstr "Matrise"

#. R3koe
#: sc/inc/scfuncs.hrc:4259
msgctxt "ocCHOOSECOLS"
msgid "The array containing the columns to be returned in the new array."
msgstr "Matrisen som inneholder kolonnene som skal returneres i den nye matrisen."

#. kZPeA
#: sc/inc/scfuncs.hrc:4260
msgctxt "ocCHOOSECOLS"
msgid "Column "
msgstr "Kolonne "

#. cwS8A
#: sc/inc/scfuncs.hrc:4261
msgctxt "ocCHOOSECOLS"
msgid "Column 1, Column 2,... The list of column numbers to be returned."
msgstr "Kolonne 1, kolonne 2,... Listen over kolonnenumre som skal returneres."

#. sGgbA
