msgstr "Hvis ikke funnet"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Verdien som returneres hvis ingen treff finnes. Standardverdien er #N/A."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Returnerer teksten som står før en gitt delstreng eller et skilletegn."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Tekst"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Den originale teksten."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Skilletegn"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Skilletegn. Flere skilletegn kan angis."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Instansnummer"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Forekomsten av skilletegnet som tekst skal trekkes ut før. Standardverdien er 1. Et negativt tall starter søket fra slutten."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Matchmodus"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Sett til 1 for å utføre et treff som ikke skiller mellom store og små bokstaver. Standardinnstillingen er 0."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Match slutt"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Sett til 1 for å behandle slutten av teksten som et skilletegn. Standardinnstillingen er 0."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Hvis ikke funnet"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Verdien som returneres hvis ingen treff finnes. Standardverdien er #N/A."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Splitter tekst med et gitt skilletegn til en matrise med flere celler."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Tekst"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "Teksten som skal splittes."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Kolonneskilletegn"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "Teksten som skal avgrense kolonnene. Flere skilletegn kan angis."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Radskilletegn"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "Teksten som skal avgrense radene. Flere skilletegn kan angis."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Ignorer tom"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Sett til SANN for å ignorere etterfølgende skilletegn, ellers opprettes en tom celle. Standardverdien er USANN."

