msgctxt "ocCLEAN"
msgid "The text from which nonprintable characters are to be removed."
msgstr "Текст, з якого вилучаються недруковані символи."

#. qCCXt
#: sc/inc/scfuncs.hrc:3601
msgctxt "ocCONCAT"
msgid "Combines several text items into one."
msgstr "Об'єднає декілька текстових елементів в один рядок."

#. Qfk8d
#: sc/inc/scfuncs.hrc:3602
msgctxt "ocCONCAT"
msgid "Text"
msgstr "Текст"

#. Ywoh6
#: sc/inc/scfuncs.hrc:3603
msgctxt "ocCONCAT"
msgid "Text for the concatenation."
msgstr "Текст для об'єднання."

#. a7n3F
#: sc/inc/scfuncs.hrc:3609
msgctxt "ocCONCAT_MS"
msgid "Combines several text items into one, accepts cell ranges as arguments."
msgstr "Об'єднує кілька текстових значень в одне; допускає як аргументи діапазони комірок."

#. Dt3XC
#: sc/inc/scfuncs.hrc:3610
msgctxt "ocCONCAT_MS"
msgid "Text"
msgstr "Текст"

#. 3UKas
#: sc/inc/scfuncs.hrc:3611
msgctxt "ocCONCAT_MS"
msgid "Text and/or cell ranges for the concatenation."
msgstr "Текст і/або діапазони комірок для об'єднання."

#. bXDdz
#: sc/inc/scfuncs.hrc:3617
msgctxt "ocTEXTJOIN_MS"
msgid "Combines several text items into one, accepts cell ranges as arguments. Uses delimiter between items."
msgstr "Об'єднує кілька текстових значень в одне; допускає як аргументи діапазони комірок. Використовує роздільник між елементами."

#. wRn9f
#: sc/inc/scfuncs.hrc:3618
msgctxt "ocTEXTJOIN_MS"
msgid "Delimiter"
msgstr "Роздільник"

#. vBL2U
#: sc/inc/scfuncs.hrc:3619
msgctxt "ocTEXTJOIN_MS"
msgid "Text string to be used as delimiter."
msgstr "Текст, що використовується як роздільник."

#. aWBkD
#: sc/inc/scfuncs.hrc:3620
msgctxt "ocTEXTJOIN_MS"
msgid "Skip empty cells"
msgstr ""

#. 54rgD
#: sc/inc/scfuncs.hrc:3621
msgctxt "ocTEXTJOIN_MS"
msgid "If TRUE, empty cells will be ignored."
msgstr "Якщо ІСТИНА, то порожні комірки будуть знехтувані."

#. AXZri
#: sc/inc/scfuncs.hrc:3622
msgctxt "ocTEXTJOIN_MS"
msgid "Text"
msgstr "Текст"

#. UgtQ9
#: sc/inc/scfuncs.hrc:3623
msgctxt "ocTEXTJOIN_MS"
msgid "Text and/or cell ranges for the concatenation."
msgstr "Текст та/або діапазон комірок для об'єднання."

#. UE3Dz
#: sc/inc/scfuncs.hrc:3629
msgctxt "ocIFS_MS"
msgid "Checks 1 or more conditions and returns a value corresponding to the first true condition."
msgstr "Перевіряє умову 1 або більше умов та повертає значення, яке відповідає першій істинній умові."

#. FbouL
#: sc/inc/scfuncs.hrc:3630
msgctxt "ocIFS_MS"
msgid "Test"
msgstr "Тест"

#. D3Gnr
#: sc/inc/scfuncs.hrc:3631
msgctxt "ocIFS_MS"
msgid "Any value or expression which can be either TRUE or FALSE."
msgstr "Будь-яке значення або вираз, які при обчисленні дають значення TRUE чи FALSE."

#. 5EAbH
#: sc/inc/scfuncs.hrc:3632
msgctxt "ocIFS_MS"
msgid "Result"
msgstr "Результат"

#. uMaAz
#: sc/inc/scfuncs.hrc:3633
msgctxt "ocIFS_MS"
msgid "The result of the function if test is TRUE."
msgstr "Результат функції, якщо текст є істиною."

#. bLDmt
#: sc/inc/scfuncs.hrc:3639
msgctxt "ocSWITCH_MS"
msgid "Compares expression against list of value/result pairs, and returns result for first value that matches the expression.  If expression does not match any value, a default result is returned, if it is placed as final item in parameter list without a value."
msgstr "Порівнює вираз зі списком пар значення / результат і повертає результат для першого значення, яке відповідає виразу. Якщо вираз не відповідає жодному значенню, надається типовий результат, якщо він розміщений як кінцевий елемент у списку параметрів без значення."

#. YW6AA
#: sc/inc/scfuncs.hrc:3640
msgctxt "ocSWITCH_MS"
msgid "Expression"
msgstr "Вираз"

#. FFu9v
#: sc/inc/scfuncs.hrc:3641
msgctxt "ocSWITCH_MS"
msgid "Value to be compared against value1…valueN (N ≤ 127)"
msgstr "Значення для порівняння зі значенням1 ... значенняN (N ≤ 127)"

#. sc7xf
#: sc/inc/scfuncs.hrc:3642
msgctxt "ocSWITCH_MS"
msgid "Value"
msgstr "Значення"

#. XynUw
#: sc/inc/scfuncs.hrc:3643
msgctxt "ocSWITCH_MS"
msgid "Value to compare against expression. If no result is given, then value is returned as default result."
msgstr "Значення для порівняння з виразом. Якщо результат не вказано, значення видається як результат за замовчуванням."

#. WMQ6f
#: sc/inc/scfuncs.hrc:3644
msgctxt "ocSWITCH_MS"
msgid "Result"
msgstr "Результат"

#. jJqUE
#: sc/inc/scfuncs.hrc:3645
msgctxt "ocSWITCH_MS"
msgid "Value to return when corresponding value argument matches expression."
msgstr "Значення, яке буде повернуто, коли відповідний аргумент дорівнює виразу."

#. iC2Ps
#: sc/inc/scfuncs.hrc:3650
msgctxt "ocMINIFS_MS"
msgid "Returns the minimum value in a range that meet multiple criteria in multiple ranges."
msgstr "Повертає найменше значення з діапазону, що задовольняє декільком критеріям з багатьох діапазонів."

#. EWx5x
#: sc/inc/scfuncs.hrc:3651
msgctxt "ocMINIFS_MS"
msgid "Min range"
msgstr "Мін. діапазон"

#. fLjGC
#: sc/inc/scfuncs.hrc:3652
msgctxt "ocMINIFS_MS"
msgid "The range from which the minimum will be determined."
msgstr "Діапазон, з якого буде визначено мінімум."

#. aW9bE
#: sc/inc/scfuncs.hrc:3653
msgctxt "ocMINIFS_MS"
msgid "Range "
msgstr "Діапазон "

#. qrT8q
#: sc/inc/scfuncs.hrc:3654
msgctxt "ocMINIFS_MS"
msgid "Range 1, range 2,... are the ranges to be evaluated by the criteria given."
msgstr "Діапазон 1, діапазон 2, ... — діапазони, до яких застосовуються критерії."

#. CBwwS
#: sc/inc/scfuncs.hrc:3655
msgctxt "ocMINIFS_MS"
msgid "Criteria "
msgstr "Критерії "

#. U5nDi
#: sc/inc/scfuncs.hrc:3656
msgctxt "ocMINIFS_MS"
msgid "Criteria 1, criteria 2,... are the criteria to be applied to the ranges given."
msgstr "Критерій 1, критерій 2,... - це критерії, які будуть застосовані до вказаного діапазону."

#. XFfNP
#: sc/inc/scfuncs.hrc:3661
msgctxt "ocMAXIFS_MS"
msgid "Returns the maximum value in a range that meet multiple criteria in multiple ranges."
msgstr "Повертає найбільше значення з діапазону, що задовольняє декільком критеріям з багатьох діапазонів."

#. FefDg
#: sc/inc/scfuncs.hrc:3662
msgctxt "ocMAXIFS_MS"
msgid "Max range"
msgstr "Макс. діапазон"

#. K2x3P
#: sc/inc/scfuncs.hrc:3663
msgctxt "ocMAXIFS_MS"
msgid "The range from which the maximum will be determined."
msgstr "Діапазон, з якого буде визначено максимум."

#. FAmqX
#: sc/inc/scfuncs.hrc:3664
msgctxt "ocMAXIFS_MS"
msgid "Range "
msgstr "Діапазон "

#. TzfDx
#: sc/inc/scfuncs.hrc:3665
msgctxt "ocMAXIFS_MS"
msgid "Range 1, range 2,... are the ranges to be evaluated by the criteria given."
msgstr "Діапазон 1, діапазон 2, ... — діапазони, до яких застосовуються критерії."

#. CAoi8
#: sc/inc/scfuncs.hrc:3666
msgctxt "ocMAXIFS_MS"
msgid "Criteria "
msgstr "Критерії "

#. qETAC
#: sc/inc/scfuncs.hrc:3667
msgctxt "ocMAXIFS_MS"
msgid "Criteria 1, criteria 2,... are the criteria to be applied to the ranges given."
msgstr "Критерій 1, критерій 2,... - це критерії, які будуть застосовані до вказаного діапазону."

#. 8myxA
#: sc/inc/scfuncs.hrc:3673
msgctxt "ocEXACT"
msgid "Specifies whether two texts are identical."
msgstr "Порівнює два текстові рядки, та повертає TRUE, якщо вони одинакові, чи FALSE, якщо рядки відрізняються."

#. PLeWB
#: sc/inc/scfuncs.hrc:3674
msgctxt "ocEXACT"
msgid "Text 1"
msgstr "Текст 1"

#. EKDrK
#: sc/inc/scfuncs.hrc:3675
msgctxt "ocEXACT"
msgid "The first text to be used for comparing texts."
msgstr "Перший текст для порівняння текстів."

#. 8NKYa
#: sc/inc/scfuncs.hrc:3676
msgctxt "ocEXACT"
msgid "Text 2"
msgstr "Текст 2"

#. avCaN
#: sc/inc/scfuncs.hrc:3677
msgctxt "ocEXACT"
msgid "The second text for comparing texts."
msgstr "Другий текст для порівняння текстів."

#. yehHT
#: sc/inc/scfuncs.hrc:3683
msgctxt "ocFIND"
msgid "Looks for a string of text within another (case sensitive)"
msgstr "Шукає частину тексту у тексті (з урахуванням регістру)"

#. XCCUs
#: sc/inc/scfuncs.hrc:3684
msgctxt "ocFIND"
msgid "Find text"
msgstr "Знайти текст"

#. EAxVC
#: sc/inc/scfuncs.hrc:3685
msgctxt "ocFIND"
msgid "The text to be found."
msgstr "Текст, який треба знайти."

#. hP6AR
#: sc/inc/scfuncs.hrc:3686
msgctxt "ocFIND"
msgid "Text"
msgstr "Текст"

#. MgVxo
#: sc/inc/scfuncs.hrc:3687
msgctxt "ocFIND"
msgid "The text in which a search is to be made."
msgstr "Текст, у якому треба шукати."

#. EB2Fg
#: sc/inc/scfuncs.hrc:3688
msgctxt "ocFIND"
msgid "Position"
msgstr ""

#. KaK97
#: sc/inc/scfuncs.hrc:3689
msgctxt "ocFIND"
msgid "The position in the text from which the search starts."
msgstr "Позиція у тексті, з якої починати пошук."

#. Q56N4
#: sc/inc/scfuncs.hrc:3695
msgctxt "ocSEARCH"
msgid "Looks for one text value within another (not case-sensitive)."
msgstr "повертає номер позиції сегменту тексту."

#. rcKnP
#: sc/inc/scfuncs.hrc:3696
msgctxt "ocSEARCH"
msgid "Find text"
msgstr "Знайти текст"

#. CCFGR
#: sc/inc/scfuncs.hrc:3697
msgctxt "ocSEARCH"
msgid "The text to be found."
msgstr "Текст, який треба знайти."

#. jCXLx
#: sc/inc/scfuncs.hrc:3698
msgctxt "ocSEARCH"
msgid "Text"
msgstr "Текст"

#. GgCCy
#: sc/inc/scfuncs.hrc:3699
msgctxt "ocSEARCH"
msgid "The text in which a search is to be made."
msgstr "Текст, у якому треба шукати."

#. JdGmJ
#: sc/inc/scfuncs.hrc:3700
msgctxt "ocSEARCH"
msgid "Position"
msgstr "Положення"

#. UWg3H
#: sc/inc/scfuncs.hrc:3701
msgctxt "ocSEARCH"
msgid "The position in the text where the search is started."
msgstr "Позиція в тексті, починаючи з якої ведеться пошук."

#. oxkZC
#: sc/inc/scfuncs.hrc:3707
msgctxt "ocTRIM"
msgid "Removes extra spaces from text."
msgstr "Видаляє зайві пробіли між словами."

#. VxHVQ
#: sc/inc/scfuncs.hrc:3708
msgctxt "ocTRIM"
msgid "Text"
msgstr "Текст"

#. G4RE2
#: sc/inc/scfuncs.hrc:3709
msgctxt "ocTRIM"
msgid "The text in which extra spaces between words are to be deleted."
msgstr "Текст, з якого вилучаються зайві пробіли між словами."

#. KTAkS
#: sc/inc/scfuncs.hrc:3715
msgctxt "ocPROPER"
msgid "Capitalizes the first letter in all words."
msgstr "Робить перші літери всіх слів великими."

#. bs7zA
#: sc/inc/scfuncs.hrc:3716
msgctxt "ocPROPER"
msgid "Text"
msgstr "Текст"

#. knQ6h
#: sc/inc/scfuncs.hrc:3717
msgctxt "ocPROPER"
msgid "The text in which the beginning of words are to be replaced by capital letters."
msgstr "Текст, у якому замінюються перші літери на великі."

#. rVBP5
#: sc/inc/scfuncs.hrc:3723
msgctxt "ocUPPER"
msgid "Converts text to uppercase."
msgstr "Перетворює всі букви вказаного тексту на великі."

#. cQj2B
#: sc/inc/scfuncs.hrc:3724
msgctxt "ocUPPER"
msgid "Text"
msgstr "Текст"

#. AEyBM
#: sc/inc/scfuncs.hrc:3725
msgctxt "ocUPPER"
msgid "The text in which lower case letters are to be converted to capitals."
msgstr "Текст, у якому маленькі літери замінюються великими."

#. 5u5iC
#: sc/inc/scfuncs.hrc:3731
msgctxt "ocLOWER"
msgid "Converts text to lowercase."
msgstr "Конвертує всі літери вказаного тексту у рядкові."

#. B5Vzm
#: sc/inc/scfuncs.hrc:3732
msgctxt "ocLOWER"
msgid "Text"
msgstr "Текст"

#. Crumi
#: sc/inc/scfuncs.hrc:3733
msgctxt "ocLOWER"
msgid "The text in which capitals are converted to lower case letters."
msgstr "Текст в якому великі літери перетворені в малі літери."

#. S6AN6
#: sc/inc/scfuncs.hrc:3739
msgctxt "ocVALUE"
msgid "Converts text to a number."
msgstr "Перетворює текст на число."

#. kS8WD
#: sc/inc/scfuncs.hrc:3740
msgctxt "ocVALUE"
msgid "Text"
msgstr "Текст"

#. s8Xoq
#: sc/inc/scfuncs.hrc:3741
msgctxt "ocVALUE"
msgid "The text to be converted to a number."
msgstr "Текст, що перетворюється на число."

#. 7ufRd
#: sc/inc/scfuncs.hrc:3747
msgctxt "ocTEXT"
msgid "Converts a number to text according to a given format."
msgstr "Конвертує число на текст відповідно до вказаного формату."

#. ht9Hc
#: sc/inc/scfuncs.hrc:3748
msgctxt "ocTEXT"
msgid "Number"
msgstr "Число"

#. aifRA
#: sc/inc/scfuncs.hrc:3749
msgctxt "ocTEXT"
msgid "The numeric value to be converted."
msgstr "Числове значення, що перетворюється."

#. WegPU
#: sc/inc/scfuncs.hrc:3750
msgctxt "ocTEXT"
msgid "Format"
msgstr ""

#. gLwBY
#: sc/inc/scfuncs.hrc:3751
msgctxt "ocTEXT"
msgid "The text that describes the format."
msgstr "Текст, що описує формат."

#. jWECZ
#: sc/inc/scfuncs.hrc:3757
msgctxt "ocT"
msgid "Returns a value if it is text, otherwise an empty string."
msgstr "Повертає аргумент, якщо це рядок, або порожній рядок."

#. z7ZYL
#: sc/inc/scfuncs.hrc:3758
msgctxt "ocT"
msgid "Value"
msgstr "Значення"

#. tGsYm
#: sc/inc/scfuncs.hrc:3759
msgctxt "ocT"
msgid "The value to be checked and returned if it is text."
msgstr "Значення, що перевіряється і буде повернене, якщо воно текстове."

#. QvTZJ
#: sc/inc/scfuncs.hrc:3765
msgctxt "ocREPLACE"
msgid "Replaces characters within a text string with a different text string."
msgstr "Замінює частину рядка іншим рядком."

#. QFBxH
#: sc/inc/scfuncs.hrc:3766
msgctxt "ocREPLACE"
msgid "Text"
msgstr "Текст"

#. a22fC
#: sc/inc/scfuncs.hrc:3767
msgctxt "ocREPLACE"
msgid "The text in which some characters are to be replaced."
msgstr "Текст, у якому слід замінити деякі симвоілів."

#. fXWgz
#: sc/inc/scfuncs.hrc:3768
msgctxt "ocREPLACE"
msgid "Position"
msgstr "Положення"

#. 9R6AG
#: sc/inc/scfuncs.hrc:3769
msgctxt "ocREPLACE"
msgid "The character position from which text is to be replaced."
msgstr "Позиція символів, з якої треба виконати заміну."

#. 46Gho
#: sc/inc/scfuncs.hrc:3770
msgctxt "ocREPLACE"
msgid "Length"
msgstr "Довжина"

#. HdAGg
#: sc/inc/scfuncs.hrc:3771
msgctxt "ocREPLACE"
msgid "The number of characters to be replaced."
msgstr "Кількість символів, що буде замінено."

#. vYevC
#: sc/inc/scfuncs.hrc:3772
msgctxt "ocREPLACE"
msgid "New text"
msgstr "Новий текст"

#. BHPKu
#: sc/inc/scfuncs.hrc:3773
msgctxt "ocREPLACE"
msgid "The text to be inserted."
msgstr "Текст, що буде вставлений."

#. d7z6V
#: sc/inc/scfuncs.hrc:3779
msgctxt "ocFIXED"
msgid "Formats a number with a fixed number of places after the decimal point and thousands separator."
msgstr "Задає формат числа з фіксованою кількістю знаків після коми та розділенням тисяч."

#. R39wU
#: sc/inc/scfuncs.hrc:3780
msgctxt "ocFIXED"
msgid "Number"
msgstr "Число"

#. TnPs3
#: sc/inc/scfuncs.hrc:3781
msgctxt "ocFIXED"
msgid "The number to be formatted."
msgstr "Число, що буде відформатовано."

#. MsQpA
#: sc/inc/scfuncs.hrc:3782
msgctxt "ocFIXED"
msgid "Decimals"
msgstr "Кількість розрядів"

#. CDUam
#: sc/inc/scfuncs.hrc:3783
msgctxt "ocFIXED"
msgid "Decimal places. The number of fixed decimal places that are to be displayed. Default 2."
msgstr "Десяткові знаки. Кількість фіксованих знаків після коми, які мають відображатися. Типове значення 2."

#. vcYMq
#: sc/inc/scfuncs.hrc:3784
msgctxt "ocFIXED"
msgid "No thousands separators"
msgstr "Без розділення тисяч"

#. zTLBt
#: sc/inc/scfuncs.hrc:3785
msgctxt "ocFIXED"
msgid "Thousands separator. If 0 or omitted the locale group separator is used else the separator is suppressed."
msgstr "Розділювач тисяч. Якщо він дорівнює 0 або пропущений, то роздільник груп визнається на основі налаштувань країни, в іншому випадку він буде опущений."

#. sicZd
#: sc/inc/scfuncs.hrc:3791
msgctxt "ocLEN"
msgid "Calculates length of a text string."
msgstr "Обчислює довжину рядка з урахуванням пробілів."

#. jcMBE
#: sc/inc/scfuncs.hrc:3792
msgctxt "ocLEN"
msgid "Text"
msgstr "Текст"

#. rZEqe
#: sc/inc/scfuncs.hrc:3793
msgctxt "ocLEN"
msgid "The text in which the length is to be determined."
msgstr "Текст, довжину якого треба визначити."

#. jaA8a
#: sc/inc/scfuncs.hrc:3799
msgctxt "ocLEFT"
msgid "Returns the first character or characters of a text."
msgstr "Визначить перший символ або символ тексту."

#. 3B9xE
#: sc/inc/scfuncs.hrc:3800
msgctxt "ocLEFT"
msgid "Text"
msgstr "Текст"

#. ExPmV
#: sc/inc/scfuncs.hrc:3801
msgctxt "ocLEFT"
msgid "The text where the initial partial words are to be determined."
msgstr "Текстовий рядок, з якого треба витягнути символи неповного слова, що містяться у ньому."

#. 3dDLt
#: sc/inc/scfuncs.hrc:3802
msgctxt "ocLEFT"
msgid "Number"
msgstr "Число"

#. KkAFw
#: sc/inc/scfuncs.hrc:3803
msgctxt "ocLEFT"
msgid "The number of characters for the start text."
msgstr "Кількість символів початкового тексту."

#. ii2Ak
#: sc/inc/scfuncs.hrc:3809
msgctxt "ocRIGHT"
msgid "Returns the last character or characters of a text."
msgstr "Повертає останні символи або символи текст."

#. paWkk
#: sc/inc/scfuncs.hrc:3810
msgctxt "ocRIGHT"
msgid "Text"
msgstr "Текст"

#. obDQZ
#: sc/inc/scfuncs.hrc:3811
msgctxt "ocRIGHT"
msgid "The text in which the end partial words are to be determined."
msgstr "Текст, у якому визначаються останні символи."

#. XaFFG
#: sc/inc/scfuncs.hrc:3812
msgctxt "ocRIGHT"
msgid "Number"
msgstr "Число"

#. nXDDL
#: sc/inc/scfuncs.hrc:3813
msgctxt "ocRIGHT"
msgid "The number of characters for the end text."
msgstr "Кількість символів, які треба визначити."

#. pEef9
#: sc/inc/scfuncs.hrc:3819
msgctxt "ocMID"
msgid "Returns a partial text string of a text."
msgstr "Повертає вказане число символів, починаючи з заданої позиції."

#. wDhoZ
#: sc/inc/scfuncs.hrc:3820
msgctxt "ocMID"
msgid "Text"
msgstr "Текст"

