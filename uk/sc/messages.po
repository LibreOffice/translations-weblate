msgctxt "ocFOURIER"
msgid "Flag to indicate whether the array is grouped by columns or not (default TRUE)."
msgstr "Прапорець, який позначає, чи згруповано масив за колонками (типово ІСТИНА)."

#. KqWyU
#: sc/inc/scfuncs.hrc:4162
msgctxt "ocFOURIER"
msgid "Inverse"
msgstr ""

#. RJc49
#: sc/inc/scfuncs.hrc:4163
