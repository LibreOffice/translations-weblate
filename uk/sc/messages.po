msgstr "Увімкнути багатопотокові обчислення"

#. c8e4A
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:706
msgctxt "optcalculatepage|threadingenabled|tooltip_text"
msgid "Enable multi-threaded calculation of formula-groups"
msgstr "Увімкнути багатопотокові обчислення груп формул"

#. MCKJ5
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:731
msgctxt "optcalculatepage|allowopencl"
