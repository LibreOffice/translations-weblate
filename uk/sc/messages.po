msgstr "Значення 0 відповідає 1899-12-30"

#. BhENG
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:303
msgctxt "extended_tip|datestd"
msgid "Sets 1899-12-30 as day zero."
msgstr "Встановлює 1899-12-30 за нульовий день."

#. hMsbb
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:314
msgctxt "optcalculatepage|datesc10"
msgid "1900-01-01 (Star_Calc 1.0)"
msgstr "1900-01-01 (Star_Calc 1.0)"

#. 5pd9U
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:318
msgctxt "optcalculatepage|datesc10|tooltip_text"
msgid "Value 0 corresponds to 1900-01-01"
msgstr "Значення 0 відповідає 1900-01-01"

#. DL4rY
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:324
msgctxt "extended_tip|datesc10"
msgid "Sets 1900-01-01 as day zero. Use this setting for StarCalc 1.0 spreadsheets containing date entries."
msgstr "Встановлює 1900-01-01 за нульовий день. Використовуйте цей параметр для електронних таблиць StarCalc 1.0, що містять записи з датами."

#. t5Cz4
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:335
msgctxt "optcalculatepage|date1904"
msgid "_1904-01-01"
msgstr "_1904-01-01"

#. BPRsN
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:339
msgctxt "optcalculatepage|date1904|tooltip_text"
msgid "0 corresponds to 1904-01-01"
msgstr "0 відповідає 1904-01-01"

#. aEwAF
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:345
msgctxt "extended_tip|date1904"
msgid "Sets 1904-01-01 as day zero. Use this setting for spreadsheets that are imported in a foreign format."
msgstr "Встановлює 1904-01-01 за нульовий день. Використовуйте цей параметр для електронних таблиць, імпортованих в інших форматах."

#. ggkEL
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:379
msgctxt "optcalculatepage|label3"
msgid "Date"
msgstr "Дата"

#. Hd6CV
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:406
msgctxt "optcalculatepage|formulawildcards"
msgid "Enable w_ildcards in formulas"
msgstr "Увімкнути _шаблони у формулах"

#. BKAzW
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:410
msgctxt "optcalculatepage|formulawildcards|tooltip_text"
msgid "Enable wildcards for interoperability with Microsoft Excel"
msgstr "Увімкнути шаблони заміни для сумісності з Microsoft Excel"

#. KXxjQ
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:416
msgctxt "extended_tip|formulawildcards"
msgid "Specifies that wildcards are enabled when searching and also for character string comparisons."
msgstr "Вказує, що замінні знаки можна використовувати під час пошуку, а також для порівняння рядків символів."

#. Gghyb
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:427
msgctxt "optcalculatepage|formularegex"
msgid "Enable r_egular expressions in formulas"
msgstr "_Дозволити регулярні вирази у формулах"

#. D9B3G
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:436
msgctxt "extended_tip|formularegex"
msgid "Specifies that regular expressions instead of simple wildcards are enabled when searching and also for character string comparisons."
msgstr "Вказує, що під час пошуку, а також для порівняння рядків символів використовуються сталі вирази замість простих замінних знаків."

#. gg3Am
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:447
msgctxt "optcalculatepage|formulaliteral"
msgid "No wildcards or regular expressions in formulas"
msgstr "Без шаблонів чи регулярних виразів у формулах"

#. BwEWx
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:456
msgctxt "extended_tip|formulaliteral"
msgid "Specifies that only literal strings are used when searching and also for character string comparisons."
msgstr "Вказує, що під час пошуку використовуються лише буквенні рядки, а також для порівняння рядків символів."

#. XEPCe
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:490
msgctxt "optcalculatepage|label5"
msgid "Formulas Wildcards"
msgstr "Замі́нні знаки формул"

#. p2vT9
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:536
msgctxt "optcalculatepage|iterate"
msgid "_Iterations"
msgstr "_Ітерації"

#. pBKcn
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:544
msgctxt "extended_tip|iterate"
msgid "Specifies whether formulas with iterative references (formulas that are continuously repeated until the problem is solved) are calculated after a specific number of repetitions."
msgstr "Вказує, чи мають обчислюватися формули з циклічними посиланнями (формули, які постійно повторюються до розв'язання задачі) після певного числа повторень."

#. S6iwg
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:573
msgctxt "optcalculatepage|stepsft"
msgid "_Steps:"
msgstr "_Кроки:"

#. aJT9u
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:587
msgctxt "optcalculatepage|minchangeft"
msgid "_Minimum change:"
msgstr "М_інімальна зміна:"

#. GmKgv
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:606
msgctxt "extended_tip|steps"
msgid "Sets the maximum number of iteration steps."
msgstr "Задає найбільше число ітерацій."

#. ZekEF
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:624
msgctxt "extended_tip|minchange"
msgid "Specifies the difference between two consecutive iteration step results. If the result of the iteration is lower than the minimum change value, then the iteration will stop."
msgstr "Вказує різницю між двома послідовними результатами кроків ітерації. Якщо результат кроку ітерації нижчий за значення мінімальної зміни, ітерація зупиниться."

#. UoUqA
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:672
msgctxt "optcalculatepage|label2"
msgid "Iterative References"
msgstr "Циклічні посилання"

#. T2p5k
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:702
msgctxt "optcalculatepage|threadingenabled"
