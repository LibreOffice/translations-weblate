msgctxt "ocRANDARRAY"
msgid "Generates an array of random numbers between two limit values."
msgstr "Генерує масив випадкових чисел між двома граничними значеннями."

#. FkAEX
#: sc/inc/scfuncs.hrc:4242
msgctxt "ocRANDARRAY"
msgid "Rows"
msgstr "Рядків"

#. MAEDm
#: sc/inc/scfuncs.hrc:4243
msgctxt "ocRANDARRAY"
msgid "The number of rows to return."
msgstr "Кількість рядків, які потрібно вивести."

#. KEjFn
#: sc/inc/scfuncs.hrc:4244
msgctxt "ocRANDARRAY"
msgid "Columns"
msgstr "Стовпців"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Кількість стовпців, які потрібно вивести."

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
msgctxt "ocRANDARRAY"
msgid "Min"
msgstr "Мінімум"

#. gEAsz
#: sc/inc/scfuncs.hrc:4247
msgctxt "ocRANDARRAY"
msgid "The lower limit of the generated numbers."
msgstr "Нижня межа згенерованих чисел."

#. zBinA
#: sc/inc/scfuncs.hrc:4248
msgctxt "ocRANDARRAY"
msgid "Max"
msgstr "Максимум"

#. kSq6A
#: sc/inc/scfuncs.hrc:4249
msgctxt "ocRANDARRAY"
msgid "The upper limit of the generated numbers."
msgstr "Верхня межа згенерованих чисел."

#. 3E6Xi
#: sc/inc/scfuncs.hrc:4250
msgctxt "ocRANDARRAY"
msgid "Integers"
msgstr "Цілі числа"

#. RM5HL
#: sc/inc/scfuncs.hrc:4251
msgctxt "ocRANDARRAY"
msgid "Return integer (TRUE) or decimal (FALSE) values."
msgstr "Виводить цілі (TRUE) або десяткові (FALSE) значення."

#. 6xiFb
#: sc/inc/scfuncs.hrc:4257
msgctxt "ocCHOOSECOLS"
msgid "Returns the specified columns from an array."
msgstr "Виводить задані стовпці з масиву."

#. vDNp8
#: sc/inc/scfuncs.hrc:4258
msgctxt "ocCHOOSECOLS"
msgid "Array"
msgstr "Масив"

#. R3koe
#: sc/inc/scfuncs.hrc:4259
msgctxt "ocCHOOSECOLS"
msgid "The array containing the columns to be returned in the new array."
msgstr "Масив, що містить стовпці, які будуть виведені у новому масиві."

#. kZPeA
#: sc/inc/scfuncs.hrc:4260
msgctxt "ocCHOOSECOLS"
msgid "Column "
msgstr "Стовпчик "

#. cwS8A
#: sc/inc/scfuncs.hrc:4261
msgctxt "ocCHOOSECOLS"
msgid "Column 1, Column 2,... The list of column numbers to be returned."
msgstr "Стовпець 1, Cтовпець 2,... Список номерів стовпців, які потрібно вивести."

#. sGgbA
#: sc/inc/scfuncs.hrc:4267
msgctxt "ocCHOOSEROWS"
msgid "Returns the specified rows from an array."
msgstr "Виводить задані рядки з масиву."

#. HkSKg
#: sc/inc/scfuncs.hrc:4268
msgctxt "ocCHOOSEROWS"
msgid "Array"
msgstr "Масив"

#. AL6gZ
#: sc/inc/scfuncs.hrc:4269
msgctxt "ocCHOOSEROWS"
msgid "The array containing the rows to be returned in the new array."
msgstr "Масив, що містить рядки, які потрібно вивести у новому масиві."

#. eMwdB
#: sc/inc/scfuncs.hrc:4270
msgctxt "ocCHOOSEROWS"
msgid "Row "
msgstr "Рядок "

#. z9XmC
#: sc/inc/scfuncs.hrc:4271
msgctxt "ocCHOOSEROWS"
msgid "Row 1, Row 2,... The list of row numbers to be returned."
msgstr "Рядок 1, Рядок 2,... Список номерів рядків, які потрібно вивести."

#. 6uAUo
#: sc/inc/scfuncs.hrc:4277
msgctxt "ocDROP"
msgid "Excludes a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Виключає вказану кількість суміжних рядків або стовпців з початку або кінця масиву."

#. qqDwt
#: sc/inc/scfuncs.hrc:4278
msgctxt "ocDROP"
msgid "Array"
msgstr "Масив"

#. 6hEEw
#: sc/inc/scfuncs.hrc:4279
msgctxt "ocDROP"
msgid "The array from which to drop rows or columns."
msgstr "Масив, з якого потрібно видалити рядки або стовпці."

#. CCEFR
#: sc/inc/scfuncs.hrc:4280
msgctxt "ocDROP"
msgid "Rows"
msgstr "Рядки"

#. 6afd9
#: sc/inc/scfuncs.hrc:4281
msgctxt "ocDROP"
msgid "The number of rows to drop. A negative value drops from the end of the array."
msgstr "Кількість відкинутих рядків. Від'ємне значення відкидається з кінця масиву."

#. 4NBh4
#: sc/inc/scfuncs.hrc:4282
msgctxt "ocDROP"
msgid "Columns"
msgstr "Колонки"

#. Smjhs
#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Кількість стовпців, які потрібно відкинути. Від'ємне значення відкидається з кінця масиву."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Розширює або ущільнює масив до вказаних розмірів рядків і стовпців."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Масив"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "Масив для розширення."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Рядки"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Кількість рядків у розширеному масиві. Якщо значення відсутнє, то рядки не будуть розширюватись."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Колонки"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Кількість стовпців у розширеному масиві. Якщо значення відсутнє, стовпці не будуть розширюватися."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "Вкласти"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "Значення кількості заповнення. Типовим є #N/A."

#. VuRi8
#: sc/inc/scfuncs.hrc:4303
msgctxt "ocHSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr "Додає масиви по горизонталі для створення більшого масиву."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Масив"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Перший масив, який потрібно додати."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Масив 1, Масив 2,... Наступні масиви для додавання. Якщо масив має менше рядків, у додаткових рядках буде видано помилку #N/A."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Додає масиви по вертикалі для створення більшого масиву."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Масив"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Перший масив для додавання."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Масив 1, Масив 2,... Наступні масиви для додавання. Якщо масив має менше стовпців, у додаткових стовпцях буде видано помилку #N/A."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Виводить задану кількість суміжних рядків або стовпців з початку або кінця масиву."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Масив"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "Масив, з якого беруться рядки або стовпці."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Рядки"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Кількість рядків, які потрібно взяти. Від'ємне значення береться з кінця масиву."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Стовпці"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Кількість стовпців, які потрібно взяти. Від'ємне значення береться з кінця масиву."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Виводить текст, що міститься після заданого підрядка або роздільника."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Текст"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "Текст в оригіналі."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Роздільник"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Розділювач. Може бути поставлено кілька роздільників."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Номер позиції"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Позиція роздільника, після якої слід витягувати текст. За замовчуванням 1. Від'ємне число починає пошук з кінця."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Режим співпадіння"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Встановіть значення 1, щоб шукати співпадіння без урахування регістру. За замовчуванням встановлено 0."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Кінець співпадінь"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Встановіть 1, щоб вважати кінець тексту роздільником. За замовчуванням встановлено значення 0."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Якщо не знайдено"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Значення, що повертається, якщо збігів не знайдено. Значення за замовчуванням #N/A."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Виводить текст, який знаходиться перед заданим підрядком або розділювачем."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Текст"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Текст в оригіналі."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Роздільник"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Розділювач. Може бути поставлено кілька роздільників."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Номер позиції"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Позиція роздільника, перед яким потрібно витягти текст. За замовчуванням 1. Від'ємне число починає пошук з кінця."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Режим співпадіння"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Встановіть значення 1, щоб шукати співпадіння без урахування регістру. За замовчуванням встановлено 0."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Кінець співпадінь"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Встановіть 1, щоб вважати кінець тексту роздільником. За замовчуванням встановлено значення 0."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Якщо не знайдено"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Значення, що повертається, якщо збігів не знайдено. Значення за замовчуванням #N/A."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Розділяє текст за заданим роздільником на масив з декількох комірок."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Текст"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "Текст для розділення."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Роздільник стовпців"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "Текст для розділення стовпців. Можна вказати декілька роздільників."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Роздільник рядків"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "Текст для розділення рядків. Можна вказати декілька роздільників."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Ігнорувати порожні"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Встановіть значення TRUE, щоб ігнорувати послідовні роздільники, інакше створюється порожня комірка. Типово встановлено значення FALSE."

#. AUSmr
#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Режим співпадіння"

#. pjYxd
#: sc/inc/scfuncs.hrc:4381
msgctxt "ocTEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Встановіть значення 1, щоб шукати співпадіння без урахування регістру. За замовчуванням встановлено 0."

#. LsoKk
#: sc/inc/scfuncs.hrc:4382
msgctxt "ocTEXTSPLIT"
msgid "Pad with"
msgstr "Вкласти"

#. niX3W
#: sc/inc/scfuncs.hrc:4383
msgctxt "ocTEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "Значення кількості заповнення. Типовим є #N/A."

#. dv6gP
#: sc/inc/scfuncs.hrc:4389
msgctxt "ocTOCOL"
msgid "Transforms an array into a single column."
msgstr "Перетворює масив на один стовпець."

#. A9zBS
#: sc/inc/scfuncs.hrc:4390
msgctxt "ocTOCOL"
msgid "Array"
msgstr "Масив"

#. x95Ef
#: sc/inc/scfuncs.hrc:4391
msgctxt "ocTOCOL"
msgid "The range or array to return as a single column."
msgstr "Діапазон або масив, який потрібно вивести у вигляді одного стовпця."

#. weBya
#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Ігнорувати"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Чи ігнорувати певні типи значень. 0 або пропущено - зберігати всі значення (типово). 1 - ігнорувати порожні комірки. 2 - ігнорувати комірки з помилками. 3 - ігнорувати порожні комірки та комірки з помилками."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Переглядати за рядками"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Переглядати масив за стовпцями. FALSE або пропущено (типове) – масив переглядається за рядками. TRUE – масив переглядається за стовпцями."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "перетворює масив в один рядок."

#. GAbkQ
#: sc/inc/scfuncs.hrc:4402
msgctxt "ocTOROW"
msgid "Array"
msgstr "Масив"

#. w7WXB
#: sc/inc/scfuncs.hrc:4403
msgctxt "ocTOROW"
msgid "The range or array to return as a single row."
msgstr "Діапазон або масив, який потрібно вивести у вигляді одного рядка."

#. GCfA2
#: sc/inc/scfuncs.hrc:4404
msgctxt "ocTOROW"
msgid "Ignore"
msgstr "Знехтувати"

#. AnEDD
#: sc/inc/scfuncs.hrc:4405
msgctxt "ocTOROW"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Чи ігнорувати певні типи значень. 0 або пропущено - зберігати всі значення (типово). 1 - ігнорувати порожні комірки. 2 - ігнорувати комірки з помилками. 3 - ігнорувати порожні комірки та комірки з помилками."

#. pDD7V
#: sc/inc/scfuncs.hrc:4406
msgctxt "ocTOROW"
msgid "Scan by column"
msgstr "Переглядати за стовпцями"

#. qxY7a
#: sc/inc/scfuncs.hrc:4407
msgctxt "ocTOROW"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Переглядати масив за стовпцями. FALSE або пропущено (типове) – масив переглядається за рядками. TRUE – масив переглядається за стовпцями."

#. 8p5AW
#: sc/inc/scfuncs.hrc:4413
msgctxt "ocUNIQUE"
msgid "Returns a list of unique values from a range or array."
msgstr "Виводить список унікальних значень з діапазону або масиву."

#. LAeWQ
#: sc/inc/scfuncs.hrc:4414
msgctxt "ocUNIQUE"
msgid "Array"
msgstr "Масив"

#. LHrXJ
#: sc/inc/scfuncs.hrc:4415
msgctxt "ocUNIQUE"
msgid "The range or array from which to return unique values."
msgstr "Діапазон або масив, з якого потрібно отримати унікальні значення."

#. TBfHR
#: sc/inc/scfuncs.hrc:4416
msgctxt "ocUNIQUE"
msgid "By col"
msgstr "За стовп"

#. xiVEn
#: sc/inc/scfuncs.hrc:4417
msgctxt "ocUNIQUE"
msgid "Logical value indicating how to compare data: TRUE - compares data across columns. FALSE or omitted (default) - compares data across rows."
msgstr "Логічне значення, що вказує на спосіб порівняння даних: TRUE - порівнює дані по стовпчиках. FALSE або пропущено (типово) - порівнює дані по рядках."

#. GLsJf
#: sc/inc/scfuncs.hrc:4418
msgctxt "ocUNIQUE"
msgid "Uniqueness"
msgstr "Унікальність"

#. ubRgX
#: sc/inc/scfuncs.hrc:4419
msgctxt "ocUNIQUE"
msgid "Logical value that defines what values are considered unique: TRUE - returns values that occur only once. FALSE or omitted (default) - returns all distinct (different) values in the range or array."
msgstr "Логічне значення, що вказує, які значення вважати унікальними: TRUE - повертає значення, що зустрічаються лише один раз. FALSE або пропущено (типово) - виводить всі відмінні (різні) значення в діапазоні або масиві."

#. 5Aaqr
#: sc/inc/scfuncs.hrc:4425
msgctxt "ocLET"
msgid "The LET function assigns names to calculation results. This allows storing intermediate calculations, values, or defining names inside a formula. These names only apply within the scope of the LET function."
msgstr "Функція LET присвоює імена результатам обчислень. Це дозволяє зберігати проміжні обчислення, значення або задавати імена всередині формули. Ці імена застосовуються лише в межах області видимості функції LET."

#. GTBCS
#: sc/inc/scfuncs.hrc:4426
msgctxt "ocLET"
msgid "Name 1"
msgstr "Назва 1"

#. BXEhz
#: sc/inc/scfuncs.hrc:4427
msgctxt "ocLET"
msgid "The first name to assign. Must start with a letter. Cannot be the output of a formula or conflict with range syntax."
msgstr "Назва, яку потрібно призначити. Має починатися з літери. Не може бути виведенням формули або конфліктувати з синтаксисом діапазону."

#. agD98
#: sc/inc/scfuncs.hrc:4428
msgctxt "ocLET"
msgid "Name value "
msgstr "Значення на́зви "

#. CjEiH
#: sc/inc/scfuncs.hrc:4429
msgctxt "ocLET"
msgid "Name value 1, Name value 2,... The value or calculation to assign to Name."
msgstr "Значення на́зви 1, Значення на́зви 2,... Значення або формула, виражена Назвою."

#. GCAQK
#: sc/inc/scfuncs.hrc:4430
msgctxt "ocLET"
msgid "Calculation or Name "
msgstr "Розрахунок або Назва "

#. uzEFm
#: sc/inc/scfuncs.hrc:4431
msgctxt "ocLET"
msgid "A calculation that uses all names within the LET function. This must be the last argument in the LET function. Or a second Name to assign to a second Name value. If a second Name is specified, Name value 2 and Calculation or Name 3 become required."
msgstr "Розрахунок, який використовує всі назви у функції LET. Це має бути останній аргумент у функції LET або друга Назва для присвоєння другому значенню Назви. Якщо вказана друга Назва, Назва значення 2 і Розрахунок або Назва 3 стають обов'язковими."

#. HbPvG
#: sc/inc/scfuncs.hrc:4437
msgctxt "ocWRAPCOLS"
msgid "Wraps the provided row or column of values by columns after a specified number of elements to form a new array."
msgstr "Обертає наданий рядок або стовпець значень по стовпцях після вказаної кількості елементів, утворюючи новий масив."

