#. q6FLc
#: sc/inc/scfuncs.hrc:3393
msgctxt "ocX_LOOKUP"
msgid ""
"0 - Exact match. Will return #N/A if no match. (default).\n"
"-1 - Exact match or the next smaller item.\n"
"1 - Exact match or the next larger item.\n"
"2 - Wildcard match.\n"
"3 - Regular expression match."
msgstr ""
"0 - Ekzakta kongruo. Liveros je #N/A se mankas kongruo. (defaŭlta).\n"
"-1 - Ekzakta kongruo aŭ la sekva pli malgranda ero.\n"
"1 - Ekzakta kongruo aŭ la sekva pli granda ero.\n"
"2 - Ĵokera kongruo.\n"
"3 - Regulesprima kongruo."

#. peAXD
