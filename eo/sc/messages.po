#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Malatenti"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Ĉu malatenti certajn tipojn da valoroj. 0 aŭ ellasita - konservi ĉiujn valorojn (defaŭlto). 1 - malatenti vakajn ĉelojn. 2 - malatenti ĉelojn kun eraro. 3 - malatenti vakajn ĉelojn kaj ĉelojn kun eraro."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Skani laŭ kolumno"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Skani la tabelon laŭ kolumno. FALSA aŭ ellasita (defaŭlto) - skani la tabelon laŭ vico. VERA - skani la tabelon laŭ kolumno."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "transformas tabelon en unuopan vicon."

