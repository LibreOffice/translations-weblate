msgstr "A 0 érték 1904. 01. 01.-nek felel meg"

#. aEwAF
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:345
msgctxt "extended_tip|date1904"
msgid "Sets 1904-01-01 as day zero. Use this setting for spreadsheets that are imported in a foreign format."
msgstr "1900. 01. 01. beállítása 0. napként. Az idegen formátumokból importált munkafüzetekhez használja ezt a beállítást."

#. ggkEL
