msgctxt "optcalculatepage|iterate"
msgid "_Iterations"
msgstr "_Iterációk"

#. pBKcn
#: sc/uiconfig/scalc/ui/optcalculatepage.ui:544
msgctxt "extended_tip|iterate"
msgid "Specifies whether formulas with iterative references (formulas that are continuously repeated until the problem is solved) are calculated after a specific number of repetitions."
msgstr "Megadja, hogy az iteratív hivatkozást tartalmazó képletek (olyan képletek melyek a feladat megoldásáig folyamatosan ismétlődnek) a megadott számú ismétlődés után kiszámításra kerüljenek-e."

#. S6iwg
