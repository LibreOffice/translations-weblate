msgctxt "ocDDE"
msgid "Server"
msgstr "Сервер"

#. DenN4
#: sc/inc/scfuncs.hrc:3509
msgctxt "ocDDE"
msgid "The name of the server application."
msgstr "Имя серверного приложения."

#. EGEFS
