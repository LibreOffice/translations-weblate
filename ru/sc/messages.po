msgstr ""

#. E5zgi
#: sc/inc/scfuncs.hrc:3469
msgctxt "ocOFFSET"
msgid "The number of columns that are to be moved to the left or to the right."
msgstr "Число столбцов смещения (допустимо отрицательное)."

#. 4gwK6
#: sc/inc/scfuncs.hrc:3470
msgctxt "ocOFFSET"
msgid "Height"
msgstr "Высота"

#. BCFK9
#: sc/inc/scfuncs.hrc:3471
msgctxt "ocOFFSET"
msgid "The number of rows of the moved reference."
msgstr "Высота нового диапазона, в строках."

#. STFTf
#: sc/inc/scfuncs.hrc:3472
msgctxt "ocOFFSET"
msgid "Width"
msgstr "Ширина"

#. Szh27
#: sc/inc/scfuncs.hrc:3473
msgctxt "ocOFFSET"
msgid "The number of columns in the moved reference."
msgstr "Ширина нового диапазона, в столбцах."

#. h4prK
#: sc/inc/scfuncs.hrc:3479
msgctxt "ocERROR_TYPE"
msgid "Returns a number corresponding to an error type"
msgstr "Возвращает значение, соответствующее типу ошибки"

#. zTcGJ
#: sc/inc/scfuncs.hrc:3480
msgctxt "ocERROR_TYPE"
msgid "Reference"
msgstr "Ссылка"

#. gBFcu
#: sc/inc/scfuncs.hrc:3481
msgctxt "ocERROR_TYPE"
msgid "The reference (cell) in which the error occurred."
msgstr "Ссылка (ячейка), в которой произошла ошибка."

#. NsBmR
#: sc/inc/scfuncs.hrc:3487
msgctxt "ocERROR_TYPE_ODF"
msgid "Returns a number corresponding to one of the error values or #N/A if no error exists"
msgstr "Возвращает число, соответствующее значению ошибки, либо #Н/Д, если ошибка не существует"

#. qcBjy
#: sc/inc/scfuncs.hrc:3488
msgctxt "ocERROR_TYPE_ODF"
msgid "Expression"
msgstr "Выражение"

#. F65VK
#: sc/inc/scfuncs.hrc:3489
msgctxt "ocERROR_TYPE_ODF"
msgid "The error value whose identifying number you want to find. Can be the actual error value or a reference to a cell that you want to test."
msgstr "Значение ошибки, числовое значение которой необходимо получить. Может быть актуальным значением ошибки или ссылкой на проверяемую ячейку."

#. QGUdC
#: sc/inc/scfuncs.hrc:3495
msgctxt "ocSTYLE"
msgid "Applies a Style to the formula cell."
msgstr "Устанавливает стиль для ячейки, содержащей формулу."

#. g7u6Y
#: sc/inc/scfuncs.hrc:3496
msgctxt "ocSTYLE"
msgid "Style"
msgstr ""

#. Pcugk
#: sc/inc/scfuncs.hrc:3497
msgctxt "ocSTYLE"
msgid "The name of the Style to be applied."
msgstr "Имя применяемого стиля."

#. JG7MT
#: sc/inc/scfuncs.hrc:3498
msgctxt "ocSTYLE"
msgid "Time"
msgstr "Время"

#. o5m9E
#: sc/inc/scfuncs.hrc:3499
msgctxt "ocSTYLE"
msgid "The time (in seconds) that the Style is to remain valid."
msgstr "Время (в секундах), в течение которого стиль остаётся действительным."

#. xpPpG
#: sc/inc/scfuncs.hrc:3500
msgctxt "ocSTYLE"
msgid "Style 2"
msgstr ""

#. CTqYM
#: sc/inc/scfuncs.hrc:3501
msgctxt "ocSTYLE"
msgid "The style to be applied after time expires."
msgstr "Стиль, который будет применён по истечении указанного времени."

#. KxFY2
