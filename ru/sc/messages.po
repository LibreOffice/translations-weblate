msgctxt "ocDDE"
msgid "Topic/file"
msgstr "Тема/файл"

#. bHNno
#: sc/inc/scfuncs.hrc:3511
msgctxt "ocDDE"
msgid "The topic or name of the file."
msgstr "Тема или имя файла."

#. Rt3Zy
#: sc/inc/scfuncs.hrc:3512
msgctxt "ocDDE"
msgid "Item/range"
msgstr "Элемент/диапазон"

#. 4ZAip
#: sc/inc/scfuncs.hrc:3513
msgctxt "ocDDE"
msgid "The item or range from which data is to be taken."
