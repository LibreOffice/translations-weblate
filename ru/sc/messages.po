#. jeVzN
#: sc/inc/scfuncs.hrc:3333
msgctxt "ocCOLUMNS"
msgid "The array (reference) for which the number of columns is to be determined."
msgstr "Массив (ссылка), в котором определяется количество столбцов."

#. DDyGE
#: sc/inc/scfuncs.hrc:3339
msgctxt "ocROWS"
msgid "Returns the number of rows in a reference or array."
msgstr "Вычисляет количество строк в соответствующем массиве."

#. w6tRD
#: sc/inc/scfuncs.hrc:3340
msgctxt "ocROWS"
msgid "Array"
msgstr "Массив"

#. jfAh6
#: sc/inc/scfuncs.hrc:3341
msgctxt "ocROWS"
msgid "The array (reference) for which the number of rows is to be determined."
msgstr "Массив (ссылка), для которого определяется число строк."

#. WY6fW
#: sc/inc/scfuncs.hrc:3347
msgctxt "ocSHEETS"
msgid "Returns the number of sheets of a given reference. If no parameter has been entered, the total number of sheets in the document is returned."
msgstr "Вычисляет количество листов в ссылке. Если не ввести этот параметр, то функция возвращает количество листов текущего документа."

#. sGMjy
#: sc/inc/scfuncs.hrc:3348
msgctxt "ocSHEETS"
msgid "Reference"
msgstr "Ссылка"

#. pE7cV
#: sc/inc/scfuncs.hrc:3349
msgctxt "ocSHEETS"
msgid "The reference to a cell or a range."
msgstr "Ссылка на ячейку или диапазон."

#. HDpaB
#: sc/inc/scfuncs.hrc:3355
msgctxt "ocH_LOOKUP"
msgid "Horizontal search and reference to the cells located below."
msgstr "Ищет значение в строках и выбирает найденное значение."

#. zdCJU
#: sc/inc/scfuncs.hrc:3356
msgctxt "ocH_LOOKUP"
msgid "Search criterion"
msgstr "Критерий поиска"

#. Dxdmt
#: sc/inc/scfuncs.hrc:3357
msgctxt "ocH_LOOKUP"
msgid "The value to be found in the first row."
msgstr "Значение, которое требуется найти в первой строке таблицы."

#. h2uF4
#: sc/inc/scfuncs.hrc:3358
msgctxt "ocH_LOOKUP"
msgid "Array"
msgstr "Массив"

#. 2Eh2T
#: sc/inc/scfuncs.hrc:3359
msgctxt "ocH_LOOKUP"
msgid "The array or the range for the reference."
msgstr "Массив или диапазон для ссылки."

#. sZVjU
#: sc/inc/scfuncs.hrc:3360
msgctxt "ocH_LOOKUP"
msgid "Index"
msgstr "Индекс"

#. yW8Mk
#: sc/inc/scfuncs.hrc:3361
msgctxt "ocH_LOOKUP"
msgid "The row index in the array."
msgstr "Индекс строки в массиве."

#. DoWac
#: sc/inc/scfuncs.hrc:3362
msgctxt "ocH_LOOKUP"
msgid "Sorted range lookup"
msgstr "Сортированный диапазон поиска"

#. zmBsJ
#: sc/inc/scfuncs.hrc:3363
msgctxt "ocH_LOOKUP"
msgid "If the value is TRUE or not given, the search row of the array represents a series of ranges, and must be sorted in ascending order."
msgstr "Если значение ИСТИНА или не указано, строка поиска в массиве представляет собой последовательность диапазонов и должна быть отсортирована в порядке возрастания."

#. siCjd
#: sc/inc/scfuncs.hrc:3369
msgctxt "ocV_LOOKUP"
msgid "Vertical search and reference to indicated cells."
msgstr "Поиск в таблице по вертикали."

#. RBGAP
#: sc/inc/scfuncs.hrc:3370
msgctxt "ocV_LOOKUP"
msgid "Search criterion"
msgstr "Критерий поиска"

#. 36Fus
#: sc/inc/scfuncs.hrc:3371
msgctxt "ocV_LOOKUP"
msgid "The value to be found in the first column."
msgstr "Значение, которое необходимо найти в первом столбце."

#. 4YE5g
#: sc/inc/scfuncs.hrc:3372
msgctxt "ocV_LOOKUP"
msgid "Array"
msgstr "Массив"

#. GNBYQ
#: sc/inc/scfuncs.hrc:3373
msgctxt "ocV_LOOKUP"
msgid "The array or range for referencing."
msgstr "Массив или диапазон для ссылки."

#. FzFuG
#: sc/inc/scfuncs.hrc:3374
msgctxt "ocV_LOOKUP"
msgid "Index"
msgstr "Индекс"

#. bbGH5
#: sc/inc/scfuncs.hrc:3375
msgctxt "ocV_LOOKUP"
msgid "Column index number in the array."
msgstr "Индекс столбца в массиве."

#. 69ZMK
#: sc/inc/scfuncs.hrc:3376
msgctxt "ocV_LOOKUP"
msgid "Sorted range lookup"
msgstr "Сортированный диапазон поиска"

#. Tvcub
#: sc/inc/scfuncs.hrc:3377
msgctxt "ocV_LOOKUP"
msgid "If the value is TRUE or not given, the search column of the array represents a series of ranges, and must be sorted in ascending order."
msgstr "Если значение ИСТИНА или не задано, столбец поиска в массиве представляет собой последовательность диапазонов и должен быть отсортирован в порядке возрастания."

#. t6g9j
#: sc/inc/scfuncs.hrc:3383
msgctxt "ocX_LOOKUP"
msgid "Extended vertical search and reference to indicated cells."
msgstr "Расширенный поиск в таблице по вертикали."

#. gGKPL
#: sc/inc/scfuncs.hrc:3384
msgctxt "ocX_LOOKUP"
msgid "Search criterion"
msgstr "Критерий поиска"

#. G5GFh
#: sc/inc/scfuncs.hrc:3385
msgctxt "ocX_LOOKUP"
msgid "The value to be found in the first column."
msgstr "Значение, которое необходимо найти в первом столбце."

#. B4aE3
#: sc/inc/scfuncs.hrc:3386
msgctxt "ocX_LOOKUP"
msgid "Search Array"
msgstr "Массив поиска"

#. mwst8
#: sc/inc/scfuncs.hrc:3387
msgctxt "ocX_LOOKUP"
msgid "The array or range to search."
msgstr "Массив или диапазон для поиска."

#. hkB5Z
#: sc/inc/scfuncs.hrc:3388
msgctxt "ocX_LOOKUP"
msgid "Result Array"
msgstr "Массив результатов"

#. fAPwy
#: sc/inc/scfuncs.hrc:3389
msgctxt "ocX_LOOKUP"
msgid "The array or range to return."
msgstr "Массив или диапазон для возврата."

#. CnsvV
#: sc/inc/scfuncs.hrc:3390
msgctxt "ocX_LOOKUP"
msgid "Result if not found"
msgstr "Результат, если не найдено"

#. 6mbNe
#: sc/inc/scfuncs.hrc:3391
msgctxt "ocX_LOOKUP"
msgid "If given, return given text, otherwise return #N/A."
msgstr "Если задано, возвращает указанный текст, в ином случае — #Н/Д."

#. zA7NF
#: sc/inc/scfuncs.hrc:3392
msgctxt "ocX_LOOKUP"
msgid "Match Mode"
msgstr "Режим сопоставления"

#. q6FLc
#: sc/inc/scfuncs.hrc:3393
msgctxt "ocX_LOOKUP"
msgid ""
"0 - Exact match. Will return #N/A if no match. (default).\n"
"-1 - Exact match or the next smaller item.\n"
"1 - Exact match or the next larger item.\n"
"2 - Wildcard match.\n"
"3 - Regular expression match."
msgstr ""
"0 — точное совпадение. Если совпадения нет, вернёт #Н/Д. (по умолчанию).\n"
"-1 — точное совпадение или следующий меньший элемент.\n"
"1 — точное совпадение или следующий больший элемент.\n"
"2 — совпадение с подстановочным знаком.\n"
"3 — совпадение с регулярным выражением."

#. peAXD
#: sc/inc/scfuncs.hrc:3394
msgctxt "ocX_LOOKUP"
msgid "Search Mode"
msgstr "Режим поиска"

#. VcnxV
#: sc/inc/scfuncs.hrc:3395
msgctxt "ocX_LOOKUP"
msgid ""
"1 - Search from the first value (default).\n"
"-1 - Search from the last value (reverse).\n"
"2 - Binary search values sorted in ascending order.\n"
"-2 - Binary search values sorted in descending order."
msgstr ""
"1 — поиск с первого значения (по умолчанию).\n"
"-1 — поиск с последнего значения (в обратном порядке).\n"
"2 — бинарный поиск значений, отсортированных по возрастанию.\n"
"-2 — бинарный поиск значений, отсортированных по убыванию."

#. vXvZf
#: sc/inc/scfuncs.hrc:3401
msgctxt "ocINDEX"
msgid "Returns a reference to a cell from a defined range."
msgstr "Возвращает содержимое ячейки из заданного диапазона."

#. EGfDu
#: sc/inc/scfuncs.hrc:3402
msgctxt "ocINDEX"
msgid "Reference"
msgstr "Ссылка"

#. JStZ5
#: sc/inc/scfuncs.hrc:3403
msgctxt "ocINDEX"
msgid "The reference to a (multiple) range."
msgstr "Ссылка на один или несколько диапазонов."

#. SFmQb
#: sc/inc/scfuncs.hrc:3404
msgctxt "ocINDEX"
msgid "Row"
msgstr "Строка"

#. G2hSC
#: sc/inc/scfuncs.hrc:3405
msgctxt "ocINDEX"
msgid "The row in the range."
msgstr "Строка в диапазоне."

#. XwfZ5
#: sc/inc/scfuncs.hrc:3406
msgctxt "ocINDEX"
msgid "Column"
msgstr "Столбец"

#. VAwV4
#: sc/inc/scfuncs.hrc:3407
msgctxt "ocINDEX"
msgid "The column in the range."
msgstr "Столбец в диапазоне."

#. SHKDQ
#: sc/inc/scfuncs.hrc:3408
msgctxt "ocINDEX"
msgid "Range"
msgstr "Диапазон"

#. j5wAA
#: sc/inc/scfuncs.hrc:3409
msgctxt "ocINDEX"
msgid "The index of the subrange if referring to a multiple range."
msgstr "Индекс одного диапазона, в случае, если речь идёт о нескольких диапазонах."

#. Egc6S
#: sc/inc/scfuncs.hrc:3415
msgctxt "ocINDIRECT"
msgid "Returns the contents of a cell that is referenced in text form."
msgstr "Возвращает содержимое ссылки, установленное текстовым значением."

#. CkZ4D
#: sc/inc/scfuncs.hrc:3416
msgctxt "ocINDIRECT"
msgid "Reference"
msgstr "Ссылка"

#. Y8hMr
#: sc/inc/scfuncs.hrc:3417
msgctxt "ocINDIRECT"
msgid "The cell whose contents are to be evaluated is to be referenced in text form (e.g. \"A1\")."
msgstr "Ссылка на ячейку, содержимое которой должно интерпретироваться как ссылка в виде текста, напр. «A1»."

#. CuXX5
#: sc/inc/scfuncs.hrc:3418
msgctxt "ocINDIRECT"
msgid "A1"
msgstr "A1"

#. CBEAT
#: sc/inc/scfuncs.hrc:3419
msgctxt "ocINDIRECT"
msgid "The reference style: 0 or FALSE means R1C1 style, any other value or omitted means A1 style."
msgstr "Стиль ссылки: 0 или Ложь означает стиль R1C1, любое другое значение или не указано — стиль A1."

#. hxmjd
#: sc/inc/scfuncs.hrc:3425
msgctxt "ocLOOKUP"
msgid "Determines a value in a vector by comparison to values in another vector."
msgstr "Вычисляет содержимое ячейки или однострочного или одностолбцового массива."

#. H43GU
#: sc/inc/scfuncs.hrc:3426
msgctxt "ocLOOKUP"
msgid "Search criterion"
msgstr "Критерий поиска"

#. 77pzS
#: sc/inc/scfuncs.hrc:3427
msgctxt "ocLOOKUP"
msgid "The value to be used for comparison."
msgstr "Значение, с которым следует сравнить."

#. LoFoB
#: sc/inc/scfuncs.hrc:3428
msgctxt "ocLOOKUP"
msgid "Search vector"
msgstr "Вектор просмотра"

#. XBDqm
#: sc/inc/scfuncs.hrc:3429
msgctxt "ocLOOKUP"
msgid "The vector (row or column) in which to search."
msgstr "Вектор (строка или столбец), в котором следует искать."

#. K5uBH
#: sc/inc/scfuncs.hrc:3430
msgctxt "ocLOOKUP"
msgid "Result vector"
msgstr "Результирующий вектор"

#. ajy2a
#: sc/inc/scfuncs.hrc:3431
msgctxt "ocLOOKUP"
msgid "The vector (row or range) from which the value is to be determined."
msgstr "Вектор (строка или диапазон), из которого определяется значение."

#. DB4G3
#: sc/inc/scfuncs.hrc:3437
msgctxt "ocMATCH"
msgid "Defines a position in an array after comparing values."
msgstr "Определяет относительное расположение элемента в массиве по условию."

#. cxhCr
#: sc/inc/scfuncs.hrc:3438
msgctxt "ocMATCH"
msgid "Search criterion"
msgstr "Критерий поиска"

#. D3YCq
#: sc/inc/scfuncs.hrc:3439
msgctxt "ocMATCH"
msgid "The value to be used for comparison."
msgstr "Значение, с которым следует сравнить."

#. RS363
#: sc/inc/scfuncs.hrc:3440
msgctxt "ocMATCH"
msgid "Lookup array"
msgstr "Массив"

#. Ftk2C
#: sc/inc/scfuncs.hrc:3441
msgctxt "ocMATCH"
msgid "The array (range) in which the search is made."
msgstr "Массив (диапазон), в котором следует искать."

#. qApjD
#: sc/inc/scfuncs.hrc:3442
msgctxt "ocMATCH"
msgid "Type"
msgstr "Тип"

#. 4q5AC
#: sc/inc/scfuncs.hrc:3443
msgctxt "ocMATCH"
msgid "Type can take the value 1 (first column array ascending), 0 (exact match or wildcard or regular expression match) or -1 (first column array descending) and determines the criteria to be used for comparison purposes."
msgstr "Тип может принимать значение 1 (возрастание массива первого столбца), 0 (точное совпадение или подстановочный знак или совпадение с регулярным выражением) или -1 (убывание массива первого столбца) и определяет критерии, которые будут использоваться для целей сравнения."

#. v7KYE
#: sc/inc/scfuncs.hrc:3449
msgctxt "ocX_MATCH"
msgid "Defines a relative position in an array or range of cells after comparing values."
msgstr "Определяет относительное расположение элемента в массиве или диапазоне ячеек после сравнения значений."

#. qQMFy
#: sc/inc/scfuncs.hrc:3450
msgctxt "ocX_MATCH"
msgid "Search criterion"
msgstr "Критерий поиска"

#. F5utc
#: sc/inc/scfuncs.hrc:3451
msgctxt "ocX_MATCH"
msgid "The value to be used for comparison."
msgstr "Значение, с которым следует сравнить."

#. Ac7kz
#: sc/inc/scfuncs.hrc:3452
msgctxt "ocX_MATCH"
msgid "Search Array"
msgstr "Массив поиска"

#. jdnmq
#: sc/inc/scfuncs.hrc:3453
msgctxt "ocX_MATCH"
msgid "The array or range to search."
msgstr "Массив или диапазон для поиска."

#. DQBR3
#: sc/inc/scfuncs.hrc:3454
msgctxt "ocX_MATCH"
msgid "Match Mode"
msgstr "Режим сопоставления"

#. FMDoP
#: sc/inc/scfuncs.hrc:3455
msgctxt "ocX_MATCH"
msgid ""
"0 - Exact match. Will return #N/A if no match. (default).\n"
"-1 - Exact match or the next smaller item.\n"
"1 - Exact match or the next larger item.\n"
"2 - Wildcard match.\n"
"3 - Regular expression match."
msgstr ""
"0 — точное совпадение. Если совпадения нет, вернёт #Н/Д. (по умолчанию).\n"
