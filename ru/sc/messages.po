msgstr "Индекс сортировки"

#. DuQFW
#: sc/inc/scfuncs.hrc:4205
msgctxt "ocSORT"
msgid "A number indicating the row or column to sort by."
msgstr "Число, обозначающее строку или столбец, по которому будет выполняться сортировка."

#. BK4XX
#: sc/inc/scfuncs.hrc:4206
msgctxt "ocSORT"
msgid "Sort order"
msgstr "Порядок сортировки"

#. zFBzs
#: sc/inc/scfuncs.hrc:4207
msgctxt "ocSORT"
msgid "A number indicating the desired sort order; 1 for ascending order (default), -1 for descending order."
msgstr "Число, обозначающее нужный порядок сортировки; 1 — по возрастанию (по умолчанию), -1 — по убыванию."

#. ResTu
#: sc/inc/scfuncs.hrc:4208
msgctxt "ocSORT"
msgid "By col"
msgstr "По стлб"

#. DwWWz
#: sc/inc/scfuncs.hrc:4209
msgctxt "ocSORT"
msgid "A logical value indicating the desired sort direction; FALSE to sort by row (default), TRUE to sort by column."
msgstr "Логическое значение, обозначающее нужное направление сортировки; Ложь — сортировка по строкам (по умолчанию), Истина — сортировка по столбцам."

#. UEqVF
#: sc/inc/scfuncs.hrc:4215
msgctxt "ocSORTBY"
msgid "Sorts the contents of a range or array based on the values in a corresponding range or array."
msgstr "Сортирует содержимое диапазона или массива на основе значений в соответствующем диапазоне или массиве."

#. Htvdm
#: sc/inc/scfuncs.hrc:4216
msgctxt "ocSORTBY"
msgid "Sort range"
msgstr "Диапазон сортировки"

#. EWvvS
#: sc/inc/scfuncs.hrc:4217
msgctxt "ocSORTBY"
msgid "The array or range to sort."
msgstr "Массив или диапазон для сортировки."

#. yh5AE
#: sc/inc/scfuncs.hrc:4218
msgctxt "ocSORTBY"
msgid "Sort by range "
msgstr "Сортировка по диапазону "

#. g2AAw
#: sc/inc/scfuncs.hrc:4219
msgctxt "ocSORTBY"
msgid "Range 1, range 2,... are the arrays or ranges to sort on."
msgstr "Диапазон 1; диапазон 2; … массивы или диапазоны, по которым выполняется сортировка."

#. Hxhru
#: sc/inc/scfuncs.hrc:4220
msgctxt "ocSORTBY"
msgid "Sort order "
msgstr "Порядок сортировки "

#. qWxek
#: sc/inc/scfuncs.hrc:4221
msgctxt "ocSORTBY"
msgid "Order 1, order 2,... are the orders to use for sorting. 1 for ascending, -1 for descending. Default is ascending."
msgstr "Порядок 1; порядок 2; … — порядки для использования при сортировке. 1 — восходящий, -1 — нисходящий. По умолчанию используется восходящий порядок."

#. Js6Dj
#: sc/inc/scfuncs.hrc:4227
msgctxt "ocMAT_SEQUENCE"
msgid "Generates a list of sequential numbers in an array, such as 1, 2, 3, 4."
msgstr "Создаёт список чисел в массиве. Например: 1, 2, 3, 4."

#. QBMEL
#: sc/inc/scfuncs.hrc:4228
msgctxt "ocMAT_SEQUENCE"
msgid "Rows"
msgstr "Строки"

#. QJTBL
#: sc/inc/scfuncs.hrc:4229
msgctxt "ocMAT_SEQUENCE"
msgid "The number of rows to return."
msgstr "Количество строк для возврата."

#. GEC8c
#: sc/inc/scfuncs.hrc:4230
msgctxt "ocMAT_SEQUENCE"
msgid "Columns"
msgstr "Столбцы"

#. fhnFH
#: sc/inc/scfuncs.hrc:4231
msgctxt "ocMAT_SEQUENCE"
msgid "The number of columns to return."
msgstr "Количество столбцов для возврата."

#. kWPVy
#: sc/inc/scfuncs.hrc:4232
msgctxt "ocMAT_SEQUENCE"
msgid "Start"
msgstr "Начало"

#. dCwre
#: sc/inc/scfuncs.hrc:4233
msgctxt "ocMAT_SEQUENCE"
msgid "The first number in the sequence."
msgstr "Первое число в последовательности."

#. Vuu2D
#: sc/inc/scfuncs.hrc:4234
msgctxt "ocMAT_SEQUENCE"
msgid "Step"
msgstr "Шаг"

#. usMFD
#: sc/inc/scfuncs.hrc:4235
msgctxt "ocMAT_SEQUENCE"
msgid "The amount to increment each subsequent value in the array."
msgstr "Значение приращения каждого последующего значения в массиве."

#. LbVEK
#: sc/inc/scfuncs.hrc:4241
msgctxt "ocRANDARRAY"
msgid "Generates an array of random numbers between two limit values."
msgstr "Создаёт массив случайных чисел между двумя предельными значениями."

#. FkAEX
#: sc/inc/scfuncs.hrc:4242
msgctxt "ocRANDARRAY"
msgid "Rows"
msgstr "Строки"

#. MAEDm
#: sc/inc/scfuncs.hrc:4243
msgctxt "ocRANDARRAY"
msgid "The number of rows to return."
msgstr "Количество строк для возврата."

#. KEjFn
#: sc/inc/scfuncs.hrc:4244
msgctxt "ocRANDARRAY"
msgid "Columns"
msgstr "Столбцы"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Количество столбцов для возврата."

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
msgctxt "ocRANDARRAY"
msgid "Min"
msgstr "Минимум"

#. gEAsz
#: sc/inc/scfuncs.hrc:4247
msgctxt "ocRANDARRAY"
msgid "The lower limit of the generated numbers."
msgstr "Нижний предел для создаваемых чисел."

#. zBinA
#: sc/inc/scfuncs.hrc:4248
msgctxt "ocRANDARRAY"
msgid "Max"
msgstr "Максимум"

#. kSq6A
#: sc/inc/scfuncs.hrc:4249
msgctxt "ocRANDARRAY"
msgid "The upper limit of the generated numbers."
msgstr "Верхний предел для создаваемых чисел."

#. 3E6Xi
#: sc/inc/scfuncs.hrc:4250
msgctxt "ocRANDARRAY"
msgid "Integers"
msgstr "Целые числа"

#. RM5HL
#: sc/inc/scfuncs.hrc:4251
msgctxt "ocRANDARRAY"
msgid "Return integer (TRUE) or decimal (FALSE) values."
msgstr "Возвращает целые (Истина) или десятичные (Ложь) значения."

#. 6xiFb
#: sc/inc/scfuncs.hrc:4257
msgctxt "ocCHOOSECOLS"
msgid "Returns the specified columns from an array."
msgstr "Возвращает указанные столбцы из массива."

#. vDNp8
#: sc/inc/scfuncs.hrc:4258
msgctxt "ocCHOOSECOLS"
msgid "Array"
msgstr "Массив"

#. R3koe
#: sc/inc/scfuncs.hrc:4259
msgctxt "ocCHOOSECOLS"
msgid "The array containing the columns to be returned in the new array."
msgstr "Массив, содержащий столбцы для возвращения в новый массив."

#. kZPeA
#: sc/inc/scfuncs.hrc:4260
msgctxt "ocCHOOSECOLS"
msgid "Column "
msgstr "Столбец "

#. cwS8A
#: sc/inc/scfuncs.hrc:4261
msgctxt "ocCHOOSECOLS"
msgid "Column 1, Column 2,... The list of column numbers to be returned."
msgstr "Столбец 1; Столбец 2; … Список номеров столбцов для возврата."

#. sGgbA
#: sc/inc/scfuncs.hrc:4267
msgctxt "ocCHOOSEROWS"
msgid "Returns the specified rows from an array."
msgstr "Возвращает указанные строки из массива."

#. HkSKg
#: sc/inc/scfuncs.hrc:4268
msgctxt "ocCHOOSEROWS"
msgid "Array"
msgstr "Массив"

#. AL6gZ
#: sc/inc/scfuncs.hrc:4269
msgctxt "ocCHOOSEROWS"
msgid "The array containing the rows to be returned in the new array."
msgstr "Массив, содержащий строки для возвращения в новый массив."

#. eMwdB
#: sc/inc/scfuncs.hrc:4270
msgctxt "ocCHOOSEROWS"
msgid "Row "
msgstr "Строка "

#. z9XmC
#: sc/inc/scfuncs.hrc:4271
msgctxt "ocCHOOSEROWS"
msgid "Row 1, Row 2,... The list of row numbers to be returned."
msgstr "Строка 1; Строка 2; … Список номеров строк для возврата."

#. 6uAUo
#: sc/inc/scfuncs.hrc:4277
msgctxt "ocDROP"
msgid "Excludes a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Исключает указанное число соседних строк или столбцов с начала или с конца массива."

#. qqDwt
#: sc/inc/scfuncs.hrc:4278
msgctxt "ocDROP"
msgid "Array"
msgstr "Массив"

#. 6hEEw
#: sc/inc/scfuncs.hrc:4279
msgctxt "ocDROP"
msgid "The array from which to drop rows or columns."
msgstr "Массив, строки или столбцы из которого следует отбросить."

#. CCEFR
#: sc/inc/scfuncs.hrc:4280
msgctxt "ocDROP"
msgid "Rows"
msgstr "Строки"

#. 6afd9
#: sc/inc/scfuncs.hrc:4281
msgctxt "ocDROP"
msgid "The number of rows to drop. A negative value drops from the end of the array."
msgstr "Количество строк для отбрасывания. При отрицательном значении отбрасываются строки с конца массива."

#. 4NBh4
#: sc/inc/scfuncs.hrc:4282
msgctxt "ocDROP"
msgid "Columns"
msgstr "Столбцы"

#. Smjhs
#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Количество столбцов для отбрасывания. При отрицательном значении отбрасываются строки с конца массива."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Расширяет или заполняет массив до указанных размеров строк и столбцов."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Массив"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "Массив для расширения."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Строки"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Количество строк в расширенном массиве. Если отсутствует, строки не будут расширены."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Столбцы"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Количество столбцов в расширенном массиве. Если отсутствует, столбцы не будут расширены."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "Заполнение"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "Значение для заполнения. По умолчанию: #Н/Д."

#. VuRi8
#: sc/inc/scfuncs.hrc:4303
msgctxt "ocHSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr "Добавляет массивы по горизонтали, создавая массив большего размера."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Массив"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Первый массив для добавления."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Массив 1; Массив 2; … Последующие массивы для добавления. Если в массиве меньше строк, в дополнительных строках будет ошибка #Н/Д."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Добавляет массивы по вертикали, создавая массив большего размера."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Массив"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Первый массив для добавления."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Массив 1; Массив 2; … Последующие массивы для добавления. Если в массиве меньше столбцов, в дополнительных столбцах будет ошибка #Н/Д."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Возвращает указанное число соседних строк или столбцов с начала или с конца массива."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Массив"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "Массив, строки или столбцы из которого следует взять."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Строки"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Количество строк для взятия. При отрицательном значении берутся строки с конца массива."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Столбцы"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Количество столбцов для взятия. При отрицательном значении берутся столбцы с конца массива."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Возвращает текст, который идёт после указанной подстроки или разделителя."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Текст"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "Исходный текст."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Разделитель"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Разделитель. Можно указать несколько разделителей."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Номер экземпляра"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Экземпляр разделителя, следующий после которого текст следует извлечь. По умолчанию: 1. При отрицательном числе поиск выполняется с конца."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Режим сопоставления"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Установите в значение 1, чтобы выполнить сопоставление без учёта регистра. По умолчанию: 0."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Сопоставлять по концу"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Установите в значение 1, чтобы конец текста считался разделителем. По умолчанию: 0."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Если не найдено"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Значение, которое возвращается при отсутствии совпадений. По умолчанию: #Н/Д."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Возвращает текст, который идёт до указанной подстроки или разделителя."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Текст"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Исходный текст."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Разделитель"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Разделитель. Можно указать несколько разделителей."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Номер экземпляра"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Экземпляр разделителя, предшествующий которому текст следует извлечь. По умолчанию: 1. При отрицательном числе поиск выполняется с конца."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Режим сопоставления"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Установите в значение 1, чтобы выполнить сопоставление без учёта регистра. По умолчанию: 0."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Сопоставлять по концу"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Установите в значение 1, чтобы конец текста считался разделителем. По умолчанию: 0."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Если не найдено"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Значение, которое возвращается при отсутствии совпадений. По умолчанию: #Н/Д."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Разбивает текст по указанному разделителю, создавая массив из нескольких ячеек."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Текст"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "Текст для разбиения."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Разделитель столбцов"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "Текст для разделения столбцов. Можно указать несколько разделителей."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Разделитель строк"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "Текст для разделения строк. Можно указать несколько разделителей."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Игнорировать пустые"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Установите в значение TRUE, чтобы игнорировать последовательные разделители (иначе создаётся пустая ячейка). По умолчанию: FALSE."

#. AUSmr
#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Режим сопоставления"

#. pjYxd
