msgid "The value with which to pad. The default is #N/A."
msgstr "Valore con cui eseguire il riempimento. L'impostazione predefinita è #N/D."

#. Bc4CS
#: sc/inc/scfuncs.hrc:4449
msgctxt "ocWRAPROWS"
msgid "Wraps the provided row or column of values by rows after a specified number of elements to form a new array."
msgstr "Suddivide i valori della riga o della colonna specificata in più righe dopo un determinato numero di elementi in modo da formare una nuova matrice."

#. UeAts
#: sc/inc/scfuncs.hrc:4450
msgctxt "ocWRAPROWS"
msgid "Range"
msgstr "Intervallo"

#. Fo4we
#: sc/inc/scfuncs.hrc:4451
msgctxt "ocWRAPROWS"
msgid "the range to wrap."
msgstr "Intervallo dei valori da suddividere."

#. B64X3
#: sc/inc/scfuncs.hrc:4452
msgctxt "ocWRAPROWS"
msgid "Wrap count"
msgstr "Numero di valori"

#. uGwSk
#: sc/inc/scfuncs.hrc:4453
msgctxt "ocWRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Numero massimo di valori per ogni riga."

#. AJosm
#: sc/inc/scfuncs.hrc:4454
msgctxt "ocWRAPROWS"
msgid "Pad with"
msgstr "Riempi con"

#. C3SiR
