#: sc/inc/scfuncs.hrc:4438
msgctxt "ocWRAPCOLS"
msgid "Range"
msgstr "Intervallo"

#. h3vyV
#: sc/inc/scfuncs.hrc:4439
msgctxt "ocWRAPCOLS"
msgid "the range to wrap."
msgstr "Intervallo dei valori da suddividere."

#. nCGAe
#: sc/inc/scfuncs.hrc:4440
msgctxt "ocWRAPCOLS"
msgid "Wrap count"
msgstr "Numero di valori"

#. su9gg
#: sc/inc/scfuncs.hrc:4441
msgctxt "ocWRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "Numero massimo di valori per ogni colonna."

#. sCG9H
#: sc/inc/scfuncs.hrc:4442
msgctxt "ocWRAPCOLS"
msgid "Pad with"
msgstr "Riempi con"

#. FnA6D
