"00000110.xhp\n"
"par_id3154514\n"
"help.text"
msgid "<ahelp hid=\".\">Moves forward to the next page.</ahelp>"
msgstr "<ahelp hid=\".\">เลื่อนไปยังหน้าถัดไป</ahelp>"

#. bYSCN
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
