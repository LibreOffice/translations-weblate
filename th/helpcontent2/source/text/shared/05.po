#. pqcge
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10926\n"
"help.text"
msgid "You can copy from the <emph>Help Viewer</emph> to the clipboard on your operating system with standard copy commands. For example:"
msgstr "คุณสามารถคัดลอกข้อความจาก<emph>โปรแกรมดูวิธีใช้</emph>ไปยังคลิปบอร์ดในระบบปฏิบัติการของคุณได้โดยใช้คำสั่งคัดลอกมาตรฐาน ตัวอย่างเช่น:"

#. Ex84y
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN1092C\n"
"help.text"
msgid "On a Help page, select the text that you want to copy."
msgstr "ในหน้าวิธีใช้ ให้เลือกข้อความที่คุณต้องการคัดลอก"

#. GDeaH
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10930\n"
"help.text"
msgid "Press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+C</emph>."
msgstr "กด <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+C</emph>"

#. egTH7
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10933\n"
"help.text"
msgid "To search the current Help page:"
msgstr "เมื่อต้องการค้นหาหน้าวิธีใช้ปัจจุบัน:"

#. j6RmU
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10939\n"
"help.text"
msgid "Click the <emph>Find on this Page</emph> icon."
msgstr "คลิกไอคอน <emph>ค้นหาในหน้านี้</emph>"

#. HB6gA
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10940\n"
"help.text"
msgid "The <emph>Find on this Page</emph> dialog opens."
msgstr "กล่องโต้ตอบ <emph>ค้นหาในหน้านี้</emph> จะเปิดขึ้น"

#. L3FYC
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A36\n"
"help.text"
msgid "You can also click in the <emph>Help</emph> page and press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+F</emph>."
msgstr "คุณยังสามารถคลิกที่หน้า<emph>วิธีใช้</emph>และกด <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+F</emph> ได้อีกด้วย"

#. F5MsA
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A22\n"
"help.text"
msgid "In the <emph>Search for</emph> box, enter the text that you want to find."
msgstr "ในช่อง <emph>ค้นหา</emph> ให้ป้อนข้อความที่คุณต้องการค้นหา"

#. XPQQQ
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A48\n"
"help.text"
msgid "Select the search options that you want to use."
msgstr "เลือกตัวเลือกการค้นหาที่คุณต้องการใช้"

#. dHfJj
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A26\n"
"help.text"
msgid "Click <emph>Find</emph>."
msgstr "คลิก <emph>ค้นหา</emph>"

#. Ck8E6
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A59\n"
"help.text"
msgid "To find the next occurrence of the search term on the page, click <emph>Find</emph> again."
msgstr "เมื่อต้องการค้นหาจุดที่พบถัดไปของคำค้นหาในหน้า ให้คลิก <emph>ค้นหา</emph> อีกครั้ง"

#. xYwKD
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10906\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/searchterm\" visibility=\"hidden\">Enter the text that you want to search for or select a text entry in the list.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/searchterm\" visibility=\"hidden\">ป้อนข้อความที่คุณต้องการค้นหา หรือเลือกข้อความจากรายการ</ahelp>"

#. BxuRD
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10993\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/wholewords\" visibility=\"hidden\">Finds complete words only.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/wholewords\" visibility=\"hidden\">ค้นหาเฉพาะคำที่สมบูรณ์เท่านั้น</ahelp>"

#. morri
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109AA\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/matchcase\" visibility=\"hidden\">Distinguishes between uppercase text and lowercase text.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/matchcase\" visibility=\"hidden\">แยกแยะระหว่างข้อความตัวพิมพ์ใหญ่กับข้อความตัวพิมพ์เล็ก</ahelp>"

#. EDGGQ
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109C1\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/wrap\" visibility=\"hidden\">Searches the entire Help page, starting at the current position of the cursor.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/wrap\" visibility=\"hidden\">ค้นหาทั้งหน้าวิธีใช้ โดยเริ่มจากตำแหน่งปัจจุบันของเคอร์เซอร์</ahelp>"

#. TQJer
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109D8\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/backwards\" visibility=\"hidden\">Searches backwards from the current position of the cursor.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/backwards\" visibility=\"hidden\">ค้นหาย้อนกลับจากตำแหน่งปัจจุบันของเคอร์เซอร์</ahelp>"

#. DFKRX
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109F5\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/search\" visibility=\"hidden\">Finds the next occurrence of the search term.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/search\" visibility=\"hidden\">ค้นหาจุดที่พบถัดไปของคำค้นหา</ahelp>"

#. 9tiYQ
