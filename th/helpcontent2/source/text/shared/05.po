msgctxt ""
"00000110.xhp\n"
"hd_id3149202\n"
"help.text"
msgid "Navigation Pane"
msgstr "ช่องนำทาง"

#. cqyrd
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3148673\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontrol/tabcontrol\">The navigation pane of the Help window contains the tab pages <emph>Contents</emph>, <emph>Index</emph>, <emph>Find</emph> and <emph>Bookmarks</emph>.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpcontrol/tabcontrol\">ช่องนำทางของหน้าต่างวิธีใช้ประกอบด้วยแท็บต่าง ๆ ได้แก่ <emph>สารบัญ</emph> <emph>ดัชนี</emph> <emph>ค้นหา</emph> และ<emph>ที่คั่นหน้า</emph></ahelp>"

#. FkVic
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3159149\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontrol/active\">The list box located at the very top is where you can select other <item type=\"productname\">%PRODUCTNAME</item> Help modules.</ahelp> The <emph>Index</emph> and <emph>Find</emph> tab pages only contain the data for the selected <item type=\"productname\">%PRODUCTNAME</item> module."
msgstr "<ahelp hid=\"sfx/ui/helpcontrol/active\">ช่องรายการที่อยู่ด้านบนสุดคือที่ที่คุณสามารถเลือกโมดูลวิธีใช้ <item type=\"productname\">%PRODUCTNAME</item> อื่น ๆ ได้</ahelp> หน้าแท็บ <emph>ดัชนี</emph> และ <emph>ค้นหา</emph> จะมีเฉพาะข้อมูลสำหรับโมดูล <item type=\"productname\">%PRODUCTNAME</item> ที่เลือกไว้เท่านั้น"

#. mxK3r
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3149983\n"
"help.text"
msgid "<link href=\"text/shared/05/00000160.xhp\">Contents</link>"
msgstr "<link href=\"text/shared/05/00000160.xhp\">สารบัญ</link>"

