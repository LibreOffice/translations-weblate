#. vmDfR
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3150960\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpindexpage/HelpIndexPage\" visibility=\"hidden\">Double-click an entry or type the word you want to find in the index.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpindexpage/HelpIndexPage\" visibility=\"hidden\">คลิกสองครั้งที่รายการ หรือพิมพ์คำที่คุณต้องการค้นหาในดัชนี</ahelp>"

#. vCFZF
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3148668\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpindexpage/display\" visibility=\"hidden\">Click to display the selected topic.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpindexpage/display\" visibility=\"hidden\">คลิกเพื่อแสดงหัวข้อที่เลือก</ahelp>"

#. HPgqx
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3155934\n"
"help.text"
msgid "You can search for a specific topic by typing a word into the <emph>Search term</emph> text box. The window contains an alphabetical list of index terms."
msgstr "คุณสามารถค้นหาหัวข้อที่ต้องการได้โดยพิมพ์คำลงในช่อง <emph>คำค้นหา</emph> หน้าต่างนี้จะแสดงรายชื่อคำค้นหาเรียงตามลำดับตัวอักษร"

#. wXC7X
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3145669\n"
"help.text"
msgid "If the cursor is in the index list when you type the search term, the display will jump directly to the next match. When you type a word in the <emph>Search term</emph> text box, the focus will jump to the best match in the index list."
msgstr "หากเคอร์เซอร์อยู่ในรายการดัชนีในขณะที่คุณพิมพ์คำค้นหา หน้าจอจะกระโดดไปยังคำที่ตรงกันถัดไปโดยตรง และเมื่อคุณพิมพ์คำลงในกล่องข้อความ <emph>คำค้นหา</emph> ระบบจะเลื่อนโฟกัสไปยังคำที่ตรงกันมากที่สุดในรายการดัชนีทันที"

#. AFUH2
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3147653\n"
"help.text"
msgid "The index and full-text searches always apply to the currently selected <item type=\"productname\">%PRODUCTNAME</item> application. Select the appropriate application using the list box on the help viewer's toolbar."
msgstr "การค้นหาด้วยดัชนีและการค้นหาข้อความแบบเต็มจะใช้กับแอปพลิเคชัน <item type=\"productname\">%PRODUCTNAME</item> ที่เลือกอยู่ในปัจจุบันเท่านั้น เลือกแอปพลิเคชันที่เหมาะสมโดยใช้กล่องรายการบนแถบเครื่องมือของโปรแกรมดูวิธีใช้"

#. MsRLT
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"tit\n"
"help.text"
msgid "Find - The Full-Text Search"
msgstr "ค้นหา - การค้นหาข้อความแบบเต็ม"

#. vqRPz
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"bm_id3148532\n"
"help.text"
msgid "<bookmark_value>Find tab in Help</bookmark_value><bookmark_value>Help; full-text search</bookmark_value><bookmark_value>full-text search in Help</bookmark_value>"
msgstr "<bookmark_value>แท็บค้นหาในวิธีใช้</bookmark_value><bookmark_value>วิธีใช้; การค้นหาข้อความแบบเต็ม</bookmark_value><bookmark_value>การค้นหาข้อความแบบเต็มในวิธีใช้</bookmark_value>"

#. x3TUv
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"hd_id3148523\n"
"help.text"
msgid "<variable id=\"00000140\"><link href=\"text/shared/05/00000140.xhp\">Find - The Full-Text Search</link></variable>"
msgstr "<variable id=\"00000140\"><link href=\"text/shared/05/00000140.xhp\">ค้นหา - การค้นหาข้อความแบบเต็ม</link></variable>"

#. U7EA6
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155599\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/search\" visibility=\"hidden\">Enter the search term here. The search is not case-sensitive.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/search\" visibility=\"hidden\">ป้อนคำค้นหาที่นี่ การค้นหาไม่คำนึงถึงตัวพิมพ์ใหญ่หรือเล็ก</ahelp>"

#. ZY75Y
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3153323\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/find\" visibility=\"hidden\">Click to start a full-text search for the term you entered.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/find\" visibility=\"hidden\">คลิกเพื่อเริ่มการค้นหาข้อความแบบเต็มสำหรับคำที่คุณป้อน</ahelp>"

#. BS7dG
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3150499\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/results\" visibility=\"hidden\">Lists the headings of the pages found in your full-text search. To display a page, double-click its entry.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/results\" visibility=\"hidden\">แสดงรายชื่อหัวเรื่องของหน้าที่พบในการค้นหาแบบเต็มข้อความ เมื่อต้องการแสดงหน้า ให้คลิกสองครั้งที่รายการนั้น</ahelp>"

#. eJLq7
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3156027\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/completewords\" visibility=\"hidden\">Specifies whether to carry out an exact search for the word you entered. Incomplete words will not be found.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/completewords\" visibility=\"hidden\">ระบุว่าจะค้นหาคำที่คุณป้อนอย่างตรงตัวหรือไม่ โดยจะไม่ค้นหาคำที่ป้อนไม่ครบถ้วน</ahelp>"

#. gbq7L
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155552\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/headings\" visibility=\"hidden\">Specifies whether to only search in document headings for the search term.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/headings\" visibility=\"hidden\">ระบุว่าจะค้นหาเฉพาะในหัวเรื่องเอกสารเท่านั้นหรือไม่</ahelp>"

#. cAGcs
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155555\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/display\" visibility=\"hidden\">Displays the entry selected in the list.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/display\" visibility=\"hidden\">แสดงรายการที่เลือกในรายชื่อ</ahelp>"

#. iBiGG
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3152552\n"
"help.text"
msgid "The full text search function in $[officename] Help allows you to find Help documents that contain any combination of search terms. To do this, type one or more words into the <emph>Search term</emph> text field."
msgstr "ฟังก์ชันค้นหาข้อความแบบเต็มในวิธีใช้ $[officename] ให้คุณสามารถค้นหาเอกสารวิธีใช้ที่มีคำค้นหาตามชุดคำที่คุณระบุได้ โดยพิมพ์ข้อความอย่างน้อยหนึ่งคำในช่อง <emph>คำค้นหา</emph>"

#. tZvTM
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3153345\n"
"help.text"
msgid "The <emph>Search term</emph> text field stores the words you entered last. To repeat a previous search, click the arrow icon and select the term from the list."
msgstr "ช่อง <emph>คำค้นหา</emph> จะเก็บคำที่คุณป้อนล่าสุด เมื่อต้องการใช้คำค้นหาเดิมอีกครั้ง ให้คลิกไอคอนลูกศร แล้วเลือกคำจากรายการ"

#. HUQ6C
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155941\n"
"help.text"
msgid "After the search has been carried out, the document headings of the results appear in a list. Either double-click an entry, or select it and click <emph>Display</emph> to load the corresponding Help document."
msgstr "หลังจากที่ทำการค้นหาแล้ว หัวเรื่องเอกสารของผลลัพธ์จะปรากฏในรายชื่อ ให้คลิกสองครั้งที่รายการ หรือเลือกรายการนั้นแล้วคลิก <emph>แสดง</emph> เพื่อโหลดเอกสารวิธีใช้ที่เกี่ยวข้อง"

#. YYczi
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3157958\n"
"help.text"
msgid "Use the check box <emph>Find in headings only</emph> to limit the search to document headings."
msgstr "ใช้กล่องกาเครื่องหมาย <emph>ค้นหาในหัวเรื่องเท่านั้น</emph> เพื่อจำกัดการค้นหาเฉพาะหัวเรื่องเอกสาร"

#. TWWt7
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3147210\n"
"help.text"
msgid "The <emph>Complete words only</emph> check box allows you to perform an exact search. If this box is marked, incomplete words will not be found. Do not mark this check box if the search term you enter should also be found as part of a longer word."
msgstr "กล่องกาเครื่องหมาย <emph>เฉพาะคำที่สมบูรณ์เท่านั้น</emph> ช่วยให้คุณทำการค้นหาแบบตรงตัวได้ ถ้ากล่องนี้กาอยู่ ระบบจะไม่ค้นหาคำที่ป้อนไม่ครบถ้วน อย่ากาช่องนี้ถ้าต้องการค้นหาคำที่เป็นส่วนหนึ่งของคำอื่นที่ยาวกว่า"

#. bY5wT
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3146798\n"
"help.text"
msgid "You can enter any combination of search terms, separated by spaces. Searching is not case-sensitive."
msgstr "คุณสามารถป้อนชุดคำค้นหาใด ๆ คั่นด้วยช่องว่าง การค้นหาไม่คำนึงถึงตัวพิมพ์ใหญ่หรือเล็ก"

#. AfnGS
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3149732\n"
"help.text"
msgid "The index and full-text searches always apply to the currently selected %PRODUCTNAME application. Select the appropriate application using the list box on the help viewer's toolbar."
msgstr "ดัชนีและการค้นหาข้อความแบบเต็มจะมีผลกับแอปพลิเคชัน %PRODUCTNAME ที่เลือกปัจจุบันเสมอ ให้เลือกแอปพลิเคชันที่เหมาะสมโดยใช้กล่องรายการบนแถบเครื่องมือของโปรแกรมดูวิธีใช้"

#. B6BtZ
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"tit\n"
"help.text"
msgid "Managing Bookmarks"
msgstr "การจัดการที่คั่นหน้า"

#. SkFUB
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"bm_id3153244\n"
"help.text"
msgid "<bookmark_value>Help; bookmarks</bookmark_value><bookmark_value>bookmarks; Help</bookmark_value>"
msgstr "<bookmark_value>วิธีใช้; ที่คั่นหน้า</bookmark_value><bookmark_value>ที่คั่นหน้า; วิธีใช้</bookmark_value>"

#. jcs4K
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"hd_id3154349\n"
"help.text"
msgid "<variable id=\"doc_title\"><link href=\"text/shared/05/00000150.xhp\">Managing Bookmarks</link></variable>"
msgstr "<variable id=\"doc_title\"><link href=\"text/shared/05/00000150.xhp\">การจัดการที่คั่นหน้า</link></variable>"

#. 4k7H2
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3154840\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/bookmarkdialog/BookmarkDialog\" visibility=\"hidden\">Displays the name of the bookmarked page. You can also type a new name for the bookmark.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/bookmarkdialog/BookmarkDialog\" visibility=\"hidden\">แสดงชื่อของหน้าที่เพิ่มที่คั่นหน้า คุณยังสามารถพิมพ์ชื่อใหม่สำหรับที่คั่นหน้าได้เช่นกัน</ahelp>"

#. DCXuy
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3149140\n"
"help.text"
msgid "<image src=\"sfx2/res/favourite.png\" id=\"img_id3149549\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149549\">Icon</alt></image>"
msgstr "<image src=\"sfx2/res/favourite.png\" id=\"img_id3149549\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149549\">ไอคอน</alt></image>"

#. EKRD3
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145314\n"
"help.text"
msgid "Use the <emph>Add to Bookmarks</emph> icon to set a <link href=\"text/shared/00/00000005.xhp#bookmark\">bookmark</link> for the current page shown in the Help."
msgstr "ใช้ไอคอน <emph>เพิ่มในที่คั่นหน้า</emph> เพื่อตั้ง<link href=\"text/shared/00/00000005.xhp#bookmark\">ที่คั่นหน้า</link>สำหรับหน้าปัจจุบันที่แสดงในวิธีใช้"

#. UK7NF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3149827\n"
"help.text"
msgid "You can find the bookmarks on the <emph>Bookmarks</emph> tab page."
msgstr "คุณสามารถพบที่คั่นหน้าได้ในหน้าแท็บ <emph>ที่คั่นหน้า</emph>"

#. ygCDN
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145345\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpbookmarkpage/HelpBookmarkPage\" visibility=\"visible\">Double-clicking a bookmark or pressing the <emph>Return</emph> key opens the assigned page in Help. A right-click opens the context menu.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpbookmarkpage/HelpBookmarkPage\" visibility=\"visible\">การคลิกสองครั้งที่ที่คั่นหน้าหรือกดปุ่ม <emph>Return</emph> จะเปิดหน้าที่กำหนดในวิธีใช้ การคลิกขวาจะเปิดเมนูบริบท</ahelp>"

#. qqCBe
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3166410\n"
"help.text"
msgid "Use the <item type=\"keycode\">Del</item> key to delete a selected bookmark."
msgstr "ใช้ปุ่ม <item type=\"keycode\">Del</item> เพื่อลบที่คั่นหน้าที่เลือก"

#. QFH6i
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145382\n"
"help.text"
msgid "The following commands are on the context menu of a bookmark:"
msgstr "คำสั่งต่อไปนี้อยู่บนเมนูบริบทของที่คั่นหน้า:"

#. ApGPm
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3147573\n"
"help.text"
msgid "<emph>Display</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_OPEN\" visibility=\"visible\">displays the selected help subject</ahelp>."
msgstr "<emph>แสดง</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_OPEN\" visibility=\"visible\">แสดงหัวเรื่องวิธีใช้ที่เลือก</ahelp>"

#. KhCTF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3150771\n"
"help.text"
msgid "<emph>Rename</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_RENAME\" visibility=\"visible\">opens a dialog for entering another name for the bookmark</ahelp>."
msgstr "<emph>เปลี่ยนชื่อ</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_RENAME\" visibility=\"visible\">เปิดกล่องโต้ตอบสำหรับป้อนชื่ออื่นให้กับที่คั่นหน้า</ahelp>"

#. DGdEF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3153087\n"
"help.text"
msgid "<emph>Delete</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_DELETE\" visibility=\"visible\">deletes the selected bookmark.</ahelp>"
msgstr "<emph>ลบ</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_DELETE\" visibility=\"visible\">ลบที่คั่นหน้าที่เลือก</ahelp>"

#. VqaZD
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"tit\n"
"help.text"
msgid "Contents - The Main Help Topics"
msgstr "สารบัญ - หัวข้อวิธีใช้หลัก"

#. y5FLx
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"bm_id3147090\n"
"help.text"
msgid "<bookmark_value>Help; topics</bookmark_value><bookmark_value>tree view of Help</bookmark_value>"
msgstr "<bookmark_value>วิธีใช้; หัวข้อ</bookmark_value><bookmark_value>โครงสร้างต้นไม้ของวิธีใช้</bookmark_value>"

#. u95Wi
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"hd_id3146856\n"
"help.text"
msgid "<variable id=\"doc_title\"><link href=\"text/shared/05/00000160.xhp\">Contents - The Main Help Topics</link></variable>"
msgstr "<variable id=\"doc_title\"><link href=\"text/shared/05/00000160.xhp\">สารบัญ - หัวข้อวิธีใช้หลัก</link></variable>"

#. 82jUN
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3147000\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontentpage/HelpContentPage\">Displays the main help themes, arranged in a similar way to folders in a file manager.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpcontentpage/HelpContentPage\">แสดงหัวข้อวิธีใช้หลัก ๆ ซึ่งจัดเรียงแบบเดียวกับโฟลเดอร์ในโปรแกรมจัดการไฟล์</ahelp>"

#. MyKSG
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3151315\n"
"help.text"
msgid "<image id=\"img_id3152924\" src=\"formula/res/fapclose.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3152924\">Icon</alt></image>"
msgstr "<image id=\"img_id3152924\" src=\"formula/res/fapclose.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3152924\">ไอคอน</alt></image>"

#. 87kb7
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3150774\n"
"help.text"
msgid "Double-click a closed folder to open it and display the subfolders and Help pages."
msgstr "คลิกสองครั้งที่โฟลเดอร์ที่ปิดอยู่เพื่อเปิดโฟลเดอร์นั้นและแสดงโฟลเดอร์ย่อยและหน้าวิธีใช้"

#. DCbpB
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3150506\n"
"help.text"
msgid "<image id=\"img_id3156426\" src=\"formula/res/fapopen.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3156426\">Icon</alt></image>"
msgstr "<image id=\"img_id3156426\" src=\"formula/res/fapopen.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3156426\">ไอคอน</alt></image>"

#. EWXAu
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3154749\n"
"help.text"
msgid "Double-click an open folder to close it and hide the subfolders and Help pages."
msgstr "คลิกสองครั้งที่โฟลเดอร์ที่เปิดอยู่เพื่อปิดโฟลเดอร์นั้นและซ่อนโฟลเดอร์ย่อยและหน้าวิธีใช้"

