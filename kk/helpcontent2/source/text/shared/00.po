"help.text"
msgid "Cancel"
msgstr "Бас тарту"

#. wMM5M
#: 00000001.xhp
msgctxt ""
"00000001.xhp\n"
"par_id3155913\n"
"help.text"
msgid "<ahelp hid=\".\">Clicking <emph>Cancel</emph> closes a dialog without saving any changes made.</ahelp>"
msgstr "<ahelp hid=\".\"><emph>Бас тарту</emph> батырмасын шерту сұхбат терезесін жасалған өзгерістерді сақтамай жабады.</ahelp>"

#. 9ELme
