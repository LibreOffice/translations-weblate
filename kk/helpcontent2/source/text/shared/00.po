"par_id3145348\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_SAVEGRAPHIC\">Opens a dialog where you can save the selected graphics.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_SAVEGRAPHIC\">Таңдалған графиканы сақтауға болатын сұхбат терезесін ашады.</ahelp>"

#. 3nWVM
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3151262\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_COPYLINK\">Copies the link at the mouse pointer to the clipboard.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_COPYLINK\">Тышқан курсорындағы сілтемені алмасу буферіне көшіреді.</ahelp>"

#. rtZo6
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3155934\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_COPYGRAPHIC\">Copies a selected graphic to the clipboard.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_COPYGRAPHIC\">Таңдалған графиканы алмасу буферіне көшіреді.</ahelp>"

#. hKB2e
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3145629\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_LOADGRAPHIC\">If you have deactivated the graphics display, choose the<emph> Load Graphics </emph>command to make them visible.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_LOADGRAPHIC\">Егер сіз графиканы көрсетуді сөндірген болсаңыз, оларды көрінетін ету үшін <emph>Графиканы жүктеу</emph> командасын таңдаңыз.</ahelp>"

#. kXRqe
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3150902\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_GRAPHICOFF\">Sets all graphics in the document to be invisible.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_GRAPHICOFF\">Құжаттағы барлық графиканы көрінбейтін етіп орнатады.</ahelp>"

#. VraVt
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3148548\n"
"help.text"
msgid "<ahelp hid=\"HID_MN_READONLY_SAVEBACKGROUND\">Allows you to save the background of a Web page.</ahelp>"
msgstr "<ahelp hid=\"HID_MN_READONLY_SAVEBACKGROUND\">Веб-беттің фонын сақтауға мүмкіндік береді.</ahelp>"

