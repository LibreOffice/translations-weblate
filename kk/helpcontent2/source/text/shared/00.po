"par_id3156042\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/asciifilterdialog/cr\">Produces a \"Carriage Return\" as the paragraph break.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/asciifilterdialog/cr\">Абзац үзілімі ретінде \"Каретканы қайтару\" командасын орындайды.</ahelp>"

#. orZMX
