msgctxt ""
"00000001.xhp\n"
"par_id761668777629023\n"
"help.text"
msgid "Click the <menuitem>Help</menuitem> button to open the help page associated with the currently open dialog."
msgstr "Қазіргі ашық сұхбат терезесіне қатысты көмек бетін ашу үшін <menuitem>Көмек</menuitem> батырмасын шертіңіз."

#. WptWZ
