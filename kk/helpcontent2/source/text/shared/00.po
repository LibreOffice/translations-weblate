msgid "Asian Language Support"
msgstr "Азия тілдерін қолдау"

#. DQj68
#: 00000007.xhp
msgctxt ""
"00000007.xhp\n"
"par_id3156326\n"
"help.text"
msgid "These commands can only be accessed after you enable support for Asian languages in <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - Languages and Locales - General</emph>."
msgstr "Бұл командаларға тек <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Баптаулар</emph></caseinline><defaultinline><emph>Құралдар - Опциялар</emph></defaultinline></switchinline><emph> - Тілдер және жергілікті баптаулар - Жалпы</emph> бөлімінде Азия тілдерін қолдауды іске қосқаннан кейін ғана қол жеткізуге болады."

#. A9MQV
#: 00000010.xhp
