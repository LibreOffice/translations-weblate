#. f2cMT
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3083278\n"
"help.text"
msgid "<ahelp hid=\"HID_GALLERY_MN_ADDMENU\">Defines how a selected graphic object is inserted into a document.</ahelp>"
msgstr "<ahelp hid=\"HID_GALLERY_MN_ADDMENU\">Таңдалған графикалық объектінің құжатқа қалай кірістірілетінін анықтайды.</ahelp>"

#. b8o6a
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3156053\n"
"help.text"
msgid "<ahelp hid=\"HID_GALLERY_MN_ADD\">Inserts a copy of the selected graphic object directly into the document.</ahelp>"
msgstr "<ahelp hid=\"HID_GALLERY_MN_ADD\">Таңдалған графикалық объектінің көшірмесін тікелей құжатқа кірістіреді.</ahelp>"

#. u8ggN
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3149038\n"
"help.text"
msgid "<ahelp hid=\"HID_GALLERY_MN_ADD_LINK\">Inserts the selected graphic as a link.</ahelp>"
msgstr "<ahelp hid=\"HID_GALLERY_MN_ADD_LINK\">Таңдалған графиканы сілтеме ретінде кірістіреді.</ahelp>"

#. zBAp3
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3158428\n"
"help.text"
msgid "<ahelp hid=\"HID_GALLERY_MN_PREVIEW\">The<emph> Preview </emph>command displays the selected graphic.</ahelp>"
msgstr "<ahelp hid=\"HID_GALLERY_MN_PREVIEW\"><emph>Алдын ала қарау</emph> командасы таңдалған графиканы көрсетеді.</ahelp>"

#. 6CUyY
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3154522\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/gallerytitledialog/GalleryTitleDialog\">Assigns a title to a selected Gallery object.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/gallerytitledialog/GalleryTitleDialog\">Таңдалған Gallery объектісіне атау тағайындайды.</ahelp>"

#. 6QoZG
#: 01010000.xhp
msgctxt ""
"01010000.xhp\n"
"par_id3149750\n"
"help.text"
msgid "<ahelp hid=\"HID_GALLERY_MN_DELETE\">Deletes the selected graphic after confirmation.</ahelp>"
msgstr "<ahelp hid=\"HID_GALLERY_MN_DELETE\">Растаудан кейін таңдалған графиканы өшіреді.</ahelp>"

