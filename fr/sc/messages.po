msgstr "Instance du délimiteur avant lequel extraire le texte. La valeur par défaut est 1. Un nombre négatif lance la recherche depuis la fin."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Mode Correspondre"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
