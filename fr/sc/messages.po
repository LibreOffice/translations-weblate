msgid "Columns"
msgstr "Colonnes"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Le nombre de colonnes à renvoyer."

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
