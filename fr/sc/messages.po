msgctxt "ocSORT"
msgid "Sorts the contents of a range or array."
msgstr "Trie le contenu d'une plage ou d'une matrice."

#. HKENV
#: sc/inc/scfuncs.hrc:4202
msgctxt "ocSORT"
msgid "Range"
msgstr "Plage"

#. vgj8a
