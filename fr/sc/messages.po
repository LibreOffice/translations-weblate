#: sc/inc/scfuncs.hrc:185
msgctxt "ocGET_DATE"
msgid "Month"
msgstr "Mois"

#. tLKRC
#: sc/inc/scfuncs.hrc:186
msgctxt "ocGET_DATE"
msgid "An integer between 1 and 12 representing the month. Values out of bounds will roll over the date, computing the result by adding months and days as necessary."
msgstr "Un entier compris entre 1 et 12 représentant le mois. Les valeurs hors limites seront reportées à la date suivante, le résultat étant calculé en additionnant les mois et les jours nécessaires."

#. MGV7P
#: sc/inc/scfuncs.hrc:187
msgctxt "ocGET_DATE"
msgid "Day"
msgstr "Jour"

#. ECDBG
#: sc/inc/scfuncs.hrc:188
msgctxt "ocGET_DATE"
msgid "An integer between 1 and 31 representing the day of the month. Values out of bounds will roll over the date, computing the result by adding months and days as necessary."
msgstr "Un entier compris entre 1 et 31 représentant le jour du mois. Les valeurs hors limites seront reportées à la date suivante, le résultat étant calculé en additionnant les mois et les jours nécessaires."

#. JUonj
#: sc/inc/scfuncs.hrc:194
