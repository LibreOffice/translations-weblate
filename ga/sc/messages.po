msgctxt "pastespecial|extended_tip|add"
msgid "Adds the values in the clipboard cells to the values in the target cells. Also, if the clipboard only contains comments, adds the comments to the target cells."
msgstr "Cuireann sé na luachanna sna cealla gearrthaisce leis na luachanna sna cealla sprice. Chomh maith leis sin, mura bhfuil ach tráchtanna sa ghearrthaisce, cuireann sé na tráchtanna leis na cealla sprice."

#. 4SmrC
#: sc/uiconfig/scalc/ui/pastespecial.ui:724
msgctxt "pastespecial|subtract"
msgid "Subtract"
msgstr "Dealaigh"

#. 2SKbT
#: sc/uiconfig/scalc/ui/pastespecial.ui:733
msgctxt "pastespecial|extended_tip|subtract"
msgid "Subtracts the values in the clipboard cells from the values in the target cells."
msgstr "Baintear na luachanna sna cealla gearrthaisce ó na luachanna sna cealla sprice."

#. 4HCRU
#: sc/uiconfig/scalc/ui/pastespecial.ui:745
msgctxt "pastespecial|multiply"
msgid "Multiply"
msgstr "Iolraigh"

