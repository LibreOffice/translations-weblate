#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Líon na gcolún le titim. Titeann luach diúltach ó dheireadh an eagair."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Leathnaíonn nó líonann sé eagar go toisí sraithe agus colúin shonraithe."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Eagar"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "An eagar le leathnú."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Sraitheanna"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Líon na sraitheanna san eagar leathnaithe. Mura bhfuil siad ann, ní leathnófar sraitheanna."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Colúin"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Líon na gcolún san eagar leathnaithe. Mura bhfuil siad ann, ní leathnófar na colúin."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "Ceap le"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "An luach le líonadh leis. Is é #N/A an réamhshocrú."

#. VuRi8
#: sc/inc/scfuncs.hrc:4303
msgctxt "ocHSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr "Cuireann sé eagair go cothrománach chun eagar níos mó a chruthú."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Eagar"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "An chéad eagar le cur leis."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Eagar 1, Eagar 2,... Na heagair seo a leanas le cur leis. Má tá níos lú sraitheanna in eagar, cuirfear an earráid #N/A ar ais sna sraitheanna breise."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Cuireann sé eagair go hingearach chun eagar níos mó a chruthú."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Eagar"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "An chéad eagar le cur leis."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Eagar 1, Eagar 2,... Na heagair seo a leanas le cur leis. Má tá níos lú colún in eagar, cuirfear an earráid #N/A ar ais sna colúin bhreise."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Tugann sé líon sonraithe sraitheanna nó colún comhleanúnacha ar ais ó thús nó ó dheireadh eagair."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Eagar"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "An eagar as a dtógfar sraitheanna nó colúin."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Sraitheanna"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Líon na sraitheanna le glacadh. Tógann luach diúltach ó dheireadh an eagair."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Colúin"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Líon na gcolún le glacadh. Glacann luach diúltach ó dheireadh an eagair."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Tugann sé seo an téacs a tharlaíonn i ndiaidh fo-theaghrán nó deighilteoir ar leith ar ais."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Téacs"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "An téacs bunaidh."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Deighilteoir"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "An deighilteoir. Is féidir roinnt deighilteoirí a sholáthar."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Uimhir na Cásca"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "An sampla den deighilteoir ar cheart téacs a bhaint ina dhiaidh. Is é 1 an réamhshocrú. Tosaíonn uimhir dhiúltach ag cuardach ón deireadh."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Mód Meaitseála"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Socraigh go 1 chun meaitseáil neamh-íogair ó thaobh cás de a dhéanamh. Is é 0 an réamhshocrú."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Deireadh an Chluiche"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Socraigh go 1 chun deireadh an téacs a láimhseáil mar theorannaitheoir. Is é 0 an réamhshocrú."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Mura bhfaightear é"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "An luach a fhilleann mura bhfaightear aon mheaitseáil. Is é #N/A an réamhshocrú."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Tugann sé seo an téacs a tharlaíonn roimh fho-theaghrán nó deighilteoir ar leith."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Téacs"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "An téacs bunaidh."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Deighilteoir"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "An deighilteoir. Is féidir roinnt deighilteoirí a sholáthar."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Uimhir na Cásca"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "An sampla den deighilteoir a mbainfear téacs roimhe. Is é 1 an réamhshocrú. Tosaíonn uimhir dhiúltach ag cuardach ón deireadh."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Mód Meaitseála"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Socraigh go 1 chun meaitseáil neamh-íogair ó thaobh cás de a dhéanamh. Is é 0 an réamhshocrú."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Deireadh an Chluiche"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Socraigh go 1 chun deireadh an téacs a láimhseáil mar theorannaitheoir. Is é 0 an réamhshocrú."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Mura bhfaightear é"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "An luach a fhilleann mura bhfaightear aon mheaitseáil. Is é #N/A an réamhshocrú."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Roinneann sé téacs le deighilteoir tugtha go sraith de chealla iolracha."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Téacs"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "An téacs le roinnt."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Deighilteoir Colún"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "An téacs chun na colúin a theorannú. Is féidir roinnt teorannaitheoirí a sholáthar."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Teorannaitheoir Ró"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "An téacs chun na sraitheanna a theorannú. Is féidir roinnt teorannaitheoirí a sholáthar."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Déan neamhaird de na rudaí folamha"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Socraigh go FÍOR chun neamhaird a dhéanamh de dheighilteoirí comhleanúnacha nó cruthaítear cill fholamh. Is é BRÉAGACH an réamhshocrú."

#. AUSmr
#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Mód meaitseála"

#. pjYxd
#: sc/inc/scfuncs.hrc:4381
msgctxt "ocTEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Socraigh go 1 chun meaitseáil neamh-íogair ó thaobh cás de a dhéanamh. Is é 0 an réamhshocrú."

#. LsoKk
#: sc/inc/scfuncs.hrc:4382
msgctxt "ocTEXTSPLIT"
msgid "Pad with"
msgstr "Ceap le"

#. niX3W
#: sc/inc/scfuncs.hrc:4383
msgctxt "ocTEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "An luach le líonadh leis. Is é #N/A an réamhshocrú."

#. dv6gP
#: sc/inc/scfuncs.hrc:4389
msgctxt "ocTOCOL"
msgid "Transforms an array into a single column."
msgstr "Claochlaíonn sé eagar ina cholún aonair."

#. A9zBS
#: sc/inc/scfuncs.hrc:4390
msgctxt "ocTOCOL"
msgid "Array"
msgstr "Eagar"

#. x95Ef
#: sc/inc/scfuncs.hrc:4391
msgctxt "ocTOCOL"
msgid "The range or array to return as a single column."
msgstr "An raon nó an eagar le tabhairt ar ais mar cholún aonair."

#. weBya
#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Déan neamhaird de"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Cibé acu ar cheart neamhaird a dhéanamh de chineálacha áirithe luachanna. 0 nó fágtha ar lár - coinnigh na luachanna uile (réamhshocraithe). 1 - déan neamhaird de chealla bána. 2 - déan neamhaird de chealla le hearráid. 3 - déan neamhaird de chealla bána agus de chealla le hearráid."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Scanadh de réir colúin"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Scanadh an eagar de réir colúin. BRÉAGACH nó fágtha ar lár (réamhshocraithe) - déantar an eagar a scanadh de réir ró. FÍOR - déantar an eagar a scanadh de réir colúin."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "athraíonn sé eagar ina shraith aonair."

#. GAbkQ
#: sc/inc/scfuncs.hrc:4402
msgctxt "ocTOROW"
msgid "Array"
msgstr "Eagar"

#. w7WXB
#: sc/inc/scfuncs.hrc:4403
msgctxt "ocTOROW"
msgid "The range or array to return as a single row."
msgstr "An raon nó an eagar le tabhairt ar ais mar shraith aonair."

#. GCfA2
#: sc/inc/scfuncs.hrc:4404
msgctxt "ocTOROW"
msgid "Ignore"
msgstr "Ignore"

#. AnEDD
#: sc/inc/scfuncs.hrc:4405
msgctxt "ocTOROW"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Cibé acu ar cheart neamhaird a dhéanamh de chineálacha áirithe luachanna. 0 nó fágtha ar lár - coinnigh na luachanna uile (réamhshocraithe). 1 - déan neamhaird de chealla bána. 2 - déan neamhaird de chealla le hearráid. 3 - déan neamhaird de chealla bána agus de chealla le hearráid."

#. pDD7V
#: sc/inc/scfuncs.hrc:4406
msgctxt "ocTOROW"
msgid "Scan by column"
msgstr "Scanadh de réir colúin"

#. qxY7a
#: sc/inc/scfuncs.hrc:4407
msgctxt "ocTOROW"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Scanadh an eagar de réir colúin. BRÉAGACH nó fágtha ar lár (réamhshocraithe) - déantar an eagar a scanadh de réir ró. FÍOR - déantar an eagar a scanadh de réir colúin."

#. 8p5AW
#: sc/inc/scfuncs.hrc:4413
msgctxt "ocUNIQUE"
msgid "Returns a list of unique values from a range or array."
msgstr "Tugann sé liosta de luachanna uathúla ó raon nó ó eagar ar ais."

#. LAeWQ
#: sc/inc/scfuncs.hrc:4414
msgctxt "ocUNIQUE"
msgid "Array"
msgstr "Eagar"

#. LHrXJ
#: sc/inc/scfuncs.hrc:4415
msgctxt "ocUNIQUE"
msgid "The range or array from which to return unique values."
msgstr "An raon nó an eagar as a dtabharfar luachanna uathúla ar ais."

#. TBfHR
#: sc/inc/scfuncs.hrc:4416
msgctxt "ocUNIQUE"
msgid "By col"
msgstr "De réir col"

#. xiVEn
#: sc/inc/scfuncs.hrc:4417
msgctxt "ocUNIQUE"
msgid "Logical value indicating how to compare data: TRUE - compares data across columns. FALSE or omitted (default) - compares data across rows."
msgstr "Luach loighciúil a léiríonn conas sonraí a chur i gcomparáid: FÍOR - déanann comparáid idir sonraí trasna colún. BRÉAGACH nó fágtha ar lár (réamhshocraithe) - déanann comparáid idir sonraí trasna sraitheanna."

#. GLsJf
#: sc/inc/scfuncs.hrc:4418
msgctxt "ocUNIQUE"
msgid "Uniqueness"
msgstr "Uathúlacht"

#. ubRgX
#: sc/inc/scfuncs.hrc:4419
msgctxt "ocUNIQUE"
msgid "Logical value that defines what values are considered unique: TRUE - returns values that occur only once. FALSE or omitted (default) - returns all distinct (different) values in the range or array."
msgstr "Luach loighciúil a shainíonn cé na luachanna a mheastar a bheith uathúil: FÍOR - tugann sé luachanna ar ais nach dtarlaíonn ach uair amháin. BRÉAGACH nó fágtha ar lár (réamhshocraithe) - tugann sé gach luach ar leith (difriúil) sa raon nó san eagar ar ais."

#. 5Aaqr
#: sc/inc/scfuncs.hrc:4425
msgctxt "ocLET"
msgid "The LET function assigns names to calculation results. This allows storing intermediate calculations, values, or defining names inside a formula. These names only apply within the scope of the LET function."
msgstr "Sannann an fheidhm LET ainmneacha do thorthaí ríomhanna. Ligeann sé seo duit ríomhanna idirmheánacha, luachanna, nó ainmneacha sainmhínithe a stóráil laistigh de fhoirmle. Ní bhaineann na hainmneacha seo ach amháin laistigh de raon feidhme na feidhme LET."

#. GTBCS
#: sc/inc/scfuncs.hrc:4426
msgctxt "ocLET"
msgid "Name 1"
msgstr "Ainm 1"

#. BXEhz
#: sc/inc/scfuncs.hrc:4427
msgctxt "ocLET"
msgid "The first name to assign. Must start with a letter. Cannot be the output of a formula or conflict with range syntax."
msgstr "An chéad ainm le sannadh. Ní mór dó tosú le litir. Ní féidir leis a bheith ina aschur foirmle ná ní féidir leis a bheith i gcoimhlint le comhréir an raoin."

#. agD98
#: sc/inc/scfuncs.hrc:4428
msgctxt "ocLET"
msgid "Name value "
msgstr "Luach ainm "

#. CjEiH
#: sc/inc/scfuncs.hrc:4429
msgctxt "ocLET"
msgid "Name value 1, Name value 2,... The value or calculation to assign to Name."
msgstr "Luach ainm 1, luach ainm 2,... An luach nó an ríomh le sannadh d'Ainm."

#. GCAQK
#: sc/inc/scfuncs.hrc:4430
msgctxt "ocLET"
msgid "Calculation or Name "
msgstr "Ríomh nó Ainm "

#. uzEFm
#: sc/inc/scfuncs.hrc:4431
msgctxt "ocLET"
msgid "A calculation that uses all names within the LET function. This must be the last argument in the LET function. Or a second Name to assign to a second Name value. If a second Name is specified, Name value 2 and Calculation or Name 3 become required."
msgstr "Ríomh a úsáideann na hainmneacha go léir laistigh den fheidhm LET. Caithfidh sé seo a bheith mar an argóint dheireanach sa fheidhm LET. Nó Ainm eile le sannadh do dhara luach Ainm. Má shonraítear dara Ainm, bíonn luach Ainm 2 agus Ríomh nó Ainm 3 riachtanach."

#. HbPvG
#: sc/inc/scfuncs.hrc:4437
msgctxt "ocWRAPCOLS"
msgid "Wraps the provided row or column of values by columns after a specified number of elements to form a new array."
msgstr "Fillteann sé an tsraith nó an colún luachanna a chuirtear ar fáil faoi cholúin i ndiaidh líon sonraithe eilimintí chun eagar nua a fhoirmiú."

#. ACoFA
#: sc/inc/scfuncs.hrc:4438
msgctxt "ocWRAPCOLS"
msgid "Range"
msgstr "Raon"

#. h3vyV
#: sc/inc/scfuncs.hrc:4439
msgctxt "ocWRAPCOLS"
msgid "the range to wrap."
msgstr "an raon le timfhilleadh."

#. nCGAe
#: sc/inc/scfuncs.hrc:4440
msgctxt "ocWRAPCOLS"
msgid "Wrap count"
msgstr "Líon fillte"

#. su9gg
#: sc/inc/scfuncs.hrc:4441
msgctxt "ocWRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "An líon uasta luachanna do gach colún."

#. sCG9H
#: sc/inc/scfuncs.hrc:4442
msgctxt "ocWRAPCOLS"
msgid "Pad with"
msgstr "Ceap le"

#. FnA6D
#: sc/inc/scfuncs.hrc:4443
msgctxt "ocWRAPCOLS"
msgid "The value with which to pad. The default is #N/A."
msgstr "An luach le líonadh leis. Is é #N/A an réamhshocrú."

#. Bc4CS
#: sc/inc/scfuncs.hrc:4449
msgctxt "ocWRAPROWS"
msgid "Wraps the provided row or column of values by rows after a specified number of elements to form a new array."
msgstr "Fillteann sé an ró nó an colún luachanna a chuirtear ar fáil de réir rónna i ndiaidh líon sonraithe eilimintí chun eagar nua a fhoirmiú."

#. UeAts
#: sc/inc/scfuncs.hrc:4450
msgctxt "ocWRAPROWS"
msgid "Range"
msgstr "Raon"

#. Fo4we
#: sc/inc/scfuncs.hrc:4451
