#: sdext/inc/strings.hrc:26
msgctxt "STR_OPTIMIZE_IMAGES"
msgid "Optimize 1 image to %QUALITY% JPEG quality at %RESOLUTION DPI."
msgid_plural "Optimize %IMAGES images to %QUALITY% JPEG quality at %RESOLUTION DPI."
msgstr[0] "%IMAGES 枚の画像を %RESOLUTION DPI、JPEG画質 %QUALITY% に最適化します。"

