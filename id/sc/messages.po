msgid "In case of Polar=TRUE, the frequency components below this magnitude are clipped out (default 0.0)."
msgstr "Dalam kasus Polar(Kutub)=TRUE, komponen frekuensi di bawah magnitude ini dipotong (baku 0,0)."

#. SDqjG
#: sc/inc/scfuncs.hrc:4173
msgctxt "ocRANDOM_NV"
msgid "Returns a random number between 0 and 1, non-volatile."
msgstr "Menghasilkan angka acak antara 0 dan 1, tidak volatil."

#. zUzWN
#: sc/inc/scfuncs.hrc:4179
msgctxt "ocRANDBETWEEN_NV"
msgid "Returns a random integer between the specified Bottom and Top values (both inclusive), non-volatile."
msgstr "Menghasilkan bilangan bulat acak antara nilai Terbawah dan Teratas yang ditentukan (keduanya inklusif), tidak mudah berubah."

#. XRTEX
#: sc/inc/scfuncs.hrc:4180
msgctxt "ocRANDBETWEEN_NV"
msgid "Bottom"
msgstr ""

#. Vipt3
#: sc/inc/scfuncs.hrc:4181
msgctxt "ocRANDBETWEEN_NV"
msgid "The smallest integer that can be returned."
msgstr "Bilangan bulat terkecil yang dapat dihasilkan."

#. TXWYA
#: sc/inc/scfuncs.hrc:4182
msgctxt "ocRANDBETWEEN_NV"
msgid "Top"
msgstr ""

#. A6fAC
#: sc/inc/scfuncs.hrc:4183
msgctxt "ocRANDBETWEEN_NV"
msgid "The largest integer that can be returned."
msgstr "Bilangan bulat terbesar yang dapat dihasilkan."

#. TVBBo
#: sc/inc/scfuncs.hrc:4189
msgctxt "ocFILTER"
msgid "Filters an array based on a Boolean (True/False) array."
msgstr "Menapis larik berdasarkan larik Boolean (Benar/Salah)."

#. d65Ge
#: sc/inc/scfuncs.hrc:4190
msgctxt "ocFILTER"
msgid "Range"
msgstr "Rentang"

#. RMEDy
#: sc/inc/scfuncs.hrc:4191
msgctxt "ocFILTER"
msgid "The array, or range to filter."
msgstr "Larik atau rentang yang akan ditapis."

#. DaokM
#: sc/inc/scfuncs.hrc:4192
msgctxt "ocFILTER"
msgid "Include"
msgstr ""

#. AEy68
#: sc/inc/scfuncs.hrc:4193
msgctxt "ocFILTER"
msgid "A Boolean array whose height or width is the same as the array."
msgstr "Larik Boolean yang tingginya atau lebarnya sama dengan larik."

#. hGyPL
#: sc/inc/scfuncs.hrc:4194
msgctxt "ocFILTER"
msgid "Result if empty"
msgstr "Hasil jika kosong"

#. Ka6BT
#: sc/inc/scfuncs.hrc:4195
msgctxt "ocFILTER"
msgid "The value to return if all values in the included array are empty (filter returns nothing)."
msgstr "Nilai yang akan dihasilkan jika semua nilai di dalam larik yang disertakan kosong (penapis tidak menghasilkan apa pun)."

#. nxhBg
#: sc/inc/scfuncs.hrc:4201
msgctxt "ocSORT"
msgid "Sorts the contents of a range or array."
msgstr "Mengurutkan konten rentang atau larik."

#. HKENV
#: sc/inc/scfuncs.hrc:4202
msgctxt "ocSORT"
msgid "Range"
msgstr "Rentang"

#. vgj8a
#: sc/inc/scfuncs.hrc:4203
msgctxt "ocSORT"
msgid "The range, or array to sort."
msgstr "Rentang, atau larik yang akan diurutkan."

#. mdeDi
#: sc/inc/scfuncs.hrc:4204
msgctxt "ocSORT"
msgid "Sort index"
msgstr "Urutkan indeks"

#. DuQFW
#: sc/inc/scfuncs.hrc:4205
msgctxt "ocSORT"
msgid "A number indicating the row or column to sort by."
msgstr "Angka yang menunjukkan baris atau kolom yang akan diurutkan."

#. BK4XX
#: sc/inc/scfuncs.hrc:4206
msgctxt "ocSORT"
msgid "Sort order"
msgstr "Susunan pengurutan"

#. zFBzs
#: sc/inc/scfuncs.hrc:4207
msgctxt "ocSORT"
msgid "A number indicating the desired sort order; 1 for ascending order (default), -1 for descending order."
msgstr "Nomor yang menunjukkan urutan pengurutan yang diinginkan; 1 untuk urutan menaik (baku), -1 untuk urutan menurun."

#. ResTu
#: sc/inc/scfuncs.hrc:4208
msgctxt "ocSORT"
msgid "By col"
msgstr "Berdasarkan kolom"

#. DwWWz
#: sc/inc/scfuncs.hrc:4209
msgctxt "ocSORT"
msgid "A logical value indicating the desired sort direction; FALSE to sort by row (default), TRUE to sort by column."
msgstr "Nilai logika yang menunjukkan arah pengurutan yang diinginkan; FALSE untuk mengurutkan berdasarkan baris (baku), TRUE untuk mengurutkan berdasarkan kolom."

#. UEqVF
#: sc/inc/scfuncs.hrc:4215
msgctxt "ocSORTBY"
msgid "Sorts the contents of a range or array based on the values in a corresponding range or array."
msgstr "Mengurutkan konten rentang atau larik berdasarkan nilai dalam rentang atau larik terkait."

#. Htvdm
#: sc/inc/scfuncs.hrc:4216
msgctxt "ocSORTBY"
msgid "Sort range"
msgstr "Rentang urut"

#. EWvvS
#: sc/inc/scfuncs.hrc:4217
msgctxt "ocSORTBY"
msgid "The array or range to sort."
msgstr "Larik atau rentang yang akan diurutkan."

#. yh5AE
#: sc/inc/scfuncs.hrc:4218
msgctxt "ocSORTBY"
msgid "Sort by range "
msgstr "Urutkan berdasarkan rentang "

#. g2AAw
#: sc/inc/scfuncs.hrc:4219
msgctxt "ocSORTBY"
msgid "Range 1, range 2,... are the arrays or ranges to sort on."
msgstr "Rentang 1, rentang 2,... adalah larik-larik atau rentang-rentang yang akan diurutkan."

#. Hxhru
#: sc/inc/scfuncs.hrc:4220
msgctxt "ocSORTBY"
msgid "Sort order "
msgstr "Susuan urutan "

#. qWxek
#: sc/inc/scfuncs.hrc:4221
msgctxt "ocSORTBY"
msgid "Order 1, order 2,... are the orders to use for sorting. 1 for ascending, -1 for descending. Default is ascending."
msgstr "Susunan 1, susunan 2,... adalah susunan-susunan yang digunakan untuk pengurutan. 1 untuk naik, -1 untuk turun. Yang baku adalah menaik."

#. Js6Dj
#: sc/inc/scfuncs.hrc:4227
msgctxt "ocMAT_SEQUENCE"
msgid "Generates a list of sequential numbers in an array, such as 1, 2, 3, 4."
msgstr "Menghasilkan senarai nomor urut di dalam larik, seperti 1, 2, 3, 4."

#. QBMEL
#: sc/inc/scfuncs.hrc:4228
msgctxt "ocMAT_SEQUENCE"
msgid "Rows"
msgstr "Baris-baris"

#. QJTBL
#: sc/inc/scfuncs.hrc:4229
msgctxt "ocMAT_SEQUENCE"
msgid "The number of rows to return."
msgstr "Jumlah baris yang akan dihasilkan."

#. GEC8c
#: sc/inc/scfuncs.hrc:4230
msgctxt "ocMAT_SEQUENCE"
msgid "Columns"
msgstr "Kolom-kolom"

#. fhnFH
#: sc/inc/scfuncs.hrc:4231
msgctxt "ocMAT_SEQUENCE"
msgid "The number of columns to return."
msgstr "Jumlah kolom yang akan dihasilkan"

#. kWPVy
#: sc/inc/scfuncs.hrc:4232
msgctxt "ocMAT_SEQUENCE"
msgid "Start"
msgstr "Mulai"

#. dCwre
#: sc/inc/scfuncs.hrc:4233
msgctxt "ocMAT_SEQUENCE"
msgid "The first number in the sequence."
msgstr "Nomor pertama dalam urutan."

#. Vuu2D
#: sc/inc/scfuncs.hrc:4234
msgctxt "ocMAT_SEQUENCE"
msgid "Step"
msgstr "Langkah"

#. usMFD
#: sc/inc/scfuncs.hrc:4235
msgctxt "ocMAT_SEQUENCE"
msgid "The amount to increment each subsequent value in the array."
msgstr "Jumlah kenaikan setiap nilai berikutnya di dalam larik."

#. LbVEK
#: sc/inc/scfuncs.hrc:4241
msgctxt "ocRANDARRAY"
msgid "Generates an array of random numbers between two limit values."
msgstr "Menghasilkan larik angka acak antara dua nilai batas."

#. FkAEX
#: sc/inc/scfuncs.hrc:4242
msgctxt "ocRANDARRAY"
msgid "Rows"
msgstr "Baris-baris"

#. MAEDm
#: sc/inc/scfuncs.hrc:4243
msgctxt "ocRANDARRAY"
msgid "The number of rows to return."
msgstr "Jumlah baris yang akan dihasilkan."

#. KEjFn
#: sc/inc/scfuncs.hrc:4244
msgctxt "ocRANDARRAY"
msgid "Columns"
msgstr "Kolom-kolom"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Jumlah kolom yang akan dihasilkan"

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
msgctxt "ocRANDARRAY"
msgid "Min"
msgstr "Min"

#. gEAsz
#: sc/inc/scfuncs.hrc:4247
msgctxt "ocRANDARRAY"
msgid "The lower limit of the generated numbers."
msgstr "Batas bawah angka yang dihasilkan."

#. zBinA
#: sc/inc/scfuncs.hrc:4248
msgctxt "ocRANDARRAY"
msgid "Max"
msgstr "Maks"

#. kSq6A
#: sc/inc/scfuncs.hrc:4249
msgctxt "ocRANDARRAY"
msgid "The upper limit of the generated numbers."
msgstr "Batas atas angka yang dihasilkan."

#. 3E6Xi
#: sc/inc/scfuncs.hrc:4250
msgctxt "ocRANDARRAY"
msgid "Integers"
msgstr "Integer"

#. RM5HL
#: sc/inc/scfuncs.hrc:4251
msgctxt "ocRANDARRAY"
msgid "Return integer (TRUE) or decimal (FALSE) values."
msgstr "Menghasilkan nilai integer (TRUE) atau desimal (FALSE)."

#. 6xiFb
#: sc/inc/scfuncs.hrc:4257
msgctxt "ocCHOOSECOLS"
msgid "Returns the specified columns from an array."
msgstr "Mengembalikan kolom yang ditentukan dari suatu larik."

#. vDNp8
#: sc/inc/scfuncs.hrc:4258
msgctxt "ocCHOOSECOLS"
msgid "Array"
msgstr "Larik"

#. R3koe
#: sc/inc/scfuncs.hrc:4259
msgctxt "ocCHOOSECOLS"
msgid "The array containing the columns to be returned in the new array."
msgstr "Larik yang berisi kolom yang akan dikembalikan dalam larik baru."

#. kZPeA
#: sc/inc/scfuncs.hrc:4260
msgctxt "ocCHOOSECOLS"
msgid "Column "
msgstr "Kolom "

#. cwS8A
#: sc/inc/scfuncs.hrc:4261
msgctxt "ocCHOOSECOLS"
msgid "Column 1, Column 2,... The list of column numbers to be returned."
msgstr "Kolom 1, Kolom 2,... Daftar nomor kolom yang akan dikembalikan."

#. sGgbA
#: sc/inc/scfuncs.hrc:4267
msgctxt "ocCHOOSEROWS"
msgid "Returns the specified rows from an array."
msgstr "Mengembalikan baris yang ditentukan dari suatu larik."

#. HkSKg
#: sc/inc/scfuncs.hrc:4268
msgctxt "ocCHOOSEROWS"
msgid "Array"
msgstr "Larik"

#. AL6gZ
#: sc/inc/scfuncs.hrc:4269
msgctxt "ocCHOOSEROWS"
msgid "The array containing the rows to be returned in the new array."
msgstr "Larik yang berisi baris yang akan dikembalikan dalam larik baru."

#. eMwdB
#: sc/inc/scfuncs.hrc:4270
msgctxt "ocCHOOSEROWS"
msgid "Row "
msgstr "Baris "

#. z9XmC
#: sc/inc/scfuncs.hrc:4271
msgctxt "ocCHOOSEROWS"
msgid "Row 1, Row 2,... The list of row numbers to be returned."
msgstr "Baris 1, Baris 2,... Daftar nomor baris yang akan dikembalikan."

#. 6uAUo
#: sc/inc/scfuncs.hrc:4277
msgctxt "ocDROP"
msgid "Excludes a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Mengecualikan sejumlah baris atau kolom bersebelahan tertentu dari awal atau akhir suatu larik."

#. qqDwt
#: sc/inc/scfuncs.hrc:4278
msgctxt "ocDROP"
msgid "Array"
msgstr "Larik"

#. 6hEEw
#: sc/inc/scfuncs.hrc:4279
msgctxt "ocDROP"
msgid "The array from which to drop rows or columns."
msgstr "Larik sumber pengisian baris atau kolom."

#. CCEFR
#: sc/inc/scfuncs.hrc:4280
msgctxt "ocDROP"
msgid "Rows"
msgstr "Baris"

#. 6afd9
#: sc/inc/scfuncs.hrc:4281
msgctxt "ocDROP"
msgid "The number of rows to drop. A negative value drops from the end of the array."
msgstr "Cacah baris yang akan diisikan. Suatu nilai negatif mengisikan dari akhir larik."

#. 4NBh4
#: sc/inc/scfuncs.hrc:4282
msgctxt "ocDROP"
msgid "Columns"
msgstr "Kolom"

#. Smjhs
#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Cacah kolom yang akan diisikan. Suatu nilai negatif mengisi dari akhir larik."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Memperluas atau mengganjal larik ke dimensi baris dan kolom yang ditentukan."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Larik"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "Larik yang akan diperluas."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Baris"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Cacah baris dalam larik yang diperluas. Jika tidak ada, baris tidak akan diperluas."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Kolom"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Cacah kolom dalam larik yang diperluas. Jika tidak ada, kolom tidak akan diperluas."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "Ganjal dengan"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "Nilai yang akan diganjal. Nilai bakunya adalah #N/A."

#. VuRi8
#: sc/inc/scfuncs.hrc:4303
msgctxt "ocHSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr "Memperluas larik secara horizontal untuk membuat larik yang lebih besar."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Larik"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Larik pertama yang akan ditambahkan."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Larik 1, Larik 2,... Larik berikut akan ditambahkan. Jika larik memiliki lebih sedikit baris, kesalahan #N/A akan ditampilkan pada baris tambahan."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Memperluas larik secara vertikal untuk membuat larik yang lebih besar."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Larik"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Larik pertama yang akan ditambahkan."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Larik 1, Larik 2,... Larik berikut akan ditambahkan. Jika larik memiliki lebih sedikit kolom, kesalahan #N/A akan ditampilkan pada kolom tambahan."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Mengembalikan sejumlah baris atau kolom berturutan yang ditentukan dari awal atau akhir suatu larik."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Larik"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "Larik tempat mengambil baris atau kolom."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Baris"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Cacah baris yang akan diambil. Nilai negatif diambil dari akhir larik."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Kolom"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Cacah kolom yang akan diambil. Nilai negatif diambil dari akhir larik."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Mengembalikan teks yang muncul setelah sub-string atau pembatas yang diberikan."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Teks"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "Teks asli."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Pembatas"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Pembatas. Beberapa pembatas dapat disediakan."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Nomor Instansi"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Instansi pembatas yang digunakan untuk mengekstrak teks. Nilai bakunya adalah 1. Angka negatif memulai pencarian dari akhir."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Mode Pencocokan"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Atur ke 1 untuk melakukan pencocokan tanpa memperhatikan huruf besar/kecil. Nilai bakunya adalah 0."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Akhir Pencocokan"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Atur ke 1 untuk memperlakukan akhir teks sebagai pembatas. Nilai bakunya adalah 0."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Bila Tidak Ditemukan"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Nilai yang dikembalikan jika tidak ada kecocokan yang ditemukan. Nilai baku adalah #N/A."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Mengembalikan teks yang muncul sebelum sub-string atau pembatas tertentu."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Teks"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Teks asli."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Pembatas"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Pembatas. Beberapa pembatas dapat disediakan."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Nomor Instansi"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Instansi pembatas tempat asal teks diekstrak. Nilai baku adalah 1. Angka negatif memulai pencarian dari akhir."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Mode Pencocokan"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Atur ke 1 untuk melakukan pencocokan tanpa memperhatikan huruf besar/kecil. Nilai bakunya adalah 0."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Akhir Pencocokan"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Atur ke 1 untuk memperlakukan akhir teks sebagai pembatas. Nilai bakunya adalah 0."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Bila Tidak Ditemukan"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Nilai yang dikembalikan jika tidak ada kecocokan yang ditemukan. Nilai baku adalah #N/A."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Membelah teks dengan pembatas yang diberikan ke dalam larik beberapa sel."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Teks"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
