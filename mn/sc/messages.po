msgstr "0 ба 1-ийн хоорондох санамсаргүй тоог буцаана, тогтворгүй."

#. zUzWN
#: sc/inc/scfuncs.hrc:4179
msgctxt "ocRANDBETWEEN_NV"
msgid "Returns a random integer between the specified Bottom and Top values (both inclusive), non-volatile."
msgstr "Заасан Доод болон Дээд утгуудын хооронд санамсаргүй бүхэл тоог буцаана (хоёуланг нь багтаасан), тогтворгүй."

#. XRTEX
#: sc/inc/scfuncs.hrc:4180
msgctxt "ocRANDBETWEEN_NV"
msgid "Bottom"
msgstr ""

#. Vipt3
#: sc/inc/scfuncs.hrc:4181
msgctxt "ocRANDBETWEEN_NV"
msgid "The smallest integer that can be returned."
msgstr "Буцааж болох хамгийн жижиг бүхэл тоо."

#. TXWYA
#: sc/inc/scfuncs.hrc:4182
msgctxt "ocRANDBETWEEN_NV"
msgid "Top"
msgstr ""

#. A6fAC
#: sc/inc/scfuncs.hrc:4183
msgctxt "ocRANDBETWEEN_NV"
msgid "The largest integer that can be returned."
msgstr "Буцааж болох хамгийн том бүхэл тоо."

#. TVBBo
#: sc/inc/scfuncs.hrc:4189
msgctxt "ocFILTER"
msgid "Filters an array based on a Boolean (True/False) array."
msgstr "Boolean (True/False) массив дээр үндэслэн массивыг шүүдэг."

#. d65Ge
#: sc/inc/scfuncs.hrc:4190
msgctxt "ocFILTER"
msgid "Range"
msgstr "Хүрээ"

#. RMEDy
#: sc/inc/scfuncs.hrc:4191
msgctxt "ocFILTER"
msgid "The array, or range to filter."
msgstr "Шүүлтүүрийн массив эсвэл муж."

#. DaokM
#: sc/inc/scfuncs.hrc:4192
msgctxt "ocFILTER"
msgid "Include"
msgstr ""

#. AEy68
#: sc/inc/scfuncs.hrc:4193
msgctxt "ocFILTER"
msgid "A Boolean array whose height or width is the same as the array."
msgstr "Өндөр эсвэл өргөн нь массивтай ижил логикийн массив."

#. hGyPL
#: sc/inc/scfuncs.hrc:4194
msgctxt "ocFILTER"
msgid "Result if empty"
msgstr "Хоосон бол үр дүн"

#. Ka6BT
#: sc/inc/scfuncs.hrc:4195
msgctxt "ocFILTER"
msgid "The value to return if all values in the included array are empty (filter returns nothing)."
msgstr "Оруулсан массив дахь бүх утгууд хоосон байвал буцаах утга (шүүлтүүр юу ч буцаадаггүй)."

#. nxhBg
#: sc/inc/scfuncs.hrc:4201
msgctxt "ocSORT"
msgid "Sorts the contents of a range or array."
msgstr "Муж эсвэл массивын агуулгыг эрэмбэлдэг."

#. HKENV
#: sc/inc/scfuncs.hrc:4202
msgctxt "ocSORT"
msgid "Range"
msgstr "Хүрээ"

#. vgj8a
#: sc/inc/scfuncs.hrc:4203
msgctxt "ocSORT"
msgid "The range, or array to sort."
msgstr "Эрэмбэлэх муж эсвэл массив."

#. mdeDi
#: sc/inc/scfuncs.hrc:4204
msgctxt "ocSORT"
msgid "Sort index"
msgstr "Эрэмбэлэх индекс"

#. DuQFW
#: sc/inc/scfuncs.hrc:4205
msgctxt "ocSORT"
msgid "A number indicating the row or column to sort by."
msgstr "Эрэмбэлэх мөр эсвэл баганыг харуулсан тоо."

#. BK4XX
#: sc/inc/scfuncs.hrc:4206
msgctxt "ocSORT"
msgid "Sort order"
msgstr "Эрэмбэлэх дараалал"

#. zFBzs
#: sc/inc/scfuncs.hrc:4207
msgctxt "ocSORT"
msgid "A number indicating the desired sort order; 1 for ascending order (default), -1 for descending order."
msgstr "Хүссэн эрэмбийн дарааллыг харуулсан тоо; Өсөх дарааллаар 1 (анхдагч), буурах дарааллаар -1."

#. ResTu
#: sc/inc/scfuncs.hrc:4208
msgctxt "ocSORT"
msgid "By col"
msgstr "Колоноор"

#. DwWWz
#: sc/inc/scfuncs.hrc:4209
msgctxt "ocSORT"
msgid "A logical value indicating the desired sort direction; FALSE to sort by row (default), TRUE to sort by column."
msgstr "Хүссэн эрэмбэлэх чиглэлийг харуулсан логик утга; Мөрөөр эрэмбэлэх бол FALSE (өгөгдмөл), баганаар эрэмбэлэх бол ҮНЭН."

#. UEqVF
#: sc/inc/scfuncs.hrc:4215
msgctxt "ocSORTBY"
msgid "Sorts the contents of a range or array based on the values in a corresponding range or array."
msgstr "Харгалзах муж эсвэл массив дахь утгууд дээр үндэслэн муж эсвэл массивын агуулгыг эрэмбэлнэ."

#. Htvdm
#: sc/inc/scfuncs.hrc:4216
msgctxt "ocSORTBY"
msgid "Sort range"
msgstr "Хүрээг эрэмбэлэх"

#. EWvvS
#: sc/inc/scfuncs.hrc:4217
msgctxt "ocSORTBY"
msgid "The array or range to sort."
msgstr "Эрэмбэлэх массив эсвэл муж."

#. yh5AE
#: sc/inc/scfuncs.hrc:4218
msgctxt "ocSORTBY"
msgid "Sort by range "
msgstr "Хүрээгээр эрэмбэлэх "

#. g2AAw
#: sc/inc/scfuncs.hrc:4219
msgctxt "ocSORTBY"
msgid "Range 1, range 2,... are the arrays or ranges to sort on."
msgstr "1-р муж, муж 2,... нь эрэмблэх массив эсвэл муж юм."

#. Hxhru
#: sc/inc/scfuncs.hrc:4220
msgctxt "ocSORTBY"
msgid "Sort order "
msgstr "Эрэмбэлэх дараалал "

#. qWxek
#: sc/inc/scfuncs.hrc:4221
msgctxt "ocSORTBY"
msgid "Order 1, order 2,... are the orders to use for sorting. 1 for ascending, -1 for descending. Default is ascending."
msgstr "1-р тушаал, 2-р тушаал,... зэрэглэлд ашиглах захиалга байна. Өсөхөд 1, буурахад -1. Өгөгдмөл нь өсөж байна."

#. Js6Dj
#: sc/inc/scfuncs.hrc:4227
msgctxt "ocMAT_SEQUENCE"
msgid "Generates a list of sequential numbers in an array, such as 1, 2, 3, 4."
msgstr "1, 2, 3, 4 гэх мэт массив дахь дараалсан тоонуудын жагсаалтыг үүсгэдэг."

#. QBMEL
#: sc/inc/scfuncs.hrc:4228
msgctxt "ocMAT_SEQUENCE"
msgid "Rows"
msgstr "Мөр"

#. QJTBL
#: sc/inc/scfuncs.hrc:4229
msgctxt "ocMAT_SEQUENCE"
msgid "The number of rows to return."
msgstr "Буцах мөрийн тоо."

#. GEC8c
#: sc/inc/scfuncs.hrc:4230
msgctxt "ocMAT_SEQUENCE"
msgid "Columns"
msgstr "Багана"

#. fhnFH
#: sc/inc/scfuncs.hrc:4231
msgctxt "ocMAT_SEQUENCE"
msgid "The number of columns to return."
msgstr "Буцах баганын тоо."

#. kWPVy
#: sc/inc/scfuncs.hrc:4232
msgctxt "ocMAT_SEQUENCE"
msgid "Start"
msgstr "Эхлэх"

#. dCwre
#: sc/inc/scfuncs.hrc:4233
msgctxt "ocMAT_SEQUENCE"
msgid "The first number in the sequence."
msgstr "Дарааллын эхний тоо."

#. Vuu2D
#: sc/inc/scfuncs.hrc:4234
msgctxt "ocMAT_SEQUENCE"
msgid "Step"
msgstr "Алхам"

#. usMFD
#: sc/inc/scfuncs.hrc:4235
msgctxt "ocMAT_SEQUENCE"
msgid "The amount to increment each subsequent value in the array."
msgstr "Массив дахь дараагийн утга бүрийг нэмэгдүүлэх дүн."

#. LbVEK
#: sc/inc/scfuncs.hrc:4241
msgctxt "ocRANDARRAY"
msgid "Generates an array of random numbers between two limit values."
msgstr "Хоёр хязгаарын утгын хооронд санамсаргүй тооны массив үүсгэдэг."

#. FkAEX
#: sc/inc/scfuncs.hrc:4242
msgctxt "ocRANDARRAY"
msgid "Rows"
msgstr "Мөр"

#. MAEDm
#: sc/inc/scfuncs.hrc:4243
msgctxt "ocRANDARRAY"
msgid "The number of rows to return."
msgstr "Буцах мөрийн тоо."

#. KEjFn
#: sc/inc/scfuncs.hrc:4244
msgctxt "ocRANDARRAY"
msgid "Columns"
msgstr "Багана"

#. Bf74v
#: sc/inc/scfuncs.hrc:4245
msgctxt "ocRANDARRAY"
msgid "The number of columns to return."
msgstr "Буцах баганын тоо."

#. sH4qD
#: sc/inc/scfuncs.hrc:4246
msgctxt "ocRANDARRAY"
msgid "Min"
msgstr "Мин"

#. gEAsz
#: sc/inc/scfuncs.hrc:4247
msgctxt "ocRANDARRAY"
msgid "The lower limit of the generated numbers."
msgstr "Үүсгэсэн тоонуудын доод хязгаар."

#. zBinA
#: sc/inc/scfuncs.hrc:4248
msgctxt "ocRANDARRAY"
msgid "Max"
msgstr "Макс"

#. kSq6A
#: sc/inc/scfuncs.hrc:4249
msgctxt "ocRANDARRAY"
msgid "The upper limit of the generated numbers."
msgstr "Үүсгэсэн тоонуудын дээд хязгаар."

#. 3E6Xi
#: sc/inc/scfuncs.hrc:4250
msgctxt "ocRANDARRAY"
msgid "Integers"
msgstr "Бүхэл тоо"

#. RM5HL
#: sc/inc/scfuncs.hrc:4251
msgctxt "ocRANDARRAY"
msgid "Return integer (TRUE) or decimal (FALSE) values."
msgstr "Бүхэл тоо (ҮНЭН) эсвэл аравтын (FALSE) утгыг буцаана."

#. 6xiFb
#: sc/inc/scfuncs.hrc:4257
msgctxt "ocCHOOSECOLS"
msgid "Returns the specified columns from an array."
msgstr "Массиваас заасан багануудыг буцаана."

#. vDNp8
#: sc/inc/scfuncs.hrc:4258
msgctxt "ocCHOOSECOLS"
msgid "Array"
msgstr "Массив"

#. R3koe
#: sc/inc/scfuncs.hrc:4259
msgctxt "ocCHOOSECOLS"
msgid "The array containing the columns to be returned in the new array."
msgstr "Шинэ массив дахь буцаах багануудыг агуулсан массив."

#. kZPeA
#: sc/inc/scfuncs.hrc:4260
msgctxt "ocCHOOSECOLS"
msgid "Column "
msgstr "Багана "

#. cwS8A
#: sc/inc/scfuncs.hrc:4261
msgctxt "ocCHOOSECOLS"
msgid "Column 1, Column 2,... The list of column numbers to be returned."
msgstr "1-р багана, 2-р багана,... Буцаах баганын дугаарын жагсаалт."

#. sGgbA
#: sc/inc/scfuncs.hrc:4267
msgctxt "ocCHOOSEROWS"
msgid "Returns the specified rows from an array."
msgstr "Массиваас заасан мөрүүдийг буцаана."

#. HkSKg
#: sc/inc/scfuncs.hrc:4268
msgctxt "ocCHOOSEROWS"
msgid "Array"
msgstr "Массив"

#. AL6gZ
#: sc/inc/scfuncs.hrc:4269
msgctxt "ocCHOOSEROWS"
msgid "The array containing the rows to be returned in the new array."
msgstr "Шинэ массив руу буцаах мөрүүдийг агуулсан массив."

#. eMwdB
#: sc/inc/scfuncs.hrc:4270
msgctxt "ocCHOOSEROWS"
msgid "Row "
msgstr "Мөр "

#. z9XmC
#: sc/inc/scfuncs.hrc:4271
msgctxt "ocCHOOSEROWS"
msgid "Row 1, Row 2,... The list of row numbers to be returned."
msgstr "Мөр 1, Мөр 2,... Буцах мөрийн дугааруудын жагсаалт."

#. 6uAUo
#: sc/inc/scfuncs.hrc:4277
msgctxt "ocDROP"
msgid "Excludes a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Массивын эхлэл эсвэл төгсгөлөөс заасан тооны зэргэлдээ мөр, баганыг оруулахгүй."

#. qqDwt
#: sc/inc/scfuncs.hrc:4278
msgctxt "ocDROP"
msgid "Array"
msgstr "Массив"

#. 6hEEw
#: sc/inc/scfuncs.hrc:4279
msgctxt "ocDROP"
msgid "The array from which to drop rows or columns."
msgstr "Мөр эсвэл багана буулгах массив."

#. CCEFR
#: sc/inc/scfuncs.hrc:4280
msgctxt "ocDROP"
msgid "Rows"
msgstr "Мөр"

#. 6afd9
#: sc/inc/scfuncs.hrc:4281
msgctxt "ocDROP"
msgid "The number of rows to drop. A negative value drops from the end of the array."
msgstr "Унах мөрийн тоо. Массивын төгсгөлөөс сөрөг утга унана."

#. 4NBh4
#: sc/inc/scfuncs.hrc:4282
msgctxt "ocDROP"
msgid "Columns"
msgstr "Багана"

#. Smjhs
#: sc/inc/scfuncs.hrc:4283
msgctxt "ocDROP"
msgid "The number of columns to drop. A negative value drops from the end of the array."
msgstr "Унах баганын тоо. Массивын төгсгөлөөс сөрөг утга унана."

#. bLqBs
#: sc/inc/scfuncs.hrc:4289
msgctxt "ocEXPAND"
msgid "Expands or pads an array to specified row and column dimensions."
msgstr "Массивыг заасан мөр, баганын хэмжээс рүү тэлэх буюу зөөлрүүлнэ."

#. nQF65
#: sc/inc/scfuncs.hrc:4290
msgctxt "ocEXPAND"
msgid "Array"
msgstr "Массив"

#. GZwDK
#: sc/inc/scfuncs.hrc:4291
msgctxt "ocEXPAND"
msgid "The array to expand."
msgstr "Өргөтгөх массив."

#. YiNrW
#: sc/inc/scfuncs.hrc:4292
msgctxt "ocEXPAND"
msgid "Rows"
msgstr "Мөр"

#. xkjNy
#: sc/inc/scfuncs.hrc:4293
msgctxt "ocEXPAND"
msgid "The number of rows in the expanded array. If missing, rows will not be expanded."
msgstr "Өргөтгөсөн массив дахь мөрүүдийн тоо. Хэрэв байхгүй бол мөрүүдийг өргөтгөхгүй."

#. DjLn4
#: sc/inc/scfuncs.hrc:4294
msgctxt "ocEXPAND"
msgid "Columns"
msgstr "Багана"

#. EFJZX
#: sc/inc/scfuncs.hrc:4295
msgctxt "ocEXPAND"
msgid "The number of columns in the expanded array. If missing, columns will not be expanded."
msgstr "Өргөтгөсөн массив дахь баганын тоо. Хэрэв байхгүй бол багануудыг өргөтгөхгүй."

#. hBDD6
#: sc/inc/scfuncs.hrc:4296
msgctxt "ocEXPAND"
msgid "Pad with"
msgstr "бүхий дэвсгэр"

#. kTicG
#: sc/inc/scfuncs.hrc:4297
msgctxt "ocEXPAND"
msgid "The value with which to pad. The default is #N/A."
msgstr "Товчлох утга. Өгөгдмөл нь #Үгүй."

#. VuRi8
#: sc/inc/scfuncs.hrc:4303
msgctxt "ocHSTACK"
msgid "Appends arrays horizontally to create a larger array."
msgstr "Илүү том массив үүсгэхийн тулд массивуудыг хэвтээ байдлаар хавсаргана."

#. NBBGw
#: sc/inc/scfuncs.hrc:4304 sc/inc/scfuncs.hrc:4306
msgctxt "ocHSTACK"
msgid "Array"
msgstr "Массив"

#. nM6qp
#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Эхний хавсаргах массив."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "1-р массив, 2-р массив,... Дараах массивуудыг хавсаргана. Хэрэв массив цөөн мөртэй бол нэмэлт мөрөнд #Үгүй алдаа гарна."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Илүү том массив үүсгэхийн тулд массивуудыг босоо байдлаар хавсаргана."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Массив"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Эхний хавсаргах массив."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "1-р массив, 2-р массив,... Дараах массивуудыг хавсаргана. Хэрэв массив цөөн баганатай бол нэмэлт баганад #Үгүй алдаа гарна."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Массивын эхлэл эсвэл төгсгөлөөс заасан тооны зэргэлдээ мөр эсвэл баганыг буцаана."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Массив"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "Мөр эсвэл багана авах массив."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Мөр"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Авах мөрийн тоо. Сөрөг утгыг массивын төгсгөлөөс авна."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Багана"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Авах баганын тоо. Сөрөг утгыг массивын төгсгөлөөс авна."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Өгөгдсөн дэд мөр эсвэл хязгаарлагчийн дараа гарч буй текстийг буцаана."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Текст"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "Эх текст."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Хязгаарлагч"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Хязгаарлагч. Олон тооны хязгаарлагчийг нийлүүлж болно."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Тохиолдлын дугаар"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Текстийг задлах хязгаарлагчийн жишээ. Анхдагч нь 1. Сөрөг тоо нь төгсгөлөөс хайж эхэлдэг."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Тохирох горим"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Том жижиг жижиг үсгээр тохируулахын тулд 1 болгож тохируулна уу. Өгөгдмөл нь 0 байна."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Тоглолтын төгсгөл"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Текстийн төгсгөлийг хязгаарлагч гэж үзэхийн тулд 1 болгож тохируулна уу. Өгөгдмөл нь 0 байна."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Хэрэв олдохгүй бол"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Тохирох зүйл олдохгүй бол буцаана. Өгөгдмөл нь #Үгүй."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Өгөгдсөн дэд мөр эсвэл хязгаарлагчийн өмнө гарч буй текстийг буцаана."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Текст"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Эх текст."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Хязгаарлагч"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Хязгаарлагч. Олон тооны хязгаарлагчийг нийлүүлж болно."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Тохиолдлын дугаар"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Текстийг задлахын өмнө хязгаарлагчийн жишээ. Анхдагч нь 1. Сөрөг тоо нь төгсгөлөөс хайж эхэлдэг."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Тохирох горим"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Том жижиг жижиг үсгээр тохируулахын тулд 1 болгож тохируулна уу. Өгөгдмөл нь 0 байна."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Тоглолтын төгсгөл"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Текстийн төгсгөлийг хязгаарлагч гэж үзэхийн тулд 1 болгож тохируулна уу. Өгөгдмөл нь 0 байна."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Хэрэв олдохгүй бол"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Тохирох зүйл олдохгүй бол буцаана. Өгөгдмөл нь #Үгүй."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Текстийг өгөгдсөн хязгаарлагчаар олон нүдний массив болгон хуваана."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Текст"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "Хуваах текст."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Баганын хязгаарлагч"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "Багануудыг хязгаарлах текст. Олон тооны хязгаарлагчийг нийлүүлж болно."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Мөр хязгаарлагч"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "Мөрүүдийг хязгаарлах текст. Олон тооны хязгаарлагчийг нийлүүлж болно."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Хоосон байхыг үл тоомсорлох"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Дараалсан хязгаарлагчийг үл тоомсорлохын тулд ҮНЭН гэж тохируулна уу, эс тэгвээс энэ нь хоосон нүдийг үүсгэнэ. Өгөгдмөл нь ХУДАЛ."

#. AUSmr
#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Тохиромжтой горим"

#. pjYxd
#: sc/inc/scfuncs.hrc:4381
msgctxt "ocTEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Том жижиг жижиг үсгээр тохируулахын тулд 1 болгож тохируулна уу. Өгөгдмөл нь 0 байна."

#. LsoKk
#: sc/inc/scfuncs.hrc:4382
msgctxt "ocTEXTSPLIT"
msgid "Pad with"
msgstr "бүхий дэвсгэр"

#. niX3W
#: sc/inc/scfuncs.hrc:4383
msgctxt "ocTEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "Товчлох утга. Өгөгдмөл нь #Үгүй."

#. dv6gP
#: sc/inc/scfuncs.hrc:4389
msgctxt "ocTOCOL"
msgid "Transforms an array into a single column."
msgstr "Массивыг нэг багана болгон хувиргана."

#. A9zBS
#: sc/inc/scfuncs.hrc:4390
msgctxt "ocTOCOL"
msgid "Array"
msgstr "Массив"

#. x95Ef
#: sc/inc/scfuncs.hrc:4391
msgctxt "ocTOCOL"
msgid "The range or array to return as a single column."
msgstr "Нэг багана болгон буцаах муж эсвэл массив."

#. weBya
#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Үл тоомсорлох"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Тодорхой төрлийн үнэт зүйлсийг үл тоомсорлох эсэх. 0 эсвэл орхигдуулсан - бүх утгыг хадгалах (анхдагч). 1 - хоосон нүдийг үл тоомсорлох. 2 - алдаатай нүднүүдийг үл тоомсорлох. 3 - хоосон нүд, алдаатай нүднүүдийг үл тоомсорлох."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Баганагаар скан хийх"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Массивыг баганаар сканнердах. ХУДАЛ эсвэл орхигдуулсан (өгөгдмөл) - массивыг мөрөөр нь сканнердсан. ҮНЭН - массивыг баганаар сканнердсан."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "массивыг нэг мөр болгон хувиргадаг."

#. GAbkQ
#: sc/inc/scfuncs.hrc:4402
msgctxt "ocTOROW"
msgid "Array"
msgstr "Массив"

#. w7WXB
#: sc/inc/scfuncs.hrc:4403
msgctxt "ocTOROW"
msgid "The range or array to return as a single row."
msgstr "Нэг мөр болгон буцаах муж эсвэл массив."

#. GCfA2
#: sc/inc/scfuncs.hrc:4404
msgctxt "ocTOROW"
msgid "Ignore"
msgstr "Үл тоомсорлох"

#. AnEDD
#: sc/inc/scfuncs.hrc:4405
msgctxt "ocTOROW"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Тодорхой төрлийн үнэт зүйлсийг үл тоомсорлох эсэх. 0 эсвэл орхигдуулсан - бүх утгыг хадгалах (анхдагч). 1 - хоосон нүдийг үл тоомсорлох. 2 - алдаатай нүднүүдийг үл тоомсорлох. 3 - хоосон нүд, алдаатай нүднүүдийг үл тоомсорлох."

#. pDD7V
#: sc/inc/scfuncs.hrc:4406
msgctxt "ocTOROW"
msgid "Scan by column"
msgstr "Баганагаар скан хийх"

#. qxY7a
#: sc/inc/scfuncs.hrc:4407
msgctxt "ocTOROW"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Массивыг баганаар сканнердах. ХУДАЛ эсвэл орхигдуулсан (өгөгдмөл) - массивыг мөрөөр нь сканнердсан. ҮНЭН - массивыг баганаар сканнердсан."

#. 8p5AW
#: sc/inc/scfuncs.hrc:4413
msgctxt "ocUNIQUE"
msgid "Returns a list of unique values from a range or array."
msgstr "Муж эсвэл массиваас өвөрмөц утгуудын жагсаалтыг буцаана."

#. LAeWQ
#: sc/inc/scfuncs.hrc:4414
msgctxt "ocUNIQUE"
msgid "Array"
msgstr "Массив"

#. LHrXJ
#: sc/inc/scfuncs.hrc:4415
msgctxt "ocUNIQUE"
msgid "The range or array from which to return unique values."
msgstr "Өвөрмөц утгыг буцаах муж эсвэл массив."

#. TBfHR
#: sc/inc/scfuncs.hrc:4416
msgctxt "ocUNIQUE"
msgid "By col"
msgstr "Колоноор"

#. xiVEn
#: sc/inc/scfuncs.hrc:4417
msgctxt "ocUNIQUE"
msgid "Logical value indicating how to compare data: TRUE - compares data across columns. FALSE or omitted (default) - compares data across rows."
msgstr "Өгөгдлийг хэрхэн харьцуулахыг харуулсан логик утга: ҮНЭН - өгөгдлийг баганаар харьцуулна. ХУДАЛ эсвэл орхигдсон (өгөгдмөл) - мөр хоорондын өгөгдлийг харьцуулна."

#. GLsJf
#: sc/inc/scfuncs.hrc:4418
msgctxt "ocUNIQUE"
msgid "Uniqueness"
msgstr "Өвөрмөц байдал"

#. ubRgX
#: sc/inc/scfuncs.hrc:4419
msgctxt "ocUNIQUE"
msgid "Logical value that defines what values are considered unique: TRUE - returns values that occur only once. FALSE or omitted (default) - returns all distinct (different) values in the range or array."
msgstr "Ямар утгыг өвөрмөц гэж үзэхийг тодорхойлдог логик утга: ҮНЭН - зөвхөн нэг удаа тохиолдох утгыг буцаана. ХУДАЛ эсвэл орхигдсон (анхдагч) - муж эсвэл массив дахь бүх ялгаатай (өөр) утгыг буцаана."

#. 5Aaqr
#: sc/inc/scfuncs.hrc:4425
msgctxt "ocLET"
msgid "The LET function assigns names to calculation results. This allows storing intermediate calculations, values, or defining names inside a formula. These names only apply within the scope of the LET function."
msgstr "LET функц нь тооцооллын үр дүнд нэр өгдөг. Энэ нь завсрын тооцоолол, утгыг хадгалах эсвэл томьёоны дотор нэрийг тодорхойлох боломжийг олгодог. Эдгээр нэрс нь зөвхөн LET функцийн хүрээнд хамаарна."

#. GTBCS
#: sc/inc/scfuncs.hrc:4426
msgctxt "ocLET"
msgid "Name 1"
msgstr "Нэр 1"

#. BXEhz
#: sc/inc/scfuncs.hrc:4427
msgctxt "ocLET"
msgid "The first name to assign. Must start with a letter. Cannot be the output of a formula or conflict with range syntax."
msgstr "Анхны нэр өгөх. Үсгээр эхлэх ёстой. Томъёоны гаралт эсвэл мужын синтакстай зөрчилдөх боломжгүй."

#. agD98
#: sc/inc/scfuncs.hrc:4428
msgctxt "ocLET"
msgid "Name value "
msgstr "Нэрийн утга "

#. CjEiH
#: sc/inc/scfuncs.hrc:4429
msgctxt "ocLET"
msgid "Name value 1, Name value 2,... The value or calculation to assign to Name."
msgstr "Нэрийн утга 1, Нэрийн утга 2,... Нэрт оноох утга буюу тооцоолол."

#. GCAQK
#: sc/inc/scfuncs.hrc:4430
msgctxt "ocLET"
msgid "Calculation or Name "
msgstr "Тооцоолол эсвэл нэр "

#. uzEFm
#: sc/inc/scfuncs.hrc:4431
msgctxt "ocLET"
msgid "A calculation that uses all names within the LET function. This must be the last argument in the LET function. Or a second Name to assign to a second Name value. If a second Name is specified, Name value 2 and Calculation or Name 3 become required."
msgstr "LET функц доторх бүх нэрийг ашигладаг тооцоо. Энэ нь LET функцийн сүүлчийн аргумент байх ёстой. Эсвэл хоёр дахь Нэрийн утгад өгөх хоёр дахь Нэр. Хэрэв хоёр дахь нэр заасан бол Нэрийн утга 2, Тооцоолол эсвэл Нэр 3 шаардлагатай болно."

#. HbPvG
#: sc/inc/scfuncs.hrc:4437
msgctxt "ocWRAPCOLS"
msgid "Wraps the provided row or column of values by columns after a specified number of elements to form a new array."
msgstr "Шинэ массив үүсгэхийн тулд өгөгдсөн мөр эсвэл утгын баганыг тодорхой тооны элементийн дараа баганаар боож өгнө."

#. ACoFA
#: sc/inc/scfuncs.hrc:4438
msgctxt "ocWRAPCOLS"
msgid "Range"
msgstr "Хүрээ"

#. h3vyV
#: sc/inc/scfuncs.hrc:4439
msgctxt "ocWRAPCOLS"
msgid "the range to wrap."
msgstr "боох хүрээ."

#. nCGAe
#: sc/inc/scfuncs.hrc:4440
msgctxt "ocWRAPCOLS"
msgid "Wrap count"
msgstr "Боодлын тоо"

#. su9gg
#: sc/inc/scfuncs.hrc:4441
msgctxt "ocWRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "Багана бүрийн утгын хамгийн их тоо."

#. sCG9H
#: sc/inc/scfuncs.hrc:4442
msgctxt "ocWRAPCOLS"
msgid "Pad with"
msgstr "бүхий дэвсгэр"

#. FnA6D
#: sc/inc/scfuncs.hrc:4443
msgctxt "ocWRAPCOLS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Товчлох утга. Өгөгдмөл нь #Үгүй."

#. Bc4CS
#: sc/inc/scfuncs.hrc:4449
msgctxt "ocWRAPROWS"
msgid "Wraps the provided row or column of values by rows after a specified number of elements to form a new array."
msgstr "Шинэ массив үүсгэхийн тулд өгөгдсөн мөр эсвэл утгуудын баганыг тодорхой тооны элементийн дараа мөрөөр боож өгнө."

#. UeAts
#: sc/inc/scfuncs.hrc:4450
msgctxt "ocWRAPROWS"
msgid "Range"
msgstr "Хүрээ"

#. Fo4we
#: sc/inc/scfuncs.hrc:4451
msgctxt "ocWRAPROWS"
msgid "the range to wrap."
msgstr "боох хүрээ."

#. B64X3
#: sc/inc/scfuncs.hrc:4452
msgctxt "ocWRAPROWS"
msgid "Wrap count"
msgstr "Боодлын тоо"

#. uGwSk
#: sc/inc/scfuncs.hrc:4453
msgctxt "ocWRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Мөр бүрийн утгын хамгийн их тоо."

#. AJosm
#: sc/inc/scfuncs.hrc:4454
msgctxt "ocWRAPROWS"
msgid "Pad with"
msgstr "бүхий дэвсгэр"

#. C3SiR
#: sc/inc/scfuncs.hrc:4455
msgctxt "ocWRAPROWS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Товчлох утга. Өгөгдмөл нь #Үгүй."

