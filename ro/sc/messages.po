#: sc/inc/scfuncs.hrc:4305
msgctxt "ocHSTACK"
msgid "The first array to append."
msgstr "Prima matrice de adăugat."

#. atWUi
#: sc/inc/scfuncs.hrc:4307
msgctxt "ocHSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer rows, #N/A error will be returned in the additional rows."
msgstr "Matrice 1, Matrice 2,... Următoarele matrice de adăugat. Dacă o matrice are mai puține rânduri, se va returna eroarea #N/A pe rândurile suplimentare."

#. TzKoX
#: sc/inc/scfuncs.hrc:4313
msgctxt "ocVSTACK"
msgid "Appends arrays vertically to create a larger array."
msgstr "Adaugă matrici pe verticală pentru a crea o matrice mai mare."

#. xBs6J
#: sc/inc/scfuncs.hrc:4314 sc/inc/scfuncs.hrc:4316
msgctxt "ocVSTACK"
msgid "Array"
msgstr "Matrice"

#. oLuqo
#: sc/inc/scfuncs.hrc:4315
msgctxt "ocVSTACK"
msgid "The first array to append."
msgstr "Prima matrice de adăugat."

#. 8A7Me
#: sc/inc/scfuncs.hrc:4317
msgctxt "ocVSTACK"
msgid "Array 1, Array 2,... The following arrays to append. If an array has fewer columns, #N/A error will be returned in the additional columns."
msgstr "Matrice 1, Matrice 2,... Următoarele matrice de adăugat. Dacă o matrice are mai puține coloane, se va returna eroarea #N/A în coloanele suplimentare."

#. wiwq5
#: sc/inc/scfuncs.hrc:4323
msgctxt "ocTAKE"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "Returnează un număr specificat de rânduri sau coloane continue de la începutul sau sfârșitul unei matrici."

#. rvJFs
#: sc/inc/scfuncs.hrc:4324
msgctxt "ocTAKE"
msgid "Array"
msgstr "Matrice"

#. tBVU7
#: sc/inc/scfuncs.hrc:4325
msgctxt "ocTAKE"
msgid "The array from which to take rows or columns."
msgstr "Matricea din care se iau rânduri sau coloane."

#. A6Jw7
#: sc/inc/scfuncs.hrc:4326
msgctxt "ocTAKE"
msgid "Rows"
msgstr "Rânduri"

#. VP2FG
#: sc/inc/scfuncs.hrc:4327
msgctxt "ocTAKE"
msgid "The number of rows to take. A negative value takes from the end of the array."
msgstr "Numărul de rânduri care vor fi luate. O valoare negativă ia de la sfârșitul matricei."

#. Bw54q
#: sc/inc/scfuncs.hrc:4328
msgctxt "ocTAKE"
msgid "Columns"
msgstr "Coloane"

#. fGjJX
#: sc/inc/scfuncs.hrc:4329
msgctxt "ocTAKE"
msgid "The number of columns to take. A negative value takes from the end of the array."
msgstr "Numărul de coloane de luat. O valoare negativă ia de la sfârșitul matricei."

#. okoEs
#: sc/inc/scfuncs.hrc:4335
msgctxt "ocTEXTAFTER"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "Returnează textul care apare după un subșir sau un delimitator dat."

#. FiLe9
#: sc/inc/scfuncs.hrc:4336
msgctxt "ocTEXTAFTER"
msgid "Text"
msgstr "Text"

#. f5aTy
#: sc/inc/scfuncs.hrc:4337
msgctxt "ocTEXTAFTER"
msgid "The original text."
msgstr "Textul original."

#. UNUCB
#: sc/inc/scfuncs.hrc:4338
msgctxt "ocTEXTAFTER"
msgid "Delimiter"
msgstr "Delimitator"

#. wtkpC
#: sc/inc/scfuncs.hrc:4339
msgctxt "ocTEXTAFTER"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Delimitatorul. Se pot furniza mai mulți delimitatori."

#. BD2BC
#: sc/inc/scfuncs.hrc:4340
msgctxt "ocTEXTAFTER"
msgid "Instance Number"
msgstr "Număr de instanță"

#. hE87s
#: sc/inc/scfuncs.hrc:4341
msgctxt "ocTEXTAFTER"
msgid "The instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Instanța delimitatorului după care se extrage textul. Valoarea implicită este 1. Un număr negativ începe căutarea de la sfârșit."

#. GYN4y
#: sc/inc/scfuncs.hrc:4342
msgctxt "ocTEXTAFTER"
msgid "Match Mode"
msgstr "Modul de potrivire"

#. pnDDX
#: sc/inc/scfuncs.hrc:4343
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Setează la 1 pentru a efectua o potrivire fără a ține cont de majuscule/minuscule. Valoarea implicită este 0."

#. GG27C
#: sc/inc/scfuncs.hrc:4344
msgctxt "ocTEXTAFTER"
msgid "Match End"
msgstr "Potrivește la sfârșit"

#. 6NMda
#: sc/inc/scfuncs.hrc:4345
msgctxt "ocTEXTAFTER"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Setează la 1 pentru a trata sfârșitul textului ca delimitator. Implicit este 0."

#. xxAE2
#: sc/inc/scfuncs.hrc:4346
msgctxt "ocTEXTAFTER"
msgid "If Not Found"
msgstr "Dacă nu este găsit"

#. yCXFo
#: sc/inc/scfuncs.hrc:4347
msgctxt "ocTEXTAFTER"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Valoarea returnată dacă nu se găsește nicio potrivire. Implicit este #N/A."

#. e3CgH
#: sc/inc/scfuncs.hrc:4353
msgctxt "ocTEXTBEFORE"
msgid "Returns the text that occurs before a given substring or delimiter."
msgstr "Returnează textul care apare înaintea unui subșir sau a unui delimitator dat."

#. fCEkH
#: sc/inc/scfuncs.hrc:4354
msgctxt "ocTEXTBEFORE"
msgid "Text"
msgstr "Text"

#. 7rRBe
#: sc/inc/scfuncs.hrc:4355
msgctxt "ocTEXTBEFORE"
msgid "The original text."
msgstr "Textul original."

#. pD2BF
#: sc/inc/scfuncs.hrc:4356
msgctxt "ocTEXTBEFORE"
msgid "Delimiter"
msgstr "Delimitator"

#. atLy4
#: sc/inc/scfuncs.hrc:4357
msgctxt "ocTEXTBEFORE"
msgid "The delimiter. Multiple delimiters can be supplied."
msgstr "Delimitatorul. Se pot furniza mai mulți delimitatori."

#. a8AQn
#: sc/inc/scfuncs.hrc:4358
msgctxt "ocTEXTBEFORE"
msgid "Instance Number"
msgstr "Număr de instanță"

#. LKDm8
#: sc/inc/scfuncs.hrc:4359
msgctxt "ocTEXTBEFORE"
msgid "The instance of the delimiter before which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "Instanța delimitatorului înaintea căruia se extrage textul. Valoarea implicită este 1. Un număr negativ începe căutarea de la sfârșit."

#. zpBYX
#: sc/inc/scfuncs.hrc:4360
msgctxt "ocTEXTBEFORE"
msgid "Match Mode"
msgstr "Modul de potrivire"

#. oDYnK
#: sc/inc/scfuncs.hrc:4361
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Setează la 1 pentru a efectua o potrivire fără a ține cont de majuscule/minuscule. Valoarea implicită este 0."

#. 3KUNG
#: sc/inc/scfuncs.hrc:4362
msgctxt "ocTEXTBEFORE"
msgid "Match End"
msgstr "Potrivește la sfârșit"

#. VutiR
#: sc/inc/scfuncs.hrc:4363
msgctxt "ocTEXTBEFORE"
msgid "Set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "Setează la 1 pentru a trata sfârșitul textului ca delimitator. Implicit este 0."

#. zBdc8
#: sc/inc/scfuncs.hrc:4364
msgctxt "ocTEXTBEFORE"
msgid "If Not Found"
msgstr "Dacă nu este găsit"

#. Vo5kF
#: sc/inc/scfuncs.hrc:4365
msgctxt "ocTEXTBEFORE"
msgid "The value returned if no match is found. The default is #N/A."
msgstr "Valoarea returnată dacă nu se găsește nicio potrivire. Implicit este #N/A."

#. uy7ox
#: sc/inc/scfuncs.hrc:4371
msgctxt "ocTEXTSPLIT"
msgid "Splits text by a given delimiter to an array of multiple cells."
msgstr "Împarte textul într-o matrice de celule multiple, după un delimitator dat."

#. qHpXB
#: sc/inc/scfuncs.hrc:4372
msgctxt "ocTEXTSPLIT"
msgid "Text"
msgstr "Text"

#. 5HCeW
#: sc/inc/scfuncs.hrc:4373
msgctxt "ocTEXTSPLIT"
msgid "The text to split."
msgstr "Textul de împărțit."

#. iijbx
#: sc/inc/scfuncs.hrc:4374
msgctxt "ocTEXTSPLIT"
msgid "Column Delimiter"
msgstr "Delimitator de coloane"

#. mtWBs
#: sc/inc/scfuncs.hrc:4375
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the columns. Multiple delimiters can be supplied."
msgstr "Textul pentru delimitarea coloanelor. Se pot furniza mai mulți delimitatori."

#. RyAtV
#: sc/inc/scfuncs.hrc:4376
msgctxt "ocTEXTSPLIT"
msgid "Row Delimiter"
msgstr "Delimitator de rânduri"

#. 9CxYK
#: sc/inc/scfuncs.hrc:4377
msgctxt "ocTEXTSPLIT"
msgid "The text to delimit the rows. Multiple delimiters can be supplied."
msgstr "Textul pentru delimitarea rândurilor. Se pot furniza mai mulți delimitatori."

#. CuHLJ
#: sc/inc/scfuncs.hrc:4378
msgctxt "ocTEXTSPLIT"
msgid "Ignore Empty"
msgstr "Ignoră celulele goale"

#. Qrkvd
#: sc/inc/scfuncs.hrc:4379
msgctxt "ocTEXTSPLIT"
msgid "Set to TRUE to ignore consecutive delimiters otherwise it creates an empty cell. The default is FALSE."
msgstr "Setează la TRUE (la ADEVĂRAT) pentru a ignora delimitatorii consecutivi, altfel se creează o celulă goală. Valoarea implicită este FALSE (FALS)."

#. AUSmr
#: sc/inc/scfuncs.hrc:4380
msgctxt "ocTEXTSPLIT"
msgid "Match mode"
msgstr "Modul de potrivire"

#. pjYxd
#: sc/inc/scfuncs.hrc:4381
msgctxt "ocTEXTSPLIT"
msgid "Set to 1 to perform a case-insensitive match. The default is 0."
msgstr "Setează la 1 pentru a efectua o potrivire fără a ține cont de majuscule/minuscule. Valoarea implicită este 0."

#. LsoKk
#: sc/inc/scfuncs.hrc:4382
msgctxt "ocTEXTSPLIT"
msgid "Pad with"
msgstr "Extinde cu"

#. niX3W
#: sc/inc/scfuncs.hrc:4383
msgctxt "ocTEXTSPLIT"
msgid "The value with which to pad. The default is #N/A."
msgstr "Valoarea cu care se completează. Implicit este #N/A."

#. dv6gP
#: sc/inc/scfuncs.hrc:4389
msgctxt "ocTOCOL"
msgid "Transforms an array into a single column."
msgstr "Transformă o matrice într-o singură coloană."

#. A9zBS
#: sc/inc/scfuncs.hrc:4390
msgctxt "ocTOCOL"
msgid "Array"
msgstr "Matrice"

#. x95Ef
#: sc/inc/scfuncs.hrc:4391
msgctxt "ocTOCOL"
msgid "The range or array to return as a single column."
msgstr "Intervalul sau matricea de returnat ca o singură coloană."

#. weBya
#: sc/inc/scfuncs.hrc:4392
msgctxt "ocTOCOL"
msgid "Ignore"
msgstr "Ignoră"

#. 5JhDs
#: sc/inc/scfuncs.hrc:4393
msgctxt "ocTOCOL"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Dacă se ignoră anumite tipuri de valori. 0 sau omis - se păstrează toate valorile (implicit). 1 - se ignoră celulele goale. 2 - se ignoră celulele cu erori. 3 - se ignoră celulele goale și celulele cu erori."

#. DDm6x
#: sc/inc/scfuncs.hrc:4394
msgctxt "ocTOCOL"
msgid "Scan by column"
msgstr "Scanează după coloană"

#. LwBTC
#: sc/inc/scfuncs.hrc:4395
msgctxt "ocTOCOL"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Scanează matricea pe coloană. FALSE (FALS) sau omis (implicit) - matricea este scanată pe rând. TRUE (ADEVĂRAT) - matricea este scanată pe coloană."

#. 89qUq
#: sc/inc/scfuncs.hrc:4401
msgctxt "ocTOROW"
msgid "transforms an array into a single row."
msgstr "transformă o matrice într-un singur rând."

#. GAbkQ
#: sc/inc/scfuncs.hrc:4402
msgctxt "ocTOROW"
msgid "Array"
msgstr "Matrice"

#. w7WXB
#: sc/inc/scfuncs.hrc:4403
msgctxt "ocTOROW"
msgid "The range or array to return as a single row."
msgstr "Intervalul sau matricea de returnat ca un singur rând."

#. GCfA2
#: sc/inc/scfuncs.hrc:4404
msgctxt "ocTOROW"
msgid "Ignore"
msgstr "Ignoră"

#. AnEDD
#: sc/inc/scfuncs.hrc:4405
msgctxt "ocTOROW"
msgid "Whether to ignore certain types of values. 0 or omitted - keep all values (default). 1 - ignore blank cells. 2 - ignore cells with error. 3 - ignore blanks cells and cells with error."
msgstr "Dacă se ignoră anumite tipuri de valori. 0 sau omis - se păstrează toate valorile (implicit). 1 - se ignoră celulele goale. 2 - se ignoră celulele cu erori. 3 - se ignoră celulele goale și celulele cu erori."

#. pDD7V
#: sc/inc/scfuncs.hrc:4406
msgctxt "ocTOROW"
msgid "Scan by column"
msgstr "Scanează după coloană"

#. qxY7a
#: sc/inc/scfuncs.hrc:4407
msgctxt "ocTOROW"
msgid "Scan the array by column. FALSE or omitted (default) - the array is scanned by row. TRUE - the array is scanned by column."
msgstr "Scanează matricea pe coloană. FALSE (FALS) sau omis (implicit) - matricea este scanată pe rând. TRUE (ADEVĂRAT) - matricea este scanată pe coloană."

#. 8p5AW
#: sc/inc/scfuncs.hrc:4413
msgctxt "ocUNIQUE"
msgid "Returns a list of unique values from a range or array."
msgstr "Returnează o listă de valori unice dintr-un interval sau o matrice."

#. LAeWQ
#: sc/inc/scfuncs.hrc:4414
msgctxt "ocUNIQUE"
msgid "Array"
msgstr "Matrice"

#. LHrXJ
#: sc/inc/scfuncs.hrc:4415
msgctxt "ocUNIQUE"
msgid "The range or array from which to return unique values."
msgstr "Intervalul sau matricea din care se returnează valori unice."

#. TBfHR
#: sc/inc/scfuncs.hrc:4416
msgctxt "ocUNIQUE"
msgid "By col"
msgstr "După coloană"

#. xiVEn
#: sc/inc/scfuncs.hrc:4417
msgctxt "ocUNIQUE"
msgid "Logical value indicating how to compare data: TRUE - compares data across columns. FALSE or omitted (default) - compares data across rows."
msgstr "Valoare logică care indică modul de comparare a datelor: TRUE (ADEVĂRAT) - compară datele pe coloane. FALSE (FALS) sau omisă (implicit) - compară datele pe rânduri."

#. GLsJf
#: sc/inc/scfuncs.hrc:4418
msgctxt "ocUNIQUE"
msgid "Uniqueness"
msgstr "Unicitate"

#. ubRgX
#: sc/inc/scfuncs.hrc:4419
msgctxt "ocUNIQUE"
msgid "Logical value that defines what values are considered unique: TRUE - returns values that occur only once. FALSE or omitted (default) - returns all distinct (different) values in the range or array."
msgstr "Valoare logică ce definește ce valori sunt considerate unice: TRUE (ADEVĂRAT) - returnează valori care apar o singură dată. FALSE (FALS) sau omis (implicit) - returnează toate valorile distincte (diferite) din interval sau matrice."

#. 5Aaqr
#: sc/inc/scfuncs.hrc:4425
msgctxt "ocLET"
msgid "The LET function assigns names to calculation results. This allows storing intermediate calculations, values, or defining names inside a formula. These names only apply within the scope of the LET function."
msgstr "Funcția LET atribuie nume rezultatelor calculelor. Aceasta permite stocarea calculelor intermediare, a valorilor sau a numelor definitorii în interiorul unei formule. Aceste nume se aplică numai în domeniul de aplicare al funcției LET."

#. GTBCS
#: sc/inc/scfuncs.hrc:4426
msgctxt "ocLET"
msgid "Name 1"
msgstr "Numele 1"

#. BXEhz
#: sc/inc/scfuncs.hrc:4427
msgctxt "ocLET"
msgid "The first name to assign. Must start with a letter. Cannot be the output of a formula or conflict with range syntax."
msgstr "Primul nume de atribuit. Trebuie să înceapă cu o literă. Nu poate fi rezultatul unei formule și nu poate intra în conflict cu sintaxa intervalului."

#. agD98
#: sc/inc/scfuncs.hrc:4428
msgctxt "ocLET"
msgid "Name value "
msgstr "Valoarea numelui "

#. CjEiH
#: sc/inc/scfuncs.hrc:4429
msgctxt "ocLET"
msgid "Name value 1, Name value 2,... The value or calculation to assign to Name."
msgstr "Valoarea numelui 1, Valoarea numelui 2,... Valoarea sau calculul de atribuit a numelui."

#. GCAQK
#: sc/inc/scfuncs.hrc:4430
msgctxt "ocLET"
msgid "Calculation or Name "
msgstr "Calcul sau nume "

#. uzEFm
#: sc/inc/scfuncs.hrc:4431
msgctxt "ocLET"
msgid "A calculation that uses all names within the LET function. This must be the last argument in the LET function. Or a second Name to assign to a second Name value. If a second Name is specified, Name value 2 and Calculation or Name 3 become required."
msgstr "Un calcul care utilizează toate numele din funcția LET. Acesta trebuie să fie ultimul argument din funcția LET. Sau un al doilea nume de atribuit unei a doua valori nume. Dacă este specificat un al doilea nume, valoarea numelui 2 și calculul sau numele 3 devin obligatorii."

#. HbPvG
#: sc/inc/scfuncs.hrc:4437
msgctxt "ocWRAPCOLS"
msgid "Wraps the provided row or column of values by columns after a specified number of elements to form a new array."
msgstr "Încadrează rândul sau coloana de valori furnizată în coloane după un număr specificat de elemente pentru a forma o matrice nouă."

#. ACoFA
#: sc/inc/scfuncs.hrc:4438
msgctxt "ocWRAPCOLS"
msgid "Range"
msgstr "Interval"

#. h3vyV
#: sc/inc/scfuncs.hrc:4439
msgctxt "ocWRAPCOLS"
msgid "the range to wrap."
msgstr "intervalul de încadrat."

#. nCGAe
#: sc/inc/scfuncs.hrc:4440
msgctxt "ocWRAPCOLS"
msgid "Wrap count"
msgstr "Numărul de încadrări"

#. su9gg
#: sc/inc/scfuncs.hrc:4441
msgctxt "ocWRAPCOLS"
msgid "The maximum number of values for each column."
msgstr "Numărul maxim de valori pentru fiecare coloană."

#. sCG9H
#: sc/inc/scfuncs.hrc:4442
msgctxt "ocWRAPCOLS"
msgid "Pad with"
msgstr "Extinde cu"

#. FnA6D
#: sc/inc/scfuncs.hrc:4443
msgctxt "ocWRAPCOLS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Valoarea cu care se completează. Implicit este #N/A."

#. Bc4CS
#: sc/inc/scfuncs.hrc:4449
msgctxt "ocWRAPROWS"
msgid "Wraps the provided row or column of values by rows after a specified number of elements to form a new array."
msgstr "Încadrează rândul sau coloana de valori furnizată cu rânduri după un număr specificat de elemente pentru a forma o matrice nouă."

#. UeAts
#: sc/inc/scfuncs.hrc:4450
msgctxt "ocWRAPROWS"
msgid "Range"
msgstr "Interval"

#. Fo4we
#: sc/inc/scfuncs.hrc:4451
msgctxt "ocWRAPROWS"
msgid "the range to wrap."
msgstr "intervalul de încadrat."

#. B64X3
#: sc/inc/scfuncs.hrc:4452
msgctxt "ocWRAPROWS"
msgid "Wrap count"
msgstr "Numărul de încadrări"

#. uGwSk
#: sc/inc/scfuncs.hrc:4453
msgctxt "ocWRAPROWS"
msgid "The maximum number of values for each row."
msgstr "Numărul maxim de valori pentru fiecare rând."

#. AJosm
#: sc/inc/scfuncs.hrc:4454
msgctxt "ocWRAPROWS"
msgid "Pad with"
msgstr "Extinde cu"

#. C3SiR
#: sc/inc/scfuncs.hrc:4455
msgctxt "ocWRAPROWS"
msgid "The value with which to pad. The default is #N/A."
msgstr "Valoarea cu care se completează. Implicit este #N/A."

