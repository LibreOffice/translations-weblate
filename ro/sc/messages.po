msgctxt "ocGET_DATE"
msgid "Provides an internal number for the date given."
msgstr "Stabilește un număr intern pentru datele date."

#. DRDD2
#: sc/inc/scfuncs.hrc:183
msgctxt "ocGET_DATE"
msgid "Year"
msgstr "An"

#. q9FWR
#: sc/inc/scfuncs.hrc:184
msgctxt "ocGET_DATE"
msgid "An integer between 1583 and 9956 or 0 and 99 (19xx or 20xx depending on the defined option)."
msgstr "Un întreg cuprins între 1583 și 9956 sau între 0 și 99 (19xx sau 20xx depinzând de opțiunea definită)."

#. 4xLC5
#: sc/inc/scfuncs.hrc:185
msgctxt "ocGET_DATE"
msgid "Month"
msgstr "Lună"

#. tLKRC
#: sc/inc/scfuncs.hrc:186
msgctxt "ocGET_DATE"
msgid "An integer between 1 and 12 representing the month. Values out of bounds will roll over the date, computing the result by adding months and days as necessary."
msgstr "Un număr întreg între 1 și 12 care reprezintă luna. Valorile în afara limitelor se vor acumula peste dată, calculându-se rezultatul adăugând luni și zile, după cum este necesar."

#. MGV7P
#: sc/inc/scfuncs.hrc:187
msgctxt "ocGET_DATE"
msgid "Day"
msgstr "Zi"

#. ECDBG
#: sc/inc/scfuncs.hrc:188
msgctxt "ocGET_DATE"
msgid "An integer between 1 and 31 representing the day of the month. Values out of bounds will roll over the date, computing the result by adding months and days as necessary."
msgstr "Un număr întreg între 1 și 31 care reprezintă ziua lunii. Valorile în afara limitelor se vor acumula peste dată, calculându-se rezultatul adăugând luni și zile, după cum este necesar."

#. JUonj
#: sc/inc/scfuncs.hrc:194
