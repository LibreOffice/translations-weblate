msgctxt ""
"01170103.xhp\n"
"par_id3152940\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>Key pressed</emph> event occurs when the user presses any key while the control has the focus.</ahelp> This event may be linked to a macro for checking entries."
