#: 01170103.xhp
msgctxt ""
"01170103.xhp\n"
"par_id3159252\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>When losing focus</emph> event takes place if a control field loses the <link href=\"text/shared/00/00000005.xhp#form_focus\">focus</link>.</ahelp>"
msgstr ""

#. JkyEm
#: 01170103.xhp
msgctxt ""
"01170103.xhp\n"
"hd_id3147287\n"
"help.text"
msgid "Key pressed"
