#~ "help.text"
#~ msgid "<ahelp hid=\"cui/ui/dimensionlinestabpage/MTR_FLD_HELPLINE_OVERHANG\">Specifies the length of the left and right guides starting at the baseline (line distance = 0). Positive values extend the guides above the baseline and negative values extend the guides below the baseline.</ahelp>"
#~ msgstr "<ahelp hid=\"cui/ui/dimensionlinestabpage/MTR_FLD_HELPLINE_OVERHANG\">бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢвҖӢвҖӢбһ”бҹ’бһҡбһңбҹӮбһ„вҖӢбһ“бҹғвҖӢбһҳбһӮбҹ’бһӮбһ»бһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚвҖӢбһҶбҹ’бһңбҹҒбһ„вҖӢ бһ“бһ·бһ„вҖӢбһҹбҹ’бһҸбһ¶бҹҶвҖӢ бһҠбҹӮбһӣвҖӢвҖӢбһ…бһ¶бһ”бҹӢвҖӢбһ•бҹ’бһҸбһҫбһҳвҖӢбһ“бҹ…вҖӢвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһҳбһјбһӣбһҠбҹ’бһӢбһ¶бһ“ вҖӢ(бһ…бһҳбҹ’бһ„бһ¶бһҷвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢ = бҹ ) бҹ” бһҸбһҳбҹ’бһӣбҹғвҖӢбһңбһ·бһҮбҹ’бһҮбһҳбһ¶бһ“вҖӢбһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҳбһӮбҹ’бһӮбһ»бһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚвҖӢбһҒбһ¶бһ„вҖӢбһӣбһҫвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһҳбһјбһӣбһҠбҹ’бһӢбһ¶бһ“вҖӢ бһ“бһ·бһ„ бһҸбһҳбҹ’бһӣбҹғвҖӢбһўбһңбһ·бһҮбҹ’бһҮбһҳбһ¶бһ“вҖӢбһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҳбһӮбҹ’бһӮбһ»бһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚвҖӢбһҒбһ¶бһ„вҖӢбһҖбҹ’бһҡбҹ„бһҳвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһҳбһјбһӣбһҠбҹ’бһӢбһ¶бһ“ бҹ”</ahelp>"

#~ msgctxt ""
#~ "05150000.xhp\n"
#~ "par_id3159203\n"
#~ "help.text"
#~ msgid "<ahelp hid=\"cui/ui/dimensionlinestabpage/MTR_FLD_HELPLINE_DIST\">Specifies the length of the right and left guides starting at the dimension line. Positive values extend the guides above the dimension line and negative values extend the guides below the dimension line.</ahelp>"
#~ msgstr "<ahelp hid=\"cui/ui/dimensionlinestabpage/MTR_FLD_HELPLINE_DIST\">вҖӢбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢвҖӢвҖӢбһ”бҹ’бһҡбһңбҹӮбһ„вҖӢбһҡбһ”бһҹбҹӢвҖӢбһҳбһӮбҹ’бһӮбһ»вҖӢбһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚвҖӢвҖӢбһҹбҹ’бһҸбһ¶бҹҶвҖӢ бһ“бһ·бһ„ бһҶбҹ’бһңбҹҒбһ„вҖӢ бһҠбҹӮбһӣвҖӢбһ…бһ¶бһ”бҹӢвҖӢбһ•бҹ’бһҸбһҫбһҳвҖӢбһ“бҹ…вҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһңбһ·бһҳбһ¶бһҸбҹ’бһҡвҖӢВ бҹ” вҖӢбһҸбһҳбҹ’бһӣбҹғвҖӢбһңбһ·бһҮбҹ’бһҮбһҳбһ¶бһ“вҖӢбһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҳбһӮбҹ’бһӮбһ»бһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚбһҒбһ¶бһ„вҖӢбһӣбһҫвҖӢвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһңбһ·бһҳбһ¶бһҸбҹ’бһҡвҖӢ бһ“бһ·бһ„ бһҸбһҳбҹ’бһӣбҹғвҖӢбһўбһңбһ·бһҮбҹ’бһҮбһҳбһ¶бһ“вҖӢбһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһҳбһӮбҹ’бһӮбһ»бһ‘бҹ’бһ‘бҹҒбһҹбһҖбҹҚвҖӢвҖӢбһҒбһ¶бһ„вҖӢбһҖбҹ’бһҡбҹ„бһҳвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһңбһ·бһҳбһ¶бһҸбҹ’бһҡвҖӢВ бҹ”</ahelp>"

