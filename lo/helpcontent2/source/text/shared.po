msgstr "<image id=\"img_id3154201\" src=\"cmd/lc_bezieredge.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3154201\">ໄອຄອນຈຸດມຸມ</alt></image>"

