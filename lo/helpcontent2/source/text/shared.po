msgstr "ເມນູເຄື່ອງມືຫຼັກ"

#. 7jd7X
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"hd_id931695907853611\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/shared/main_tools.xhp\">Tools</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/shared/main_tools.xhp\">ເຄື່ອງມື</link></variable>"

#. 9Gkzv
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"par_id3147258\n"
"help.text"
msgid "<ahelp hid=\".\">Contains spelling tools, redact options, mail merge wizard, macros, development tools, extension manager, as well as tools for configuring and customizing menus, and setting program preferences.</ahelp>"
msgstr "<ahelp hid=\".\">ປະກອບມີເຄື່ອງມືການກວດສອບຕົວສະກົດ, ຕົວເລືອກການປົກປິດຂໍ້ຄວາມ, ຕົວຊ່ວຍສ້າງຈົດໝາຍວຽນ, ມາກໂຄຣ, ເຄື່ອງມືນັກພັດທະນາ, ຕົວຈັດການສ່ວນຂະຫຍາຍ, ລວມທັງເຄື່ອງມືສຳລັບການຕັ້ງຄ່າ ແລະ ປັບແຕ່ງເມນູ, ແລະ ການຕັ້ງຄ່າຄວາມມັກຂອງໂປຣແກຣມ.</ahelp>"

#. Cqcd2
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"par_id3150440\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>Tools</emph> menu contains commands to check spelling, to trace sheet references, to find mistakes and to define scenarios, as well as tools for configuring menus, and setting program preferences.</ahelp>"
msgstr "<ahelp hid=\".\">ເມນູ <emph>ເຄື່ອງມື</emph> ປະກອບມີຄຳສັ່ງເພື່ອການກວດສອບຕົວສະກົດ, ເພື່ອຕິດຕາມການອ້າງອີງຊີດ, ເພື່ອຄົ້ນຫາຂໍ້ຜິດພາດ ແລະ ກຳນົດສະຖານະການ, ລວມທັງເຄື່ອງມືສຳລັບການຕັ້ງຄ່າເມນູ, ແລະ ການຕັ້ງຄ່າຄວາມມັກຂອງໂປຣແກຣມ.</ahelp>"

#. 8RKCG
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"par_id3155064\n"
"help.text"
msgid "<ahelp hid=\".\">Contains spelling tools, media player, color replacer, presentation minimizer and tools for configuring menus, and setting program preferences.</ahelp>"
msgstr "<ahelp hid=\".\">ປະກອບມີເຄື່ອງມືການກວດສອບຕົວສະກົດ, ເຄື່ອງຫຼິ້ນສື່, ຕົວແທນທີ່ສີ, ຕົວຫຼຸດຂະໜາດການນຳສະເໜີ ແລະ ເຄື່ອງມືສຳລັບການຕັ້ງຄ່າເມນູ, ແລະ ການຕັ້ງຄ່າຄວາມມັກຂອງໂປຣແກຣມ.</ahelp>"

#. RVeBo
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"par_id3156443\n"
"help.text"
msgid "This menu provides tools for $[officename] Draw as well as access to language and system settings."
msgstr "ເມນູນີ້ໃຫ້ເຄື່ອງມືສຳລັບ $[officename] Draw ລວມທັງການເຂົ້າເຖິງການຕັ້ງຄ່າພາສາ ແລະ ລະບົບ."

#. iRaXX
#: main_tools.xhp
msgctxt ""
"main_tools.xhp\n"
"par_id31695910499529\n"
"help.text"
msgid "Choose <menuitem>Tools</menuitem>."
msgstr "ເລືອກ <menuitem>ເຄື່ອງມື</menuitem>."

#. NJGJa
#: need_help.xhp
msgctxt ""
"need_help.xhp\n"
"tit\n"
"help.text"
msgid "We Need Your Help"
msgstr "ພວກເຮົາຕ້ອງການຄວາມຊ່ວຍເຫຼືອຈາກທ່ານ"

#. Pw8Hr
#: need_help.xhp
msgctxt ""
"need_help.xhp\n"
"hd_id1000010\n"
"help.text"
msgid "This help page needs further work for correctness and completion. Please join the LibreOffice project and help us out to write the missing information. Visit our <link href=\"https://documentation.libreoffice.org/en/join-community/update-help-contents\"><emph>web page on writing Help contents</emph></link>."
msgstr "ໜ້າຊ່ວຍເຫຼືອນີ້ຍັງຕ້ອງການການປັບປຸງເພື່ອຄວາມຖືກຕ້ອງ ແລະ ສົມບູນ. ກະລຸນາເຂົ້າຮ່ວມໂຄງການ LibreOffice ແລະ ຊ່ວຍພວກເຮົາຂຽນຂໍ້ມູນທີ່ຍັງຂາດຫາຍໄປ. ເຂົ້າເບິ່ງ <link href=\"https://documentation.libreoffice.org/en/join-community/update-help-contents\"><emph>ໜ້າເວັບກ່ຽວກັບການຂຽນເນື້ອຫາຊ່ວຍເຫຼືອ</emph></link> ຂອງພວກເຮົາ."
