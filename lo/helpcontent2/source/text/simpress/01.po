msgctxt ""
"03150100.xhp\n"
"tit\n"
"help.text"
msgid "Master Slide"
msgstr "ສະໄລ້ຕົ້ນແບບ"

#. DDEYo
#: 03150100.xhp
msgctxt ""
"03150100.xhp\n"
