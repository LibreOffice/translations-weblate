msgctxt ""
"04110100.xhp\n"
"par_id3156448\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/insertslidesdialog/links\">Inserts a file or some file elements as a link that is automatically updated when the source file is modified.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/insertslidesdialog/links\">ແຊກໄຟລ໌ ຫຼື ອົງປະກອບບາງຢ່າງຂອງໄຟລ໌ເປັນລິ້ງ ເຊິ່ງຈະຖືກອັບເດດໂດຍອັດຕະໂນມັດເມື່ອໄຟລ໌ຕົ້ນສະບັບມີການປ່ຽນແປງ.</ahelp>"

#. ZkofH
