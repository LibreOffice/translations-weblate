msgctxt ""
"06050000.xhp\n"
"par_id3145386\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/dockinganimation/prev\">Plays the animation backwards.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/dockinganimation/prev\">ຫຼິ້ນອານິເມຊັນຖອຍຫຼັງ.</ahelp>"

