"help.text"
msgid "Presentation Mode"
msgstr "ໂໝດການນຳສະເໜີ"

#. zmuAH
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3149354\n"
"help.text"
msgid "Select the slide show type."
msgstr "ເລືອກປະເພດການສາຍສະໄລ້."

#. Vt9FD
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3150482\n"
"help.text"
msgid "Full screen"
msgstr "ເຕັມຈໍ"

#. KE3kd
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3148730\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/default\">A full screen slide is shown.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/default\">ສະແດງສະໄລ້ແບບເຕັມໜ້າຈໍ.</ahelp>"

#. 5W6rK
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3153034\n"
"help.text"
msgid "In a window"
msgstr "ໃນໜ້າຕ່າງ"

#. hVbaV
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3155257\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/window\">Slide show runs in the $[officename] program window.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/window\">ການສາຍສະໄລ້ຈະເຮັດວຽກໃນໜ້າຕ່າງໂປຣແກຣມ $[officename].</ahelp>"

#. LjMiE
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3145593\n"
"help.text"
msgid "Loop and repeat after"
msgstr "ວົນຊ້ຳ ແລະ ເລີ່ມໃໝ່ຫຼັງຈາກ"

#. CVq2y
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3149509\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/auto\">Restarts the slide show after the pause interval you specify. A pause slide is displayed between the final slide and the start slide. Press the Esc key to stop the show.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/auto\">ເລີ່ມການສາຍສະໄລ້ໃໝ່ຫຼັງຈາກໄລຍະເວລາຢຸດພັກທີ່ທ່ານກຳນົດ. ສະໄລ້ຢຸດພັກຈະຖືກສະແດງລະຫວ່າງສະໄລ້ສຸດທ້າຍ ແລະ ສະໄລ້ເລີ່ມຕົ້ນ. ກົດປຸ່ມ Esc ເພື່ອຢຸດການສາຍ.</ahelp>"

#. QyefK
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3150862\n"
"help.text"
msgid "Duration of pause"
msgstr "ໄລຍະເວລາຢຸດພັກ"

#. VJGEd
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3153112\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/pauseduration\">Enter the duration of the pause before the slide show is repeated. If you enter zero, the show restarts immediately without showing a pause slide.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/pauseduration\">ປ້ອນໄລຍະເວລາຢຸດພັກກ່ອນທີ່ການສາຍສະໄລ້ຈະເລີ່ມໃໝ່. ຖ້າທ່ານປ້ອນເລກສູນ, ການສາຍຈະເລີ່ມໃໝ່ທັນທີໂດຍບໍ່ສະແດງສະໄລ້ຢຸດພັກ.</ahelp>"

#. ikQ4w
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3166420\n"
"help.text"
msgid "Show logo"
msgstr "ສະແດງໂລໂກ້"

#. yVeeF
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3154501\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/showlogo\">Displays the $[officename] logo on the pause slide.</ahelp> The logo cannot be exchanged."
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/showlogo\">ສະແດງໂລໂກ້ $[officename] ໃນສະໄລ້ຢຸດພັກ.</ahelp> ໂລໂກ້ນີ້ບໍ່ສາມາດປ່ຽນແປງໄດ້."

#. sWkYG
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3150130\n"
"help.text"
msgid "Presentation Options"
msgstr "ຕົວເລືອກການນຳສະເໜີ"

#. ALZps
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3149883\n"
"help.text"
msgid "Disable automatic change of slide"
msgstr "ປິດການປ່ຽນສະໄລ້ອັດຕະໂນມັດ"

#. gjhEC
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3147373\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/manualslides\">Slides never change automatically when this box is selected.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/manualslides\">ສະໄລ້ຈະບໍ່ປ່ຽນອັດຕະໂນມັດເມື່ອເລືອກຊ່ອງນີ້.</ahelp>"

#. VzERx
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3152478\n"
"help.text"
msgid "Change slides by clicking on background"
msgstr "ປ່ຽນສະໄລ້ໂດຍການຄລິກໃສ່ພື້ນຫຼັງ"

#. 6GKwg
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3156305\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/changeslidesbyclick\">Advances to the next slide when you click on the background of a slide.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/changeslidesbyclick\">ເລື່ອນໄປສະໄລ້ຖັດໄປເມື່ອທ່ານຄລິກໃສ່ພື້ນຫຼັງຂອງສະໄລ້.</ahelp>"

#. oVyJ6
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3155439\n"
"help.text"
msgid "Mouse pointer visible"
msgstr "ສະແດງຕົວຊີ້ເມົາສ໌"

#. WgACr
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3150272\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/pointervisible\">Shows the mouse pointer during a slide show.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/pointervisible\">ສະແດງຕົວຊີ້ເມົາສ໌ໃນລະຫວ່າງການສາຍສະໄລ້.</ahelp>"

#. Y3RTU
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3150570\n"
"help.text"
msgid "Mouse pointer as pen"
msgstr "ໃຊ້ຕົວຊີ້ເມົາສ໌ເປັນບິກ"

#. GWCTF
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3150665\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/pointeraspen\">Changes the mouse pointer to a pen which you can use to draw on slides during the presentation.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/pointeraspen\">ປ່ຽນຕົວຊີ້ເມົາສ໌ເປັນບິກ ເຊິ່ງທ່ານສາມາດໃຊ້ແຕ້ມໃສ່ສະໄລ້ໃນລະຫວ່າງການນຳສະເໜີ.</ahelp>"

#. YpTZ4
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3150475\n"
"help.text"
msgid "Anything you write with the pen will appear in your slides after exiting the slideshow. The properties of the pen can be changed by choosing the <emph>Pen Thickness</emph> or <emph>Change pen Color</emph> command in the context menu of the running slide show."
msgstr "ສິ່ງໃດກໍຕາມທີ່ທ່ານຂຽນດ້ວຍບິກຈະປະກົດຢູ່ໃນສະໄລ້ຂອງທ່ານຫຼັງຈາກອອກຈາກການສາຍສະໄລ້. ສາມາດປ່ຽນຄຸນສົມບັດຂອງບິກໄດ້ໂດຍການເລືອກຄຳສັ່ງ <emph>ຄວາມໜາຂອງບິກ</emph> ຫຼື <emph>ປ່ຽນສີບິກ</emph> ໃນເມນູລັດຂອງການສາຍສະໄລ້ທີ່ກຳລັງເຮັດວຽກຢູ່."

#. wxPk5
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3153718\n"
"help.text"
msgid "Enable animated images"
msgstr "ເປີດໃຊ້ຮູບພາບເຄື່ອນໄຫວ"

#. FwfCe
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3083445\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/animationsallowed\">Displays all frames of animated GIF files during the slide show.</ahelp> If this option is not selected, only the first frame of an animated GIF file is displayed."
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/animationsallowed\">ສະແດງທຸກເຟຣມຂອງໄຟລ໌ GIF ເຄື່ອນໄຫວໃນລະຫວ່າງການສະແດງສະໄລ້.</ahelp> ຖ້າບໍ່ເລືອກຕົວເລືອກນີ້, ຈະສະແດງສະເພາະເຟຣມທຳອິດຂອງໄຟລ໌ GIF ເຄື່ອນໄຫວເທົ່ານັ້ນ."

#. mVrvA
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3150960\n"
"help.text"
msgid "Keep presentation always on top"
msgstr "ໃຫ້ການນຳສະເໜີຢູ່ເທິງສຸດສະເໝີ"

#. batkj
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3150764\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/presentationdialog/alwaysontop\">The $[officename] window remains on top during the presentation. No other program will show its window in front of your presentation.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/presentationdialog/alwaysontop\">ໜ້າຕ່າງ $[officename] ຈະຢູ່ເທິງສຸດໃນລະຫວ່າງການນຳສະເໜີ. ຈະບໍ່ມີໂປຣແກຣມອື່ນສະແດງໜ້າຕ່າງຂຶ້ນມາບັງໜ້າການນຳສະເໜີຂອງທ່ານ.</ahelp>"

#. T6F5S
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id851716226303008\n"
"help.text"
msgid "Live-mode slideshow editing"
msgstr "ການແກ້ໄຂການສະແດງສະໄລ້ໃນໂໝດສົດ (Live-mode)"

#. xoann
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id511716226331936\n"
"help.text"
msgid "When this box is checked the Impress main document window remains active during the presentation. Users can continue to edit slide content. Changes will be reflected in the running slideshow."
msgstr "ເມື່ອໝາຍຕິກໃສ່ຫ້ອງນີ້ ໜ້າຕ່າງຫຼັກຂອງ Impress ຈະຍັງຄົງເຮັດວຽກຢູ່ລະຫວ່າງການນຳສະເໜີ. ຜູ້ໃຊ້ສາມາດແກ້ໄຂເນື້ອໃນສະໄລ້ຕໍ່ໄປໄດ້. ການປ່ຽນແປງຈະສະແດງຜົນໃນການສະແດງສະໄລ້ທີ່ກຳລັງເຮັດວຽກຢູ່."

#. dnXCx
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id6086611\n"
"help.text"
msgid "Display"
msgstr "ຈໍສະແດງຜົນ"

#. CyE4H
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id5446943\n"
"help.text"
msgid "By default the primary display is used for slide show mode. If the current desktop is displayed on more than one display, you can select which display to use for full screen slide show mode. If the current desktop spans only one display, or if the multi display feature is not supported on the current system, you cannot select another display."
msgstr "ຕາມຄ່າມາດຕະຖານແມ່ນຈະໃຊ້ຈໍສະແດງຜົນຫຼັກສຳລັບໂໝດສະແດງສະໄລ້. ຖ້າເດັສທັອບປັດຈຸບັນສະແດງຜົນໃນຫຼາຍຈໍ, ທ່ານສາມາດເລືອກໄດ້ວ່າຈະໃຊ້ຈໍໃດສຳລັບການສະແດງສະໄລ້ແບບເຕັມຈໍ. ຖ້າເດັສທັອບປັດຈຸບັນມີພຽງຈໍດຽວ ຫຼື ລະບົບບໍ່ຮອງຮັບຄຸນສົມບັດຫຼາຍຈໍ, ທ່ານຈະບໍ່ສາມາດເລືອກຈໍອື່ນໄດ້."

#. tksDe
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id2321543\n"
"help.text"
msgid "These settings are saved in the user configuration and not inside the document."
msgstr "ການຕັ້ງຄ່າເຫຼົ່ານີ້ຈະຖືກບັນທຶກໄວ້ໃນການຕັ້ງຄ່າຂອງຜູ້ໃຊ້ ແລະ ບໍ່ໄດ້ບັນທຶກໄວ້ພາຍໃນເອກະສານ."

#. 3nodF
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id4962309\n"
"help.text"
msgid "Presentation display"
msgstr "ຈໍສະແດງຜົນການນຳສະເໜີ"

#. tQFsf
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id5168919\n"
"help.text"
msgid "<ahelp hid=\".\">Select a display to use for full screen slide show mode.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຈໍສະແດງຜົນທີ່ຈະໃຊ້ສຳລັບໂໝດສະແດງສະໄລ້ແບບເຕັມຈໍ.</ahelp>"

#. uiCco
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id4846339\n"
"help.text"
msgid "If the system allows the user to span a window over all available displays, you can also select \"All displays\". In this case the presentation is spanned over all available displays."
msgstr "ຖ້າລະບົບອະນຸຍາດໃຫ້ຜູ້ໃຊ້ຂະຫຍາຍໜ້າຕ່າງໄປທຸກຈໍທີ່ມີຢູ່, ທ່ານຍັງສາມາດເລືອກ \"ທຸກຈໍສະແດງຜົນ\" ໄດ້. ໃນກໍລະນີນີ້ ການນຳສະເໜີຈະຖືກຂະຫຍາຍໄປທົ່ວທຸກຈໍທີ່ມີຢູ່."

#. 5dDNP
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id801700814088862\n"
"help.text"
msgid "Presenter console"
msgstr "ຄອນໂຊນຜູ້ນຳສະເໜີ"

#. Mjgig
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id811700817391617\n"
"help.text"
msgid "The <link href=\"text/simpress/guide/presenter_console.xhp\"><emph>Presenter console</emph></link> provides extra controls and tools useful to the presenter. You can choose to use it in windowed or full screen mode, or disable it entirely."
msgstr "<link href=\"text/simpress/guide/presenter_console.xhp\"><emph>ຄອນໂຊນຜູ້ນຳສະເໜີ</emph></link> ມີເຄື່ອງມື ແລະ ປຸ່ມຄວບຄຸມເພີ່ມເຕີມທີ່ເປັນປະໂຫຍດສຳລັບຜູ້ນຳສະເໜີ. ທ່ານສາມາດເລືອກໃຊ້ມັນໃນໂໝດໜ້າຕ່າງ ຫຼື ແບບເຕັມຈໍ, ຫຼື ປິດການໃຊ້ມັນໄປເລີຍກໍໄດ້."

#. ffBZD
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id841700817775313\n"
"help.text"
msgid "Show navigation bar"
msgstr "ສະແດງແຖບນຳທາງ"

#. N27Mg
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id971700817802604\n"
"help.text"
msgid "The navigation bar allows the presenter to control the presentation with buttons at the bottom left of the screen, either with the mouse pointer or directly on display if a touch screen is used."
msgstr "ແຖບນຳທາງຊ່ວຍໃຫ້ຜູ້ນຳສະເໜີສາມາດຄວບຄຸມການນຳສະເໜີດ້ວຍປຸ່ມຕ່າງໆຢູ່ທາງລຸ່ມເບື້ອງຊ້າຍຂອງໜ້າຈໍ, ບໍ່ວ່າຈະໃຊ້ເມົ້າ ຫຼື ໃຊ້ການສຳຜັດໂດຍກົງໃນກໍລະນີທີ່ໃຊ້ຈໍສຳຜັດ."

#. QACFB
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id221716227647562\n"
"help.text"
msgid "Button size"
msgstr "ຂະໜາດປຸ່ມ"

#. 55gkP
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id851716227648861\n"
"help.text"
msgid "Select the size of the buttons in the navigation bar from the dropdown."
msgstr "ເລືອກຂະໜາດຂອງປຸ່ມໃນແຖບນຳທາງຈາກລາຍການເລືອກລົງ."

#. VfvEF
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id591700817455799\n"
"help.text"
msgid "Remote control"
msgstr "ການຄວບຄຸມໄລຍະໄກ"

#. Be9xm
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id141700819107315\n"
"help.text"
msgid "Enable remote control"
msgstr "ເປີດໃຊ້ການຄວບຄຸມໄລຍະໄກ"

#. 95kM6
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3155963\n"
"help.text"
msgid "Specifies that you want to enable Bluetooth remote control while Impress is running. Unmark<emph> Enable remote control</emph> to disable remote controlling."
msgstr "ກຳນົດວ່າທ່ານຕ້ອງການເປີດໃຊ້ການຄວບຄຸມໄລຍະໄກຜ່ານ Bluetooth ໃນຂະນະທີ່ Impress ກຳລັງເຮັດວຽກຢູ່. ຍົກເລີກການໝາຍຕິກ <emph>ເປີດໃຊ້ການຄວບຄຸມໄລຍະໄກ</emph> ເພື່ອປິດການຄວບຄຸມໄລຍະໄກ."

#. YEnzg
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id241716224473837\n"
"help.text"
msgid "Download app"
msgstr "ດາວໂຫຼດແອັບ"

#. 2tZxn
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id941700818283800\n"
"help.text"
msgid "A link directs you to the <link href=\"https://hub.libreoffice.org/impress-remote\">available options to install the application</link> on your device."
msgstr "ລິງກ໌ນີ້ຈະນຳທ່ານໄປຫາ <link href=\"https://hub.libreoffice.org/impress-remote\">ຕົວເລືອກຕ່າງໆທີ່ມີຢູ່ເພື່ອຕິດຕັ້ງແອັບພລິເຄຊັນ</link> ລົງໃນອຸປະກອນຂອງທ່ານ."

#. JRgf9
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id471716213316781\n"
"help.text"
msgid "Enable insecure WiFi connections"
msgstr "ເປີດໃຊ້ການເຊື່ອມຕໍ່ WiFi ທີ່ບໍ່ປອດໄພ"

#. K9xgv
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id741716213318479\n"
"help.text"
msgid "If this box is checked, %PRODUCTNAME Impress enables insecure and unencrypted connections via IP on all interfaces."
msgstr "ຖ້າໝາຍຕິກໃສ່ຫ້ອງນີ້, %PRODUCTNAME Impress ຈະເປີດໃຊ້ການເຊື່ອມຕໍ່ຜ່ານ IP ທີ່ບໍ່ມີຄວາມປອດໄພ ແລະ ບໍ່ມີການເຂົ້າລະຫັດในທຸກອິນເຕີເຟສ."

#. SVwum
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id741716213318480\n"
"help.text"
msgid "You can only enable insecure WiFi connections if remote control is enabled."
msgstr "ທ່ານສາມາດເປີດໃຊ້ການເຊື່ອມຕໍ່ WiFi ທີ່ບໍ່ປອດໄພໄດ້ກໍຕໍ່ເມື່ອເປີດການຄວບຄຸມໄລຍະໄກແລ້ວເທົ່ານັ້ນ."

#. 9CBTY
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id171716213320419\n"
"help.text"
msgid "Enabling insecure WiFi connections is not recommended in public settings."
msgstr "ບໍ່ແນະນຳໃຫ້ເປີດໃຊ້ການເຊື່ອມຕໍ່ WiFi ທີ່ບໍ່ປອດໄພໃນສະຖານທີ່ສາທາລະນະ."

#. w2iqM
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"tit\n"
"help.text"
msgid "Custom Slide Shows"
msgstr "ການສະແດງສະໄລ້ທີ່ກຳນົດເອງ"

#. BB4Cs
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3154659\n"
"help.text"
msgid "<variable id=\"CustomShow_h1\"><link href=\"text/simpress/01/06100000.xhp\">Custom Slide Shows</link></variable>"
msgstr "<variable id=\"CustomShow_h1\"><link href=\"text/simpress/01/06100000.xhp\">ການສະແດງສະໄລ້ທີ່ກຳນົດເອງ</link></variable>"

#. EB558
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3149207\n"
"help.text"
msgid "<variable id=\"indipraesent\"><ahelp hid=\".uno:CustomShowDialog\">Defines a custom slide show using slides within the current presentation. You can then pick slides to meet the needs of your audience. You can create as many custom slide shows as you want.</ahelp>  </variable>"
msgstr "<variable id=\"indipraesent\"><ahelp hid=\".uno:CustomShowDialog\">ກຳນົດການສະແດງສະໄລ້ທີ່ກຳນົດເອງໂດຍໃຊ້ສະໄລ້ຕ່າງໆພາຍໃນການນຳສະເໜີປັດຈຸບັນ. ຈາກນັ້ນທ່ານສາມາດເລືອກສະໄລ້ໃຫ້ກົງກັບຄວາມຕ້ອງການຂອງຜູ້ຊົມ. ທ່ານສາມາດສ້າງການສະແດງສະໄລ້ທີ່ກຳນົດເອງໄດ້ຫຼາຍເທົ່າທີ່ຕ້ອງການ.</ahelp> </variable>"

#. YgWfS
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id641634164174393\n"
"help.text"
msgid "Read the help page <link href=\"text/simpress/guide/individual.xhp#individual\">Creating a Custom Slide Show</link> to learn more about how to set up your own custom slide shows."
msgstr "ອ່ານໜ້າຊ່ວຍເຫຼືອ <link href=\"text/simpress/guide/individual.xhp#individual\">ການສ້າງການສະແດງສະໄລ້ທີ່ກຳນົດເອງ</link> ເພື່ອຮຽນຮູ້ເພີ່ມເຕີມກ່ຽວກັບວິທີຕັ້ງຄ່າການສະແດງສະໄລ້ທີ່ກຳນົດເອງຂອງທ່ານເອງ."

#. JyjJt
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3155530\n"
"help.text"
msgid "List of custom slide shows"
msgstr "ລາຍການຂອງການສະແດງສະໄລ້ທີ່ກຳນົດເອງ"

#. 9WeMN
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3156449\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/customslideshows/customshowlist\">Lists the custom slide shows that are available in the document.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/customslideshows/customshowlist\">ສະແດງລາຍການການສະແດງສະໄລ້ທີ່ກຳນົດເອງທີ່ມີຢູ່ໃນເອກະສານ.</ahelp>"

#. T3UBF
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3149408\n"
"help.text"
msgid "To create a custom slide show, click <emph>New</emph>."
msgstr "ເພື່ອສ້າງການສະແດງສະໄລ້ທີ່ກຳນົດເອງ, ໃຫ້ຄລິກ <emph>ໃໝ່</emph>."

#. tmqBb
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3148604\n"
"help.text"
msgid "To run a custom slide show:"
msgstr "ເພື່ອເລີ່ມການສະແດງສະໄລ້ທີ່ກຳນົດເອງ:"

#. KDQG6
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3153250\n"
"help.text"
msgid "Select a custom slide show from the list."
msgstr "ເລືອກການສະແດງສະໄລ້ທີ່ກຳນົດເອງຈາກລາຍການ."

#. yFmBx
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3159230\n"
"help.text"
msgid "Click <emph>Start</emph>."
msgstr "ຄລິກ <emph>ເລີ່ມ</emph>."

#. jLADH
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3153808\n"
"help.text"
msgid "<link href=\"text/simpress/01/06100100.xhp\">New</link>"
msgstr "<link href=\"text/simpress/01/06100100.xhp\">ໃໝ່</link>"

#. kyB6T
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3153073\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. gEwnF
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3150431\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/customslideshows/edit\"><link href=\"text/simpress/01/06100100.xhp\">Add, remove or reorder</link> slides as well as change the name of the selected custom slide show.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/customslideshows/edit\"><link href=\"text/simpress/01/06100100.xhp\">ເພີ່ມ, ລຶບ ຫຼື ຈັດລຳດັບໃໝ່</link> ຂອງສະໄລ້ ລວມທັງປ່ຽນຊື່ຂອງການສະແດງສະໄລ້ທີ່ກຳນົດເອງທີ່ເລືອກໄວ້.</ahelp>"

#. ZbCU7
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3151393\n"
"help.text"
msgid "Copy"
msgstr "ສຳເນົາ"

#. CYBcT
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3145236\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/customslideshows/copy\">Creates a copy of the selected custom slide show. You can modify the name of the show by clicking <emph>Edit</emph>.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/customslideshows/copy\">ສ້າງສຳເນົາຂອງການສະແດງສະໄລ້ທີ່ກຳນົດເອງທີ່ເລືອກໄວ້. ທ່ານສາມາດແກ້ໄຂຊື່ຂອງການສະແດງໄດ້ໂດຍການຄລິກ <emph>ແກ້ໄຂ</emph>.</ahelp>"

#. 5ARCC
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3153121\n"
"help.text"
msgid "Start"
msgstr "ເລີ່ມ"

#. EKdWF
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3157907\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/customslideshows/startshow\">Runs the selected custom slide show.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/customslideshows/startshow\">ເລີ່ມການສະແດງສະໄລ້ທີ່ກຳນົດເອງທີ່ເລືອກໄວ້.</ahelp>"

#. u5kLV
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"tit\n"
"help.text"
msgid "Define Custom Slide Show"
msgstr "ກຳນົດການສະແດງສະໄລ້ທີ່ກຳນົດເອງ"

#. 7Be2o
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"hd_id3154020\n"
"help.text"
msgid "Define Custom Slide Show"
msgstr "ກຳນົດການສະແດງສະໄລ້ທີ່ກຳນົດເອງ"

#. 8fuYs
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3154659\n"
"help.text"
msgid "<variable id=\"neu\"><ahelp hid=\".\" visibility=\"visible\">Creates a custom slide show.</ahelp></variable>"
msgstr "<variable id=\"neu\"><ahelp hid=\".\" visibility=\"visible\">ສ້າງການສະແດງສະໄລ້ທີ່ກຳນົດເອງ.</ahelp></variable>"

#. K72mf
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3155379\n"
"help.text"
msgid "Select a slide and click <emph>>></emph> or <emph><<</emph> to add or remove the slide from the list."
msgstr "ເລືອກສະໄລ້ແລ້ວຄລິກ <emph>>></emph> ຫຼື <emph><<</emph> ເພື່ອເພີ່ມ ຫຼື ລຶບສະໄລ້ອອກຈາກລາຍການ."

#. sggau
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3156449\n"
"help.text"
msgid "<ahelp visibility=\"visible\" hid=\"modules/simpress/ui/definecustomslideshow/add\">Adds an existing slide to the bottom of the <emph>Selected slides</emph> list. You need to select a slide in the <emph>Existing slides</emph> list before you can use this button.</ahelp>"
msgstr "<ahelp visibility=\"visible\" hid=\"modules/simpress/ui/definecustomslideshow/add\">ເພີ່ມສະໄລ້ທີ່ມີຢູ່ແລ້ວລົງໃນສ່ວນລຸ່ມຂອງລາຍການ <emph>ສະໄລ້ທີ່ເລືອກ</emph>. ທ່ານຕ້ອງເລືອກສະໄລ້ໃນລາຍການ <emph>ສະໄລ້ທີ່ມີຢູ່</emph> ກ່ອນຈຶ່ງຈະສາມາດໃຊ້ປຸ່ມນີ້ໄດ້.</ahelp>"

#. VB5Da
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3151240\n"
"help.text"
msgid "<ahelp visibility=\"visible\" hid=\"modules/simpress/ui/definecustomslideshow/remove\">Removes a slide from the <emph>Selected slides </emph>list. You need to choose a slide in the <emph>Selected slides </emph>list before you can use this button.</ahelp>"
msgstr "<ahelp visibility=\"visible\" hid=\"modules/simpress/ui/definecustomslideshow/remove\">ລຶບສະໄລ້ອອກຈາກລາຍການ <emph>ສະໄລ້ທີ່ເລືອກ</emph>. ທ່ານຕ້ອງເລືອກສະໄລ້ໃນລາຍການ <emph>ສະໄລ້ທີ່ເລືອກ</emph> ກ່ອນຈຶ່ງຈະສາມາດໃຊ້ປຸ່ມນີ້ໄດ້.</ahelp>"

#. 6nms8
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"hd_id3156018\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. uenBk
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3152871\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/customname\" visibility=\"visible\">Displays the name of the custom slide show. If you want, you can enter a new name.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/customname\" visibility=\"visible\">ສະແດງຊື່ຂອງການສະແດງສະໄລ້ທີ່ກຳນົດເອງ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດໃສ່ຊື່ໃໝ່ໄດ້.</ahelp>"

#. PBDYa
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"hd_id3149050\n"
"help.text"
msgid "Existing slides"
msgstr "ສະໄລ້ທີ່ມີຢູ່"

#. GhFWP
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3154767\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/pages\" visibility=\"visible\">Lists all of the slides in the order in which they appear in the current document.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/pages\" visibility=\"visible\">ສະແດງລາຍການສະໄລ້ທັງໝົດຕາມລຳດັບທີ່ປາກົດໃນເອກະສານປັດຈຸບັນ.</ahelp>"

#. UXnQA
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"hd_id3146965\n"
"help.text"
msgid "Selected slides"
msgstr "ສະໄລ້ທີ່ເລືອກ"

#. 6zJ54
#: 06100100.xhp
msgctxt ""
"06100100.xhp\n"
"par_id3149874\n"
"help.text"
msgid "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/custompages\" visibility=\"visible\">Lists all of the slides in the custom slide show. If you want, you can change the order of the list by dragging the slides up or down.</ahelp>"
msgstr "<ahelp hid=\"modules/simpress/ui/definecustomslideshow/custompages\" visibility=\"visible\">ສະແດງລາຍການສະໄລ້ທັງໝົດໃນການສະແດງສະໄລ້ທີ່ກຳນົດເອງ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ່ຽນລຳດັບຂອງລາຍການໂດຍການລາກສະໄລ້ຂຶ້ນ ຫຼື ລົງ.</ahelp>"

#. 9jAiq
#: 13050000.xhp
msgctxt ""
"13050000.xhp\n"
"tit\n"
"help.text"
msgid "Convert"
msgstr "ແປງ"

#. h6Rok
#: 13050000.xhp
msgctxt ""
"13050000.xhp\n"
"hd_id3152596\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050000.xhp\">Convert</link>"
msgstr "<link href=\"text/simpress/01/13050000.xhp\">ແປງ</link>"

#. osJbe
#: 13050000.xhp
msgctxt ""
"13050000.xhp\n"
"par_id3151075\n"
"help.text"
msgid "Options for converting the selected object."
msgstr "ຕົວເລືອກສຳລັບການແປງວັດຖຸທີ່ເລືອກໄວ້."

#. KZVkx
#: 13050100.xhp
msgctxt ""
"13050100.xhp\n"
"tit\n"
"help.text"
msgid "To Curve"
msgstr "ເປັນເສັ້ນໂຄ້ງ"

#. SPxyK
#: 13050100.xhp
msgctxt ""
"13050100.xhp\n"
"hd_id3125864\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050100.xhp\">To Curve</link>"
msgstr "<link href=\"text/simpress/01/13050100.xhp\">ເປັນເສັ້ນໂຄ້ງ</link>"

#. i9Df4
#: 13050100.xhp
msgctxt ""
"13050100.xhp\n"
"par_id3147436\n"
"help.text"
msgid "<ahelp hid=\".uno:ChangeBezier\">Converts the selected object to a Bézier curve.</ahelp>"
msgstr "<ahelp hid=\".uno:ChangeBezier\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນເສັ້ນໂຄ້ງເບຊີເອ (Bézier curve).</ahelp>"

#. 9z9dw
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"tit\n"
"help.text"
msgid "To Polygon"
msgstr "ເປັນຮູບຫຼາຍແຈ (Polygon)"

#. 3U2LL
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3152578\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050200.xhp\">To Polygon</link>"
msgstr "<link href=\"text/simpress/01/13050200.xhp\">ເປັນຮູບຫຼາຍແຈ (Polygon)</link>"

#. 4e8ts
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3145252\n"
"help.text"
msgid "<ahelp hid=\".uno:ChangePolygon\">Converts the selected object to a polygon (a closed object bounded by straight lines).</ahelp> The appearance of the object does not change. If you want, you can right-click and choose <link href=\"text/shared/main0227.xhp\"><emph>Edit Points</emph></link> to view the changes."
msgstr "<ahelp hid=\".uno:ChangePolygon\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນຮູບຫຼາຍແຈ (ວັດຖຸປິດທີ່ຂອບດ້ວຍເສັ້ນຊື່).</ahelp> ຮູບຮ່າງພາຍນອກຂອງວັດຖຸຈະບໍ່ປ່ຽນແປງ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດຄລິກຂວາແລ້ວເລືອກ <link href=\"text/shared/main0227.xhp\"><emph>ແກ້ໄຂຈຸດ</emph></link> ເພື່ອເບິ່ງການປ່ຽນແປງ."

#. JpSgf
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3155066\n"
"help.text"
msgid "Convert to Polygon"
msgstr "ແປງເປັນຮູບຫຼາຍແຈ (Polygon)"

#. SFES2
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3153713\n"
"help.text"
msgid "The following options are required to convert a bitmap image to a polygon. The converted image is actually a collection of smaller polygons filled with color."
msgstr "ຕົວເລືອກຕໍ່ໄປນີ້ຈຳເປັນສຳລັບການແປງຮູບພາບແບບບິດແມັບໃຫ້ເປັນຮູບຫຼາຍແຈ. ຮູບພາບທີ່ຖືກແປງແລ້ວຈະເປັນການລວມຕົວຂອງຮູບຫຼາຍແຈຂະໜາດນ້ອຍທີ່ເຕັມດ້ວຍສີ."

#. tCoSn
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3154254\n"
"help.text"
msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

#. wWCLH
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3149126\n"
"help.text"
msgid "Set the conversion options for the image."
msgstr "ຕັ້ງຄ່າຕົວເລືອກການແປງສຳລັບຮູບພາບ."

#. nBFSE
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3146314\n"
"help.text"
msgid "Number of colors:"
msgstr "ຈຳນວນສີ:"

#. K3h9g
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3145790\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/vectorize/colors\">Enter the number of colors to be displayed in the converted image. $[officename] generates a polygon for each occurrence of a color in the image.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/vectorize/colors\">ໃສ່ຈຳນວນສີທີ່ຈະສະແດງໃນຮູບທີ່ຖືກແປງແລ້ວ. $[officename] ຈະສ້າງຮູບຫຼາຍແຈສຳລັບແຕ່ລະສີທີ່ປາກົດໃນຮູບ.</ahelp>"

#. 5nq8u
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3150206\n"
"help.text"
msgid "Point reduction"
msgstr "ການຫຼຸດຈຸດ"

#. 5fgWJ
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3159236\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/vectorize/points\">Removes color polygons that are smaller than the pixel value you enter.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/vectorize/points\">ລຶບຮູບຫຼາຍແຈທີ່ມີສີເຊິ່ງມີຂະໜາດນ້ອຍກວ່າຄ່າພິກເຊວທີ່ທ່ານໃສ່.</ahelp>"

#. Sh9Hm
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3150364\n"
"help.text"
msgid "Fill holes"
msgstr "ຕື່ມຊ່ອງວ່າງ"

#. rpZAB
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3145584\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/vectorize/fillholes\">Fills the color gaps caused by applying a point reduction.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/vectorize/fillholes\">ຕື່ມຊ່ອງວ່າງຂອງສີທີ່ເກີດຈາກການນຳໃຊ້ການຫຼຸດຈຸດ.</ahelp>"

#. AUYka
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3154371\n"
"help.text"
msgid "Tile size"
msgstr "ຂະໜາດແຜ່ນ"

#. uj7Mx
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3156448\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/vectorize/tiles\">Enter the size of the rectangle for the background fill.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/vectorize/tiles\">ໃສ່ຂະໜາດຂອງຮູບສີ່ແຈສຳລັບການຕື່ມສີພື້ນຫຼັງ.</ahelp>"

#. wMeob
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3148840\n"
"help.text"
msgid "Source image:"
msgstr "ຮູບຕົ້ນສະບັບ:"

#. C8DaD
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3153917\n"
"help.text"
msgid "Preview of the original image."
msgstr "ຕົວຢ່າງຂອງຮູບພາບຕົ້ນສະບັບ."

#. dARnr
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3149944\n"
"help.text"
msgid "Vectorized image:"
msgstr "ຮູບແບບເວັກເຕີ:"

#. fi5Ff
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3148605\n"
"help.text"
msgid "Preview of the converted image. Click <emph>Preview</emph> to generate the vectorized image."
msgstr "ຕົວຢ່າງຂອງຮູບພາບທີ່ຖືກແປງແລ້ວ. ຄລິກ <emph>ສະແດງຕົວຢ່າງ</emph> ເພື່ອສ້າງຮູບພາບແບບເວັກເຕີ."

#. PcFXs
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3156020\n"
"help.text"
msgid "Progress"
msgstr "ຄວາມຄືບໜ້າ"

#. LEgF4
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3159207\n"
"help.text"
msgid "Displays the conversion progress."
msgstr "ສະແດງຄວາມຄືບໜ້າຂອງການແປງ."

#. yQApT
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"hd_id3149048\n"
"help.text"
msgid "Preview"
msgstr "ສະແດງຕົວຢ່າງ"

#. fwm8P
#: 13050200.xhp
msgctxt ""
"13050200.xhp\n"
"par_id3150046\n"
"help.text"
msgid "<ahelp hid=\"modules/sdraw/ui/vectorize/preview\">Previews the converted image without applying the changes.</ahelp>"
msgstr "<ahelp hid=\"modules/sdraw/ui/vectorize/preview\">ສະແດງຕົວຢ່າງຂອງຮູບທີ່ຖືກແປງໂດຍບໍ່ທັນໄດ້ນຳໃຊ້ການປ່ຽນແປງ.</ahelp>"

#. aocCm
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"tit\n"
"help.text"
msgid "Convert to 3D"
msgstr "ແປງເປັນ 3 ມິຕິ"

#. AfbJN
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"hd_id3154017\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050300.xhp\">Convert to 3D</link>"
msgstr "<link href=\"text/simpress/01/13050300.xhp\">ແປງເປັນ 3 ມິຕິ</link>"

#. fE6mo
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3155066\n"
"help.text"
msgid "<ahelp hid=\".uno:ConvertInto3D\">Converts the selected object to a three-dimensional (3D) object.</ahelp>"
msgstr "<ahelp hid=\".uno:ConvertInto3D\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນວັດຖຸສາມມິຕິ (3D).</ahelp>"

#. U9nei
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3147339\n"
"help.text"
msgid "<variable id=\"anmerkung\">The selected object is first converted to a contour, and then to a 3D object.</variable>"
msgstr "<variable id=\"anmerkung\">ວັດຖຸທີ່ເລືອກຈະຖືກແປງໃຫ້ເປັນເສັ້ນຂອບກ່ອນ, ແລ້ວຈຶ່ງແປງເປັນວັດຖຸ 3 ມິຕິ.</variable>"

#. qc8HD
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3149127\n"
"help.text"
msgid "If you select two or more objects and convert them to 3D, the result is a 3D group that acts as a single object. You can edit the individual objects in the group by choosing <switchinline select=\"appl\"><caseinline select=\"DRAW\"><emph>Shape - Group - Enter Group</emph></caseinline><defaultinline><emph>Format - Group - Enter Group</emph></defaultinline></switchinline>. Choose <switchinline select=\"appl\"><caseinline select=\"DRAW\"><emph>Shape - Group - Exit Group</emph></caseinline><defaultinline><emph>Format - Group - Exit Group</emph></defaultinline></switchinline> when you are finished."
msgstr "ຖ້າທ່ານເລືອກສອງວັດຖຸ ຫຼື ຫຼາຍກວ່ານັ້ນແລ້ວແປງເປັນ 3 ມິຕິ, ຜົນທີ່ໄດ້ຈະເປັນກຸ່ມ 3 ມິຕິທີ່ເຮັດວຽກຄືກັບວັດຖຸດຽວ. ທ່ານສາມາດແກ້ໄຂວັດຖຸແຕ່ລະອັນໃນກຸ່ມໄດ້ໂດຍການເລືອກ <switchinline select=\"appl\"><caseinline select=\"DRAW\"><emph>ຮູບຊົງ - ກຸ່ມ - ເຂົ້າຮ່ວມກຸ່ມ</emph></caseinline><defaultinline><emph>ຮູບແບບ - ກຸ່ມ - ເຂົ້າຮ່ວມກຸ່ມ</emph></defaultinline></switchinline>. ເລືອກ <switchinline select=\"appl\"><caseinline select=\"DRAW\"><emph>ຮູບຊົງ - ກຸ່ມ - ອອກຈາກກຸ່ມ</emph></caseinline><defaultinline><emph>ຮູບແບບ - ກຸ່ມ - ອອກຈາກກຸ່ມ</emph></defaultinline></switchinline> ເມື່ອແກ້ໄຂສຳເລັດແລ້ວ."

#. S7yqE
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3151242\n"
"help.text"
msgid "Converting a group of objects to 3D does not change the stacking order of the individual objects."
msgstr "ການແປງກຸ່ມວັດຖຸເປັນ 3 ມິຕິ ຈະບໍ່ປ່ຽນລຳດັບການຊ້ອນກັນຂອງວັດຖຸແຕ່ລະອັນ."

#. pz3dH
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3146965\n"
"help.text"
msgid "Press F3 to quickly enter a group and <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+F3</keycode> to leave the group."
msgstr "ກົດ F3 ເພື່ອເຂົ້າຮ່ວມກຸ່ມຢ່າງວ່ອງໄວ ແລະ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+F3</keycode> ເພື່ອອອກຈາກກຸ່ມ."

#. faBGW
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3145114\n"
"help.text"
msgid "You can also convert bitmap images and vector graphics, including clipart, to 3D objects. $[officename] treats bitmaps as rectangles and vector graphics as a group of polygons when converting to 3D."
msgstr "ທ່ານຍັງສາມາດແປງຮູບພາບແບບບິດແມັບ ແລະ ກຣາຟິກເວັກເຕີ, ລວມທັງຄລິບອາດ (clipart), ໃຫ້ເປັນວັດຖຸ 3 ມິຕິໄດ້. $[officename] ຈະຖືວ່າບິດແມັບເປັນຮູບສີ່ແຈ ແລະ ກຣາຟິກເວັກເຕີເປັນກຸ່ມຂອງຮູບຫຼາຍແຈເມື່ອແປງເປັນ 3 ມິຕິ."

#. rcCzG
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3149876\n"
"help.text"
msgid "Even drawing objects that contain text can be converted."
msgstr "ແມ່ນແຕ່ວັດຖຸທີ່ແຕ້ມຂຶ້ນທີ່ມີຂໍ້ຄວາມກໍສາມາດແປງໄດ້."

#. sCemD
#: 13050300.xhp
msgctxt ""
"13050300.xhp\n"
"par_id3153960\n"
"help.text"
msgid "If you want, you can also apply a <link href=\"text/shared/01/05350000.xhp\">3D Effect</link> to the converted object."
msgstr "ຖ້າທ່ານຕ້ອງການ, ທ່ານຍັງສາມາດນຳໃຊ້ <link href=\"text/shared/01/05350000.xhp\">ເອັບເຟັກ 3 ມິຕິ</link> ໃສ່ວັດຖຸທີ່ແປງແລ້ວໄດ້."

#. k8Bxk
#: 13050400.xhp
msgctxt ""
"13050400.xhp\n"
"tit\n"
"help.text"
msgid "Convert to 3D Rotation Object"
msgstr "ແປງເປັນວັດຖຸໝູນ 3 ມິຕິ"

#. ei7Cd
#: 13050400.xhp
msgctxt ""
"13050400.xhp\n"
"hd_id3146974\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050400.xhp\">Convert to 3D Rotation Object</link>"
msgstr "<link href=\"text/simpress/01/13050400.xhp\">ແປງເປັນວັດຖຸໝູນ 3 ມິຕິ</link>"

#. EDRF2
#: 13050400.xhp
msgctxt ""
"13050400.xhp\n"
"par_id3150717\n"
"help.text"
msgid "<ahelp hid=\".uno:ConvertInto3DLatheFast\">Creates a three-dimensional shape by rotating the selected object around its vertical axis.</ahelp>"
msgstr "<ahelp hid=\".uno:ConvertInto3DLatheFast\">ສ້າງຮູບຊົງສາມມິຕິໂດຍການໝູນວັດຖຸທີ່ເລືອກອ້ອມແກນຕັ້ງຂອງມັນ.</ahelp>"

#. vPdPh
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"tit\n"
"help.text"
msgid "To Bitmap"
msgstr "ເປັນບິດແມັບ (Bitmap)"

#. KQXwf
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"bm_id3153142\n"
"help.text"
msgid "<bookmark_value>converting; to bitmaps</bookmark_value><bookmark_value>bitmaps; converting to</bookmark_value>"
msgstr "<bookmark_value>ການແປງ; ເປັນບິດແມັບ</bookmark_value><bookmark_value>ບິດແມັບ; ການແປງເປັນ</bookmark_value>"

#. eXBYH
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"hd_id3153142\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050500.xhp\">To Bitmap</link>"
msgstr "<link href=\"text/simpress/01/13050500.xhp\">ເປັນບິດແມັບ (Bitmap)</link>"

#. c6dej
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"par_id3146975\n"
"help.text"
msgid "<ahelp hid=\".uno:ConvertIntoBitmap\">Converts the selected object to a bitmap (a grid of pixels that represents an image).</ahelp>"
msgstr "<ahelp hid=\".uno:ConvertIntoBitmap\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນບິດແມັບ (ຕາໜ່າງຂອງພິກເຊວທີ່ສະແດງເຖິງຮູບພາບ).</ahelp>"

#. C5bW5
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"par_id3149377\n"
"help.text"
msgid "For more information, see the <link href=\"text/shared/00/00000005.xhp\">Glossary</link>."
msgstr "ສຳລັບຂໍ້ມູນເພີ່ມເຕີມ, ໃຫ້ເບິ່ງທີ່ <link href=\"text/shared/00/00000005.xhp\">ອະພິທານສັບ</link>."

#. AmCFw
#: 13050500.xhp
msgctxt ""
"13050500.xhp\n"
"par_id3155333\n"
"help.text"
msgid "You can also copy the selected object and choose <emph>Edit - Paste Special </emph>and select the bitmap format from the list."
msgstr "ທ່ານຍັງສາມາດສຳເນົາວັດຖຸທີ່ເລືອກແລ້ວເລືອກ <emph>ແກ້ໄຂ - ວາງແບບພິເສດ </emph>ແລະ ເລືອກຮູບແບບບິດແມັບຈາກລາຍການ."

#. 2xwr8
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"tit\n"
"help.text"
msgid "To metafile"
msgstr "ເປັນເມຕາໄຟລ໌ (Metafile)"

#. xNrms
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"bm_id3147434\n"
"help.text"
msgid "<bookmark_value>converting; to metafile format (WMF)</bookmark_value><bookmark_value>metafiles; converting to</bookmark_value>"
msgstr "<bookmark_value>ການແປງ; ເປັນຮູບແບບເມຕາໄຟລ໌ (WMF)</bookmark_value><bookmark_value>ເມຕາໄຟລ໌; ການແປງເປັນ</bookmark_value>"

#. 6Z3BN
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"hd_id3147434\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050600.xhp\">To metafile</link>"
msgstr "<link href=\"text/simpress/01/13050600.xhp\">ເປັນເມຕາໄຟລ໌ (Metafile)</link>"

#. y3w7E
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"par_id3154490\n"
"help.text"
msgid "<ahelp hid=\".uno:ConvertIntoMetaFile\">Converts the selected object to Windows Metafile Format (WMF), containing both bitmap and vector graphic data.</ahelp>"
msgstr "<ahelp hid=\".uno:ConvertIntoMetaFile\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນຮູບແບບ Windows Metafile (WMF), ເຊິ່ງປະກອບດ້ວຍທັງຂໍ້ມູນບິດແມັບ ແລະ ກຣາຟິກເວັກເຕີ.</ahelp>"

#. KA7dg
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"par_id3151075\n"
"help.text"
msgid "For more information on WMF, see the <link href=\"text/shared/00/00000005.xhp\">Glossary</link>."
msgstr "ສຳລັບຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບ WMF, ໃຫ້ເບິ່ງທີ່ <link href=\"text/shared/00/00000005.xhp\">ອະພິທານສັບ</link>."

#. ZF3LC
#: 13050600.xhp
msgctxt ""
"13050600.xhp\n"
"par_id3147344\n"
"help.text"
msgid "You can also copy the selected object and choose <emph>Edit - Paste Special </emph>and select MetaFile from the list."
msgstr "ທ່ານຍັງສາມາດສຳເນົາວັດຖຸທີ່ເລືອກແລ້ວເລືອກ <emph>ແກ້ໄຂ - ວາງແບບພິເສດ </emph>ແລະ ເລືອກ MetaFile ຈາກລາຍການ."

#. C79C2
#: 13050700.xhp
msgctxt ""
"13050700.xhp\n"
"tit\n"
"help.text"
msgid "To Contour"
msgstr "ເປັນເສັ້ນຂອບ (Contour)"

#. szxqe
#: 13050700.xhp
msgctxt ""
"13050700.xhp\n"
"bm_id3146119\n"
"help.text"
msgid "<bookmark_value>converting; to contours</bookmark_value><bookmark_value>contours; converting to</bookmark_value>"
msgstr "<bookmark_value>ການແປງ; ເປັນເສັ້ນຂອບ</bookmark_value><bookmark_value>ເສັ້ນຂອບ; ການແປງເປັນ</bookmark_value>"

#. gAGkK
#: 13050700.xhp
msgctxt ""
"13050700.xhp\n"
"hd_id3146119\n"
"help.text"
msgid "<link href=\"text/simpress/01/13050700.xhp\">To Contour</link>"
msgstr "<link href=\"text/simpress/01/13050700.xhp\">ເປັນເສັ້ນຂອບ (Contour)</link>"

#. TJiqQ
#: 13050700.xhp
msgctxt ""
"13050700.xhp\n"
"par_id3146974\n"
"help.text"
msgid "<ahelp hid=\".uno:convert_to_contour\">Converts the selected object to a polygon, or a group of polygons.</ahelp> If the conversion creates a group of polygons (for example, when you convert a text object), then press F3 to enter the group before you can select an individual polygon."
msgstr "<ahelp hid=\".uno:convert_to_contour\">ແປງວັດຖຸທີ່ເລືອກໃຫ້ເປັນຮູບຫຼາຍແຈ, ຫຼື ກຸ່ມຂອງຮູບຫຼາຍແຈ.</ahelp> ຖ້າການແປງນັ້ນສ້າງກຸ່ມຂອງຮູບຫຼາຍແຈຂຶ້ນມາ (ຕົວຢ່າງ: ເມື່ອທ່ານແປງວັດຖຸຂໍ້ຄວາມ), ໃຫ້ກົດ F3 ເພື່ອເຂົ້າຮ່ວມກຸ່ມກ່ອນຈຶ່ງຈະສາມາດເລືອກຮູບຫຼາຍແຈແຕ່ລະອັນໄດ້."

#. UTXAL
#: 13050700.xhp
msgctxt ""
"13050700.xhp\n"
"par_id3155601\n"
"help.text"
msgid "Once you convert a line or a text object to a contour, you can no longer edit it as you normally would. Instead, you can edit the contour as you would any polygon, including using the <emph>Edit – Points </emph>command to adjust its shape."
msgstr "ເມື່ອທ່ານແປງເສັ້ນ ຫຼື ວັດຖຸຂໍ້ຄວາມໃຫ້ເປັນເສັ້ນຂອບແລ້ວ, ທ່ານຈະບໍ່ສາມາດແກ້ໄຂມັນໃນແບບປົກກະຕິໄດ້ອີກ. ແຕ່ທ່ານສາມາດແກ້ໄຂເສັ້ນຂອບໄດ້ຄືກັບຮູບຫຼາຍແຈທົ່ວໄປ, ລວມທັງການໃຊ້ຄຳສັ່ງ <emph>ແກ້ໄຂ – ຈຸດ </emph>ເພື່ອປັບປຸງຮູບຮ່າງຂອງມັນ."

#. ao35i
#: 13140000.xhp
msgctxt ""
"13140000.xhp\n"
"tit\n"
"help.text"
msgid "Combine"
msgstr "ລວມເຂົ້າກັນ (Combine)"

#. 692XG
#: 13140000.xhp
msgctxt ""
"13140000.xhp\n"
"hd_id3150012\n"
"help.text"
msgid "<link href=\"text/simpress/01/13140000.xhp\">Combine</link>"
msgstr "<link href=\"text/simpress/01/13140000.xhp\">ລວມເຂົ້າກັນ (Combine)</link>"

#. HHHQi
#: 13140000.xhp
msgctxt ""
"13140000.xhp\n"
"par_id3146974\n"
"help.text"
msgid "<ahelp hid=\".uno:Combine\">Combines two or more selected objects into a single shape.</ahelp> Unlike <link href=\"text/shared/01/05290000.xhp\">grouping</link>, a combined object takes on the properties of the lowermost object in the stacking order. You can <link href=\"text/simpress/01/13150000.xhp\">split</link> apart combined objects, but the original object properties are lost."
msgstr "<ahelp hid=\".uno:Combine\">ລວມວັດຖຸທີ່ເລືອກຕັ້ງແຕ່ສອງອັນຂຶ້ນໄປໃຫ້ເປັນຮູບຊົງດຽວ.</ahelp> ມັນຈະແຕກຕ່າງຈາກ <link href=\"text/shared/01/05290000.xhp\">ການຈັດກຸ່ມ</link> ຄືວັດຖຸທີ່ລວມກັນແລ້ວຈະໄດ້ຮັບຄຸນສົມບັດຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລຳດັບການຊ້ອນກັນ. ທ່ານສາມາດ <link href=\"text/simpress/01/13150000.xhp\">ແຍກ</link> ວັດຖຸທີ່ລວມກັນອອກຈາກກັນໄດ້, ແຕ່ຄຸນສົມບັດຂອງວັດຖຸເດີມຈະເສຍໄປ."

#. BmsmL
#: 13140000.xhp
msgctxt ""
"13140000.xhp\n"
"par_id3153876\n"
"help.text"
msgid "When you combine objects, the drawing elements are replaced by Bézier curves and holes appear where the objects overlap."
msgstr "ເມື່ອທ່ານລວມວັດຖຸເຂົ້າກັນ, ອົງປະກອບການແຕ້ມຈະຖືກປ່ຽນແທນດ້ວຍເສັ້ນໂຄ້ງເບຊີເອ ແລະ ຈະເກີດມີຊ່ອງວ່າງຂຶ້ນໃນບ່ອນທີ່ວັດຖຸຊ້ອນທັບກັນ."

#. v8ve3
#: 13150000.xhp
msgctxt ""
"13150000.xhp\n"
"tit\n"
"help.text"
msgid "Split"
msgstr "ແຍກອອກ (Split)"

#. YXtaA
#: 13150000.xhp
msgctxt ""
"13150000.xhp\n"
"bm_id3150439\n"
"help.text"
msgid "<bookmark_value>combining; undoing</bookmark_value><bookmark_value>splitting; combinations</bookmark_value>"
msgstr "<bookmark_value>ການລວມ; ການຍົກເລີກ</bookmark_value><bookmark_value>ການແຍກ; ການລວມ</bookmark_value>"

#. FjcAF
#: 13150000.xhp
msgctxt ""
"13150000.xhp\n"
"hd_id3150439\n"
"help.text"
msgid "<link href=\"text/simpress/01/13150000.xhp\">Split</link>"
msgstr "<link href=\"text/simpress/01/13150000.xhp\">ແຍກອອກ (Split)</link>"

#. bgJGV
#: 13150000.xhp
msgctxt ""
"13150000.xhp\n"
"par_id3147435\n"
"help.text"
msgid "<ahelp hid=\".uno:Dismantle\">Splits a <link href=\"text/simpress/01/13140000.xhp\">combined</link> object into individual objects.</ahelp> The resulting objects have the same line and fill properties as the combined object."
msgstr "<ahelp hid=\".uno:Dismantle\">ແຍກວັດຖຸທີ່ <link href=\"text/simpress/01/13140000.xhp\">ລວມກັນ</link> ໃຫ້ເປັນວັດຖຸແຕ່ລະອັນຄືເກົ່າ.</ahelp> ວັດຖຸທີ່ໄດ້ຈະມີຄຸນສົມບັດເສັ້ນ ແລະ ການຕື່ມສີຄືກັນກັບວັດຖຸທີ່ເຄີຍລວມກັນນັ້ນ."

#. CiAPY
#: 13160000.xhp
msgctxt ""
"13160000.xhp\n"
"tit\n"
"help.text"
msgid "Connect"
msgstr "ເຊື່ອມຕໍ່ (Connect)"

#. KPHAx
#: 13160000.xhp
msgctxt ""
"13160000.xhp\n"
"hd_id3153768\n"
"help.text"
msgid "<link href=\"text/simpress/01/13160000.xhp\">Connect</link>"
msgstr "<link href=\"text/simpress/01/13160000.xhp\">ເຊື່ອມຕໍ່ (Connect)</link>"

#. nCBkq
#: 13160000.xhp
msgctxt ""
"13160000.xhp\n"
"par_id3152598\n"
"help.text"
msgid "<ahelp hid=\".uno:Connect\" visibility=\"visible\">Creates a line or Bézier curve by connecting two or more lines, Bézier curves, or other objects with a line.</ahelp> Closed objects containing a fill are converted to lines and lose their fill."
msgstr "<ahelp hid=\".uno:Connect\" visibility=\"visible\">ສ້າງເສັ້ນຊື່ ຫຼື ເສັ້ນໂຄ້ງເບຊີເອ ໂດຍການເຊື່ອມຕໍ່ເສັ້ນສອງເສັ້ນ ຫຼື ຫຼາຍກວ່ານັ້ນ, ເສັ້ນໂຄ້ງເບຊີເອ, ຫຼື ວັດຖຸອື່ນໆດ້ວຍເສັ້ນ.</ahelp> ວັດຖຸປິດທີ່ມີການຕື່ມສີຈະຖືກແປງເປັນເສັ້ນ ແລະ ຈະເສຍການຕື່ມສີໄປ."

#. cbzRu
#: 13170000.xhp
msgctxt ""
"13170000.xhp\n"
"tit\n"
"help.text"
msgid "Break"
msgstr "ຕັດອອກ (Break)"

#. FsNNj
#: 13170000.xhp
msgctxt ""
"13170000.xhp\n"
"bm_id3150870\n"
"help.text"
msgid "<bookmark_value>objects; breaking connections</bookmark_value><bookmark_value>breaking object connections</bookmark_value>"
msgstr "<bookmark_value>ວັດຖຸ; ການຕັດການເຊື່ອມຕໍ່</bookmark_value><bookmark_value>ການຕັດການເຊື່ອມຕໍ່ວັດຖຸ</bookmark_value>"

#. 2ZdeF
#: 13170000.xhp
msgctxt ""
"13170000.xhp\n"
"hd_id3150870\n"
"help.text"
msgid "<link href=\"text/simpress/01/13170000.xhp\">Break</link>"
msgstr "<link href=\"text/simpress/01/13170000.xhp\">ຕັດອອກ (Break)</link>"

#. BBjb3
#: 13170000.xhp
msgctxt ""
"13170000.xhp\n"
"par_id3156441\n"
"help.text"
msgid "<ahelp hid=\".uno:Break\">Breaks apart lines joined with the <emph>Connect</emph> command.</ahelp>"
msgstr "<ahelp hid=\".uno:Break\">ຕັດແຍກເສັ້ນທີ່ເຄີຍເຊື່ອມຕໍ່ກັນດ້ວຍຄຳສັ່ງ <emph>ເຊື່ອມຕໍ່</emph> ອອກຈາກກັນ.</ahelp>"

#. LRwvg
#: 13170000.xhp
msgctxt ""
"13170000.xhp\n"
"par_id3153726\n"
"help.text"
msgid "You cannot apply a fill to closed shapes that have been broken apart with this command."
msgstr "ທ່ານບໍ່ສາມາດນຳໃຊ້ການຕື່ມສີໃສ່ຮູບຊົງປິດທີ່ຖືກຕັດແຍກອອກຈາກກັນດ້ວຍຄຳສັ່ງນີ້ໄດ້."

#. n5qHk
#: 13180000.xhp
msgctxt ""
"13180000.xhp\n"
"tit\n"
"help.text"
msgid "Shapes"
msgstr "ຮູບຊົງ"

#. CNxUV
#: 13180000.xhp
msgctxt ""
"13180000.xhp\n"
"hd_id3154319\n"
"help.text"
msgid "<link href=\"text/simpress/01/13180000.xhp\">Shapes</link>"
msgstr "<link href=\"text/simpress/01/13180000.xhp\">ຮູບຊົງ</link>"

#. VfDM8
#: 13180000.xhp
msgctxt ""
"13180000.xhp\n"
"par_id3147435\n"
"help.text"
msgid "Creates a shape from two or more selected objects."
msgstr "ສ້າງຮູບຊົງຈາກວັດຖຸທີ່ເລືອກຕັ້ງແຕ່ສອງອັນຂຶ້ນໄປ."

#. VfCmz
#: 13180000.xhp
msgctxt ""
"13180000.xhp\n"
"par_id3156286\n"
"help.text"
msgid "Shapes take on the properties of the lowermost object in the stacking order."
msgstr "ຮູບຊົງຈະໄດ້ຮັບຄຸນສົມບັດຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລຳດັບການຊ້ອນກັນ."

#. yBe8Z
#: 13180100.xhp
msgctxt ""
"13180100.xhp\n"
"tit\n"
"help.text"
msgid "Merge"
msgstr "ຮວມ (Merge)"

#. TzWg3
#: 13180100.xhp
msgctxt ""
"13180100.xhp\n"
"hd_id3150870\n"
"help.text"
msgid "<link href=\"text/simpress/01/13180100.xhp\">Merge</link>"
msgstr "<link href=\"text/simpress/01/13180100.xhp\">ຮວມ (Merge)</link>"

#. y9YTM
#: 13180100.xhp
msgctxt ""
"13180100.xhp\n"
"par_id3150012\n"
"help.text"
msgid "<ahelp hid=\".uno:Merge\" visibility=\"visible\">Adds the area of the selected objects to the area of the lowermost object in the selection. This command is best used with overlapping objects.</ahelp>"
msgstr "<ahelp hid=\".uno:Merge\" visibility=\"visible\">ເພີ່ມພື້ນທີ່ຂອງວັດຖຸທີ່ເລືອກເຂົ້າໃນພື້ນທີ່ຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດ. ຄຳສັ່ງນີ້ແມ່ນໃຊ້ໄດ້ດີທີ່ສຸດກັບວັດຖຸທີ່ຊ້ອນທັບກັນ.</ahelp>"

#. CuBaF
#: 13180100.xhp
msgctxt ""
"13180100.xhp\n"
"par_id3152578\n"
"help.text"
msgid "Any spaces that are visible between the objects are preserved."
msgstr "ຊ່ອງວ່າງໃດໆທີ່ເຫັນຢູ່ລະຫວ່າງວັດຖຸຈະຍັງຄົງຮັກສາໄວ້ຄືເກົ່າ."

#. hoCHQ
#: 13180200.xhp
msgctxt ""
"13180200.xhp\n"
"tit\n"
"help.text"
msgid "Subtract"
msgstr "ລົບອອກ (Subtract)"

#. NWgnt
#: 13180200.xhp
msgctxt ""
"13180200.xhp\n"
"hd_id3150439\n"
"help.text"
msgid "<link href=\"text/simpress/01/13180200.xhp\">Subtract</link>"
msgstr "<link href=\"text/simpress/01/13180200.xhp\">ລົບອອກ (Subtract)</link>"

#. VFGCM
#: 13180200.xhp
msgctxt ""
"13180200.xhp\n"
"par_id3152596\n"
"help.text"
msgid "<ahelp hid=\".uno:Substract\" visibility=\"visible\">Subtracts the area of the selected objects from the area of the lowermost object.</ahelp>"
msgstr "<ahelp hid=\".uno:Substract\" visibility=\"visible\">ລົບພື້ນທີ່ຂອງວັດຖຸທີ່ເລືອກອອກຈາກພື້ນທີ່ຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດ.</ahelp>"

#. hEAEj
#: 13180200.xhp
msgctxt ""
"13180200.xhp\n"
"par_id3154320\n"
"help.text"
msgid "Any spaces between the objects are preserved."
msgstr "ຊ່ອງວ່າງໃດໆລະຫວ່າງວັດຖຸຈະຍັງຄົງຮັກສາໄວ້ຄືເກົ່າ."

#. asjbL
#: 13180300.xhp
msgctxt ""
"13180300.xhp\n"
"tit\n"
"help.text"
msgid "Intersect"
msgstr "ສ່ວນຕັດ (Intersect)"

#. LGfDD
#: 13180300.xhp
msgctxt ""
"13180300.xhp\n"
"hd_id3153768\n"
"help.text"
msgid "<link href=\"text/simpress/01/13180300.xhp\">Intersect</link>"
msgstr "<link href=\"text/simpress/01/13180300.xhp\">ສ່ວນຕັດ (Intersect)</link>"

#. sHqmC
#: 13180300.xhp
msgctxt ""
"13180300.xhp\n"
"par_id3146975\n"
"help.text"
msgid "<ahelp hid=\".uno:Intersect\" visibility=\"visible\">Creates a shape from the overlapping area of the selected objects.</ahelp>"
msgstr "<ahelp hid=\".uno:Intersect\" visibility=\"visible\">ສ້າງຮູບຊົງຈາກພື້ນທີ່ທີ່ຊ້ອນທັບກັນຂອງວັດຖຸທີ່ເລືອກ.</ahelp>"

#. bQByv
#: PresentationMinimizer.xhp
msgctxt ""
"PresentationMinimizer.xhp\n"
"tit\n"
"help.text"
msgid "Presentation Minimizer"
msgstr "ຕົວຫຼຸດຂະໜາດການນຳສະເໜີ"

#. QMfX2
#: PresentationMinimizer.xhp
msgctxt ""
"PresentationMinimizer.xhp\n"
"hd_id881695940019967\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/simpress/01/PresentationMinimizer.xhp\">Presentation Minimizer</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/simpress/01/PresentationMinimizer.xhp\">ຕົວຫຼຸດຂະໜາດການນຳສະເໜີ</link></variable>"

#. NqVw9
#: PresentationMinimizer.xhp
msgctxt ""
"PresentationMinimizer.xhp\n"
"par_id981695940019969\n"
"help.text"
msgid "Opens the Presentation Minimizer dialog to reduce the file size of the current presentation."
msgstr "ເປີດກ່ອງຂໍ້ຄວາມຕົວຫຼຸດຂະໜາດການນຳສະເໜີ ເພື່ອຫຼຸດຂະໜາດໄຟລ໌ຂອງການນຳສະເໜີປັດຈຸບັນ."

#. 8mBdR
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"tit\n"
"help.text"
msgid "Bullet and Position"
msgstr "ສັນຍະລັກຫົວຂໍ້ ແລະ ຕຳແໜ່ງ"

#. xAFoQ
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id591623253567629\n"
"help.text"
msgid "<link href=\"text/simpress/01/bulletandposition.xhp\">Bullet and Position</link>"
msgstr "<link href=\"text/simpress/01/bulletandposition.xhp\">ສັນຍະລັກຫົວຂໍ້ ແລະ ຕຳແໜ່ງ</link>"

#. phgxq
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id371623258309050\n"
"help.text"
msgid "In a selected text, choose <menuitem>Format - Bullets and Numbering</menuitem>."
msgstr "ໃນຂໍ້ຄວາມທີ່ເລືອກ, ໃຫ້ເລືອກ <menuitem>ຮູບແບບ - ສັນຍະລັກຫົວຂໍ້ ແລະ ລຳດັບເລກ</menuitem>."

#. HC9PJ
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id151692539352713\n"
"help.text"
msgid "In a selected text, choose <menuitem>Bullets and Numbering</menuitem>."
msgstr "ໃນຂໍ້ຄວາມທີ່ເລືອກ, ໃຫ້ເລືອກ <menuitem>ສັນຍະລັກຫົວຂໍ້ ແລະ ລຳດັບເລກ</menuitem>."

#. eq2HC
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id571692539528746\n"
"help.text"
msgid "On the <switchinline select=\"appl\"><caseinline select=\"DRAW\"><menuitem>Text</menuitem></caseinline><caseinline select=\"IMPRESS\"><menuitem>Home</menuitem></caseinline></switchinline> tab, long click on <menuitem>Ordered</menuitem> or <menuitem>Unordered</menuitem> list, select <menuitem>Customize</menuitem>."
msgstr "ໃນແທັບ <switchinline select=\"appl\"><caseinline select=\"DRAW\"><menuitem>ຂໍ້ຄວາມ</menuitem></caseinline><caseinline select=\"IMPRESS\"><menuitem>ໜ້າຫຼັກ</menuitem></caseinline></switchinline>, ຄລິກຄ້າງໄວ້ທີ່ລາຍການ <menuitem>ຈັດລຳດັບ</menuitem> ຫຼື <menuitem>ບໍ່ຈັດລຳດັບ</menuitem>, ແລ້ວເລືອກ <menuitem>ປັບແຕ່ງ</menuitem>."

#. 2yyGA
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id111692539654810\n"
"help.text"
msgid "On the <menuitem>Lists</menuitem> panel of <menuitem>Properties</menuitem> deck, long click on <menuitem>Ordered</menuitem> or <menuitem>Unordered</menuitem> list, select <menuitem>Customize</menuitem>."
msgstr "ໃນແຜງ <menuitem>ລາຍການ</menuitem> ຂອງໜ້າຕ່າງ <menuitem>ຄຸນສົມບັດ</menuitem>, ຄລິກຄ້າງໄວ້ທີ່ລາຍການ <menuitem>ຈັດລຳດັບ</menuitem> ຫຼື <menuitem>ບໍ່ຈັດລຳດັບ</menuitem>, ແລ້ວເລືອກ <menuitem>ປັບແຕ່ງ</menuitem>."

#. ysA68
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id401623260265986\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. KEsmt
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id191623260097778\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. LikX8
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id291623260116361\n"
"help.text"
msgid "Select the type of list. Unordered with character bullet, unordered with graphics bullet, or ordered with a numbering scheme of your choice."
msgstr "ເລືອກປະເພດຂອງລາຍການ. ແບບບໍ່ຈັດລຳດັບດ້ວຍຕົວອັກສອນ, ແບບບໍ່ຈັດລຳດັບດ້ວຍກຣາຟິກ, ຫຼື ແບບຈັດລຳດັບດ້ວຍຮູບແບບຕົວເລກທີ່ທ່ານເລືອກ."

#. 3862v
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id611623260134513\n"
"help.text"
msgid "Character"
msgstr "ຕົວອັກສອນ"

#. AAFD3
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id641623260148566\n"
"help.text"
msgid "Select the character for the unordered list."
msgstr "ເລືອກຕົວອັກສອນສຳລັບລາຍການແບບບໍ່ຈັດລຳດັບ."

#. FmbAq
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id681623260246435\n"
"help.text"
msgid "Start at"
msgstr "ເລີ່ມທີ່"

#. EgRBS
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id551623260225990\n"
"help.text"
msgid "For ordered lists, select the value of first item of the list."
msgstr "ສຳລັບລາຍການແບບຈັດລຳດັບ, ເລືອກຄ່າຂອງລາຍການທຳອິດໃນລາຍການ."

#. CN44e
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id671623259902753\n"
"help.text"
msgid "Color"
msgstr "ສີ"

#. HSGAj
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id781623260255715\n"
"help.text"
msgid "Select the color of the list characters for ordered and unordered lists. Color does not apply for lists with graphic bullets."
msgstr "ເລືອກສີຂອງຕົວອັກສອນລາຍການສຳລັບລາຍການແບບຈັດລຳດັບ ແລະ ບໍ່ຈັດລຳດັບ. ສີຈະບໍ່ນຳໃຊ້ກັບລາຍການທີ່ໃຊ້ສັນຍະລັກຫົວຂໍ້ແບບກຣາຟິກ."

#. XnEwE
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id691623261496489\n"
"help.text"
msgid "Separator"
msgstr "ຕົວແຍກ"

#. ytZGx
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id791623261930996\n"
"help.text"
msgid "For ordered lists, set the text to display before and after the numbering scheme."
msgstr "ສຳລັບລາຍການແບບຈັດລຳດັບ, ຕັ້ງຄ່າຂໍ້ຄວາມທີ່ຈະສະແດງກ່ອນໜ້າ ແລະ ຫຼັງຈາກຮູບແບບຕົວເລກ."

#. JojhJ
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id681623261502578\n"
"help.text"
msgid "Before"
msgstr "ກ່ອນໜ້າ"

#. VTjZ9
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id641623261927147\n"
"help.text"
msgid "Enter the text to display before the numbering."
msgstr "ໃສ່ຂໍ້ຄວາມທີ່ຈະສະແດງກ່ອນໜ້າຕົວເລກ."

#. aB6uH
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id331623261507547\n"
"help.text"
msgid "After"
msgstr "ຫຼັງຈາກ"

#. 93cte
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id391623261922737\n"
"help.text"
msgid "Enter the text to display after the numbering."
msgstr "ໃສ່ຂໍ້ຄວາມທີ່ຈະສະແດງຫຼັງຈາກຕົວເລກ."

#. hUAWj
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id551623260579519\n"
"help.text"
msgid "Size"
msgstr "ຂະໜາດ"

#. MxDGA
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id521623261977095\n"
"help.text"
msgid "Set the size of the character and graphic bullets with respect to the paragraph font size."
msgstr "ຕັ້ງຄ່າຂະໜາດຂອງຕົວອັກສອນ ແລະ ກຣາຟິກສັນຍະລັກຫົວຂໍ້ ໂດຍທຽບໃສ່ຂະໜາດຟອນຂອງຫຍໍ້ໜ້າ."

#. 2pjgX
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id261623260584277\n"
"help.text"
msgid "Width"
msgstr "ຄວາມກວ້າງ"

#. rKipB
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id821623291829425\n"
"help.text"
msgid "Enter the width of the graphic bullet character."
msgstr "ໃສ່ຄວາມກວ້າງຂອງສັນຍະລັກຫົວຂໍ້ແບບກຣາຟິກ."

#. gCssw
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id531623260588282\n"
"help.text"
msgid "Height"
msgstr "ຄວາມສູງ"

#. xa2FN
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id321623291834607\n"
"help.text"
msgid "Enter the height of the graphic bullet character."
msgstr "ໃສ່ຄວາມສູງຂອງສັນຍະລັກຫົວຂໍ້ແບບກຣາຟິກ."

#. SjRNb
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id951623260634795\n"
"help.text"
msgid "Keep ratio"
msgstr "ຮັກສາອັດຕາສ່ວນ"

#. AKwMq
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id181623260599850\n"
"help.text"
msgid "Rel. Size"
msgstr "ຂະໜາດສຳພັດ"

#. eP9FG
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id281623260605208\n"
"help.text"
msgid "For character unordered and ordered lists, set the relative size of the list character. The relative size applies to the <emph>Before</emph> and <emph>After</emph> text as well."
msgstr "ສຳລັບລາຍການແບບຕົວອັກສອນທັງແບບຈັດລຳດັບ ແລະ ບໍ່ຈັດລຳດັບ, ໃຫ້ຕັ້ງຄ່າຂະໜາດສຳພັດຂອງຕົວອັກສອນລາຍການ. ຂະໜາດສຳພັດນີ້ຈະນຳໃຊ້ກັບຂໍ້ຄວາມ <emph>ກ່ອນໜ້າ</emph> ແລະ <emph>ຫຼັງຈາກ</emph> ນຳອີກ."

#. CGphX
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id931623261370137\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. yiqWW
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id421623262130068\n"
"help.text"
msgid "Indent"
msgstr "ຫຍໍ້ໜ້າ"

#. Bam8q
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id6081728\n"
"help.text"
msgid "Enter the distance from the left edge of the containing object to the start of all lines in the list."
msgstr "ໃສ່ໄລຍະຫ່າງຈາກຂອບຊ້າຍຂອງວັດຖຸທີ່ບັນຈຸ ໄປຫາຈຸດເລີ່ມຕົ້ນຂອງທຸກແຖວໃນລາຍການ."

#. 37TGG
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id651623262149945\n"
"help.text"
msgid "Width"
msgstr "ຄວາມກວ້າງ"

#. sQ2Ck
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id141623291867477\n"
"help.text"
msgid "Enter or select the width of the list element."
msgstr "ໃສ່ ຫຼື ເລືອກຄວາມກວ້າງຂອງອົງປະກອບລາຍການ."

#. DotNG
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id221623265073936\n"
"help.text"
msgid "The combined total length of <emph>Before</emph>, <emph>After</emph> and the numbering characters may override the width setting."
msgstr "ຄວາມຍາວທັງໝົດທີ່ລວມກັນຂອງຂໍ້ຄວາມ <emph>ກ່ອນໜ້າ</emph>, <emph>ຫຼັງຈາກ</emph> ແລະ ຕົວອັກສອນລຳດັບເລກ ອາດຈະທັບຊ້ອນການຕັ້ງຄ່າຄວາມກວ້າງໄດ້."

#. pnNqC
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id291623263843749\n"
"help.text"
msgid "Relative"
msgstr "ສຳພັດ"

#. oHCPh
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id561623268136625\n"
"help.text"
msgid "Relative to the upper list level. The entered value is added to that of this field in the level before. If “Indent: 20mm” on list level 1 and “Indent: 10mm Relative” on list level 2 will result in an effective indent of 30mm for level 2."
msgstr "ສຳພັດກັບລະດັບລາຍການທີ່ຢູ່ຂຶ້ນໄປ. ຄ່າທີ່ໃສ່ຈະຖືກບວກເຂົ້າກັບຄ່າຂອງຫ້ອງນີ້ໃນລະດັບກ່ອນໜ້າ. ຕົວຢ່າງ: ຖ້າ “ຫຍໍ້ໜ້າ: 20mm” ໃນລາຍການລະດັບ 1 ແລະ “ຫຍໍ້ໜ້າ: 10mm ສຳພັດ” ໃນລາຍການລະດັບ 2 ຈະສົ່ງຜົນໃຫ້ການຫຍໍ້ໜ້າຕົວຈິງເປັນ 30mm ສຳລັບລະດັບ 2."

#. VAwoR
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id261623263839244\n"
"help.text"
msgid "Alignment"
msgstr "ການຈັດວາງ"

#. FFN3B
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id361623265059971\n"
"help.text"
msgid "Select the alignment of the ordered list numbering contents inside the list <emph>Width</emph> setting."
msgstr "ເລືອກການຈັດວາງເນື້ອໃນລຳດັບເລກຂອງລາຍການແບບຈັດລຳດັບ ພາຍໃນການຕັ້ງຄ່າ <emph>ຄວາມກວ້າງ</emph> ຂອງລາຍການ."

#. tRzbn
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id871623265256880\n"
"help.text"
msgid "Scope"
msgstr "ຂອບເຂດ"

#. YcbZA
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id41623265263152\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"IMPRESS\">Slide</caseinline><defaultinline>Page</defaultinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><defaultinline>ໜ້າ</defaultinline></switchinline>"

#. BktFm
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id31623272228782\n"
"help.text"
msgid "Applies the modification to the whole <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">slide</caseinline><defaultinline>page</defaultinline></switchinline>."
msgstr "ນຳໃຊ້ການປ່ຽນແປງກັບທັງໝົດ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><defaultinline>ໜ້າ</defaultinline></switchinline>."

#. uzPBx
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id351623265267695\n"
"help.text"
msgid "Selection"
msgstr "ສ່ວນທີ່ເລືອກ"

#. mLzWE
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id821623272290885\n"
"help.text"
msgid "Applies the modification to the selection."
msgstr "ນຳໃຊ້ການປ່ຽນແປງກັບສ່ວນທີ່ເລືອກ."

#. PSDGB
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"hd_id141623265272187\n"
"help.text"
msgid "Apply to Master"
msgstr "ນຳໃຊ້ກັບຕົ້ນແບບ"

#. DTCfC
#: bulletandposition.xhp
msgctxt ""
"bulletandposition.xhp\n"
"par_id31623272423870\n"
"help.text"
msgid "Click to apply the modification to all <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">slides</caseinline><defaultinline>pages</defaultinline></switchinline> that use the current master <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">slide</caseinline><defaultinline>page</defaultinline></switchinline>."
msgstr "ຄລິກເພື່ອສັ່ງໃຫ້ນຳໃຊ້ການປ່ຽນແປງກັບທຸກໆ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><defaultinline>ໜ້າ</defaultinline></switchinline> ທີ່ນຳໃຊ້ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><defaultinline>ໜ້າ</defaultinline></switchinline> ຕົ້ນແບບປັດຈຸບັນ."

#. 5H8sr
