#. Ezvdm
#: 03090000.xhp
msgctxt ""
"03090000.xhp\n"
"S700003\n"
"help.text"
msgid "<link href=\"text/shared/02/06050000.xhp\">Demote</link>,"
msgstr "<link href=\"text/shared/02/06050000.xhp\">ຫຼຸດຂັ້ນລົງ</link>,"

#. pc4MC
