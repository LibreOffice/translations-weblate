msgid "Notes mode"
msgstr "ໂໝດບັນທຶກ"

#. QootH
#: presenter_console.xhp
msgctxt ""
"presenter_console.xhp\n"
"par_id711512828774884\n"
"help.text"
msgid "The Notes mode displays the current slide on the left, the slides notes on the right and the next slide below the current slide."
msgstr "ໂໝດບັນທຶກຈະສະແດງສະໄລ້ປັດຈຸບັນຢູ່ເບື້ອງຊ້າຍ, ບັນທຶກສະໄລ້ຢູ່ເບື້ອງຂວາ ແລະ ສະໄລ້ຖັດໄປຢູ່ລຸ່ມສະໄລ້ປັດຈຸບັນ."

