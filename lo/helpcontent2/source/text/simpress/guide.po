msgctxt ""
"printing.xhp\n"
"hd_id3154486\n"
"help.text"
msgid "Default printer settings"
msgstr "ການຕັ້ງຄ່າເຄື່ອງພິມເລີ່ມຕົ້ນ"

#. DWRL2
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3156385\n"
"help.text"
msgid "To set the default printing options for $[officename] Impress, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - Print</menuitem>."
msgstr "ເພື່ອຕັ້ງຄ່າຕົວເລືອກການພິມເລີ່ມຕົ້ນສຳລັບ $[officename] Impress, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - ພິມ</menuitem>."

#. eFCv4
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"hd_id3153914\n"
"help.text"
msgid "Setting printer options for the current presentation"
msgstr "ການຕັ້ງຄ່າຕົວເລືອກເຄື່ອງພິມສຳລັບການນຳສະເໜີປັດຈຸບັນ"

#. UsuiV
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3154651\n"
"help.text"
msgid "Choose <emph>File - Print</emph>."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ພິມ</emph>."

#. CsxH8
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3149870\n"
"help.text"
msgid "Click the <emph>%PRODUCTNAME Impress</emph> or the <emph>Options</emph> tab page, and then select the printer options."
msgstr "ຄລິກແຖບ <emph>%PRODUCTNAME Impress</emph> ຫຼື <emph>ຕົວເລືອກ</emph>, ແລ້ວເລືອກຕົວເລືອກເຄື່ອງພິມ."

#. xAqs2
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3150431\n"
"help.text"
msgid "These settings override the default printer options in <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - Print</menuitem> for the current print job only."
msgstr "ການຕັ້ງຄ່າເຫຼົ່ານີ້ຈະແທນທີ່ຕົວເລືອກເຄື່ອງພິມເລີ່ມຕົ້ນໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - ພິມ</menuitem> ສຳລັບວຽກການພິມປັດຈຸບັນນີ້ເທົ່ານັ້ນ."

#. 5HEGY
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"hd_id4555192\n"
"help.text"
msgid "Choosing a print layout for handouts"
msgstr "ການເລືອກເຄົ້າຮ່າງການພິມສຳລັບເອກະສານແຈກ"

#. vBHgk
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id7197790\n"
"help.text"
msgid "Choose <item type=\"menuitem\">File - Print</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ໄຟລ໌ - ພິມ</item>."

#. aPptT
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id1104159\n"
"help.text"
msgid "On the <emph>General</emph> tab page of the <emph>Print</emph> dialog, select the \"Handouts\" entry from the Document listbox."
msgstr "ໃນແຖບ <emph>ທົ່ວໄປ</emph> ຂອງກ່ອງໂຕ້ຕອບ <emph>ພິມ</emph>, ໃຫ້ເລືອກລາຍການ \"ເອກະສານແຈກ\" ຈາກກ່ອງລາຍການເອກະສານ."

#. FeDHe
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id9354533\n"
"help.text"
msgid "Select the number of slides to print per page of paper."
msgstr "ເລືອກຈຳນວນສະໄລ້ທີ່ຈະພິມຕໍ່ໜ້າເຈ້ຍ."

#. RmU5G
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"hd_id6556596\n"
"help.text"
msgid "Defining print options for handouts"
msgstr "ການກຳນົດຕົວເລືອກການພິມສຳລັບເອກະສານແຈກ"

#. hYypf
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id6744285\n"
"help.text"
msgid "Click the Handout tab."
msgstr "ຄລິກແຖບ ເອກະສານແຈກ."

#. UQvRq
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id996734\n"
"help.text"
msgid "Choose <emph>Insert - Page Number</emph> to open the <emph>Header and Footer</emph> dialog box."
msgstr "ເລືອກ <emph>ແຊກ - ເລກໜ້າ</emph> ເພື່ອເປີດກ່ອງໂຕ້ຕອບ <emph>ຫົວ ແລະ ທ້າຍກະດາດ</emph>."

#. DeFiF
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id6752220\n"
"help.text"
msgid "Click <emph>Notes and Handouts</emph> to enter the header and footer text for handouts."
msgstr "ຄລິກ <emph>ບັນທຶກ ແລະ ເອກະສານແຈກ</emph> ເພື່ອປ້ອນຂໍ້ຄວາມຫົວ ແລະ ທ້າຍກະດາດສຳລັບເອກະສານແຈກ."

#. cssex
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id5703909\n"
"help.text"
msgid "You see four areas on this dialog with check boxes for Header, Date and time, Footer, and Page number. These four areas correspond to the four areas in the corners of the master handout view."
msgstr "ທ່ານຈະເຫັນສີ່ສ່ວນໃນກ່ອງໂຕ້ຕອບນີ້ພ້ອມກັບຊ່ອງໝາຍສຳລັບ ຫົວຂໍ້, ວັນທີ ແລະ ເວລາ, ທ້າຍກະດາດ, ແລະ ເລກໜ້າ. ສີ່ສ່ວນນີ້ຈະກົງກັບສີ່ສ່ວນທີ່ຢູ່ຕາມມຸມຕ່າງໆໃນມຸມມອງເອກະສານແຈກແມ່ແບບ."

#. VaD3B
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id4984282\n"
"help.text"
msgid "Enter text for header, footer, and date. Check the <emph>Page number</emph> box, if you want to number the handout pages. Ensure the <emph>Header</emph> check box is enabled if you want your header text to be printed."
msgstr "ປ້ອນຂໍ້ຄວາມສຳລັບຫົວຂໍ້, ທ້າຍກະດາດ, ແລະ ວັນທີ. ໝາຍເອົາຊ່ອງ <emph>ເລກໜ້າ</emph> ຖ້າທ່ານຕ້ອງການໃສ່ເລກໜ້າໃຫ້ກັບເອກະສານແຈກ. ໃຫ້ແນ່ໃຈວ່າໄດ້ເປີດຊ່ອງໝາຍ <emph>ຫົວຂໍ້</emph> ແລ້ວ ຖ້າທ່ານຕ້ອງການໃຫ້ຂໍ້ຄວາມຫົວຂໍ້ຖືກພິມອອກມາ."

#. hpBrY
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id816064\n"
"help.text"
msgid "Click <emph>Apply to All</emph>."
msgstr "ຄລິກ <emph>ນຳໃຊ້ກັບທັງໝົດ</emph>."

#. UYFn6
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id863063\n"
"help.text"
msgid "The fields in the master handout view on screen are not updated, but the text that you entered will be printed."
msgstr "ເຂດຂໍ້ມູນໃນມຸມມອງເອກະສານແຈກແມ່ແບບໃນໜ້າຈໍຈະບໍ່ຖືກອັບເດດ, ແຕ່ຂໍ້ຄວາມທີ່ທ່ານປ້ອນເຂົ້າໄປຈະຖືກພິມອອກມາ."

#. YHUmc
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"hd_id5036164\n"
"help.text"
msgid "Printing handouts or notes"
msgstr "ການພິມເອກະສານແຈກ ຫຼື ບັນທຶກ"

#. Dbb6d
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id2901394\n"
"help.text"
msgid "Choose <item type=\"menuitem\">File - Print</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ໄຟລ໌ - ພິມ</item>."

#. DEC3A
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id5674611\n"
"help.text"
msgid "Click the Document listbox and select the type of contents to print."
msgstr "ຄລິກກ່ອງລາຍການເອກະສານ ແລ້ວເລືອກປະເພດເນື້ອຫາທີ່ຈະພິມ."

#. DZDZG
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id1308023\n"
"help.text"
msgid "Select <emph>Handouts</emph> or <emph>Notes</emph> and select the number of slides to print on each page of paper."
msgstr "ເລືອກ <emph>ເອກະສານແຈກ</emph> ຫຼື <emph>ບັນທຶກ</emph> ແລ້ວເລືອກຈຳນວນສະໄລ້ທີ່ຈະພິມໃນແຕ່ລະໜ້າເຈ້ຍ."

#. v4SpZ
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id6821192\n"
"help.text"
msgid "If you want another layout of the slides on the printed paper pages, use the mouse to move the slides around on the Handout view."
msgstr "ຖ້າທ່ານຕ້ອງການເຄົ້າຮ່າງຂອງສະໄລ້ໃນໜ້າເຈ້ຍທີ່ພິມແບບອື່ນ, ໃຫ້ໃຊ້ເມົາສ໌ເພື່ອຍ້າຍສະໄລ້ໄປມາໃນມຸມມອງເອກະສານແຈກ."

#. CVaZL
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"hd_id3151389\n"
"help.text"
msgid "Printing a range of slides"
msgstr "ການພິມສະໄລ້ຕາມຊ່ວງທີ່ກຳນົດ"

#. ccCG7
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3146318\n"
"help.text"
msgid "Choose <emph>View - Slide Sorter</emph>."
msgstr "ເລືອກ <emph>ມຸມມອງ - ຕົວຈັດລຽງສະໄລ້</emph>."

#. 3eRhG
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3166465\n"
"help.text"
msgid "Hold down Shift, and click the range of slides that you want to print."
msgstr "ກົດ Shift ຄ້າງໄວ້, ແລ້ວຄລິກເລືອກຊ່ວງຂອງສະໄລ້ທີ່ທ່ານຕ້ອງການພິມ."

#. Gezab
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3157875\n"
"help.text"
msgid "Choose <emph>File - Print</emph>."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ພິມ</emph>."

#. t7G82
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3150746\n"
"help.text"
msgid "In the <emph>Range and copies</emph> area, click <emph>Slides</emph>."
msgstr "ໃນສ່ວນ <emph>ຊ່ວງ ແລະ ຈຳນວນສຳເນົາ</emph>, ໃຫ້ຄລິກ <emph>ສະໄລ້</emph>."

#. j8WBh
#: printing.xhp
msgctxt ""
"printing.xhp\n"
"par_id3154561\n"
"help.text"
msgid "Enter the slide numbers you want to print, and click <emph>OK</emph>."
msgstr "ປ້ອນເລກສະໄລ້ທີ່ທ່ານຕ້ອງການພິມ, ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. 8ghEM
#: rehearse_timings.xhp
msgctxt ""
"rehearse_timings.xhp\n"
"tit\n"
"help.text"
msgid "Rehearse Timings of Slide Changes"
