msgctxt ""
"print_tofit.xhp\n"
"par_id3154658\n"
"help.text"
msgid "Open the document that you want to print."
msgstr "ເປີດເອກະສານທີ່ທ່ານຕ້ອງການພິມ."

#. rVCF3
#: print_tofit.xhp
msgctxt ""
"print_tofit.xhp\n"
"par_id3145384\n"
"help.text"
msgid "In <emph>Normal View</emph>, choose <emph>Slide - Properties</emph>, and then click the <emph>Page</emph> tab."
msgstr "ໃນ <emph>ມຸມມອງປົກກະຕິ</emph>, ໃຫ້ເລືອກ <emph>ສະໄລ້ - ຄຸນສົມບັດ</emph>, ແລ້ວຄລິກແຖບ <emph>ໜ້າ</emph>."

#. Gbe2k
#: print_tofit.xhp
msgctxt ""
"print_tofit.xhp\n"
"par_id3148871\n"
"help.text"
msgid "In <emph>Layout settings </emph>area, select the <emph>Fit object to paper format</emph> check box."
msgstr "ໃນສ່ວນ <emph>ການຕັ້ງຄ່າເຄົ້າຮ່າງ</emph>, ໃຫ້ເລືອກຊ່ອງໝາຍ <emph>ປັບວັດຖຸໃຫ້ພໍດີກັບຮູບແບບເຈ້ຍ</emph>."

#. h6cpW
#: print_tofit.xhp
msgctxt ""
"print_tofit.xhp\n"
"par_id3153811\n"
"help.text"
msgid "In the <emph>Paper format</emph> area, select a <emph>Format</emph>."
msgstr "ໃນສ່ວນ <emph>ຮູບແບບເຈ້ຍ</emph>, ໃຫ້ເລືອກ <emph>ຮູບແບບ</emph>."

#. 7S6Dr
#: print_tofit.xhp
msgctxt ""
"print_tofit.xhp\n"
"par_id3150431\n"
"help.text"
msgid "Click <emph>OK</emph>. The slide is resized to fit the printed page, while maintaining the relative positions of the objects on the slide."
msgstr "ຄລິກ <emph>ຕົກລົງ</emph>. ສະໄລ້ຈະຖືກປ່ຽນຂະໜາດໃຫ້ພໍດີກັບໜ້າເຈ້ຍທີ່ພິມ, ໃນຂະນະທີ່ຍັງຮັກສາຕຳແໜ່ງສຳພັນຂອງວັດຖຸຕ່າງໆໃນສະໄລ້ໄວ້."

