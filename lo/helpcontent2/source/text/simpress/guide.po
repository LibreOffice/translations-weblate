msgctxt ""
"presenter_console.xhp\n"
"par_id311512825411947\n"
"help.text"
msgid "<image src=\"media/helpimg/sd_PresenterConsole01.png\" id=\"img_id481512825411947\" width=\"640\" height=\"360\"><alt id=\"alt_id151512825411947\">Presenter console normal mode</alt></image>"
msgstr "<image src=\"media/helpimg/sd_PresenterConsole01.png\" id=\"img_id481512825411947\" width=\"640\" height=\"360\"><alt id=\"alt_id151512825411947\">ຄອນໂຊລຜູ້ບັນຍາຍໂໝດປົກກະຕິ</alt></image>"

