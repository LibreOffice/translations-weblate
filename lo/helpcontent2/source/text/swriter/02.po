"par_id3147034\n"
"help.text"
msgid "EQ or =="
msgstr "EQ ຫຼື =="

#. WcTEB
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150936\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/eq\">Checks if selected values are equal.</ahelp> If they are unequal, the result is zero, otherwise 1 (true) appears."
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/eq\">ກວດສອບວ່າຄ່າທີ່ເລືອກເທົ່າກັນຫຼືບໍ່.</ahelp> ຖ້າບໍ່ເທົ່າກັນ ຜົນລັບຈະເປັນສູນ, ຖ້າເທົ່າກັນຈະສະແດງ 1 (ຈິງ)."

#. vuDKJ
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150961\n"
"help.text"
msgid "Example: <A1> EQ 2 displays 1, if the content of A1 equals 2"
msgstr "ຕົວຢ່າງ: <A1> EQ 2 ສະແດງ 1, ຖ້າຂໍ້ມູນໃນ A1 ເທົ່າກັບ 2"

#. b2AXc
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3154370\n"
"help.text"
msgid "Not Equal"
msgstr "ບໍ່ເທົ່າກັບ"

#. jsDQ8
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150503\n"
"help.text"
msgid "NEQ or !="
msgstr "NEQ ຫຼື !="

#. rMcNe
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150526\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/neq\">Tests for inequality between selected values.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/neq\">ທົດສອບຄວາມບໍ່ເທົ່າກັນລະຫວ່າງຄ່າທີ່ເລືອກ.</ahelp>"

#. STM3V
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3147524\n"
"help.text"
msgid "Example: <A1> NEQ 2 displays 0 (wrong), if the content of A1 equals 2"
msgstr "ຕົວຢ່າງ: <A1> NEQ 2 ສະແດງ 0 (ເທັດ), ຖ້າຂໍ້ມູນໃນ A1 ເທົ່າກັບ 2"

#. FuXYL
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3147553\n"
"help.text"
msgid "Less than or Equal"
msgstr "ໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບ"

#. m6G89
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153622\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/leq\">Tests for values less than or equal to a specified value.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/leq\">ທົດສອບຄ່າທີ່ໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບຄ່າທີ່ລະບຸ.</ahelp>"

#. FeJXs
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3151280\n"
"help.text"
msgid "Example: <A1> LEQ 2 displays 1 (true), if the content of A1 is less than or equal to 2"
msgstr "ຕົວຢ່າງ: <A1> LEQ 2 ສະແດງ 1 (ຈິງ), ຖ້າຂໍ້ມູນໃນ A1 ໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບ 2"

#. 24FA3
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153729\n"
"help.text"
msgid "Greater than or Equal"
msgstr "ຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ"

#. DKZmP
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3148876\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/geq\">Tests for values greater than or equal to a specified value.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/geq\">ທົດສອບຄ່າທີ່ຫຼາຍກວ່າ ຫຼື ເທົ່າກັບຄ່າທີ່ລະບຸ.</ahelp>"

#. pdd5D
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3148898\n"
"help.text"
msgid "Example: <A1> GEQ 2 displays 1 (true), if the content of A1 is greater than or equal to 2"
msgstr "ຕົວຢ່າງ: <A1> GEQ 2 ສະແດງ 1 (ຈິງ), ຖ້າຂໍ້ມູນໃນ A1 ຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 2"

#. zEADu
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150836\n"
"help.text"
msgid "Less"
msgstr "ໜ້ອຍກວ່າ"

#. G4UeN
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3155411\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/l\">Tests for values less than a specified value.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/l\">ທົດສອບຄ່າທີ່ໜ້ອຍກວ່າຄ່າທີ່ລະບຸ.</ahelp>"

#. ZF7Jb
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3155433\n"
"help.text"
msgid "Example: <A1> L 2 displays 1 (true), if the content of A1 is less than 2"
msgstr "ຕົວຢ່າງ: <A1> L 2 ສະແດງ 1 (ຈິງ), ຖ້າຫາກເນື້ອໃນຂອງ A1 ນ້ອຍກວ່າ 2"

#. R7RyE
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150720\n"
"help.text"
msgid "Greater"
msgstr "ໃຫຍ່ກວ່າ"

#. ytwUF
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3147310\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/g\">Tests for values greater than a specified value.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/g\">ກວດສອບຫາຄ່າທີ່ໃຫຍ່ກວ່າຄ່າທີ່ລະບຸໄວ້.</ahelp>"

#. UsxXH
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3147333\n"
"help.text"
msgid "Example: <A1> G 2 displays 1 (true), if the content of A1 is greater than 2"
msgstr "ຕົວຢ່າງ: <A1> G 2 ສະແດງ 1 (ຈິງ), ຖ້າຫາກເນື້ອໃນຂອງ A1 ໃຫຍ່ກວ່າ 2"

#. 9DyRz
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3148408\n"
"help.text"
msgid "Boolean Or"
msgstr "ບູລີນ Or"

#. guFCu
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150274\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/or\">Tests for values matching the Boolean OR.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/or\">ກວດສອບຫາຄ່າທີ່ກົງກັບບູລີນ OR.</ahelp>"

#. wmnDC
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3150297\n"
"help.text"
msgid "Example: 0 OR 0 displays 0 (false), anything else results in 1 (true)"
msgstr "ຕົວຢ່າງ: 0 OR 0 ສະແດງ 0 (ເທັດ), ຄ່າອື່ນໆຈະໃຫ້ຜົນເປັນ 1 (ຈິງ)"

#. GNQAT
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3149434\n"
"help.text"
msgid "Boolean X Or"
msgstr "ບູລີນ X Or"

#. EQwEt
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3146980\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/xor\">Tests for values matching the Boolean exclusive OR.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/xor\">ກວດສອບຫາຄ່າທີ່ກົງກັບບູລີນ exclusive OR (XOR).</ahelp>"

#. N9cHQ
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3147003\n"
"help.text"
msgid "Example: 1 XOR 0 displays 1 (true)"
msgstr "ຕົວຢ່າງ: 1 XOR 0 ສະແດງ 1 (ຈິງ)"

#. CNW42
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3152925\n"
"help.text"
msgid "Boolean And"
msgstr "ບູລີນ And"

#. x4HL7
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153792\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/and\">Tests for values matching the Boolean AND.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/and\">ກວດສອບຫາຄ່າທີ່ກົງກັບບູລີນ AND.</ahelp>"

#. DFCfW
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153814\n"
"help.text"
msgid "Example: 1 AND 2 displays 1 (true)"
msgstr "ຕົວຢ່າງ: 1 AND 2 ສະແດງ 1 (ຈິງ)"

#. a23Nq
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153938\n"
"help.text"
msgid "Boolean Not"
msgstr "ບູລີນ Not"

#. oEENQ
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3148633\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/not\">Tests for values matching the Boolean NOT.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/not\">ກວດສອບຫາຄ່າທີ່ກົງກັບບູລີນ NOT.</ahelp>"

#. r4fRG
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3148655\n"
"help.text"
msgid "Example: NOT 1 (true) displays 0 (false)"
msgstr "ຕົວຢ່າງ: NOT 1 (ຈິງ) ສະແດງ 0 (ເທັດ)"

#. 5JNFn
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"hd_id3154240\n"
"help.text"
msgid "Statistical Functions"
msgstr "ຟັງຊັນທາງສະຖິຕິ"

#. CEssi
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3154263\n"
"help.text"
msgid "<ahelp hid=\".\">You can choose from the following statistical functions:</ahelp>"
msgstr "<ahelp hid=\".\">ທ່ານສາມາດເລືອກຈາກຟັງຊັນທາງສະຖິຕິດັ່ງຕໍ່ໄປນີ້:</ahelp>"

#. AeKzo
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id541599496194035\n"
"help.text"
msgid "Function"
msgstr "ຟັງຊັນ"

#. fLyDG
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id481599496194036\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. z9BBL
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id331599524563749\n"
"help.text"
msgid "Example"
msgstr "ຕົວຢ່າງ"

#. SimgP
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153176\n"
"help.text"
msgid "Mean"
msgstr "ຄ່າສະເລ່ຍ"

#. Gu59Y
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3154076\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/mean\">Calculates the arithmetic mean of the values in an area or a list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/mean\">ຄິດໄລ່ຄ່າສະເລ່ຍເລກຄະນິດຂອງຄ່າຕ່າງໆໃນຂອບເຂດ ຫຼື ໃນລາຍການ.</ahelp>"

#. GjHGV
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3145625\n"
"help.text"
msgid "Example: MEAN 10|30|20 displays 20"
msgstr "ຕົວຢ່າງ: MEAN 10|30|20 ສະແດງ 20"

#. TNZeD
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3145652\n"
"help.text"
msgid "Minimum Value"
msgstr "ຄ່ານ້ອຍສຸດ"

#. 9CKG8
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3155281\n"
