msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/min\">ຄິດໄລ່ຄ່ານ້ອຍທີ່ສຸດໃນຂອບເຂດ ຫຼື ໃນລາຍການ.</ahelp>"

#. F9J3k
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3155304\n"
"help.text"
msgid "Example: MIN 10|30|20 displays 10"
msgstr "ຕົວຢ່າງ: MIN 10|30|20 ສະແດງ 10"

#. G4CMT
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3153993\n"
"help.text"
msgid "Maximum Value"
msgstr "ຄ່າໃຫຍ່ສຸດ"

#. mCGfj
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3154726\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputwinmenu/max\">Calculates the maximum value in an area or a list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputwinmenu/max\">ຄິດໄລ່ຄ່າໃຫຍ່ທີ່ສຸດໃນຂອບເຂດ ຫຼື ໃນລາຍການ.</ahelp>"

#. fN5WF
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id3154748\n"
"help.text"
msgid "Example: MAX 10|30|20 displays 30"
msgstr "ຕົວຢ່າງ: MAX 10|30|20 ສະແດງ 30"

#. 76riF
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id21599557699262\n"
"help.text"
msgid "Product"
msgstr "ຜົນຄູນ"

#. 5caRN
