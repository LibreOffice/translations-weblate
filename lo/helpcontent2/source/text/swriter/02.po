msgctxt ""
"14020000.xhp\n"
"par_id671599563830630\n"
"help.text"
msgid "Calculates the product of the selected cells."
msgstr "ຄິດໄລ່ຜົນຄູນຂອງຫ້ອງທີ່ເລືອກ."

#. bwMRb
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id631599557734781\n"
"help.text"
msgid "Example: PRODUCT <A2:C2> displays the product of the values in cells A2 to C2"
msgstr "ຕົວຢ່າງ: PRODUCT <A2:C2> ສະແດງຜົນຄູນຂອງຄ່າຕ່າງໆໃນຫ້ອງ A2 ຫາ C2"

#. DXVgk
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id31599557699262\n"
"help.text"
msgid "Count"
msgstr "ນັບ"

#. 53YC3
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id331599557734781\n"
"help.text"
msgid "Counts the number of non empty cells."
msgstr "ນັບຈຳນວນຫ້ອງທີ່ບໍ່ຫວ່າງ."

#. hgQfG
#: 14020000.xhp
msgctxt ""
"14020000.xhp\n"
"par_id141599563739504\n"
