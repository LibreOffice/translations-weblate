"hd_id3151083\n"
"help.text"
msgid "New user-defined index"
msgstr "ດັດຊະນີກຳນົດເອງໃໝ່"

#. ATPwD
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3150161\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/new\">Opens the <emph>Create New User-defined Index</emph> dialog where you can create a custom index.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/new\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ສ້າງດັດຊະນີກຳນົດເອງໃໝ່</emph> ເຊິ່ງທ່ານສາມາດສ້າງດັດຊະນີແບບພິເສດໄດ້.</ahelp>"

#. 6T9op
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id961680430335329\n"
"help.text"
msgid "<image src=\"cmd/lc_insertmultiindex.svg\" id=\"img_id291680430335329\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id991680430335329\">New User-defined Index Icon</alt></image>"
msgstr "<image src=\"cmd/lc_insertmultiindex.svg\" id=\"img_id291680430335329\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id991680430335329\">ໄອຄອນດັດຊະນີກຳນົດເອງໃໝ່</alt></image>"

#. ZFnrq
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id701680430335329\n"
"help.text"
msgid "New User-defined Index"
msgstr "ດັດຊະນີກຳນົດເອງໃໝ່"

#. rEAy8
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3153296\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. qhnVS
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3153507\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/newuserindexdialog/NewUserIndexDialog\">Enter a name for the new user-defined index. The new index is added to the list of available indexes and tables.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/newuserindexdialog/NewUserIndexDialog\">ປ້ອນຊື່ສຳລັບດັດຊະນີກຳນົດເອງໃໝ່. ດັດຊະນີໃໝ່ນີ້ຈະຖືກເພີ່ມເຂົ້າໃນລາຍການດັດຊະນີ ແລະ ຕາຕະລາງທີ່ມີໃຫ້.</ahelp>"

#. uxWFA
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3153527\n"
"help.text"
msgid "Entry"
msgstr "ລາຍການ"

#. CWmA3
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3151312\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/entryed\">Displays the text that is selected in the document. If you want, you can enter a different word for the index entry. The selected text in the document is not changed.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/entryed\">ສະແດງຂໍ້ຄວາມທີ່ຖືກເລືອກໃນເອກະສານ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ້ອນຄຳອື່ນສຳລັບລາຍການດັດຊະນີໄດ້. ຂໍ້ຄວາມທີ່ຖືກເລືອກໃນເອກະສານຈະບໍ່ມີການປ່ຽນແປງ.</ahelp>"

#. K3C4i
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id201673355540477\n"
"help.text"
msgid "Or, edit the index entry if necessary. When you modify the index entry, the new text only appears in the index, and not at the index entry anchor in the document. For example, you can enter an index with comments such as \"Basics, see also General\"."
msgstr "ຫຼື ແກ້ໄຂລາຍການດັດຊະນີຫາກຈຳເປັນ. ເມື່ອທ່ານແກ້ໄຂລາຍການດັດຊະນີ, ຂໍ້ຄວາມໃໝ່ຈະປາກົດສະເພາະໃນດັດຊະນີເທົ່ານັ້ນ, ບໍ່ແມ່ນຢູ່ບ່ອນປັກມຸດ (anchor) ຂອງລາຍການດັດຊະນີໃນເອກະສານ. ຕົວຢ່າງ: ທ່ານສາມາດປ້ອນດັດຊະນີພ້ອມຄຳອະທິບາຍເຊັ່ນ \"ພື້ນຖານ, ເບິ່ງທົ່ວໄປນຳ\"."

#. BeXDF
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id641680430780293\n"
"help.text"
msgid "Update entry from selection"
msgstr "ອັບເດດລາຍການຈາກສິ່ງທີ່ເລືອກ"

#. AtLqT
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id461680430803357\n"
"help.text"
msgid "Click the icon to update <emph>Entry</emph> with the current text selection in the document."
msgstr "ຄລິກທີ່ໄອຄອນເພື່ອອັບເດດ <emph>ລາຍການ</emph> ດ້ວຍຂໍ້ຄວາມທີ່ເລືອກຢູ່ໃນປັດຈຸບັນໃນເອກະສານ."

#. jtvEY
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id731680430862525\n"
"help.text"
msgid "<image src=\"cmd/32/refresh.png\" id=\"img_id611680430862525\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id161680430862525\">Update Entry from Selection Icon</alt></image>"
msgstr "<image src=\"cmd/32/refresh.png\" id=\"img_id611680430862525\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id161680430862525\">ໄອຄອນອັບເດດລາຍການຈາກສິ່ງທີ່ເລືອກ</alt></image>"

#. xCTzW
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id801680430862525\n"
"help.text"
msgid "Update Entry from Selection"
msgstr "ອັບເດດລາຍການຈາກສິ່ງທີ່ເລືອກ"

#. KVCfP
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3154480\n"
"help.text"
msgid "1st key"
msgstr "ລະດັບທີ 1"

#. t63PE
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3152953\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/key1cb\">Makes the current selection a subentry of the word that you enter here. For example, if you select \"cold\", and enter \"weather\" as the 1st key, the index entry is \"weather, cold\".</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/key1cb\">ເຮັດໃຫ້ສິ່ງທີ່ເລືອກປັດຈຸບັນເປັນລາຍການຍ່ອຍຂອງຄຳທີ່ທ່ານປ້ອນຢູ່ທີ່ນີ້. ຕົວຢ່າງ: ຖ້າທ່ານເລືອກ \"ໜາວ\", ແລະ ປ້ອນ \"ອາກາດ\" ເປັນລະດັບທີ 1, ລາຍການດັດຊະນີຈະແມ່ນ \"ອາກາດ, ໜາວ\".</ahelp>"

#. RK9e6
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3154572\n"
"help.text"
msgid "2nd key"
msgstr "ລະດັບທີ 2"

#. AMWwE
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3155904\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/key2cb\">Makes the current selection a sub-subentry of the 1st key. For example, if you select \"cold\", and enter \"weather\" as the 1st key and \"winter\" as the 2nd key, the index entry is \"weather, winter, cold\".</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/key2cb\">ເຮັດໃຫ້ສິ່ງທີ່ເລືອກປັດຈຸບັນເປັນລາຍການຍ່ອຍຊ້ອນຂອງລະດັບທີ 1. ຕົວຢ່າງ: ຖ້າທ່ານເລືອກ \"ໜາວ\", ແລະ ປ້ອນ \"ອາກາດ\" ເປັນລະດັບທີ 1 ແລະ \"ລະດູ\" ເປັນລະດັບທີ 2, ລາຍການດັດຊະນີຈະແມ່ນ \"ອາກາດ, ລະດູ, ໜາວ\".</ahelp>"

#. ncuAv
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3155174\n"
"help.text"
msgid "Phonetic reading"
msgstr "ການອ່ານອອກສຽງ"

#. 3EGx9
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3149484\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/phonetic0ed\">Enter the phonetic reading for the corresponding entry. For example, if a Japanese Kanji word has more than one pronunciation, enter the correct pronunciation as a Katakana word. The Kanji word is then sorted according to the phonetic reading entry.</ahelp> This option is only available if Asian language support is enabled."
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/phonetic0ed\">ປ້ອນການອ່ານອອກສຽງສຳລັບລາຍການທີ່ກ່ຽວຂ້ອງ. ຕົວຢ່າງ: ຖ້າຄຳສັບພາສາຍີ່ປຸ່ນ (Kanji) ມີການອອກສຽງຫຼາຍກວ່າໜຶ່ງແບບ, ໃຫ້ປ້ອນການອອກສຽງທີ່ຖືກຕ້ອງເປັນຄຳ Katakana. ຈາກນັ້ນຄຳ Kanji ຈະຖືກຈັດລຽງຕາມການອ່ານອອກສຽງນັ້ນ.</ahelp> ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະເມື່ອມີການເປີດໃຊ້ການຮອງຮັບພາສາອາຊີ."

#. 79kAq
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3143284\n"
"help.text"
msgid "Main Entry"
msgstr "ລາຍການຫຼັກ"

#. Dbyz6
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3151248\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/mainentrycb\">Makes the selected text the main entry in an alphabetical index.</ahelp> $[officename] displays the page number of the main entry in a different format than the other entries in the index."
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/mainentrycb\">ກຳນົດໃຫ້ຂໍ້ຄວາມທີ່ເລືອກເປັນລາຍການຫຼັກໃນດັດຊະນີລຽງຕາມຕົວອັກສອນ.</ahelp> $[officename] ຈະສະແດງເລກໜ້າຂອງລາຍການຫຼັກໃນຮູບແບບທີ່ແຕກຕ່າງຈາກລາຍການອື່ນໆໃນດັດຊະນີ."

#. TZhEr
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3149821\n"
"help.text"
msgid "Index level"
msgstr "ລະດັບດັດຊະນີ"

#. vtaMk
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id181679725408785\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/levelnf\">Specify the index level for the inserted index entry.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/levelnf\">ກຳນົດລະດັບດັດຊະນີສຳລັບລາຍການດັດຊະນີທີ່ແຊກເຂົ້າໄປ.</ahelp>"

#. TiRwJ
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3149175\n"
"help.text"
msgid "This option is available only for table of contents and user-defined index entries."
msgstr "ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະກັບສານບັນ ແລະ ລາຍການດັດຊະນີທີ່ກຳນົດເອງເທົ່ານັ້ນ."

#. kdXNe
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id451679725054579\n"
"help.text"
msgid "For Selected Entry"
msgstr "ສຳລັບລາຍການທີ່ເລືອກ"

#. EBemh
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id351680468441462\n"
"help.text"
msgid "The following three options are available when a text selection is loaded in <emph>Entry</emph>, either by selecting the text in the document and then opening the dialog, or by using <emph>Update entry from selection</emph> in the dialog."
msgstr "ສາມຕົວເລືອກຕໍ່ໄປນີ້ຈະມີໃຫ້ໃຊ້ເມື່ອມີການໂຫຼດຂໍ້ຄວາມທີ່ເລືອກເຂົ້າໃນ <emph>ລາຍການ</emph>, ບໍ່ວ່າຈະເປັນການເລືອກຂໍ້ຄວາມໃນເອກະສານກ່ອນແລ້ວຈຶ່ງເປີດກ່ອງໂຕ້ຕອບ, ຫຼື ການໃຊ້ <emph>ອັບເດດລາຍການຈາກສິ່ງທີ່ເລືອກ</emph> ໃນກ່ອງໂຕ້ຕອບ."

#. BLpnN
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3156278\n"
"help.text"
msgid "Apply to all other occurrences"
msgstr "ໃຊ້ກັບທຸກບ່ອນທີ່ປາກົດຄຳນີ້"

#. hDn3k
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3145783\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/applytoallcb\">Automatically marks all other occurrences of the selected text in the document. For a modified entry, the match is conducted on the original selection, but the modified entry is inserted as the index entry. Text in headers, footers, and frames is not included.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/applytoallcb\">ໝາຍທຸກໆບ່ອນທີ່ປາກົດຂໍ້ຄວາມທີ່ເລືອກໃນເອກະສານໂດຍອັດຕະໂນມັດ. ສຳລັບລາຍການທີ່ຖືກແກ້ໄຂ, ການຄົ້ນຫາຈະອີງຕາມຂໍ້ຄວາມທີ່ເລືອກເບື້ອງຕົ້ນ, ແຕ່ຈະແຊກລາຍການທີ່ແກ້ໄຂແລ້ວເຂົ້າເປັນລາຍການດັດຊະນີ. ຂໍ້ຄວາມໃນຫົວເຈ້ຍ, ທ້າຍເຈ້ຍ ແລະ ກອບ ຈະບໍ່ຖືກລວມເຂົ້າ.</ahelp>"

#. 9ABNB
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3147741\n"
"help.text"
msgid "Whole words only"
msgstr "ພຽງແຕ່ທັງໝົດຄຳ"

#. 4q3Vj
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3149568\n"
"help.text"
msgid "Match case"
msgstr "ຕົວພິມໃຫຍ່/ນ້ອຍຕ້ອງກົງກັນ"

#. X8xFe
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3147496\n"
"help.text"
msgid "To include all occurrences of a text passage in an index, select the text, choose<emph> Edit - Find & Replace</emph>, and click <emph>Find All</emph>. Then choose <emph>Insert - Table of Contents and Index - Index Entry</emph> and click <emph>Insert</emph>."
msgstr "ເພື່ອລວມທຸກໆບ່ອນທີ່ປາກົດຂອງຂໍ້ຄວາມເຂົ້າໃນດັດຊະນີ, ໃຫ້ເລືອກຂໍ້ຄວາມ, ເລືອກ <emph>ແກ້ໄຂ - ຄົ້ນຫາ ແລະ ແທນທີ່</emph>, ແລ້ວຄລິກ <emph>ຄົ້ນຫາທັງໝົດ</emph>. ຈາກນັ້ນເລືອກ <emph>ແຊກ - ສານບັນ ແລະ ດັດຊະນີ - ລາຍການດັດຊະນີ</emph> ແລະ ຄລິກ <emph>ແຊກ</emph>."

#. Gv4NF
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3146345\n"
"help.text"
msgid "Insert"
msgstr "ແຊກ"

#. CWNVf
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3149845\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/insert\">Marks an index entry in your text.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/insert\">ໝາຍລາຍການດັດຊະນີໃນຂໍ້ຄວາມຂອງທ່ານ.</ahelp>"

#. c7vhJ
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3148855\n"
"help.text"
msgid "Close"
msgstr "ປິດ"

#. mGVfH
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3154777\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/close\">Closes the dialog.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/close\">ປິດກ່ອງໂຕ້ຕອບ.</ahelp>"

#. 9xER9
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3145785\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. rtZ32
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3155919\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/delete\">Deletes the selected entry from the index. The entry text in the document is not deleted.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/delete\">ລຶບລາຍການທີ່ເລືອກອອກຈາກດັດຊະນີ. ຂໍ້ຄວາມຂອງລາຍການໃນເອກະສານຈະບໍ່ຖືກລຶບ.</ahelp>"

#. uFr5y
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id941680478201536\n"
"help.text"
msgid "The following navigation buttons are only available in the <emph>Edit Index Entry</emph> dialog."
msgstr "ປຸ່ມນຳທາງຕໍ່ໄປນີ້ມີໃຫ້ໃຊ້ສະເພາະໃນກ່ອງໂຕ້ຕອບ <emph>ແກ້ໄຂລາຍການດັດຊະນີ</emph> ເທົ່ານັ້ນ."

#. Re4K4
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3151384\n"
"help.text"
msgid "Previous entry (same name)"
msgstr "ລາຍການກ່ອນໜ້າ (ຊື່ດຽວກັນ)"

#. VvKuV
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3155869\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/first\">Jumps to the previous index entry with the same entry and type as the current index entry.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/first\">ໂດດໄປຫາລາຍການດັດຊະນີກ່ອນໜ້າທີ່ມີຂໍ້ຄວາມ ແລະ ປະເພດດຽວກັນກັບລາຍການປັດຈຸບັນ.</ahelp>"

#. nkQAF
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3147420\n"
"help.text"
msgid "<image id=\"img_id3149551\" src=\"cmd/lc_firstrecord.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149551\">Previous entry (same name) Icon</alt></image>"
msgstr "<image id=\"img_id3149551\" src=\"cmd/lc_firstrecord.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149551\">ໄອຄອນລາຍການກ່ອນໜ້າ (ຊື່ດຽວກັນ)</alt></image>"

#. iAfFv
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3150550\n"
"help.text"
msgid "Previous entry (same name)"
msgstr "ລາຍການກ່ອນໜ້າ (ຊື່ດຽວກັນ)"

#. ABDK2
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3147736\n"
"help.text"
msgid "Next entry (same name)"
msgstr "ລາຍການຖັດໄປ (ຊື່ດຽວກັນ)"

#. sMpb5
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3149829\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/last\">Jumps to the next index entry with the same entry and type as the current index entry.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/last\">ໂດດໄປຫາລາຍການດັດຊະນີຖັດໄປທີ່ມີຂໍ້ຄວາມ ແລະ ປະເພດດຽວກັນກັບລາຍການປັດຈຸບັນ.</ahelp>"

#. D5DfT
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3153298\n"
"help.text"
msgid "<image id=\"img_id3153309\" src=\"cmd/lc_lastrecord.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153309\">Next entry (same name) Icon</alt></image>"
msgstr "<image id=\"img_id3153309\" src=\"cmd/lc_lastrecord.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153309\">ໄອຄອນລາຍການຖັດໄປ (ຊື່ດຽວກັນ)</alt></image>"

#. xsGLv
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3156108\n"
"help.text"
msgid "Next entry (same name)"
msgstr "ລາຍການຖັດໄປ (ຊື່ດຽວກັນ)"

#. xNpTa
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3155080\n"
"help.text"
msgid "Previous entry"
msgstr "ລາຍການກ່ອນໜ້າ"

#. fo4yy
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3154327\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/previous\">Jumps to the previous index entry of the same type in the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/previous\">ໂດດໄປຫາລາຍການດັດຊະນີກ່ອນໜ້າທີ່ມີປະເພດດຽວກັນໃນເອກະສານ.</ahelp>"

#. 84DKp
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3148785\n"
"help.text"
msgid "<image id=\"img_id3148791\" src=\"cmd/lc_arrowshapes.left-arrow.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3148791\">Previous Entry Icon</alt></image>"
msgstr "<image id=\"img_id3148791\" src=\"cmd/lc_arrowshapes.left-arrow.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3148791\">ໄອຄອນລາຍການກ່ອນໜ້າ</alt></image>"

#. FqhyE
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3153129\n"
"help.text"
msgid "Previous entry"
msgstr "ລາຍການກ່ອນໜ້າ"

#. eBfbt
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"hd_id3154617\n"
"help.text"
msgid "Next entry"
msgstr "ລາຍການຖັດໄປ"

#. aLSWm
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3154633\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indexentry/next\">Jumps to the next index entry of the same type in the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indexentry/next\">ໂດດໄປຫາລາຍການດັດຊະນີຖັດໄປຂອງປະເພດດຽວກັນໃນເອກະສານ.</ahelp>"

#. fMA3a
#: 04120100.xhp
msgctxt ""
