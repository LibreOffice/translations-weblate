msgid "<image id=\"img_id3154020\" src=\"cmd/lc_arrowshapes.right-arrow.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3154020\">Next Entry Icon</alt></image>"
msgstr "<image id=\"img_id3154020\" src=\"cmd/lc_arrowshapes.right-arrow.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3154020\">ໄອຄອນລາຍການຖັດໄປ</alt></image>"

#. wpTeb
#: 04120100.xhp
msgctxt ""
"04120100.xhp\n"
"par_id3149965\n"
"help.text"
msgid "Next entry"
msgstr "ລາຍການຖັດໄປ"

#. 78xJ7
#: 04120100.xhp
