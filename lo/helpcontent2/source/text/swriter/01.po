msgctxt ""
"05060900.xhp\n"
"par_id3151028\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/frmaddpage/printframe\">Includes the selected item when you print the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/frmaddpage/printframe\">ລວມລາຍການທີ່ເລືອກເຂົ້າໃນເວລາທີ່ທ່ານພິມເອກະສານ.</ahelp>"

