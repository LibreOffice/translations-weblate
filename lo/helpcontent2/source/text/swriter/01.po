#. 6dwhJ
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3150110\n"
"help.text"
msgid "<ahelp hid=\".\">Prevents the selected section from being edited.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອງກັນບໍ່ໃຫ້ແກ້ໄຂສ່ວນທີ່ເລືອກ.</ahelp>"

#. mG7PE
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"hd_id3145261\n"
"help.text"
msgid "With password"
msgstr "ດ້ວຍລະຫັດຜ່ານ"

#. 9RXy6
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3149555\n"
"help.text"
msgid "<ahelp hid=\".\">Protects the selected section with a password. The password must have a minimum of 5 characters.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອງກັນສ່ວນທີ່ເລືອກດ້ວຍລະຫັດຜ່ານ. ລະຫັດຜ່ານຕ້ອງມີຢ່າງໜ້ອຍ 5 ຕົວອັກສອນ.</ahelp>"

#. uciGn
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"hd_id3150549\n"
"help.text"
msgid "Password"
msgstr "ລະຫັດຜ່ານ"

#. An8TC
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3147742\n"
"help.text"
msgid "<ahelp hid=\".\">Opens a dialog where you can change the current password.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບທີ່ທ່ານສາມາດປ່ຽນລະຫັດຜ່ານປັດຈຸບັນໄດ້.</ahelp>"

#. g7Rcr
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"hd_id3146333\n"
"help.text"
msgid "Hide"
msgstr "ຊ້ອນ"

#. xoPWA
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"hd_id3149830\n"
"help.text"
msgid "Hide"
msgstr "ຊ້ອນ"

#. EZthG
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3148849\n"
"help.text"
msgid "<ahelp hid=\".\">Hides and prevents the selected section from being printed.</ahelp> The components of a hidden sections appear gray in the Navigator. When you rest your mouse pointer over a hidden component in the Navigator, the Help tip \"hidden\" is displayed."
msgstr "<ahelp hid=\".\">ຊ້ອນ ແລະ ປ້ອງກັນບໍ່ໃຫ້ພິມສ່ວນທີ່ເລືອກອອກມາ.</ahelp> ອົງປະກອບຂອງສ່ວນທີ່ຊ້ອນຢູ່ຈະປະກົດເປັນສີເທົາໃນຕົວນຳທາງ (Navigator). ເມື່ອທ່ານວາງເຄີເຊີເມົາໄວ້ເທິງອົງປະກອບທີ່ຊ້ອນຢູ່ນັ້ນ, ຈະມີຂໍ້ຄວາມຊ່ວຍເຫຼືອ \"ຊ້ອນຢູ່\" ສະແດງຂຶ້ນມາ."

#. UaiNQ
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3155074\n"
"help.text"
msgid "You cannot hide a section if it is the only content on a page, or in a header, footer, footnote, frame, or table cell."
msgstr "ທ່ານບໍ່ສາມາດຊ້ອນສ່ວນໃດໜຶ່ງໄດ້ ຖ້າມັນເປັນເນື້ອໃນດຽວໃນໜ້າເຈ້ຍ, ຫຼື ຢູ່ໃນຫົວເຈ້ຍ, ທ້າຍເຈ້ຍ, ເຊິງອັດ, ກອບ, ຫຼື ເຊວຕາຕະລາງ."

#. TmAhd
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"hd_id3154323\n"
"help.text"
msgid "With condition"
msgstr "ດ້ວຍເງື່ອນໄຂ"

#. SG3TB
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3154343\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the condition that must be met to hide the section.</ahelp> A condition is a <link href=\"text/swriter/01/04090200.xhp\">logical expression</link> and must resolve to TRUE or FALSE."
msgstr "<ahelp hid=\".\">ປ້ອນເງື່ອນໄຂທີ່ຕ້ອງກົງກັນເພື່ອຊ້ອນສ່ວນ.</ahelp> ເງື່ອນໄຂແມ່ນ <link href=\"text/swriter/01/04090200.xhp\">ສຳນວນທາງຕັກກະສາດ</link> ແລະ ຕ້ອງມີຄ່າເປັນ ຈິງ (TRUE) ຫຼື ເທັດ (FALSE)."

#. EBKbm
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3150086\n"
"help.text"
msgid "For example, you can create the field variable <emph>x</emph> and set its value to 1. Then specify a condition based on this variable for hiding a section, such as: <emph>x EQ 1</emph> to hide the section. If you want to display the section, set the value of the variable <emph>x</emph> to 0."
msgstr "ຕົວຢ່າງ: ທ່ານສາມາດສ້າງຕົວປ່ຽນຟິວ <emph>x</emph> ແລະ ຕັ້ງຄ່າໃຫ້ເປັນ 1. ຈາກນັ້ນລະບຸເງື່ອນໄຂໂດຍອີງໃສ່ຕົວປ່ຽນນີ້ເພື່ອຊ້ອນສ່ວນ ເຊັ່ນ: <emph>x EQ 1</emph> ເພື່ອຊ້ອນສ່ວນ. ຖ້າທ່ານຕ້ອງການສະແດງສ່ວນນັ້ນ, ໃຫ້ຕັ້ງຄ່າຕົວປ່ຽນ <emph>x</emph> ເປັນ 0."

#. wYJfj
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id391767359626214\n"
"help.text"
msgid "When using conditions based on database fields, always fully qualify the field by specifying it as <emph>Database_name.Table_name.Field_name</emph>."
msgstr "ເມື່ອໃຊ້ເງື່ອນໄຂໂດຍອີງໃສ່ຟິວຂອງຖານຂໍ້ມູນ, ໃຫ້ລະບຸຊື່ຟິວໃຫ້ຄົບຖ້ວນສະເໝີ ໂດຍລະບຸເປັນ <emph>ຊື່ຖານຂໍ້ມູນ.ຊື່ຕາຕະລາງ.ຊື່ຟິວ</emph>."

#. SFuYt
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_idN108DF\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. j34CE
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_idN108E3\n"
"help.text"
msgid "You see this area of the dialog when the current document is an XForms document."
msgstr "ທ່ານຈະເຫັນສ່ວນນີ້ຂອງກ່ອງໂຕ້ຕອບເມື່ອເອກະສານປັດຈຸບັນເປັນເອກະສານ XForms."

#. z8Moz
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_idN108E6\n"
"help.text"
msgid "Editable in read-only document"
msgstr "ສາມາດແກ້ໄຂໄດ້ໃນເອກະສານທີ່ອ່ານໄດ້ຢ່າງດຽວ"

#. kdATA
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_idN108EA\n"
"help.text"
msgid "Select to allow editing of the section's contents even if the document is opened in read-only mode."
msgstr "ເລືອກເພື່ອອະນຸຍາດໃຫ້ແກ້ໄຂເນື້ອໃນຂອງສ່ວນໄດ້ ເຖິງແມ່ນວ່າເອກະສານຈະຖືກເປີດໃນໂໝດອ່ານໄດ້ຢ່າງດຽວກໍຕາມ."

#. Ws6Fx
#: 04020100.xhp
msgctxt ""
"04020100.xhp\n"
"par_id3158420\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090200.xhp\">Syntax for conditions</link>"
msgstr "<link href=\"text/swriter/01/04090200.xhp\">ໄວຍາກອນສຳລັບເງື່ອນໄຂ</link>"

