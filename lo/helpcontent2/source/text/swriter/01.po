#. RE7s8
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id671648814369419\n"
"help.text"
msgid "Continue at the next line which is unblocked on the right hand side."
msgstr "ຕໍ່ເນື່ອງທີ່ແຖວຖັດໄປເຊິ່ງບໍ່ມີສິ່ງກີດຂວາງຢູ່ເບື້ອງຂວາ."

#. Kd7EQ
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id341648819715404\n"
"help.text"
msgid "<image src=\"media/helpimg/line_break_sample_right.png\" id=\"img_id94164883712405\" width=\"477px\" height=\"215px\"><alt id=\"alt_id361648819712407\">Example of Line break right</alt></image>"
msgstr "<image src=\"media/helpimg/line_break_sample_right.png\" id=\"img_id94164883712405\" width=\"477px\" height=\"215px\"><alt id=\"alt_id361648819712407\">ຕົວຢ່າງການຂຶ້ນແຖວໃໝ່ເບື້ອງຂວາ</alt></image>"

#. HjTa9
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id961648814424612\n"
"help.text"
msgid "The default value for the line break is none."
msgstr "ຄ່າເລີ່ມຕົ້ນສຳລັບການຂຶ້ນແຖວໃໝ່ແມ່ນ ບໍ່ມີ."

#. L77Xt
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3149685\n"
"help.text"
msgid "You can also insert a default line break by pressing <keycode>Shift+Enter</keycode>."
msgstr "ທ່ານຍັງສາມາດແຊກການຂຶ້ນແຖວໃໝ່ແບບເລີ່ມຕົ້ນໄດ້ໂດຍການກົດ <keycode>Shift+Enter</keycode>."

#. CZccf
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"hd_id3148566\n"
"help.text"
msgid "Column Break"
msgstr "ການຕັດຄໍລຳ"

#. RoFAB
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3155182\n"
"help.text"
msgid "Inserts a manual column break (in a multiple column layout), and moves the text found to the right of the cursor to the beginning of the next <link href=\"text/swriter/01/05040500.xhp\">column</link>. A manual column break is indicated by a nonprinting border at the top of the new column."
msgstr "ແຊກການຕັດຄໍລຳດ້ວຍຕົນເອງ (ໃນຮູບແບບທີ່ມີຫຼາຍຄໍລຳ), ແລະ ຍ້າຍຂໍ້ຄວາມທີ່ຢູ່ເບື້ອງຂວາຂອງເຄີເຊີໄປຍັງຈຸດເລີ່ມຕົ້ນຂອງ <link href=\"text/swriter/01/05040500.xhp\">ຄໍລຳ</link> ຖັດໄປ. ການຕັດຄໍລຳດ້ວຍຕົນເອງຈະຖືກສະແດງດ້ວຍຂອບທີ່ບໍ່ໄດ້ພິມອອກມາຢູ່ທາງເທິງຂອງຄໍລຳໃໝ່."

#. G9g6z
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id61601653541581\n"
"help.text"
msgid "Insert a column break by pressing <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+Enter</keycode>"
msgstr "ແຊກການຕັດຄໍລຳໂດຍການກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+Enter</keycode>"

#. P7DHK
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"hd_id3149487\n"
"help.text"
msgid "Page Break"
msgstr "ການຕັດໜ້າ"

#. mHBEG
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3149102\n"
"help.text"
msgid "Inserts a manual page break, and moves the text found to the right of the cursor to the beginning of the next page. The inserted page break is indicated by a nonprinting border at the top of the new page."
msgstr "ແຊກການຕັດໜ້າດ້ວຍຕົນເອງ, ແລະ ຍ້າຍຂໍ້ຄວາມທີ່ຢູ່ເບື້ອງຂວາຂອງເຄີເຊີໄປຍັງຈຸດເລີ່ມຕົ້ນຂອງໜ້າຖັດໄປ. ການຕັດໜ້າທີ່ແຊກເຂົ້າໄປຈະຖືກສະແດງດ້ວຍຂອບທີ່ບໍ່ໄດ້ພິມອອກມາຢູ່ທາງເທິງຂອງໜ້າໃໝ່."

#. bAwS6
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3145758\n"
"help.text"
msgid "You can also insert a page break by pressing <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Enter</keycode>. However, if you want to assign the following page a different Page Style, you must use the menu command to insert the manual page break."
msgstr "ທ່ານຍັງສາມາດແຊກການຕັດໜ້າໄດ້ໂດຍການກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Enter</keycode>. ແນວໃດກໍຕາມ, ຖ້າທ່ານຕ້ອງການກຳນົດຮູບແບບໜ້າທີ່ແຕກຕ່າງກັນໃຫ້ກັບໜ້າຖັດໄປ, ທ່ານຕ້ອງໃຊ້ຄຳສັ່ງເມນູເພື່ອແຊກການຕັດໜ້າດ້ວຍຕົນເອງ."

#. cDBHn
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"hd_id3149175\n"
"help.text"
msgid "Page Style"
msgstr "ຮູບແບບໜ້າ"

#. E3CxE
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3156275\n"
"help.text"
msgid "Select the page style for the page that follows the manual page break."
msgstr "ເລືອກຮູບແບບໜ້າສຳລັບໜ້າທີ່ຖັດຈາກການຕັດໜ້າດ້ວຍຕົນເອງ."

#. VGFcT
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id71633464502255\n"
"help.text"
msgid "To switch between landscape and portrait orientation, choose the <emph>Default Page Style</emph> to apply portrait orientation or the <emph>Landscape</emph> style to apply landscape orientation."
msgstr "ເພື່ອສະຫຼັບລະຫວ່າງລັກສະນະແນວນອນ ແລະ ແນວຕັ້ງ, ໃຫ້ເລືອກ <emph>ຮູບແບບໜ້າເລີ່ມຕົ້ນ</emph> ເພື່ອໃຊ້ລັກສະນະແນວຕັ້ງ ຫຼື ຮູບແບບ <emph>ແນວນອນ</emph> ເພື່ອໃຊ້ລັກສະນະແນວນອນ."

#. iEpne
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"hd_id3145782\n"
"help.text"
msgid "Change page number"
msgstr "ປ່ຽນເລກໜ້າ"

#. G55MH
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3155917\n"
"help.text"
msgid "Assigns the page number that you specify to the page that follows the manual page break. This option is only available if you assign a different page style to the page that follows manual page break."
msgstr "ກຳນົດເລກໜ້າທີ່ທ່ານລະບຸໃຫ້ກັບໜ້າທີ່ຖັດຈາກການຕັດໜ້າດ້ວຍຕົນເອງ. ຕົວເລືອກນີ້ຈະໃຊ້ໄດ້ກໍຕໍ່ເມື່ອທ່ານກຳນົດຮູບແບບໜ້າທີ່ແຕກຕ່າງກັນໃຫ້ກັບໜ້າທີ່ຖັດຈາກການຕັດໜ້ານັ້ນ."

#. UGCug
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3155920\n"
"help.text"
msgid "Insert a <emph>Page Count in Range</emph> field from the header or footer floating menu to display the number of pages until the next reset of page numbering."
msgstr "ແຊກຟິວ <emph>ຈຳນວນໜ້າໃນຊ່ວງ</emph> ຈາກເມນູລອຍຂອງຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ ເພື່ອສະແດງຈຳນວນໜ້າຈົນກວ່າຈະມີການຕັ້ງຄ່າເລກໜ້າໃໝ່ໃນຄັ້ງຖັດໄປ."

#. EZk6A
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"hd_id3151384\n"
"help.text"
msgid "Page number"
msgstr "ເລກໜ້າ"

#. GEj9d
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3150700\n"
"help.text"
msgid "Enter the new page number for the page that follows the manual page break."
msgstr "ປ້ອນເລກໜ້າໃໝ່ສຳລັບໜ້າທີ່ຖັດຈາກການຕັດໜ້າດ້ວຍຕົນເອງ."

#. xiSAL
#: 04010000.xhp
msgctxt ""
"04010000.xhp\n"
"par_id3150554\n"
"help.text"
msgid "To display manual breaks, choose <link href=\"text/swriter/01/03100000.xhp\"><menuitem>View - Nonprinting Characters</menuitem></link>."
msgstr "ເພື່ອສະແດງການຕັດດ້ວຍຕົນເອງ, ໃຫ້ເລືອກ <link href=\"text/swriter/01/03100000.xhp\"><menuitem>ເບິ່ງ - ອັກສອນທີ່ບໍ່ໄດ້ພິມ</menuitem></link>."

#. YTDkt
#: 04020000.xhp
msgctxt ""
"04020000.xhp\n"
"tit\n"
"help.text"
msgid "Insert Section"
msgstr "ແຊກສ່ວນ"

#. cnHNX
#: 04020000.xhp
msgctxt ""
"04020000.xhp\n"
"hd_id3154108\n"
"help.text"
msgid "<variable id=\"bereicheinfuegen\"><link href=\"text/swriter/01/04020000.xhp\">Insert Section</link></variable>"
msgstr "<variable id=\"bereicheinfuegen\"><link href=\"text/swriter/01/04020000.xhp\">ແຊກສ່ວນ</link></variable>"

#. BGrBT
#: 04020000.xhp
msgctxt ""
"04020000.xhp\n"
"par_id3154480\n"
"help.text"
msgid "<variable id=\"bereich\"><ahelp hid=\".\">Inserts a text section at the cursor position in the document. You can also select a block of text and then choose this command to create a section. You can use sections to insert blocks of text from other documents, to apply custom column layouts, or to protect or to hide blocks of text if a condition is met.</ahelp></variable>"
msgstr "<variable id=\"bereich\"><ahelp hid=\".\">ແຊກສ່ວນຂໍ້ຄວາມຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີໃນເອກະສານ. ທ່ານຍັງສາມາດເລືອກກຸ່ມຂໍ້ຄວາມແລ້ວເລືອກຄຳສັ່ງນີ້ເພື່ອສ້າງສ່ວນໄດ້. ທ່ານສາມາດໃຊ້ສ່ວນຕ່າງໆເພື່ອແຊກກຸ່ມຂໍ້ຄວາມຈາກເອກະສານອື່ນ, ເພື່ອໃຊ້ຮູບແບບຄໍລຳທີ່ກຳນົດເອງ, ຫຼື ເພື່ອປ້ອງກັນ ຫຼື ຊ້ອນກຸ່ມຂໍ້ຄວາມຖ້າກົງກັບເງື່ອນໄຂ.</ahelp></variable>"

#. DrsAC
#: 04020000.xhp
msgctxt ""
"04020000.xhp\n"
"par_id3152955\n"
"help.text"
msgid "You can insert an entire document in a section, or a named section from another. You can also insert a section as a <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> link."
msgstr "ທ່ານສາມາດແຊກເອກະສານທັງໝົດລົງໃນສ່ວນໃດໜຶ່ງ, ຫຼື ແຊກສ່ວນທີ່ມີຊື່ຈາກເອກະສານອື່ນ. ທ່ານຍັງສາມາດແຊກສ່ວນເປັນລິ້ງ <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> ໄດ້."

#. saGBB
#: 04020000.xhp
msgctxt ""
"04020000.xhp\n"
"par_id3149684\n"
"help.text"
msgid "To edit a section, choose <link href=\"text/swriter/01/02170000.xhp\"><emph>Format - Sections</emph></link>."
msgstr "ເພື່ອແກ້ໄຂສ່ວນ, ໃຫ້ເລືອກ <link href=\"text/swriter/01/02170000.xhp\"><emph>ຮູບແບບ - ສ່ວນ</emph></link>."

#. DqPAE
