msgstr "<link href=\"text/swriter/01/04020200.xhp\">ການຫຍໍ້ໜ້າ</link>"

#. i46ga
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"par_id3155182\n"
"help.text"
msgid "Indents the section with a left and right margin."
msgstr "ຫຍໍ້ໜ້າສ່ວນດ້ວຍຂອບຊ້າຍ ແລະ ຂວາ."

#. BXhv5
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"hd_id3149488\n"
"help.text"
msgid "Before section"
msgstr "ກ່ອນສ່ວນ"

#. pr2HD
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"par_id3149824\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indentpage/before\">Specifies the indents before the section, at the left margin.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indentpage/before\">ລະບຸການຫຍໍ້ໜ້າກ່ອນສ່ວນ, ຢູ່ທີ່ຂອບຊ້າຍ.</ahelp>"

#. s72D3
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"hd_id3149108\n"
"help.text"
msgid "After section"
msgstr "ຫຼັງສ່ວນ"

#. SXCn5
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"par_id3148970\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/indentpage/after\">Specifies the indents after the section, at the right margin.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/indentpage/after\">ລະບຸການຫຍໍ້ໜ້າຫຼັງສ່ວນ, ຢູ່ທີ່ຂອບຂວາ.</ahelp>"

#. ZS7tx
#: 04020200.xhp
msgctxt ""
"04020200.xhp\n"
"par_id3149032\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090000.xhp\">Field commands</link>"
msgstr "<link href=\"text/swriter/01/04090000.xhp\">ຄຳສັ່ງຟິວ</link>"

#. YKHpH
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"tit\n"
"help.text"
msgid "Footnote/Endnote"
msgstr "ເຊິງອັດ/ທ້າຍບົດ"

#. HAGpY
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3145241\n"
"help.text"
msgid "<link href=\"text/swriter/01/04030000.xhp\">Footnote/Endnote</link>"
msgstr "<link href=\"text/swriter/01/04030000.xhp\">ເຊິງອັດ/ທ້າຍບົດ</link>"

#. gsdd3
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3147167\n"
"help.text"
msgid "<variable id=\"fussnoteein\"><ahelp hid=\".uno:InsertFootnote\">Inserts a footnote or an endnote in the document. The anchor for the note is inserted at the current cursor position.</ahelp> You can choose between automatic numbering or a custom symbol.</variable>"
msgstr "<variable id=\"fussnoteein\"><ahelp hid=\".uno:InsertFootnote\">ແຊກເຊິງອັດ ຫຼື ທ້າຍບົດໃນເອກະສານ. ຈຸດຍຶດສຳລັບໝາຍເຫດຈະຖືກແຊກຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ.</ahelp> ທ່ານສາມາດເລືອກລະຫວ່າງການໃສ່ເລກອັດຕະໂນມັດ ຫຼື ສັນຍະລັກທີ່ກຳນົດເອງ.</variable>"

#. ogEtt
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3154645\n"
"help.text"
msgid "<variable id=\"endnoten\">The following applies to both footnotes and endnotes.</variable>"
msgstr "<variable id=\"endnoten\">ຂໍ້ມູນຕໍ່ໄປນີ້ໃຊ້ໄດ້ກັບທັງເຊິງອັດ ແລະ ທ້າຍບົດ.</variable>"

#. nMBWW
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3151175\n"
"help.text"
msgid "<variable id=\"endnotetext\">Footnotes are inserted at the end of a page, and endnotes are inserted at the end of a document.</variable>"
msgstr "<variable id=\"endnotetext\">ເຊິງອັດຈະຖືກແຊກຢູ່ທີ່ທ້າຍໜ້າເຈ້ຍ, ແລະ ທ້າຍບົດຈະຖືກແຊກຢູ່ທີ່ທ້າຍເອກະສານ.</variable>"

#. 6sxBh
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3154106\n"
"help.text"
msgid "Numbering"
msgstr "ການໃສ່ເລກ"

#. JyYGt
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3149812\n"
"help.text"
msgid "Select the type of numbering that you want to use for footnotes and endnotes."
msgstr "ເລືອກປະເພດການໃສ່ເລກທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບເຊິງອັດ ແລະ ທ້າຍບົດ."

#. SgBHA
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3154470\n"
"help.text"
msgid "Automatic"
msgstr "ອັດຕະໂນມັດ"

#. DqtGU
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3153670\n"
"help.text"
msgid "<variable id=\"bearbeitenautomatisch\"><ahelp hid=\"modules/swriter/ui/insertfootnote/automatic\">Automatically assigns consecutive numbers to the footnotes or endnotes that you insert.</ahelp> To change the settings for automatic numbering, choose <link href=\"text/swriter/01/06080000.xhp\"><emph>Tools - Footnote/Endnote Settings</emph></link>.</variable>"
msgstr "<variable id=\"bearbeitenautomatisch\"><ahelp hid=\"modules/swriter/ui/insertfootnote/automatic\">ກຳນົດເລກລຽງລຳດັບໃຫ້ກັບເຊິງອັດ ຫຼື ທ້າຍບົດທີ່ທ່ານແຊກໂດຍອັດຕະໂນມັດ.</ahelp> ເພື່ອປ່ຽນການຕັ້ງຄ່າສຳລັບການໃສ່ເລກອັດຕະໂນມັດ, ໃຫ້ເລືອກ <link href=\"text/swriter/01/06080000.xhp\"><emph>ເຄື່ອງມື - ການຕັ້ງຄ່າ ເຊິງອັດ/ທ້າຍບົດ</emph></link>.</variable>"

#. bRDn5
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3152952\n"
"help.text"
msgid "Character"
msgstr "ຕົວອັກສອນ"

#. 9GVCs
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3155901\n"
"help.text"
msgid "<variable id=\"bearbeitenzeichen\"><ahelp hid=\"modules/swriter/ui/insertfootnote/characterentry\">Choose this option to define a character or symbol for the current footnote.</ahelp> This can be either a letter, number or special character.</variable>"
msgstr "<variable id=\"bearbeitenzeichen\"><ahelp hid=\"modules/swriter/ui/insertfootnote/characterentry\">ເລືອກຕົວເລືອກນີ້ເພື່ອລະບຸຕົວອັກສອນ ຫຼື ສັນຍະລັກສຳລັບເຊິງອັດປັດຈຸບັນ.</ahelp> ເຊິ່ງສາມາດເປັນໄດ້ທັງຕົວອັກສອນ, ຕົວເລກ ຫຼື ອັກສອນພິເສດ.</variable>"

#. nNcCJ
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3155185\n"
"help.text"
msgid "Choose"
msgstr "ເລືອກ"

#. 8FGmJ
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3153526\n"
"help.text"
msgid "<variable id=\"bearbeitensonderzeichen\"><ahelp hid=\"modules/swriter/ui/insertfootnote/choosecharacter\">Inserts a <link href=\"text/shared/01/04100000.xhp\">special character</link> as a footnote or endnote anchor.</ahelp></variable>"
msgstr "<variable id=\"bearbeitensonderzeichen\"><ahelp hid=\"modules/swriter/ui/insertfootnote/choosecharacter\">ແຊກ <link href=\"text/shared/01/04100000.xhp\">ອັກສອນພິເສດ</link> ເປັນຈຸດຍຶດສຳລັບເຊິງອັດ ຫຼື ທ້າຍບົດ.</ahelp></variable>"

#. CqdLB
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3149493\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. dEuEh
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3151256\n"
"help.text"
msgid "Select whether to insert a footnote or an endnote. Endnote numbering is separate from the footnote numbering."
msgstr "ເລືອກວ່າຈະແຊກເຊິງອັດ ຫຼື ທ້າຍບົດ. ການໃສ່ເລກຂອງທ້າຍບົດຈະແຍກຕ່າງຫາກຈາກການໃສ່ເລກຂອງເຊິງອັດ."

#. YNgy3
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3149104\n"
"help.text"
msgid "Footnote"
msgstr "ເຊິງອັດ"

#. EoYDB
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3148981\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertfootnote/footnote\">Inserts a footnote anchor at the current cursor position in the document, and adds a footnote to the bottom of the page.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/insertfootnote/footnote\">ແຊກຈຸດຍຶດເຊິງອັດຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນໃນເອກະສານ, ແລະ ເພີ່ມເຊິງອັດລົງໃນທ້າຍໜ້າເຈ້ຍ.</ahelp>"

#. bHSgs
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"hd_id3153644\n"
"help.text"
msgid "Endnote"
msgstr "ທ້າຍບົດ"

#. KBmnh
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"par_id3152770\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertfootnote/endnote\">Inserts an endnote anchor at the current cursor position in the document, and adds an endnote at the end of the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/insertfootnote/endnote\">ແຊກຈຸດຍຶດທ້າຍບົດຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນໃນເອກະສານ, ແລະ ເພີ່ມທ້າຍບົດລົງໃນທ້າຍເອກະສານ.</ahelp>"

#. fCB3Q
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"tit\n"
"help.text"
msgid "Insert Bookmark"
msgstr "ແຊກບຸກມາກ"

#. FuA3L
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"bm_id4974211\n"
"help.text"
msgid "<bookmark_value>bookmarks;inserting</bookmark_value>"
msgstr "<bookmark_value>ບຸກມາກ;ການແຊກ</bookmark_value>"

#. g6MXd
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3147506\n"
"help.text"
msgid "Insert Bookmark"
msgstr "ແຊກບຸກມາກ"

#. csZJN
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3149806\n"
"help.text"
msgid "<variable id=\"bookmark_text\"><variable id=\"textmarkeein\"><ahelp hid=\".uno:InsertBookmark\">Inserts a <link href=\"text/shared/00/00000005.xhp#bookmark\">bookmark</link> at the cursor position. You can then use the Navigator to quickly jump to the marked location at a later time.</ahelp> In an HTML document, bookmarks are converted to anchors that you can jump to from a hyperlink.</variable></variable>"
msgstr "<variable id=\"bookmark_text\"><variable id=\"textmarkeein\"><ahelp hid=\".uno:InsertBookmark\">ແຊກ <link href=\"text/shared/00/00000005.xhp#bookmark\">ບຸກມາກ</link> ຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີ. ຈາກນັ້ນທ່ານສາມາດໃຊ້ຕົວນຳທາງ (Navigator) ເພື່ອໂດດໄປຍັງຕຳແໜ່ງທີ່ໝາຍໄວ້ໄດ້ຢ່າງວ່ອງໄວໃນພາຍຫຼັງ.</ahelp> ໃນເອກະສານ HTML, ບຸກມາກຈະຖືກປ່ຽນເປັນຈຸດຍຶດທີ່ທ່ານສາມາດໂດດໄປຫາໄດ້ຈາກໄຮເປີລິ້ງ.</variable></variable>"

#. NHiG3
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3153677\n"
"help.text"
msgid "To jump to a specific bookmark, press <keycode>F5</keycode> to open the <link href=\"text/swriter/01/02110000.xhp\">Navigator</link>, click the plus sign (+) next to the<emph> Bookmarks</emph> entry, and then double-click the bookmark."
msgstr "ເພື່ອໂດດໄປຍັງບຸກມາກໃດໜຶ່ງ, ໃຫ້ກົດ <keycode>F5</keycode> ເພື່ອເປີດ <link href=\"text/swriter/01/02110000.xhp\">ຕົວນຳທາງ (Navigator)</link>, ຄລິກເຄື່ອງໝາຍບວກ (+) ຖັດຈາກລາຍການ <emph> ບຸກມາກ</emph>, ແລ້ວດັບເບິ້ນຄລິກທີ່ບຸກມາກນັ້ນ."

#. ATBbv
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3151308\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\"></caseinline><defaultinline>You can also right-click the <emph>Page Number</emph> field at the left end of the <emph>Status Bar</emph> at the bottom of the document window, and then choose the bookmark that you want to jump to.</defaultinline></switchinline>"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\"></caseinline><defaultinline>ທ່ານຍັງສາມາດຄລິກຂວາທີ່ຟິວ <emph>ເລກໜ້າ</emph> ຢູ່ທາງຊ້າຍສຸດຂອງ <emph>ແຖບສະຖານະ</emph> ທີ່ຢູ່ທາງລຸ່ມຂອງປ່ອງຢ້ຽມເອກະສານ, ແລ້ວເລືອກບຸກມາກທີ່ທ່ານຕ້ອງການໂດດໄປຫາໄດ້.</defaultinline></switchinline>"

#. KdpJp
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3154143\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. wsww3
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3155178\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertbookmark/bookmarks\">Type the name of the bookmark that you want to create. Then, click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/insertbookmark/bookmarks\">ພິມຊື່ບຸກມາກທີ່ທ່ານຕ້ອງການສ້າງ. ຈາກນັ້ນ, ຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. s7rfA
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3149483\n"
"help.text"
msgid "You cannot use the following characters in a bookmark name: / \\ @ : * ? \" ; , . #"
msgstr "ທ່ານບໍ່ສາມາດໃຊ້ອັກສອນຕໍ່ໄປນີ້ໃນຊື່ບຸກມາກ: / \\ @ : * ? \" ; , . #"

#. GZrtc
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3154188\n"
"help.text"
msgid "Bookmarks"
msgstr "ບຸກມາກ"

#. MjEEc
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id171581934040077\n"
"help.text"
msgid "Lists all the bookmarks in the current document."
msgstr "ສະແດງລາຍຊື່ບຸກມາກທັງໝົດໃນເອກະສານປັດຈຸບັນ."

#. ZyeAw
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id32341878\n"
"help.text"
msgid "Rename"
msgstr "ປ່ຽນຊື່"

#. 9B5gm
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id971581935166865\n"
"help.text"
msgid "To rename a bookmark, select the bookmark, press <emph>Rename</emph>, then type the new name in the dialog box."
msgstr "ເພື່ອປ່ຽນຊື່ບຸກມາກ, ໃຫ້ເລືອກບຸກມາກນັ້ນ, ກົດ <emph>ປ່ຽນຊື່</emph>, ແລ້ວພິມຊື່ໃໝ່ລົງໃນກ່ອງໂຕ້ຕອບ."

#. aLuDE
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3149817\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. oHMfQ
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3151251\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertbookmark/delete\">To delete a bookmark, select the bookmark and click the <emph>Delete</emph> button. No confirmation dialog will follow.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/insertbookmark/delete\">ເພື່ອລຶບບຸກມາກ, ໃຫ້ເລືອກບຸກມາກນັ້ນແລ້ວຄລິກປຸ່ມ <emph>ລຶບ</emph>. ຈະບໍ່ມີກ່ອງໂຕ້ຕອບຢືນຢັນປະກົດຂຶ້ນ.</ahelp>"

#. zfGWi
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id231581943669611\n"
"help.text"
msgid "If bookmarks are protected, then they cannot be deleted or renamed."
msgstr "ຖ້າບຸກມາກຖືກປ້ອງກັນໄວ້, ຈະບໍ່ສາມາດລຶບ ຫຼື ປ່ຽນຊື່ໄດ້."

#. caM6E
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3149838\n"
"help.text"
msgid "Go to"
msgstr "ໄປຫາ"

#. ABDnD
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id511581935446495\n"
"help.text"
msgid "To move the cursor in the document to a bookmark, select the bookmark, then press <emph>Go to</emph>."
msgstr "ເພື່ອຍ້າຍເຄີເຊີໃນເອກະສານໄປຫາບຸກມາກ, ໃຫ້ເລືອກບຸກມາກນັ້ນ, ແລ້ວກົດ <emph>ໄປຫາ</emph>."

#. ifBCD
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"tit\n"
"help.text"
msgid "Caption"
msgstr "ຄຳບັນຍາຍ"

#. 4mpMM
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3147173\n"
"help.text"
msgid "<link href=\"text/swriter/01/04060000.xhp\">Caption</link>"
msgstr "<link href=\"text/swriter/01/04060000.xhp\">ຄຳບັນຍາຍ</link>"

#. ciBED
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3149288\n"
"help.text"
msgid "<variable id=\"beschrifttext\"><ahelp hid=\".\">Adds a numbered caption to a selected image, table, chart, frame, or shape.</ahelp> You can also access this command by right-clicking the item that you want to add the caption to. </variable>"
msgstr "<variable id=\"beschrifttext\"><ahelp hid=\".\">ເພີ່ມຄຳບັນຍາຍທີ່ມີເລກລຳດັບໃຫ້ກັບຮູບພາບ, ຕາຕະລາງ, ແຜນພູມ, ກອບ, ຫຼື ຮູບຊົງທີ່ເລືອກ.</ahelp> ທ່ານຍັງສາມາດເຂົ້າເຖິງຄຳສັ່ງນີ້ໄດ້ໂດຍການຄລິກຂວາທີ່ລາຍການທີ່ທ່ານຕ້ອງການເພີ່ມຄຳບັນຍາຍໃຫ້. </variable>"

#. vn862
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3155893\n"
"help.text"
msgid "Caption"
msgstr "ຄຳບັນຍາຍ"

#. gMuCQ
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3149688\n"
"help.text"
msgid "Type the text that you want to appear after the caption category and caption number."
msgstr "ພິມຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ປະກົດຂຶ້ນຫຼັງຈາກໝວດໝູ່ຄຳບັນຍາຍ ແລະ ເລກຄຳບັນຍາຍ."

#. fUKh2
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3154098\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. amHnH
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3149804\n"
"help.text"
msgid "Set the caption options for the current selection."
msgstr "ຕັ້ງຄ່າຕົວເລືອກຄຳບັນຍາຍສຳລັບການເລືອກປັດຈຸບັນ."

#. 7t995
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3153533\n"
"help.text"
msgid "Category"
msgstr "ໝວດໝູ່"

#. myQ93
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3154574\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertcaption/category\">Select the caption category, or type a name to create a new category. The category text appears before or after the caption number, depending on the <menuitem>Caption order</menuitem> setting in <link href=\"text/swriter/01/04060100.xhp\">Options</link>. Captions made with a predefined caption category are formatted with a paragraph style with the same name as the category. </ahelp> For example, captions made with the “Illustration” caption category are formatted with the “Illustration” paragraph style."
msgstr "<ahelp hid=\"modules/swriter/ui/insertcaption/category\">ເລືອກໝວດໝູ່ຄຳບັນຍາຍ, ຫຼື ພິມຊື່ເພື່ອສ້າງໝວດໝູ່ໃໝ່. ຂໍ້ຄວາມໝວດໝູ່ຈະປະກົດຂຶ້ນກ່ອນ ຫຼື ຫຼັງເລກຄຳບັນຍາຍ, ຂຶ້ນກັບການຕັ້ງຄ່າ <menuitem>ລຳດັບຄຳບັນຍາຍ</menuitem> ໃນ <link href=\"text/swriter/01/04060100.xhp\">ຕົວເລືອກ</link>. ຄຳບັນຍາຍທີ່ສ້າງຂຶ້ນດ້ວຍໝວດໝູ່ທີ່ກຳນົດໄວ້ລ່ວງໜ້າຈະຖືກຈັດຮູບແບບດ້ວຍຮູບແບບຫຍໍ້ໜ້າທີ່ມີຊື່ດຽວກັນກັບໝວດໝູ່ນັ້ນ. </ahelp> ຕົວຢ່າງ: ຄຳບັນຍາຍທີ່ສ້າງຂຶ້ນດ້ວຍໝວດໝູ່ “ຮູບປະກອບ” (Illustration) ຈະຖືກຈັດຮູບແບບດ້ວຍຮູບແບບຫຍໍ້ໜ້າ “ຮູບປະກອບ”."

#. nFocV
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3153675\n"
"help.text"
msgid "Numbering"
msgstr "ການໃສ່ເລກ"

#. GtgAE
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3152962\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertcaption/numbering\">Select the type of numbering that you want to use in the caption.</ahelp> The selection is also applied to any previous captions in the category."
msgstr "<ahelp hid=\"modules/swriter/ui/insertcaption/numbering\">ເລືອກປະເພດການໃສ່ເລກທີ່ທ່ານຕ້ອງການໃຊ້ໃນຄຳບັນຍາຍ.</ahelp> ການເລືອກນີ້ຈະມີຜົນຕໍ່ຄຳບັນຍາຍກ່ອນໜ້ານີ້ທັງໝົດໃນໝວດໝູ່ນັ້ນນຳ."

#. Qtg2X
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id661675732010450\n"
"help.text"
msgid "After number"
msgstr "ຫຼັງຕົວເລກ"

#. 5nCqg
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id871675733307406\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertcaption/num_separator_edit\">Enter optional text characters to appear between numbering and category.</ahelp> Only active when <menuitem>Numbering first</menuitem> is selected for <menuitem>Caption order</menuitem> in <link href=\"text/swriter/01/04060100.xhp\">Options</link>."
msgstr "<ahelp hid=\"modules/swriter/ui/insertcaption/num_separator_edit\">ປ້ອນຕົວອັກສອນທີ່ຕ້ອງການໃຫ້ປະກົດຂຶ້ນລະຫວ່າງການໃສ່ເລກ ແລະ ໝວດໝູ່.</ahelp> ຈະໃຊ້ໄດ້ກໍຕໍ່ເມື່ອເລືອກ <menuitem>ເລກມາກ່ອນ</menuitem> (Numbering first) ສຳລັບ <menuitem>ລຳດັບຄຳບັນຍາຍ</menuitem> ໃນ <link href=\"text/swriter/01/04060100.xhp\">ຕົວເລືອກ</link>."

#. gTLmN
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_idN1068A\n"
"help.text"
msgid "Before caption"
msgstr "ກ່ອນຄຳບັນຍາຍ"

#. c7CLA
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_idN10690\n"
"help.text"
msgid "<ahelp hid=\".\">Enter optional text characters to appear after the caption category and number and before the caption text. These characters are not inserted if no caption text is given.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຕົວອັກສອນທີ່ຕ້ອງການໃຫ້ປະກົດຂຶ້ນຫຼັງຈາກໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ ແລະ ກ່ອນຂໍ້ຄວາມຄຳບັນຍາຍ. ຕົວອັກສອນເຫຼົ່ານີ້ຈະບໍ່ຖືກແຊກເຂົ້າໄປຖ້າບໍ່ມີຂໍ້ຄວາມຄຳບັນຍາຍ.</ahelp>"

#. saodu
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3154199\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. PWZPs
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3149486\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertcaption/position\">Adds the caption above or below the selected item. This option is only available for some objects.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/insertcaption/position\">ເພີ່ມຄຳບັນຍາຍໄວ້ທາງເທິງ ຫຼື ທາງລຸ່ມຂອງລາຍການທີ່ເລືອກ. ຕົວເລືອກນີ້ຈະໃຊ້ໄດ້ສະເພາະກັບບາງວັດຖຸເທົ່ານັ້ນ.</ahelp>"

#. Hu5xy
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3149043\n"
"help.text"
msgid "<link href=\"text/swriter/01/04060100.xhp\">Options</link>"
msgstr "<link href=\"text/swriter/01/04060100.xhp\">ຕົວເລືອກ</link>"

#. aCCVV
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id51677247311637\n"
"help.text"
msgid "Opens the Options dialog, where it is possible to customize the appearance of the caption label. <embedvar href=\"text/swriter/01/04060100.xhp#optionentext\"/>"
msgstr "ເປີດກ່ອງໂຕ້ຕອບຕົວເລືອກ, ເຊິ່ງທ່ານສາມາດປັບແຕ່ງລັກສະນະຂອງປ້າຍຊື່ຄຳບັນຍາຍໄດ້. <embedvar href=\"text/swriter/01/04060100.xhp#optionentext\"/>"

#. aGbBK
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_idN10744\n"
"help.text"
msgid "AutoCaption"
msgstr "ຄຳບັນຍາຍອັດຕະໂນມັດ"

#. kPfAd
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_idN1074A\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the AutoCaption dialog. This is the same dialog you get by <menuitem>Tools - Options - %PRODUCTNAME Writer - AutoCaption</menuitem>.</ahelp> Changes to this dialog do not affect the inserted caption for the current selection."
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບຄຳບັນຍາຍອັດຕະໂນມັດ (AutoCaption). ນີ້ແມ່ນກ່ອງໂຕ້ຕອບດຽວກັບທີ່ທ່ານໄດ້ຮັບຈາກ <menuitem>ເຄື່ອງມື - ຕົວເລືອກ - %PRODUCTNAME Writer - ຄຳບັນຍາຍອັດຕະໂນມັດ</menuitem>.</ahelp> ການປ່ຽນແປງໃນກ່ອງໂຕ້ຕອບນີ້ຈະບໍ່ມີຜົນຕໍ່ຄຳບັນຍາຍທີ່ແຊກໄວ້ສຳລັບການເລືອກປັດຈຸບັນ."

#. ZedFw
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"tit\n"
"help.text"
msgid "Options (caption)"
msgstr "ຕົວເລືອກ (ຄຳບັນຍາຍ)"

#. FJExT
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3149287\n"
"help.text"
msgid "Options (caption)"
msgstr "ຕົວເລືອກ (ຄຳບັນຍາຍ)"

#. dgsEP
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id3151177\n"
"help.text"
msgid "Customize the appearance of the caption label. <variable id=\"optionentext\"><ahelp hid=\"modules/swriter/ui/insertcaption/options\">You can choose to add a heading number to the caption number, add a character style to the caption category and number, and choose the order of the caption category and caption number.</ahelp></variable>"
msgstr "ປັບແຕ່ງລັກສະນະຂອງປ້າຍຊື່ຄຳບັນຍາຍ. <variable id=\"optionentext\"><ahelp hid=\"modules/swriter/ui/insertcaption/options\">ທ່ານສາມາດເລືອກເພີ່ມເລກຫົວຂໍ້ໃສ່ໜ້າເລກຄຳບັນຍາຍ, ເພີ່ມຮູບແບບຕົວອັກສອນໃຫ້ກັບໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ, ແລະ ເລືອກລຳດັບຂອງໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ.</ahelp></variable>"

#. eQhDw
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id151675734641196\n"
"help.text"
msgid "Category and caption number"
msgstr "ໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ"

#. FdCvG
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id751675734666407\n"
"help.text"
msgid "Caption order"
msgstr "ລຳດັບຄຳບັນຍາຍ"

#. BvaYe
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id241675734682855\n"
"help.text"
msgid "Select ordering of caption category and caption number."
msgstr "ເລືອກລຳດັບຂອງໝວດໝູ່ຄຳບັນຍາຍ ແລະ ເລກຄຳບັນຍາຍ."

#. RyKnz
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_idN10639\n"
"help.text"
msgid "Character style"
msgstr "ຮູບແບບຕົວອັກສອນ"

#. jEmn6
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_idN1063F\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the character style of the caption category and caption number.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຮູບແບບຕົວອັກສອນຂອງໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ.</ahelp>"

#. i8AxN
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_idN10633\n"
"help.text"
msgid "Frame format"
msgstr "ຮູບແບບກອບ"

#. DUVFm
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3143280\n"
"help.text"
msgid "Apply border and shadow"
msgstr "ໃຊ້ຂອບ ແລະ ເງົາ"

#. hhgEi
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id3149826\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/captionoptions/border_and_shadow\">Applies the border and shadow of the object to the caption frame.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/captionoptions/border_and_shadow\">ໃຊ້ຂອບ ແລະ ເງົາຂອງວັດຖຸກັບກອບຄຳບັນຍາຍ.</ahelp>"

#. KaKDq
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3149805\n"
"help.text"
msgid "Heading Number before Caption Number"
msgstr "ເລກຫົວຂໍ້ກ່ອນເລກຄຳບັນຍາຍ"

#. skACZ
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id3153532\n"
"help.text"
msgid "If heading numbers are enabled, then use this option to prepend a heading number to the caption number. Use <menuitem>Tools - Heading Numbering</menuitem> to enable heading numbering."
msgstr "ຖ້າເປີດໃຊ້ເລກຫົວຂໍ້, ໃຫ້ໃຊ້ຕົວເລືອກນີ້ເພື່ອເພີ່ມເລກຫົວຂໍ້ໄວ້ທາງໜ້າເລກຄຳບັນຍາຍ. ໃຊ້ <menuitem>ເຄື່ອງມື - ການໃສ່ເລກຫົວຂໍ້</menuitem> ເພື່ອເປີດໃຊ້ການໃສ່ເລກຫົວຂໍ້."

#. 9qNR4
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3154574\n"
"help.text"
msgid "Up to level"
msgstr "ເຖິງລະດັບ"

#. 2ZBvD
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3151316\n"
"help.text"
msgid "Separator"
msgstr "ຕົວຂັ້ນ"

#. QdV9G
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id3155892\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/captionoptions/separator\">Enter the character to  display between the heading number and the caption number.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/captionoptions/separator\">ປ້ອນຕົວອັກສອນທີ່ຈະໃຫ້ສະແດງລະຫວ່າງເລກຫົວຂໍ້ ແລະ ເລກຄຳບັນຍາຍ.</ahelp>"

#. nDEEx
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id731680344781153\n"
"help.text"
msgid "Changes to <menuitem>Up to level</menuitem> or <menuitem>separator</menuitem> are also applied to any existing captions."
msgstr "ການປ່ຽນແປງໃນ <menuitem>ເຖິງລະດັບ</menuitem> ຫຼື <menuitem>ຕົວຂັ້ນ</menuitem> ຈະມີຜົນຕໍ່ຄຳບັນຍາຍທີ່ມີຢູ່ແລ້ວນຳ."

#. gpHWC
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"tit\n"
"help.text"
msgid "Envelope"
msgstr "ຊອງຈົດໝາຍ"

#. HdfFu
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"bm_id7094027\n"
"help.text"
msgid "<bookmark_value>inserting;envelopes</bookmark_value>      <bookmark_value>letters;inserting envelopes</bookmark_value>      <bookmark_value>envelopes</bookmark_value>"
msgstr "<bookmark_value>ການແຊກ;ຊອງຈົດໝາຍ</bookmark_value>      <bookmark_value>ຈົດໝາຍ;ການແຊກຊອງຈົດໝາຍ</bookmark_value>      <bookmark_value>ຊອງຈົດໝາຍ</bookmark_value>"

#. uiRTw
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id3145245\n"
"help.text"
msgid "<link href=\"text/swriter/01/04070000.xhp\">Envelope</link>"
msgstr "<link href=\"text/swriter/01/04070000.xhp\">ຊອງຈົດໝາຍ</link>"

#. 76gXj
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id3149289\n"
"help.text"
msgid "<variable id=\"briefum\"><ahelp hid=\".uno:InsertEnvelope\">Creates an envelope.</ahelp> On three tab pages, you can specify the addressee and sender, the position and format for both addresses, the size of the envelope, and the envelope orientation.</variable>"
msgstr "<variable id=\"briefum\"><ahelp hid=\".uno:InsertEnvelope\">ສ້າງຊອງຈົດໝາຍ.</ahelp> ໃນສາມໜ້າແທັບ, ທ່ານສາມາດລະບຸຜູ້ຮັບ ແລະ ຜູ້ສົ່ງ, ຕຳແໜ່ງ ແລະ ຮູບແບບສຳລັບທັງສອງທີ່ຢູ່, ຂະໜາດຂອງຊອງຈົດໝາຍ, ແລະ ທິດທາງຂອງຊອງຈົດໝາຍ.</variable>"

#. 8CAxZ
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id3153540\n"
"help.text"
msgid "New doc."
msgstr "ເອກະສານໃໝ່"

#. 26cZG
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id3154473\n"
"help.text"
msgid "<ahelp hid=\"HID_ENVELOP_PRINT\">Creates a new document and inserts the envelope.</ahelp>"
msgstr "<ahelp hid=\"HID_ENVELOP_PRINT\">ສ້າງເອກະສານໃໝ່ ແລະ ແຊກຊອງຈົດໝາຍ.</ahelp>"

#. iBWJU
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id3152959\n"
"help.text"
msgid "Insert"
msgstr "ແຊກ"

#. 6ryVK
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id3151320\n"
"help.text"
msgid "<ahelp hid=\"HID_ENVELOP_INSERT\">Inserts the envelope before the current page in the document.</ahelp>"
msgstr "<ahelp hid=\"HID_ENVELOP_INSERT\">ແຊກຊອງຈົດໝາຍໄວ້ທາງໜ້າຂອງໜ້າເຈ້ຍປັດຈຸບັນໃນເອກະສານ.</ahelp>"

#. HxvVj
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id8208563\n"
"help.text"
msgid "To delete an envelope from a document"
msgstr "ວິທີລຶບຊອງຈົດໝາຍອອກຈາກເອກະສານ"

#. Cji5e
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id396130\n"
"help.text"
msgid "Click into the envelope page to make it the current page."
msgstr "ຄລິກລົງໃນໜ້າຊອງຈົດໝາຍເພື່ອໃຫ້ມັນເປັນໜ້າປັດຈຸບັນ."

#. WpPCG
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id7174596\n"
"help.text"
msgid "Right-click the field on the status line that shows \"Envelope\"."
msgstr "ຄລິກຂວາທີ່ຟິວໃນແຖບສະຖານະທີ່ສະແດງຂໍ້ຄວາມ \"ຊອງຈົດໝາຍ\" (Envelope)."

#. SUCEa
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id7657704\n"
"help.text"
msgid "A submenu opens showing some page styles."
msgstr "ເມນູຍ່ອຍຈະເປີດຂຶ້ນເພື່ອສະແດງຮູບແບບໜ້າບາງຢ່າງ."

#. xckvs
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id5187536\n"
"help.text"
msgid "Choose the \"Default\" page style from the submenu."
msgstr "ເລືອກຮູບແບບໜ້າ \"ເລີ່ມຕົ້ນ\" (Default) ຈາກເມນູຍ່ອຍ."

#. JyxEQ
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id6952726\n"
"help.text"
msgid "This removes the special \"Envelope\" page formatting."
msgstr "ນີ້ຈະເປັນການລຶບຮູບແບບໜ້າ \"ຊອງຈົດໝາຍ\" ແບບພິເສດອອກ."

#. 3iAPy
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id1777092\n"
"help.text"
msgid "Delete the frames for sender and recipient. Click the border of each frame and press the Del key."
msgstr "ລຶບກອບສຳລັບຜູ້ສົ່ງ ແລະ ຜູ້ຮັບ. ຄລິກທີ່ຂອບຂອງແຕ່ລະກອບແລ້ວກົດປຸ່ມ Del."

#. g6Bgv
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"tit\n"
"help.text"
msgid "Envelope"
msgstr "ຊອງຈົດໝາຍ"

#. CkEG3
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3145243\n"
"help.text"
msgid "<link href=\"text/swriter/01/04070100.xhp\">Envelope</link>"
msgstr "<link href=\"text/swriter/01/04070100.xhp\">ຊອງຈົດໝາຍ</link>"

#. C4ewN
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3147172\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/envaddresspage/EnvAddressPage\" visibility=\"visible\">Enter the delivery and return addresses for the envelope. You can also insert address fields from a database, for example from the Addresses database.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/envaddresspage/EnvAddressPage\" visibility=\"visible\">ປ້ອນທີ່ຢູ່ຜູ້ຮັບ ແລະ ທີ່ຢູ່ຜູ້ສົ່ງສຳລັບຊອງຈົດໝາຍ. ທ່ານຍັງສາມາດແຊກຟິວທີ່ຢູ່ຈາກຖານຂໍ້ມູນໄດ້, ຕົວຢ່າງ: ຈາກຖານຂໍ້ມູນທີ່ຢູ່ (Addresses database).</ahelp>"

#. Bk8HG
