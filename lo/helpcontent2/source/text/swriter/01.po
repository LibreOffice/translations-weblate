"help.text"
msgid "<bookmark_value>converting; text, into tables</bookmark_value><bookmark_value>text; converting to tables</bookmark_value><bookmark_value>tables; converting to text</bookmark_value>"
msgstr "<bookmark_value>ການປ່ຽນ; ຂໍ້ຄວາມ, ເປັນຕາຕະລາງ</bookmark_value><bookmark_value>ຂໍ້ຄວາມ; ການປ່ຽນເປັນຕາຕະລາງ</bookmark_value><bookmark_value>ຕາຕະລາງ; ການປ່ຽນເປັນຂໍ້ຄວາມ</bookmark_value>"

#. Z5tk2
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3147402\n"
"help.text"
msgid "<link href=\"text/swriter/01/06090000.xhp\">Convert Text to Table</link>"
msgstr "<link href=\"text/swriter/01/06090000.xhp\">ປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງ</link>"

#. sMxFh
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3145829\n"
"help.text"
msgid "<variable id=\"texttab\"><ahelp hid=\".uno:ConvertTableText\">Converts the selected text into a table, or the selected table into text.</ahelp></variable>"
msgstr "<variable id=\"texttab\"><ahelp hid=\".uno:ConvertTableText\">ປ່ຽນຂໍ້ຄວາມທີ່ເລືອກໃຫ້ເປັນຕາຕະລາງ, ຫຼື ປ່ຽນຕາຕະລາງທີ່ເລືອກໃຫ້ເປັນຂໍ້ຄວາມ.</ahelp></variable>"

#. x3MAF
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3150015\n"
"help.text"
msgid "The options available in this dialog depending on the type of conversion."
msgstr "ຕົວເລືອກທີ່ມີຢູ່ໃນປ່ອງຢ້ຽມໂຕ້ຕອບນີ້ແມ່ນຂຶ້ນກັບປະເພດຂອງການປ່ຽນ."

#. cF9A5
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3145247\n"
"help.text"
msgid "Separate text at"
msgstr "ແຍກຂໍ້ຄວາມທີ່"

#. UZZy3
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3148388\n"
"help.text"
msgid "A separator, such as a tab, marks the column boundaries in the selected text. Each paragraph in the selection is converted into a row in the table. Similarly, when you convert a table into text, the column markers are changed to the character that you specify, and each row is converted into a separate paragraph."
msgstr "ຕົວຂັ້ນ, ເຊັ່ນ: ແທັບ, ຈະເປັນຕົວບົ່ງບອກຂອບເຂດຂອງຖັນໃນຂໍ້ຄວາມທີ່ເລືອກ. ແຕ່ລະຫຍໍ້ໜ້າໃນສ່ວນທີ່ເລືອກຈະຖືກປ່ຽນເປັນແຖວໃນຕາຕະລາງ. ໃນທາງດຽວກັນ, ເມື່ອທ່ານປ່ຽນຕາຕະລາງເປັນຂໍ້ຄວາມ, ຕົວບົ່ງບອກຖັນຈະຖືກປ່ຽນເປັນຕົວອັກສອນທີ່ທ່ານລະບຸ, ແລະ ແຕ່ລະແຖວຈະຖືກປ່ຽນເປັນຫຍໍ້ໜ້າແຍກຕ່າງຫາກ."

#. XPoRD
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3150936\n"
"help.text"
msgid "Tabs"
msgstr "ແທັບ"

#. DELsb
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3149027\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/tabs\">Converts the text to a table using tabs as column markers.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/tabs\">ປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງໂດຍໃຊ້ແທັບເປັນຕົວບົ່ງບອກຖັນ.</ahelp>"

#. fe37j
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3147171\n"
"help.text"
msgid "Semicolons"
msgstr "ເຄື່ອງໝາຍຈ້ຳຈຸດ (;)"

#. vCDMB
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3147565\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/semicolons\">Converts the text to a table using semi-colons (;) as column markers.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/semicolons\">ປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງໂດຍໃຊ້ເຄື່ອງໝາຍຈ້ຳຈຸດ (;) ເປັນຕົວບົ່ງບອກຖັນ.</ahelp>"

#. qpWBj
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3151273\n"
"help.text"
msgid "Paragraph"
msgstr "ຫຍໍ້ໜ້າ"

#. XDVAF
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3154645\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/paragraph\">Converts the text to a table using paragraphs as column markers.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/paragraph\">ປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງໂດຍໃຊ້ຫຍໍ້ໜ້າເປັນຕົວບົ່ງບອກຖັນ.</ahelp>"

#. AF4j8
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3151184\n"
"help.text"
msgid "Other:"
msgstr "ອື່ນໆ:"

#. D7aAk
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3150256\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/other\">Converts the text to a table using the character that you type in the box as a column marker.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/other\">ປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງໂດຍໃຊ້ຕົວອັກສອນທີ່ທ່ານພິມໃນຊ່ອງເປັນຕົວບົ່ງບອກຖັນ.</ahelp>"

#. jb7Wr
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3149295\n"
"help.text"
msgid "Text box"
msgstr "ຊ່ອງຂໍ້ຄວາມ"

#. z3hxE
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3151175\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/othered\">Type the character that you want to use as a column marker.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/othered\">ພິມຕົວອັກສອນທີ່ທ່ານຕ້ອງການໃຊ້ເປັນຕົວບົ່ງບອກຖັນ.</ahelp>"

#. 3NefT
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3147508\n"
"help.text"
msgid "Equal width for all columns"
msgstr "ຄວາມກວ້າງເທົ່າກັນສຳລັບທຸກຖັນ"

#. EMSC8
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3154278\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/keepcolumn\">Creates columns of equal width, regardless of the position of the column marker.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/keepcolumn\">ສ້າງຖັນທີ່ມີຄວາມກວ້າງເທົ່າກັນ, ໂດຍບໍ່ຄຳນຶງເຖິງຕຳແໜ່ງຂອງຕົວບົ່ງບອກຖັນ.</ahelp>"

#. 9bMRZ
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3150703\n"
"help.text"
msgid "AutoFormat"
msgstr "ຈັດຮູບແບບອັດຕະໂນມັດ"

#. GGKFD
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id31542781\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the <emph>AutoFormat</emph> dialog, where you can select a predefined layout for table.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດປ່ອງຢ້ຽມໂຕ້ຕອບ <emph>ຈັດຮູບແບບອັດຕະໂນມັດ</emph>, ທີ່ທ່ານສາມາດເລືອກເຄົ້າໂຄງທີ່ຕັ້ງໄວ້ລ່ວງໜ້າສຳລັບຕາຕະລາງ.</ahelp>"

#. CDCyN
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3154097\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. ZZGPi
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3149802\n"
"help.text"
msgid "Heading"
msgstr "ຫົວຂໍ້"

#. kyQhi
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3153535\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/headingcb\">Formats the first row of the new table as a heading.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/headingcb\">ຈັດຮູບແບບແຖວທຳອິດຂອງຕາຕະລາງໃໝ່ໃຫ້ເປັນຫົວຂໍ້.</ahelp>"

#. 842uw
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3150359\n"
"help.text"
msgid "Repeat heading"
msgstr "ເຮັດຊ້ຳຫົວຂໍ້"

#. 6Tbiw
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3150973\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/repeatheading\">Repeats the table header on each page that the table spans.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/repeatheading\">ເຮັດຊ້ຳຫົວຂໍ້ຕາຕະລາງໃນແຕ່ລະໜ້າທີ່ຕາຕະລາງນັ້ນກວມເອົາ.</ahelp>"

#. iHhoh
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id5971251\n"
"help.text"
msgid "The first ... rows"
msgstr "ແຖວທຳອິດ ..."

#. t9di6
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id4136478\n"
"help.text"
msgid "<ahelp hid=\".\">Repeats the first n rows as a header.</ahelp>"
msgstr "<ahelp hid=\".\">ເຮັດຊ້ຳ n ແຖວທຳອິດເປັນຫົວຂໍ້.</ahelp>"

#. pHxwj
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3151315\n"
"help.text"
msgid "Don't split table"
msgstr "ບໍ່ແຍກຕາຕະລາງ"

#. UsGW6
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3147530\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/dontsplitcb\">Does not divide the table across pages.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/dontsplitcb\">ບໍ່ແບ່ງຕາຕະລາງຂ້າມໜ້າ.</ahelp>"

#. AKsbe
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"hd_id3154472\n"
"help.text"
msgid "Border"
msgstr "ເສັ້ນຂອບ"

#. 5EBEP
#: 06090000.xhp
msgctxt ""
"06090000.xhp\n"
"par_id3154570\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/converttexttable/bordercb\">Adds a border to the table and the table cells.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/converttexttable/bordercb\">ເພີ່ມເສັ້ນຂອບໃຫ້ກັບຕາຕະລາງ ແລະ ຫ້ອງຕາຕະລາງ.</ahelp>"

#. uBe9d
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"tit\n"
"help.text"
msgid "Sort"
msgstr "ຈັດລຽງ"

#. CuoQx
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"bm_id3149353\n"
"help.text"
msgid "<bookmark_value>tables;sorting rows</bookmark_value><bookmark_value>sorting;paragraphs/table rows</bookmark_value><bookmark_value>text; sorting paragraphs</bookmark_value><bookmark_value>lines of text; sorting paragraphs</bookmark_value><bookmark_value>sorting;paragraphs in special languages</bookmark_value><bookmark_value>Asian languages;sorting paragraphs/table rows</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງ;ການຈັດລຽງແຖວ</bookmark_value><bookmark_value>ການຈັດລຽງ;ຫຍໍ້ໜ້າ/ແຖວຕາຕະລາງ</bookmark_value><bookmark_value>ຂໍ້ຄວາມ; ການຈັດລຽງຫຍໍ້ໜ້າ</bookmark_value><bookmark_value>ແຖວຂໍ້ຄວາມ; ການຈັດລຽງຫຍໍ້ໜ້າ</bookmark_value><bookmark_value>ການຈັດລຽງ;ຫຍໍ້ໜ້າໃນພາສາພິເສດ</bookmark_value><bookmark_value>ພາສາອາຊີ;ການຈັດລຽງຫຍໍ້ໜ້າ/ແຖວຕາຕະລາງ</bookmark_value>"

#. EA6YJ
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3149353\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/06100000.xhp\">Sort</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/06100000.xhp\">ຈັດລຽງ</link></variable>"

#. XnAEB
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3150015\n"
"help.text"
msgid "<variable id=\"sort\"><ahelp hid=\".uno:SortDialog\">Sorts the selected paragraphs or table rows alphabetically or numerically.</ahelp> You can define up to three sort keys as well as combine alphanumeric and numeric sort keys.</variable>"
msgstr "<variable id=\"sort\"><ahelp hid=\".uno:SortDialog\">ຈັດລຽງຫຍໍ້ໜ້າ ຫຼື ແຖວຕາຕະລາງທີ່ເລືອກຕາມຕົວອັກສອນ ຫຼື ຕົວເລກ.</ahelp> ທ່ານສາມາດກຳນົດຄີການຈັດລຽງໄດ້ສູງສຸດສາມຄີ ລວມທັງລວມຄີການຈັດລຽງແບບຕົວອັກສອນ ແລະ ຕົວເລກເຂົ້າກັນ.</variable>"

#. 6Q37N
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3150931\n"
"help.text"
msgid "Sort criteria"
msgstr "ເງື່ອນໄຂການຈັດລຽງ"

#. zTa4Y
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3149029\n"
"help.text"
msgid "Keys 1 to 3"
msgstr "ຄີ 1 ຫາ 3"

#. vGcgi
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3147170\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/key3\">Specifies additional sorting criteria. You can also combine sort keys.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/key3\">ລະບຸເງື່ອນໄຂການຈັດລຽງເພີ່ມເຕີມ. ທ່ານຍັງສາມາດລວມຄີການຈັດລຽງເຂົ້າກັນໄດ້.</ahelp>"

#. StLHG
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3147565\n"
"help.text"
msgid "Column 1 to 3"
msgstr "ຖັນ 1 ຫາ 3"

#. FpRTV
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3154644\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/colsb3\">Enter the number of the table column that you want to use as a basis for sorting.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/colsb3\">ປ້ອນຕົວເລກຂອງຖັນຕາຕະລາງທີ່ທ່ານຕ້ອງການໃຊ້ເປັນພື້ນຖານໃນການຈັດລຽງ.</ahelp>"

#. wMewq
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3150254\n"
"help.text"
msgid "Key type 1 to 3"
msgstr "ປະເພດຄີ 1 ຫາ 3"

#. Knx9D
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3149752\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/typelb3\">Select the sorting option that you want to use.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/typelb3\">ເລືອກຕົວເລືອກການຈັດລຽງທີ່ທ່ານຕ້ອງການໃຊ້.</ahelp>"

#. wEXV5
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3151177\n"
"help.text"
msgid "Order"
msgstr "ລຳດັບ"

#. oSn3c
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id072020090105453\n"
"help.text"
msgid "Ascending"
msgstr "ຈາກນ້ອຍຫາໃຫຍ່"

#. SEkEJ
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3154270\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/up3\">Sorts in ascending order, (for example, 1, 2, 3 or a, b, c).</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/up3\">ຈັດລຽງຕາມລຳດັບຈາກນ້ອຍຫາໃຫຍ່ (ຕົວຢ່າງ: 1, 2, 3 ຫຼື ກ, ຂ, ຄ).</ahelp>"

#. ivmBV
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3150708\n"
"help.text"
msgid "Descending"
msgstr "ຈາກໃຫຍ່ຫານ້ອຍ"

#. zV5AE
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3152946\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/down3\">Sorts in descending order (for example, 9, 8, 7 or z, y, x).</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/down3\">ຈັດລຽງຕາມລຳດັບຈາກໃຫຍ່ຫານ້ອຍ (ຕົວຢ່າງ: 9, 8, 7 ຫຼື x, y, z ໃນທາງກັບກັນ).</ahelp>"

#. xFCA5
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3149812\n"
"help.text"
msgid "Direction"
msgstr "ທິດທາງ"

#. APvd9
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3153540\n"
"help.text"
msgid "Columns"
msgstr "ຖັນ"

#. 3vtfF
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3150973\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/columns\">Sorts the columns in the table according to the current sort options.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/columns\">ຈັດລຽງຖັນໃນຕາຕະລາງຕາມຕົວເລືອກການຈັດລຽງປັດຈຸບັນ.</ahelp>"

#. tHGEb
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3147526\n"
"help.text"
msgid "Rows"
msgstr "ແຖວ"

#. U6t8h
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3153677\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/rows\">Sorts the rows in the table or the paragraphs in the selection according to the current sort options.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/rows\">ຈັດລຽງແຖວໃນຕາຕະລາງ ຫຼື ຫຍໍ້ໜ້າໃນສ່ວນທີ່ເລືອກຕາມຕົວເລືອກການຈັດລຽງປັດຈຸບັນ.</ahelp>"

#. ZFq2Q
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3151312\n"
"help.text"
msgid "Separator"
msgstr "ຕົວຂັ້ນ"

#. 2Bs8N
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3150350\n"
"help.text"
msgid "Paragraphs are separated by nonprinting paragraph marks. You can also specify that tabs or a character act as separators when you sort paragraphs."
msgstr "ຫຍໍ້ໜ້າຖືກແຍກດ້ວຍເຄື່ອງໝາຍຫຍໍ້ໜ້າທີ່ບໍ່ພິມອອກມາ. ທ່ານຍັງສາມາດລະບຸໃຫ້ແທັບ ຫຼື ຕົວອັກສອນເຮັດໜ້າທີ່ເປັນຕົວຂັ້ນເມື່ອທ່ານຈັດລຽງຫຍໍ້ໜ້າ."

#. V3PcF
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3154570\n"
"help.text"
msgid "Tabs"
msgstr "ແທັບ"

#. YHihi
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3155902\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/tabs\">If the selected paragraphs correspond to a list separated by tabs, select this option.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/tabs\">ຖ້າຫຍໍ້ໜ້າທີ່ເລືອກເປັນລາຍການທີ່ແຍກດ້ວຍແທັບ, ໃຫ້ເລືອກຕົວເລືອກນີ້.</ahelp>"

#. x5DsZ
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3154190\n"
"help.text"
msgid "Character"
msgstr "ຕົວອັກສອນ"

#. 7YxmV
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3159196\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/separator\">Enter the character that you want to use as a separator in the selected area.</ahelp> By using the separator, $[officename] can determine the position of the sorting key in the selected paragraph."
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/separator\">ປ້ອນຕົວອັກສອນທີ່ທ່ານຕ້ອງການໃຊ້ເປັນຕົວຂັ້ນໃນສ່ວນທີ່ເລືອກ.</ahelp> ໂດຍການໃຊ້ຕົວຂັ້ນ, $[officename] ສາມາດກຳນົດຕຳແໜ່ງຂອງຄີການຈັດລຽງໃນຫຍໍ້ໜ້າທີ່ເລືອກໄດ້."

#. d6YsT
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3151324\n"
"help.text"
msgid "Select"
msgstr "ເລືອກ"

#. HhFEh
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3155178\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/delimpb\">Opens the <emph>Special Characters</emph> dialog, where you can select the character that you want to use as a separator.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/delimpb\">ເປີດປ່ອງຢ້ຽມໂຕ້ຕອບ <emph>ຕົວອັກສອນພິເສດ</emph>, ທີ່ທ່ານສາມາດເລືອກຕົວອັກສອນທີ່ຕ້ອງການໃຊ້ເປັນຕົວຂັ້ນ.</ahelp>"

#. iDM6r
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3149482\n"
"help.text"
msgid "Language"
msgstr "ພາສາ"

#. awMcA
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3151252\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/langlb\">Select the language that defines the sorting rules.</ahelp> Some languages sort special characters differently than other languages."
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/langlb\">ເລືອກພາສາທີ່ກຳນົດກົດລະບຽບການຈັດລຽງ.</ahelp> ບາງພາສາຈັດລຽງຕົວອັກສອນພິເສດແຕກຕ່າງຈາກພາສາອື່ນ."

#. jEXDv
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"hd_id3149104\n"
"help.text"
msgid "Match case"
msgstr "ຕົວພິມໃຫຍ່/ນ້ອຍໃຫ້ກົງກັນ"

#. 5D9kq
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_id3154838\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/sortdialog/matchcase\">Distinguishes between uppercase and lowercase letters when you sort a table. For Asian languages special handling applies.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/sortdialog/matchcase\">ແຍກຄວາມແຕກຕ່າງລະຫວ່າງຕົວພິມໃຫຍ່ ແລະ ຕົວພິມນ້ອຍເມື່ອທ່ານຈັດລຽງຕາຕະລາງ. ສຳລັບພາສາອາຊີ ຈະມີການຈັດການແບບພິເສດ.</ahelp>"

#. EvVGs
#: 06100000.xhp
msgctxt ""
"06100000.xhp\n"
"par_idN10895\n"
"help.text"
msgid "For Asian languages, select <emph>Match case </emph>to apply multi-level collation. In the multi-level collation, the primitive forms of the entries are first compared with the cases of the forms and diacritics ignored. If the forms are the same, the diacritics of the forms are compared. If the forms are still the same, the cases, character widths, and Japanese Kana differences of the forms are compared."
msgstr "ສຳລັບພາສາອາຊີ, ໃຫ້ເລືອກ <emph>ຕົວພິມໃຫຍ່/ນ້ອຍໃຫ້ກົງກັນ </emph>ເພື່ອນຳໃຊ້ການລຽງລຳດັບແບບຫຼາຍລະດັບ. ໃນການລຽງລຳດັບແບບຫຼາຍລະດັບ, ຮູບແບບເດີມຂອງລາຍການຈະຖືກປຽບທຽບກ່ອນໂດຍບໍ່ສົນໃຈຕົວພິມໃຫຍ່ນ້ອຍ ແລະ ເຄື່ອງໝາຍກຳກັບສຽງ. ຖ້າຮູບແບບຄືກັນ, ຈະປຽບທຽບເຄື່ອງໝາຍກຳກັບສຽງ. ຖ້າຍັງຄືກັນຢູ່, ຈະປຽບທຽບຕົວພິມໃຫຍ່ນ້ອຍ, ຄວາມກວ້າງຂອງຕົວອັກສອນ, ແລະ ຄວາມແຕກຕ່າງຂອງຕົວອັກສອນ Kana ຂອງຍີ່ປຸ່ນ."

#. kNbhq
#: 06110000.xhp
msgctxt ""
"06110000.xhp\n"
"tit\n"
"help.text"
msgid "Calculate"
msgstr "ຄຳນວນ"

#. 2Fc6W
#: 06110000.xhp
msgctxt ""
"06110000.xhp\n"
"hd_id3154505\n"
"help.text"
msgid "<link href=\"text/swriter/01/06110000.xhp\">Calculate</link>"
msgstr "<link href=\"text/swriter/01/06110000.xhp\">ຄຳນວນ</link>"

#. yzg8C
#: 06110000.xhp
msgctxt ""
"06110000.xhp\n"
"par_id3150021\n"
"help.text"
msgid "<ahelp hid=\".uno:CalculateSel\" visibility=\"visible\">Calculates the selected formula and copies the result to the clipboard.</ahelp>"
msgstr "<ahelp hid=\".uno:CalculateSel\" visibility=\"visible\">ຄຳນວນສູດທີ່ເລືອກ ແລະ ສຳເນົາຜົນລັບໃສ່ຄລິບບອດ (clipboard).</ahelp>"

#. 8eVUy
#: 06120000.xhp
msgctxt ""
"06120000.xhp\n"
"tit\n"
"help.text"
msgid "Page Formatting"
msgstr "ການຈັດຮູບແບບໜ້າ"

#. Vku4B
#: 06120000.xhp
msgctxt ""
"06120000.xhp\n"
"hd_id3155961\n"
"help.text"
msgid "<link href=\"text/swriter/01/06120000.xhp\">Page Formatting</link>"
msgstr "<link href=\"text/swriter/01/06120000.xhp\">ການຈັດຮູບແບບໜ້າ</link>"

#. zQpK8
#: 06120000.xhp
msgctxt ""
"06120000.xhp\n"
"par_id3150249\n"
"help.text"
msgid "<ahelp visibility=\"visible\" hid=\".uno:Repaginate\">Updates the page formats in the document and recalculates the total number of pages that is displayed on the <emph>Status Bar</emph>.</ahelp>"
msgstr "<ahelp visibility=\"visible\" hid=\".uno:Repaginate\">ປັບປຸງຮູບແບບໜ້າໃນເອກະສານ ແລະ ຄຳນວນຈຳນວນໜ້າທັງໝົດຄືນໃໝ່ ທີ່ສະແດງຢູ່ໃນ <emph>ແຖບສະຖານະ</emph>.</ahelp>"

#. Epp32
#: 06120000.xhp
msgctxt ""
"06120000.xhp\n"
"par_id3154766\n"
"help.text"
msgid "In long documents, updating the page formatting can take a while."
msgstr "ໃນເອກະສານທີ່ມີຄວາມຍາວຫຼາຍ, ການປັບປຸງການຈັດຮູບແບບໜ້າອາດຈະໃຊ້ເວລາໄລຍະໜຶ່ງ."

#. W63g9
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"tit\n"
"help.text"
msgid "Current Index"
msgstr "ດັດຊະນີປັດຈຸບັນ"

#. 2FaEC
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"hd_id3154704\n"
"help.text"
msgid "<link href=\"text/swriter/01/06160000.xhp\">Current Index</link>"
msgstr "<link href=\"text/swriter/01/06160000.xhp\">ດັດຊະນີປັດຈຸບັນ</link>"

#. iMkmd
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"par_id3149499\n"
"help.text"
msgid "<ahelp hid=\".uno:UpdateCurIndex\" visibility=\"visible\">Updates the current index.</ahelp> The current index is the one that contains the cursor."
msgstr "<ahelp hid=\".uno:UpdateCurIndex\" visibility=\"visible\">ປັບປຸງດັດຊະນີປັດຈຸບັນ.</ahelp> ດັດຊະນີປັດຈຸບັນແມ່ນອັນທີ່ມີເຄີເຊີຢູ່."

#. dVm6f
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"par_id3154763\n"
"help.text"
msgid "You can also right-click in an index or table of contents, and then choose <emph>Update Index or Table of Contents</emph>. The following commands are also available in the context menu:"
msgstr "ທ່ານຍັງສາມາດຄລິກຂວາໃນດັດຊະນີ ຫຼື ສາລະບານ, ຈາກນັ້ນເລືອກ <emph>ປັບປຸງດັດຊະນີ ຫຼື ສາລະບານ</emph>. ຄຳສັ່ງດັ່ງຕໍ່ໄປນີ້ຍັງມີໃຫ້ໃຊ້ໃນເມນູຄລິກຂວາ:"

#. EEH64
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"hd_id3146967\n"
"help.text"
msgid "Edit Index or Table of Contents"
msgstr "ແກ້ໄຂດັດຊະນີ ຫຼື ສາລະບານ"

#. yyjDo
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"par_id3151387\n"
"help.text"
msgid "<ahelp hid=\".uno:EditCurIndex\" visibility=\"visible\">Edits the current index or table.</ahelp>"
msgstr "<ahelp hid=\".uno:EditCurIndex\" visibility=\"visible\">ແກ້ໄຂດັດຊະນີ ຫຼື ຕາຕະລາງປັດຈຸບັນ.</ahelp>"

#. Qh48d
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"hd_id3147403\n"
"help.text"
msgid "Delete Index or Table of Contents"
msgstr "ລຶບດັດຊະນີ ຫຼື ສາລະບານ"

#. BZDEn
#: 06160000.xhp
msgctxt ""
"06160000.xhp\n"
"par_id3155625\n"
"help.text"
msgid "<ahelp hid=\".uno:RemoveTableOf\" visibility=\"visible\">Deletes the current index or table.</ahelp>"
msgstr "<ahelp hid=\".uno:RemoveTableOf\" visibility=\"visible\">ລຶບດັດຊະນີ ຫຼື ຕາຕະລາງປັດຈຸບັນ.</ahelp>"

#. EytrE
#: 06170000.xhp
msgctxt ""
"06170000.xhp\n"
"tit\n"
"help.text"
msgid "All Indexes and Tables"
msgstr "ດັດຊະນີ ແລະ ຕາຕະລາງທັງໝົດ"

#. EaDB5
#: 06170000.xhp
msgctxt ""
"06170000.xhp\n"
"hd_id3149875\n"
"help.text"
msgid "<link href=\"text/swriter/01/06170000.xhp\">All Indexes and Tables</link>"
msgstr "<link href=\"text/swriter/01/06170000.xhp\">ດັດຊະນີ ແລະ ຕາຕະລາງທັງໝົດ</link>"

#. FjJnf
#: 06170000.xhp
msgctxt ""
"06170000.xhp\n"
"par_id3150211\n"
"help.text"
msgid "<ahelp hid=\".uno:UpdateAllIndexes\" visibility=\"visible\">Update all indexes and tables of contents in the current document. You do not need to place the cursor in an index or table before you use this command.</ahelp>"
msgstr "<ahelp hid=\".uno:UpdateAllIndexes\" visibility=\"visible\">ປັບປຸງດັດຊະນີ ແລະ ສາລະບານທັງໝົດໃນເອກະສານປັດຈຸບັນ. ທ່ານບໍ່ຈຳເປັນຕ້ອງວາງເຄີເຊີໃນດັດຊະນີ ຫຼື ຕາຕະລາງກ່ອນທີ່ຈະໃຊ້ຄຳສັ່ງນີ້.</ahelp>"

#. TEBED
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"tit\n"
"help.text"
msgid "Line Numbering"
msgstr "ການໃສ່ລຳດັບເລກແຖວ"

#. cmZB8
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"hd_id3154705\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/06180000.xhp#linenumbers\">Line Numbering</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/06180000.xhp#linenumbers\">ການໃສ່ລຳດັບເລກແຖວ</link></variable>"

#. R9fgE
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"par_id3150249\n"
"help.text"
msgid "<variable id=\"zeinum\">Adds or removes and formats line numbers in the current document.</variable>"
msgstr "<variable id=\"zeinum\">ເພີ່ມ ຫຼື ລຶບ ແລະ ຈັດຮູບແບບລຳດັບເລກແຖວໃນເອກະສານປັດຈຸບັນ.</variable>"

#. GcdFF
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"par_id248115\n"
"help.text"
msgid "Line numbers are not available in HTML format."
msgstr "ລຳດັບເລກແຖວບໍ່ມີໃຫ້ໃຊ້ໃນຮູບແບບ HTML."

#. ec2Bu
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"par_id301695921327210\n"
"help.text"
msgid "To exclude a paragraph from line numbering, click in the paragraph, choose <menuitem>Format - Paragraph</menuitem>, click the <emph>Outline & List</emph> tab, and then clear the <emph>Include this paragraph in line numbering</emph> check box. You can also exclude a paragraph style from line numbering."
msgstr "ເພື່ອຍົກເວັ້ນຫຍໍ້ໜ້າຈາກການໃສ່ລຳດັບເລກແຖວ, ໃຫ້ຄລິກໃສ່ຫຍໍ້ໜ້ານັ້ນ, ເລືອກ <menuitem>ຮູບແບບ - ຫຍໍ້ໜ້າ</menuitem>, ຄລິກແຖບ <emph>ໂຄງຮ່າງ ແລະ ລາຍການ</emph>, ຈາກນັ້ນຍົກເລີກການເລືອກຊ່ອງ <emph>ລວມຫຍໍ້ໜ້ານີ້ໃນການໃສ່ລຳດັບເລກແຖວ</emph>. ທ່ານຍັງສາມາດຍົກເວັ້ນຮູບແບບຫຍໍ້ໜ້າຈາກການໃສ່ລຳດັບເລກແຖວໄດ້ຄືກັນ."

