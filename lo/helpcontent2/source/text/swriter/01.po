msgctxt ""
"copyfielddialog.xhp\n"
"par_id181516900309119\n"
"help.text"
msgid "<ahelp hid=\".\">Copy the contents of the field for reuse in other documents.</ahelp>"
msgstr "<ahelp hid=\".\">ຄັດລອກເນື້ອໃນຂອງຟິວເພື່ອເອົາໄປໃຊ້ໃໝ່ໃນເອກະສານອື່ນ.</ahelp>"

