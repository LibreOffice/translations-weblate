"help.text"
msgid "<ahelp hid=\"sfx/ui/loadtemplatedialog/overwrite\">Replaces styles in the current document that have the same name as the styles you are loading. No warning message is given.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/loadtemplatedialog/overwrite\">ປ່ຽນແທນຮູບແບບໃນເອກະສານປັດຈຸບັນທີ່ມີຊື່ດຽວກັນກັບຮູບແບບທີ່ທ່ານກຳລັງໂຫຼດ. ຈະບໍ່ມີການແຈ້ງເຕືອນໃດໆ.</ahelp>"

#. EqEyd
#: 05170000.xhp
msgctxt ""
"05170000.xhp\n"
"par_id3150358\n"
"help.text"
msgid "Only applied styles and modified styles are loaded from a document or template. The styles shown in the sidebar cannot be used as a guide."
msgstr "ສະເພາະຮູບແບບທີ່ຖືກນຳໃຊ້ ແລະ ຮູບແບບທີ່ຖືກດັດແກ້ເທົ່ານັ້ນທີ່ຈະຖືກໂຫຼດຈາກເອກະສານ ຫຼື ແມ່ແບບ. ຮູບແບບທີ່ສະແດງຢູ່ໃນແຖບຂ້າງບໍ່ສາມາດໃຊ້ເປັນຄູ່ມືໄດ້."

#. ivfvH
#: 05170000.xhp
msgctxt ""
"05170000.xhp\n"
"hd_id3153668\n"
"help.text"
msgid "From File"
msgstr "ຈາກໄຟລ໌"

#. 8Npm7
#: 05170000.xhp
msgctxt ""
"05170000.xhp\n"
"par_id3147526\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/loadtemplatedialog/fromfile\">Locate the file containing the styles that you want to load, and then click <emph>Open</emph>.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/loadtemplatedialog/fromfile\">ຊອກຫາໄຟລ໌ທີ່ມີຮູບແບບທີ່ທ່ານຕ້ອງການໂຫຼດ, ຈາກນັ້ນຄລິກ <emph>ເປີດ</emph>.</ahelp>"

#. 6QB2V
#: 05170000.xhp
msgctxt ""
"05170000.xhp\n"
"par_id121611051600253\n"
"help.text"
msgid "To save styles from a document as a template, use <emph>From File</emph> to load the styles to an empty document, then choose <menuitem>File - Templates - Save as Template</menuitem>."
msgstr "ເພື່ອບັນທຶກຮູບແບບຈາກເອກະສານເປັນແມ່ແບບ, ໃຫ້ໃຊ້ <emph>ຈາກໄຟລ໌</emph> ເພື່ອໂຫຼດຮູບແບບໃສ່ເອກະສານຫວ່າງເປົ່າ, ຈາກນັ້ນເລືອກ <menuitem>ໄຟລ໌ - ແມ່ແບບ - ບັນທຶກເປັນແມ່ແບບ</menuitem>."

#. xjekF
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"tit\n"
"help.text"
msgid "Split Table"
msgstr "ແຍກຕາຕະລາງ"

#. AicjV
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"bm_id3153246\n"
"help.text"
msgid "<bookmark_value>tables; splitting</bookmark_value><bookmark_value>splitting tables; at cursor position</bookmark_value><bookmark_value>dividing tables</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງ; ການແຍກ</bookmark_value><bookmark_value>ການແຍກຕາຕະລາງ; ຢູ່ຕຳແໜ່ງເຄີເຊີ</bookmark_value><bookmark_value>ການແບ່ງຕາຕະລາງ</bookmark_value>"

#. p3i4E
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3153246\n"
"help.text"
msgid "<link href=\"text/swriter/01/05190000.xhp\">Split Table</link>"
msgstr "<link href=\"text/swriter/01/05190000.xhp\">ແຍກຕາຕະລາງ</link>"

#. RiuSm
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3083450\n"
"help.text"
msgid "<ahelp hid=\".uno:SplitTable\">Splits the current table into two separate tables at the cursor position.</ahelp> You can also access this command by right-clicking in a table cell."
msgstr "<ahelp hid=\".uno:SplitTable\">ແຍກຕາຕະລາງປັດຈຸບັນອອກເປັນສອງຕາຕະລາງຢູ່ຕຳແໜ່ງເຄີເຊີ.</ahelp> ທ່ານຍັງສາມາດເຂົ້າເຖິງຄຳສັ່ງນີ້ໄດ້ໂດຍການຄລິກຂວາໃນຫ້ອງຕາຕະລາງ."

#. 9mApf
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3149351\n"
"help.text"
msgid "Mode"
msgstr "ໂໝດ"

#. dLB2T
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3154554\n"
"help.text"
msgid "Copy heading"
msgstr "ສຳເນົາຫົວຂໍ້"

#. e3CtK
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3154503\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/splittable/copyheading\">Includes the first row of the original table as the first row of the second table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/splittable/copyheading\">ລວມເອົາແຖວທຳອິດຂອງຕາຕະລາງເດີມເປັນແຖວທຳອິດຂອງຕາຕະລາງທີສອງ.</ahelp>"

#. 5bFfm
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3149880\n"
"help.text"
msgid "Custom heading (apply style)"
msgstr "ຫົວຂໍ້ກຳນົດເອງ (ນຳໃຊ້ຮູບແບບ)"

#. uFWhC
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3148389\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/splittable/customheadingapplystyle\">Inserts a blank header row in the second table that is formatted with the style of the first row in the original table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/splittable/customheadingapplystyle\">ແຊກແຖວຫົວຂໍ້ຫວ່າງເປົ່າໃນຕາຕະລາງທີສອງ ທີ່ຈັດຮູບແບບດ້ວຍຮູບແບບຂອງແຖວທຳອິດໃນຕາຕະລາງເດີມ.</ahelp>"

#. nhrJp
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3150568\n"
"help.text"
msgid "Custom heading"
msgstr "ຫົວຂໍ້ກຳນົດເອງ"

#. Pr3Rb
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3149027\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/splittable/customheading\">Inserts an additional blank row in the second table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/splittable/customheading\">ແຊກແຖວຫວ່າງເປົ່າເພີ່ມເຕີມໃນຕາຕະລາງທີສອງ.</ahelp>"

#. UwcD8
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"hd_id3153720\n"
"help.text"
msgid "No heading"
msgstr "ບໍ່ມີຫົວຂໍ້"

#. rE7g4
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3156318\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/splittable/noheading\">Splits the table without copying the header row.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/splittable/noheading\">ແຍກຕາຕະລາງໂດຍບໍ່ສຳເນົາແຖວຫົວຂໍ້.</ahelp>"

#. Gx63y
#: 05190000.xhp
msgctxt ""
"05190000.xhp\n"
"par_id3145411\n"
"help.text"
msgid "When you split a table that contains formulas, the formulas may be affected."
msgstr "ເມື່ອທ່ານແຍກຕາຕະລາງທີ່ມີສູດຄຳນວນ, ສູດເຫຼົ່ານັ້ນອາດຈະໄດ້ຮັບຜົນກະທົບ."

#. JwChf
#: 05200000.xhp
msgctxt ""
"05200000.xhp\n"
"tit\n"
"help.text"
msgid "Merge Table"
msgstr "ລວມຕາຕະລາງ"

#. D27vi
#: 05200000.xhp
msgctxt ""
"05200000.xhp\n"
"bm_id3154652\n"
"help.text"
msgid "<bookmark_value>tables; merging</bookmark_value><bookmark_value>merging; tables</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງ; ການລວມ</bookmark_value><bookmark_value>ການລວມ; ຕາຕະລາງ</bookmark_value>"

#. DJwCN
#: 05200000.xhp
msgctxt ""
"05200000.xhp\n"
"hd_id3154652\n"
"help.text"
msgid "<link href=\"text/swriter/01/05200000.xhp\">Merge Table</link>"
msgstr "<link href=\"text/swriter/01/05200000.xhp\">ລວມຕາຕະລາງ</link>"

#. 7qBjV
#: 05200000.xhp
msgctxt ""
"05200000.xhp\n"
"par_id3147401\n"
"help.text"
msgid "<ahelp hid=\".\">Combines two consecutive tables into a single table. The tables must be directly next to each other and not separated by an empty paragraph.</ahelp>"
msgstr "<ahelp hid=\".\">ລວມສອງຕາຕະລາງທີ່ຢູ່ຕິດກັນໃຫ້ເປັນຕາຕະລາງດຽວ. ຕາຕະລາງຕ້ອງຢູ່ຕິດກັນໂດຍກົງ ແລະ ບໍ່ຖືກແຍກດ້ວຍຫຍໍ້ໜ້າຫວ່າງເປົ່າ.</ahelp>"

#. Eop64
#: 05200000.xhp
msgctxt ""
"05200000.xhp\n"
"par_id3146325\n"
"help.text"
msgid "If you choose this command when the cursor is in the middle of three consecutive tables, you are prompted to select the table that you want to merge with."
msgstr "ຖ້າທ່ານເລືອກຄຳສັ່ງນີ້ເມື່ອເຄີເຊີຢູ່ລະຫວ່າງກາງຂອງສາມຕາຕະລາງທີ່ຢູ່ຕິດກັນ, ທ່ານຈະຖືກຖາມໃຫ້ເລືອກຕາຕະລາງທີ່ທ່ານຕ້ອງການລວມເຂົ້າກັນ."

#. gDnAn
#: 06040000.xhp
msgctxt ""
"06040000.xhp\n"
"tit\n"
"help.text"
msgid "Word Count"
msgstr "ນັບຈຳນວນຄຳ"

#. LSvFZ
#: 06040000.xhp
msgctxt ""
"06040000.xhp\n"
"par_idN10542\n"
"help.text"
msgid "<link href=\"text/swriter/01/06040000.xhp\">Word Count</link>"
msgstr "<link href=\"text/swriter/01/06040000.xhp\">ນັບຈຳນວນຄຳ</link>"

#. 9yDkF
#: 06040000.xhp
msgctxt ""
"06040000.xhp\n"
"par_idN10552\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/wordcount/WordCountDialog\">Counts the words and characters, with or without spaces, in the current selection and in the whole document. The count is kept up to date as you type or change the selection.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/wordcount/WordCountDialog\">ນັບຈຳນວນຄຳ ແລະ ຕົວອັກສອນ, ແບບລວມ ຫຼື ບໍ່ລວມຍະຫວ່າງ, ໃນສ່ວນທີ່ເລືອກ ແລະ ໃນເອກະສານທັງໝົດ. ຈຳນວນທີ່ນັບຈະຖືກປັບປຸງໃຫ້ເປັນປັດຈຸບັນສະເໝີໃນຂະນະທີ່ທ່ານພິມ ຫຼື ປ່ຽນແປງສ່ວນທີ່ເລືອກ.</ahelp>"

#. e9tdK
#: 06040000.xhp
msgctxt ""
"06040000.xhp\n"
"par_idN1062D\n"
"help.text"
msgid "<link href=\"text/shared/01/01100400.xhp\"><menuitem>File - Properties - Statistics</menuitem> </link>"
msgstr "<link href=\"text/shared/01/01100400.xhp\"><menuitem>ໄຟລ໌ - ຄຸນສົມບັດ - ສະຖິຕິ</menuitem> </link>"

#. zeLA7
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"tit\n"
"help.text"
msgid "Heading Numbering"
msgstr "ການໃສ່ລຳດັບເລກຫົວຂໍ້"

#. inDT7
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"hd_id3154561\n"
"help.text"
msgid "<variable id=\"ChapNumh1\"><link href=\"text/swriter/01/06060000.xhp\">Heading Numbering</link></variable>"
msgstr "<variable id=\"ChapNumh1\"><link href=\"text/swriter/01/06060000.xhp\">ການໃສ່ລຳດັບເລກຫົວຂໍ້</link></variable>"

#. 5hhEW
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3145246\n"
"help.text"
msgid "<variable id=\"headingnum\"><ahelp hid=\".uno:ChapterNumberingDialog\">Specify the numbering format used for automatic numbering of headings in the current document.</ahelp></variable>"
msgstr "<variable id=\"headingnum\"><ahelp hid=\".uno:ChapterNumberingDialog\">ລະບຸຮູບແບບການໃສ່ລຳດັບເລກທີ່ໃຊ້ສຳລັບການໃສ່ລຳດັບເລກຫົວຂໍ້ອັດຕະໂນມັດໃນເອກະສານປັດຈຸບັນ.</ahelp></variable>"

#. 27WCr
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3150934\n"
"help.text"
msgid "Numbering on headings is achieved by setting a numbering scheme to paragraph styles used as headings. The outline level assigned to the paragraph style expresses the place of a heading in your document structure. A numbering scheme can be set for each outline level."
msgstr "ການໃສ່ລຳດັບເລກຫົວຂໍ້ເຮັດໄດ້ໂດຍການຕັ້ງຄ່າຮູບແບບການໃສ່ລຳດັບເລກໃຫ້ກັບຮູບແບບຫຍໍ້ໜ້າທີ່ໃຊ້ເປັນຫົວຂໍ້. ລະດັບໂຄງຮ່າງທີ່ກຳນົດໃຫ້ກັບຮູບແບບຫຍໍ້ໜ້າຈະບົ່ງບອກເຖິງຕຳແໜ່ງຂອງຫົວຂໍ້ໃນໂຄງສ້າງເອກະສານຂອງທ່ານ. ສາມາດຕັ້ງຄ່າຮູບແບບການໃສ່ລຳດັບເລກໄດ້ສຳລັບແຕ່ລະລະດັບໂຄງຮ່າງ."

#. soEh3
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id941676633263661\n"
"help.text"
msgid "By default, %PRODUCTNAME assigns the predefined “Heading [1–10]” paragraph styles to the corresponding outline levels (1–10) in the dialog. You can use the dialog to assign a different paragraph style to an outline level. Only one paragraph style can be assigned to each outline level."
msgstr "ໂດຍຄ່າເລີ່ມຕົ້ນ, %PRODUCTNAME ຈະກຳນົດຮູບແບບຫຍໍ້ໜ້າ \"ຫົວຂໍ້ [1-10]\" ທີ່ຕັ້ງໄວ້ລ່ວງໜ້າໃຫ້ກັບລະດັບໂຄງຮ່າງທີ່ກ່ຽວຂ້ອງ (1-10) ໃນປ່ອງຢ້ຽມໂຕ້ຕອບ. ທ່ານສາມາດໃຊ້ປ່ອງຢ້ຽມໂຕ້ຕອບເພື່ອ ກຳນົດຮູບແບບຫຍໍ້ໜ້າອື່ນໃຫ້ກັບລະດັບໂຄງຮ່າງ. ສາມາດກຳນົດຮູບແບບຫຍໍ້ໜ້າໄດ້ພຽງໜຶ່ງຮູບແບບຕໍ່ໜຶ່ງລະດັບໂຄງຮ່າງເທົ່ານັ້ນ."

#. noC3N
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id8237250\n"
"help.text"
msgid "<variable id=\"chapter_numbering_tip\">If you want numbered headings, choose <menuitem>Tools - </menuitem><link href=\"text/swriter/01/06060000.xhp#ChapNumh1\"><menuitem>Heading Numbering</menuitem></link>. This command opens a dialog where numbering schemes can be assigned to paragraph styles used for headings. Do not use the <link href=\"text/swriter/02/02110000.xhp\">Toggle Ordered List</link> icon on the <link href=\"text/swriter/main0202.xhp\">Formatting Bar</link> or the <menuitem>Format - </menuitem><link href=\"text/shared/01/06050000.xhp\"><menuitem>Bullets and Numbering</menuitem></link> dialog.</variable>"
msgstr "<variable id=\"chapter_numbering_tip\">ຖ້າທ່ານຕ້ອງການຫົວຂໍ້ທີ່ມີລຳດັບເລກ, ໃຫ້ເລືອກ <menuitem>ເຄື່ອງມື - </menuitem><link href=\"text/swriter/01/06060000.xhp#ChapNumh1\"><menuitem>ການໃສ່ລຳດັບເລກຫົວຂໍ້</menuitem></link>. ຄຳສັ່ງນີ້ຈະເປີດປ່ອງຢ້ຽມໂຕ້ຕອບທີ່ສາມາດກຳນົດຮູບແບບການໃສ່ລຳດັບເລກໃຫ້ກັບຮູບແບບຫຍໍ້ໜ້າທີ່ໃຊ້ສຳລັບຫົວຂໍ້. ຢ່າໃຊ້ໄອຄອນ <link href=\"text/swriter/02/02110000.xhp\">ສະຫຼັບລາຍການແບບລຳດັບ</link> ໃນ <link href=\"text/swriter/main0202.xhp\">ແຖບການຈັດຮູບແບບ</link> ຫຼື ປ່ອງຢ້ຽມໂຕ້ຕອບ <menuitem>ຮູບແບບ - </menuitem><link href=\"text/shared/01/06050000.xhp\"><menuitem>ຫົວຂໍ້ຍ່ອຍ ແລະ ການໃສ່ລຳດັບເລກ</menuitem></link>.</variable>"

#. DFbiG
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"hd_id3151168\n"
"help.text"
msgid "Load/Save"
msgstr "ໂຫຼດ/ບັນທຶກ"

#. AyMcG
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3147512\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/outlinenumbering/format\">Saves or loads a numbering format for headings. Saved numbering formats are available to load into other text documents.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/outlinenumbering/format\">ບັນທຶກ ຫຼື ໂຫຼດຮູບແບບການໃສ່ລຳດັບເລກສຳລັບຫົວຂໍ້. ຮູບແບບການໃສ່ລຳດັບເລກທີ່ບັນທຶກໄວ້ສາມາດໂຫຼດໄປໃຊ້ໃນເອກະສານຂໍ້ຄວາມອື່ນໆໄດ້.</ahelp>"

#. JdVMu
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3150979\n"
"help.text"
msgid "The <widget>Load/Save</widget> button is only available for heading numbering. Use List styles to save formatting for ordered or unordered lists."
msgstr "ປຸ່ມ <widget>ໂຫຼດ/ບັນທຶກ</widget> ມີໃຫ້ໃຊ້ສະເພາະສຳລັບການໃສ່ລຳດັບເລກຫົວຂໍ້ເທົ່ານັ້ນ. ໃຫ້ໃຊ້ຮູບແບບລາຍການເພື່ອບັນທຶກການຈັດຮູບແບບສຳລັບລາຍການແບບລຳດັບ ຫຼື ບໍ່ເປັນລຳດັບ."

#. EV2DT
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"hd_id3154572\n"
"help.text"
msgid "Untitled 1 - 9"
msgstr "ບໍ່ມີຫົວຂໍ້ 1 - 9"

#. NFECZ
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3150350\n"
"help.text"
msgid "<ahelp hid=\".\">Select a predefined numbering format.</ahelp> Initially the  “Untitled [1–9]”  formats are empty. You can save your settings as a numbering format using <menuitem>Save As</menuitem>. Saved formats appear in the menu with the name you entered."
msgstr "<ahelp hid=\".\">ເລືອກຮູບແບບການໃສ່ລຳດັບເລກທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ.</ahelp> ໃນຕອນເລີ່ມຕົ້ນ ຮູບແບບ \"ບໍ່ມີຫົວຂໍ້ [1–9]\" ຈະຫວ່າງເປົ່າ. ທ່ານສາມາດບັນທຶກການຕັ້ງຄ່າຂອງທ່ານເປັນຮູບແບບການໃສ່ລຳດັບເລກໂດຍໃຊ້ <menuitem>ບັນທຶກເປັນ</menuitem>. ຮູບແບບທີ່ບັນທຶກໄວ້ຈະປາກົດຢູ່ໃນເມນູດ້ວຍຊື່ທີ່ທ່ານປ້ອນເຂົ້າ."

#. NoHGV
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"hd_id3153675\n"
"help.text"
msgid "Save As"
msgstr "ບັນທຶກເປັນ"

#. AfDgB
#: 06060000.xhp
msgctxt ""
"06060000.xhp\n"
"par_id3155892\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/outlinenumbering/saveas\">Opens a dialog where you can save the current numbering and position settings for all levels as a numbering format. Saved numbering formats are available to load into other documents.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/outlinenumbering/saveas\">ເປີດປ່ອງຢ້ຽມໂຕ້ຕອບທີ່ທ່ານສາມາດບັນທຶກການໃສ່ລຳດັບເລກ ແລະ ການຕັ້ງຄ່າຕຳແໜ່ງປັດຈຸບັນສຳລັບທຸກລະດັບເປັນຮູບແບບການໃສ່ລຳດັບເລກ. ຮູບແບບທີ່ບັນທຶກໄວ້ສາມາດໂຫຼດໄປໃຊ້ໃນເອກະສານອື່ນໆໄດ້.</ahelp>"

