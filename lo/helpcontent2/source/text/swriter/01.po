#. bFVzE
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"bm_id551630942369429\n"
"help.text"
msgid "<bookmark_value>accessibility;check in text document</bookmark_value>    <bookmark_value>PDF/UA;check</bookmark_value>"
msgstr "<bookmark_value>ການເຂົ້າເຖິງ;ກວດສອບໃນເອກະສານຂໍ້ຄວາມ</bookmark_value>    <bookmark_value>PDF/UA;ກວດສອບ</bookmark_value>"

#. 9MTFg
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"hd_id771630940172827\n"
"help.text"
msgid "<variable id=\"accessibilitycheckh1\"><link href=\"text/swriter/01/accessibility_check.xhp\">Accessibility Check</link></variable>"
msgstr "<variable id=\"accessibilitycheckh1\"><link href=\"text/swriter/01/accessibility_check.xhp\">ການກວດສອບການເຂົ້າເຖິງ</link></variable>"

#. ocjWU
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id951630940172830\n"
"help.text"
msgid "Review common accessibility problems in the document, and support for PDF/UA specifications in the PDF export dialog and the accessibility deck of the sidebar."
msgstr "ກວດສອບບັນຫາການເຂົ້າເຖິງທົ່ວໄປໃນເອກະສານ, ແລະ ຮອງຮັບຂໍ້ກຳນົດ PDF/UA ໃນປ່ອງຢ້ຽມສົ່ງອອກ PDF ແລະ ສ່ວນການເຂົ້າເຖິງຂອງແຖບຂ້າງ."

#. FvnEV
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id901630941406987\n"
"help.text"
msgid "The Accessibility Check tool traverses the document structure and gather all possible accessibility issues. The check can be run manually through the menu or it will be triggered after PDF export dialog, when the PDF/UA support is enabled."
msgstr "ເຄື່ອງມືກວດສອບການເຂົ້າເຖິງຈະກວດຜ່ານໂຄງສ້າງເອກະສານ ແລະ ຮວບຮວມບັນຫາການເຂົ້າເຖິງທີ່ເປັນໄປໄດ້ທັງໝົດ. ການກວດສອບສາມາດເຮັດໄດ້ດ້ວຍຕົນເອງຜ່ານເມນູ ຫຼື ຈະຖືກກະຕຸ້ນຫຼັງຈາກປ່ອງຢ້ຽມສົ່ງອອກ PDF ເມື່ອເປີດໃຊ້ການຮອງຮັບ PDF/UA."

#. fAJBE
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"hd_id271630943848307\n"
"help.text"
msgid "The Accessibility Check Panel on Sidebar"
msgstr "ແຖບການກວດສອບການເຂົ້າເຖິງຢູ່ແຖບຂ້າງ"

#. cMPRg
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id681630943858371\n"
"help.text"
msgid "The Accessibility Check panel on sidebar shows a list of all issues found in the text document."
msgstr "ແຖບການກວດສອບການເຂົ້າເຖິງຢູ່ແຖບຂ້າງຈະສະແດງລາຍຊື່ຂອງບັນຫາທັງໝົດທີ່ພົບໃນເອກະສານຂໍ້ຄວາມ."

#. xy8hY
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id611696018066788\n"
"help.text"
msgid "Links are provided to navigate to the issue immediately. Double click the link to jump and select the object with the accessibility issue."
msgstr "ມີລິ້ງໃຫ້ເພື່ອໄປຫາບັນຫາໄດ້ທັນທີ. ຄລິກສອງບາດທີ່ລິ້ງເພື່ອໄປຫາ ແລະ ເລືອກວັດຖຸທີ່ມີບັນຫາການເຂົ້າເຖິງ."

#. JbQ8L
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"hd_id841630943833924\n"
"help.text"
msgid "Fix button"
msgstr "ປຸ່ມແກ້ໄຂ"

#. FVp9R
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id41630943863594\n"
"help.text"
msgid "Click the Fix button to jump to the issue and provide commands to fix it."
msgstr "ຄລິກປຸ່ມແກ້ໄຂເພື່ອໄປຫາບັນຫາ ແລະ ໃຊ້ຄຳສັ່ງເພື່ອແກ້ໄຂມັນ."

#. WgpUi
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"hd_id121630943721145\n"
"help.text"
msgid "Common accessibility checks"
msgstr "ການກວດສອບການເຂົ້າເຖິງທົ່ວໄປ"

#. 9u7no
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id31630941412046\n"
"help.text"
msgid "The checks that are currently implemented are:"
msgstr "ການກວດສອບທີ່ມີການນຳໃຊ້ໃນປັດຈຸບັນຄື:"

#. sxkkp
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id191630941836904\n"
"help.text"
msgid "Check that the document title is set."
msgstr "ກວດສອບວ່າມີການຕັ້ງຊື່ຫົວຂໍ້ເອກະສານແລ້ວ."

#. B3GtS
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id1001630941860410\n"
"help.text"
msgid "Check that the document language is set, or that all styles that are in use, have the language set."
msgstr "ກວດສອບວ່າມີການຕັ້ງພາສາຂອງເອກະສານແລ້ວ, ຫຼື ຮູບແບບທັງໝົດທີ່ໃຊ້ຢູ່ມີການຕັ້ງພາສາໄວ້."

#. EhNJE
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id1001630941880414\n"
"help.text"
msgid "Check all images, graphics, OLE objects for the alt (or title in some objects) text."
msgstr "ກວດສອບຮູບພາບ, ກຣາບຟິກ, ວັດຖຸ OLE ທັງໝົດ ສຳລັບຂໍ້ຄວາມອະທິບາຍ (ຫຼື ຫົວຂໍ້ໃນບາງວັດຖຸ)."

#. AKxvB
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id491630941907745\n"
"help.text"
msgid "Check that tables do not include split or merged cells, which could be disorienting for users with visual impairments."
msgstr "ກວດສອບວ່າຕາຕະລາງບໍ່ມີການແຍກ ຫຼື ລວມຫ້ອງ, ເຊິ່ງອາດເຮັດໃຫ້ຜູ້ໃຊ້ທີ່ມີຄວາມບົກພ່ອງທາງສາຍຕາເກີດຄວາມສັບສົນ."

#. wkEAD
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id901630941949974\n"
"help.text"
msgid "Check for fake/manual numbering (not using integrated numbering). For example writing \"1.\" \"2.\" \"3.\" at the beginning of the paragraphs."
msgstr "ກວດສອບການໃສ່ລຳດັບເລກແບບປອມ/ເຮັດເອງ (ບໍ່ໄດ້ໃຊ້ການໃສ່ລຳດັບເລກແບບລະບົບ). ຕົວຢ່າງ: ການຂຽນ \"1.\" \"2.\" \"3.\" ຢູ່ຕອນເລີ່ມຕົ້ນຂອງຫຍໍ້ໜ້າ."

#. 9e7Xi
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id981630941970321\n"
"help.text"
msgid "Check that hyperlink text is not a hyperlink itself - hyperlink should be described."
msgstr "ກວດສອບວ່າຂໍ້ຄວາມໄຮເປີລິ້ງບໍ່ແມ່ນຕົວໄຮເປີລິ້ງເອງ - ໄຮເປີລິ້ງຄວນມີຄຳອະທິບາຍ."

#. DRKCs
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id421630941989099\n"
"help.text"
msgid "Check for the contrast between text and the background. The algorithm is described in the WCAG specification."
msgstr "ກວດສອບຄວາມແຕກຕ່າງ (contrast) ລະຫວ່າງຂໍ້ຄວາມ ແລະ ພື້ນຫຼັງ. ຂັ້ນຕອນການຄຳນວນແມ່ນຖືກອະທິບາຍໄວ້ໃນຂໍ້ກຳນົດ WCAG."

#. dVG2r
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id781630942005022\n"
"help.text"
msgid "Check for blinking text, which can be problematic for people with cognitive disabilities or photosensitive epilepsy."
msgstr "ກວດສອບຂໍ້ຄວາມທີ່ກະພິບ, ເຊິ່ງອາດເປັນບັນຫາສຳລັບຄົນທີ່ມີຄວາມບົກພ່ອງທາງສະຕິປັນຍາ ຫຼື ໂລກລົມຊັກທີ່ເກີດຈາກແສງ."

#. QgCco
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id651630942022847\n"
"help.text"
msgid "Check for footnotes and endnotes, which should be avoided."
msgstr "ກວດສອບເຊີນອັດ ແລະ ໝາຍເຫດທ້າຍເອກະສານ, ເຊິ່ງເປັນສິ່ງທີ່ຄວນຫຼີກເວັ້ນ."

#. uoggD
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id531630942039864\n"
"help.text"
msgid "Check for heading order. Order of the headings must increase incrementally with no skips (for example Heading 1 to Heading 3, skipping Heading 2)."
msgstr "ກວດສອບລຳດັບຫົວຂໍ້. ລຳດັບຂອງຫົວຂໍ້ຕ້ອງເພີ່ມຂຶ້ນຕາມລຳດັບໂດຍບໍ່ມີການຂ້າມ (ຕົວຢ່າງ: ຫົວຂໍ້ 1 ໄປຫາ ຫົວຂໍ້ 3, ໂດຍຂ້າມ ຫົວຂໍ້ 2)."

#. LdMWG
#: accessibility_check.xhp
msgctxt ""
"accessibility_check.xhp\n"
"par_id221630942064725\n"
"help.text"
msgid "Check, if text conveys additional meaning with (direct) formatting."
msgstr "ກວດສອບວ່າ ຂໍ້ຄວາມສື່ຄວາມໝາຍເພີ່ມເຕີມດ້ວຍການຈັດຮູບແບບ (ໂດຍກົງ) ຫຼື ບໍ່."

#. ZhX7A
#: baseline_grid.xhp
msgctxt ""
"baseline_grid.xhp\n"
"tit\n"
"help.text"
msgid "Baseline Grid"
msgstr "ເສັ້ນຕາຕະລາງພື້ນຖານ"

#. G4uzC
#: baseline_grid.xhp
msgctxt ""
"baseline_grid.xhp\n"
"bm_id571767535451864\n"
"help.text"
msgid "<bookmark_value>view;baseline grid</bookmark_value>        <bookmark_value>register-true;baseline grid</bookmark_value>        <bookmark_value>baseline grid;page line spacing</bookmark_value>        <bookmark_value>page line spacing;baseline grid</bookmark_value>"
msgstr "<bookmark_value>ເບິ່ງ;ຕາຕະລາງເສັ້ນພື້ນຖານ</bookmark_value>........<bookmark_value>ການຈັດໄລຍະບັນທັດໃຫ້ກົງກັນ;ຕາຕະລາງເສັ້ນພື້ນຖານ</bookmark_value>........<bookmark_value>ຕາຕະລາງເສັ້ນພື້ນຖານ;ໄລຍະຫ່າງແຖວໜ້າເຈ້ຍ</bookmark_value>........<bookmark_value>ໄລຍະຫ່າງແຖວໜ້າເຈ້ຍ;ຕາຕະລາງເສັ້ນພື້ນຖານ</bookmark_value>"

#. ne82j
