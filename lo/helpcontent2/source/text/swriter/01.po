msgid "Width"
msgstr "ຄວາມກວ້າງ"

#. FJses
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id3149880\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnwidth/width\">Enter the width that you want for the selected column(s).</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnwidth/width\">ປ້ອນຄວາມກວ້າງທີ່ທ່ານຕ້ອງການສຳລັບຖັນທີ່ເລືອກ.</ahelp>"

#. 9nDpw
