msgid "Edit Sections"
msgstr "ແກ້ໄຂສ່ວນ"

#. KvFD9
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"hd_id3153673\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/02170000.xhp#edit sections\">Sections</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/02170000.xhp#edit sections\">ສ່ວນ</link></variable>"

#. sBXSk
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3155902\n"
"help.text"
msgid "<variable id=\"bereichetext\"><ahelp hid=\".uno:EditRegion\">Changes the properties of sections defined in your document.</ahelp></variable>"
msgstr "<variable id=\"bereichetext\"><ahelp hid=\".uno:EditRegion\">ປ່ຽນແປງຄຸນສົມບັດຂອງສ່ວນທີ່ກຳນົດໄວ້ໃນເອກະສານຂອງທ່ານ.</ahelp></variable>"

#. Bf7Bi
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id781692738749024\n"
"help.text"
msgid "To insert a section, select text or click in your document, and then choose <emph>Insert - Section</emph>."
msgstr "ເພື່ອແຊກສ່ວນ, ໃຫ້ເລືອກຂໍ້ຄວາມ ຫຼື ຄລິກໃນເອກະສານຂອງທ່ານ, ແລ້ວເລືອກ <emph>ແຊກ - ສ່ວນ</emph>."

#. QkAqn
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3143275\n"
"help.text"
msgid "The <emph>Edit Sections</emph> dialog is similar to the <link href=\"text/swriter/01/04020100.xhp\"><emph>Insert - Section</emph></link> dialog, and offers the following additional options:"
msgstr "ໄດອະລັອກ <emph>ແກ້ໄຂສ່ວນ</emph> ແມ່ນຄ້າຍຄືກັບໄດອະລັອກ <link href=\"text/swriter/01/04020100.xhp\"><emph>ແຊກ - ສ່ວນ</emph></link>, ແລະ ມີຕົວເລືອກເພີ່ມເຕີມຕໍ່ໄປນີ້:"

#. w27PP
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"hd_id3149820\n"
"help.text"
msgid "Section"
msgstr "ສ່ວນ"

#. t7ZoG
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3149104\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/editsectiondialog/tree\">Type the name of the section that you want to edit, or click a name in the <emph>Section </emph>list.</ahelp> If the cursor is currently in a section, the section name is displayed on the right side of the status bar at the bottom of the document window."
msgstr "<ahelp hid=\"modules/swriter/ui/editsectiondialog/tree\">ພິມຊື່ຂອງສ່ວນທີ່ທ່ານຕ້ອງການແກ້ໄຂ, ຫຼື ຄລິກເລືອກຊື່ໃນລາຍການ <emph>ສ່ວນ </emph>.</ahelp> ຖ້າເຄີເຊີຢູ່ໃນສ່ວນໃດໜຶ່ງ, ຊື່ຂອງສ່ວນນັ້ນຈະຖືກສະແດງຢູ່ເບື້ອງຂວາຂອງແຖບສະຖານະທີ່ຢູ່ດ້ານລຸ່ມຂອງໜ້າຕ່າງເອກະສານ."

#. Gm7fw
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3149040\n"
"help.text"
msgid "The current write protection status of a section is indicated by the lock symbol in front of the section name in the list. An open lock is unprotected and a closed lock is protected. Similarly, visible sections are indicated by a glasses symbol."
msgstr "ສະຖານະການປ້ອງກັນການຂຽນປັດຈຸບັນຂອງສ່ວນໃດໜຶ່ງແມ່ນຖືກລະບຸດ້ວຍສັນຍະລັກຮູບກະແຈຢູ່ທາງໜ້າຊື່ສ່ວນໃນລາຍການ. ຮູບກະແຈທີ່ເປີດຢູ່ໝາຍເຖິງບໍ່ໄດ້ຖືກປ້ອງກັນ ແລະ ກະແຈທີ່ປິດຢູ່ໝາຍເຖິງຖືກປ້ອງກັນ. ໃນທຳນອງດຽວກັນ, ສ່ວນທີ່ເບິ່ງເຫັນໄດ້ແມ່ນຖືກລະບຸດ້ວຍສັນຍະລັກຮູບແວ່ນຕາ."

#. AsGFs
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"hd_id3153638\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. eQGUF
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3152773\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/editsectiondialog/tree\">Opens the <link href=\"text/swriter/01/05040501.xhp\"><emph>Options</emph></link> dialog, where you can edit the column layout, background, footnote and endnote behavior of the selected section.</ahelp> If the section is password protected, you must enter the password first."
msgstr "<ahelp hid=\"modules/swriter/ui/editsectiondialog/tree\">ເປີດໄດອະລັອກ <link href=\"text/swriter/01/05040501.xhp\"><emph>ຕົວເລືອກ</emph></link>, ເຊິ່ງທ່ານສາມາດແກ້ໄຂການຈັດວາງຖັນ, ພື້ນຫຼັງ, ພຶດຕິກຳຂອງເຊິງອັດ ແລະ ໝາຍເຫດທ້າຍບົດຂອງສ່ວນທີ່ເລືອກໄດ້.</ahelp> ຖ້າສ່ວນນັ້ນຖືກປ້ອງກັນດ້ວຍລະຫັດຜ່ານ, ທ່ານຈະຕ້ອງປ້ອນລະຫັດຜ່ານກ່ອນ."

#. moNZF
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"hd_id3155143\n"
"help.text"
msgid "Remove"
msgstr "ເອົາອອກ"

#. DStAD
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3145413\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/editsectiondialog/remove\">Removes the selected section from the document, and inserts the contents of the section into the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/editsectiondialog/remove\">ເອົາສ່ວນທີ່ເລືອກອອກຈາກເອກະສານ, ແລະ ແຊກເນື້ອໃນຂອງສ່ວນນັ້ນເຂົ້າໃນເອກະສານໂດຍກົງ.</ahelp>"

