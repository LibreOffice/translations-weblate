"help.text"
msgid "Available field Types and Select lists"
msgstr "ປະເພດຟິວ ແລະ ລາຍການເລືອກທີ່ມີຢູ່"

#. XLkyh
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3155182\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. UFpdn
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3143272\n"
"help.text"
msgid "Select list"
msgstr "ລາຍການເລືອກ"

#. Go6eY
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3151248\n"
"help.text"
msgid "Author"
msgstr "ຜູ້ຂຽນ"

#. wC9wy
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3148975\n"
"help.text"
msgid "Name or initials of current user (as entered in <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01010100.xhp\"><menuitem>$[officename] - User Data)</menuitem></link>."
msgstr "ຊື່ ຫຼື ອັກສອນຫຍໍ້ຂອງຜູ້ໃຊ້ປັດຈຸບັນ (ຕາມທີ່ປ້ອນເຂົ້າໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ການຕັ້ງຄ່າ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01010100.xhp\"><menuitem>$[officename] - ຂໍ້ມູນຜູ້ໃຊ້</menuitem></link>)."

#. Jb4YE
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3145771\n"
"help.text"
msgid "Date"
msgstr "ວັນທີ"

#. QdC4f
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3151370\n"
"help.text"
msgid "Inserts the current date. You can insert the date as a fixed field - <item type=\"literal\">Date (fixed)</item> - that does not change, or as a dynamic field - <literal>Date</literal> - that it is updated automatically. To manually update the <literal>Date</literal> field, press <keycode>F9</keycode>."
msgstr "ແຊກວັນທີປັດຈຸບັນ. ທ່ານສາມາດແຊກວັນທີເປັນຟິວຄົງທີ່ - <item type=\"literal\">ວັນທີ (ຄົງທີ່)</item> - ເຊິ່ງຈະບໍ່ມີການປ່ຽນແປງ, ຫຼື ເປັນຟິວທີ່ມີການເຄື່ອນໄຫວ - <literal>ວັນທີ</literal> - ເຊິ່ງຈະມີການອັບເດດໂດຍອັດຕະໂນມັດ. ເພື່ອອັບເດດຟິວ <literal>ວັນທີ</literal> ດ້ວຍຕົນເອງ, ໃຫ້ກົດ <keycode>F9</keycode>."

#. DtBK4
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3150699\n"
"help.text"
msgid "File name"
msgstr "ຊື່ໄຟລ໌"

#. mDLDd
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3150122\n"
"help.text"
msgid "Inserts the filename and/or the directory path of the current document, as well as the filename without extension."
msgstr "ແຊກຊື່ໄຟລ໌ ແລະ/ຫຼື ເສັ້ນທາງໄດເຣັກທໍຣີຂອງເອກະສານປັດຈຸບັນ, ລວມທັງຊື່ໄຟລ໌ໂດຍບໍ່ມີນາມສະກຸນ."

#. crvH2
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3145759\n"
"help.text"
msgid "Heading"
msgstr "ຫົວຂໍ້"

#. XHoBm
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3149172\n"
"help.text"
msgid "Shows the heading number and/or the heading contents of a heading prior to the inserted field."
msgstr "ສະແດງເລກຫົວຂໍ້ ແລະ/ຫຼື ເນື້ອໃນຫົວຂໍ້ຂອງຫົວຂໍ້ທີ່ຢູ່ກ່ອນຟິວທີ່ແຊກໄວ້."

#. 493NN
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3147495\n"
"help.text"
msgid "Page"
msgstr "ໜ້າ"

#. cNG7e
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3145264\n"
"help.text"
msgid "Inserts the page number of the current, previous, or next page."
msgstr "ແຊກເລກໜ້າຂອງໜ້າປັດຈຸບັນ, ໜ້າກ່ອນໜ້າ, ຫຼື ໜ້າຖັດໄປ."

#. xYn3y
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id611601755863247\n"
"help.text"
msgid "Inserts a meta-data field with a digital signature for the paragraph. You must have a digital certificate to sign a paragraph."
msgstr "ແຊກຟິວຂໍ້ມູນເມຕາ (meta-data) ພ້ອມກັບລາຍເຊັນດິຈິຕອນສຳລັບຫຍໍ້ໜ້າ. ທ່ານຕ້ອງມີໃບຢັ້ງຢືນດິຈິຕອນເພື່ອເຊັນຊື່ໃນຫຍໍ້ໜ້າ."

#. N2r6D
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3150561\n"
"help.text"
msgid "Sender"
msgstr "ຜູ້ສົ່ງ"

#. G2Caf
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3146341\n"
"help.text"
msgid "Inserts fields containing user data. You can change the user-data that is displayed by choosing <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01010100.xhp\"><menuitem>$[officename] - User Data</menuitem></link>."
msgstr "ແຊກຊ່ອງຂໍ້ມູນທີ່ມີຂໍ້ມູນຜູ້ໃຊ້. ທ່ານສາມາດປ່ຽນແປງຂໍ້ມູນຜູ້ໃຊ້ທີ່ຖືກສະແດງ ໂດຍການເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ການກຳນົດຄ່າ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01010100.xhp\"><menuitem>$[officename] - ຂໍ້ມູນຜູ້ໃຊ້</menuitem></link>."

#. WxVLH
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3148863\n"
"help.text"
msgid "Statistics"
msgstr "ສະຖິຕິ"

#. huxeZ
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3151091\n"
"help.text"
msgid "Inserts document statistics, such as page and word counts, as a field. To view the statistics of a document, choose <menuitem>File - Properties</menuitem>, and then click the <emph>Statistics</emph> tab."
msgstr "ແຊກສະຖິຕິເອກະສານ ເຊັ່ນ: ຈຳນວນໜ້າ ແລະ ຈຳນວນຄຳ ເປັນຟິວ. ເພື່ອເບິ່ງສະຖິຕິຂອງເອກະສານ, ໃຫ້ເລືອກ <menuitem>ໄຟລ໌ - ຄຸນສົມບັດ</menuitem>, ແລ້ວຄລິກທີ່ແທັບ <emph>ສະຖິຕິ</emph>."

#. u227i
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3153302\n"
"help.text"
msgid "Templates"
msgstr "ແມ່ແບບ"

#. abE2q
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3156123\n"
"help.text"
msgid "Inserts the filename, the filename without the file extension, the path, or the path and filename of the current template. You can also insert the <literal>Template name</literal> and <literal>Category</literal> of the current template."
msgstr "ແຊກຊື່ໄຟລ໌, ຊື່ໄຟລ໌ໂດຍບໍ່ມີນາມສະກຸນ, ເສັ້ນທາງ, ຫຼື ເສັ້ນທາງ ແລະ ຊື່ໄຟລ໌ຂອງແມ່ແບບປັດຈຸບັນ. ທ່ານຍັງສາມາດແຊກ <literal>ຊື່ແມ່ແບບ</literal> ແລະ <literal>ໝວດໝູ່</literal> ຂອງແມ່ແບບປັດຈຸບັນໄດ້."

#. mMpkY
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3146939\n"
"help.text"
msgid "Time"
msgstr "ເວລາ"

#. kZ4up
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154340\n"
"help.text"
msgid "Inserts the current time. You can insert the time as a fixed field - <literal>Time (fixed)</literal> - that does not change, or as a dynamic field - <literal>Time</literal> - that it is updated automatically. To manually update the <literal>Time</literal> field, press <keycode>F9</keycode>."
msgstr "ແຊກເວລາປັດຈຸບັນ. ທ່ານສາມາດແຊກເວລາເປັນຟິວຄົງທີ່ - <literal>ເວລາ (ຄົງທີ່)</literal> - ເຊິ່ງຈະບໍ່ມີການປ່ຽນແປງ, ຫຼື ເປັນຟິວທີ່ມີການເຄື່ອນໄຫວ - <literal>ເວລາ</literal> - ເຊິ່ງຈະມີການອັບເດດໂດຍອັດຕະໂນມັດ. ເພື່ອອັບເດດຟິວ <literal>ເວລາ</literal> ດ້ວຍຕົນເອງ, ໃຫ້ກົດ <keycode>F9</keycode>."

#. Baiuy
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3155537\n"
"help.text"
msgid "To quickly insert a field from the <emph>Select</emph> list, double-click the field."
msgstr "ເພື່ອແຊກຟິວຈາກລາຍການ <emph>ເລືອກ</emph> ຢ່າງວ່ອງໄວ, ໃຫ້ດັບເບິ້ນຄລິກທີ່ຟິວນັ້ນ."

#. zVKLG
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"hd_id3145595\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. 2vKF6
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3145613\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/format\">If a field is displaying a date, time or number, then <emph>Format</emph> is used to customize the appearance of the date, time, or number. Common formats are shown in the Format window, or click \"Additional formats\" to define a custom format.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/format\">ຖ້າຟິວໃດໜຶ່ງສະແດງວັນທີ, ເວລາ ຫຼື ຕົວເລກ, <emph>ຮູບແບບ</emph> ຈະຖືກໃຊ້ເພື່ອປັບແຕ່ງລັກສະນະຂອງວັນທີ, ເວລາ, ຫຼື ຕົວເລກນັ້ນ. ຮູບແບບທົ່ວໄປຈະສະແດງຢູ່ໃນປ່ອງຢ້ຽມຮູບແບບ, ຫຼື ຄລິກ \"ຮູບແບບເພີ່ມເຕີມ\" ເພື່ອກຳນົດຮູບແບບເອງ.</ahelp>"

#. UQ3xW
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3150138\n"
"help.text"
msgid "<variable id=\"datetimeformat\">When you click \"Additional formats\", the <link href=\"text/shared/01/05020300.xhp\"><emph>Number Format</emph></link> dialog opens, where you can define a custom format. </variable>"
msgstr "<variable id=\"datetimeformat\">ເມື່ອທ່ານຄລິກ \"ຮູບແບບເພີ່ມເຕີມ\", ກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/05020300.xhp\"><emph>ຮູບແບບຕົວເລກ</emph></link> ຈະເປີດຂຶ້ນ, ເຊິ່ງທ່ານສາມາດກຳນົດຮູບແບບເອງໄດ້. </variable>"

#. zYGSB
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3156079\n"
"help.text"
msgid "For type <emph>Heading</emph>, choose the format <menuitem>Heading number</menuitem> to display the heading number with the separator specified in <link href=\"text/swriter/01/06060000.xhp\"><menuitem>Tools - Heading Numbering</menuitem></link>."
msgstr "ສຳລັບປະເພດ <emph>ຫົວຂໍ້</emph>, ໃຫ້ເລືອກຮູບແບບ <menuitem>ເລກຫົວຂໍ້</menuitem> ເພື່ອສະແດງເລກຫົວຂໍ້ພ້ອມກັບຕົວຂັ້ນທີ່ລະບຸໄວ້ໃນ <link href=\"text/swriter/01/06060000.xhp\"><menuitem>ເຄື່ອງມື - ການໃສ່ເລກຫົວຂໍ້</menuitem></link>."

#. VBv3A
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154867\n"
"help.text"
msgid "Choose <menuitem>Heading number without separator</menuitem> to display the heading number alone without the separator."
msgstr "ເລືອກ <menuitem>ເລກຫົວຂໍ້ທີ່ບໍ່ມີຕົວຂັ້ນ</menuitem> ເພື່ອສະແດງແຕ່ເລກຫົວຂໍ້ໂດຍບໍ່ມີຕົວຂັ້ນ."

#. 2BXHk
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id741678670945615\n"
"help.text"
msgid "If the selected heading is not numbered, then the field is left blank."
msgstr "ຖ້າຫົວຂໍ້ທີ່ເລືອກບໍ່ໄດ້ໃສ່ເລກ, ຟິວນັ້ນຈະຖືກປ່ອຍວ່າງໄວ້."

#. xDYYF
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id0902200804313432\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Inserts the field as static content, that is, the field cannot be updated.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ແຊກຟິວເປັນເນື້ອໃນຄົງທີ່, ນັ້ນຄື ຟິວຈະບໍ່ສາມາດອັບເດດໄດ້.</ahelp>"

#. fUZ8r
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154470\n"
"help.text"
msgid "For the HTML export and import of date and time fields, <link href=\"text/swriter/01/04090007.xhp#date_and_time\">special $[officename] formats</link> are used."
msgstr "ສຳລັບການສົ່ງອອກ ແລະ ນຳເຂົ້າ HTML ຂອງຟິວວັນທີ ແລະ ເວລາ, ຈະມີການໃຊ້ <link href=\"text/swriter/01/04090007.xhp#date_and_time\">ຮູບແບບ $[officename] ພິເສດ</link>."

#. i2kyZ
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"hd_id3153026\n"
"help.text"
msgid "Up to level"
msgstr "ເຖິງລະດັບ"

#. xBCCe
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154580\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/level\">Use this option with type <menuitem>Heading</menuitem> to specify which heading to display. The displayed heading is the first one before the field, whose outline level is equal to or less than the specified value.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/level\">ໃຊ້ຕົວເລືອກນີ້ຮ່ວມກັບປະເພດ <menuitem>ຫົວຂໍ້</menuitem> ເພື່ອລະບຸວ່າຈະໃຫ້ສະແດງຫົວຂໍ້ໃດ. ຫົວຂໍ້ທີ່ຈະສະແດງແມ່ນຫົວຂໍ້ທຳອິດທີ່ຢູ່ກ່ອນຟິວ ເຊິ່ງມີລະດັບໂຄງຮ່າງເທົ່າກັບ ຫຼື ໜ້ອຍກວ່າຄ່າທີ່ລະບຸໄວ້.</ahelp>"

#. GtaP3
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"hd_id3150891\n"
"help.text"
msgid "Offset"
msgstr "ໄລຍະຫ່າງ"

#. THAiS
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3155312\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/value\">Enter the offset value that you want to apply to a page number field, for example \"+1\".</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/value\">ປ້ອນຄ່າໄລຍະຫ່າງທີ່ທ່ານຕ້ອງການໃຊ້ກັບຟິວເລກໜ້າ, ຕົວຢ່າງ: \"+1\".</ahelp>"

#. fFDEh
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3145188\n"
"help.text"
msgid "With an <emph>Offset</emph> value of 1, the field will display a number that is 1 more than the current page number, but only if a page with that number exists. On the last page of the document, this same field will be empty."
msgstr "ດ້ວຍຄ່າ <emph>ໄລຍະຫ່າງ</emph> ເປັນ 1, ຟິວຈະສະແດງຕົວເລກທີ່ຫຼາຍກວ່າເລກໜ້າປັດຈຸບັນຢູ່ 1, ແຕ່ຈະສະແດງກໍຕໍ່ເມື່ອມີໜ້າທີ່ມີເລກນັ້ນຢູ່ແທ້. ໃນໜ້າສຸດທ້າຍຂອງເອກະສານ, ຟິວນີ້ຈະວ່າງຢູ່."

#. UWoEn
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154948\n"
"help.text"
msgid "If you want to change the actual page number and not the displayed number, do not use the <emph>Offset</emph> value. To change page numbers, read the <link href=\"text/swriter/guide/pagenumbers.xhp\"><emph>Page Numbers</emph></link> guide."
msgstr "ຖ້າທ່ານຕ້ອງການປ່ຽນເລກໜ້າຕົວຈິງ ແລະ ບໍ່ແມ່ນແຕ່ຕົວເລກທີ່ສະແດງ, ຢ່າໃຊ້ຄ່າ <emph>ໄລຍະຫ່າງ</emph>. ເພື່ອປ່ຽນເລກໜ້າ, ໃຫ້ອ່ານຄູ່ມື <link href=\"text/swriter/guide/pagenumbers.xhp\"><emph>ເລກໜ້າ</emph></link>."

#. FzJ8M
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"hd_id3154598\n"
"help.text"
msgid "Offset in days/minutes"
msgstr "ໄລຍະຫ່າງເປັນ ມື້/ນາທີ"

#. xVNTE
#: 04090001.xhp
msgctxt ""
"04090001.xhp\n"
"par_id3154899\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/offset\">Enter the offset that you want to apply to a date or time field.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/offset\">ປ້ອນໄລຍະຫ່າງທີ່ທ່ານຕ້ອງການໃຊ້ກັບຟິວວັນທີ ຫຼື ເວລາ.</ahelp>"

#. 5EfAy
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"tit\n"
"help.text"
msgid "Cross-references"
msgstr "ການອ້າງອີງໄຂວ່"

#. tDZs7
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id3153641\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090002.xhp\">Cross-reference</link>"
msgstr "<link href=\"text/swriter/01/04090002.xhp\">ການອ້າງອີງໄຂວ່</link>"

#. 58E48
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3155142\n"
"help.text"
msgid "<variable id=\"reftext\"><ahelp hid=\".\">This is where you insert the references or referenced fields into the current document. References are referenced fields within the same document or within sub-documents of a master document.</ahelp></variable>"
msgstr "<variable id=\"reftext\"><ahelp hid=\".\">ນີ້ແມ່ນບ່ອນທີ່ທ່ານແຊກການອ້າງອີງ ຫຼື ຟິວທີ່ຖືກອ້າງອີງເຂົ້າໃນເອກະສານປັດຈຸບັນ. ການອ້າງອີງແມ່ນຟິວທີ່ຖືກອ້າງອີງພາຍໃນເອກະສານດຽວກັນ ຫຼື ພາຍໃນເອກະສານຍ່ອຍຂອງເອກະສານຫຼັກ.</ahelp></variable>"

#. 4BgfB
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3159197\n"
"help.text"
msgid "The advantage of entering a cross-reference as a field is that you do not have to adjust the references manually every time you change the document. Just update the fields with F9 and the references in the document are updated too."
msgstr "ຂໍ້ດີຂອງການປ້ອນການອ້າງອີງໄຂວ່ເປັນຟິວແມ່ນທ່ານບໍ່ຈຳເປັນຕ້ອງປັບການອ້າງອີງດ້ວຍຕົນເອງທຸກຄັ້ງທີ່ທ່ານປ່ຽນແປງເອກະສານ. ພຽງແຕ່ອັບເດດຟິວດ້ວຍ F9 ແລະ ການອ້າງອີງໃນເອກະສານກໍຈະຖືກອັບເດດນຳ."

#. SEjd7
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id4333628\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. vqmpq
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id4516129\n"
"help.text"
msgid "<ahelp hid=\".\">Lists the available field types. To add a field to your document, click a field type, click a field in the Selection list, and then click Insert.</ahelp> The following fields are available:"
msgstr "<ahelp hid=\".\">ສະແດງລາຍຊື່ປະເພດຟິວທີ່ມີຢູ່. ເພື່ອເພີ່ມຟິວໃສ່ເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກທີ່ປະເພດຟິວ, ຄລິກທີ່ຟິວໃນລາຍການເລືອກ, ແລ້ວຄລິກ ແຊກ.</ahelp> ຟິວຕໍ່ໄປນີ້ແມ່ນມີໃຫ້ໃຊ້:"

#. XXYfa
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3151380\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. wivF5
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3150700\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. AYQSS
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3155862\n"
"help.text"
msgid "Set Reference"
msgstr "ຕັ້ງຄ່າການອ້າງອີງ"

#. nD596
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3147422\n"
"help.text"
msgid "Set target for a referenced field. Under <emph>Name</emph>, enter a name for the reference. When inserting the reference, the name will then appear as an identification in the list box <emph>Selection</emph>."
msgstr "ຕັ້ງຄ່າເປົ້າໝາຍສຳລັບຟິວທີ່ຖືກອ້າງອີງ. ພາຍໃຕ້ <emph>ຊື່</emph>, ໃຫ້ປ້ອນຊື່ສຳລັບການອ້າງອີງ. ເມື່ອແຊກການອ້າງອີງ, ຊື່ນັ້ນຈະປະກົດເປັນຕົວລະບຸໃນກ່ອງລາຍການ <emph>ການເລືອກ</emph>."

#. fk6xU
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149556\n"
"help.text"
msgid "In an HTML document, reference fields entered this way will be ignored. For the target in HTML documents, you have to <link href=\"text/swriter/01/04040000.xhp\">insert a bookmark</link>."
msgstr "ໃນເອກະສານ HTML, ຟິວອ້າງອີງທີ່ປ້ອນດ້ວຍວິທີນີ້ຈະຖືກລະເລີຍ. ສຳລັບເປົ້າໝາຍໃນເອກະສານ HTML, ທ່ານຕ້ອງ <link href=\"text/swriter/01/04040000.xhp\">ແຊກບຸກມາກ</link>."

#. LDyBc
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3150548\n"
"help.text"
msgid "Insert Reference"
msgstr "ແຊກການອ້າງອີງ"

#. 2uYWW
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3147746\n"
"help.text"
msgid "Inserting a reference to another position in the document. The corresponding text position has to be defined with \"Set Reference\" first. Otherwise, inserting a reference by choosing a field name under <emph>Selection</emph> is not possible."
msgstr "ແຊກການອ້າງອີງໄປຍັງຕຳແໜ່ງອື່ນໃນເອກະສານ. ຕຳແໜ່ງຂໍ້ຄວາມທີ່ກ່ຽວຂ້ອງຕ້ອງໄດ້ຮັບການກຳນົດດ້ວຍ \"ຕັ້ງຄ່າການອ້າງອີງ\" ກ່ອນ. ບໍ່ດັ່ງນັ້ນ, ຈະບໍ່ສາມາດແຊກການອ້າງອີງໂດຍການເລືອກຊື່ຟິວພາຍໃຕ້ <emph>ການເລືອກ</emph> ໄດ້."

#. gGk3v
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3146344\n"
"help.text"
msgid "In master documents, you can also reference from one sub-document to another. Note that the reference name will not appear in the selection field and has to be entered \"by hand\"."
msgstr "ໃນເອກະສານຫຼັກ, ທ່ານຍັງສາມາດອ້າງອີງຈາກເອກະສານຍ່ອຍໜຶ່ງໄປຫາອີກອັນໜຶ່ງໄດ້. ໝາຍເຫດວ່າຊື່ອ້າງອີງຈະບໍ່ປະກົດໃນຟິວການເລືອກ ແລະ ຕ້ອງປ້ອນດ້ວຍຕົນເອງ."

#. iq5bz
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149847\n"
"help.text"
msgid "In an HTML document, reference fields entered this way will be ignored. For referenced fields in HTML documents, you have to <link href=\"text/shared/01/05020400.xhp\">insert a hyperlink</link>."
msgstr "ໃນເອກະສານ HTML, ຟິວອ້າງອີງທີ່ປ້ອນດ້ວຍວິທີນີ້ຈະຖືກລະເລີຍ. ສຳລັບຟິວທີ່ຖືກອ້າງອີງໃນເອກະສານ HTML, ທ່ານຕ້ອງ <link href=\"text/shared/01/05020400.xhp\">ແຊກໄຮເປີລິ້ງ</link>."

#. vnX7A
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id2408825\n"
"help.text"
msgid "Headings"
msgstr "ຫົວຂໍ້"

#. Rudew
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id9988402\n"
"help.text"
msgid "The Selection box shows a list of all headings in the order of their appearance in the document."
msgstr "ກ່ອງການເລືອກຈະສະແດງລາຍຊື່ຫົວຂໍ້ທັງໝົດຕາມລຳດັບທີ່ປະກົດໃນເອກະສານ."

#. dmDrR
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id6401257\n"
"help.text"
msgid "Numbered Paragraphs"
msgstr "ຫຍໍ້ໜ້າທີ່ມີເລກລຳດັບ"

#. CCYQm
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id5841242\n"
"help.text"
msgid "The Selection box shows a list of all ordered paragraphs in the order of their appearance in the document. The list includes:"
msgstr "ກ່ອງການເລືອກຈະສະແດງລາຍຊື່ຫຍໍ້ໜ້າທີ່ມີລຳດັບທັງໝົດຕາມລຳດັບທີ່ປະກົດໃນເອກະສານ. ລາຍການລວມມີ:"

#. 7AVYf
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id971618826026891\n"
"help.text"
msgid "paragraphs with a paragraph style assigned a numbering scheme in the Tools > Heading Numbering dialog"
msgstr "ຫຍໍ້ໜ້າທີ່ມີຮູບແບບຫຍໍ້ໜ້າທີ່ຖືກກຳນົດຮູບແບບການໃສ່ເລກໃນກ່ອງໂຕ້ຕອບ ເຄື່ອງມື > ການໃສ່ເລກຫົວຂໍ້"

#. aJ9QE
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id1001618826039875\n"
"help.text"
msgid "ordered list paragraphs, formatted with the Formatting toolbar or Bullets and Numbering dialog"
msgstr "ຫຍໍ້ໜ້າລາຍການທີ່ມີລຳດັບ, ຈັດຮູບແບບດ້ວຍແຖບເຄື່ອງມືການຈັດຮູບແບບ ຫຼື ກ່ອງໂຕ້ຕອບ ສັນຍະລັກຫົວຂໍ້ ແລະ ການໃສ່ເລກ"

#. EsEhC
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id761618826048138\n"
"help.text"
msgid "paragraphs formatted with a numbered list style"
msgstr "ຫຍໍ້ໜ້າທີ່ຈັດຮູບແບບດ້ວຍຮູບແບບລາຍການທີ່ມີເລກລຳດັບ"

#. X7UTU
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id941618826055035\n"
"help.text"
msgid "paragraphs formatted with a paragraph style with a numbered list style applied in the Outline & List tab."
msgstr "ຫຍໍ້ໜ້າທີ່ຈັດຮູບແບບດ້ວຍຮູບແບບຫຍໍ້ໜ້າທີ່ມີການໃຊ້ຮູບແບບລາຍການທີ່ມີເລກລຳດັບໃນແທັບ ໂຄງຮ່າງ ແລະ ລາຍການ (Outline & List)."

#. DXnQx
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id306711\n"
"help.text"
msgid "Bookmarks"
msgstr "ບຸກມາກ"

#. J5zLW
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3150907\n"
"help.text"
msgid "After inserting a bookmark in the document with <emph>Insert - Bookmark</emph>, the bookmarks entry on the <emph>References</emph> tab becomes usable. Bookmarks are used to mark certain text passages in a document. In a text document, you can use the bookmarks, for example, to jump from one passage in the document to another."
msgstr "ຫຼັງຈາກແຊກບຸກມາກໃນເອກະສານດ້ວຍ <emph>ແຊກ - ບຸກມາກ</emph>, ລາຍການບຸກມາກໃນແທັບ <emph>ການອ້າງອີງ</emph> ຈະສາມາດໃຊ້ໄດ້. ບຸກມາກຖືກໃຊ້ເພື່ອໝາຍຂໍ້ຄວາມບາງສ່ວນໃນເອກະສານ. ໃນເອກະສານຂໍ້ຄວາມ, ທ່ານສາມາດໃຊ້ບຸກມາກເພື່ອໂດດຈາກສ່ວນໜຶ່ງຂອງເອກະສານໄປຫາອີກສ່ວນໜຶ່ງໄດ້."

#. kEd5w
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3155080\n"
"help.text"
msgid "In an HTML document, these bookmarks become anchors <A name>, which determine the target of hyperlinks for example."
msgstr "ໃນເອກະສານ HTML, ບຸກມາກເຫຼົ່ານີ້ຈະກາຍເປັນຈຸດຍຶດ <A name>, ເຊິ່ງກຳນົດເປົ້າໝາຍຂອງໄຮເປີລິ້ງ."

#. AC68a
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id0818200811011072\n"
"help.text"
msgid "Footnotes"
msgstr "ເຊິງອັດ"

#. u6RCy
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id0818200811011049\n"
"help.text"
msgid "If your documents contains a footnote, you can select the Footnotes entry. A reference to a footnote returns the footnote number."
msgstr "ຖ້າເອກະສານຂອງທ່ານມີເຊິງອັດ, ທ່ານສາມາດເລືອກລາຍການ ເຊິງອັດ. ການອ້າງອີງເຖິງເຊິງອັດຈະສົ່ງຄືນເປັນເລກເຊິງອັດ."

#. 3iXKW
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id6794030\n"
"help.text"
msgid "(Inserted objects with captions)"
msgstr "(ວັດຖຸທີ່ແຊກໄວ້ພ້ອມຄຳບັນຍາຍ)"

#. XNfy8
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id7096774\n"
"help.text"
msgid "You can set references to objects that have captions applied. For example, insert a picture, right-click the picture, choose Caption. Now the object shows up as a numbered \"Illustration\" in the list."
msgstr "ທ່ານສາມາດຕັ້ງຄ່າການອ້າງອີງເຖິງວັດຖຸທີ່ມີຄຳບັນຍາຍໄດ້. ຕົວຢ່າງ: ແຊກຮູບພາບ, ຄລິກຂວາທີ່ຮູບ, ເລືອກ ຄຳບັນຍາຍ. ຕອນນີ້ວັດຖຸຈະປະກົດເປັນ \"ຮູບປະກອບ\" (Illustration) ທີ່ມີເລກລຳດັບໃນລາຍຊື່."

#. 3Uoa3
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3154772\n"
"help.text"
msgid "References are fields. To remove a reference, delete the field. If you set a longer text as a reference and you do not want to reenter it after deleting the reference, select the text and copy it to the clipboard. You can then reinsert it as \"unformatted text\" at the same position using the command <emph>Edit - Paste special</emph>. The text remains intact while the reference is deleted."
msgstr "ການອ້າງອີງແມ່ນຟິວ. ເພື່ອລຶບການອ້າງອີງ, ໃຫ້ລຶບຟິວນັ້ນ. ຖ້າທ່ານຕັ້ງຂໍ້ຄວາມທີ່ຍາວເປັນການອ້າງອີງ ແລະ ບໍ່ຕ້ອງການພິມໃໝ່ຫຼັງຈາກລຶບການອ້າງອີງແລ້ວ, ໃຫ້ເລືອກຂໍ້ຄວາມນັ້ນແລ້ວຄັດລອກໄວ້ໃນຄລິບບອດ. ຈາກນັ້ນທ່ານສາມາດແຊກມັນຄືນເປັນ \"ຂໍ້ຄວາມທີ່ບໍ່ໄດ້ຈັດຮູບແບບ\" ຢູ່ຕຳແໜ່ງເດີມໂດຍໃຊ້ຄຳສັ່ງ <emph>ແກ້ໄຂ - ວາງແບບພິເສດ</emph>. ຂໍ້ຄວາມຈະຍັງຄືເກົ່າໃນຂະນະທີ່ການອ້າງອີງຖືກລຶບອອກ."

#. ecCiS
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id5824152\n"
"help.text"
msgid "Selection"
msgstr "ການເລືອກ"

#. xpdHq
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id7374187\n"
"help.text"
msgid "<ahelp hid=\".\">Lists the available fields for the field type selected in the <emph>Type </emph>list. To insert a field, click the field, select a format in the \"Refer using\" list, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງລາຍຊື່ຟິວທີ່ມີຢູ່ສຳລັບປະເພດຟິວທີ່ເລືອກໃນລາຍການ <emph>ປະເພດ</emph>. ເພື່ອແຊກຟິວ, ໃຫ້ຄລິກທີ່ຟິວ, ເລືອກຮູບແບບໃນລາຍການ \"ອ້າງອີງໂດຍໃຊ້\", ແລ້ວຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. ABxYv
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id7729728\n"
"help.text"
msgid "To quickly insert a field from the list, hold down <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> and double-click the field."
msgstr "ເພື່ອແຊກຟິວຈາກລາຍການຢ່າງວ່ອງໄວ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> ຄ້າງໄວ້ແລ້ວດັບເບິ້ນຄລິກທີ່ຟິວນັ້ນ."

#. ESKFM
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id3154333\n"
"help.text"
msgid "Refer using"
msgstr "ອ້າງອີງໂດຍໃຊ້"

#. hvMHh
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3148786\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldrefpage/format\">Select the format that you want to use for the selected reference field.</ahelp> The following formats are available:"
msgstr "<ahelp hid=\"modules/swriter/ui/fldrefpage/format\">ເລືອກຮູບແບບທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບຟິວອ້າງອີງທີ່ເລືອກ.</ahelp> ຮູບແບບຕໍ່ໄປນີ້ແມ່ນມີໃຫ້ໃຊ້:"

#. suGEE
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id7576525\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. zLU3D
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id641193\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. 2CfpX
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3150039\n"
"help.text"
msgid "Page number (unstyled)"
msgstr "ເລກໜ້າ (ບໍ່ມີຮູບແບບ)"

#. 3G7sS
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3153134\n"
"help.text"
msgid "Inserts the number of the page containing the reference target."
msgstr "ແຊກເລກໜ້າຂອງໜ້າທີ່ມີເປົ້າໝາຍການອ້າງອີງຢູ່."

#. LMBWA
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3154635\n"
"help.text"
msgid "Chapter"
msgstr "ບົດ"

#. Ffc2y
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149646\n"
"help.text"
msgid "Inserts the heading number or list number of the reference target."
msgstr "ແຊກເລກຫົວຂໍ້ ຫຼື ເລກລາຍການຂອງເປົ້າໝາຍການອ້າງອີງ."

#. oZCtF
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3150681\n"
"help.text"
msgid "Referenced text"
msgstr "ຂໍ້ຄວາມທີ່ຖືກອ້າງອີງ"

#. rDXQJ
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3154040\n"
"help.text"
msgid "Inserts the complete reference target text. For footnotes the footnote number is inserted. For captions the complete caption (category, number and text) is inserted."
msgstr "ແຊກຂໍ້ຄວາມເປົ້າໝາຍການອ້າງອີງທີ່ສົມບູນ. ສຳລັບເຊິງອັດຈະແຊກເລກເຊິງອັດ. ສຳລັບຄຳບັນຍາຍຈະແຊກຄຳບັນຍາຍທີ່ສົມບູນ (ໝວດໝູ່, ເລກລຳດັບ ແລະ ຂໍ້ຄວາມ)."

#. eCVMk
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149972\n"
"help.text"
msgid "“Above”/“Below”"
msgstr "“ເທິງ”/“ລຸ່ມ”"

#. pyJB4
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149619\n"
"help.text"
msgid "Inserts \"above\" or \"below\", depending on the location of the reference target relative to the position of the reference field."
msgstr "ແຊກ \"ເທິງ\" ຫຼື \"ລຸ່ມ\", ຂຶ້ນກັບຕຳແໜ່ງຂອງເປົ້າໝາຍການອ້າງອີງເມື່ອທຽບກັບຕຳແໜ່ງຂອງຟິວອ້າງອີງ."

#. vEbaW
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3148705\n"
"help.text"
msgid "Page number (styled)"
msgstr "ເລກໜ້າ (ມີຮູບແບບ)"

#. NsCLY
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3148728\n"
"help.text"
msgid "Inserts the number of the page containing the reference target using the format specified in the page style."
msgstr "ແຊກເລກໜ້າຂອງໜ້າທີ່ມີເປົ້າໝາຍການອ້າງອີງຢູ່ ໂດຍໃຊ້ຮູບແບບທີ່ລະບຸໄວ້ໃນຮູບແບບໜ້າ."

#. NbaoY
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id5699942\n"
"help.text"
msgid "Number"
msgstr "ຕົວເລກ"

#. hdVeE
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id6420484\n"
"help.text"
msgid "Inserts the number of the heading or numbered paragraph, including superior levels depending on the context. See note below this table for more information."
msgstr "ແຊກເລກຫົວຂໍ້ ຫຼື ຫຍໍ້ໜ້າທີ່ມີເລກລຳດັບ, ລວມທັງລະດັບທີ່ສູງກວ່າຂຶ້ນກັບບໍລິບົດ. ເບິ່ງໝາຍເຫດລຸ່ມຕາຕະລາງນີ້ສຳລັບຂໍ້ມູນເພີ່ມເຕີມ."

#. 9cC54
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id6986602\n"
"help.text"
msgid "Number (no context)"
msgstr "ຕົວເລກ (ບໍ່ມີບໍລິບົດ)"

#. ACjjz
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id616779\n"
"help.text"
msgid "Inserts only the number of the heading or numbered paragraph."
msgstr "ແຊກສະເພາະເລກຫົວຂໍ້ ຫຼື ຫຍໍ້ໜ້າທີ່ມີເລກລຳດັບ."

#. aDKB4
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id791039\n"
"help.text"
msgid "Number (full context)"
msgstr "ຕົວເລກ (ບໍລິບົດເຕັມ)"

#. KLBbQ
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id1953489\n"
"help.text"
msgid "Inserts the number of the heading or numbered paragraph, including all superior levels."
msgstr "ແຊກເລກຫົວຂໍ້ ຫຼື ຫຍໍ້ໜ້າທີ່ມີເລກລຳດັບ, ລວມທັງລະດັບທີ່ສູງກວ່າທັງໝົດ."

#. 5tWih
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3155553\n"
"help.text"
msgid "Category and Number"
msgstr "ໝວດໝູ່ ແລະ ຕົວເລກ"

#. QS9Ck
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3155356\n"
"help.text"
msgid "Inserts the caption category and caption number (or number range variable name and value). Any text between the category and number (or variable name and value) is also inserted."
msgstr "ແຊກໝວດໝູ່ຄຳບັນຍາຍ ແລະ ເລກຄຳບັນຍາຍ (ຫຼື ຊື່ຕົວປ່ຽນຊ່ວງຕົວເລກ ແລະ ຄ່າ). ຂໍ້ຄວາມໃດໜຶ່ງລະຫວ່າງໝວດໝູ່ ແລະ ຕົວເລກ (ຫຼື ຊື່ຕົວປ່ຽນ ແລະ ຄ່າ) ກໍຈະຖືກແຊກເຂົ້າໄປນຳ."

#. GQ8kL
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id891681357258258\n"
"help.text"
msgid "<variable id=\"captionformat\">This option is available for all number range variables, including caption numbers.</variable>"
msgstr "<variable id=\"captionformat\">ຕົວເລືອກນີ້ໃຊ້ໄດ້ກັບທຸກຕົວປ່ຽນຊ່ວງຕົວເລກ, ລວມທັງເລກຄຳບັນຍາຍ.</variable>"

#. qWwbd
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3154224\n"
"help.text"
msgid "Caption Text"
msgstr "ຂໍ້ຄວາມຄຳບັນຍາຍ"

#. GHTgV
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3145105\n"
"help.text"
msgid "Inserts all text that follows the caption category and caption number until end of paragraph."
msgstr "ແຊກຂໍ້ຄວາມທັງໝົດທີ່ຢູ່ຖັດຈາກໝວດໝູ່ ແລະ ເລກຄຳບັນຍາຍ ຈົນກວ່າຈະສິ້ນສຸດຫຍໍ້ໜ້າ."

#. FNgvg
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3149587\n"
"help.text"
msgid "Number"
msgstr "ຕົວເລກ"

#. Cat6z
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3146883\n"
"help.text"
msgid "Inserts the caption number (or number range value)."
msgstr "ແຊກເລກຄຳບັນຍາຍ (ຫຼື ຄ່າຊ່ວງຕົວເລກ)."

#. LLSAE
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id5189062\n"
"help.text"
msgid "For “Chapter”, “Number”, “Number (no context)”, and “Number(full context)” formats, the number of sublevels shown for the selected format depends on the <menuitem>Show sublevels</menuitem> setting for the relevant outline levels in <menuitem>Tools - Heading Numbering</menuitem>."
msgstr "ສຳລັບຮູບແບບ “ບົດ”, “ຕົວເລກ”, “ຕົວເລກ (ບໍ່ມີບໍລິບົດ)”, ແລະ “ຕົວເລກ (ບໍລິບົດເຕັມ)”, ຈຳນວນລະດັບຍ່ອຍທີ່ສະແດງຈະຂຶ້ນກັບການຕັ້ງຄ່າ <menuitem>ສະແດງລະດັບຍ່ອຍ</menuitem> ສຳລັບລະດັບໂຄງຮ່າງທີ່ກ່ຽວຂ້ອງໃນ <menuitem>ເຄື່ອງມື - ການໃສ່ເລກຫົວຂໍ້</menuitem>."

#. gJEWQ
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id3156242\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. kDDEs
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3156259\n"
"help.text"
msgid "<variable id=\"FieldName\"><ahelp hid=\"modules/swriter/ui/fldrefpage/name\">Type the name of the user-defined field that you want to create.</ahelp></variable> To set a target, click \"Set Reference\" in the <emph>Type</emph> list, type a name in this box, and then click <emph>Insert</emph>. To reference the new target, click the target name in the <emph>Selection</emph> list."
msgstr "<variable id=\"FieldName\"><ahelp hid=\"modules/swriter/ui/fldrefpage/name\">ພິມຊື່ຂອງຟິວທີ່ຜູ້ໃຊ້ກຳນົດເອງທີ່ທ່ານຕ້ອງການສ້າງ.</ahelp></variable> ເພື່ອຕັ້ງຄ່າເປົ້າໝາຍ, ໃຫ້ຄລິກ \"ຕັ້ງຄ່າການອ້າງອີງ\" ໃນລາຍການ <emph>ປະເພດ</emph>, ພິມຊື່ໃນກ່ອງນີ້, ແລ້ວຄລິກ <emph>ແຊກ</emph>. ເພື່ອອ້າງອີງເຖິງເປົ້າໝາຍໃໝ່, ໃຫ້ຄລິກທີ່ຊື່ເປົ້າໝາຍໃນລາຍການ <emph>ການເລືອກ</emph>."

#. DRRLC
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3156032\n"
"help.text"
msgid "In a master document, targets that are in different sub-documents are not displayed in the<emph> Selection</emph> list. If you want to insert a reference to the target, you must type the path and the name in the <emph>Name </emph>box."
msgstr "ໃນເອກະສານຫຼັກ, ເປົ້າໝາຍທີ່ຢູ່ໃນເອກະສານຍ່ອຍທີ່ແຕກຕ່າງກັນຈະບໍ່ຖືກສະແດງໃນລາຍການ <emph>ການເລືອກ</emph>. ຖ້າທ່ານຕ້ອງການແຊກການອ້າງອີງເຖິງເປົ້າໝາຍນັ້ນ, ທ່ານຕ້ອງພິມເສັ້ນທາງ ແລະ ຊື່ລົງໃນກ່ອງ <emph>ຊື່ </emph>ດ້ວຍຕົນເອງ."

#. aAfem
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id0903200802250745\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the contents that you want to add to a user-defined fields.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນເນື້ອໃນທີ່ທ່ານຕ້ອງການເພີ່ມເຂົ້າໃນຟິວທີ່ຜູ້ໃຊ້ກຳນົດເອງ.</ahelp>"

#. JyGN8
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"hd_id3154922\n"
"help.text"
msgid "Value"
msgstr "ຄ່າ"

#. DCA8i
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3153049\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/offset\">Enter the contents that you want to add to a user-defined field.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/offset\">ປ້ອນເນື້ອໃນທີ່ທ່ານຕ້ອງການເພີ່ມເຂົ້າໃນຟິວທີ່ຜູ້ໃຊ້ກຳນົດເອງ.</ahelp>"

#. zRBwU
#: 04090002.xhp
msgctxt ""
"04090002.xhp\n"
"par_id3159216\n"
"help.text"
msgid "If you select text in the document, and then insert a reference, the selected text becomes the contents of the field that you insert."
msgstr "ຖ້າທ່ານເລືອກຂໍ້ຄວາມໃນເອກະສານ, ແລ້ວແຊກການອ້າງອີງ, ຂໍ້ຄວາມທີ່ຖືກເລືອກຈະກາຍເປັນເນື້ອໃນຂອງຟິວທີ່ທ່ານແຊກ."

#. YMeVu
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"tit\n"
"help.text"
msgid "Functions"
msgstr "ຟັງຊັນ"

#. ya2mx
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3149123\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090003.xhp\">Functions</link>"
msgstr "<link href=\"text/swriter/01/04090003.xhp\">ຟັງຊັນ</link>"

#. X6H7i
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3150343\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Sets additional function parameters for fields. The type of parameter depends on the field type that you select.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ກຳນົດພາກສ່ວນເສີມຂອງຟັງຊັນສຳລັບຟິວ. ປະເພດຂອງພາກສ່ວນເສີມແມ່ນຂຶ້ນກັບປະເພດຂອງຟິວທີ່ທ່ານເລືອກ.</ahelp>"

#. rqsNt
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3151242\n"
"help.text"
msgid "<ahelp hid=\".\">Depending on the field type that you select, you can assign conditions to certain functions. For example, you can define a field that executes a macro when you click the field in the document, or a condition that, when met, hides a field. You can also define placeholder fields that insert graphics, tables, frames and other objects into your document when needed.</ahelp>"
msgstr "<ahelp hid=\".\">ອີງຕາມປະເພດຟິວທີ່ທ່ານເລືອກ, ທ່ານສາມາດກຳນົດເງື່ອນໄຂໃຫ້ກັບຟັງຊັນໃດໜຶ່ງໄດ້. ຕົວຢ່າງ: ທ່ານສາມາດກຳນົດຟິວທີ່ເຮັດວຽກມາກໂຄເມື່ອທ່ານຄລິກໃສ່ຟິວໃນເອກະສານ, ຫຼື ເງື່ອນໄຂທີ່ເຮັດໃຫ້ຟິວຖືກເຊື່ອງໄວ້ເມື່ອເງື່ອນໄຂນັ້ນຖືກຕ້ອງ. ທ່ານຍັງສາມາດກຳນົດຟິວຕົວແທນບ່ອນວ່າງເພື່ອແຊກຮູບພາບ, ຕາຕະລາງ, ກອບ ແລະ ວັດຖຸອື່ນໆ ເຂົ້າໃນເອກະສານຂອງທ່ານເມື່ອຈຳເປັນ.</ahelp>"

#. vXJzx
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id0902200804352037\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the available field types. To add a field to your document, click a field type, click a field in the <emph>Select </emph>list, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງລາຍການປະເພດຟິວທີ່ມີໃຫ້. ເພື່ອເພີ່ມຟິວເຂົ້າໃນເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກໃສ່ປະເພດຟິວ, ແລ້ວຄລິກໃສ່ຟິວໃນລາຍການ <emph>ເລືອກ</emph>, ຈາກນັ້ນຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. SRfFS
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3150537\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. Ro3wx
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3155623\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. yQjB9
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3152999\n"
"help.text"
msgid "Conditional text"
msgstr "ຂໍ້ຄວາມແບບມີເງື່ອນໄຂ"

#. CfwF9
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3149881\n"
"help.text"
msgid "Inserts text if a certain <link href=\"text/swriter/01/04090200.xhp\">condition</link> is met. For example, enter \"sun eq 1\" in the <emph>Condition</emph> box, and then the text that you want to insert when the variable \"sun\" equals \"1\" in the <emph>Then </emph>box. If you want, you can also enter the text that you want to display when this condition is not met in the <emph>Else</emph> box. To define the variable \"sun\", click the <link href=\"text/swriter/01/04090005.xhp\"><emph>Variables</emph></link> tab, select \"Set variable\", type \"sun\" in the<emph> Name</emph> box, and its value in the<emph> Value</emph> box."
msgstr "ແຊກຂໍ້ຄວາມຖ້າຫາກກົງກັບ <link href=\"text/swriter/01/04090200.xhp\">ເງື່ອນໄຂ</link> ໃດໜຶ່ງ. ຕົວຢ່າງ: ປ້ອນ \"sun eq 1\" ໃນຫ້ອງ <emph>ເງື່ອນໄຂ</emph>, ແລ້ວປ້ອນຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການແຊກເມື່ອຕົວປ່ຽນ \"sun\" ເທົ່າກັບ \"1\" ໃນຫ້ອງ <emph>ຖ້າວ່າ</emph>. ຖ້າທ່ານຕ້ອງການ, ທ່ານຍັງສາມາດປ້ອນຂໍ້ຄວາມທີ່ຈະສະແດງເມື່ອບໍ່ກົງກັບເງື່ອນໄຂໃນຫ້ອງ <emph>ຖ້າບໍ່ດັ່ງນັ້ນ</emph>. ເພື່ອກຳນົດຕົວປ່ຽນ \"sun\", ໃຫ້ຄລິກທີ່ແທັບ <link href=\"text/swriter/01/04090005.xhp\"><emph>ຕົວປ່ຽນ</emph></link>, ເລືອກ \"ກຳນົດຕົວປ່ຽນ\", ພິມ \"sun\" ໃນຫ້ອງ <emph>ຊື່</emph>, ແລະ ຄ່າຂອງມັນໃນຫ້ອງ <emph>ຄ່າ</emph>."

#. UzeYZ
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3153719\n"
"help.text"
msgid "Input list"
msgstr "ລາຍການປ້ອນຂໍ້ມູນ"

#. U6HBq
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147564\n"
"help.text"
msgid "Inserts a text field that displays one item from a list. You can add, edit, and remove items, and change their order in the list. Click an <emph>Input list</emph> field in your document or press <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+F9</keycode> to display the <link href=\"text/swriter/01/04090003.xhp\"><emph>Choose Item</emph></link> dialog."
msgstr "ແຊກຟິວຂໍ້ຄວາມທີ່ຈະສະແດງລາຍການໜຶ່ງຈາກລາຍຊື່. ທ່ານສາມາດເພີ່ມ, ແກ້ໄຂ ແລະ ລຶບລາຍການອອກໄດ້, ລວມທັງປ່ຽນລຳດັບໃນລາຍການ. ຄລິກໃສ່ຟິວ <emph>ລາຍການປ້ອນຂໍ້ມູນ</emph> ໃນເອກະສານຂອງທ່ານ ຫຼື ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+F9</keycode> ເພື່ອສະແດງກ່ອງໂຕ້ຕອບ <link href=\"text/swriter/01/04090003.xhp\"><emph>ເລືອກລາຍການ</emph></link>."

#. Bsz3R
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3153146\n"
"help.text"
msgid "Input field"
msgstr "ຟິວປ້ອນຂໍ້ມູນ"

#. EygCr
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3149287\n"
"help.text"
msgid "Inserts a text field that you can open by <link href=\"text/swriter/01/04090100.xhp\">clicking</link> it in the document. You can then change the text that is displayed."
msgstr "ແຊກຟິວຂໍ້ຄວາມທີ່ທ່ານສາມາດເປີດໄດ້ໂດຍການ <link href=\"text/swriter/01/04090100.xhp\">ຄລິກ</link> ໃສ່ມັນໃນເອກະສານ. ຈາກນັ້ນທ່ານສາມາດປ່ຽນຂໍ້ຄວາມທີ່ຈະສະແດງໄດ້."

#. fKEyC
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3154691\n"
"help.text"
msgid "Execute macro"
msgstr "ເຮັດວຽກມາກໂຄ"

#. p5aNy
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147515\n"
"help.text"
msgid "Inserts a text field that runs a macro when you click the field in the document. To assign a macro to the field, click the <emph>Macro</emph> button."
msgstr "ແຊກຟິວຂໍ້ຄວາມທີ່ຈະສັ່ງໃຫ້ມາກໂຄເຮັດວຽກເມື່ອທ່ານຄລິກໃສ່ຟິວໃນເອກະສານ. ເພື່ອກຳນົດມາກໂຄໃຫ້ກັບຟິວ, ໃຫ້ຄລິກທີ່ປຸ່ມ <emph>ມາກໂຄ</emph>."

#. yqa9m
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3152946\n"
"help.text"
msgid "Placeholder"
msgstr "ຕົວແທນບ່ອນວ່າງ"

#. CXPtM
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3153527\n"
"help.text"
msgid "Inserts a placeholder field in the document, for example, for graphics. When you click a placeholder field in the document, you are prompted to insert the item that is missing."
msgstr "ແຊກຟິວຕົວແທນບ່ອນວ່າງໃນເອກະສານ, ຕົວຢ່າງ: ສຳລັບຮູບພາບ. ເມື່ອທ່ານຄລິກໃສ່ຟິວຕົວແທນໃນເອກະສານ, ລະບົບຈະຖາມໃຫ້ທ່ານແຊກລາຍການທີ່ຂາດຫາຍໄປ."

#. CyoSC
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3150973\n"
"help.text"
msgid "Hidden text"
msgstr "ຂໍ້ຄວາມທີ່ເຊື່ອງໄວ້"

#. wUxEE
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147524\n"
"help.text"
msgid "Inserts a text field that is hidden when the condition that you specify is met. To use this function, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01040200.xhp\"><menuitem>%PRODUCTNAME Writer - View</menuitem></link> and clear the <emph>Hidden text</emph> check box."
msgstr "ແຊກຟິວຂໍ້ຄວາມທີ່ຈະຖືກເຊື່ອງໄວ້ເມື່ອເງື່ອນໄຂທີ່ທ່ານກຳນົດນັ້ນຖືກຕ້ອງ. ເພື່ອໃຊ້ຟັງຊັນນີ້, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - </menuitem><link href=\"text/shared/optionen/01040200.xhp\"><menuitem>%PRODUCTNAME Writer - ການເບິ່ງ</menuitem></link> ແລະ ຍົກເລີກການເລືອກຊ່ອງ <emph>ຂໍ້ຄວາມທີ່ເຊື່ອງໄວ້</emph>."

#. BMoMs
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3154480\n"
"help.text"
msgid "Hidden Paragraph"
msgstr "ຫຍໍ້ໜ້າທີ່ເຊື່ອງໄວ້"

#. xyjWR
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3153677\n"
"help.text"
msgid "Hides a paragraph when the condition that you specify is met. To use this function, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01040200.xhp\"><menuitem>%PRODUCTNAME Writer - View</menuitem></link> and clear the <emph>Hidden paragraphs</emph> check box."
msgstr "ເຊື່ອງຫຍໍ້ໜ້າເມື່ອເງື່ອນໄຂທີ່ທ່ານກຳນົດນັ້ນຖືກຕ້ອງ. ເພື່ອໃຊ້ຟັງຊັນນີ້, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01040200.xhp\"><menuitem>%PRODUCTNAME Writer - ການເບິ່ງ</menuitem></link> ແລະ ຍົກເລີກການເລືອກຊ່ອງ <emph>ຫຍໍ້ໜ້າທີ່ເຊື່ອງໄວ້</emph>."

#. sT58o
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3154192\n"
"help.text"
msgid "Combine characters"
msgstr "ຮວມຕົວອັກສອນ"

#. ZvbFD
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3159199\n"
"help.text"
msgid "Combines up to 6 characters, so that they behave as a single character. This feature is only available when Asian fonts are supported."
msgstr "ຮວມຕົວອັກສອນໄດ້ສູງສຸດ 6 ຕົວ, ເພື່ອໃຫ້ພວກມັນສະແດງຜົນຄືກັບຕົວອັກສອນດຽວ. ຄຸນສົມບັດນີ້ມີໃຫ້ໃຊ້ສະເພາະເມື່ອມີການຮອງຮັບຟອນອາຊີ."

#. FT5JN
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3154631\n"
"help.text"
msgid "The following fields can only be inserted if the corresponding field type is selected in the <emph>Type </emph>list."
msgstr "ຟິວດັ່ງຕໍ່ໄປນີ້ສາມາດແຊກໄດ້ກໍຕໍ່ເມື່ອມີການເລືອກປະເພດຟິວທີ່ກ່ຽວຂ້ອງໃນລາຍການ <emph>ປະເພດ</emph>."

#. 3KLNk
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3145595\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. 2iDAk
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3151329\n"
"help.text"
msgid "For function fields, the format field is only used for fields of the type placeholder. Here, the format determines the object for which the placeholder stands."
msgstr "ສຳລັບຟິວຟັງຊັນ, ຟິວຮູບແບບຈະຖືກໃຊ້ສະເພາະກັບຟິວປະເພດຕົວແທນບ່ອນວ່າງເທົ່ານັ້ນ. ໃນທີ່ນີ້, ຮູບແບບຈະເປັນຕົວກຳນົດວ່າຕົວແທນນັ້ນໃຊ້ສຳລັບວັດຖຸໃດ."

#. dHRZG
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3149494\n"
"help.text"
msgid "Condition"
msgstr "ເງື່ອນໄຂ"

#. BJMdk
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3143281\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/condition\">For fields linked to a <link href=\"text/swriter/01/04090200.xhp\">condition</link>, enter the criteria here.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/condition\">ສຳລັບຟິວທີ່ເຊື່ອມໂຍງກັບ <link href=\"text/swriter/01/04090200.xhp\">ເງື່ອນໄຂ</link>, ໃຫ້ປ້ອນເກນການຕັດສິນຢູ່ທີ່ນີ້.</ahelp>"

#. BwPbJ
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3151248\n"
"help.text"
msgid "Then, Else"
msgstr "ຖ້າວ່າ, ຖ້າບໍ່ດັ່ງນັ້ນ"

#. zejxc
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3154830\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the text to display when the condition is met in the <emph>Then </emph>box, and the text to display when the condition is not met in the <emph>Else </emph>box.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຂໍ້ຄວາມທີ່ຈະສະແດງເມື່ອເງື່ອນໄຂຖືກຕ້ອງໃນຫ້ອງ <emph>ຖ້າວ່າ</emph>, ແລະ ປ້ອນຂໍ້ຄວາມທີ່ຈະສະແດງເມື່ອເງື່ອນໄຂບໍ່ຖືກຕ້ອງໃນຫ້ອງ <emph>ຖ້າບໍ່ດັ່ງນັ້ນ</emph>.</ahelp>"

#. vA4qz
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3146865\n"
"help.text"
msgid "You can also insert database fields in the <emph>Then </emph>and <emph>Else </emph>boxes using the format \"databasename.tablename.fieldname\"."
msgstr "ທ່ານຍັງສາມາດແຊກຟິວຖານຂໍ້ມູນໃນຫ້ອງ <emph>ຖ້າວ່າ</emph> ແລະ <emph>ຖ້າບໍ່ດັ່ງນັ້ນ</emph> ໂດຍໃຊ້ຮູບແບບ \"ຊື່ຖານຂໍ້ມູນ.ຊື່ຕາຕະລາງ.ຊື່ຟິວ\"."

#. 8VE4N
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147583\n"
"help.text"
msgid "If the table or the field name does not exist in a database, nothing is inserted."
msgstr "ຖ້າຊື່ຕາຕະລາງ ຫຼື ຊື່ຟິວ ບໍ່ມີຢູ່ໃນຖານຂໍ້ມູນ, ຈະບໍ່ມີການແຊກຫຍັງລົງໄປ."

#. yu9r8
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3152585\n"
"help.text"
msgid "If you include the quotes in \"databasename.tablename.fieldname\", the expression is inserted as text."
msgstr "ຖ້າທ່ານໃສ່ເຄື່ອງໝາຍຄຳເວົ້າຄອບ \"ຊື່ຖານຂໍ້ມູນ.ຊື່ຕາຕະລາງ.ຊື່ຟິວ\", ຂໍ້ຄວາມນັ້ນຈະຖືກແຊກເປັນໂຕໜັງສືທຳມະດາ."

#. Yt9YV
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3155136\n"
"help.text"
msgid "Reference"
msgstr "ການອ້າງອີງ"

#. NJ5MQ
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3155149\n"
"help.text"
msgid "Type the text that you want to display in the field. If you are inserting a placeholder field, type the text that you want to display as a help tip when you rest the mouse pointer over the field."
msgstr "ພິມຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ສະແດງໃນຟິວ. ຖ້າທ່ານກຳລັງແຊກຟິວຕົວແທນບ່ອນວ່າງ, ໃຫ້ພິມຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ສະແດງເປັນຄຳແນະນຳ (Help tip) ເມື່ອທ່ານເອົາເມົາສ໌ໄປວາງໄວ້ເທິງຟິວນັ້ນ."

#. SXZpH
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3147071\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. GamNK
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147084\n"
"help.text"
msgid "Select the macro that you want to run when the field is clicked."
msgstr "ເລືອກມາກໂຄທີ່ທ່ານຕ້ອງການໃຫ້ເຮັດວຽກເມື່ອມີການຄລິກໃສ່ຟິວ."

#. DVBiB
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3154384\n"
"help.text"
msgid "Macro name"
msgstr "ຊື່ມາກໂຄ"

#. 6fLTW
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3153351\n"
"help.text"
msgid "Displays the name of the selected macro."
msgstr "ສະແດງຊື່ຂອງມາກໂຄທີ່ຖືກເລືອກ."

#. D7DBC
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3156269\n"
"help.text"
msgid "Placeholder"
msgstr "ຕົວແທນບ່ອນວ່າງ"

#. G2o86
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3156282\n"
"help.text"
msgid "Type the text that you want to appear in the placeholder field."
msgstr "ພິມຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ປາກົດໃນຟິວຕົວແທນບ່ອນວ່າງ."

#. FCAcm
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3150587\n"
"help.text"
msgid "Hidden text"
msgstr "ຂໍ້ຄວາມທີ່ເຊື່ອງໄວ້"

#. rBVwv
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3149173\n"
"help.text"
msgid "Type the text that you want to hide if a condition is met."
msgstr "ພິມຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການເຊື່ອງຫາກກົງກັບເງື່ອນໄຂ."

#. Dy6nr
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3151028\n"
"help.text"
msgid "Characters"
msgstr "ຕົວອັກສອນ"

#. tovHs
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3145771\n"
"help.text"
msgid "Enter the characters that you want to combine. You can combine a maximum of 6 characters. This option is only available for the <emph>Combine characters</emph> field type."
msgstr "ປ້ອນຕົວອັກສອນທີ່ທ່ານຕ້ອງການຮວມເຂົ້າກັນ. ທ່ານສາມາດຮວມໄດ້ສູງສຸດ 6 ຕົວອັກສອນ. ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະກັບຟິວປະເພດ <emph>ຮວມຕົວອັກສອນ</emph> ເທົ່ານັ້ນ."

#. Ai2hU
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3156369\n"
"help.text"
msgid "Value"
msgstr "ຄ່າ"

#. Nr8gi
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3151370\n"
"help.text"
msgid "Enter a value for the selected field."
msgstr "ປ້ອນຄ່າສຳລັບຟິວທີ່ເລືອກ."

#. ND3xr
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3148877\n"
"help.text"
msgid "Macro"
msgstr "ມາກໂຄ"

#. KASPr
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3155912\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/macro\">Opens the <emph>Macro Selector</emph> dialog, where you can choose the macro that will run when you click the selected field in the document.</ahelp> This button is only available for the \"Execute macro\" function field."
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/macro\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ຕົວເລືອກມາກໂຄ</emph>, ເຊິ່ງທ່ານສາມາດເລືອກມາກໂຄທີ່ຈະເຮັດວຽກເມື່ອທ່ານຄລິກໃສ່ຟິວທີ່ເລືອກໃນເອກະສານ.</ahelp> ປຸ່ມນີ້ມີໃຫ້ໃຊ້ສະເພາະກັບຟິວຟັງຊັນ \"ເຮັດວຽກມາກໂຄ\" ເທົ່ານັ້ນ."

#. CB3DA
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3150111\n"
"help.text"
msgid "The following controls are displayed for <emph>Input list</emph> fields:"
msgstr "ສ່ວນຄວບຄຸມຕໍ່ໄປນີ້ຈະສະແດງສຳລັບຟິວ <emph>ລາຍການປ້ອນຂໍ້ມູນ</emph>:"

#. Hyp5X
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3155860\n"
"help.text"
msgid "Item"
msgstr "ລາຍການ"

#. Quiiv
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3150688\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/item\">Enter a new item.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/item\">ປ້ອນລາຍການໃໝ່.</ahelp>"

#. KUsBa
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3147413\n"
"help.text"
msgid "Add"
msgstr "ເພີ່ມ"

#. M3529
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147473\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/add\">Adds the <emph>Item</emph> to the list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/add\">ເພີ່ມ <emph>ລາຍການ</emph> ເຂົ້າໃນລາຍຊື່.</ahelp>"

#. ZkhHj
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3147496\n"
"help.text"
msgid "Items on list"
msgstr "ລາຍການໃນລາຍຊື່"

#. kkZWu
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3147618\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/listitems\">Lists the items. The topmost item is shown in the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/listitems\">ສະແດງລາຍການຕ່າງໆ. ລາຍການທີ່ຢູ່ເທິງສຸດຈະຖືກສະແດງໃນເອກະສານ.</ahelp>"

#. 8CKY4
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3145263\n"
"help.text"
msgid "Remove"
msgstr "ລຶບອອກ"

#. ntJZC
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3149558\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/remove\">Removes the selected item from the list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/remove\">ລຶບລາຍການທີ່ເລືອກອອກຈາກລາຍຊື່.</ahelp>"

#. LUZ9B
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3145126\n"
"help.text"
msgid "Move Up"
msgstr "ຍ້າຍຂຶ້ນ"

#. AyxCU
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3155970\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/up\">Moves the selected item up in the list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/up\">ຍ້າຍລາຍການທີ່ເລືອກຂຶ້ນໄປຂ້າງເທິງໃນລາຍຊື່.</ahelp>"

#. P4c6b
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"hd_id3150549\n"
"help.text"
msgid "Move Down"
msgstr "ຍ້າຍລົງ"

#. RVPyR
#: 04090003.xhp
msgctxt ""
"04090003.xhp\n"
"par_id3156221\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldfuncpage/down\">Moves the selected item down in the list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldfuncpage/down\">ຍ້າຍລາຍການທີ່ເລືອກລົງໄປຂ້າງລຸ່ມໃນລາຍຊື່.</ahelp>"

#. sKtnG
#: 04090003.xhp
msgctxt ""
