#. SykGh
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"hd_id3154479\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090004.xhp\">DocInformation</link>"
msgstr "<link href=\"text/swriter/01/04090004.xhp\">ຂໍ້ມູນເອກະສານ</link>"

#. tpcju
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3149692\n"
"help.text"
msgid "<ahelp hid=\".\">DocInformation fields contain information about the properties of a document, such as the date a document was created. To view the properties of a document, choose <menuitem>File - Properties</menuitem>.</ahelp>"
msgstr "<ahelp hid=\".\">ຟິວຂໍ້ມູນເອກະສານປະກອບດ້ວຍຂໍ້ມູນກ່ຽວກັບຄຸນສົມບັດຂອງເອກະສານ, ເຊັ່ນ: ວັນທີສ້າງເອກະສານ. ເພື່ອເບິ່ງຄຸນສົມບັດຂອງເອກະສານ, ໃຫ້ເລືອກ <menuitem>ໄຟລ໌ - ຄຸນສົມບັດ</menuitem>.</ahelp>"

#. 4iQpY
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3148982\n"
"help.text"
msgid "When you export and import an HTML document containing DocInformation fields, <link href=\"text/swriter/01/04090007.xhp#DocInformation\">special $[officename] formats</link> are used."
msgstr "ເມື່ອທ່ານສົ່ງອອກ ແລະ ນຳເຂົ້າເອກະສານ HTML ທີ່ມີຟິວຂໍ້ມູນເອກະສານ, ຈະມີການໃຊ້ <link href=\"text/swriter/01/04090007.xhp#DocInformation\">ຮູບແບບພິເສດຂອງ $[officename]</link>."

#. Y9tFf
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id0902200804290053\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the available field types. To add a field to your document, click a field type, click a field in the Select list, and then click Insert.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງລາຍການປະເພດຟິວທີ່ມີໃຫ້. ເພື່ອເພີ່ມຟິວເຂົ້າໃນເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກໃສ່ປະເພດຟິວ, ແລ້ວຄລິກໃສ່ຟິວໃນລາຍການ ເລືອກ, ຈາກນັ້ນຄລິກ ແຊກ.</ahelp>"

