msgstr "<ahelp hid=\"modules/swriter/ui/mailmerge/printer\">ພິມຈົດໝາຍແບບຟອມ.</ahelp>"

#. NyMNd
#: 01150000.xhp
msgctxt ""
"01150000.xhp\n"
"hd_id3145773\n"
"help.text"
