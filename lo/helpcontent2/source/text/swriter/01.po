#. mvJwN
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3149805\n"
"help.text"
msgid "<variable id=\"feldbefehltext\"><ahelp hid=\".uno:InsertField\">Inserts a field at the current cursor position.</ahelp> The dialog lists all available fields.</variable>"
msgstr "<variable id=\"feldbefehltext\"><ahelp hid=\".uno:InsertField\">ແຊກຟິວຢູ່ທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ.</ahelp> ກ່ອງໂຕ້ຕອບຈະສະແດງລາຍຊື່ຟິວທັງໝົດທີ່ມີຢູ່.</variable>"

#. cFGme
