msgctxt ""
"04120250.xhp\n"
"par_id3151180\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/createautomarkdialog/CreateAutomarkDialog\">Create or edit a list of words to include in an Alphabetical Index.</ahelp> A concordance file lists words that should be referenced in an alphabetical index, together with the page number(s) where they appear in the document."
msgstr "<ahelp hid=\"modules/swriter/ui/createautomarkdialog/CreateAutomarkDialog\">ສ້າງ ຫຼື ແກ້ໄຂລາຍຊື່ຄຳສັບທີ່ຈະລວມເຂົ້າໃນດັດຊະນີຕາມຕົວອັກສອນ.</ahelp> ໄຟລ໌ລາຍການຄຳສັບຈະລະບຸຄຳສັບທີ່ຄວນອ້າງອີງໃນດັດຊະນີຕາມຕົວອັກສອນ, ພ້ອມກັບເລກໜ້າທີ່ພວກມັນປະກົດຢູ່ໃນເອກະສານ."

#. rZWDJ
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id837427\n"
"help.text"
msgid "You can use the Find All button on the Find & Replace dialog to highlight all places where a word appears, then open the Insert Index Entry dialog to add that word and places to the alphabetical index. However, if you need the same set of alphabetical indexes in multiple documents, the concordance file allows you to enter every word just once, then use the list many times."
msgstr "ທ່ານສາມາດໃຊ້ປຸ່ມ ຄົ້ນຫາທັງໝົດ ໃນປ່ອງຢ້ຽມ ຄົ້ນຫາ ແລະ ແທນທີ່ ເພື່ອເນັ້ນທຸກບ່ອນທີ່ຄຳສັບປະກົດຂຶ້ນ, ແລ້ວເປີດປ່ອງຢ້ຽມ ແຊກລາຍການດັດຊະນີ ເພື່ອເພີ່ມຄຳສັບ ແລະ ບ່ອນນັ້ນເຂົ້າໃນດັດຊະນີຕາມຕົວອັກສອນ. ແນວໃດກໍຕາມ, ຖ້າທ່ານຕ້ອງການໃຊ້ຊຸດດັດຊະນີຕາມຕົວອັກສອນດຽວກັນໃນຫຼາຍເອກະສານ, ໄຟລ໌ລາຍການຄຳສັບຈະຊ່ວຍໃຫ້ທ່ານປ້ອນແຕ່ລະຄຳສັບພຽງແຕ່ຄັ້ງດຽວ, ແລ້ວສາມາດໃຊ້ລາຍຊື່ນັ້ນໄດ້ຫຼາຍຄັ້ງ."

#. FVXZ4
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id771599006446118\n"
"help.text"
msgid "The default filter for creating or opening concordance files is <literal>*.sdi</literal>. However, the file format of the concordance file is plain text."
msgstr "ຕົວຕອງເລີ່ມຕົ້ນສຳລັບການສ້າງ ຫຼື ເປີດໄຟລ໌ລາຍການຄຳສັບແມ່ນ <literal>*.sdi</literal>. ແນວໃດກໍຕາມ, ຮູບແບບໄຟລ໌ຂອງໄຟລ໌ລາຍການຄຳສັບແມ່ນຂໍ້ຄວາມທຳມະດາ (plain text)."

#. cFHDU
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"hd_id3154645\n"
"help.text"
msgid "To access the Edit Concordance File dialog:"
msgstr "ເພື່ອເຂົ້າຫາປ່ອງຢ້ຽມ ແກ້ໄຂໄຟລ໌ລາຍການຄຳສັບ:"

#. FyzzX
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3149292\n"
"help.text"
msgid "Choose <emph>Insert - Table of Contents and Index - Table of Contents, Index or Bibliography - Type</emph>."
msgstr "ເລືອກ <emph>ແຊກ - ສາລະບານ ແລະ ດັດຊະນີ - ສາລະບານ, ດັດຊະນີ ຫຼື ບັນນານຸກົມ - ປະເພດ</emph>."

#. YJSWn
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3145420\n"
"help.text"
msgid "In the <emph>Type </emph>box, select \"Alphabetical Index\"."
msgstr "ໃນກ່ອງ <emph>ປະເພດ </emph>, ໃຫ້ເລືອກ \"ດັດຊະນີຕາມຕົວອັກສອນ\"."

#. tNeAS
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3154107\n"
"help.text"
msgid "In the <emph>Options </emph>area, select the <emph>Concordance file</emph> check box."
msgstr "ໃນສ່ວນ <emph>ຕົວເລືອກ </emph>, ໃຫ້ເລືອກຊ່ອງ <emph>ໄຟລ໌ລາຍການຄຳສັບ</emph>."

#. Z4xDT
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3153668\n"
"help.text"
msgid "Click the <emph>File</emph> button, and then choose <emph>New</emph> or <emph>Edit</emph>."
msgstr "ຄລິກປຸ່ມ <emph>ໄຟລ໌</emph>, ແລ້ວເລືອກ <emph>ໃໝ່</emph> ຫຼື <emph>ແກ້ໄຂ</emph>."

#. g9voW
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3154470\n"
"help.text"
msgid "A concordance file contains the following fields:"
msgstr "ໄຟລ໌ລາຍການຄຳສັບປະກອບດ້ວຍຟິວດັ່ງນີ້:"

#. 9wETm
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id91599005949275\n"
"help.text"
msgid "Term"
msgstr "ຄຳສັບ"

#. zMi8V
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id461599005949276\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. e7Npc
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id291599005949278\n"
"help.text"
msgid "Search term"
msgstr "ຄຳຄົ້ນຫາ"

#. zFwbQ
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3152953\n"
"help.text"
msgid "\"Search term\" refers to the index entry that you want to mark in the document."
msgstr "\"ຄຳຄົ້ນຫາ\" ໝາຍເຖິງລາຍການດັດຊະນີທີ່ທ່ານຕ້ອງການໝາຍໄວ້ໃນເອກະສານ."

#. CEahq
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id811599006053151\n"
"help.text"
msgid "Alternative entry"
msgstr "ລາຍການທາງເລືອກ"

#. rxooN
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3155896\n"
"help.text"
msgid "\"Alternative entry\" refers to the index entry that you want to appear in the index."
msgstr "\"ລາຍການທາງເລືອກ\" ໝາຍເຖິງລາຍການດັດຊະນີທີ່ທ່ານຕ້ອງການໃຫ້ປະກົດຂຶ້ນໃນດັດຊະນີ."

#. q3DFC
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id661599006090921\n"
"help.text"
msgid "1st and 2nd Keys"
msgstr "ຄີທີ 1 ແລະ ທີ 2"

#. VRBtF
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3154194\n"
"help.text"
msgid "The 1st and 2nd Keys are parent index entries. The \"Search term\" or the \"Alternative entry\" appears as a subentry under the 1st and 2nd Keys."
msgstr "ຄີທີ 1 ແລະ ທີ 2 ແມ່ນລາຍການດັດຊະນີຫຼັກ. \"ຄຳຄົ້ນຫາ\" ຫຼື \"ລາຍການທາງເລືອກ\" ຈະປະກົດເປັນລາຍການຍ່ອຍພາຍໃຕ້ຄີທີ 1 ແລະ ທີ 2."

#. DuJqR
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id521599007507727\n"
"help.text"
msgid "Comment"
msgstr "ຄຳເຫັນ"

#. GCW2W
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id981599007507728\n"
"help.text"
msgid "Add a comment line above the entry. Commented lines start with #."
msgstr "ເພີ່ມແຖວຄຳເຫັນໄວ້ທາງເທິງຂອງລາຍການ. ແຖວທີ່ເປັນຄຳເຫັນຈະເລີ່ມຕົ້ນດ້ວຍ #."

#. MPT5J
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id441599006128506\n"
"help.text"
msgid "Match case"
msgstr "ຕົວພິມໃຫຍ່-ນ້ອຍໃຫ້ກົງກັນ"

#. PqJ9t
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3155184\n"
"help.text"
msgid "\"Match case\" means that uppercase and lowercase letters are considered."
msgstr "\"ຕົວພິມໃຫຍ່-ນ້ອຍໃຫ້ກົງກັນ\" ໝາຍຄວາມວ່າຈະມີການພິຈາລະນາຄວາມແຕກຕ່າງລະຫວ່າງຕົວພິມໃຫຍ່ ແລະ ຕົວພິມນ້ອຍ."

#. 9Zvp6
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id361599006161460\n"
"help.text"
msgid "Word only"
msgstr "ສະເພາະຄຳສັບ"

#. hFig3
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3143282\n"
"help.text"
msgid "\"Word only\" searches for the term as a single word."
msgstr "\"ສະເພາະຄຳສັບ\" ແມ່ນການຄົ້ນຫາຄຳສັບນັ້ນໃນຖານະເປັນຄຳສັບດ່ຽວ."

#. YmG7P
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3147220\n"
"help.text"
msgid "To enable the \"Match case\" or \"Word only\" options, click in the corresponding cell, and then select the check box."
msgstr "ເພື່ອເປີດໃຊ້ຕົວເລືອກ \"ຕົວພິມໃຫຍ່-ນ້ອຍໃຫ້ກົງກັນ\" ຫຼື \"ສະເພາະຄຳສັບ\", ໃຫ້ຄລິກໃນຫ້ອງທີ່ກົງກັນ, ແລ້ວເລືອກຊ່ອງໝາຍ."

#. xADn5
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"hd_id3153629\n"
"help.text"
msgid "To create a concordance file without the Edit Concordance File dialog:"
msgstr "ເພື່ອສ້າງໄຟລ໌ລາຍການຄຳສັບໂດຍບໍ່ໃຊ້ປ່ອງຢ້ຽມ ແກ້ໄຂໄຟລ໌ລາຍການຄຳສັບ:"

#. JyULM
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3153644\n"
"help.text"
msgid "Use the following format guidelines when you create a concordance file:"
msgstr "ໃຊ້ແນວທາງຮູບແບບຕໍ່ໄປນີ້ເມື່ອທ່ານສ້າງໄຟລ໌ລາຍການຄຳສັບ:"

#. jGqc5
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3152770\n"
"help.text"
msgid "Each entry in the concordance file is on a separate line."
msgstr "ແຕ່ລະລາຍການໃນໄຟລ໌ລາຍການຄຳສັບຈະຕ້ອງຢູ່ຄົນລະແຖວ."

#. wHVsM
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3155142\n"
"help.text"
msgid "Commented lines start with #."
msgstr "ແຖວທີ່ເປັນຄຳເຫັນຈະເລີ່ມຕົ້ນດ້ວຍ #."

#. XWACd
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3153354\n"
"help.text"
msgid "Use the following format for the entries:"
msgstr "ໃຊ້ຮູບແບບຕໍ່ໄປນີ້ສຳລັບລາຍການ:"

#. GoFzo
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3149172\n"
"help.text"
msgid "<literal>Search term;Alternative entry;1st key;2nd key;Match case;Word only</literal>"
msgstr "<literal>ຄຳຄົ້ນຫາ;ລາຍການທາງເລືອກ;ຄີທີ 1;ຄີທີ 2;ຕົວພິມໃຫຍ່-ນ້ອຍໃຫ້ກົງກັນ;ສະເພາະຄຳສັບ</literal>"

#. FWVnU
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3156270\n"
"help.text"
msgid "The entries \"Match case\" and \"Word only\" are interpreted as \"No\" or FALSE if they are empty or zero (0). All other contents are interpreted as \"Yes\" or TRUE."
msgstr "ລາຍການ \"ຕົວພິມໃຫຍ່-ນ້ອຍໃຫ້ກົງກັນ\" ແລະ \"ສະເພາະຄຳສັບ\" ຈະຖືກຕີຄວາມໝາຍວ່າ \"ບໍ່\" ຫຼື FALSE ຖ້າພວກມັນຫວ່າງເປົ່າ ຫຼື ເປັນສູນ (0). ສ່ວນເນື້ອໃນອື່ນໆທັງໝົດຈະຖືກຕີຄວາມໝາຍວ່າ \"ແມ່ນ\" ຫຼື TRUE."

#. 4EEHT
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"hd_id3145778\n"
"help.text"
msgid "Example"
msgstr "ຕົວຢ່າງ"

#. AFejJ
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3155907\n"
"help.text"
msgid "For example, to include the word \"Boston\" in your alphabetical index under the \"Cities\" entry, enter the following line in the concordance file:"
msgstr "ຕົວຢ່າງ, ເພື່ອລວມເອົາຄຳວ່າ \"ບອສຕັນ\" (Boston) ໃນດັດຊະນີຕາມຕົວອັກສອນຂອງທ່ານພາຍໃຕ້ລາຍການ \"ເມືອງ\" (Cities), ໃຫ້ປ້ອນແຖວຕໍ່ໄປນີ້ໃນໄຟລ໌ລາຍການຄຳສັບ:"

#. hqr4T
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3151370\n"
"help.text"
msgid "<literal>Boston;Boston;Cities;;0;0</literal>"
msgstr "<literal>ບອສຕັນ;ບອສຕັນ;ຕົວເມືອງ;;0;0</literal>"

#. NQkQN
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3151383\n"
"help.text"
msgid "This also finds \"Boston\" if it is written in lowercase letters."
msgstr "ນີ້ຍັງຈະຄົ້ນຫາຄຳວ່າ \"boston\" ເຖິງແມ່ນວ່າຈະຂຽນດ້ວຍຕົວພິມນ້ອຍກໍຕາມ."

#. 3Skot
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3155866\n"
"help.text"
msgid "To include the \"Beacon Hill\" district in Boston under the \"Cities\" entry, enter the following line:"
msgstr "ເພື່ອລວມເອົາເຂດ \"ບີຄອນຮິວ\" (Beacon Hill) ໃນບອສຕັນ ໄວ້ພາຍໃຕ້ລາຍການ \"ເມືອງ\" (Cities), ໃຫ້ປ້ອນແຖວຕໍ່ໄປນີ້:"

#. J8EX4
#: 04120250.xhp
msgctxt ""
"04120250.xhp\n"
"par_id3150116\n"
"help.text"
msgid "<literal>Beacon Hill;Boston;Cities;</literal>"
msgstr "<literal>ບີຄອນຮິລ;ບອສຕັນ;ເມືອງ;</literal>"

#. BTrFZ
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"tit\n"
"help.text"
msgid "Insert Citation Entry"
msgstr "ແຊກລາຍການອ້າງອີງ"

#. mCZNR
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3151187\n"
"help.text"
msgid "Insert Bibliography Entry"
msgstr "ແຊກລາຍການບັນນານຸກົມ"

#. ZcFkK
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3154642\n"
"help.text"
msgid "<variable id=\"literaturvz\"><ahelp hid=\".uno:InsertAuthoritiesEntry\">Inserts a bibliography reference.</ahelp></variable>"
msgstr "<variable id=\"literaturvz\"><ahelp hid=\".uno:InsertAuthoritiesEntry\">ແຊກການອ້າງອີງບັນນານຸກົມ.</ahelp></variable>"

#. yeADc
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3145416\n"
"help.text"
msgid "Bibliography Source"
msgstr "ແຫຼ່ງຂໍ້ມູນບັນນານຸກົມ"

#. DjUbU
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3157721\n"
"help.text"
msgid "Bibliography Database"
msgstr "ຖານຂໍ້ມູນບັນນານຸກົມ"

#. Azb9b
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3154096\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/frombibliography\">Inserts a reference from the bibliography database.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/frombibliography\">ແຊກການອ້າງອີງຈາກຖານຂໍ້ມູນບັນນານຸກົມ.</ahelp>"

#. k9wFw
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3149805\n"
"help.text"
msgid "Document Content"
msgstr "ເນື້ອໃນເອກະສານ"

#. EFHjE
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3153536\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/fromdocument\">Inserts a reference from the bibliography records that are stored in the current document.</ahelp> An entry that is stored in the document has priority over an entry that is stored in the bibliography database."
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/fromdocument\">ແຊກການອ້າງອີງຈາກບັນທຶກບັນນານຸກົມທີ່ຖືກເກັບໄວ້ໃນເອກະສານປັດຈຸບັນ.</ahelp> ລາຍການທີ່ເກັບໄວ້ໃນເອກະສານຈະມີລຳດັບຄວາມສຳຄັນສູງກວ່າລາຍການທີ່ເກັບໄວ້ໃນຖານຂໍ້ມູນບັນນານຸກົມ."

#. EqM3G
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3154200\n"
"help.text"
msgid "When you save a document that contains bibliography entries, the corresponding records are automatically saved in a hidden field in the document."
msgstr "ເມື່ອທ່ານບັນທຶກເອກະສານທີ່ມີລາຍການບັນນານຸກົມ, ບັນທຶກທີ່ກ່ຽວຂ້ອງຈະຖືກບັນທຶກໄວ້ໃນຟິວທີ່ເຊື່ອງໄວ້ໃນເອກະສານໂດຍອັດຕະໂນມັດ."

#. 9wZtT
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id261770756581700\n"
"help.text"
msgid "Citation"
msgstr "ການອ້າງອີງ"

#. dAjrs
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3143273\n"
"help.text"
msgid "Short name"
msgstr "ຊື່ຫຍໍ້"

#. ELSTQ
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3149490\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/entrylb\">Select the short name of the bibliography record that you want to insert.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/entrylb\">ເລືອກຊື່ຫຍໍ້ຂອງບັນທຶກບັນນານຸກົມທີ່ທ່ານຕ້ອງການແຊກ.</ahelp>"

#. tHGjs
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3151260\n"
"help.text"
msgid "Author, Title"
msgstr "ຜູ້ຂຽນ, ຫົວຂໍ້"

#. SPaPA
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3149824\n"
"help.text"
msgid "If available, the author and the full title of the selected short name are displayed in this area."
msgstr "ຖ້າມີຂໍ້ມູນ, ຜູ້ຂຽນ ແລະ ຫົວຂໍ້ເຕັມຂອງຊື່ຫຍໍ້ທີ່ເລືອກຈະຖືກສະແດງໃນສ່ວນນີ້."

#. NQuDP
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3149105\n"
"help.text"
msgid "Insert"
msgstr "ແຊກ"

#. peCYF
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3147100\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/insert\">Inserts the bibliographic reference into the document. If you created a new record, you must also insert it as an entry, otherwise the record is lost when you close the document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/insert\">ແຊກການອ້າງອີງບັນນານຸກົມເຂົ້າໃນເອກະສານ. ຖ້າທ່ານສ້າງບັນທຶກໃໝ່, ທ່ານຕ້ອງແຊກມັນເປັນລາຍການນຳ, ຖ້າບໍ່ດັ່ງນັ້ນ ບັນທຶກຈະຫາຍໄປເມື່ອທ່ານປິດເອກະສານ.</ahelp>"

#. 6KNyf
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3147216\n"
"help.text"
msgid "Close"
msgstr "ປິດ"

#. twQjc
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3149036\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/close\">Closes the dialog.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/close\">ປິດປ່ອງຢ້ຽມ.</ahelp>"

#. hEjoD
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3153634\n"
"help.text"
msgid "New"
msgstr "ໃໝ່"

#. uAbVs
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3147579\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/new\">Opens the <link href=\"text/swriter/01/04120229.xhp\">Define Bibliography Entry</link> dialog, where you can create a new bibliography record. This record is only stored in the document. To add a record to the bibliography database, choose <emph>Tools - Bibliography Database</emph>.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/new\">ເປີດປ່ອງຢ້ຽມ <link href=\"text/swriter/01/04120229.xhp\">ກຳນົດລາຍການບັນນານຸກົມ</link>, ເຊິ່ງທ່ານສາມາດສ້າງບັນທຶກບັນນານຸກົມໃໝ່ໄດ້. ບັນທຶກນີ້ຈະຖືກເກັບໄວ້ສະເພາະໃນເອກະສານເທົ່ານັ້ນ. ເພື່ອເພີ່ມບັນທຶກເຂົ້າໃນຖານຂໍ້ມູນບັນນານຸກົມ, ໃຫ້ເລືອກ <emph>ເຄື່ອງມື - ຖານຂໍ້ມູນບັນນານຸກົມ</emph>.</ahelp>"

#. uC9hu
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"hd_id3155142\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. nmpbn
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3157900\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/bibliographyentry/edit\">Opens the <link href=\"text/swriter/01/04120229.xhp\">Define Bibliography Entry</link> dialog where you can edit the selected bibliography record.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/bibliographyentry/edit\">ເປີດປ່ອງຢ້ຽມ <link href=\"text/swriter/01/04120229.xhp\">ກຳນົດລາຍການບັນນານຸກົມ</link> ເຊິ່ງທ່ານສາມາດແກ້ໄຂບັນທຶກບັນນານຸກົມທີ່ເລືອກໄດ້.</ahelp>"

#. KzfjB
#: 04120300.xhp
msgctxt ""
"04120300.xhp\n"
"par_id3149172\n"
"help.text"
msgid "<link href=\"text/swriter/guide/indices_literature.xhp\">Tips for working with bibliography entries</link>"
msgstr "<link href=\"text/swriter/guide/indices_literature.xhp\">ເຄັດລັບການເຮັດວຽກກັບລາຍການບັນນານຸກົມ</link>"

#. GPs88
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"tit\n"
"help.text"
msgid "Frame"
msgstr "ຂອບ"

#. CmuKq
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"hd_id3151189\n"
"help.text"
msgid "<link href=\"text/swriter/01/04130000.xhp\">Frame</link>"
msgstr "<link href=\"text/swriter/01/04130000.xhp\">ຂອບ</link>"

#. Bsp5M
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3145420\n"
"help.text"
msgid "<variable id=\"rahm\"><ahelp hid=\".uno:InsertFrame\">Inserts a frame that you can use to create a layout of one or more columns of text and objects.</ahelp></variable>"
msgstr "<variable id=\"rahm\"><ahelp hid=\".uno:InsertFrame\">ແຊກຂອບທີ່ທ່ານສາມາດໃຊ້ເພື່ອສ້າງການຈັດວາງຂໍ້ຄວາມ ແລະ ວັດຖຸແບບໜຶ່ງຖັນ ຫຼື ຫຼາຍຖັນ.</ahelp></variable>"

#. PKUNC
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"hd_id3149107\n"
"help.text"
msgid "Icon on the Insert toolbar:"
msgstr "ໄອຄອນໃນແຖບເຄື່ອງມືແຊກ:"

#. GrRhe
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3148970\n"
"help.text"
msgid "<variable id=\"syrahmentext\"><ahelp hid=\".uno:InsertFrameInteract\">Draws a frame where you drag in the document. Click the arrow next to the icon to select the number of columns for the frame.</ahelp></variable>"
msgstr "<variable id=\"syrahmentext\"><ahelp hid=\".uno:InsertFrameInteract\">ແຕ້ມຂອບໃນບ່ອນທີ່ທ່ານລາກເມົາສ໌ໃນເອກະສານ. ຄລິກທີ່ລູກສອນຂ້າງໄອຄອນເພື່ອເລືອກຈຳນວນຖັນສຳລັບຂອບ.</ahelp></variable>"

#. VcCe8
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3153678\n"
"help.text"
msgid "To edit a frame, click the border to select it, and then choose <emph>Format - Frame and Object - Properties</emph>. You can also resize or move a selected frame using special <link href=\"text/swriter/01/04130100.xhp\">shortcut keys</link>."
msgstr "ເພື່ອແກ້ໄຂຂອບ, ໃຫ້ຄລິກທີ່ເສັ້ນຂອບເພື່ອເລືອກມັນ, ແລ້ວເລືອກ <emph>ຮູບແບບ - ຂອບ ແລະ ວັດຖຸ - ຄຸນສົມບັດ</emph>. ທ່ານຍັງສາມາດປ່ຽນຂະໜາດ ຫຼື ຍ້າຍຂອບທີ່ເລືອກໄດ້ໂດຍໃຊ້ <link href=\"text/swriter/01/04130100.xhp\">ປຸ່ມລັດ</link> ພິເສດ."

#. vEHph
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3152952\n"
"help.text"
msgid "To delete a frame, click the border of the frame, and then press Delete."
msgstr "ເພື່ອລຶບຂອບ, ໃຫ້ຄລິກທີ່ເສັ້ນຂອບຂອງຂອບນັ້ນ, ແລ້ວກົດ Delete."

#. bUwz7
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3151311\n"
"help.text"
msgid "If you see small red arrows at the beginning and the end of text in frame, use the arrow keys to scroll through the remaining text."
msgstr "ຖ້າທ່ານເຫັນລູກສອນສີແດງນ້ອຍໆຢູ່ຕອນຕົ້ນ ແລະ ຕອນທ້າຍຂອງຂໍ້ຄວາມໃນຂອບ, ໃຫ້ໃຊ້ປຸ່ມລູກສອນເພື່ອເລື່ອນເບິ່ງຂໍ້ຄວາມທີ່ເຫຼືອ."

#. riDFE
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3155896\n"
"help.text"
msgid "In the preview area of the <emph>Frame</emph> dialog, the frame is represented by a green rectangle, and the reference area by a red rectangle."
msgstr "ໃນສ່ວນເບິ່ງຕົວຢ່າງຂອງປ່ອງຢ້ຽມ <emph>ຂອບ</emph>, ຂອບຈະຖືກສະແດງດ້ວຍຮູບສີ່ແຈສີຂຽວ, ແລະ ເຂດອ້າງອີງຈະສະແດງດ້ວຍຮູບສີ່ແຈສີແດງ."

#. 4MpvJ
#: 04130000.xhp
msgctxt ""
"04130000.xhp\n"
"par_id3149694\n"
"help.text"
msgid "You can also preview the effects when you change the frame anchor to \"As Character\". The \"Baseline\" is drawn in red, \"Character\" is the font height, and \"line\" is the height of the line, including the frame."
msgstr "ທ່ານຍັງສາມາດເບິ່ງຕົວຢ່າງຜົນກະທົບເມື່ອທ່ານປ່ຽນການຍຶດຂອບເປັນ \"ຄືກັບຕົວອັກສອນ\". \"ເສັ້ນພື້ນຖານ\" ຈະຖືກແຕ້ມເປັນສີແດງ, \"ຕົວອັກສອນ\" ຄືຄວາມສູງຂອງຟອນ, ແລະ \"ແຖວ\" ຄືຄວາມສູງຂອງແຖວລວມທັງຂອບນຳ."

#. D9kGV
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"tit\n"
"help.text"
msgid "Resizing and Moving Frames, Objects With the Keyboard"
msgstr "ການປ່ຽນຂະໜາດ ແລະ ການຍ້າຍຂອບ ຫຼື ວັດຖຸດ້ວຍແປ້ນພິມ"

#. oSqBh
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"bm_id3154506\n"
"help.text"
msgid "<bookmark_value>moving;objects and frames</bookmark_value><bookmark_value>objects;moving and resizing with keyboard</bookmark_value><bookmark_value>resizing;objects and frames, by keyboard</bookmark_value>"
msgstr "<bookmark_value>ການຍ້າຍ; ວັດຖຸ ແລະ ຂອບ</bookmark_value><bookmark_value>ວັດຖຸ; ການຍ້າຍ ແລະ ການປ່ຽນຂະໜາດດ້ວຍແປ້ນພິມ</bookmark_value><bookmark_value>ການປ່ຽນຂະໜາດ; ວັດຖຸ ແລະ ຂອບ ດ້ວຍແປ້ນພິມ</bookmark_value>"

#. zgGPo
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"hd_id3154506\n"
"help.text"
msgid "Resizing and Moving Frames, Objects With the Keyboard"
msgstr "ການປ່ຽນຂະໜາດ ແລະ ການຍ້າຍຂອບ ຫຼື ວັດຖຸດ້ວຍແປ້ນພິມ"

#. JrFJL
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"par_id3145248\n"
"help.text"
msgid "You can resize and move selected frames and objects with the keyboard."
msgstr "ທ່ານສາມາດປ່ຽນຂະໜາດ ແລະ ຍ້າຍຂອບ ຫຼື ວັດຖຸທີ່ເລືອກໄດ້ດ້ວຍແປ້ນພິມ."

#. n8Gvj
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"par_id3148771\n"
"help.text"
msgid "To move a selected frame or object, press an arrow key. To move by one pixel, hold down <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, and then press an arrow key."
msgstr "ເພື່ອຍ້າຍຂອບ ຫຼື ວັດຖຸທີ່ເລືອກ, ໃຫ້ກົດປຸ່ມລູກສອນ. ເພື່ອຍ້າຍເທື່ອລະໜຶ່ງພິກເຊວ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline> ຄ້າງໄວ້, ແລ້ວກົດປຸ່ມລູກສອນ."

#. Gnk49
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"par_id3150762\n"
"help.text"
msgid "To resize a selected frame or object, first press <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Tab</keycode>. Now one of the handles blinks to show that it is selected. To select another handle, press <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Tab</keycode> again. Press an arrow key to resize the object by one grid unit. To resize by one pixel, hold down <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, and then press an arrow key."
msgstr "ເພື່ອປ່ຽນຂະໜາດຂອບ ຫຼື ວັດຖຸທີ່ເລືອກ, ກ່ອນອື່ນໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Tab</keycode>. ຕອນນີ້ໜຶ່ງໃນຈຸດຈັບຈະກະພິບເພື່ອສະແດງວ່າມັນຖືກເລືອກຢູ່. ເພື່ອເລືອກຈຸດຈັບອື່ນ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Tab</keycode> ອີກຄັ້ງ. ກົດປຸ່ມລູກສອນເພື່ອປ່ຽນຂະໜາດວັດຖຸເທື່ອລະໜຶ່ງຫົວໜ່ວຍເສັ້ນຕາໜ່າງ. ເພື່ອປ່ຽນຂະໜາດເທື່ອລະໜຶ່ງພິກເຊວ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline> ຄ້າງໄວ້, ແລ້ວກົດປຸ່ມລູກສອນ."

#. xjkNq
#: 04130100.xhp
msgctxt ""
"04130100.xhp\n"
"par_id3149294\n"
"help.text"
msgid "The increment by which you move an object with the keyboard is determined by the document grid. To change the properties of the document grid, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01050100.xhp\"><emph>%PRODUCTNAME Writer - Grid</emph></link>."
msgstr "ໄລຍະການຍ້າຍວັດຖຸດ້ວຍແປ້ນພິມແມ່ນຖືກກຳນົດໂດຍເສັ້ນຕາໜ່າງເອກະສານ. ເພື່ອປ່ຽນຄຸນສົມບັດຂອງເສັ້ນຕາໜ່າງເອກະສານ, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ການຕັ້ງຄ່າ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01050100.xhp\"><emph>%PRODUCTNAME Writer - ເສັ້ນຕາໜ່າງ</emph></link>."

#. ZdisA
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"tit\n"
"help.text"
msgid "Insert Table"
msgstr "ແຊກຕາຕະລາງ"

#. KCxNG
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3147402\n"
"help.text"
msgid "<link href=\"text/swriter/01/04150000.xhp\">Insert Table</link>"
msgstr "<link href=\"text/swriter/01/04150000.xhp\">ແຊກຕາຕະລາງ</link>"

#. oj7hR
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3149355\n"
"help.text"
msgid "<variable id=\"tabelletext\"><ahelp hid=\".\">Inserts a table into the document. You can also click the arrow, drag to select the number of rows and columns to include in the table, and then click in the last cell.</ahelp></variable>"
msgstr "<variable id=\"tabelletext\"><ahelp hid=\".\">ແຊກຕາຕະລາງເຂົ້າໃນເອກະສານ. ທ່ານຍັງສາມາດຄລິກທີ່ລູກສອນ, ລາກເພື່ອເລືອກຈຳນວນແຖວ ແລະ ຖັນທີ່ຈະລວມເຂົ້າໃນຕາຕະລາງ, ແລ້ວຄລິກໃນຫ້ອງສຸດທ້າຍ.</ahelp></variable>"

#. m7tXV
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3153922\n"
"help.text"
msgid "To insert a table from another document, copy the table, and then paste the table into the current document."
msgstr "ເພື່ອແຊກຕາຕະລາງຈາກເອກະສານອື່ນ, ໃຫ້ກັອບປີ້ຕາຕະລາງນັ້ນ, ແລ້ວນຳມາວາງລົງໃນເອກະສານປັດຈຸບັນ."

#. CDsan
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3151181\n"
"help.text"
msgid "To convert text into a table, select the text, and then choose <emph>Table - Convert - Text to Table</emph>."
msgstr "ເພື່ອປ່ຽນຂໍ້ຄວາມເປັນຕາຕະລາງ, ໃຫ້ເລືອກຂໍ້ຄວາມ, ແລ້ວເລືອກ <emph>ຕາຕະລາງ - ປ່ຽນ - ຂໍ້ຄວາມເປັນຕາຕະລາງ</emph>."

#. ubUEG
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_idN10642\n"
"help.text"
msgid "To insert a table into a table, click in a cell in the table and choose <emph>Table - Insert Table</emph>."
msgstr "ເພື່ອແຊກຕາຕະລາງຊ້ອນໃນຕາຕະລາງ, ໃຫ້ຄລິກໃນຫ້ອງຕາຕະລາງ ແລ້ວເລືອກ <emph>ຕາຕະລາງ - ແຊກຕາຕະລາງ</emph>."

#. kESht
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3154638\n"
"help.text"
msgid "$[officename] can automatically format numbers that you enter in a table cell, for example, dates and times. To activate this feature, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Writer - Table</emph> and click the<emph> Number recognition </emph>check box in the <emph>Input in tables</emph> area."
msgstr "$[officename] ສາມາດຈັດຮູບແບບຕົວເລກທີ່ທ່ານປ້ອນໃນຫ້ອງຕາຕະລາງໄດ້ໂດຍອັດຕະໂນມັດ, ເຊັ່ນ ວັນທີ ແລະ ເວລາ. ເພື່ອເປີດໃຊ້ຄຸນສົມບັດນີ້, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ການຕັ້ງຄ່າ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Writer - ຕາຕະລາງ</emph> ແລ້ວຄລິກທີ່ຊ່ອງ <emph>ການຮັບຮູ້ຕົວເລກ </emph> ໃນສ່ວນ <emph>ການປ້ອນຂໍ້ມູນໃນຕາຕະລາງ</emph>."

#. ZUkKE
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3145419\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. 4sAqB
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3154099\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/nameedit\">Enter a name for the table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/nameedit\">ປ້ອນຊື່ສຳລັບຕາຕະລາງ.</ahelp>"

#. hntte
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3153672\n"
"help.text"
msgid "Columns"
msgstr "ຖັນ"

#. gPCJg
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3154576\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/colspin\">Enter the number of columns that you want in the table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/colspin\">ປ້ອນຈຳນວນຖັນທີ່ທ່ານຕ້ອງການໃນຕາຕະລາງ.</ahelp>"

#. SSKv4
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3152954\n"
"help.text"
msgid "Rows"
msgstr "ແຖວ"

#. yRV8J
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3154477\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/rowspin\">Enter the number of rows that you want in the table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/rowspin\">ປ້ອນຈຳນວນແຖວທີ່ທ່ານຕ້ອງການໃນຕາຕະລາງ.</ahelp>"

#. endB3
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3155903\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. L8xLS
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3149694\n"
"help.text"
msgid "Set the options for the table."
msgstr "ຕັ້ງຄ່າຕົວເລືອກສຳລັບຕາຕະລາງ."

#. kfT4e
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3154198\n"
"help.text"
msgid "Heading"
msgstr "ຫົວຂໍ້"

#. 7r8rq
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3155188\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/headercb\">Includes a heading row in the table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/headercb\">ລວມເອົາແຖວຫົວຂໍ້ເຂົ້າໃນຕາຕະລາງ.</ahelp>"

#. ydJxJ
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3143270\n"
"help.text"
msgid "Repeat heading rows on new pages"
msgstr "ເຮັດຊ້ຳແຖວຫົວຂໍ້ໃນໜ້າໃໝ່"

#. LFsuE
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3151252\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/repeatcb\">Repeats the heading of the table at the top of subsequent page if the table spans more than one page.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/repeatcb\">ເຮັດຊ້ຳຫົວຂໍ້ຂອງຕາຕະລາງຢູ່ສ່ວນເທິງຂອງໜ້າຖັດໄປ ຖ້າຕາຕະລາງຍາວເກີນໜຶ່ງໜ້າ.</ahelp>"

#. EE5iD
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_idN10754\n"
"help.text"
msgid "Heading rows"
msgstr "ແຖວຫົວຂໍ້"

#. C3bL5
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_idN10758\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/repeatheaderspin\">Select the number of rows that you want to use for the heading.</ahelp> The spinbox accepts values up to one less than the number of rows being inserted."
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/repeatheaderspin\">ເລືອກຈຳນວນແຖວທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບຫົວຂໍ້.</ahelp> ກ່ອງປັບຄ່າສາມາດຮັບຄ່າໄດ້ສູງສຸດໜ້ອຍກວ່າຈຳນວນແຖວທັງໝົດທີ່ແຊກໄວ້ໜຶ່ງແຖວ."

#. kw4EB
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3149821\n"
"help.text"
msgid "Don't split the table over pages"
msgstr "ບໍ່ໃຫ້ແຍກຕາຕະລາງຂ້າມໜ້າ"

#. LXrWD
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3149106\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inserttable/dontsplitcb\">Prevents the table from spanning more than one page.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inserttable/dontsplitcb\">ປ້ອງກັນບໍ່ໃຫ້ຕາຕະລາງແຍກອອກໄປຫຼາຍກວ່າໜຶ່ງໜ້າ.</ahelp>"

#. isAiK
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3147213\n"
"help.text"
msgid "List of table styles"
msgstr "ລາຍຊື່ຮູບແບບຕາຕະລາງ"

#. bXXB9
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3149036\n"
"help.text"
msgid "<ahelp hid=\".\">Select a predefined style for the new table.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຮູບແບບທີ່ກຳນົດໄວ້ລ່ວງໜ້າສຳລັບຕາຕະລາງໃໝ່.</ahelp>"

#. BqFkE
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"hd_id3147575\n"
"help.text"
msgid "Icon on the Insert toolbar"
msgstr "ໄອຄອນໃນແຖບເຄື່ອງມືແຊກ"

#. pcCBW
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3153511\n"
"help.text"
msgid "On the Insert toolbar, click the <emph>Table</emph> icon to open the <emph>Insert Table</emph> dialog, where you can insert a table in the current document. You can also click the arrow, drag to select the number of rows and columns to include in the table, and then click in the last cell."
msgstr "ໃນແຖບເຄື່ອງມືແຊກ, ໃຫ້ຄລິກໄອຄອນ <emph>ຕາຕະລາງ</emph> ເພື່ອເປີດປ່ອງຢ້ຽມ <emph>ແຊກຕາຕະລາງ</emph>, ເຊິ່ງທ່ານສາມາດແຊກຕາຕະລາງໃນເອກະສານປັດຈຸບັນ. ທ່ານຍັງສາມາດຄລິກທີ່ລູກສອນ, ລາກເພື່ອເລືອກຈຳນວນແຖວ ແລະ ຖັນທີ່ຈະລວມເຂົ້າໃນຕາຕະລາງ, ແລ້ວຄລິກໃນຫ້ອງສຸດທ້າຍ."

#. CLka9
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3155912\n"
"help.text"
msgid "<link href=\"text/swriter/01/05090300.xhp\">Table - Properties - Text Flow</link>"
msgstr "<link href=\"text/swriter/01/05090300.xhp\">ຕາຕະລາງ - ຄຸນສົມບັດ - ການໄຫຼຂອງຂໍ້ຄວາມ</link>"

#. xUCvt
#: 04150000.xhp
msgctxt ""
"04150000.xhp\n"
"par_id3150688\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - Preferences</caseinline><defaultinline>Tools - Options</defaultinline></switchinline> - <link href=\"text/shared/optionen/01040500.xhp\">%PRODUCTNAME Writer - Table</link>"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - ການຕັ້ງຄ່າ</caseinline><defaultinline>ເຄື່ອງມື - ຕົວເລືອກ</defaultinline></switchinline> - <link href=\"text/shared/optionen/01040500.xhp\">%PRODUCTNAME Writer - ຕາຕະລາງ</link>"

#. zB6Vh
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"tit\n"
"help.text"
msgid "Exchange Database"
msgstr "ແລກປ່ຽນຖານຂໍ້ມູນ"

#. Vu975
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"bm_id3145799\n"
"help.text"
msgid "<bookmark_value>databases; exchanging</bookmark_value>  <bookmark_value>address books; exchanging</bookmark_value>  <bookmark_value>exchanging databases</bookmark_value>  <bookmark_value>replacing;databases</bookmark_value>"
msgstr "<bookmark_value>ຖານຂໍ້ມູນ; ການແລກປ່ຽນ</bookmark_value>  <bookmark_value>ປຶ້ມທີ່ຢູ່; ການແລກປ່ຽນ</bookmark_value>  <bookmark_value>ການແລກປ່ຽນຖານຂໍ້ມູນ</bookmark_value>  <bookmark_value>ການປ່ຽນແທນ; ຖານຂໍ້ມູນ</bookmark_value>"

#. 4Y79x
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3145799\n"
"help.text"
msgid "<link href=\"text/swriter/01/04180400.xhp\">Exchange Database</link>"
msgstr "<link href=\"text/swriter/01/04180400.xhp\">ແລກປ່ຽນຖານຂໍ້ມູນ</link>"

#. Dn8Gu
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3156384\n"
"help.text"
msgid "<variable id=\"datenbankaustext\"><ahelp hid=\".uno:ChangeDatabaseField\">Change the data sources for the current document.</ahelp> To correctly display the contents of inserted fields, the replacement database must contain identical field names. </variable>"
msgstr "<variable id=\"datenbankaustext\"><ahelp hid=\".uno:ChangeDatabaseField\">ປ່ຽນແຫຼ່ງຂໍ້ມູນສຳລັບເອກະສານປັດຈຸບັນ.</ahelp> ເພື່ອໃຫ້ສະແດງເນື້ອໃນຂອງຟິວທີ່ແຊກໄວ້ໄດ້ຢ່າງຖືກຕ້ອງ, ຖານຂໍ້ມູນທີ່ຈະນຳມາປ່ຽນແທນຕ້ອງມີຊື່ຟິວທີ່ຄືກັນ. </variable>"

#. r7xGt
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3153818\n"
"help.text"
msgid "For example, if you inserting address fields in a form letter from an address database, you can then exchange the database with another address database to insert different addresses."
msgstr "ຕົວຢ່າງ, ຖ້າທ່ານແຊກຟິວທີ່ຢູ່ລົງໃນຈົດໝາຍວຽນຈາກຖານຂໍ້ມູນທີ່ຢູ່, ທ່ານສາມາດແລກປ່ຽນຖານຂໍ້ມູນນັ້ນກັບຖານຂໍ້ມູນທີ່ື່ອື່ນ ເພື່ອແຊກທີ່ຢູ່ທີ່ແຕກຕ່າງກັນໄດ້."

#. fW8tm
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3149130\n"
"help.text"
msgid "Exchange Databases"
msgstr "ແລກປ່ຽນຖານຂໍ້ມູນ"

#. yBq8D
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3154651\n"
"help.text"
msgid "You can only change one database at a time in this dialog."
msgstr "ທ່ານສາມາດປ່ຽນຖານຂໍ້ມູນໄດ້ເທື່ອລະອັນເທົ່ານັ້ນໃນປ່ອງຢ້ຽມນີ້."

#. sj7AA
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3146965\n"
"help.text"
msgid "Databases in Use"
msgstr "ຖານຂໍ້ມູນທີ່ກຳລັງໃຊ້"

#. xBFGo
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3149053\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/exchangedatabases/inuselb\">Lists the databases that are currently in use.</ahelp> The current document contains at least one data field from each of the databases in the list."
msgstr "<ahelp hid=\"modules/swriter/ui/exchangedatabases/inuselb\">ສະແດງລາຍຊື່ຖານຂໍ້ມູນທີ່ກຳລັງໃຊ້ຢູ່ໃນປັດຈຸບັນ.</ahelp> ເອກະສານປັດຈຸບັນມີຢ່າງໜ້ອຍໜຶ່ງຟິວຂໍ້ມູນຈາກແຕ່ລະຖານຂໍ້ມູນໃນລາຍຊື່ນີ້."

#. Bka2R
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3147300\n"
"help.text"
msgid "Available Databases"
msgstr "ຖານຂໍ້ມູນທີ່ມີຢູ່"

#. suHg5
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3150533\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/exchangedatabases/availablelb\">Lists the databases that are registered in <item type=\"productname\">%PRODUCTNAME</item>.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/exchangedatabases/availablelb\">ສະແດງລາຍຊື່ຖານຂໍ້ມູນທີ່ໄດ້ລົງທະບຽນໄວ້ໃນ <item type=\"productname\">%PRODUCTNAME</item>.</ahelp>"

#. DPRAw
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_idN106DB\n"
"help.text"
msgid "Browse"
msgstr "ເລືອກເບິ່ງ"

#. BTw79
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_idN106DF\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/exchangedatabases/browse\">Opens the Open dialog to select a database file (*.odb). The selected file is added to the Available Databases list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/exchangedatabases/browse\">ເປີດປ່ອງຢ້ຽມ ເປີດ ເພື່ອເລືອກໄຟລ໌ຖານຂໍ້ມູນ (*.odb). ໄຟລ໌ທີ່ເລືອກຈະຖືກເພີ່ມເຂົ້າໃນລາຍຊື່ ຖານຂໍ້ມູນທີ່ມີຢູ່.</ahelp>"

#. BBDeX
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3149349\n"
"help.text"
msgid "Define"
msgstr "ກຳນົດ"

#. UViah
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3145827\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/exchangedatabases/define\">Replaces the current data source with the data source that you selected in the <emph>Available Databases </emph>list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/exchangedatabases/define\">ປ່ຽນແຫຼ່ງຂໍ້ມູນປັດຈຸບັນດ້ວຍແຫຼ່ງຂໍ້ມູນທີ່ທ່ານເລືອກໃນລາຍຊື່ <emph>ຖານຂໍ້ມູນທີ່ມີຢູ່ </emph>.</ahelp>"

#. Lnfqa
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"hd_id3154506\n"
"help.text"
msgid "To exchange a database:"
msgstr "ເພື່ອແລກປ່ຽນຖານຂໍ້ມູນ:"

#. ojBfK
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3149881\n"
"help.text"
msgid "Ensure that both databases contain matching field names and field types."
msgstr "ກວດສອບໃຫ້ແນ່ໃຈວ່າຖານຂໍ້ມູນທັງສອງມີຊື່ຟິວ ແລະ ປະເພດຟິວທີ່ກົງກັນ."

#. mjEXo
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3148386\n"
"help.text"
msgid "Click in the document that you want to change the data source for."
msgstr "ຄລິກໃນເອກະສານທີ່ທ່ານຕ້ອງການປ່ຽນແຫຼ່ງຂໍ້ມູນ."

#. AcSAx
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3150564\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Edit - Exchange Database</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ແກ້ໄຂ - ແລກປ່ຽນຖານຂໍ້ມູນ</item>."

#. eBQEv
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3153925\n"
"help.text"
msgid "In the <emph>Databases in Use</emph> list, select the database table that you want to replace."
msgstr "ໃນລາຍຊື່ <emph>ຖານຂໍ້ມູນທີ່ກຳລັງໃຊ້</emph>, ໃຫ້ເລືອກຕາຕະລາງຖານຂໍ້ມູນທີ່ທ່ານຕ້ອງການປ່ຽນແທນ."

#. GTAEC
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3147169\n"
"help.text"
msgid "In the <emph>Available Databases</emph> list, select the replacement database table."
msgstr "ໃນລາຍຊື່ <emph>ຖານຂໍ້ມູນທີ່ມີຢູ່</emph>, ໃຫ້ເລືອກຕາຕະລາງຖານຂໍ້ມູນທີ່ຈະນຳມາປ່ຽນແທນ."

#. xHdin
#: 04180400.xhp
msgctxt ""
"04180400.xhp\n"
"par_id3151273\n"
"help.text"
msgid "Click <emph>Define</emph>."
msgstr "ຄລິກ <emph>ກຳນົດ</emph>."

#. sCkK8
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"tit\n"
"help.text"
msgid "Insert (Text from File)"
msgstr "ແຊກ (ຂໍ້ຄວາມຈາກໄຟລ໌)"

#. tAvDd
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"hd_id3147562\n"
"help.text"
msgid "Insert (Text from File)"
msgstr "ແຊກ (ຂໍ້ຄວາມຈາກໄຟລ໌)"

#. uZwPG
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"par_id3145411\n"
"help.text"
msgid "<variable id=\"datei\"><ahelp hid=\".\">Inserts the contents of another document into the current document at the cursor position.</ahelp> </variable>"
msgstr "<variable id=\"datei\"><ahelp hid=\".\">ແຊກເນື້ອໃນຂອງເອກະສານອື່ນລົງໃນເອກະສານປັດຈຸບັນຢູ່ຕຳແໜ່ງເຄີເຊີ.</ahelp> </variable>"

#. BguD6
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"par_idN105BD\n"
"help.text"
msgid "To always have the latest version of the contents of a file, insert a section into your document, and then insert a link to the text file in the section. See <link href=\"text/swriter/01/04020100.xhp\">insert a section</link> for details."
msgstr "ເພື່ອໃຫ້ໄດ້ເນື້ອໃນເວີຊັນຫຼ້າສຸດຂອງໄຟລ໌ຢູ່ສະເໝີ, ໃຫ້ແຊກ \"ສ່ວນ\" (section) ເຂົ້າໃນເອກະສານຂອງທ່ານ, ແລ້ວແຊກລິງໄປຫາໄຟລ໌ຂໍ້ຄວາມໃນສ່ວນນັ້ນ. ເບິ່ງ <link href=\"text/swriter/01/04020100.xhp\">ການແຊກສ່ວນ</link> ສຳລັບລາຍລະອຽດ."

#. HZdz8
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"hd_id71670928615261\n"
"help.text"
msgid "File name"
msgstr "ຊື່ໄຟລ໌"

#. aGS2S
#: 04190000.xhp
msgctxt ""
"04190000.xhp\n"
"hd_id31670928645389\n"
"help.text"
msgid "File type"
msgstr "ປະເພດໄຟລ໌"

#. NYm4u
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"tit\n"
"help.text"
msgid "Insert Script"
msgstr "ແຊກສະຄຣິບ"

#. CQMQF
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"hd_id3147402\n"
"help.text"
msgid "Insert Script"
msgstr "ແຊກສະຄຣິບ"

#. BA7jw
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3155620\n"
"help.text"
msgid "<variable id=\"scripttext\"><ahelp hid=\".uno:InsertScript\">Inserts a script at the current cursor position in an HTML or text document.</ahelp></variable>"
msgstr "<variable id=\"scripttext\"><ahelp hid=\".uno:InsertScript\">ແຊກສະຄຣິບຢູ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນໃນເອກະສານ HTML ຫຼື ເອກະສານຂໍ້ຄວາມ.</ahelp></variable>"

#. SAdJG
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3149880\n"
"help.text"
msgid "An inserted script is indicated by a small green rectangle. If you do not see the rectangle, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Writer/Web - </emph><link href=\"text/shared/optionen/01040200.xhp\"><emph>View</emph></link>, and select the <emph>Comments</emph> check box. To edit a script, double-click the green rectangle."
msgstr "ສະຄຣິບທີ່ແຊກໄວ້ຈະສະແດງດ້ວຍຮູບສີ່ແຈສີຂຽວນ້ອຍໆ. ຖ້າທ່ານບໍ່ເຫັນຮູບສີ່ແຈ, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ການຕັ້ງຄ່າ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Writer/Web - </emph><link href=\"text/shared/optionen/01040200.xhp\"><emph>ການເບິ່ງ</emph></link>, ແລ້ວເລືອກຊ່ອງ <emph>ຄຳເຫັນ</emph>. ເພື່ອແກ້ໄຂສະຄຣິບ, ໃຫ້ດັບເບິ້ລຄລິກທີ່ຮູບສີ່ແຈສີຂຽວ."

#. pB6kM
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3150572\n"
"help.text"
msgid "If your document contains more than one script, the <emph>Edit Script</emph> dialog contains previous and next buttons to jump from script to script."
msgstr "ຖ້າເອກະສານຂອງທ່ານມີຫຼາຍກວ່າໜຶ່ງສະຄຣິບ, ປ່ອງຢ້ຽມ <emph>ແກ້ໄຂສະຄຣິບ</emph> ຈະມີປຸ່ມ ກ່ອນໜ້າ ແລະ ຖັດໄປ ເພື່ອໂດດໄປຫາສະຄຣິບຕ່າງໆ."

#. T2xmF
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id0903200802541668\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Jump to Previous Script.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ໂດດໄປຫາສະຄຣິບກ່ອນໜ້າ.</ahelp>"

#. RsmdP
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id0903200802541770\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Jump to Next Script.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ໂດດໄປຫາສະຄຣິບຖັດໄປ.</ahelp>"

#. U4HTP
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"hd_id3154644\n"
"help.text"
msgid "Contents"
msgstr "ເນື້ອໃນ"

#. mc4wG
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"hd_id3149294\n"
"help.text"
msgid "Script Type"
msgstr "ປະເພດສະຄຣິບ"

#. fgDcy
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3145413\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertscript/scripttype\">Enter the type of script that you want to insert.</ahelp> The script is identified in the HTML source code by the tag <SCRIPT LANGUAGE=\"JavaScript\">."
msgstr "<ahelp hid=\"modules/swriter/ui/insertscript/scripttype\">ປ້ອນປະເພດຂອງສະຄຣິບທີ່ທ່ານຕ້ອງການແຊກ.</ahelp> ສະຄຣິບຈະຖືກລະບຸໃນຊອດໂຄ້ດ HTML ດ້ວຍແທັກ <SCRIPT LANGUAGE=\"JavaScript\">."

#. KCaYb
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"hd_id3154097\n"
"help.text"
msgid "URL"
msgstr "URL"

#. dKFBw
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3149810\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/insertscript/urlentry\">Adds a link to a script file. Click the <emph>URL </emph>radio button, and then enter the link in the box. You can also click the <emph>Browse</emph> button, locate the file, and then click <emph>Insert</emph>.</ahelp> The linked script file is identified in the HTML source code by the following tags:"
msgstr "<ahelp hid=\"modules/swriter/ui/insertscript/urlentry\">ເພີ່ມລິງໄປຫາໄຟລ໌ສະຄຣິບ. ຄລິກທີ່ປຸ່ມ <emph>URL </emph>, ແລ້ວປ້ອນລິງລົງໃນຊ່ອງ. ທ່ານຍັງສາມາດຄລິກປຸ່ມ <emph>ເລືອກເບິ່ງ</emph>, ຄົ້ນຫາໄຟລ໌, ແລ້ວຄລິກ <emph>ແຊກ</emph>.</ahelp> ໄຟລ໌ສະຄຣິບທີ່ເຊື່ອມໂຍງຈະຖືກລະບຸໃນຊອດໂຄ້ດ HTML ດ້ວຍແທັກດັ່ງນີ້:"

#. mnjEL
#: 04200000.xhp
msgctxt ""
"04200000.xhp\n"
"par_id3152963\n"
"help.text"
msgid "<SCRIPT LANGUAGE=\"JavaScript\" SRC=\"url\">"
msgstr "<SCRIPT LANGUAGE=\"JavaScript\" SRC=\"url\">"

