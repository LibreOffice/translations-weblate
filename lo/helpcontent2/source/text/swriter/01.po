msgctxt ""
"01150000.xhp\n"
"par_id3101901\n"
"help.text"
msgid "<ahelp hid=\".\">Create one big document containing all data records.</ahelp>"
msgstr "<ahelp hid=\".\">ສ້າງເອກະສານຂະໜາດໃຫຍ່ໜຶ່ງສະບັບທີ່ລວມເອົາຂໍ້ມູນທັງໝົດເຂົ້າໄວ້.</ahelp>"

#. bWfGH
#: 01150000.xhp
msgctxt ""
"01150000.xhp\n"
"hd_id3150110\n"
"help.text"
msgid "Save as individual documents"
msgstr "ບັນທຶກເປັນເອກະສານແຍກແຕ່ລະອັນ"

