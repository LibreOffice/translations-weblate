#: 01150000.xhp
msgctxt ""
"01150000.xhp\n"
"par_id3149034\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the number of the first record to be printed.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸລຳດັບຂອງຂໍ້ມູນທຳອິດທີ່ຈະພິມ.</ahelp>"

#. AQKFV
#: 01150000.xhp
msgctxt ""
"01150000.xhp\n"
"hd_id3153631\n"
"help.text"
msgid "To:"
msgstr "ເຖິງ:"

