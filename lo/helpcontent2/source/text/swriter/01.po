msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/swriter/01/mm_seladdblo.xhp\">ເລືອກບລັອກທີ່ຢູ່</link>.</ahelp>"

#. mSbut
