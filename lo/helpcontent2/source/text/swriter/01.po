msgctxt ""
"04020100.xhp\n"
"par_id3156274\n"
"help.text"
msgid "<ahelp hid=\".\">Locate the file that you want to insert as a link, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ຄົ້ນຫາໄຟລ໌ທີ່ທ່ານຕ້ອງການແຊກເປັນລິ້ງ, ແລ້ວຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. EGZDJ
