msgctxt ""
"05120400.xhp\n"
"par_id3151241\n"
"help.text"
msgid "<variable id=\"einfuegentext\">Inserts a row or column into the table. This command is only available when the cursor is in a table.    </variable>"
msgstr "<variable id=\"einfuegentext\">ແຊກແຖວ ຫຼື ຖັນເຂົ້າໃນຕາຕະລາງ. ຄຳສັ່ງນີ້ຈະໃຊ້ໄດ້ເມື່ອຕົວຊີ້ຢູ່ໃນຕາຕະລາງເທົ່ານັ້ນ. </variable>"

#. Bphk7
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3083447\n"
"help.text"
msgid "Insert"
msgstr "ແຊກ"

#. izqTU
