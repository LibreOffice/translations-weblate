"help.text"
msgid "Header or Footer Menu"
msgstr "ເມນູຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ"

#. ExdKF
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id231743083733654\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/HeaderFooterWin.xhp\">Header and Footer menu</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/HeaderFooterWin.xhp\">ເມນູຫົວເຈ້ຍ ແລະ ທ້າຍເຈ້ຍ</link></variable>"

#. 7PKjK
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id711743083733655\n"
"help.text"
msgid "Allows quick access of the header or footer properties and commands of a text document."
msgstr "ຊ່ວຍໃຫ້ເຂົ້າເຖິງຄຸນສົມບັດ ແລະ ຄຳສັ່ງຂອງຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ ຂອງເອກະສານຂໍ້ຄວາມໄດ້ຢ່າງວ່ອງໄວ."

#. nCXaF
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id581743096465779\n"
"help.text"
msgid "All commands are applied to the current page style."
msgstr "ຄຳສັ່ງທັງໝົດຈະຖືກນຳໃຊ້ກັບຮູບແບບໜ້າປັດຈຸບັນ."

#. DtvoW
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id571743084578879\n"
"help.text"
msgid "Enable the header or footer of the current page style, hover the mouse over the header or footer and choose a command from the dropdown menu."
msgstr "ເປີດໃຊ້ງານຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ ຂອງຮູບແບບໜ້າປັດຈຸບັນ, ເອົາເມົາສ໌ໄປຈໍ່ໄວ້ເທິງຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ ແລ້ວເລືອກຄຳສັ່ງຈາກເມນູແບບເລື່ອນລົງ."

#. sGoGL
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id811743085049024\n"
"help.text"
msgid "Format Header / Format Footer"
msgstr "ຈັດຮູບແບບຫົວເຈ້ຍ / ຈັດຮູບແບບທ້າຍເຈ້ຍ"

#. sg4Ws
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id801743085053779\n"
"help.text"
msgid "Opens the <link href=\"text/shared/01/05040300.xhp\">Page Style Header</link> (<link href=\"text/shared/01/05040400.xhp\">Page Style Footer</link>) page dialog for the current page style."
msgstr "ເປີດປ່ອງຢ້ຽມໂຕ້ຕອບ <link href=\"text/shared/01/05040300.xhp\">ຫົວເຈ້ຍຮູບແບບໜ້າ</link> (<link href=\"text/shared/01/05040400.xhp\">ທ້າຍເຈ້ຍຮູບແບບໜ້າ</link>) ສຳລັບຮູບແບບໜ້າປັດຈຸບັນ."

#. bEqDE
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id171743085352973\n"
"help.text"
msgid "Border and Background"
msgstr "ເສັ້ນຂອບ ແລະ ພື້ນຫຼັງ"

#. R2VfY
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id261743085513681\n"
"help.text"
msgid "Opens the header or footer Border / Background dialog to set border, area and transparency of the header or footer."
msgstr "ເປີດປ່ອງຢ້ຽມໂຕ້ຕອບ ເສັ້ນຂອບ / ພື້ນຫຼັງ ຂອງຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍ ເພື່ອຕັ້ງຄ່າເສັ້ນຂອບ, ພື້ນທີ່ ແລະ ຄວາມໂປ່ງໃສ."

#. pihUH
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id231743085219240\n"
"help.text"
msgid "Delete Header / Delete Footer"
msgstr "ລຶບຫົວເຈ້ຍ / ລຶບທ້າຍເຈ້ຍ"

#. 54ZHm
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id991743085214976\n"
"help.text"
msgid "Deletes the Header (Footer) of the current page style."
msgstr "ລຶບຫົວເຈ້ຍ (ທ້າຍເຈ້ຍ) ຂອງຮູບແບບໜ້າປັດຈຸບັນ."

#. ZZehB
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id201743085649557\n"
"help.text"
msgid "Insert Page Number"
msgstr "ແຊກເລກໜ້າ"

#. hpZGg
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id401743085704461\n"
"help.text"
msgid "Inserts the page number. The page number format is defined in the page style."
msgstr "ແຊກເລກໜ້າ. ຮູບແບບຂອງເລກໜ້າແມ່ນຖືກກຳນົດໄວ້ໃນຮູບແບບໜ້າ."

#. hBTin
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id531743085747963\n"
"help.text"
msgid "Insert Page Count"
msgstr "ແຊກຈຳນວນໜ້າທັງໝົດ"

#. EFcyS
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id201743085885898\n"
"help.text"
msgid "Inserts the page count of the current document."
msgstr "ແຊກຈຳນວນໜ້າທັງໝົດຂອງເອກະສານປັດຈຸບັນ."

#. xzACd
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"hd_id271743085855665\n"
"help.text"
msgid "Insert Page Count in Range"
msgstr "ແຊກຈຳນວນໜ້າໃນຊ່ວງ"

#. zbCER
#: HeaderFooterWin.xhp
msgctxt ""
"HeaderFooterWin.xhp\n"
"par_id311743085878601\n"
"help.text"
msgid "Inserts the page count in the page numbering range."
msgstr "ແຊກຈຳນວນໜ້າໃນຊ່ວງການໃສ່ລຳດັບເລກໜ້າ."

#. PDPrT
#: HeadingRowsRepeat.xhp
msgctxt ""
"HeadingRowsRepeat.xhp\n"
"tit\n"
"help.text"
msgid "Header Rows Repeat Across Pages"
msgstr "ເຮັດຊ້ຳແຖວຫົວຂໍ້ຂ້າມໜ້າ"

#. ELXQ9
#: HeadingRowsRepeat.xhp
msgctxt ""
"HeadingRowsRepeat.xhp\n"
"bm_id701694260835034\n"
"help.text"
msgid "<bookmark_value>tables; header repetition after page breaks</bookmark_value><bookmark_value>repeating; table headers after page breaks</bookmark_value><bookmark_value>headers; repeating in tables</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງ; ການເຮັດຊ້ຳຫົວຂໍ້ຫຼັງຈາກການຂຶ້ນໜ້າໃໝ່</bookmark_value><bookmark_value>ການເຮັດຊ້ຳ; ຫົວຂໍ້ຕາຕະລາງຫຼັງຈາກການຂຶ້ນໜ້າໃໝ່</bookmark_value><bookmark_value>ຫົວຂໍ້; ການເຮັດຊ້ຳໃນຕາຕະລາງ</bookmark_value>"

#. K3xAV
#: HeadingRowsRepeat.xhp
msgctxt ""
"HeadingRowsRepeat.xhp\n"
"hd_id161694258259129\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/HeadingRowsRepeat.xhp\">Header Rows Repeat Across Pages</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/HeadingRowsRepeat.xhp\">ເຮັດຊ້ຳແຖວຫົວຂໍ້ຂ້າມໜ້າ</link></variable>"

#. dguEc
#: HeadingRowsRepeat.xhp
msgctxt ""
"HeadingRowsRepeat.xhp\n"
"par_id451630938722616\n"
"help.text"
msgid "Repeat a table header on each new page that the table spans."
msgstr "ເຮັດຊ້ຳຫົວຂໍ້ຕາຕະລາງໃນແຕ່ລະໜ້າໃໝ່ທີ່ຕາຕະລາງນັ້ນກວມເອົາ."

#. CEDGU
#: HeadingRowsRepeat.xhp
msgctxt ""
"HeadingRowsRepeat.xhp\n"
"par_id571694256958083\n"
"help.text"
msgid "When this feature is on, a check mark is displayed in front of the <menuitem>Header Rows Repeat Across Pages</menuitem> command."
msgstr "ເມື່ອຄຸນສົມບັດນີ້ຖືກເປີດໃຊ້, ຈະມີເຄື່ອງໝາຍຖືກສະແດງຢູ່ຕໍ່ໜ້າຄຳສັ່ງ <menuitem>ເຮັດຊ້ຳແຖວຫົວຂໍ້ຂ້າມໜ້າ</menuitem>."

#. nAKZ7
#: RowSplit.xhp
msgctxt ""
"RowSplit.xhp\n"
"tit\n"
"help.text"
msgid "Row to Break Across Pages"
msgstr "ອະນຸຍາດໃຫ້ແຖວແຍກຂ້າມໜ້າ"

#. FMzbi
#: RowSplit.xhp
msgctxt ""
"RowSplit.xhp\n"
"bm_id451694263612943\n"
"help.text"
msgid "<bookmark_value>tables; allowing page breaks</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງ; ການອະນຸຍາດໃຫ້ຂຶ້ນໜ້າໃໝ່</bookmark_value>"

#. wMEbG
#: RowSplit.xhp
msgctxt ""
"RowSplit.xhp\n"
"hd_id491694262517019\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/RowSplit.xhp\">Row to Break Across Pages</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/RowSplit.xhp\">ອະນຸຍາດໃຫ້ແຖວແຍກຂ້າມໜ້າ</link></variable>"

#. KPHhY
#: RowSplit.xhp
msgctxt ""
"RowSplit.xhp\n"
"par_id841630938899606\n"
"help.text"
msgid "Allows a page break or column break inside a row of the table. This option is not applied to the first row in a table if the <emph>Repeat Heading</emph> option is selected."
msgstr "ອະນຸຍາດໃຫ້ມີການຂຶ້ນໜ້າໃໝ່ ຫຼື ຂຶ້ນຖັນໃໝ່ພາຍໃນແຖວຂອງຕາຕະລາງ. ຕົວເລືອກນີ້ຈະບໍ່ຖືກນຳໃຊ້ກັບແຖວທຳອິດໃນຕາຕະລາງ ຖ້າມີການເລືອກຕົວເລືອກ <emph>ເຮັດຊ້ຳຫົວຂໍ້</emph>."

#. TcWYY
#: RowSplit.xhp
msgctxt ""
"RowSplit.xhp\n"
"par_id571694256958083\n"
"help.text"
msgid "When this feature is on, a check mark is displayed in front of the <menuitem>Row to Break Across Pages</menuitem> command."
msgstr "ເມື່ອຄຸນສົມບັດນີ້ຖືກເປີດໃຊ້, ຈະມີເຄື່ອງໝາຍຖືກສະແດງຢູ່ຕໍ່ໜ້າຄຳສັ່ງ <menuitem>ອະນຸຍາດໃຫ້ແຖວແຍກຂ້າມໜ້າ</menuitem>."

#. GZoig
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"tit\n"
"help.text"
msgid "Spotlight Characters"
msgstr "ເນັ້ນຮູບແບບຕົວອັກສອນ"

#. RPAjL
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"bm_id71705516048353\n"
"help.text"
msgid "<bookmark_value>style spotlight;character styles</bookmark_value>"
msgstr "<bookmark_value>ການເນັ້ນຮູບແບບ;ຮູບແບບຕົວອັກສອນ</bookmark_value>"

#. MJkww
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"hd_id31705511866295\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/swriter/01/SpotlightCharStyles.xhp\">Spotlight Character Styles</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/swriter/01/SpotlightCharStyles.xhp\">ເນັ້ນຮູບແບບຕົວອັກສອນ</link></variable>"

#. 4LbDW
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id481705511866297\n"
"help.text"
msgid "Activates spotlighting of character styles."
msgstr "ເປີດໃຊ້ງານການເນັ້ນຮູບແບບຕົວອັກສອນ."

#. yiY4A
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id881705514569887\n"
"help.text"
msgid "Spotlighting character styles allows a better control of the application of character styles in the document."
msgstr "ການເນັ້ນຮູບແບບຕົວອັກສອນຊ່ວຍໃຫ້ຄວບຄຸມການນຳໃຊ້ຮູບແບບຕົວອັກສອນໃນເອກະສານໄດ້ດີຂຶ້ນ."

#. iYu9G
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id171705512039793\n"
"help.text"
msgid "Character style spotlight displays the styled characters with a background color and a call-out with a unique number for each applied character style in the document. The background color and call-out number are also displayed in the corresponding character entry in the <menuitem>Styles</menuitem> deck on the sidebar."
msgstr "ການເນັ້ນຮູບແບບຕົວອັກສອນຈະສະແດງຕົວອັກສອນທີ່ມີຮູບແບບດ້ວຍສີພື້ນຫຼັງ ແລະ ປ້າຍໝາຍເລກສະເພາະສຳລັບແຕ່ລະຮູບແບບຕົວອັກສອນທີ່ນຳໃຊ້ໃນເອກະສານ. ສີພື້ນຫຼັງ ແລະ ໝາຍເລກປ້າຍຍັງຈະຖືກສະແດງໃນລາຍການຕົວອັກສອນທີ່ກ່ຽວຂ້ອງໃນສ່ວນ <menuitem>ຮູບແບບ</menuitem> ຢູ່ແຖບຂ້າງ."

#. o7SqG
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id371705509091105\n"
"help.text"
msgid "Character styles are not given a color and call-out number until they are applied in the document."
msgstr "ຮູບແບບຕົວອັກສອນຈະບໍ່ໄດ້ຮັບສີ ແລະ ໝາຍເລກປ້າຍ ຈົນກວ່າພວກມັນຈະຖືກນຳໃຊ້ໃນເອກະສານ."

#. 2y7si
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id21705518127906\n"
"help.text"
msgid "When the extended tips features is enabled in <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools – Options</menuitem></defaultinline></switchinline><menuitem> – LibreOffice – General</menuitem>, a tooltip shows the style name and many attributes of the style applied."
msgstr "ເມື່ອເປີດໃຊ້ຄຸນສົມບັດຄຳແນະນຳເພີ່ມເຕີມໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ສິ່ງທີ່ມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື – ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> – LibreOffice – ທົ່ວໄປ</menuitem>, ຈະມີຂໍ້ຄວາມແນະນຳສະແດງຊື່ຮູບແບບ ແລະ ຄຸນລັກສະນະຕ່າງໆຂອງຮູບແບບທີ່ນຳໃຊ້."

#. FHGBF
#: SpotlightCharStyles.xhp
msgctxt ""
"SpotlightCharStyles.xhp\n"
"par_id811705512892082\n"
"help.text"
msgid "Character direct formatting attributes are <link href=\"text/shared/01/05020100.xhp\">Font</link>, <link href=\"text/shared/01/05020200.xhp\">Font Effects</link>, <link href=\"text/shared/01/05020500.xhp\">Position</link>, <link href=\"text/shared/01/05020600.xhp\">Asian Layout</link>, <link href=\"text/shared/01/05020400.xhp\">Hyperlink</link>, <link href=\"text/shared/01/05210100.xhp\">Highlighting</link> and <link href=\"text/shared/01/05030500.xhp\">Borders</link>."
msgstr "ຄຸນລັກສະນະການຈັດຮູບແບບຕົວອັກສອນໂດຍກົງປະກອບມີ <link href=\"text/shared/01/05020100.xhp\">ຟອນ</link>, <link href=\"text/shared/01/05020200.xhp\">ເອັບເຟັກຟອນ</link>, <link href=\"text/shared/01/05020500.xhp\">ຕຳແໜ່ງ</link>, <link href=\"text/shared/01/05020600.xhp\">ເຄົ້າໂຄງອາຊີ</link>, <link href=\"text/shared/01/05020400.xhp\">ໄຮເປີລິ້ງ</link>, <link href=\"text/shared/01/05210100.xhp\">ການເນັ້ນຂໍ້ຄວາມ</link> ແລະ <link href=\"text/shared/01/05030500.xhp\">ເສັ້ນຂອບ</link>."

