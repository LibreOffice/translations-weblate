msgctxt ""
"05040600.xhp\n"
"hd_id3145412\n"
"help.text"
msgid "Not larger than page area"
msgstr "ບໍ່ໃຫຍ່ກວ່າບໍລິເວນໜ້າ"

#. Edox7
#: 05040600.xhp
msgctxt ""
"05040600.xhp\n"
"par_id3147514\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/footnoteareapage/maxheightpage\">Automatically adjusts the height of the footnote area depending on the number of footnotes.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/footnoteareapage/maxheightpage\">ປັບປ່ຽນຄວາມສູງຂອງບໍລິເວນເຊິງອັດໂດຍອັດຕະໂນມັດ ໂດຍຂຶ້ນກັບຈຳນວນຂອງເຊິງອັດ.</ahelp>"

#. haeeT
