#. ZACmA
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id3149503\n"
"help.text"
msgid "<variable id=\"breitetext\"><ahelp hid=\".uno:SetColumnWidth\">Changes the width of the selected column(s).</ahelp></variable>"
msgstr "<variable id=\"breitetext\"><ahelp hid=\".uno:SetColumnWidth\">ປ່ຽນແປງຄວາມກວ້າງຂອງຖັນທີ່ເລືອກ.</ahelp></variable>"

#. FEtu6
#: 05120100.xhp
