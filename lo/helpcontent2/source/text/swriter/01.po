msgid "Combine"
msgstr "ລວມ"

#. ZmAGd
#: 05150104.xhp
msgctxt ""
"05150104.xhp\n"
"hd_id3154502\n"
"help.text"
msgid "Combine"
msgstr "ລວມ"

