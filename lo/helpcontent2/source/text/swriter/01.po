#: 01150000.xhp
msgctxt ""
"01150000.xhp\n"
"par_id3145758\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/mailmerge/to\">Specify the number of the last record to be printed.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/mailmerge/to\">ລະບຸລຳດັບຂອງຂໍ້ມູນສຸດທ້າຍທີ່ຈະພິມ.</ahelp>"

