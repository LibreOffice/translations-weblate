"par_id3150108\n"
"help.text"
msgid "Total editing time"
msgstr "ເວລາແກ້ໄຂທັງໝົດ"

#. fnmmz
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3155860\n"
"help.text"
