"help.text"
msgid "Displays the author and title information contained in the bibliography entry."
msgstr "ສະແດງຂໍ້ມູນຜູ້ຂຽນ ແລະ ຊື່ເລື່ອງທີ່ມີຢູ່ໃນລາຍການບັນນານຸກົມ."

#. wxiBi
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"hd_id3150214\n"
"help.text"
msgid "Apply"
msgstr "ນຳໃຊ້"

#. F9TwU
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"par_id3154766\n"
"help.text"
msgid "Applies the changes that you made, and then closes the <emph>Edit Bibliography Entry </emph>dialog."
msgstr "ນຳໃຊ້ການປ່ຽນແປງທີ່ທ່ານໄດ້ເຮັດ, ແລ້ວປິດໄດອະລັອກ <emph>ແກ້ໄຂລາຍການບັນນານຸກົມ </emph>."

#. gq7x2
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"hd_id3146968\n"
"help.text"
msgid "Close"
msgstr "ປິດ"

#. UWaCM
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"par_id3166468\n"
"help.text"
msgid "Closes the dialog."
msgstr "ປິດໄດອະລັອກ."

#. UXnkX
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"hd_id3147299\n"
"help.text"
msgid "New"
msgstr "ໃໝ່"

#. VvYca
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"par_id3151389\n"
"help.text"
msgid "Opens the <link href=\"text/swriter/01/04120229.xhp\">Define Bibliography Entry</link> dialog, where you can create a new entry."
msgstr "ເປີດໄດອະລັອກ <link href=\"text/swriter/01/04120229.xhp\">ກຳນົດລາຍການບັນນານຸກົມ</link>, ເຊິ່ງທ່ານສາມາດສ້າງລາຍການໃໝ່ໄດ້."

#. MDGAn
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"hd_id3150534\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. U6KLb
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"par_id3155620\n"
"help.text"
msgid "Opens the <link href=\"text/swriter/01/04120229.xhp\">Define Bibliography Entry</link> dialog, where you can edit the current entry."
msgstr "ເປີດໄດອະລັອກ <link href=\"text/swriter/01/04120229.xhp\">ກຳນົດລາຍການບັນນານຸກົມ</link>, ເຊິ່ງທ່ານສາມາດແກ້ໄຂລາຍການປັດຈຸບັນໄດ້."

#. yiBdr
#: 02130000.xhp
msgctxt ""
"02130000.xhp\n"
"par_id3154560\n"
"help.text"
msgid "<link href=\"text/swriter/guide/indices_literature.xhp\">Tips for working with bibliography entries</link>."
msgstr "<link href=\"text/swriter/guide/indices_literature.xhp\">ເຄັດລັບສຳລັບການເຮັດວຽກກັບລາຍການບັນນານຸກົມ</link>."

#. kERFw
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"tit\n"
"help.text"
msgid "Edit Fields"
msgstr "ແກ້ໄຂຟິວ"

#. neC2W
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3150493\n"
"help.text"
msgid "Edit Fields"
msgstr "ແກ້ໄຂຟິວ"

#. APCwH
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3151184\n"
"help.text"
msgid "<variable id=\"fields_text\"><variable id=\"feldbefehltext\"><ahelp hid=\".uno:FieldDialog\">Opens a dialog where you can edit the properties of a field. Click in front of a field, and then choose this command.</ahelp> In the dialog, you can use the arrow buttons to move to the previous or the next field. </variable></variable>"
msgstr "<variable id=\"fields_text\"><variable id=\"feldbefehltext\"><ahelp hid=\".uno:FieldDialog\">ເປີດໄດອະລັອກທີ່ທ່ານສາມາດແກ້ໄຂຄຸນສົມບັດຂອງຟິວ. ຄລິກທາງໜ້າຂອງຟິວ, ແລ້ວເລືອກຄຳສັ່ງນີ້.</ahelp> ໃນໄດອະລັອກ, ທ່ານສາມາດໃຊ້ປຸ່ມລູກສອນເພື່ອຍ້າຍໄປຫາຟິວກ່ອນໜ້າ ຫຼື ຖັດໄປ. </variable></variable>"

#. 25o6K
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3151168\n"
"help.text"
msgid "You can also double-click a field in your document to open the field for editing."
msgstr "ທ່ານຍັງສາມາດຄລິກສອງບາດໃສ່ຟິວໃນເອກະສານຂອງທ່ານເພື່ອເປີດຟິວນັ້ນເພື່ອແກ້ໄຂ."

#. 9U9ki
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3153668\n"
"help.text"
msgid "To change the view between field names and field contents in your document, choose <emph>View - Field Names</emph>."
msgstr "ເພື່ອປ່ຽນມຸມມອງລະຫວ່າງຊື່ຟິວ ແລະ ເນື້ອໃນຟິວໃນເອກະສານຂອງທ່ານ, ໃຫ້ເລືອກ <emph>ມຸມມອງ - ຊື່ຟິວ</emph>."

#. HpWj4
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3149106\n"
"help.text"
msgid "If you select a <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> link in your document, and then choose <item type=\"menuitem\">Edit - Fields</item>, the <link href=\"text/shared/01/02180000.xhp\"><emph>Edit Links</emph></link> dialog opens."
msgstr "ຖ້າທ່ານເລືອກລິ້ງ <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> ໃນເອກະສານຂອງທ່ານ, ແລ້ວເລືອກ <item type=\"menuitem\">ແກ້ໄຂ - ຟິວ</item>, ໄດອະລັອກ <link href=\"text/shared/01/02180000.xhp\"><emph>ແກ້ໄຂລິ້ງ</emph></link> ຈະເປີດຂຶ້ນ."

#. pJGco
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3149036\n"
"help.text"
msgid "If you click in front of a \"sender\" type field, and then choose <item type=\"menuitem\">Edit - Fields</item>, the <link href=\"text/shared/optionen/01010100.xhp\"><emph>User data</emph></link> dialog opens."
msgstr "ຖ້າທ່ານຄລິກທາງໜ້າຂອງຟິວປະເພດ \"ຜູ້ສົ່ງ\", ແລ້ວເລືອກ <item type=\"menuitem\">ແກ້ໄຂ - ຟິວ</item>, ໄດອະລັອກ <link href=\"text/shared/optionen/01010100.xhp\"><emph>ຂໍ້ມູນຜູ້ໃຊ້</emph></link> ຈະເປີດຂຶ້ນ."

#. Yikj8
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3145765\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. bvSw5
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3155142\n"
"help.text"
msgid "Lists the type of field that you are editing."
msgstr "ສະແດງປະເພດຂອງຟິວທີ່ທ່ານກຳລັງແກ້ໄຂ."

#. qPvDs
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3151371\n"
"help.text"
msgid "The following dialog elements are only visible when the corresponding field type is selected."
msgstr "ອົງປະກອບໄດອະລັອກຕໍ່ໄປນີ້ຈະປາກົດໃຫ້ເຫັນກໍຕໍ່ເມື່ອມີການເລືອກປະເພດຟິວທີ່ກ່ຽວຂ້ອງເທົ່ານັ້ນ."

#. YHXBC
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3150687\n"
"help.text"
msgid "Select"
msgstr "ເລືອກ"

#. G8yZS
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3150700\n"
"help.text"
msgid "Lists the field options, for example, \"fixed\". If you want, you can click another option for the selected field type."
msgstr "ສະແດງຕົວເລືອກຂອງຟິວ, ຕົວຢ່າງ: \"ຄົງທີ່\". ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດຄລິກເລືອກຕົວເລືອກອື່ນສຳລັບປະເພດຟິວທີ່ເລືອກໄດ້."

#. C4eTx
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3155854\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. 7gCVA
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3147409\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocumentpage/numformat\">Select the format for the contents of the field. For date, time, and user-defined fields, you can also click \"Additional formats\" in the list, and then choose a different format.</ahelp> The formats that are available depend on the type of field that you are editing."
msgstr "<ahelp hid=\"modules/swriter/ui/flddocumentpage/numformat\">ເລືອກຮູບແບບສຳລັບເນື້ອໃນຂອງຟິວ. ສຳລັບຟິວວັນທີ, ເວລາ, ແລະ ຟິວທີ່ຜູ້ໃຊ້ກຳນົດເອງ, ທ່ານຍັງສາມາດຄລິກ \"ຮູບແບບເພີ່ມເຕີມ\" ໃນລາຍຊື່, ແລ້ວເລືອກຮູບແບບອື່ນໄດ້.</ahelp> ຮູບແບບທີ່ມີໃຫ້ຈະຂຶ້ນກັບປະເພດຂອງຟິວທີ່ທ່ານກຳລັງແກ້ໄຂ."

#. QgFxo
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3149556\n"
"help.text"
msgid "Offset"
msgstr "ໄລຍະຫ່າງ (Offset)"

#. TX3VG
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3145256\n"
"help.text"
msgid "Displays the offset for the selected field type, for example, for \"Next Page,\" \"Page Numbers\" or \"Previous Page\". You can enter a new offset value which will be added to the displayed page number."
msgstr "ສະແດງໄລຍະຫ່າງ (offset) ສຳລັບປະເພດຟິວທີ່ເລືອກ, ຕົວຢ່າງ: ສຳລັບ \"ໜ້າຖັດໄປ,\" \"ເລກໜ້າ\" ຫຼື \"ໜ້າກ່ອນໜ້າ\". ທ່ານສາມາດປ້ອນຄ່າໄລຍະຫ່າງໃໝ່ເຊິ່ງຈະຖືກບວກເຂົ້າກັບເລກໜ້າທີ່ສະແດງ."

#. Etric
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id5081637\n"
"help.text"
msgid "If you want to change the actual page number and not the displayed number, do not use the <emph>Offset</emph> value. To change page numbers, read the <link href=\"text/swriter/guide/pagenumbers.xhp\"><emph>Page Numbers</emph></link> guide."
msgstr "ຖ້າທ່ານຕ້ອງການປ່ຽນເລກໜ້າທີ່ແທ້ຈິງ ແລະ ບໍ່ແມ່ນເລກທີ່ສະແດງ, ຢ່າໃຊ້ຄ່າ <emph>ໄລຍະຫ່າງ (Offset)</emph>. ເພື່ອປ່ຽນເລກໜ້າ, ໃຫ້ອ່ານຄຳແນະນຳ <link href=\"text/swriter/guide/pagenumbers.xhp\"><emph>ເລກໜ້າ</emph></link>."

#. WiTUi
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3145269\n"
"help.text"
msgid "Up to level"
msgstr "ເຖິງລະດັບ"

#. xgCJD
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3150559\n"
"help.text"
msgid "Selects the heading to display according to the specified format. The first heading before the field whose outline level is equal to or less than the specified outline level is selected. This option is available only for field types <menuitem>Heading</menuitem> (document) and <menuitem>Number range</menuitem> (variable)."
msgstr "ເລືອກຫົວຂໍ້ທີ່ຈະສະແດງຕາມຮູບແບບທີ່ລະບຸ. ຫົວຂໍ້ທຳອິດກ່ອນຟິວທີ່ມີລະດັບໂຄງຮ່າງເທົ່າກັບ ຫຼື ຕ່ຳກວ່າລະດັບໂຄງຮ່າງທີ່ລະບຸຈະຖືກເລືອກ. ຕົວເລືອກນີ້ໃຊ້ໄດ້ສະເພາະກັບປະເພດຟິວ <menuitem>ຫົວຂໍ້</menuitem> (ເອກະສານ) ແລະ <menuitem>ຊ່ວງຕົວເລກ</menuitem> (ຕົວແປ) ເທົ່ານັ້ນ."

#. ayo4c
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3147744\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. 4arvz
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3149834\n"
"help.text"
msgid "Displays the name of a field variable. If you want, you can enter a new name."
msgstr "ສະແດງຊື່ຂອງຕົວແປຟິວ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ້ອນຊື່ໃໝ່ໄດ້."

#. GCAGs
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3148844\n"
"help.text"
msgid "Value"
msgstr "ຄ່າ"

#. CbGAJ
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3148857\n"
"help.text"
msgid "Displays the current value of the field variable. If you want, you can enter a new value."
msgstr "ສະແດງຄ່າປັດຈຸບັນຂອງຕົວແປຟິວ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ້ອນຄ່າໃໝ່ໄດ້."

#. q4Q5B
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3153306\n"
"help.text"
msgid "Condition"
msgstr "ເງື່ອນໄຂ"

#. Aj68C
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3156124\n"
"help.text"
msgid "Displays the condition that must be met for the field to be activated. If you want, you can enter a new <link href=\"text/swriter/01/04090200.xhp\">condition</link>."
msgstr "ສະແດງເງື່ອນໄຂທີ່ຈະຕ້ອງເປັນໄປຕາມນັ້ນເພື່ອໃຫ້ຟິວເຮັດວຽກ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ້ອນ <link href=\"text/swriter/01/04090200.xhp\">ເງື່ອນໄຂ</link> ໃໝ່ໄດ້."

#. Tcj4R
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3156103\n"
"help.text"
msgid "Then, Else"
msgstr "ຖ້າເປັນຈິງ, ຖ້າເປັນເທັດ"

#. sB6KA
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3155073\n"
"help.text"
msgid "Change the field contents that are displayed depending on whether the field condition is met or not."
msgstr "ປ່ຽນເນື້ອໃນຟິວທີ່ຈະສະແດງ ໂດຍຂຶ້ນກັບວ່າເງື່ອນໄຂຂອງຟິວເປັນໄປຕາມທີ່ກຳນົດຫຼືບໍ່."

#. wBgvj
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"hd_id3154326\n"
"help.text"
msgid "Reference"
msgstr "ການອ້າງອີງ"

#. cjvWa
#: 02140000.xhp
msgctxt ""
"02140000.xhp\n"
"par_id3154339\n"
"help.text"
msgid "Insert or modify the reference text for the selected field."
msgstr "ແຊກ ຫຼື ປ່ຽນແປງຂໍ້ຄວາມອ້າງອີງສຳລັບຟິວທີ່ເລືອກ."

#. Ah7vE
