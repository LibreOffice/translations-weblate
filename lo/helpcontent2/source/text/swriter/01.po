#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN108DA\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/splitrow\">Allows a page break or column break inside a row of the table.</ahelp> This option is not applied to the first row in a table if the <emph>Repeat Heading</emph> option is selected."
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/splitrow\">ອະນຸຍາດໃຫ້ຂຶ້ນໜ້າໃໝ່ ຫຼື ຂຶ້ນຖັນໃໝ່ພາຍໃນແຖວຂອງຕາຕະລາງ.</ahelp> ຕົວເລືອກນີ້ຈະບໍ່ມີຜົນກັບແຖວທຳອິດຂອງຕາຕະລາງ ຖ້າຫາກເລືອກຕົວເລືອກ <emph>ເຮັດຫົວຂໍ້ຄືນໃໝ່</emph> ໄວ້."

#. WGCLb
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"hd_id3149034\n"
"help.text"
msgid "Keep with next paragraph"
msgstr "ໃຫ້ຢູ່ກັບວັກຕອນຖັດໄປ"

#. rxmcF
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_id3147577\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/keep\">Keeps the table and the following paragraph together when you insert the break.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/keep\">ໃຫ້ຕາຕະລາງ ແລະ ວັກຕອນຖັດໄປຢູ່ຮ່ວມກັນເມື່ອທ່ານແຊກການຂຶ້ນໜ້າໃໝ່.</ahelp>"

#. xUCFJ
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"hd_id3152772\n"
"help.text"
msgid "Repeat heading"
msgstr "ເຮັດຫົວຂໍ້ຄືນໃໝ່"

#. cToDE
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_id3153350\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/headline\">Repeats the table heading on a new page when the table spans more than one page.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/headline\">ເຮັດຫົວຂໍ້ຕາຕະລາງຄືນໃໝ່ໃນໜ້າໃໝ່ ເມື່ອຕາຕະລາງຍາວເກີນໜຶ່ງໜ້າ.</ahelp>"

#. 2XMyA
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN1091C\n"
"help.text"
msgid "The first ... rows"
msgstr "ແຖວທຳອິດ ... ແຖວ"

#. DecEp
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10920\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/repeatheadernf\">Enter the number of rows to include in the heading.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/repeatheadernf\">ປ້ອນຈຳນວນແຖວທີ່ຈະລວມເຂົ້າໃນສ່ວນຫົວຂໍ້.</ahelp>"

#. 5pLQE
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10940\n"
"help.text"
msgid "Text orientation"
msgstr "ທິດທາງຂອງຂໍ້ຄວາມ"

#. uwLDA
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10944\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/textorientation\">Select the orientation for the text in the cells.</ahelp> You can use the following formatting options to specify the orientation of text in table cells:"
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/textorientation\">ເລືອກທິດທາງສຳລັບຂໍ້ຄວາມໃນຫ້ອງຕາຕະລາງ.</ahelp> ທ່ານສາມາດໃຊ້ຕົວເລືອກການຈັດຮູບແບບຕໍ່ໄປນີ້ເພື່ອ ກຳນົດທິດທາງຂອງຂໍ້ຄວາມໃນຫ້ອງຕາຕະລາງ:"

#. 9Z2rm
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10964\n"
"help.text"
msgid "Horizontal"
msgstr "ແນວນອນ"

#. NMEVT
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10968\n"
"help.text"
msgid "Vertical (top to bottom)"
msgstr "ແນວຕັ້ງ (ເທິງລົງລຸ່ມ)"

#. rDCzA
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN1097T\n"
"help.text"
msgid "Use superordinate object settings. The superordinate objects are pages and frames containing the table. They define how the table is positioned and behaves within its parent layout."
msgstr "ໃຊ້ການຕັ້ງຄ່າວັດຖຸຂັ້ນສູງກວ່າ. ວັດຖຸຂັ້ນສູງກວ່າແມ່ນໜ້າ ແລະ ກອບທີ່ບັນຈຸຕາຕະລາງ. ພວກມັນກຳນົດວິທີການວາງຕຳແໜ່ງ ແລະ ພຶດຕິກຳຂອງຕາຕະລາງພາຍໃນເຄົ້າຮ່າງຕົ້ນສັງກັດ."

#. Tg9Ei
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_idN10969\n"
"help.text"
msgid "Vertical (bottom to top)"
msgstr "ແນວຕັ້ງ (ລຸ່ມຂຶ້ນເທິງ)"

#. GACgG
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"hd_id3151028\n"
"help.text"
msgid "Vertical alignment"
msgstr "ການຈັດວາງແນວຕັ້ງ"

#. NtjWj
#: 05090300.xhp
msgctxt ""
"05090300.xhp\n"
"par_id3149164\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/vertorient\">Specify the vertical text alignment for the cells in the table.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/tabletextflowpage/vertorient\">ກຳນົດການຈັດວາງຂໍ້ຄວາມໃນແນວຕັ້ງສຳລັບຫ້ອງຕາຕະລາງ.</ahelp>"

#. uajQ9
#: 05100000.xhp
msgctxt ""
"05100000.xhp\n"
"tit\n"
"help.text"
msgid "Cell"
msgstr "ຫ້ອງຕາຕະລາງ"

#. jTBKK
#: 05100000.xhp
msgctxt ""
"05100000.xhp\n"
"hd_id3150765\n"
"help.text"
msgid "<link href=\"text/swriter/01/05100000.xhp\">Cell</link>"
msgstr "<link href=\"text/swriter/01/05100000.xhp\">ຫ້ອງຕາຕະລາງ</link>"

#. w9Xny
#: 05100000.xhp
msgctxt ""
"05100000.xhp\n"
"par_id3147567\n"
"help.text"
msgid "This command is only available if you have selected a table in your document, or if the cursor is in a table cell."
msgstr "ຄຳສັ່ງນີ້ຈະໃຊ້ໄດ້ຖ້າຫາກທ່ານເລືອກຕາຕະລາງໃນເອກະສານຂອງທ່ານ, ຫຼື ຖ້າຕົວຊີ້ຢູ່ໃນຫ້ອງຕາຕະລາງ."

#. E68EJ
#: 05100400.xhp
msgctxt ""
"05100400.xhp\n"
"tit\n"
"help.text"
msgid "Unprotect"
msgstr "ຍົກເລີກການປ້ອງກັນ"

#. jBRsZ
#: 05100400.xhp
msgctxt ""
"05100400.xhp\n"
"hd_id3149052\n"
"help.text"
msgid "<link href=\"text/swriter/01/05100400.xhp\">Unprotect</link>"
msgstr "<link href=\"text/swriter/01/05100400.xhp\">ຍົກເລີກການປ້ອງກັນ</link>"

#. dyWFA
#: 05100400.xhp
msgctxt ""
"05100400.xhp\n"
"par_id3083450\n"
"help.text"
msgid "<ahelp hid=\".uno:UnsetCellsReadOnly\">Removes the cell protection for all selected cells in the current table.</ahelp>"
msgstr "<ahelp hid=\".uno:UnsetCellsReadOnly\">ເອົາການປ້ອງກັນຫ້ອງອອກສຳລັບຫ້ອງທີ່ເລືອກທັງໝົດໃນຕາຕະລາງປັດຈຸບັນ.</ahelp>"

#. EKmDK
#: 05100400.xhp
msgctxt ""
"05100400.xhp\n"
"par_id3154558\n"
"help.text"
msgid "To remove the protection from several tables at once, select the tables, and then press <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+T</keycode>. To remove the protection from all of the tables in a document, click anywhere in the document, and then press <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+T</keycode>."
msgstr "ເພື່ອເອົາການປ້ອງກັນອອກຈາກຕາຕະລາງຫຼາຍໆອັນພ້ອມກັນ, ໃຫ້ເລືອກຕາຕະລາງເຫຼົ່ານັ້ນ, ແລ້ວກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+T</keycode>. ເພື່ອເອົາການປ້ອງກັນອອກຈາກຕາຕະລາງທັງໝົດໃນເອກະສານ, ໃຫ້ຄລິກບ່ອນໃດກໍໄດ້ໃນເອກະສານ, ແລ້ວກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+Shift+T</keycode>."

#. NuGEd
#: 05100400.xhp
msgctxt ""
"05100400.xhp\n"
"par_id3150765\n"
"help.text"
msgid "You can also remove cell protection from a table in the <link href=\"text/swriter/01/02110000.xhp\">Navigator</link>."
msgstr "ທ່ານຍັງສາມາດເອົາການປ້ອງກັນຫ້ອງອອກຈາກຕາຕະລາງໄດ້ໃນ <link href=\"text/swriter/01/02110000.xhp\">ຕົວນຳທາງ (Navigator)</link>."

#. MtE2e
#: 05110100.xhp
msgctxt ""
"05110100.xhp\n"
"tit\n"
"help.text"
