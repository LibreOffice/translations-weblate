msgctxt ""
"05040600.xhp\n"
"par_id3154568\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/footnoteareapage/maxheightsb\">Enter the maximum height for the footnote area.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/footnoteareapage/maxheightsb\">ປ້ອນຄວາມສູງສູງສຸດສຳລັບບໍລິເວນເຊິງອັດ.</ahelp>"

#. Zyb37
