"help.text"
msgid "Columns"
msgstr "ຄໍລຳ"

#. sVopW
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3154508\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/colsnf\">Enter the number of columns that you want in the page, frame, or section.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/colsnf\">ປ້ອນຈຳນວນຄໍລຳທີ່ທ່ານຕ້ອງການໃນໜ້າ, ເຟຣມ, ຫຼື ເຊັກຊັນ.</ahelp>"

#. 3sBQN
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3150933\n"
"help.text"
msgid "Selection fields"
msgstr "ເຂດຂໍ້ມູນການເລືອກ"

#. XXCCD
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3149884\n"
"help.text"
msgid "You can also select one of the predefined column layouts."
msgstr "ທ່ານຍັງສາມາດເລືອກໜຶ່ງໃນການຈັດວາງຄໍລຳທີ່ກຳນົດໄວ້ລ່ວງໜ້າ."

#. aH2jv
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id971604735234085\n"
"help.text"
msgid "Tooltips describe each predefined selection."
msgstr "ຄຳແນະນຳເຄື່ອງມືຈະອະທິບາຍແຕ່ລະການເລືອກທີ່ກຳນົດໄວ້ລ່ວງໜ້າ."

#. 2Dr2B
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3151248\n"
"help.text"
msgid "Apply to"
msgstr "ນຳໃຊ້ກັບ"

#. AgHsC
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3154827\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/applytolb\">Select the item that you want to apply the column layout to.</ahelp> This option is only available if you access this dialog by choosing <emph>Format - Columns</emph>."
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/applytolb\">ເລືອກລາຍການທີ່ທ່ານຕ້ອງການນຳໃຊ້ການຈັດວາງຄໍລຳເຂົ້າຫາ.</ahelp> ຕົວເລືອກນີ້ຈະມີໃຫ້ໃຊ້ກໍຕໍ່ເມື່ອທ່ານເຂົ້າຫາໜ້າຕ່າງໂຕ້ຕອບນີ້ໂດຍການເລືອກ <emph>ຮູບແບບ - ຄໍລຳ</emph>."

#. rHT7H
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id321604744698332\n"
"help.text"
msgid "The following two options are only available when formatting sections."
msgstr "ສອງຕົວເລືອກຕໍ່ໄປນີ້ຈະມີໃຫ້ໃຊ້ໃນເວລາຈັດຮູບແບບເຊັກຊັນເທົ່ານັ້ນ."

#. znZph
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3148386\n"
"help.text"
msgid "Evenly distribute contents to all columns"
msgstr "ແຈກຢາຍເນື້ອໃນໃຫ້ສະເໝີກັນທຸກຄໍລຳ"

#. tTRCL
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3149024\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Distributes the text in multi-column sections. The text flows into all columns to the same height. The height of the section adjusts automatically.</ahelp> Evenly distributes the text in <link href=\"text/swriter/01/04020000.xhp\">multi-column sections</link>."
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ແຈກຢາຍຂໍ້ຄວາມໃນເຊັກຊັນທີ່ມີຫຼາຍຄໍລຳ. ຂໍ້ຄວາມຈະໄຫຼເຂົ້າໄປໃນທຸກຄໍລຳໃຫ້ມີຄວາມສູງເທົ່າກັນ. ຄວາມສູງຂອງເຊັກຊັນຈະຖືກປັບປ່ຽນໂດຍອັດຕະໂນມັດ.</ahelp> ແຈກຢາຍຂໍ້ຄວາມໃຫ້ສະເໝີກັນໃນ <link href=\"text/swriter/01/04020000.xhp\">ເຊັກຊັນທີ່ມີຫຼາຍຄໍລຳ</link>."

#. 3hGFh
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3155892\n"
"help.text"
msgid "The column layout preview only shows the columns and not the surrounding page."
msgstr "ຕົວຢ່າງການຈັດວາງຄໍລຳຈະສະແດງພຽງແຕ່ຄໍລຳເທົ່ານັ້ນ ແລະ ບໍ່ສະແດງໜ້າທີ່ຢູ່ອ້ອມຂ້າງ."

#. HBegH
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3153924\n"
"help.text"
msgid "Width and spacing"
msgstr "ຄວາມກວ້າງ ແລະ ໄລຍະຫ່າງ"

#. D3X5T
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3147530\n"
"help.text"
msgid "AutoWidth"
msgstr "ຄວາມກວ້າງອັດຕະໂນມັດ"

#. CVbrT
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3150986\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/autowidth\">Creates columns of equal width.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/autowidth\">ສ້າງຄໍລຳໃຫ້ມີຄວາມກວ້າງເທົ່າກັນ.</ahelp>"

#. senM3
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3147176\n"
"help.text"
msgid "If the <emph>AutoWidth</emph> check box is not selected, enter the width and spacing options for the columns."
msgstr "ຖ້າບໍ່ໄດ້ເລືອກຊ່ອງ <emph>ຄວາມກວ້າງອັດຕະໂນມັດ</emph>, ໃຫ້ປ້ອນຕົວເລືອກຄວາມກວ້າງ ແລະ ໄລຍະຫ່າງສຳລັບຄໍລຳ."

#. WKBWJ
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3147562\n"
"help.text"
msgid "Column"
msgstr "ຄໍລຳ"

#. EQzit
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3145206\n"
"help.text"
msgid "Displays the column number, as well as width and distance to the adjacent columns."
msgstr "ສະແດງເລກລຳດັບຄໍລຳ, ລວມທັງຄວາມກວ້າງ ແລະ ໄລຍະຫ່າງຫາຄໍລຳທີ່ຢູ່ຕິດກັນ."

#. D3PKF
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3156324\n"
"help.text"
msgid "Left Arrow"
msgstr "ລູກສອນຊ້າຍ"

#. CqwA8
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3150761\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/back\">Moves the column display one column to the left.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/back\">ຍ້າຍການສະແດງຄໍລຳໄປທາງຊ້າຍໜຶ່ງຄໍລຳ.</ahelp>"

#. FBEiL
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3149287\n"
"help.text"
msgid "<image id=\"img_id3149750\" src=\"res/sc06301.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149750\">Left Arrow Icon</alt></image>"
msgstr "<image id=\"img_id3149750\" src=\"res/sc06301.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149750\">ໄອຄອນລູກສອນຊ້າຍ</alt></image>"

#. xFUCF
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3154694\n"
"help.text"
msgid "Left Arrow"
msgstr "ລູກສອນຊ້າຍ"

#. cREuM
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3145421\n"
"help.text"
msgid "Right Arrow"
msgstr "ລູກສອນຂວາ"

#. oYQ83
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3153576\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/next\">Moves the column display one column to the right.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/next\">ຍ້າຍການສະແດງຄໍລຳໄປທາງຂວາໜຶ່ງຄໍລຳ.</ahelp>"

#. 4yw8c
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3152938\n"
"help.text"
msgid "<image id=\"img_id3152948\" src=\"res/sc06300.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3152948\">Right Arrow Icon</alt></image>"
msgstr "<image id=\"img_id3152948\" src=\"res/sc06300.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3152948\">ໄອຄອນລູກສອນຂວາ</alt></image>"

#. EFqg6
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3153540\n"
"help.text"
msgid "Right Arrow"
msgstr "ລູກສອນຂວາ"

#. H84Pd
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3154470\n"
"help.text"
msgid "Width"
msgstr "ຄວາມກວ້າງ"

#. YkEJ2
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3152963\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/width3mf\">Enter the width of the column.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/width3mf\">ປ້ອນຄວາມກວ້າງຂອງຄໍລຳ.</ahelp>"

#. QEcCN
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3151308\n"
"help.text"
msgid "Spacing"
msgstr "ໄລຍະຫ່າງ"

#. LAEmS
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3153672\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/spacing2mf\">Enter the amount of space that you want to leave between the columns.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/spacing2mf\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ທ່ານຕ້ອງການໃຫ້ເຫຼືອໄວ້ລະຫວ່າງຄໍລຳ.</ahelp>"

#. DFN3C
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3149685\n"
"help.text"
msgid "Separator line"
msgstr "ເສັ້ນແບ່ງ"

#. vqfuv
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3154188\n"
"help.text"
msgid "This area is only available if your layout contains more than one column."
msgstr "ບໍລິເວນນີ້ຈະມີໃຫ້ໃຊ້ກໍຕໍ່ເມື່ອການຈັດວາງຂອງທ່ານມີຫຼາຍກວ່າໜຶ່ງຄໍລຳ."

#. 4CSvr
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3155775\n"
"help.text"
msgid "Style"
msgstr "ຮູບແບບ"

#. yYDqn
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3159190\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/linestylelb\">Select the formatting style for the column separator line. If you do not want a separator line, choose \"None\".</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/linestylelb\">ເລືອກຮູບແບບການຈັດຮູບແບບສຳລັບເສັ້ນແບ່ງຄໍລຳ. ຖ້າທ່ານບໍ່ຕ້ອງການເສັ້ນແບ່ງ, ໃຫ້ເລືອກ \"ບໍ່ມີ\".</ahelp>"

#. AGizj
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id931604684769944\n"
"help.text"
msgid "Width"
msgstr "ຄວາມກວ້າງ"

#. H2vfk
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id931604684783303\n"
"help.text"
msgid "Enter width of the separator line."
msgstr "ປ້ອນຄວາມກວ້າງຂອງເສັ້ນແບ່ງ."

#. jT4PA
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id421604684687071\n"
"help.text"
msgid "Color"
msgstr "ສີ"

#. CuuBH
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id601604684699407\n"
"help.text"
msgid "Select a color for the separator line."
msgstr "ເລືອກສີສຳລັບເສັ້ນແບ່ງ."

#. u3jAb
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3155184\n"
"help.text"
msgid "Height"
msgstr "ຄວາມສູງ"

#. PWrQt
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3149309\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/lineheightmf\">Enter the length of the separator line as a percentage of the height of the column area.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/lineheightmf\">ປ້ອນຄວາມຍາວຂອງເສັ້ນແບ່ງເປັນເປີເຊັນຂອງຄວາມສູງຂອງບໍລິເວນຄໍລຳ.</ahelp>"

#. zSG6G
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"hd_id3143271\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. xxo93
#: 05040500.xhp
msgctxt ""
"05040500.xhp\n"
"par_id3149485\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/lineposlb\">Select the vertical alignment of the separator line. This option is only available if <emph>Height</emph> value of the line is less than 100%.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/lineposlb\">ເລືອກການຈັດລຽງໃນແນວຕັ້ງຂອງເສັ້ນແບ່ງ. ຕົວເລືອກນີ້ຈະມີໃຫ້ໃຊ້ກໍຕໍ່ເມື່ອຄ່າ <emph>ຄວາມສູງ</emph> ຂອງເສັ້ນນ້ອຍກວ່າ 100% ເທົ່ານັ້ນ.</ahelp>"

#. aAggJ
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"tit\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. CBB4B
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"hd_id3149871\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. jxu7i
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"par_id3148569\n"
"help.text"
msgid "Specifies the number of columns and the column layout for the section."
msgstr "ກຳນົດຈຳນວນຄໍລຳ ແລະ ການຈັດວາງຄໍລຳສຳລັບເຊັກຊັນ."

#. kNCQC
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"par_id3151390\n"
"help.text"
msgid "Sections follow the text flow behavior of the page they are inserted into."
msgstr "ເຊັກຊັນຈະປະຕິບັດຕາມພຶດຕິກຳການໄຫຼຂອງຂໍ້ຄວາມຂອງໜ້າທີ່ພວກມັນຖືກແຊກເຂົ້າໄປ."

#. UQAQK
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"par_id3083448\n"
"help.text"
msgid "For example, if you insert a section that uses a two-column layout into a page style that uses a four-column layout, the two-column layout is nested inside one of the four columns."
msgstr "ຕົວຢ່າງ: ຖ້າທ່ານແຊກເຊັກຊັນທີ່ໃຊ້ການຈັດວາງແບບສອງຄໍລຳເຂົ້າໃນຮູບແບບໜ້າທີ່ໃຊ້ການຈັດວາງແບບສີ່ຄໍລຳ, ການຈັດວາງແບບສອງຄໍລຳນັ້ນຈະຖືກຊ້ອນຢູ່ພາຍໃນໜຶ່ງໃນສີ່ຄໍລຳນັ້ນ."

#. AKVK9
#: 05040501.xhp
msgctxt ""
"05040501.xhp\n"
"par_id3155625\n"
"help.text"
msgid "You can also nest sections, that is, you can insert a section into another section."
msgstr "ທ່ານຍັງສາມາດເຮັດເຊັກຊັນຊ້ອນກັນໄດ້, ນັ້ນຄື ທ່ານສາມາດແຊກເຊັກຊັນເຂົ້າໃນອີກເຊັກຊັນໜຶ່ງໄດ້."

#. aAvbs
#: 05040600.xhp
msgctxt ""
"05040600.xhp\n"
"tit\n"
"help.text"
msgid "Footnote"
msgstr "ເຊິງອັດ (Footnote)"

#. izqFS
#: 05040600.xhp
msgctxt ""
"05040600.xhp\n"
"hd_id3154767\n"
"help.text"
msgid "<link href=\"text/swriter/01/05040600.xhp\">Footnote</link>"
msgstr "<link href=\"text/swriter/01/05040600.xhp\">ເຊິງອັດ</link>"

#. gsgW6
#: 05040600.xhp
msgctxt ""
"05040600.xhp\n"
"par_id3149351\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/footnoteareapage/FootnoteAreaPage\">Specifies the layout options for footnotes, including the line that separates the footnote from the main body of document.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/footnoteareapage/FootnoteAreaPage\">ກຳນົດຕົວເລືອກການຈັດວາງສຳລັບເຊິງອັດ, ລວມທັງເສັ້ນທີ່ແຍກເຊິງອັດອອກຈາກເນື້ອໃນຫຼັກຂອງເອກະສານ.</ahelp>"

