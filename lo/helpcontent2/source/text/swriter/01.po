msgctxt ""
"05120400.xhp\n"
"hd_id3150016\n"
"help.text"
msgid "Number"
msgstr "ຈຳນວນ"

#. TJaqq
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3155626\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/insertrowcolumn/insert_number\">Enter the number of columns or rows that you want.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/insertrowcolumn/insert_number\">ປ້ອນຈຳນວນຖັນ ຫຼື ແຖວທີ່ທ່ານຕ້ອງການ.</ahelp>"

#. Ra9rz
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3145829\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. jCxcD
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3154504\n"
"help.text"
msgid "Specifies where to insert the columns or rows."
msgstr "ກຳນົດບ່ອນທີ່ຈະແຊກຖັນ ຫຼື ແຖວ."

#. dm6DF
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3150015\n"
"help.text"
msgid "Before"
msgstr "ກ່ອນໜ້າ"

#. xY9HU
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3150564\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/insertrowcolumn/insert_before\">Adds new columns to the left of the current column, or adds new rows above the current row.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/insertrowcolumn/insert_before\">ເພີ່ມຖັນໃໝ່ໃສ່ເບື້ອງຊ້າຍຂອງຖັນປັດຈຸບັນ, ຫຼື ເພີ່ມແຖວໃໝ່ໃສ່ເທິງແຖວປັດຈຸບັນ.</ahelp>"

#. cDP9A
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3149024\n"
"help.text"
msgid "After"
msgstr "ຫຼັງຈາກ"

#. fSaYP
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3153718\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/insertrowcolumn/insert_after\">Adds new columns to the right of the current column, or adds new rows below the current row.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/insertrowcolumn/insert_after\">ເພີ່ມຖັນໃໝ່ໃສ່ເບື້ອງຂວາຂອງຖັນປັດຈຸບັນ, ຫຼື ເພີ່ມແຖວໃໝ່ໃສ່ລຸ່ມແຖວປັດຈຸບັນ.</ahelp>"

#. twzAP
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"tit\n"
"help.text"
msgid "Styles in Writer"
msgstr "ຮູບແບບໃນ Writer"

#. AeLTT
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"bm_id4005249\n"
"help.text"
msgid "<bookmark_value>styles;categories</bookmark_value><bookmark_value>character styles;style categories</bookmark_value><bookmark_value>paragraph styles;style categories</bookmark_value><bookmark_value>table styles;style categories</bookmark_value><bookmark_value>frames styles; style categories</bookmark_value><bookmark_value>page styles;style categories</bookmark_value><bookmark_value>list styles;style categories</bookmark_value>"
msgstr "<bookmark_value>ຮູບແບບ;ໝວດໝູ່</bookmark_value><bookmark_value>ຮູບແບບຕົວອັກສອນ;ໝວດໝູ່ຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບວັກຕອນ;ໝວດໝູ່ຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບຕາຕະລາງ;ໝວດໝູ່ຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບກອບ; ໝວດໝູ່ຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບໜ້າ;ໝວດໝູ່ຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບລາຍການ;ໝວດໝູ່ຮູບແບບ</bookmark_value>"

#. X4XhT
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"hd_id3150344\n"
"help.text"
msgid "<variable id=\"styles_in_writer\"><link href=\"text/swriter/01/05130000.xhp\">Styles in Writer</link></variable>"
msgstr "<variable id=\"styles_in_writer\"><link href=\"text/swriter/01/05130000.xhp\">ຮູບແບບໃນ Writer</link></variable>"

#. DRycB
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3149052\n"
"help.text"
msgid "The following information concerns Writer styles that you can apply using the <link href=\"text/shared/01/styles.xhp\">Styles</link> deck of the Sidebar."
msgstr "ຂໍ້ມູນຕໍ່ໄປນີ້ກ່ຽວຂ້ອງກັບຮູບແບບ Writer ທີ່ທ່ານສາມາດນຳໃຊ້ໄດ້ໂດຍໃຊ້ສ່ວນ <link href=\"text/shared/01/styles.xhp\">ຮູບແບບ</link> ໃນແຖບຂ້າງ (Sidebar)."

#. 2rE8i
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3150015\n"
"help.text"
msgid "If you want, you can edit the styles of the current document, and then save the document as a template. To save the document as template, choose <emph>File - </emph><link href=\"text/shared/01/01110300.xhp\"><emph>Templates - Save as Template</emph></link>."
msgstr "ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດແກ້ໄຂຮູບແບບຂອງເອກະສານປັດຈຸບັນ, ແລ້ວບັນທຶກເອກະສານເປັນແມ່ແບບ (template). ເພື່ອບັນທຶກເອກະສານເປັນແມ່ແບບ, ໃຫ້ເລືອກ <emph>ໄຟລ໌ - </emph><link href=\"text/shared/01/01110300.xhp\"><emph>ແມ່ແບບ - ບັນທຶກເປັນແມ່ແບບ</emph></link>."

#. H7sEC
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"hd_id3150572\n"
"help.text"
msgid "Style Category"
msgstr "ໝວດໝູ່ຮູບແບບ"

#. 6sU4A
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3153721\n"
"help.text"
msgid "These are the different categories of formatting styles."
msgstr "ເຫຼົ່ານີ້ແມ່ນໝວດໝູ່ຕ່າງໆຂອງຮູບແບບການຈັດຮູບແບບ."

#. 2KtwH
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3151271\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. iV6fo
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3153154\n"
"help.text"
msgid "Description"
msgstr "ຄຳອະທິບາຍ"

#. NMaG8
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3151172\n"
"help.text"
msgid "Character Styles"
msgstr "ຮູບແບບຕົວອັກສອນ"

#. EjCSg
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3147512\n"
"help.text"
msgid "Use Character Styles to format single characters, or entire words and phrases. If you want, you can nest Character Styles."
msgstr "ໃຊ້ຮູບແບບຕົວອັກສອນເພື່ອຈັດຮູບແບບຕົວອັກສອນດຽວ, ຫຼື ຄຳສັບ ແລະ ວະລີທັງໝົດ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດຈັດຊ້ອນຮູບແບບຕົວອັກສອນໄດ້."

#. 63PvY
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3150713\n"
"help.text"
msgid "Paragraph Styles"
msgstr "ຮູບແບບວັກຕອນ"

#. X5xEB
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3149810\n"
"help.text"
msgid "Use Paragraph Styles to format paragraphs, including the font type and size. You can also select the paragraph style to apply to the next paragraph."
msgstr "ໃຊ້ຮູບແບບວັກຕອນເພື່ອຈັດຮູບແບບວັກຕອນ, ລວມທັງປະເພດ ແລະ ຂະໜາດຕົວອັກສອນ. ທ່ານຍັງສາມາດເລືອກຮູບແບບວັກຕອນທີ່ຈະນຳໃຊ້ກັບວັກຕອນຖັດໄປ."

#. 2oLtm
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3151308\n"
"help.text"
msgid "Frame Styles"
msgstr "ຮູບແບບກອບ"

#. CTrZd
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3147527\n"
"help.text"
msgid "Use Frame Styles to format text and graphic frames."
msgstr "ໃຊ້ຮູບແບບກອບເພື່ອຈັດຮູບແບບຂໍ້ຄວາມ ແລະ ກອບກຣາບຟິກ."

#. QU9kM
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3152960\n"
"help.text"
msgid "Page Styles"
msgstr "ຮູບແບບໜ້າ"

#. GiASi
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3155897\n"
"help.text"
msgid "Use Page Styles to organize the structure of the document, and to add page numbers. You can also specify the page style to apply to the first page that follows after a page break."
msgstr "ໃຊ້ຮູບແບບໜ້າເພື່ອຈັດລະບຽບໂຄງສ້າງຂອງເອກະສານ, ແລະ ເພີ່ມເລກໜ້າ. ທ່ານຍັງສາມາດກຳນົດຮູບແບບໜ້າທີ່ຈະນຳໃຊ້ກັບໜ້າທຳອິດທີ່ຖັດຈາກການຂຶ້ນໜ້າໃໝ່."

#. SF5Ek
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3154196\n"
"help.text"
msgid "List Styles"
msgstr "ຮູບແບບລາຍການ"

#. cSJFe
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3149298\n"
"help.text"
msgid "Use List Styles to format ordered or unordered lists."
msgstr "ໃຊ້ຮູບແບບລາຍການເພື່ອຈັດຮູບແບບລາຍການທີ່ມີລຳດັບ ຫຼື ບໍ່ມີລຳດັບ."

#. JoBUY
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id151737041693286\n"
"help.text"
msgid "Table Styles"
msgstr "ຮູບແບບຕາຕະລາງ"

#. MZyaE
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id761737041693286\n"
"help.text"
msgid "Use table styles to format table rows, columns, headings, totals for rows and columns, and more."
msgstr "ໃຊ້ຮູບແບບຕາຕະລາງເພື່ອຈັດຮູບແບບແຖວ, ຖັນ, ຫົວຂໍ້, ຜົນລວມຂອງແຖວ ແລະ ຖັນ, ແລະ ອື່ນໆ."

#. Mh2Ct
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"hd_id3149821\n"
"help.text"
msgid "<variable id=\"style_groups_hd\">Style Groups</variable>"
msgstr "<variable id=\"style_groups_hd\">ກຸ່ມຮູບແບບ</variable>"

#. EqCk3
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3154828\n"
"help.text"
msgid "These are the style groups that you can display in the Styles window."
msgstr "ເຫຼົ່ານີ້ແມ່ນກຸ່ມຮູບແບບທີ່ທ່ານສາມາດສະແດງໃນປ່ອງຢ້ຽມຮູບແບບ."

#. nrKfL
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3148977\n"
"help.text"
msgid "<variable id=\"table_head_name\">Name</variable>"
msgstr "<variable id=\"table_head_name\">ຊື່</variable>"

#. YAVXB
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3149032\n"
"help.text"
msgid "<variable id=\"table_head_meaning\">Meaning</variable>"
msgstr "<variable id=\"table_head_meaning\">ຄວາມໝາຍ</variable>"

#. 8R5Fe
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3153642\n"
"help.text"
msgid "<variable id=\"automatic_name\">Automatic</variable>"
msgstr "<variable id=\"automatic_name\">ອັດຕະໂນມັດ</variable>"

#. tBM7u
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3152769\n"
"help.text"
msgid "<variable id=\"automatic_meaning\">Displays styles appropriate to the current context.</variable>"
msgstr "<variable id=\"automatic_meaning\">ສະແດງຮູບແບບທີ່ເໝາະສົມກັບບໍລິບົດປັດຈຸບັນ.</variable>"

#. rWEP7
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3154374\n"
"help.text"
msgid "<variable id=\"all_name\">All Styles</variable>"
msgstr "<variable id=\"all_name\">ຮູບແບບທັງໝົດ</variable>"

#. 97i6u
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3153351\n"
"help.text"
msgid "<variable id=\"all_meaning\">Displays all styles of the active style category.</variable>"
msgstr "<variable id=\"all_meaning\">ສະແດງຮູບແບບທັງໝົດຂອງໝວດໝູ່ຮູບແບບທີ່ໃຊ້ງານຢູ່.</variable>"

#. AEAUR
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id841725551315242\n"
"help.text"
msgid "<variable id=\"hidden_name\">Hidden Styles</variable>"
msgstr "<variable id=\"hidden_name\">ຮູບແບບທີ່ຖືກເຊື່ອງ</variable>"

#. YAVXY
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id991725551315242\n"
"help.text"
msgid "<variable id=\"hidden_meaning\">Display styles that have been hidden in the Styles window.</variable>"
msgstr "<variable id=\"hidden_meaning\">ສະແດງຮູບແບບທີ່ຖືກເຊື່ອງໄວ້ໃນປ່ອງຢ້ຽມຮູບແບບ.</variable>"

#. hEgFF
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3150590\n"
"help.text"
msgid "<variable id=\"applied_name\">Applied Styles</variable>"
msgstr "<variable id=\"applied_name\">ຮູບແບບທີ່ນຳໃຊ້ແລ້ວ</variable>"

#. 88uHF
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3149168\n"
"help.text"
msgid "<variable id=\"applied_meaning\">Displays the styles (of selected category) applied in the current document.</variable>"
msgstr "<variable id=\"applied_meaning\">ສະແດງຮູບແບບ (ຂອງໝວດໝູ່ທີ່ເລືອກ) ທີ່ຖືກນຳໃຊ້ໃນເອກະສານປັດຈຸບັນ.</variable>"

#. SFwtr
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3156368\n"
"help.text"
msgid "<variable id=\"custom_name\">Custom Styles</variable>"
msgstr "<variable id=\"custom_name\">ຮູບແບບທີ່ກຳນົດເອງ</variable>"

#. dv4mq
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3145780\n"
"help.text"
msgid "<variable id=\"custom_meaning\">Displays all user-defined styles in the selected style category.</variable>"
msgstr "<variable id=\"custom_meaning\">ສະແດງຮູບແບບທີ່ຜູ້ໃຊ້ກຳນົດເອງທັງໝົດໃນໝວດໝູ່ຮູບແບບທີ່ເລືອກ.</variable>"

#. GmDWB
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3155908\n"
"help.text"
msgid "<variable id=\"text_name\">Text Styles</variable>"
msgstr "<variable id=\"text_name\">ຮູບແບບຂໍ້ຄວາມ</variable>"

#. SUBtR
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3150114\n"
"help.text"
msgid "<variable id=\"text_meaning\">Displays formatting styles for text.</variable>"
msgstr "<variable id=\"text_meaning\">ສະແດງຮູບແບບການຈັດຮູບແບບສຳລັບຂໍ້ຄວາມ.</variable>"

#. KtBNA
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3150700\n"
"help.text"
msgid "<variable id=\"document_structure_name\">Document Structure</variable>"
msgstr "<variable id=\"document_structure_name\">ໂຄງສ້າງເອກະສານ</variable>"

#. mDje8
#: 05130000.xhp
msgctxt ""
"05130000.xhp\n"
"par_id3147412\n"
"help.text"
msgid "<variable id=\"document_structure_meaning\">Displays formatting styles for structuring documents.</variable>"
