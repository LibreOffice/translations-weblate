#. tAx3e
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id0902200804290272\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the available fields for the field type selected in the <emph>Type</emph> list. To insert a field, click the field, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງລາຍການຟິວທີ່ມີໃຫ້ສຳລັບປະເພດຟິວທີ່ເລືອກໃນລາຍການ <emph>ປະເພດ</emph>. ເພື່ອແຊກຟິວ, ໃຫ້ຄລິກໃສ່ຟິວ, ແລ້ວຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. NDsUM
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3149956\n"
"help.text"
msgid "For the \"Created\", \"Modified\", and \"Last printed\" field types, you can include the author, date, and time of the corresponding operation."
msgstr "ສຳລັບປະເພດຟິວ \"ສ້າງເມື່ອ\", \"ແກ້ໄຂເມື່ອ\", ແລະ \"ພິມຄັ້ງລ່າສຸດ\", ທ່ານສາມາດໃສ່ຊື່ຜູ້ຂຽນ, ວັນທີ, ແລະ ເວລາຂອງການດຳເນີນການນັ້ນໆໄດ້."

#. pWTCF
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id0902200804290382\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Click the format that you want to apply to the selected field, or click \"Additional formats\" to define a custom format.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຄລິກໃສ່ຮູບແບບທີ່ທ່ານຕ້ອງການໃຊ້ກັບຟິວທີ່ເລືອກ, ຫຼື ຄລິກ \"ຮູບແບບເພີ່ມເຕີມ\" ເພື່ອກຳນົດຮູບແບບເອງ.</ahelp>"

#. uAw3D
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"hd_id3149608\n"
"help.text"
msgid "Fixed content"
msgstr "ເນື້ອໃນແບບຄົງທີ່"

#. 3TZKN
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3150767\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddocinfopage/fixed\">Inserts the field as static content, that is, the field cannot be updated.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddocinfopage/fixed\">ແຊກຟິວເປັນເນື້ອໃນແບບຄົງທີ່, ນັ້ນຄື ຟິວຈະບໍ່ສາມາດອັບເດດໄດ້.</ahelp>"

#. ApvrX
#: 04090004.xhp
msgctxt ""
"04090004.xhp\n"
"par_id3155554\n"
"help.text"
msgid "Fields with fixed content are only evaluated when you create a new document from a template that contains such a field. For example, a date field with fixed content inserts the date that a new document was created from the template."
msgstr "ຟິວທີ່ມີເນື້ອໃນຄົງທີ່ ຈະຖືກປະເມີນຄ່າເມື່ອທ່ານສ້າງເອກະສານໃໝ່ຈາກແມ່ແບບ (Template) ທີ່ມີຟິວດັ່ງກ່າວເທົ່ານັ້ນ. ຕົວຢ່າງ: ຟິວວັນທີທີ່ມີເນື້ອໃນຄົງທີ່ ຈະແຊກວັນທີທີ່ເອກະສານໃໝ່ຖືກສ້າງຂຶ້ນຈາກແມ່ແບບນັ້ນ."

#. ADuXD
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"tit\n"
"help.text"
msgid "Variables (fields)"
msgstr "ຕົວປ່ຽນ (ຟິວ)"

#. PhMkX
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"bm_id8526261\n"
"help.text"
msgid "<bookmark_value>user-defined fields, restriction</bookmark_value>"
msgstr "<bookmark_value>ຟິວກຳນົດເອງ, ຂໍ້ຈຳກັດ</bookmark_value>"

#. KGQCu
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3153716\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090005.xhp\">Variables</link>"
msgstr "<link href=\"text/swriter/01/04090005.xhp\">ຕົວປ່ຽນ</link>"

#. VYoYN
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150764\n"
"help.text"
msgid "<ahelp hid=\".\">Variable fields let you add dynamic content to your document. For example, you can use a variable to reset the page numbering.</ahelp>"
msgstr "<ahelp hid=\".\">ຟິວຕົວປ່ຽນຊ່ວຍໃຫ້ທ່ານເພີ່ມເນື້ອໃນທີ່ມີການປ່ຽນແປງໄດ້ (dynamic) ເຂົ້າໃນເອກະສານຂອງທ່ານ. ຕົວຢ່າງ: ທ່ານສາມາດໃຊ້ຕົວປ່ຽນເພື່ອຕັ້ງຄ່າເລກໜ້າໃໝ່.</ahelp>"

#. Asa9F
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id0903200802243625\n"
"help.text"
msgid "To add a field to your document, click a field type, click a field in the <emph>Select </emph>list, and then click <emph>Insert</emph>."
msgstr "ເພື່ອເພີ່ມຟິວເຂົ້າໃນເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກໃສ່ປະເພດຟິວ, ແລ້ວຄລິກໃສ່ຟິວໃນລາຍການ <emph>ເລືອກ</emph>, ຈາກນັ້ນຄລິກ <emph>ແຊກ</emph>."

#. UthzB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3151312\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. jPLTD
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3153672\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/type\">Lists the available Variable field types. </ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/type\">ສະແດງລາຍການປະເພດຟິວຕົວປ່ຽນທີ່ມີໃຫ້. </ahelp>"

#. y7FnB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150703\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. PSauB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3154096\n"
"help.text"
msgid "Description"
msgstr "ຄຳອະທິບາຍ"

#. 2BQKn
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149803\n"
"help.text"
msgid "Set Variable"
msgstr "ກຳນົດຕົວປ່ຽນ"

#. AbNGB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150996\n"
"help.text"
msgid "Defines a variable and its value. You can change the value of a variable by clicking in front of the variable field, and then choosing <menuitem>Edit - Field</menuitem>."
msgstr "ກຳນົດຕົວປ່ຽນ ແລະ ຄ່າຂອງມັນ. ທ່ານສາມາດປ່ຽນຄ່າຂອງຕົວປ່ຽນໄດ້ໂດຍການຄລິກໄວ້ທາງໜ້າຟິວຕົວປ່ຽນ, ແລ້ວເລືອກ <menuitem>ແກ້ໄຂ - ຟິວ</menuitem>."

#. BfBz8
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id41762472836706\n"
"help.text"
msgid "By default, all variables are created of numeric type."
msgstr "ຕາມຄ່າເລີ່ມຕົ້ນ, ທຸກຕົວປ່ຽນຈະຖືກສ້າງເປັນປະເພດຕົວເລກ."

#. iqB7Z
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id421762471624199\n"
"help.text"
msgid "When you insert a <emph>Set Variable</emph> field into the document for the first time, you need to define its format in the <emph>Format</emph> area. The format can be either text or numeric, with various number formats available. Once defined, you cannot change the format unless you <link href=\"text/swriter/01/04090005.xhp#delete\">remove the variable</link> from the document. By default, all variables are created of numeric format."
msgstr "ເມື່ອທ່ານແຊກຟິວ <emph>ກຳນົດຕົວປ່ຽນ</emph> ເຂົ້າໃນເອກະສານເປັນຄັ້ງທຳອິດ, ທ່ານຕ້ອງກຳນົດຮູບແບບຂອງມັນໃນສ່ວນ <emph>ຮູບແບບ</emph>. ຮູບແບບສາມາດເປັນໄດ້ທັງຂໍ້ຄວາມ ຫຼື ຕົວເລກ, ໂດຍມີຮູບແບບຕົວເລກຕ່າງໆໃຫ້ເລືອກ. ເມື່ອກຳນົດແລ້ວ, ທ່ານຈະບໍ່ສາມາດປ່ຽນຮູບແບບໄດ້ ນອກຈາກທ່ານຈະ <link href=\"text/swriter/01/04090005.xhp#delete\">ລຶບຕົວປ່ຽນ</link> ອອກຈາກເອກະສານ. ຕາມຄ່າເລີ່ມຕົ້ນ, ທຸກຕົວປ່ຽນຈະຖືກສ້າງເປັນຮູບແບບຕົວເລກ."

#. WjgAZ
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3154571\n"
"help.text"
msgid "Show Variable"
msgstr "ສະແດງຕົວປ່ຽນ"

#. dDFj8
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3153669\n"
"help.text"
msgid "Inserts the current value of the variable that you click in the <emph>Select</emph> list."
msgstr "ແຊກຄ່າປັດຈຸບັນຂອງຕົວປ່ຽນທີ່ທ່ານຄລິກໃນລາຍການ <emph>ເລືອກ</emph>."

#. 6BsrS
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3147531\n"
"help.text"
msgid "DDE field"
msgstr "ຟິວ DDE"

#. c7Enn
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149684\n"
"help.text"
msgid "Inserts a <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> link into the document, that you can update as often as you want through the assigned name."
msgstr "ແຊກລິ້ງ <link href=\"text/shared/00/00000005.xhp#dde\">DDE</link> ເຂົ້າໃນເອກະສານ, ເຊິ່ງທ່ານສາມາດອັບເດດໄດ້ເລື້ອຍໆຕາມທີ່ຕ້ອງການຜ່ານຊື່ທີ່ກຳນົດໄວ້."

#. B7dkh
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3159196\n"
"help.text"
msgid "Insert Formula"
msgstr "ແຊກສູດ"

#. wwbye
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3151322\n"
"help.text"
msgid "Inserts a fixed number, or the result of a formula."
msgstr "ແຊກຕົວເລກຄົງທີ່, ຫຼື ຜົນຮັບຂອງສູດ."

#. Vpg4U
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id711762479329045\n"
"help.text"
msgid "When a variable is created with a numeric value, its content is interpreted as a formula, and the result is automatically converted to a number. Plain text enclosed in quotes evaluates to <emph>0</emph>, but if you enter a mixed string like <emph>\"123a456\"</emph>, the conversion stops at the first non-numeric character—resulting in the number <emph>123</emph>."
msgstr "ເມື່ອຕົວປ່ຽນຖືກສ້າງຂຶ້ນດ້ວຍຄ່າຕົວເລກ, ເນື້ອໃນຂອງມັນຈະຖືກຕີຄວາມໝາຍເປັນສູດ, ແລະ ຜົນຮັບຈະຖືກປ່ຽນເປັນຕົວເລກໂດຍອັດຕະໂນມັດ. ຂໍ້ຄວາມທຳມະດາທີ່ຢູ່ໃນເຄື່ອງໝາຍຄຳເວົ້າຈະມີຄ່າເທົ່າກັບ <emph>0</emph>, ແຕ່ຖ້າທ່ານປ້ອນຂໍ້ຄວາມປະສົມເຊັ່ນ <emph>\"123a456\"</emph>, ການປ່ຽນຄ່າຈະຢຸດຢູ່ທີ່ຕົວອັກສອນທຳອິດທີ່ບໍ່ແມ່ນຕົວເລກ — ເຊິ່ງຈະໄດ້ຜົນຮັບເປັນຕົວເລກ <emph>123</emph>."

#. PSDZm
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id921762479337853\n"
"help.text"
msgid "The formula expression follows the rules for <link href=\"text/swriter/02/14020000.xhp\">formulas in tables</link>, using variables defined in the document rather than table cells."
msgstr "ການສະແດງອອກຂອງສູດແມ່ນປະຕິບັດຕາມກົດເກນຂອງ <link href=\"text/swriter/02/14020000.xhp\">ສູດໃນຕາຕະລາງ</link>, ໂດຍໃຊ້ຕົວປ່ຽນທີ່ກຳນົດໄວ້ໃນເອກະສານແທນທີ່ຈະເປັນຫ້ອງຕາຕະລາງ."

#. RGteS
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149494\n"
"help.text"
msgid "Input field"
msgstr "ຟິວປ້ອນຂໍ້ມູນ"

#. T9M8F
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3154829\n"
"help.text"
msgid "Inserts a new value for a variable or a User Field."
msgstr "ແຊກຄ່າໃໝ່ສຳລັບຕົວປ່ຽນ ຫຼື ຟິວຜູ້ໃຊ້."

#. X6pz3
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149098\n"
"help.text"
msgid "The value of a variable in an Input field is only valid from where the field is inserted and onwards. To change the value of the variable later in the document, insert another Input field of the same name, but with a different value. However, the value of a User Field is changed globally."
msgstr "ຄ່າຂອງຕົວປ່ຽນໃນຟິວປ້ອນຂໍ້ມູນຈະມີຜົນນັບຈາກຈຸດທີ່ແຊກຟິວເປັນຕົ້ນໄປ. ເພື່ອປ່ຽນຄ່າຂອງຕົວປ່ຽນໃນພາກສ່ວນຕໍ່ໄປຂອງເອກະສານ, ໃຫ້ແຊກຟິວປ້ອນຂໍ້ມູນອີກອັນໜຶ່ງທີ່ມີຊື່ດຽວກັນແຕ່ມີຄ່າຕ່າງກັນ. ແນວໃດກໍຕາມ, ຄ່າຂອງຟິວຜູ້ໃຊ້ຈະຖືກປ່ຽນແປງໃນທົ່ວເອກະສານ."

#. LWrGQ
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3151255\n"
"help.text"
msgid "The variables are displayed in the <emph>Select</emph> field. When you click the <emph>Insert</emph> button, the dialog <link href=\"text/swriter/01/04090100.xhp\"><emph>Review Fields</emph></link> appears, where you can enter the new value or additional text as a remark."
msgstr "ຕົວປ່ຽນຈະຖືກສະແດງໃນຟິວ <emph>ເລືອກ</emph>. ເມື່ອທ່ານຄລິກປຸ່ມ <emph>ແຊກ</emph>, ກ່ອງໂຕ້ຕອບ <link href=\"text/swriter/01/04090100.xhp\"><emph>ກວດສອບຟິວ</emph></link> ຈະປາກົດຂຶ້ນ, ເຊິ່ງທ່ານສາມາດປ້ອນຄ່າໃໝ່ ຫຼື ຂໍ້ຄວາມເພີ່ມເຕີມເປັນໝາຍເຫດໄດ້."

#. tbz9T
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149034\n"
"help.text"
msgid "Number range"
msgstr "ຊ່ວງຕົວເລກ"

#. 7amgE
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3152772\n"
"help.text"
msgid "Inserts automatic numbering for tables, graphics, or frames."
msgstr "ແຊກລຳດັບຕົວເລກອັດຕະໂນມັດສຳລັບຕາຕະລາງ, ຮູບພາບ, ຫຼື ກອບ."

#. VB7DC
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3147073\n"
"help.text"
msgid "Set page variable"
msgstr "ກຳນົດຕົວປ່ຽນໜ້າ"

#. wa2GR
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3154389\n"
"help.text"
msgid "Inserts a reference point in the document, after which the page count restarts. Select \"on\" to enable the reference point, and \"off\" to disable it. You can also enter an offset to start the page count at a different number."
msgstr "ແຊກຈຸດອ້າງອີງໃນເອກະສານ, ເຊິ່ງຫຼັງຈາກຈຸດນັ້ນການນັບໜ້າຈະເລີ່ມໃໝ່. ເລືອກ \"ເປີດ\" ເພື່ອເປີດໃຊ້ຈຸດອ້າງອີງ, ແລະ \"ປິດ\" ເພື່ອປິດການໃຊ້ງານ. ທ່ານຍັງສາມາດປ້ອນຄ່າເລີ່ມຕົ້ນ (offset) ເພື່ອໃຫ້ເລີ່ມນັບໜ້າດ້ວຍຕົວເລກອື່ນໄດ້."

#. DZ22Q
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3156267\n"
"help.text"
msgid "Show page variable"
msgstr "ສະແດງຕົວປ່ຽນໜ້າ"

#. KbVdV
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150588\n"
"help.text"
msgid "Displays the number of pages from the \"Set page variable\" reference point to this field."
msgstr "ສະແດງຈຳນວນໜ້ານັບຈາກຈຸດອ້າງອີງ \"ກຳນົດຕົວປ່ຽນໜ້າ\" ມາຈົນເຖິງຟິວນີ້."

#. 6SKyt
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3145779\n"
"help.text"
msgid "User Field"
msgstr "ຟິວຜູ້ໃຊ້"

#. QnUXa
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3151377\n"
"help.text"
msgid "Inserts a custom global variable. You can use the User Field to define a variable for a condition statement. When you change a User Field, all instances of the variable in the document are updated."
msgstr "ແຊກຕົວປ່ຽນສ່ວນກາງທີ່ກຳນົດເອງ. ທ່ານສາມາດໃຊ້ຟິວຜູ້ໃຊ້ເພື່ອມີກຳນົດຕົວປ່ຽນສຳລັບຂໍ້ຄວາມເງື່ອນໄຂ. ເມື່ອທ່ານປ່ຽນແປງຟິວຜູ້ໃຊ້, ທຸກໆບ່ອນທີ່ມີຕົວປ່ຽນນີ້ໃນເອກະສານຈະຖືກອັບເດດນຳກັນ."

#. nrVng
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3888363\n"
"help.text"
msgid "Select"
msgstr "ເລືອກ"

#. XpBx7
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id7453535\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/select\"><variable id=\"selecthelp\">Lists the available fields for the field type selected in the <emph>Type </emph>list.</variable> To insert a field, click the field, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/select\"><variable id=\"selecthelp\">ສະແດງລາຍການຟິວທີ່ມີໃຫ້ສຳລັບປະເພດຟິວທີ່ເລືອກໃນລາຍການ <emph>ປະເພດ</emph>.</variable> ເພື່ອແຊກຟິວ, ໃຫ້ຄລິກໃສ່ຟິວ, ແລ້ວຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. DUaXS
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3326822\n"
"help.text"
msgid "To quickly insert a field from the <emph>Select</emph> list, hold down <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> and double-click the field."
msgstr "ເພື່ອແຊກຟິວຈາກລາຍການ <emph>ເລືອກ</emph> ຢ່າງໄວວາ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> ຄ້າງໄວ້ ແລ້ວດັບເບີ້ນຄລິກໃສ່ຟິວນັ້ນ."

#. 6vw2i
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id0903200802243892\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Click the format that you want to apply to the selected field, or click \"Additional formats\" to define a custom format.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຄລິກໃສ່ຮູບແບບທີ່ທ່ານຕ້ອງການໃຊ້ກັບຟິວທີ່ເລືອກ, ຫຼື ຄລິກ \"ຮູບແບບເພີ່ມເຕີມ\" ເພື່ອກຳນົດຮູບແບບເອງ.</ahelp>"

#. uy2HM
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id0903200802243880\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Type the name of the user-defined field that you want to create.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ພິມຊື່ຂອງຟິວທີ່ກຳນົດເອງທີ່ທ່ານຕ້ອງການສ້າງ.</ahelp>"

#. BufeR
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id381583794664065\n"
"help.text"
msgid "<embedvar href=\"text/swriter/01/04090002.xhp#FieldName\"/> This option is available for \"Set variable\", \"DDE field\", \"Number range\" and \"User Field\" field types."
msgstr "<embedvar href=\"text/swriter/01/04090002.xhp#FieldName\"/> ຕົວເລືອກນີ້ມີໃຫ້ສຳລັບປະເພດຟິວ \"ກຳນົດຕົວປ່ຽນ\", \"ຟິວ DDE\", \"ຊ່ວງຕົວເລກ\" ແລະ \"ຟິວຜູ້ໃຊ້\"."

#. KsGDR
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149759\n"
"help.text"
msgid "User-defined fields are only available in the current document."
msgstr "ຟິວທີ່ກຳນົດເອງຈະມີໃຫ້ໃຊ້ສະເພາະໃນເອກະສານປັດຈຸບັນເທົ່ານັ້ນ."

#. u6NiB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id0903200802243951\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the contents that you want to add to a user-defined field.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນເນື້ອໃນທີ່ທ່ານຕ້ອງການເພີ່ມເຂົ້າໃນຟິວທີ່ກຳນົດເອງ.</ahelp>"

#. NLKFC
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3155860\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/format\">In the <emph>Format</emph> list, define if the value is inserted as text or a number.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/format\">ໃນລາຍການ <emph>ຮູບແບບ</emph>, ໃຫ້ກຳນົດວ່າຈະແຊກຄ່າເປັນຂໍ້ຄວາມ ຫຼື ຕົວເລກ.</ahelp>"

#. C2c7a
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150696\n"
"help.text"
msgid "In an HTML document, two additional fields are available for the \"Set variable\" field type: HTML_ON and HTML_OFF. The text that you type in the <emph>Value </emph>box is converted to an opening HTML <link href=\"text/shared/00/00000002.xhp#tags\">tag</link> (<Value>) or to a closing HTML (</Value>) tag when the file is saved as an HTML document, depending on the option that you select."
msgstr "ໃນເອກະສານ HTML, ຈະມີສອງຟິວເພີ່ມເຕີມສຳລັບປະເພດຟິວ \"ກຳນົດຕົວປ່ຽນ\": HTML_ON ແລະ HTML_OFF. ຂໍ້ຄວາມທີ່ທ່ານພິມໃນຫ້ອງ <emph>ຄ່າ</emph> ຈະຖືກປ່ຽນເປັນ <link href=\"text/shared/00/00000002.xhp#tags\">ແທັກ</link> HTML ເປີດ (<Value>) ຫຼື ແທັກ HTML ປິດ (</Value>) ເມື່ອບັນທຶກໄຟລ໌ເປັນເອກະສານ HTML, ຂຶ້ນກັບຕົວເລືອກທີ່ທ່ານເລືອກ."

#. BFvdg
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id871583773320305\n"
"help.text"
msgid "DDE Statement"
msgstr "ຄຳສັ່ງ DDE"

#. LeD7F
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id481583773333848\n"
"help.text"
msgid "This option is only available if the \"DDE field\" field type is selected."
msgstr "ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະເມື່ອເລືອກປະເພດຟິວ \"ຟິວ DDE\" ເທົ່ານັ້ນ."

#. CwbNv
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3155969\n"
"help.text"
msgid "Formula"
msgstr "ສູດ"

#. sEDCi
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3155982\n"
"help.text"
msgid "This option is only available if the \"Insert Formula\" field type is selected."
msgstr "ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະເມື່ອເລືອກປະເພດຟິວ \"ແຊກສູດ\" ເທົ່ານັ້ນ."

#. YZNGC
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id71583772995807\n"
"help.text"
msgid "This option is only available if the \"Set page variable\" field type is selected."
msgstr "ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະເມື່ອເລືອກປະເພດຟິວ \"ກຳນົດຕົວປ່ຽນໜ້າ\" ເທົ່ານັ້ນ."

#. Yr3JD
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3149229\n"
"help.text"
msgid "Invisible"
msgstr "ເບິ່ງບໍ່ເຫັນ"

#. qZx3N
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3156233\n"
"help.text"
msgid "<variable id=\"invisiblehelp\"><ahelp hid=\"modules/swriter/ui/fldvarpage/invisible\">Hides the field contents in the document.</ahelp> The field is inserted as a thin gray mark in the document.</variable> This option is only available for the \"Set Variable\" and \"User Field\" field types."
msgstr "<variable id=\"invisiblehelp\"><ahelp hid=\"modules/swriter/ui/fldvarpage/invisible\">ເຊື່ອງເນື້ອໃນຂອງຟິວໃນເອກະສານ.</ahelp> ຟິວຈະຖືກແຊກເປັນເຄື່ອງໝາຍສີເທົາບາງໆໃນເອກະສານ.</variable> ຕົວເລືອກນີ້ມີໃຫ້ໃຊ້ສະເພາະກັບປະເພດຟິວ \"ກຳນົດຕົວປ່ຽນ\" ແລະ \"ຟິວຜູ້ໃຊ້\" ເທົ່ານັ້ນ."

#. USeMu
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3146326\n"
"help.text"
msgid "With Heading Number"
msgstr "ພ້ອມດ້ວຍເລກຫົວຂໍ້"

#. irPyB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3146340\n"
"help.text"
msgid "Use this option to display a heading number before a “number range” field. The heading number comes from a heading prior to the location of the field."
msgstr "ໃຊ້ຕົວເລືອກນີ້ເພື່ອສະແດງເລກຫົວຂໍ້ກ່ອນຟິວ “ຊ່ວງຕົວເລກ”. ເລກຫົວຂໍ້ຈະມາຈາກຫົວຂໍ້ທີ່ຢູ່ກ່ອນຕຳແໜ່ງຂອງຟິວນັ້ນ."

#. mxcAB
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3147456\n"
"help.text"
msgid "Up to level"
msgstr "ເຖິງລະດັບ"

#. eDx3W
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3149836\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/level\">With typical use of headings in the document, the selected number will indicate how many levels of heading number (starting from level 1) to display.</ahelp> The selected value indicates the maximum number of levels to show. The actual number may have fewer levels. For example, if the immediately prior heading number is <literal>2.6</literal>, and <menuitem>4</menuitem> is selected, then only <literal>2.6</literal> is displayed . If <menuitem>[None]</menuitem> is selected, no heading number is displayed."
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/level\">ດ້ວຍການໃຊ້ຫົວຂໍ້ທົ່ວໄປໃນເອກະສານ, ຕົວເລກທີ່ເລືອກຈະບອກວ່າມີຈັກລະດັບຂອງເລກຫົວຂໍ້ (ເລີ່ມຈາກລະດັບ 1) ທີ່ຈະສະແດງ.</ahelp> ຄ່າທີ່ເລືອກຈະບອກຈຳນວນລະດັບສູງສຸດທີ່ຈະສະແດງ. ຕົວເລກຕົວຈິງອາດຈະມີລະດັບໜ້ອຍກວ່າ. ຕົວຢ່າງ: ຖ້າເລກຫົວຂໍ້ທີ່ຢູ່ກ່ອນໜ້ານັ້ນແມ່ນ <literal>2.6</literal>, ແລະ ເລືອກ <menuitem>4</menuitem>, ມັນກໍຈະສະແດງພຽງແຕ່ <literal>2.6</literal>. ຖ້າເລືອກ <menuitem>[ບໍ່ມີ]</menuitem>, ຈະບໍ່ມີເລກຫົວຂໍ້ສະແດງຜົນ."

#. qesfL
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3147594\n"
"help.text"
msgid "Separator"
msgstr "ຕົວຂັ້ນ"

#. UGEwR
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3148846\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/separator\">Specify the character to use as a separator between the heading number and the field number.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/separator\">ກຳນົດຕົວອັກສອນທີ່ຈະໃຊ້ເປັນຕົວຂັ້ນລະຫວ່າງເລກຫົວຂໍ້ ແລະ ເລກຟິວ.</ahelp>"

#. nT3WC
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id941584040174795\n"
"help.text"
msgid "<emph>With Heading Number</emph>, <emph>Up to level</emph> and <emph>Separator</emph> are only available for the “Number range” field type."
msgstr "<emph>ພ້ອມດ້ວຍເລກຫົວຂໍ້</emph>, <emph>ເຖິງລະດັບ</emph> ແລະ <emph>ຕົວຂັ້ນ</emph> ມີໃຫ້ໃຊ້ສະເພາະກັບປະເພດຟິວ “ຊ່ວງຕົວເລກ” ເທົ່ານັ້ນ."

#. u5c6E
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3147057\n"
"help.text"
msgid "Apply"
msgstr "ນຳໃຊ້"

#. 46bSG
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3155562\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/apply\">Adds the user-defined field to the <emph>Select</emph> list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/apply\">ເພີ່ມຟິວທີ່ກຳນົດເອງເຂົ້າໃນລາຍການ <emph>ເລືອກ</emph>.</ahelp>"

#. iaGUw
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"hd_id3151080\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. Cp5d2
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3154769\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/fldvarpage/delete\">Removes the user-defined field from the select list. You can only remove fields that are not used in the current document.</ahelp> To remove a field that is used in the current document from the list, first delete all instances of the field in the document, and then remove it from the list."
msgstr "<ahelp hid=\"modules/swriter/ui/fldvarpage/delete\">ລຶບຟິວທີ່ກຳນົດເອງອອກຈາກລາຍການເລືອກ. ທ່ານສາມາດລຶບໄດ້ສະເພາະຟິວທີ່ບໍ່ໄດ້ຖືກໃຊ້ໃນເອກະສານປັດຈຸບັນເທົ່ານັ້ນ.</ahelp> ເພື່ອລຶບຟິວທີ່ກຳລັງຖືກໃຊ້ຢູ່, ກ່ອນອື່ນທ່ານຕ້ອງລຶບຟິວນັ້ນອອກຈາກທຸກໆບ່ອນໃນເອກະສານກ່ອນ, ແລ້ວຈຶ່ງມາລຶບອອກຈາກລາຍການ."

#. TTtqT
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3145318\n"
"help.text"
msgid "<image id=\"img_id3153293\" src=\"svx/res/nu02.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153293\">Icon Delete</alt></image>"
msgstr "<image id=\"img_id3153293\" src=\"svx/res/nu02.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153293\">ໄອຄອນລຶບ</alt></image>"

#. mYecc
#: 04090005.xhp
msgctxt ""
"04090005.xhp\n"
"par_id3150169\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. mVhjg
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"tit\n"
"help.text"
msgid "Database"
msgstr "ຖານຂໍ້ມູນ"

#. 6ZiYE
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3153536\n"
"help.text"
msgid "<link href=\"text/swriter/01/04090006.xhp\">Database</link>"
msgstr "<link href=\"text/swriter/01/04090006.xhp\">ຖານຂໍ້ມູນ</link>"

#. B8JD8
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3154471\n"
"help.text"
msgid "<ahelp hid=\".\">You can insert fields from any database, for example, address fields, into your document.</ahelp>"
msgstr "<ahelp hid=\".\">ທ່ານສາມາດແຊກຟິວຈາກຖານຂໍ້ມູນໃດກໍໄດ້, ຕົວຢ່າງ: ຟິວທີ່ຢູ່, ເຂົ້າໃນເອກະສານຂອງທ່ານ.</ahelp>"

#. hAFUi
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id090220080439090\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the available field types. To add a field to your document, click a field type, click a field in the <emph>Select </emph>list, and then click <emph>Insert</emph>.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງລາຍການປະເພດຟິວທີ່ມີໃຫ້. ເພື່ອເພີ່ມຟິວເຂົ້າໃນເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກໃສ່ປະເພດຟິວ, ແລ້ວຄລິກໃສ່ຟິວໃນລາຍການ <emph>ເລືອກ</emph>, ຈາກນັ້ນຄລິກ <emph>ແຊກ</emph>.</ahelp>"

#. SF5Rx
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3154196\n"
"help.text"
msgid "Field type"
msgstr "ປະເພດຟິວ"

#. MHxBg
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3149484\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. Ahow2
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3149096\n"
"help.text"
msgid "Any Record"
msgstr "ລະບຽນໃດໜຶ່ງ"

#. B3GQn
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3151257\n"
"help.text"
msgid "Inserts the contents of the database field that you specify in the <emph>Record Number</emph> box as a mail merge field if the <link href=\"text/swriter/01/04090200.xhp\"><emph>Condition</emph></link> that you enter is met. Only records selected by a multiple selection in the data source view are considered."
msgstr "ແຊກເນື້ອໃນຂອງຟິວຖານຂໍ້ມູນທີ່ທ່ານກຳນົດໃນຫ້ອງ <emph>ເລກທີລະບຽນ</emph> ເປັນຟິວຈົດໝາຍວຽນ ຫາກກົງກັບ <link href=\"text/swriter/01/04090200.xhp\"><emph>ເງື່ອນໄຂ</emph></link> ທີ່ທ່ານປ້ອນ. ຈະພິຈາລະນາສະເພາະລະບຽນທີ່ຖືກເລືອກແບບຫຼາຍລາຍການໃນມຸມເບິ່ງແຫຼ່ງຂໍ້ມູນເທົ່ານັ້ນ."

#. abTaE
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3147100\n"
"help.text"
msgid "You can use this field to insert several records into a document. Simply insert the <emph>Any Record</emph> field in front of the form letter fields that use a certain record."
msgstr "ທ່ານສາມາດໃຊ້ຟິວນີ້ເພື່ອແຊກຫຼາຍລະບຽນເຂົ້າໃນເອກະສານດຽວ. ພຽງແຕ່ແຊກຟິວ <emph>ລະບຽນໃດໜຶ່ງ</emph> ໄວ້ທາງໜ້າຟິວຈົດໝາຍວຽນທີ່ໃຊ້ລະບຽນນັ້ນໆ."

#. FEURP
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3153632\n"
"help.text"
msgid "Database Name"
msgstr "ຊື່ຖານຂໍ້ມູນ"

#. DK49c
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3152776\n"
"help.text"
msgid "Inserts the name of the database table selected in the <emph>Database selection </emph>box. The \"Database Name\" field is a global field, that is, if you insert a different database name in your document, the contents of all previously inserted \"Database Name\" fields are updated."
msgstr "ແຊກຊື່ຂອງຕາຕະລາງຖານຂໍ້ມູນທີ່ເລືອກໃນຫ້ອງ <emph>ການເລືອກຖານຂໍ້ມູນ</emph>. ຟິວ \"ຊື່ຖານຂໍ້ມູນ\" ແມ່ນຟິວສ່ວນກາງ, ນັ້ນຄື ຖ້າທ່ານແຊກຊື່ຖານຂໍ້ມູນອື່ນໃນເອກະສານ, ເນື້ອໃນຂອງຟິວ \"ຊື່ຖານຂໍ້ມູນ\" ທັງໝົດທີ່ແຊກໄວ້ກ່ອນໜ້ານີ້ຈະຖືກອັບເດດນຳກັນ."

#. KSREY
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3149167\n"
"help.text"
msgid "Mail merge field"
msgstr "ຟິວຈົດໝາຍວຽນ"

#. frDFg
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3145779\n"
"help.text"
msgid "Inserts the name of a database field as a placeholder, so that you can create a mail merge document. The field content is automatically inserted when you print the form letter."
msgstr "ແຊກຊື່ຂອງຟິວຖານຂໍ້ມູນເປັນຕົວແທນບ່ອນວ່າງ, ເພື່ອໃຫ້ທ່ານສາມາດສ້າງເອກະສານຈົດໝາຍວຽນໄດ້. ເນື້ອໃນຂອງຟິວຈະຖືກແຊກໃຫ້ໂດຍອັດຕະໂນມັດເມື່ອທ່ານສັ່ງພິມຈົດໝາຍ."

#. avtjX
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3151372\n"
"help.text"
msgid "Next record"
msgstr "ລະບຽນຖັດໄປ"

#. iVBZu
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3150114\n"
"help.text"
msgid "Inserts the contents of the next mail merge field in your document, if the condition that you define is met. The records that you want to include must be selected in the data source view."
msgstr "ແຊກເນື້ອໃນຂອງຟິວຈົດໝາຍວຽນຖັດໄປໃນເອກະສານຂອງທ່ານ ຫາກກົງກັບເງື່ອນໄຂທີ່ທ່ານກຳນົດ. ລະບຽນທີ່ທ່ານຕ້ອງການລວມເຂົ້ານັ້ນຕ້ອງຖືກເລືອກໄວ້ໃນມຸມເບິ່ງແຫຼ່ງຂໍ້ມູນກ່ອນ."

#. Co9zg
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3155861\n"
"help.text"
msgid "You can use the \"Next record\" field to insert the contents of consecutive records between the mail merge fields in a document."
msgstr "ທ່ານສາມາດໃຊ້ຟິວ \"ລະບຽນຖັດໄປ\" ເພື່ອແຊກເນື້ອໃນຂອງລະບຽນທີ່ຕໍ່ເນື່ອງກັນລະຫວ່າງຟິວຈົດໝາຍວຽນໃນເອກະສານ."

#. B3Coy
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3147412\n"
"help.text"
msgid "Record number"
msgstr "ເລກທີລະບຽນ"

#. 8pCNM
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3147495\n"
"help.text"
msgid "Inserts the number of the selected database record."
msgstr "ແຊກໝາຍເລກຂອງລະບຽນຖານຂໍ້ມູນທີ່ຖືກເລືອກ."

#. NFRgf
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3149565\n"
"help.text"
msgid "Database Selection"
msgstr "ການເລືອກຖານຂໍ້ມູນ"

#. z5QsL
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3145268\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/select\">Select the database table or the database query that you want the field to refer to.</ahelp> You can include fields from more than one database or query in a document."
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/select\">ເລືອກຕາຕະລາງຖານຂໍ້ມູນ ຫຼື ຄຳສັ່ງສອບຖາມ (query) ທີ່ທ່ານຕ້ອງການໃຫ້ຟິວອ້າງອີງເຖິງ.</ahelp> ທ່ານສາມາດລວມຟິວຈາກຫຼາຍຖານຂໍ້ມູນ ຫຼື ຫຼາຍຄຳສັ່ງສອບຖາມເຂົ້າໃນເອກະສານດຽວໄດ້."

#. Wd3DA
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id0902200804391084\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">For fields linked to a condition, enter the criteria here.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສຳລັບຟິວທີ່ເຊື່ອມໂຍງກັບເງື່ອນໄຂ, ໃຫ້ປ້ອນເກນການຕັດສິນຢູ່ທີ່ນີ້.</ahelp>"

#. cUbyM
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3147739\n"
"help.text"
msgid "If you want, you can assign a condition that must be met before the contents of the \"Any Record\" and \"Next Record\" fields are inserted. The default condition is \"True\", that is, the condition is always true if you do not change the condition text."
msgstr "ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດກຳນົດເງື່ອນໄຂທີ່ຕ້ອງກົງກັນກ່ອນທີ່ເນື້ອໃນຂອງຟິວ \"ລະບຽນໃດໜຶ່ງ\" ແລະ \"ລະບຽນຖັດໄປ\" ຈະຖືກແຊກ. ເງື່ອນໄຂເລີ່ມຕົ້ນແມ່ນ \"True\" (ຈິງ), ຊຶ່ງໝາຍຄວາມວ່າເງື່ອນໄຂຈະເປັນຈິງສະເໝີຫາກທ່ານບໍ່ປ່ຽນແປງຂໍ້ຄວາມເງື່ອນໄຂ."

#. PUHJF
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3146336\n"
"help.text"
msgid "Record number"
msgstr "ເລກທີລະບຽນ"

#. LbYwQ
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3149836\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/recnumber\">Enter the number of the record that you want to insert when the condition that you specify is met.</ahelp> The record number corresponds to the current selection in the data source view. For example, if you select the last 5 records in a database containing 10 records, the number of the first record will be 1, and not 6."
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/recnumber\">ປ້ອນໝາຍເລກຂອງລະບຽນທີ່ທ່ານຕ້ອງການແຊກເມື່ອກົງກັບເງື່ອນໄຂທີ່ທ່ານກຳນົດ.</ahelp> ເລກທີລະບຽນຈະກົງກັບສິ່ງທີ່ເລືອກໃນມຸມເບິ່ງແຫຼ່ງຂໍ້ມູນ. ຕົວຢ່າງ: ຖ້າທ່ານເລືອກ 5 ລະບຽນສຸດທ້າຍໃນຖານຂໍ້ມູນທີ່ມີ 10 ລະບຽນ, ໝາຍເລກຂອງລະບຽນທຳອິດຈະແມ່ນ 1, ບໍ່ແມ່ນ 6."

#. 7gngC
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3153305\n"
"help.text"
msgid "If you refer to fields in a different database (or in a different table or query within the same database), $[officename] determines the record number relative to the current selection."
msgstr "ຫາກທ່ານອ້າງອີງເຖິງຟິວໃນຖານຂໍ້ມູນອື່ນ (ຫຼື ໃນຕາຕະລາງ/ຄຳສັ່ງສອບຖາມອື່ນພາຍໃນຖານຂໍ້ມູນດຽວກັນ), $[officename] ຈະກຳນົດເລກທີລະບຽນໂດຍທຽບກັບສິ່ງທີ່ເລືອກໃນປັດຈຸບັນ."

#. FBgdG
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3156109\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. JvPgr
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3156122\n"
"help.text"
msgid "Select the format of the field that you want to insert. This option is available for numerical, boolean, date and time fields."
msgstr "ເລືອກຮູບແບບຂອງຟິວທີ່ທ່ານຕ້ອງການແຊກ. ຕົວເລືອກນີ້ມີໃຫ້ສຳລັບຟິວຕົວເລກ, ຄ່າຄວາມຈິງ (boolean), ວັນທີ ແລະ ເວລາ."

#. HyEBd
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3150904\n"
"help.text"
msgid "From database"
msgstr "ຈາກຖານຂໍ້ມູນ"

#. 7nEtn
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3150922\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/fromdatabasecb\">Uses the format defined in the selected database.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/fromdatabasecb\">ໃຊ້ຮູບແບບທີ່ກຳນົດໄວ້ໃນຖານຂໍ້ມູນທີ່ເລືອກ.</ahelp>"

#. DKy6F
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_idN1076E\n"
"help.text"
msgid "Browse"
msgstr "ຊອກຫາ"

#. q4QAg
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_idN10772\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/browse\">Opens the Open dialog where you can select a database file (*.odb). The selected file is added to the Databases Selection list.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/browse\">ເປີດກ່ອງໂຕ້ຕອບການເປີດໄຟລ໌ເພື່ອໃຫ້ທ່ານເລືອກໄຟລ໌ຖານຂໍ້ມູນ (*.odb). ໄຟລ໌ທີ່ເລືອກຈະຖືກເພີ່ມເຂົ້າໃນລາຍການການເລືອກຖານຂໍ້ມູນ.</ahelp>"

#. BZDCz
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3155084\n"
"help.text"
msgid "User defined"
msgstr "ກຳນົດເອງ"

#. ukHtX
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3154333\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/flddbpage/userdefinedcb\">Applies the format that you select in the <emph>List of user-defined formats</emph>.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/flddbpage/userdefinedcb\">ນຳໃຊ້ຮູບແບບທີ່ທ່ານເລືອກໃນ <emph>ລາຍການຮູບແບບທີ່ກຳນົດເອງ</emph>.</ahelp>"

#. ZkpDF
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"hd_id3146948\n"
"help.text"
msgid "List of user-defined formats"
msgstr "ລາຍການຮູບແບບທີ່ກຳນົດເອງ"

#. cUEoB
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_id3150093\n"
"help.text"
msgid "<ahelp hid=\".\">Lists the available user-defined formats.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງລາຍການຮູບແບບທີ່ກຳນົດເອງທີ່ມີໃຫ້.</ahelp>"

#. UZajB
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_idN107FF\n"
"help.text"
msgid "Printing a form letter"
msgstr "ການພິມຈົດໝາຍວຽນ"

#. CkAyn
#: 04090006.xhp
msgctxt ""
"04090006.xhp\n"
"par_idN10803\n"
"help.text"
msgid "<ahelp hid=\".\">When you print a document that contains database fields, a dialog asks you if you want to print a form letter. If you answer Yes, the <link href=\"text/swriter/01/01150000.xhp\">Mail Merge</link> dialog opens where you can select the database records to print.</ahelp>"
msgstr "<ahelp hid=\".\">ເມື່ອທ່ານພິມເອກະສານທີ່ມີຟິວຖານຂໍ້ມູນ, ກ່ອງໂຕ້ຕອບຈະຖາມວ່າທ່ານຕ້ອງການພິມຈົດໝາຍວຽນຫຼືບໍ່. ຫາກທ່ານຕອບ ແມ່ນ, ກ່ອງໂຕ້ຕອບ <link href=\"text/swriter/01/01150000.xhp\">ຈົດໝາຍວຽນ</link> ຈະເປີດຂຶ້ນເພື່ອໃຫ້ທ່ານເລືອກລະບຽນຖານຂໍ້ມູນທີ່ຈະພິມ.</ahelp>"

#. 29FtT
