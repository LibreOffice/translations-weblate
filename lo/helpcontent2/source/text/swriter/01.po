"hd_id3153669\n"
"help.text"
msgid "Reference"
msgstr "ການອ້າງອີງ"

#. D7fsP
#: 04090100.xhp
msgctxt ""
"04090100.xhp\n"
"par_id3154571\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputfielddialog/text\">This box displays the name that you entered in the <emph>Reference</emph> box on the <emph>Functions</emph> or <emph>Variables</emph> tab of the <emph>Fields</emph> dialog. The box underneath displays the contents of the field.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/inputfielddialog/text\">ຫ້ອງນີ້ສະແດງຊື່ທີ່ທ່ານປ້ອນໃນຫ້ອງ <emph>ການອ້າງອີງ</emph> ໃນແທັບ <emph>ຟັງຊັນ</emph> ຫຼື <emph>ຕົວປ່ຽນ</emph> ຂອງກ່ອງໂຕ້ຕອບ <emph>ຟິວ</emph>. ຫ້ອງດ້ານລຸ່ມສະແດງເນື້ອໃນຂອງຟິວ.</ahelp>"

#. 4YeCA
#: 04090100.xhp
msgctxt ""
"04090100.xhp\n"
"hd_id3155897\n"
"help.text"
msgid "Next"
msgstr "ຕໍ່ໄປ"

#. nQfrA
#: 04090100.xhp
msgctxt ""
"04090100.xhp\n"
"par_id3149691\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/inputfielddialog/next\">Jumps to the next input field in the document.</ahelp> This button is only available when you position the cursor directly before an input field, and then press Shift+Ctrl+F9."
msgstr "<ahelp hid=\"modules/swriter/ui/inputfielddialog/next\">ໂດດໄປຫາຟິວປ້ອນຂໍ້ມູນຖັດໄປໃນເອກະສານ.</ahelp> ປຸ່ມນີ້ຈະມີໃຫ້ໃຊ້ເມື່ອທ່ານວາງເຄີເຊີໄວ້ທາງໜ້າຟິວປ້ອນຂໍ້ມູນໂດຍກົງ, ແລ້ວກົດ Shift+Ctrl+F9."

#. FoGW5
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"tit\n"
"help.text"
msgid "Defining Conditions"
msgstr "ການກຳນົດເງື່ອນໄຂ"

#. w6GFr
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"bm_id3145828\n"
"help.text"
msgid "<bookmark_value>logical expressions</bookmark_value>      <bookmark_value>formulating conditions</bookmark_value>      <bookmark_value>conditions; in fields and sections</bookmark_value>      <bookmark_value>fields;defining conditions</bookmark_value>      <bookmark_value>sections;defining conditions</bookmark_value>      <bookmark_value>variables; in conditions</bookmark_value>      <bookmark_value>user data;in conditions</bookmark_value>      <bookmark_value>databases;in conditions</bookmark_value>      <bookmark_value>hiding; database fields</bookmark_value>"
msgstr "<bookmark_value>ການສະແດງອອກທາງຕັກກະສາດ</bookmark_value>      <bookmark_value>ການສ້າງເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ເງື່ອນໄຂ; ໃນຟິວ ແລະ ສ່ວນ</bookmark_value>      <bookmark_value>ຟິວ; ການກຳນົດເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ສ່ວນ; ການກຳນົດເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ຕົວປ່ຽນ; ໃນເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ຂໍ້ມູນຜູ້ໃຊ້; ໃນເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ຖານຂໍ້ມູນ; ໃນເງື່ອນໄຂ</bookmark_value>      <bookmark_value>ການເຊື່ອງ; ຟິວຖານຂໍ້ມູນ</bookmark_value>"

#. bGg9p
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"hd_id3145828\n"
"help.text"
msgid "<variable id=\"defining_conditions\"><link href=\"text/swriter/01/04090200.xhp\">Defining Conditions</link></variable>"
msgstr "<variable id=\"defining_conditions\"><link href=\"text/swriter/01/04090200.xhp\">ການກຳນົດເງື່ອນໄຂ</link></variable>"

#. J8SYs
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3145242\n"
"help.text"
msgid "Conditions are logical expressions that you can use to control the display of <link href=\"text/swriter/01/04090000.xhp\">fields</link> and <link href=\"text/swriter/01/04020000.xhp\">sections</link> in your document. Although the following examples apply to fields, they also apply to sections."
msgstr "ເງື່ອນໄຂແມ່ນການສະແດງອອກທາງຕັກກະສາດທີ່ທ່ານສາມາດໃຊ້ເພື່ອຄວບຄຸມການສະແດງຜົນຂອງ <link href=\"text/swriter/01/04090000.xhp\">ຟິວ</link> ແລະ <link href=\"text/swriter/01/04020000.xhp\">ສ່ວນ</link> ໃນເອກະສານຂອງທ່ານ. ເຖິງແມ່ນວ່າຕົວຢ່າງຕໍ່ໄປນີ້ຈະໃຊ້ກັບຟິວ, ແຕ່ພວກມັນກໍສາມາດໃຊ້ກັບສ່ວນຕ່າງໆໄດ້ຄືກັນ."

#. kFVxj
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147171\n"
"help.text"
msgid "You can define conditions for the following field types:"
msgstr "ທ່ານສາມາດກຳນົດເງື່ອນໄຂສຳລັບປະເພດຟິວດັ່ງຕໍ່ໄປນີ້:"

#. uhYUE
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3151185\n"
"help.text"
msgid "Conditional text: displays text A if the condition is true, or text B if the condition is false."
msgstr "ຂໍ້ຄວາມແບບມີເງື່ອນໄຂ: ສະແດງຂໍ້ຄວາມ A ຖ້າເງື່ອນໄຂເປັນຈິງ, ຫຼື ສະແດງຂໍ້ຄວາມ B ຖ້າເງື່ອນໄຂເປັນເທັດ."

#. i5GC7
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3149289\n"
"help.text"
msgid "Hidden text: hides the contents of the field if the condition is true."
msgstr "ຂໍ້ຄວາມທີ່ເຊື່ອງໄວ້: ເຊື່ອງເນື້ອໃນຂອງຟິວຖ້າເງື່ອນໄຂເປັນຈິງ."

#. DovMC
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3145412\n"
"help.text"
msgid "Hidden paragraph: hides the paragraph if the condition is true."
msgstr "ຫຍໍ້ໜ້າທີ່ເຊື່ອງໄວ້: ເຊື່ອງຫຍໍ້ໜ້າຖ້າເງື່ອນໄຂເປັນຈິງ."

#. 23Bhj
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147515\n"
"help.text"
msgid "Any record and next record: controls the access to database records."
msgstr "ລະບຽນໃດໜຶ່ງ ແລະ ລະບຽນຖັດໄປ: ຄວບຄຸມການເຂົ້າເຖິງລະບຽນຖານຂໍ້ມູນ."

#. Rjj7J
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3149802\n"
"help.text"
msgid "The simplest way to define a condition is to type the logical expression directly in a <emph>Condition </emph>box using the following values:"
msgstr "ວິທີທີ່ງ່າຍທີ່ສຸດໃນການກຳນົດເງື່ອນໄຂແມ່ນການພິມການສະແດງອອກທາງຕັກກະສາດລົງໃນຫ້ອງ <emph>ເງື່ອນໄຂ</emph> ໂດຍໃຊ້ຄ່າດັ່ງຕໍ່ໄປນີ້:"

#. 8p96j
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3153677\n"
"help.text"
msgid "TRUE"
msgstr "TRUE (ຈິງ)"

#. jH4Z3
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3152960\n"
"help.text"
msgid "The condition is always met. You can also enter any value not equal to 0 as the conditional text."
msgstr "ເງື່ອນໄຂຈະຖືກຕ້ອງສະເໝີ. ທ່ານຍັງສາມາດປ້ອນຄ່າໃດໆກໍໄດ້ທີ່ບໍ່ເທົ່າກັບ 0 ເປັນຂໍ້ຄວາມເງື່ອນໄຂ."

#. bVhKR
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3155900\n"
"help.text"
msgid "FALSE"
msgstr "FALSE (ເທັດ)"

#. ZT8mx
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3154191\n"
"help.text"
msgid "The condition is not met. You can also enter the value 0."
msgstr "ເງື່ອນໄຂບໍ່ຖືກຕ້ອງ. ທ່ານຍັງສາມາດປ້ອນຄ່າ 0 ໄດ້."

#. hyaBZ
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147090\n"
"help.text"
msgid "If you leave the <emph>Condition </emph>box empty, the condition is interpreted as not being met."
msgstr "ຖ້າທ່ານປ່ອຍໃຫ້ຫ້ອງ <emph>ເງື່ອນໄຂ</emph> ວ່າງໄວ້, ເງື່ອນໄຂຈະຖືກຕີຄວາມໝາຍວ່າບໍ່ຖືກຕ້ອງ."

#. HyEVQ
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3148980\n"
"help.text"
msgid "When you define a condition, use the same <link href=\"text/swriter/02/14020000.xhp\">elements</link> for defining a formula, namely comparative operators, mathematical and statistical functions, number formats, variables and constants."
msgstr "ເມື່ອທ່ານກຳນົດເງື່ອນໄຂ, ໃຫ້ໃຊ້ <link href=\"text/swriter/02/14020000.xhp\">ອົງປະກອບ</link> ດຽວກັນກັບການກຳນົດສູດ, ເຊັ່ນ: ຕົວດຳເນີນການປຽບທຽບ, ຟັງຊັນທາງຄະນິດສາດ ແລະ ສະຖິຕິ, ຮູບແບບຕົວເລກ, ຕົວປ່ຽນ ແລະ ຄ່າຄົງທີ່."

#. xGZuG
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3153638\n"
"help.text"
msgid "You can use the following types of variables when you define a condition:"
msgstr "ທ່ານສາມາດໃຊ້ຕົວປ່ຽນປະເພດດັ່ງຕໍ່ໄປນີ້ເມື່ອທ່ານກຳນົດເງື່ອນໄຂ:"

#. ChwEN
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3155135\n"
"help.text"
msgid "Predefined <link href=\"text/swriter/02/14020000.xhp\">$[officename] variables</link> that use statistics on document properties"
msgstr "<link href=\"text/swriter/02/14020000.xhp\">ຕົວປ່ຽນຂອງ $[officename]</link> ທີ່ກຳນົດໄວ້ລ່ວງໜ້າ ເຊິ່ງໃຊ້ສະຖິຕິກ່ຽວກັບຄຸນສົມບັດຂອງເອກະສານ"

#. i4seA
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3156273\n"
"help.text"
msgid "Custom variables, that are a created with the \"Set variable\" field"
msgstr "ຕົວປ່ຽນກຳນົດເອງ, ເຊິ່ງສ້າງຂຶ້ນດ້ວຍຟິວ \"ກຳນົດຕົວປ່ຽນ\""

#. SSQFn
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3149174\n"
"help.text"
msgid "Variables based on user data"
msgstr "ຕົວປ່ຽນທີ່ອີງໃສ່ຂໍ້ມູນຜູ້ໃຊ້"

#. HjMGK
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3145781\n"
"help.text"
msgid "Variables based on the contents of database fields"
msgstr "ຕົວປ່ຽນທີ່ອີງໃສ່ເນື້ອໃນຂອງຟິວຖານຂໍ້ມູນ"

#. 4vRCr
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3155916\n"
"help.text"
msgid "You cannot use internal variables, such as page and chapter numbers, in condition expression."
msgstr "ທ່ານບໍ່ສາມາດໃຊ້ຕົວປ່ຽນພາຍໃນ, ເຊັ່ນ: ເລກໜ້າ ແລະ ເລກບົດ, ໃນການສະແດງອອກຂອງເງື່ອນໄຂໄດ້."

#. 8L4R9
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"hd_id3151375\n"
"help.text"
msgid "Conditions and Variables"
msgstr "ເງື່ອນໄຂ ແລະ ຕົວປ່ຽນ"

#. 7SFsW
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3150122\n"
"help.text"
msgid "The following examples use a variable called \"x\":"
msgstr "ຕົວຢ່າງຕໍ່ໄປນີ້ໃຊ້ຕົວປ່ຽນທີ່ຊື່ວ່າ \"x\":"

#. JQeFL
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147417\n"
"help.text"
msgid "x == 1 or x EQ 1"
msgstr "x == 1 ຫຼື x EQ 1"

#. JCgHz
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147500\n"
"help.text"
msgid "The condition is true if \"x\" is equal to 1."
msgstr "ເງື່ອນໄຂເປັນຈິງ ຖ້າ \"x\" ເທົ່າກັບ 1."

#. EAuFn
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3145259\n"
"help.text"
msgid "x != 1 or x NEQ 1"
msgstr "x != 1 ຫຼື x NEQ 1"

#. xhFp2
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3150551\n"
"help.text"
msgid "The condition is true if \"x\" does not equal 1."
msgstr "ເງື່ອນໄຂເປັນຈິງ ຖ້າ \"x\" ບໍ່ເທົ່າກັບ 1."

#. b4kQm
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3147749\n"
"help.text"
msgid "sinx == 0"
msgstr "sinx == 0"

#. xNMJB
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3146345\n"
"help.text"
msgid "The condition is true if \"x\" is a multiple of pi."
msgstr "ເງື່ອນໄຂເປັນຈິງ ຖ້າ \"x\" ເປັນຕົວຄູນຂອງ pi."

#. CYBa5
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3149846\n"
"help.text"
msgid "To use comparative operators with strings, the operands must be bounded by double quotation marks:"
msgstr "ເພື່ອໃຊ້ຕົວດຳເນີນການປຽບທຽບກັບຂໍ້ຄວາມ, ຄ່າທີ່ນຳມາປຽບທຽບຕ້ອງຢູ່ໃນເຄື່ອງໝາຍຄຳເວົ້າຄູ່:"

#. 48SNN
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3151078\n"
"help.text"
msgid "x == \"ABC\" or x EQ \"ABC\""
msgstr "x == \"ABC\" ຫຼື x EQ \"ABC\""

#. CvAqA
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3150162\n"
"help.text"
msgid "Checks if variable \"x\" contains (true) the \"ABC\" string, or not (false)."
msgstr "ກວດສອບວ່າຕົວປ່ຽນ \"x\" ປະກອບດ້ວຍຂໍ້ຄວາມ \"ABC\" (ຈິງ) ຫຼື ບໍ່ (ເທັດ)."

#. 23iCh
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3153301\n"
"help.text"
msgid "x == \"\" or x EQ \"\""
msgstr "x == \"\" ຫຼື x EQ \"\""

#. Eog2t
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3156120\n"
"help.text"
msgid "or"
msgstr "ຫຼື"

#. bdkAT
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3156133\n"
"help.text"
msgid "!x or NOT x"
msgstr "!x ຫຼື NOT x"

#. HZref
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3156112\n"
"help.text"
msgid "Checks if the variable \"x\" contains an empty string."
msgstr "ກວດສອບວ່າຕົວປ່ຽນ \"x\" ເປັນຂໍ້ຄວາມວ່າງຫຼືບໍ່."

#. qzHpM
#: 04090200.xhp
msgctxt ""
"04090200.xhp\n"
"par_id3150097\n"
"help.text"
msgid "The \"equal\" comparative operator must be represented by two equal signs (==) in a condition. For example, if you define a variable \"x\" with the value of 1, you can enter the condition as x==1."
msgstr "ຕົວດຳເນີນການປຽບທຽບ \"ເທົ່າກັບ\" ຕ້ອງໃຊ້ເຄື່ອງໝາຍເທົ່າກັບສອງອັນ (==) ໃນເງື່ອນໄຂ. ຕົວຢ່າງ: ຖ້າທ່ານກຳນົດຕົວປ່ຽນ \"x\" ໃຫ້ມີຄ່າ 1, ທ່ານສາມາດປ້ອນເງື່ອນໄຂເປັນ x==1."

