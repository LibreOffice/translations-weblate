msgctxt ""
"05040700.xhp\n"
"tit\n"
"help.text"
msgid "Footnotes/Endnotes"
msgstr "ເຊິງອັດ/ໝາຍເຫດທ້າຍເລື່ອງ"

#. 3WhwZ
#: 05040700.xhp
msgctxt ""
"05040700.xhp\n"
"hd_id3149028\n"
"help.text"
msgid "<variable id=\"fussendnotenh1\"><link href=\"text/swriter/01/05040700.xhp\">Footnotes/Endnotes</link></variable>"
