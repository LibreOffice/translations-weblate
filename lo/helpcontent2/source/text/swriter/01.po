#. Cj4Xa
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"hd_id3153677\n"
"help.text"
msgid "Blank lines"
msgstr "ແຖວຫວ່າງເປົ່າ"

#. QCDRC
#: 06180000.xhp
msgctxt ""
"06180000.xhp\n"
"par_id3150973\n"
"help.text"
