#. Ttu5Y
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3153693\n"
"help.text"
msgid "<emph>Move up</emph>. Move the active paragraph or selected paragraphs up one paragraph."
msgstr "<emph>ຍ້າຍຂຶ້ນ</emph>. ຍ້າຍຫຍໍ້ໜ້າທີ່ກຳລັງເຮັດວຽກ ຫຼື ຫຍໍ້ໜ້າທີ່ເລືອກຂຶ້ນໄປໜຶ່ງຫຍໍ້ໜ້າ."

#. SBqVR
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3153679\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command+Option</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+Up Arrow"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command+Option</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+ລູກສອນຂຶ້ນ"

#. CYuBA
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154639\n"
"help.text"
msgid "<emph>Move down</emph>. Move the active paragraph or selected paragraphs down one paragraph."
msgstr "<emph>ຍ້າຍລົງ</emph>. ຍ້າຍຫຍໍ້ໜ້າທີ່ກຳລັງເຮັດວຽກ ຫຼື ຫຍໍ້ໜ້າທີ່ເລືອກລົງໄປໜຶ່ງຫຍໍ້ໜ້າ."

#. F7h8g
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3153712\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command+Option</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+Down Arrow"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command+Option</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+ລູກສອນລົງ"

#. 9Y84A
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154672\n"
"help.text"
msgid "<emph>Move level down</emph>. With the cursor positioned in front of a paragraph with paragraph style “Heading X” (X = 1–9), the outline level is moved down one level. For list paragraphs, the list level is moved down one level."
msgstr "<emph>ຍ້າຍລະດັບລົງ</emph>. ເມື່ອວາງເຄີເຊີໄວ້ທາງໜ້າຫຍໍ້ໜ້າທີ່ມີຮູບແບບ “ຫົວຂໍ້ X” (X = 1-9), ລະດັບເຄົ້າຮ່າງຈະຖືກຍ້າຍລົງໜຶ່ງລະດັບ. ສຳລັບລາຍການຫຍໍ້ໜ້າ, ລະດັບລາຍການຈະຖືກຍ້າຍລົງໜຶ່ງລະດັບ."

#. nt4tL
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154658\n"
"help.text"
msgid "Tab"
msgstr "Tab"

#. M7Ghv
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3155346\n"
"help.text"
msgid "<emph>Move level up</emph>. With the cursor positioned in front of a paragraph with paragraph style “Heading X” (X = 2–10), the outline level is moved up one level. For list paragraphs, the list level is moved up one level."
msgstr "<emph>ຍ້າຍລະດັບຂຶ້ນ</emph>. ເມື່ອວາງເຄີເຊີໄວ້ທາງໜ້າຫຍໍ້ໜ້າທີ່ມີຮູບແບບ “ຫົວຂໍ້ X” (X = 2-10), ລະດັບເຄົ້າຮ່າງຈະຖືກຍ້າຍຂຶ້ນໜຶ່ງລະດັບ. ສຳລັບລາຍການຫຍໍ້ໜ້າ, ລະດັບລາຍການຈະຖືກຍ້າຍຂຶ້ນໜຶ່ງລະດັບ."

#. AuZkE
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154695\n"
"help.text"
msgid "Shift+Tab"
msgstr "Shift+Tab"

#. gttcL
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"bm_id3155395\n"
"help.text"
msgid "<bookmark_value>tab stops; before headings</bookmark_value><bookmark_value>headings; starting with tab stops</bookmark_value>"
msgstr "<bookmark_value>ຕຳແໜ່ງແທັບ; ທາງໜ້າຫົວຂໍ້</bookmark_value><bookmark_value>ຫົວຂໍ້; ເລີ່ມຕົ້ນດ້ວຍຕຳແໜ່ງແທັບ</bookmark_value>"

#. PCe3i
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3155395\n"
"help.text"
msgid "<emph>Increase alignment</emph>. With the cursor placed anywhere in a heading or list paragraph: Increases the alignment for all headings. For list paragraphs, increases the alignment for all paragraphs in the same list."
msgstr "<emph>ເພີ່ມການຍໍ້ໜ້າ</emph>. ເມື່ອວາງເຄີເຊີໄວ້ບ່ອນໃດກໍຕາມໃນຫົວຂໍ້ ຫຼື ລາຍການຫຍໍ້ໜ້າ: ຈະເພີ່ມການຍໍ້ໜ້າສຳລັບທຸກຫົວຂໍ້. ສຳລັບລາຍການຫຍໍ້ໜ້າ, ຈະເພີ່ມການຍໍ້ໜ້າສຳລັບທຸກຫຍໍ້ໜ້າໃນລາຍການດຽວກັນ."

#. TL5GS
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3155369\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Tab"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Tab"

#. A6kX6
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id71655381890029\n"
"help.text"
msgid "<emph>Decrease alignment</emph>. With the cursor placed anywhere in a heading or list paragraph: Decreases the alignment for all headings. For list paragraphs, decreases the alignment for all paragraphs in the same list."
msgstr "<emph>ຫຼຸດການຍໍ້ໜ້າ</emph>. ເມື່ອວາງເຄີເຊີໄວ້ບ່ອນໃດກໍຕາມໃນຫົວຂໍ້ ຫຼື ລາຍການຫຍໍ້ໜ້າ: ຈະຫຼຸດການຍໍ້ໜ້າສຳລັບທຸກຫົວຂໍ້. ສຳລັບລາຍການຫຍໍ້ໜ້າ, ຈະຫຼຸດການຍໍ້ໜ້າສຳລັບທຸກຫຍໍ້ໜ້າໃນລາຍການດຽວກັນ."

#. HKCQQ
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id491655382453027\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+Tab"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+Tab"

#. YDhXD
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id491655382900210\n"
"help.text"
msgid "To insert a tab at the beginning of a heading or list paragraph, use the <menuitem>Numbering followed by</menuitem> option in the <link href=\"text/shared/01/06050600.xhp\"><menuitem>Position</menuitem></link> tab in the <menuitem>Heading Numbering</menuitem> or <menuitem>Bullets and Numbering</menuitem> dialog. Alternatively, a tab can be copied and then pasted at the beginning."
msgstr "ເພື່ອແຊກແທັບຢູ່ຕົ້ນຫົວຂໍ້ ຫຼື ລາຍການຫຍໍ້ໜ້າ, ໃຫ້ໃຊ້ຕົວເລືອກ <menuitem>ລຳດັບເລກຕາມດ້ວຍ</menuitem> ໃນແທັບ <link href=\"text/shared/01/06050600.xhp\"><menuitem>ຕຳແໜ່ງ</menuitem></link> ໃນກ່ອງໂຕ້ຕອບ <menuitem>ລຳດັບເລກຫົວຂໍ້</menuitem> ຫຼື <menuitem>ເຄື່ອງໝາຍຫົວຂໍ້ ແລະ ລຳດັບເລກ</menuitem>. ນອກຈາກນັ້ນ, ທ່ານຍັງສາມາດສຳເນົາແທັບແລ້ວນຳມາວາງໃສ່ທາງໜ້າໄດ້."

#. J9mpa
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149180\n"
"help.text"
msgid "<variable id=\"keystables\"><link href=\"text/swriter/04/01020000.xhp#keystables\">Shortcut Keys for Tables in %PRODUCTNAME Writer</link></variable>"
msgstr "<variable id=\"keystables\"><link href=\"text/swriter/04/01020000.xhp#keystables\">ປຸ່ມລັດສຳລັບຕາຕະລາງໃນ %PRODUCTNAME Writer</link></variable>"

#. Xg6dB
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id781762974569404\n"
"help.text"
msgid "<emph>Insert paragraph</emph>. Inserts a new paragraph directly before or after table. The cursor must be placed at the first character of the first cell or the last character of the last cell."
msgstr "<emph>ແຊກຫຍໍ້ໜ້າ</emph>. ແຊກຫຍໍ້ໜ້າໃໝ່ໃສ່ທາງໜ້າ ຫຼື ທາງຫຼັງຕາຕະລາງໂດຍກົງ. ເຄີເຊີຈະຕ້ອງຖືກວາງໄວ້ທີ່ອັກຂະລະທຳອິດຂອງຫ້ອງທຳອິດ ຫຼື ອັກຂະລະສຸດທ້າຍຂອງຫ້ອງສຸດທ້າຍ."

#. SV6ED
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id361762974569404\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Options</keycode></caseinline><defaultinline><keycode>Alt</keycode></defaultinline></switchinline><keycode> + Enter</keycode>"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Options</keycode></caseinline><defaultinline><keycode>Alt</keycode></defaultinline></switchinline><keycode> + Enter</keycode>"

#. NEAD3
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3156048\n"
"help.text"
msgid "<emph>Selects all</emph>. If the active cell is empty: selects the whole table. Otherwise: selects the contents of the active cell. Pressing again selects the entire table."
msgstr "<emph>ເລືອກທັງໝົດ</emph>. ຫາກຫ້ອງທີ່ກຳລັງເຮັດວຽກນັ້ນຫວ່າງເປົ່າ: ຈະເລືອກທັງໝົດຕາຕະລາງ. ຖ້າບໍ່ດັ່ງນັ້ນ: ຈະເລືອກເນື້ອໃນຂອງຫ້ອງທີ່ກຳລັງເຮັດວຽກ. ການກົດອີກຄັ້ງຈະເລືອກທັງໝົດຕາຕະລາງ."

#. TiSKB
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3156014\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+A"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+A"

#. NhnFD
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154285\n"
"help.text"
msgid "<emph>Go to beginning</emph>.If the active cell is empty: goes to the beginning of the table. Otherwise: first press goes to beginning of the active cell, second press goes to beginning of the current table, third press goes to beginning of document."
msgstr "<emph>ໄປຫາຈຸດເລີ່ມຕົ້ນ</emph>. ຫາກຫ້ອງທີ່ກຳລັງເຮັດວຽກຫວ່າງເປົ່າ: ຈະໄປຫາຕົ້ນຕາຕະລາງ. ຖ້າບໍ່ດັ່ງນັ້ນ: ການກົດຄັ້ງທຳອິດຈະໄປຫາຕົ້ນຫ້ອງທີ່ກຳລັງເຮັດວຽກ, ຄັ້ງທີສອງຈະໄປຫາຕົ້ນຕາຕະລາງປັດຈຸບັນ, ແລະ ຄັ້ງທີສາມຈະໄປຫາຕົ້ນເອກະສານ."

#. 9CzVw
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3156069\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Home"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Home"

#. Tn5QR
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154334\n"
"help.text"
msgid "<emph>Go to end</emph>. If the active cell is empty: goes to the end of the table. Otherwise: first press goes to the end of the active cell, second press goes to the end of the current table, third press goes to the end of the document."
msgstr "<emph>ໄປຫາຈຸດສິ້ນສຸດ</emph>. ຫາກຫ້ອງທີ່ກຳລັງເຮັດວຽກຫວ່າງເປົ່າ: ຈະໄປຫາທ້າຍຕາຕະລາງ. ຖ້າບໍ່ດັ່ງນັ້ນ: ການກົດຄັ້ງທຳອິດຈະໄປຫາທ້າຍຫ້ອງທີ່ກຳລັງເຮັດວຽກ, ຄັ້ງທີສອງຈະໄປຫາທ້າຍຕາຕະລາງປັດຈຸບັນ, ແລະ ຄັ້ງທີສາມຈະໄປຫາທ້າຍເອກະສານ."

#. WBHQy
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154308\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+End"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+End"

#. ot9WQ
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3153281\n"
"help.text"
msgid "<emph>Inserts a tab stop</emph> (only in tables). Depending on the Window Manager in use, <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Tab may be used instead."
msgstr "<emph>ແຊກຕຳແໜ່ງແທັບ</emph> (ສະເພາະໃນຕາຕະລາງ). ອີງຕາມຕົວຈັດການປ່ອງຢ້ຽມທີ່ໃຊ້ຢູ່, ທ່ານອາດຈະໃຊ້ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Tab ແທນກໍໄດ້."

#. RGzSL
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3153255\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Tab"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Tab"

#. 8LmCh
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154931\n"
"help.text"
msgid "<emph>Size of column/row at the end</emph>. Increases/decreases the size of the column/row on the right/bottom cell edge"
msgstr "<emph>ຂະໜາດຂອງຄໍລຳ/ແຖວ ຢູ່ສ່ວນທ້າຍ</emph>. ເພີ່ມ/ຫຼຸດ ຂະໜາດຂອງຄໍລຳ/ແຖວ ຢູ່ຂອບຂ້າງຂວາ/ຂ້າງລຸ່ມ ຂອງຫ້ອງ."

#. khtQJ
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154905\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Arrow Keys"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+ປຸ່ມລູກສອນ"

#. bMxqs
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3150772\n"
"help.text"
msgid "<emph>Size of column/row at the beginning</emph>. Increase/decrease the size of the column/row on the left/top cell edge"
msgstr "<emph>ຂະໜາດຂອງຄໍລຳ/ແຖວ ຢູ່ສ່ວນຕົ້ນ</emph>. ເພີ່ມ/ຫຼຸດ ຂະໜາດຂອງຄໍລຳ/ແຖວ ຢູ່ຂອບຂ້າງຊ້າຍ/ຂ້າງເທິງ ຂອງຫ້ອງ."

#. tZNBA
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154951\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Shift+Arrow Keys"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Shift+ປຸ່ມລູກສອນ"

#. cs4En
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3150818\n"
"help.text"
msgid "Like <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, but only the active cell is modified"
msgstr "ຄືກັນກັບ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, ແຕ່ຈະມີຜົນປ່ຽນແປງສະເພາະຫ້ອງທີ່ກຳລັງເຮັດວຽກຢູ່ເທົ່ານັ້ນ."

#. bvA38
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3150793\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option+Command</caseinline><defaultinline>Alt+Ctrl</defaultinline></switchinline>+Arrow Keys"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option+Command</caseinline><defaultinline>Alt+Ctrl</defaultinline></switchinline>+ປຸ່ມລູກສອນ"

#. DEEkg
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3154477\n"
"help.text"
msgid "Like <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, but only the active cell is modified"
msgstr "ຄືກັນກັບ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>, ແຕ່ຈະມີຜົນປ່ຽນແປງສະເພາະຫ້ອງທີ່ກຳລັງເຮັດວຽກຢູ່ເທົ່ານັ້ນ."

#. jF3cF
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3154451\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option+Command</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+Shift+Arrow Keys"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option+Command</caseinline><defaultinline>Ctrl+Alt</defaultinline></switchinline>+Shift+ປຸ່ມລູກສອນ"

#. oPEfV
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3147474\n"
"help.text"
msgid "<emph>Cell protection</emph>. Removes cell protection from all selected tables. If no table is selected, then cell protection is removed from all of the tables in the document."
msgstr "<emph>ການປ້ອງກັນຫ້ອງ</emph>. ຍົກເລີກການປ້ອງກັນຫ້ອງຈາກທຸກຕາຕະລາງທີ່ເລືອກ. ຫາກບໍ່ມີການເລືອກຕາຕະລາງ, ການປ້ອງກັນຫ້ອງຈະຖືກຍົກເລີກອອກຈາກທຸກຕາຕະລາງໃນເອກະສານ."

#. xGCUp
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"bm_id3155593\n"
"help.text"
msgid "<bookmark_value>removing; cell protection in text documents</bookmark_value>"
msgstr "<bookmark_value>ການຍົກເລີກ; ການປ້ອງກັນຫ້ອງໃນເອກະສານຂໍ້ຄວາມ</bookmark_value>"

#. XksMw
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3155593\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+T"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+T"

#. ZBM6a
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id821762974242631\n"
"help.text"
msgid "<emph>Delete contents</emph>"
msgstr "<emph>ລຶບເນື້ອໃນ</emph>"

#. DDBvE
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3149504\n"
"help.text"
msgid "If no whole cell is selected, the text from the cursor to the end of the current sentence is deleted. If the cursor is at the end of a cell, and no whole cell is selected, the contents of the next cell are deleted."
msgstr "ຫາກບໍ່ມີການເລືອກທັງໝົດຫ້ອງ, ຂໍ້ຄວາມຕັ້ງແຕ່ເຄີເຊີໄປຫາທ້າຍປະໂຫຍກປັດຈຸບັນຈະຖືກລຶບ. ຫາກເຄີເຊີຢູ່ທ້າຍຫ້ອງ ແລະ ບໍ່ມີການເລືອກທັງໝົດຫ້ອງ, ເນື້ອໃນຂອງຫ້ອງຖັດໄປຈະຖືກລຶບ."

#. HPovX
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id8539384\n"
"help.text"
msgid "If no whole cell is selected and the cursor is at the end of the table, the paragraph following the table will be deleted, unless it is the last paragraph in the document."
msgstr "ຫາກບໍ່ມີການເລືອກທັງໝົດຫ້ອງ ແລະ ເຄີເຊີຢູ່ທ້າຍຕາຕະລາງ, ຫຍໍ້ໜ້າທີ່ຕາມຫຼັງຕາຕະລາງຈະຖືກລຶບ, ຍົກເວັ້ນແຕ່ວ່າມັນເປັນຫຍໍ້ໜ້າສຸດທ້າຍໃນເອກະສານ."

#. 5npCj
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id5891903\n"
"help.text"
msgid "If one or more cells are selected, the whole rows containing the selection will be deleted. If all rows are selected completely or partially, the entire table will be deleted."
msgstr "ຫາກເລືອກໜຶ່ງຫ້ອງ ຫຼື ຫຼາຍກວ່ານັ້ນ, ທຸກແຖວທີ່ມີການເລືອກຈະຖືກລຶບ. ຫາກເລືອກທຸກແຖວບໍ່ວ່າຈະເລືອກທັງໝົດ ຫຼື ບາງສ່ວນ, ທັງໝົດຕາຕະລາງຈະຖືກລຶບ."

#. YXuHn
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3147496\n"
"help.text"
msgid "Shift+<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Del"
msgstr "Shift+<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Del"

#. D3BNY
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id561762975449132\n"
"help.text"
msgid "<variable id=\"sections\"><link href=\"text/swriter/04/01020000.xhp#sections\">Shortcut Keys for Sections</link></variable>"
msgstr "<variable id=\"sections\"><link href=\"text/swriter/04/01020000.xhp#sections\">ປຸ່ມລັດສຳລັບສ່ວນຕ່າງໆ</link></variable>"

#. Z33cD
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id181762975491903\n"
"help.text"
msgid "<emph>Insert paragraph</emph>. Inserts a new paragraph directly before or after the section. The cursor must be placed at the first character of the section or the last character of the section."
msgstr "<emph>ແຊກຫຍໍ້ໜ້າ</emph>. ແຊກຫຍໍ້ໜ້າໃໝ່ໃສ່ທາງໜ້າ ຫຼື ທາງຫຼັງຂອງສ່ວນນັ້ນໂດຍກົງ. ເຄີເຊີຈະຕ້ອງຖືກວາງໄວ້ທີ່ອັກຂະລະທຳອິດ ຫຼື ອັກຂະລະສຸດທ້າຍຂອງສ່ວນນັ້ນ."

#. ekkGQ
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id311762975491903\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Options</keycode></caseinline><defaultinline><keycode>Alt</keycode></defaultinline></switchinline><keycode> + Enter</keycode>"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Options</keycode></caseinline><defaultinline><keycode>Alt</keycode></defaultinline></switchinline><keycode> + Enter</keycode>"

#. eFxzW
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149537\n"
"help.text"
msgid "<variable id=\"keysframes\"><link href=\"text/swriter/04/01020000.xhp#keysframes\">Shortcut Keys for Moving and Resizing Frames, Graphics and Objects</link></variable>"
msgstr "<variable id=\"keysframes\"><link href=\"text/swriter/04/01020000.xhp#keysframes\">ປຸ່ມລັດສຳລັບການຍ້າຍ ແລະ ການປ່ຽນຂະໜາດເຟຣມ, ຮູບພາບ ແລະ ວັດຖຸ</link></variable>"

#. DqEaP
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3148993\n"
"help.text"
msgid "Effect"
msgstr "ຜົນທີ່ໄດ້ຮັບ"

#. xhxzZ
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149565\n"
"help.text"
msgid "Shortcut Keys"
msgstr "ປຸ່ມລັດ"

#. 2Rxbk
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3149024\n"
"help.text"
msgid "Cursor is inside a frame and no text is selected: Escape selects the frame."
msgstr "ເຄີເຊີຢູ່ພາຍໃນເຟຣມ ແລະ ບໍ່ມີການເລືອກຂໍ້ຄວາມ: Escape ຈະເລືອກເຟຣມ."

#. 9B5YD
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3149039\n"
"help.text"
msgid "Frame is selected: Escape clears the cursor from the frame."
msgstr "ເມື່ອເຟຣມຖືກເລືອກ: Escape ຈະຍົກເລີກການວາງເຄີເຊີອອກຈາກເຟຣມ."

#. zirpM
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149010\n"
"help.text"
msgid "Esc"
msgstr "Esc"

#. 3dnSh
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3149890\n"
"help.text"
msgid "If a frame is selected: positions the cursor to the end of the text in the frame. If you press any key that produces a character on screen, and the document is in edit mode, the character is appended to the text."
msgstr "ຫາກເລືອກເຟຣມ: ຈະວາງເຄີເຊີໄວ້ທີ່ສ່ວນທ້າຍຂອງຂໍ້ຄວາມໃນເຟຣມ. ຫາກທ່ານກົດປຸ່ມໃດໜຶ່ງທີ່ສະແດງອັກຂະລະໃນໜ້າຈໍ, ແລະ ເອກະສານຢູ່ໃນໂໝດແກ້ໄຂ, ອັກຂະລະນັ້ນຈະຖືກເພີ່ມເຂົ້າໃສ່ຂໍ້ຄວາມ."

#. aCq7z
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149054\n"
"help.text"
msgid "F2 or Enter or any key that produces a character on screen"
msgstr "F2 ຫຼື Enter ຫຼື ປຸ່ມໃດໜຶ່ງທີ່ສະແດງອັກຂະລະໃນໜ້າຈໍ"

#. pTvHe
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3149939\n"
"help.text"
msgid "Move object."
msgstr "ຍ້າຍວັດຖຸ."

#. EHxBu
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"hd_id3149913\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+Arrow Keys"
msgstr "<switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline>+ປຸ່ມລູກສອນ"

#. e5FsB
#: 01020000.xhp
msgctxt ""
"01020000.xhp\n"
"par_id3151226\n"
