msgctxt ""
"03020201.xhp\n"
"par_id3149411\n"
"help.text"
msgid "Seek #iNumber,1 ' Position at beginning"
msgstr "Seek #iNumber,1 ' ໄປທີ່ຕຳແໜ່ງເລີ່ມຕົ້ນ"

#. ZgEGn
