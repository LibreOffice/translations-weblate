msgctxt ""
"03120111.xhp\n"
"par_id3148797\n"
"help.text"
msgid "Print AscW(string:=\"Ω\") ' returns 937"
msgstr "Print AscW(string:=\"Ω\") ' ສົ່ງຄືນ 937"

#. KNmoP
#: 03120111.xhp
msgctxt ""
"03120111.xhp\n"
"par_id3163800\n"
"help.text"
msgid "Print AscW(\"Αθήνα\") ' returns 913, since only the first character (Alpha) is taken into account"
msgstr "Print AscW(\"Αθήνα\") ' ສົ່ງຄືນ 913, ເນື່ອງຈາກພິຈາລະນາສະເພາະຕົວອັກສອນທຳອິດ (Alpha) ເທົ່ານັ້ນ"

