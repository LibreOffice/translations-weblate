msgctxt ""
"01170101.xhp\n"
"par_id3145298\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to add spin buttons to a numerical, currency, date, or time control to allow increasing and decreasing the input value using arrow buttons.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອເພີ່ມປຸ່ມໝຸນໃຫ້ກັບການຄວບຄຸມຕົວເລກ, ສະກຸນເງິນ, ວັນທີ ຫຼື ເວລາ ເພື່ອອະນຸຍາດໃຫ້ເພີ່ມ ແລະ ຫຼຸດຄ່າທີ່ປ້ອນເຂົ້າໂດຍໃຊ້ປຸ່ມລູກສອນ.</ahelp>"

