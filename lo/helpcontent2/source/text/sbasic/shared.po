"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to make the current button control the default selection. Pressing <emph>Return</emph> in the dialog activates the default button.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອເຮັດໃຫ້ປຸ່ມປັດຈຸບັນເປັນຕົວເລືອກເລີ່ມຕົ້ນ. ການກົດ <emph>Return</emph> ໃນໄດອາລັອກຈະເປັນການເປີດໃຊ້ງານປຸ່ມເລີ່ມຕົ້ນນັ້ນ.</ahelp>"

#. bsDNs
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN108BA\n"
"help.text"
msgid "Delay"
msgstr "ການໜ່ວງເວລາ (Delay)"

#. UGWJG
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN108D0\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the delay in milliseconds between scrollbar trigger events.</ahelp> A trigger event occurs when you click a scrollbar arrow or click the background area in a scrollbar. Repeated trigger events occur if you keep the mouse button pressed when you click a scrollbar arrow or background area in a scrollbar. If you want, you can include valid time units with the number that you enter, for example, 2 s or 500 ms."
msgstr "<ahelp hid=\".\">ກຳນົດການໜ່ວງເວລາເປັນມິນລິວິນາທີ ລະຫວ່າງເຫດການກະຕຸ້ນຂອງແຖບເລື່ອນ.</ahelp> ເຫດການກະຕຸ້ນຈະເກີດຂຶ້ນເມື່ອທ່ານຄລິກລູກສອນແຖບເລື່ອນ ຫຼື ຄລິກພື້ນທີ່ພື້ນຫຼັງໃນແຖບເລື່ອນ. ເຫດການກະຕຸ້ນທີ່ເກີດຂຶ້ນຊ້ຳໆຈະເກີດຂຶ້ນ ຖ້າທ່ານກົດປຸ່ມເມົ້າຄ້າງໄວ້ເມື່ອຄລິກລູກສອນແຖບເລື່ອນ ຫຼື ພື້ນທີ່ພື້ນຫຼັງ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດໃສ່ຫົວໜ່ວຍເວລາທີ່ຖືກຕ້ອງລວມກັບຕົວເລກທີ່ທ່ານປ້ອນ, ຕົວຢ່າງ 2 s ຫຼື 500 ms."

#. jFKSh
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3151278\n"
"help.text"
msgid "Dropdown"
msgstr "ລາຍການແບບເລື່ອນລົງ (Dropdown)"

#. Cip9s
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155113\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to enable the dropdown option for list or combo box controls. A dropdown control field has an arrow button which you can click to open a list of the existing form entries.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອເປີດໃຊ້ງານຕົວເລືອກ Dropdown ສຳລັບການຄວບຄຸມລາຍການ ຫຼື ຄອມໂບ້ບັອກ. ຟີວການຄວບຄຸມແບບ Dropdown ຈະມີປຸ່ມລູກສອນເຊິ່ງທ່ານສາມາດຄລິກເພື່ອເປີດລາຍການຂອງຂໍ້ມູນຟອມທີ່ມີຢູ່ໄດ້.</ahelp>"

#. tCz4B
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3151216\n"
"help.text"
msgid "Enabled"
msgstr "ເປີດໃຊ້ງານ"

#. t4GJD
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3150517\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to enable the control. If the control is disabled, it is grayed out in the dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອເປີດໃຊ້ງານການຄວບຄຸມ. ຖ້າການຄວບຄຸມຖືກປິດໃຊ້ງານ, ມັນຈະຖືກສະແດງເປັນສີເທົາໃນໄດອາລັອກ.</ahelp>"

#. M7AWe
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3155379\n"
"help.text"
msgid "Edit mask"
msgstr "ຫນ້າກາກການແກ້ໄຂ (Edit mask)"

#. X3nvF
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155509\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the edit mask for a pattern control. This is a character code that defines the input format for the control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດ Edit mask ສຳລັບການຄວບຄຸມຮູບແບບ (Pattern control). ນີ້ແມ່ນລະຫັດຕົວອັກສອນທີ່ກຳນົດຮູບແບບການປ້ອນຂໍ້ມູນສຳລັບການຄວບຄຸມ.</ahelp>"

#. B7JzP
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154485\n"
"help.text"
msgid "You need to specify a masking character for each input character of the edit mask to restrict the input to the values that are listed in the following table:"
msgstr "ທ່ານຈຳເປັນຕ້ອງກຳນົດຕົວອັກສອນ Masking ສຳລັບແຕ່ລະຕົວອັກສອນທີ່ປ້ອນເຂົ້າຂອງ Edit mask ເພື່ອຈຳກັດການປ້ອນຂໍ້ມູນໃຫ້ເປັນຄ່າທີ່ລະບຸໄວ້ໃນຕາຕະລາງຕໍ່ໄປນີ້:"

#. AicCo
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155809\n"
"help.text"
msgid "Character"
msgstr "ຕົວອັກສອນ"

#. 7B8iu
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3148702\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. qAQoQ
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3148869\n"
"help.text"
msgid "A text constant. This character cannot be modified by the user."
msgstr "ຄ່າຄົງທີ່ຂອງຂໍ້ຄວາມ. ຕົວອັກສອນນີ້ຜູ້ໃຊ້ບໍ່ສາມາດແກ້ໄຂໄດ້."

#. yEwjE
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3157983\n"
"help.text"
msgid "The characters a-z can be entered here. If a capital letter is entered, it is automatically converted to a lowercase letter."
msgstr "ສາມາດປ້ອນຕົວອັກສອນ a-z ທີ່ນີ້. ຖ້າປ້ອນຕົວພິມໃຫຍ່, ມັນຈະຖືກປ່ຽນເປັນຕົວພິມນ້ອຍໂດຍອັດຕະໂນມັດ."

#. Q86Zu
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3159204\n"
"help.text"
msgid "The characters A-Z can be entered here. If a lowercase letter is entered, it is automatically converted to a capital letter"
msgstr "ສາມາດປ້ອນຕົວອັກສອນ A-Z ທີ່ນີ້. ຖ້າປ້ອນຕົວພິມນ້ອຍ, ມັນຈະຖືກປ່ຽນເປັນຕົວພິມໃຫຍ່ໂດຍອັດຕະໂນມັດ."

#. tuUGC
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3151304\n"
"help.text"
msgid "The characters a-z and 0-9 can be entered here. If a capital letter is entered, it is automatically converted to a lowercase letter."
msgstr "ສາມາດປ້ອນຕົວອັກສອນ a-z ແລະ 0-9 ທີ່ນີ້. ຖ້າປ້ອນຕົວພິມໃຫຍ່, ມັນຈະຖືກປ່ຽນເປັນຕົວພິມນ້ອຍໂດຍອັດຕະໂນມັດ."

#. urwGP
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155071\n"
"help.text"
msgid "The characters a-z and 0-9 can be entered here. If a lowercase letter is entered, it is automatically converted to a capital letter"
msgstr "ສາມາດປ້ອນຕົວອັກສອນ a-z ແລະ 0-9 ທີ່ນີ້. ຖ້າປ້ອນຕົວພິມນ້ອຍ, ມັນຈະຖືກປ່ຽນເປັນຕົວພິມໃຫຍ່ໂດຍອັດຕະໂນມັດ."

#. U4J7u
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154650\n"
"help.text"
msgid "Only the characters 0-9 can be entered."
msgstr "ສາມາດປ້ອນໄດ້ສະເພາະຕົວເລກ 0-9 ເທົ່ານັ້ນ."

#. Gpn4f
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3153489\n"
"help.text"
msgid "All printable characters can be entered."
msgstr "ສາມາດປ້ອນຕົວອັກສອນທີ່ສາມາດພິມໄດ້ທັງໝົດ."

#. SxFCq
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154707\n"
"help.text"
msgid "All printable characters can be entered. If a lowercase letter is used, it is automatically converted to a capital letter."
msgstr "ສາມາດປ້ອນຕົວອັກສອນທີ່ສາມາດພິມໄດ້ທັງໝົດ. ຖ້າໃຊ້ຕົວພິມນ້ອຍ, ມັນຈະຖືກປ່ຽນເປັນຕົວພິມໃຫຍ່ໂດຍອັດຕະໂນມັດ."

#. F3XwG
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id2128971\n"
"help.text"
msgid "Editable"
msgstr "ແກ້ໄຂໄດ້"

#. R4Axb
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id6519974\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether the nodes of the tree control are editable.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າໂນດ (Nodes) ຂອງການຄວບຄຸມແບບຕົ້ນໄມ້ (Tree control) ສາມາດແກ້ໄຂໄດ້ຫຼືບໍ່.</ahelp>"

#. 6E3fY
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id4591814\n"
"help.text"
msgid "The default value is FALSE."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ ບໍ່ແມ່ນ (FALSE)."

#. VDs3B
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3149317\n"
"help.text"
msgid "Graphics"
msgstr "ກຣາຟິກ"

#. phpED
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3147546\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the source of the graphics for a button or an image control. Click \"...\" to select a file.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດແຫຼ່ງທີ່ມາຂອງກຣາຟິກສຳລັບປຸ່ມ ຫຼື ການຄວບຄຸມຮູບພາບ. ຄລິກ \"...\" ເພື່ອເລືອກໄຟລ໌.</ahelp>"

#. iPZoL
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154627\n"
"help.text"
msgid "Height"
msgstr "ຄວາມສູງ"

#. Bs2gd
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155754\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the height of the current control or the dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄວາມສູງຂອງການຄວບຄຸມ ຫຼື ໄດອາລັອກປັດຈຸບັນ.</ahelp>"

#. VvPRw
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3153072\n"
"help.text"
msgid "Help text"
msgstr "ຂໍ້ຄວາມຊ່ວຍເຫຼືອ"

#. Kz7Ys
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3147502\n"
"help.text"
msgid "<ahelp hid=\".\">Enter a help text that is displayed as a tip (bubble help) when the mouse rests over the control.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຂໍ້ຄວາມຊ່ວຍເຫຼືອທີ່ຈະໃຫ້ສະແດງເປັນຄຳແນະນຳ (Bubble help) ເມື່ອວາງເມົ້າໄວ້ເທິງການຄວບຄຸມ.</ahelp>"

#. pTjfM
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154400\n"
"help.text"
msgid "Help URL"
msgstr "URL ຊ່ວຍເຫຼືອ"

#. XxuEf
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3150431\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the help URL that is called when you press F1 while the focus is on a particular control. For example, use the format HID:1234 to call the Help-ID with the number 1234.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດ URL ຊ່ວຍເຫຼືອທີ່ຈະຖືກເອີ້ນໃຊ້ເມື່ອທ່ານກົດ F1 ໃນຂະນະທີ່ກຳລັງໂຟກັສຢູ່ທີ່ການຄວບຄຸມໃດໜຶ່ງ. ຕົວຢ່າງ, ໃຊ້ຮູບແບບ HID:1234 ເພື່ອເອີ້ນໃຊ້ Help-ID ໝາຍເລກ 1234.</ahelp>"

#. yaVgx
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id4171269\n"
"help.text"
msgid "Set the environment variable HELP_DEBUG to 1 to view the Help-IDs as extended help tips."
msgstr "ຕັ້ງຄ່າຕົວປ່ຽນສະພາບແວດລ້ອມ HELP_DEBUG ເປັນ 1 ເພື່ອເບິ່ງ Help-IDs ເປັນຄຳແນະນຳການຊ່ວຍເຫຼືອແບບຂະຫຍາຍ."

#. PeAAF
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3159260\n"
"help.text"
msgid "Incr./decrement value"
msgstr "ຄ່າການເພີ່ມ/ຫຼຸດ"

#. j6dm5
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3145233\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the increment and decrement interval for spin button controls.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດໄລຍະຫ່າງຂອງການເພີ່ມ ແລະ ຫຼຸດ ສຳລັບການຄວບຄຸມປຸ່ມໝຸນ (Spin button).</ahelp>"

#. WRQBk
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id539262\n"
"help.text"
msgid "Invokes stop mode editing"
msgstr "ເອີ້ນໃຊ້ການແກ້ໄຂໂໝດຢຸດ"

#. uYGG2
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id234382\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies what happens when editing is interrupted by selecting another node in the tree, a change in the tree's data, or by some other means.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າຈະໃຫ້ເກີດຫຍັງຂຶ້ນ ເມື່ອການແກ້ໄຂຖືກລົບກວນ ໂດຍການເລືອກໂນດອື່ນໃນຕົ້ນໄມ້, ການປ່ຽນແປງຂໍ້ມູນຂອງຕົ້ນໄມ້ ຫຼື ໂດຍວິທີອື່ນ.</ahelp>"

#. ExcDe
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id6591082\n"
"help.text"
msgid "Setting this property to TRUE causes the changes to be automatically saved when editing is interrupted. FALSE means that editing is canceled and changes are lost."
msgstr "ການຕັ້ງຄ່າຄຸນສົມບັດນີ້ເປັນ ແມ່ນ (TRUE) ຈະເຮັດໃຫ້ການປ່ຽນແປງຖືກບັນທຶກໂດຍອັດຕະໂນມັດ ເມື່ອການແກ້ໄຂຖືກລົບກວນ. ບໍ່ແມ່ນ (FALSE) ໝາຍຄວາມວ່າການແກ້ໄຂຈະຖືກຍົກເລີກ ແລະ ການປ່ຽນແປງຈະສູນຫາຍ."

#. DgFkR
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id9298074\n"
"help.text"
msgid "The default value is FALSE."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ ບໍ່ແມ່ນ (FALSE)."

#. Di9Xo
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3150536\n"
"help.text"
msgid "Label"
msgstr "ປ້າຍຊື່"

#. BH2nz
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3146324\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the label of the current control. The label is displayed along with the control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດປ້າຍຊື່ຂອງການຄວບຄຸມປັດຈຸບັນ. ປ້າຍຊື່ຈະຖືກສະແດງຮ່ວມກັບການຄວບຄຸມ.</ahelp>"

#. 6X5mC
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3146816\n"
"help.text"
msgid "You can create multi-line <emph>labels</emph> by inserting manual line breaks in the label using <emph>Shift+Enter</emph>."
msgstr "ທ່ານສາມາດສ້າງ <emph>ປ້າຍຊື່</emph> ຫຼາຍບັນທັດໄດ້ ໂດຍການແຊກການຂຶ້ນບັນທັດໃໝ່ດ້ວຍຕົນເອງໃນປ້າຍຊື່ ໂດຍໃຊ້ <emph>Shift+Enter</emph>."

#. r4WBz
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3150457\n"
"help.text"
msgid "Line Count"
msgstr "ຈຳນວນບັນທັດ"

#. YBUsT
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3149143\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the number of lines to be displayed for a list control. For combo boxes, this setting is only active if the dropdown option is enabled. </ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຈຳນວນບັນທັດທີ່ຈະໃຫ້ສະແດງສຳລັບການຄວບຄຸມລາຍການ. ສຳລັບຄອມໂບ້ບັອກ, ການຕັ້ງຄ່ານີ້ຈະມີຜົນກໍຕໍ່ເມື່ອຕົວເລືອກ Dropdown ຖືກເປີດໃຊ້ງານເທົ່ານັ້ນ. </ahelp>"

#. bJA4h
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id7468489\n"
"help.text"
msgid "Scrollbar"
msgstr "ແຖບເລື່ອນ (Scrollbar)"

#. nDA7n
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id7706228\n"
"help.text"
msgid "Adds the scrollbar type that you specify to a text box."
msgstr "ເພີ່ມປະເພດແຖບເລື່ອນທີ່ທ່ານກຳນົດໃຫ້ກັບກ່ອງຂໍ້ຄວາມ."

#. 6xNxb
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3153121\n"
"help.text"
msgid "Small change"
msgstr "ການປ່ຽນແປງຂະໜາດນ້ອຍ"

#. CGeAu
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3157875\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the number of units to scroll when a user clicks an arrow on a scrollbar.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຈຳນວນໜ່ວຍທີ່ຈະເລື່ອນ ເມື່ອຜູ້ໃຊ້ຄລິກລູກສອນໃນແຖບເລື່ອນ.</ahelp>"

#. kC4mu
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3145221\n"
"help.text"
msgid "List entries"
msgstr "ລາຍການທີ່ປ້ອນ"

#. Ga3fT
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154580\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the entries for a list control. One line takes one list entry. Press <emph>Shift+Enter</emph> to insert a new line.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດລາຍການສຳລັບການຄວບຄຸມລາຍການ. ໜຶ່ງບັນທັດຄືໜຶ່ງລາຍການ. ກົດ <emph>Shift+Enter</emph> ເພື່ອແຊກບັນທັດໃໝ່.</ahelp>"

#. qBq9j
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3149723\n"
"help.text"
msgid "Literal mask"
msgstr "ຫນ້າກາກຕົວອັກສອນ (Literal mask)"

#. 7seGj
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3150656\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the initial values to be displayed in a pattern control. This helps the user to identify which values are allowed in a pattern control. The literal mask is restricted by the format specified by the edit mask.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າເລີ່ມຕົ້ນທີ່ຈະໃຫ້ສະແດງໃນການຄວບຄຸມຮູບແບບ. ນີ້ຊ່ວຍໃຫ້ຜູ້ໃຊ້ລະບຸໄດ້ວ່າຄ່າໃດທີ່ໄດ້ຮັບອະນຸຍາດໃນການຄວບຄຸມຮູບແບບ. Literal mask ຈະຖືກຈຳກັດໂດຍຮູບແບບທີ່ກຳນົດໄວ້ໃນ Edit mask.</ahelp>"

#. CRUKE
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3149015\n"
"help.text"
msgid "Manual line break"
msgstr "ການຂຶ້ນບັນທັດໃໝ່ດ້ວຍຕົນເອງ"

#. BdKPT
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3149893\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to allow manual line breaks inside multiline controls.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອອະນຸຍາດໃຫ້ມີການຂຶ້ນບັນທັດໃໝ່ດ້ວຍຕົນເອງພາຍໃນການຄວບຄຸມແບບຫຼາຍບັນທັດ.</ahelp>"

#. Q954Y
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3150463\n"
"help.text"
msgid "Max. text length"
msgstr "ຄວາມຍາວຂໍ້ຄວາມສູງສຸດ"

#. jCAEZ
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3150745\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the maximum number of characters that the user can enter.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຈຳນວນຕົວອັກສອນສູງສຸດທີ່ຜູ້ໃຊ້ສາມາດປ້ອນເຂົ້າໄດ້.</ahelp>"

#. fWJry
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154675\n"
"help.text"
msgid "Multiline Input"
msgstr "ການປ້ອນຂໍ້ມູນຫຼາຍບັນທັດ"

#. j9JFM
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3144741\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to allow the input of multiple lines in the control. Press Enter to insert a manual line break in the control.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອອະນຸຍາດໃຫ້ປ້ອນຂໍ້ມູນຫຼາຍບັນທັດໃນການຄວບຄຸມ. ກົດ Enter ເພື່ອແຊກການຂຶ້ນບັນທັດໃໝ່ດ້ວຍຕົນເອງໃນການຄວບຄຸມ.</ahelp>"

#. GHYEq
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154848\n"
"help.text"
msgid "Multiselection"
msgstr "ການເລືອກໄດ້ຫຼາຍລາຍການ"

#. rtqLT
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3151235\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to allow the selection of multiple entries in list controls.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອອະນຸຍາດໃຫ້ເລືອກລາຍການໄດ້ຫຼາຍລາຍການໃນການຄວບຄຸມລາຍການ.</ahelp>"

#. 5XDPo
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3148887\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. NuDCQ
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154548\n"
"help.text"
msgid "<ahelp hid=\".\">Insert a name for the current control. This name is used to identify the control.</ahelp>"
msgstr "<ahelp hid=\".\">ໃສ່ຊື່ສຳລັບການຄວບຄຸມປັດຈຸບັນ. ຊື່ນີ້ແມ່ນໃຊ້ເພື່ອລະບຸຕົວຕົນຂອງການຄວບຄຸມ.</ahelp>"

#. F2dAE
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3148739\n"
"help.text"
msgid "Order"
msgstr "ລຳດັບ"

#. i7fot
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3149252\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the order in which the controls receive the focus when the Tab key is pressed in the dialog.</ahelp> On entering a dialog, the control with the lowest order (0) receives the focus. Pressing the <emph>Tab</emph> key the successively focuses the other controls as specified by their order number."
msgstr "<ahelp hid=\".\">ກຳນົດລຳດັບທີ່ການຄວບຄຸມຈະໄດ້ຮັບໂຟກັສ ເມື່ອກົດປຸ່ມ Tab ໃນໄດອາລັອກ.</ahelp> ເມື່ອເຂົ້າສູ່ໄດອາລັອກ, ການຄວບຄຸມທີ່ມີລຳດັບຕ່ຳສຸດ (0) ຈະໄດ້ຮັບໂຟກັສກ່ອນ. ການກົດປຸ່ມ <emph>Tab</emph> ຈະເປັນການຍ້າຍໂຟກັສໄປຍັງການຄວບຄຸມອື່ນໆ ຕາມລຳດັບໝາຍເລກທີ່ກຳນົດໄວ້."

#. 54etz
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155259\n"
"help.text"
msgid "Initially, the controls receive numbers in the order they are added to the dialog. You can change the order numbers for controls. $[officename] Basic updates the order numbers automatically to avoid duplicate numbers. Controls that cannot be focused are also assigned a value but these controls are skipped when using the Tab key."
msgstr "ໃນຕອນເລີ່ມຕົ້ນ, ການຄວບຄຸມຈະໄດ້ຮັບໝາຍເລກຕາມລຳດັບທີ່ພວກມັນຖືກເພີ່ມເຂົ້າໃນໄດອາລັອກ. ທ່ານສາມາດປ່ຽນໝາຍເລກລຳດັບສຳລັບການຄວບຄຸມໄດ້. $[officename] Basic ຈະອັບເດດໝາຍເລກລຳດັບໂດຍອັດຕະໂນມັດເພື່ອຫຼີກເວັ້ນໝາຍເລກທີ່ຊ້ຳກັນ. ການຄວບຄຸມທີ່ບໍ່ສາມາດຮັບໂຟກັສໄດ້ກໍຈະຖືກກຳນົດຄ່າໄວ້ເຊັ່ນກັນ ແຕ່ການຄວບຄຸມເຫຼົ່ານີ້ຈະຖືກຂ້າມໄປເມື່ອໃຊ້ປຸ່ມ Tab."

#. 9AfPp
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3149511\n"
"help.text"
msgid "Orientation"
msgstr "ການວາງແນວ"

#. ikZBx
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3153780\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the orientation for a scrollbar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດການວາງແນວສຳລັບການຄວບຄຸມແຖບເລື່ອນ.</ahelp>"

#. wPXqH
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154374\n"
"help.text"
msgid "Page (step)"
msgstr "ໜ້າ (ຂັ້ນຕອນ)"

#. UcdiE
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154109\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the number of the dialog page to which the current control is assigned or the page number of the dialog you want to edit.</ahelp> If a dialog has only one page set its <emph>Page (Step)</emph> value to <emph>0</emph>."
msgstr "<ahelp hid=\".\">ກຳນົດໝາຍເລກໜ້າຂອງໄດອາລັອກທີ່ການຄວບຄຸມປັດຈຸບັນຖືກມອບໝາຍໃຫ້ ຫຼື ໝາຍເລກໜ້າຂອງໄດອາລັອກທີ່ທ່ານຕ້ອງການແກ້ໄຂ.</ahelp> ຖ້າໄດອາລັອກມີພຽງໜ້າດຽວ ໃຫ້ຕັ້ງຄ່າ <emph>ໜ້າ (ຂັ້ນຕອນ)</emph> ເປັນ <emph>0</emph>."

#. BoGGV
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3148580\n"
"help.text"
msgid "Select <emph>Page (Step)</emph> = 0 to make a control visible on every dialog page."
msgstr "ເລືອກ <emph>ໜ້າ (ຂັ້ນຕອນ)</emph> = 0 ເພື່ອເຮັດໃຫ້ການຄວບຄຸມສະແດງໃຫ້ເຫັນໃນທຸກໆໜ້າຂອງໄດອາລັອກ."

#. CWHWy
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3146144\n"
"help.text"
msgid "To switch between dialog pages at run time, you need to create a macro that changes the value of <emph>Page (Step)</emph>."
msgstr "ເພື່ອສະຫຼັບລະຫວ່າງໜ້າຂອງໄດອາລັອກໃນຂະນະເຮັດວຽກ, ທ່ານຈຳເປັນຕ້ອງສ້າງມາໂຄຣທີ່ປ່ຽນແປງຄ່າຂອງ <emph>ໜ້າ (ຂັ້ນຕອນ)</emph>."

#. yfdsF
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154558\n"
"help.text"
msgid "Password characters"
msgstr "ຕົວອັກສອນລະຫັດຜ່ານ"

#. kNFHd
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3152787\n"
"help.text"
msgid "<ahelp hid=\".\">Enter a character to be displayed instead of the characters that are typed. This can be used for entering passwords in text controls.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຕົວອັກສອນທີ່ຈະໃຫ້ສະແດງແທນຕົວອັກສອນທີ່ພິມລົງໄປ. ສິ່ງນີ້ສາມາດໃຊ້ສຳລັບການປ້ອນລະຫັດຜ່ານໃນການຄວບຄຸມຂໍ້ຄວາມ.</ahelp>"

#. h8SXD
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3148750\n"
"help.text"
msgid "PositionX"
msgstr "ຕຳແໜ່ງ X"

#. 2EVcB
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154517\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the distance of the current control from the left side of the dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດໄລຍະຫ່າງຂອງການຄວບຄຸມປັດຈຸບັນຈາກດ້ານຊ້າຍຂອງໄດອາລັອກ.</ahelp>"

#. JTKqk
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3152767\n"
"help.text"
msgid "PositionY"
msgstr "ຕຳແໜ່ງ Y"

#. J7py4
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3159082\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the distance of the current control from the top of the dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດໄລຍະຫ່າງຂອງການຄວບຄຸມປັດຈຸບັນຈາກດ້ານເທິງຂອງໄດອາລັອກ.</ahelp>"

#. bGzny
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3159213\n"
"help.text"
msgid "Prefix symbol"
msgstr "ສັນຍະລັກນຳໜ້າ (Prefix symbol)"

#. ezYKt
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3149688\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to display the currency symbol prefix in currency controls when a number was entered.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອສະແດງສັນຍະລັກສະກຸນເງິນເປັນຄຳນຳໜ້າໃນການຄວບຄຸມສະກຸນເງິນເມື່ອມີການປ້ອນຕົວເລກ.</ahelp>"

#. ACDzZ
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3149728\n"
"help.text"
msgid "Print"
msgstr "ພິມ"

#. DTyCw
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3150001\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to include the current control in a document's printout.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອລວມການຄວບຄຸມປັດຈຸບັນເຂົ້າໃນການພິມເອກະສານ.</ahelp>"

#. cff54
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3154671\n"
"help.text"
msgid "Progress value"
msgstr "ຄ່າຄວາມຄືບໜ້າ"

#. hZPwV
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3146849\n"
"help.text"
msgid "<ahelp hid=\".\">Specify a progress value for a progress bar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າຄວາມຄືບໜ້າສຳລັບການຄວບຄຸມແຖບຄວາມຄືບໜ້າ (Progress bar).</ahelp>"

#. AVt7R
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3153112\n"
"help.text"
msgid "Progress value max."
msgstr "ຄ່າຄວາມຄືບໜ້າສູງສຸດ"

#. KAaFj
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3145167\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the maximum value of a progress bar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າສູງສຸດຂອງການຄວບຄຸມແຖບຄວາມຄືບໜ້າ.</ahelp>"

#. 7Euj4
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3153569\n"
"help.text"
msgid "Progress value min."
msgstr "ຄ່າຄວາມຄືບໜ້າຕ່ຳສຸດ"

#. oBei3
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3154506\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the minimum value of a progress bar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າຕ່ຳສຸດຂອງການຄວບຄຸມແຖບຄວາມຄືບໜ້າ.</ahelp>"

#. ZbJ4B
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3150134\n"
"help.text"
msgid "Read-only"
msgstr "ອ່ານຢ່າງດຽວ"

#. pDFLA
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3155930\n"
"help.text"
msgid "<ahelp hid=\".\">Select \"Yes\" to prevent the user from editing the value of the current control. The control is enabled and can be focused but not modified.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ \"ແມ່ນ\" ເພື່ອປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ແກ້ໄຂຄ່າຂອງການຄວບຄຸມປັດຈຸບັນ. ການຄວບຄຸມຍັງຄົງເປີດໃຊ້ງານ ແລະ ສາມາດຮັບໂຟກັສໄດ້ ແຕ່ບໍ່ສາມາດແກ້ໄຂໄດ້.</ahelp>"

#. QcDc4
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN11112\n"
"help.text"
msgid "Repeat"
msgstr "ເຮັດຊ້ຳ (Repeat)"

#. Tn2Gm
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN11128\n"
"help.text"
msgid "<ahelp hid=\".\">Repeats trigger events when you keep the mouse button pressed on a control such as a spin button.</ahelp>"
msgstr "<ahelp hid=\".\">ເຮັດຊ້ຳເຫດການກະຕຸ້ນ ເມື່ອທ່ານກົດປຸ່ມເມົ້າຄ້າງໄວ້ໃນການຄວບຄຸມ ເຊັ່ນ ປຸ່ມໝຸນ (Spin button).</ahelp>"

#. RP3VX
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id9579149\n"
"help.text"
msgid "Root displayed"
msgstr "ສະແດງຮາກ (Root displayed)"

#. adGTR
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id7126987\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies if the root node of the tree control is displayed.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າຈະໃຫ້ສະແດງໂນດຮາກ (Root node) ຂອງການຄວບຄຸມແບບຕົ້ນໄມ້ຫຼືບໍ່.</ahelp>"

#. p9tYi
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id9174779\n"
"help.text"
msgid "If Root displayed is set to FALSE, the root node of a model is no longer a valid node for the tree control and can't be used with any method of XTreeControl."
msgstr "ຖ້າ Root displayed ຖືກຕັ້ງເປັນ ບໍ່ແມ່ນ (FALSE), ໂນດຮາກຂອງໂມເດວຈະບໍ່ແມ່ນໂນດທີ່ຖືກຕ້ອງສຳລັບການຄວບຄຸມແບບຕົ້ນໄມ້ອີກຕໍ່ໄປ ແລະ ບໍ່ສາມາດໃຊ້ກັບເມັດທອດ (Method) ໃດໆຂອງ XTreeControl ໄດ້."

#. KucrS
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id594195\n"
"help.text"
msgid "The default value is TRUE."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ ແມ່ນ (TRUE)."

#. UFPCV
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id7534409\n"
"help.text"
msgid "Row height"
msgstr "ຄວາມສູງຂອງແຖວ"

#. xPrCr
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id6471755\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the height of each row of a tree control, in pixels.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄວາມສູງຂອງແຕ່ລະແຖວຂອງການຄວບຄຸມແບບຕົ້ນໄມ້ ເປັນພິກເຊວ.</ahelp>"

#. wFHUd
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id2909329\n"
"help.text"
msgid "If the specified value is less than or equal to zero, the row height is the maximum height of all rows."
msgstr "ຖ້າຄ່າທີ່ກຳນົດຕ່ຳກວ່າ ຫຼື ເທົ່າກັບສູນ, ຄວາມສູງຂອງແຖວຈະເປັນຄວາມສູງສູງສຸດຂອງທຸກແຖວ."

#. CLPMV
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id4601580\n"
"help.text"
msgid "The default value is 0."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ 0."

#. ydxCG
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3148761\n"
"help.text"
msgid "Scale"
msgstr "ມາດຕາສ່ວນ (Scale)"

#. 9qp2q
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3159134\n"
"help.text"
msgid "<ahelp hid=\".\">Scales the image to fit the control size.</ahelp>"
msgstr "<ahelp hid=\".\">ປັບມາດຕາສ່ວນຂອງຮູບພາບໃຫ້ພໍດີກັບຂະໜາດຂອງການຄວບຄຸມ.</ahelp>"

#. FrqW5
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id7597277\n"
"help.text"
msgid "Scrollbar"
msgstr "ແຖບເລື່ອນ (Scrollbar)"

#. jiW7j
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id986968\n"
"help.text"
msgid "<ahelp hid=\".\">Adds the scrollbar type that you specify to a text box.</ahelp>"
msgstr "<ahelp hid=\".\">ເພີ່ມປະເພດແຖບເລື່ອນທີ່ທ່ານກຳນົດໃຫ້ກັບກ່ອງຂໍ້ຄວາມ.</ahelp>"

#. gkvzY
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3147370\n"
"help.text"
msgid "Scroll value"
msgstr "ຄ່າການເລື່ອນ"

#. 24GzW
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3159622\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the initial value of a scrollbar control. This determines the position of the scrollbar slider.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າເລີ່ມຕົ້ນຂອງການຄວບຄຸມແຖບເລື່ອນ. ສິ່ງນີ້ຈະກຳນົດຕຳແໜ່ງຂອງແຖບເລື່ອນ.</ahelp>"

#. FEeCy
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id3155440\n"
"help.text"
msgid "Scroll value max."
msgstr "ຄ່າການເລື່ອນສູງສຸດ"

#. 2QDng
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3148877\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the maximum value of a scrollbar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າສູງສຸດຂອງການຄວບຄຸມແຖບເລື່ອນ.</ahelp>"

#. WhdNX
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN111E4\n"
"help.text"
msgid "Scroll value min."
msgstr "ຄ່າການເລື່ອນຕ່ຳສຸດ"

#. KkkV7
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN111E8\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the minimum value of a scrollbar control.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຄ່າຕ່ຳສຸດຂອງການຄວບຄຸມແຖບເລື່ອນ.</ahelp>"

#. E6FFj
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id543534\n"
"help.text"
msgid "Show handles"
msgstr "ສະແດງມືຈັບ (Show handles)"

#. wG6AD
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id5060884\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether the handles of the nodes should be displayed.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າຄວນຈະສະແດງມືຈັບຂອງໂນດຫຼືບໍ່.</ahelp>"

#. TC8mj
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id4974822\n"
"help.text"
msgid "The handles are dotted lines that visualize the hierarchy of the tree control."
msgstr "ມືຈັບແມ່ນເສັ້ນຈ້ຳໆທີ່ສະແດງໃຫ້ເຫັນເຖິງລຳດັບຊັ້ນຂອງການຄວບຄຸມແບບຕົ້ນໄມ້."

#. 55Gfe
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id7687307\n"
"help.text"
msgid "The default value is TRUE."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ ແມ່ນ (TRUE)."

#. kEF3n
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id4062013\n"
"help.text"
msgid "Show root handles"
msgstr "ສະແດງມືຈັບຂອງຮາກ"

#. nGccA
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3314004\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether the handles of the nodes should also be displayed at root level.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າຄວນຈະສະແດງມືຈັບຂອງໂນດໃນລະດັບຮາກ (Root level) ນຳຫຼືບໍ່.</ahelp>"

#. GCfuF
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id2396313\n"
"help.text"
msgid "The default value is TRUE."
msgstr "ຄ່າເລີ່ມຕົ້ນແມ່ນ ແມ່ນ (TRUE)."

#. XLMGF
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN10EC2\n"
"help.text"
msgid "Selection"
msgstr "ການເລືອກ"

#. mF5w3
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN10ED8\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the sequence of the selected items, where \"0\" corresponds to the first item. To select more than one item, Multiselection must be enabled.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດລຳດັບຂອງລາຍການທີ່ເລືອກ, ໂດຍທີ່ \"0\" ຈະກົງກັບລາຍການທຳອິດ. ເພື່ອເລືອກຫຼາຍກວ່າໜຶ່ງລາຍການ, ຕ້ອງເປີດໃຊ້ງານ Multiselection ກ່ອນ.</ahelp>"

#. jwSUy
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN10EEB\n"
"help.text"
msgid "Click the <emph>...</emph> button to open the <emph>Selection</emph> dialog."
msgstr "ຄລິກປຸ່ມ <emph>...</emph> ເພື່ອເປີດໄດອາລັອກ <emph>ການເລືອກ</emph>."

#. oEvvu
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_idN10F0A\n"
"help.text"
msgid "<ahelp hid=\".\">Click the item or items that you want to select. To select more than one item, ensure that the Multiselection option is selected.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກລາຍການທີ່ທ່ານຕ້ອງການເລືອກ. ເພື່ອເລືອກຫຼາຍກວ່າໜຶ່ງລາຍການ, ໃຫ້ແນ່ໃຈວ່າໄດ້ເລືອກຕົວເລືອກ Multiselection ແລ້ວ.</ahelp>"

#. 56k8D
#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"hd_id5026093\n"
"help.text"
