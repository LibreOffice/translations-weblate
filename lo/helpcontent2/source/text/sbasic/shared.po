msgctxt ""
"03170000.xhp\n"
"par_id061420170153186193\n"
"help.text"
msgid "<link href=\"text/scalc/01/04060106.xhp#Section21\">Calc ROUND function</link>"
msgstr "<link href=\"text/scalc/01/04060106.xhp#Section21\">ຟັງຊັນ ROUND ໃນ Calc</link>"

