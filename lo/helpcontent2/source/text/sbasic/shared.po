"par_id3159252\n"
"help.text"
msgid "sInput = InputBox(\"Please input a date in the international format 'YYYY-MM-DD'\")"
msgstr "sInput = InputBox(\"ກະລຸນາປ້ອນວັນທີໃນຮູບແບບສາກົນ 'YYYY-MM-DD'\")"

#. CDv6e
