msgctxt ""
"03103350.xhp\n"
"par_id051720171055361727\n"
"help.text"
msgid "1: Enable VBA support in %PRODUCTNAME"
msgstr "1: ເປີດໃຊ້ການສະໜັບສະໜູນ VBA ໃນ %PRODUCTNAME"

