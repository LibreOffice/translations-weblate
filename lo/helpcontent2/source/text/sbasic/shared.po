"par_id3155805\n"
"help.text"
msgid "Compares two strings and returns an integer value that represents the result of the comparison."
msgstr "ປຽບທຽບສອງຂໍ້ຄວາມ ແລະ ສົ່ງຄືນຄ່າຕົວເລກຖ້ວນທີ່ສະແດງເຖິງຜົນຂອງການປຽບທຽບ."

#. WpnwF
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3150503\n"
"help.text"
msgid "StrComp (string1 As String, string2 As String[, Compare As Integer]) As Integer"
msgstr "StrComp (ຂໍ້ຄວາມ1 ເປັນ String, ຂໍ້ຄວາມ2 ເປັນ String[, ປຽບທຽບ ເປັນ Integer]) ເປັນ Integer"

#. Bx8HF
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3351061\n"
"help.text"
msgid "<emph>string1</emph>: Any string expression"
msgstr "<emph>ຂໍ້ຄວາມ1</emph>: ນິພົດຂໍ້ຄວາມໃດໆ"

#. vNvkn
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3153061\n"
"help.text"
msgid "<emph>string2</emph>: Any string expression"
msgstr "<emph>ຂໍ້ຄວາມ2</emph>: ນິພົດຂໍ້ຄວາມໃດໆ"

#. 59SPq
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3146796\n"
"help.text"
msgid "<emph>Compare</emph>: This optional parameter sets the comparison method. If <literal>Compare</literal> = 1, the string comparison is case-sensitive. If <literal>Compare</literal> = 0, no distinction is made between uppercase and lowercase letters."
msgstr "<emph>ປຽບທຽບ</emph>: ພາລາມິເຕີທາງເລືອກນີ້ກຳນົດວິທີການປຽບທຽບ. ຖ້າ <literal>Compare</literal> = 1, ການປຽບທຽບຈະຈຳແນກຕົວພິມໃຫຍ່-ນ້ອຍ. ຖ້າ <literal>Compare</literal> = 0, ຈະບໍ່ມີການແບ່ງແຍກລະຫວ່າງຕົວອັກສອນພິມໃຫຍ່ ແລະ ພິມນ້ອຍ."

#. Hi2Cp
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3150358\n"
"help.text"
msgid "If string1 < string2 the function returns -1"
msgstr "ຖ້າ ຂໍ້ຄວາມ1 < ຂໍ້ຄວາມ2 ຟັງຊັນຈະສົ່ງຄືນ -1"

#. Y4fnJ
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3151043\n"
"help.text"
msgid "If string1 = string2 the function returns 0"
msgstr "ຖ້າ ຂໍ້ຄວາມ1 = ຂໍ້ຄວາມ2 ຟັງຊັນຈະສົ່ງຄືນ 0"

#. QX67G
#: 03120403.xhp
msgctxt ""
"03120403.xhp\n"
"par_id3158410\n"
"help.text"
msgid "If string1 > string2 the function returns 1"
msgstr "ຖ້າ ຂໍ້ຄວາມ1 > ຂໍ້ຄວາມ2 ຟັງຊັນຈະສົ່ງຄືນ 1"

