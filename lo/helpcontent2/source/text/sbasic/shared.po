#. tUDMG
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_id3149670\n"
"help.text"
msgid "Performs the integer division on two numbers and returns the result."
msgstr "ເຮັດການຫານແບບເລກຖ້ວນໃນສອງຕົວເລກ ແລະ ສົ່ງຄືນຜົນໄດ້ຮັບ."

#. 7hxCB
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"bm_id3150669\n"
"help.text"
msgid "<bookmark_value>Operators;Integer division (\\\\)</bookmark_value>  <bookmark_value>\"\\\\\" operator (mathematical)</bookmark_value>"
msgstr "<bookmark_value>ຕົວດຳເນີນການ;ການຫານຈຳນວນຖ້ວນ (\\\\)</bookmark_value>  <bookmark_value>ຕົວດຳເນີນການ \"\\\\\" (ທາງຄະນິດສາດ)</bookmark_value>"

#. KDgG2
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_id3153360\n"
"help.text"
msgid "result = expression1 \\ expression2"
msgstr "ຜົນໄດ້ຮັບ = ສຳນວນ1 \\ ສຳນວນ2"

#. jSHq3
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_id3154141\n"
"help.text"
msgid "<emph>result</emph>: A numerical value that contains the result of the integer division."
msgstr "<emph>ຜົນໄດ້ຮັບ</emph>: ຄ່າຕົວເລກທີ່ມີຜົນຂອງການຫານແບບເລກຖ້ວນ."

#. K3YrU
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_id3150448\n"
"help.text"
msgid "<emph>expression1, expression2</emph>: Dividend and diviser operands of the integer division."
msgstr "<emph>ສຳນວນ1, ສຳນວນ2</emph>: ຕົວຕັ້ງຫານ ແລະ ຕົວຫານຂອງການຫານແບບເລກຖ້ວນ."

#. sxofZ
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_id951642689912087\n"
"help.text"
msgid "Before division both operands are rounded to whole numbers. The fractional part of the result is dropped."
msgstr "ກ່ອນການຫານ, ທັງສອງຄ່າຈະຖືກປັດເປັນເລກຖ້ວນ. ສ່ວນທີ່ເປັນທົດສະນິຍົມຂອງຜົນໄດ້ຮັບຈະຖືກຕັດຖິ້ມ."

#. BaAgA
#: 03070700.xhp
msgctxt ""
"03070700.xhp\n"
"par_idm1341471776\n"
"help.text"
msgid "Print 5 \\ 4 , 5 / 4   ' 1 , 1.25"
msgstr "Print 5 \\ 4 , 5 / 4   ' 1 , 1.25"

#. NYoaW
