msgctxt ""
"01170103.xhp\n"
"par_id3155267\n"
"help.text"
msgid "<ahelp hid=\"HID_EVT_KEYUP\">This event occurs when the user releases a key while the control has the focus.</ahelp>"
msgstr "<ahelp hid=\"HID_EVT_KEYUP\">ເຫດການນີ້ຈະເກີດຂຶ້ນ ເມື່ອຜູ້ໃຊ້ປ່ອຍປຸ່ມ ໃນຂະນະທີ່ການຄວບຄຸມນັ້ນກຳລັງໄດ້ຮັບໂຟກັສ.</ahelp>"

#. pVAed
