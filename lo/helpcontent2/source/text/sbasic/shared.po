"help.text"
msgid "The following logical operators are supported by $[officename] Basic."
msgstr "ຕົວດຳເນີນການທາງຕັກກະສາດຕໍ່ໄປນີ້ແມ່ນຮອງຮັບໂດຍ $[officename] Basic."

#. coCYu
#: 03060000.xhp
msgctxt ""
"03060000.xhp\n"
"par_id3154138\n"
"help.text"
msgid "Logical operators combine (bitwise) the contents of two expressions or variables, for example, to test if specific bits are set or not."
msgstr "ຕົວດຳເນີນການທາງຕັກກະສາດຈະຮວມຂໍ້ມູນ (ແບບບິດ/bitwise) ຂອງສອງສຳນວນ ຫຼື ຕົວປ່ຽນເຂົ້າກັນ, ຕົວຢ່າງເຊັ່ນ: ເພື່ອກວດສອບວ່າບິດໃດໜຶ່ງຖືກກຳນົດໄວ້ຫຼືບໍ່."

#. bwPRh
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"tit\n"
"help.text"
msgid "AND Operator"
msgstr "ຕົວດຳເນີນການ AND"

#. FEioU
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"bm_id3146117\n"
"help.text"
msgid "<bookmark_value>AND operator (logical)</bookmark_value>"
msgstr "<bookmark_value>ຕົວດຳເນີນການ AND (ທາງຕັກກະສາດ)</bookmark_value>"

#. AsRzu
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"hd_id3146117\n"
"help.text"
msgid "<link href=\"text/sbasic/shared/03060100.xhp\">AND Operator</link>"
msgstr "<link href=\"text/sbasic/shared/03060100.xhp\">ຕົວດຳເນີນການ AND</link>"

#. 3PFwA
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3143268\n"
"help.text"
msgid "Logically combines two expressions."
msgstr "ຮວມສອງສຳນວນເຂົ້າກັນທາງຕັກກະສາດ."

#. c8FVE
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"hd_id3147574\n"
"help.text"
msgid "Syntax:"
msgstr "ໄວຍາກອນ:"

#. jairQ
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3156344\n"
"help.text"
msgid "Result = Expression1 And Expression2"
msgstr "ຜົນໄດ້ຮັບ = ສຳນວນ1 And ສຳນວນ2"

#. Nfu49
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"hd_id3148946\n"
"help.text"
msgid "Parameters:"
msgstr "ພາຣາມີເຕີ:"

#. ovB8C
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3149457\n"
"help.text"
msgid "<emph>Result:</emph> Any numeric variable that records the result of the combination."
msgstr "<emph>ຜົນໄດ້ຮັບ:</emph> ຕົວປ່ຽນຕົວເລກໃດໜຶ່ງທີ່ບັນທຶກຜົນຂອງການຮວມກັນ."

#. Fqpsu
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3150541\n"
"help.text"
msgid "<emph>Expression1, Expression2:</emph> Any expressions that you want to combine."
msgstr "<emph>ສຳນວນ1, ສຳນວນ2:</emph> ສຳນວນໃດໜຶ່ງທີ່ທ່ານຕ້ອງການຮວມເຂົ້າກັນ."

#. iXktT
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3156215\n"
"help.text"
msgid "Boolean expressions combined with AND only return the value <emph>True</emph> if both expressions evaluate to <emph>True</emph>:"
msgstr "ສຳນວນ Boolean ທີ່ຮວມດ້ວຍ AND ຈະສົ່ງຄືນຄ່າ <emph>True</emph> ກໍຕໍ່ເມື່ອທັງສອງສຳນວນມີຄ່າເປັນ <emph>True</emph> ເທົ່ານັ້ນ:"

#. EW3Cz
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3150870\n"
"help.text"
msgid "<emph>True</emph> AND <emph>True</emph> returns <emph>True</emph>; for all other combinations the result is <emph>False</emph>."
msgstr "<emph>True</emph> AND <emph>True</emph> ຈະສົ່ງຄືນ <emph>True</emph>; ສຳລັບການຮວມກັນແບບອື່ນໆ ຜົນໄດ້ຮັບຈະເປັນ <emph>False</emph>."

#. B6iuu
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3153768\n"
"help.text"
msgid "The AND operator also performs a bitwise comparison of identically positioned bits in two numeric expressions."
msgstr "ຕົວດຳເນີນການ AND ຍັງເຮັດການປຽບທຽບແບບບິດ (bitwise) ຂອງບິດທີ່ຢູ່ໃນຕຳແໜ່ງດຽວກັນໃນສອງສຳນວນຕົວເລກ."

#. fiZ9F
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"hd_id3153727\n"
"help.text"
msgid "Example:"
msgstr "ຕົວຢ່າງ:"

#. wxads
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3146984\n"
"help.text"
msgid "vVarOut = A > B And B > C ' returns -1"
msgstr "vVarOut = A > B And B > C ' ສົ່ງຄືນ -1"

#. SdE4N
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3154014\n"
"help.text"
msgid "vVarOut = B > A And B > C ' returns 0"
msgstr "vVarOut = B > A And B > C ' ສົ່ງຄືນ 0"

#. G6dnE
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3149262\n"
"help.text"
msgid "vVarOut = A > B And B > D ' returns 0"
msgstr "vVarOut = A > B And B > D ' ສົ່ງຄືນ 0"

#. PFew6
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3145751\n"
"help.text"
msgid "vVarOut = (B > D And B > A) ' returns 0"
msgstr "vVarOut = (B > D And B > A) ' ສົ່ງຄືນ 0"

#. kRzbt
#: 03060100.xhp
msgctxt ""
"03060100.xhp\n"
"par_id3147394\n"
"help.text"
msgid "vVarOut = B And A ' returns 8 due to the bitwise And combination of both arguments"
msgstr "vVarOut = B And A ' ສົ່ງຄືນ 8 ຍ້ອນການຮວມກັນແບບບິດ (bitwise And) ຂອງທັງສອງອາກິວເມັນ"

#. BAgFA
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"tit\n"
"help.text"
msgid "Eqv Operator"
msgstr "ຕົວດຳເນີນການ Eqv"

#. q6v9d
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"bm_id3156344\n"
"help.text"
msgid "<bookmark_value>Eqv operator (logical)</bookmark_value>"
msgstr "<bookmark_value>ຕົວດຳເນີນການ Eqv (ທາງຕັກກະສາດ)</bookmark_value>"

#. EQ8cg
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"hd_id3156344\n"
"help.text"
msgid "<link href=\"text/sbasic/shared/03060200.xhp\">Eqv Operator</link>"
msgstr "<link href=\"text/sbasic/shared/03060200.xhp\">ຕົວດຳເນີນການ Eqv</link>"

#. oTT4F
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3149656\n"
"help.text"
msgid "Calculates the logical equivalence of two expressions."
msgstr "ຄຳນວນຄວາມສົມມູນທາງຕັກກະສາດ (logical equivalence) ຂອງສອງສຳນວນ."

#. sRZNW
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"hd_id3154367\n"
"help.text"
msgid "Syntax:"
msgstr "ໄວຍາກອນ:"

#. m9bM6
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3154910\n"
"help.text"
msgid "Result = Expression1 Eqv Expression2"
msgstr "ຜົນໄດ້ຮັບ = ສຳນວນ1 Eqv ສຳນວນ2"

#. 7fkPv
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"hd_id3151043\n"
"help.text"
msgid "Parameters:"
msgstr "ພາຣາມີເຕີ:"

#. DCU3B
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3150869\n"
"help.text"
msgid "<emph>Result:</emph> Any numeric variable that contains the result of the comparison."
msgstr "<emph>ຜົນໄດ້ຮັບ:</emph> ຕົວປ່ຽນຕົວເລກໃດໜຶ່ງທີ່ມີຜົນຂອງການປຽບທຽບ."

#. YrAyQ
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3150448\n"
"help.text"
msgid "<emph>Expression1, Expression2:</emph> Any expressions that you want to compare."
msgstr "<emph>ສຳນວນ1, ສຳນວນ2:</emph> ສຳນວນໃດໜຶ່ງທີ່ທ່ານຕ້ອງການປຽບທຽບ."

#. SBRud
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3149562\n"
"help.text"
msgid "When testing for equivalence between Boolean expressions, the result is <emph>True</emph> if both expressions are either <emph>True</emph> or <emph>False</emph>."
msgstr "ເມື່ອກວດສອບຄວາມສົມມູນລະຫວ່າງສຳນວນ Boolean, ຜົນໄດ້ຮັບຈະເປັນ <emph>True</emph> ຖ້າທັງສອງສຳນວນເປັນ <emph>True</emph> ຄືກັນ ຫຼື ເປັນ <emph>False</emph> ຄືກັນ."

#. XrGXb
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3154319\n"
"help.text"
msgid "In a bit-wise comparison, the Eqv operator only sets the corresponding bit in the result if a bit is set in both expressions, or in neither expression."
msgstr "ໃນການປຽບທຽບແບບບິດ (bit-wise), ຕົວດຳເນີນການ Eqv ຈະກຳນົດບິດໃນຜົນໄດ້ຮັບກໍຕໍ່ເມື່ອບິດຖືກກຳນົດໄວ້ໃນທັງສອງສຳນວນ ຫຼື ບໍ່ໄດ້ຖືກກຳນົດໄວ້ທັງສອງສຳນວນ."

#. FpFjm
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"hd_id3159154\n"
"help.text"
msgid "Example:"
msgstr "ຕົວຢ່າງ:"

#. CTzEE
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3152462\n"
"help.text"
msgid "vOut = A > B Eqv B > C ' returns -1"
msgstr "vOut = A > B Eqv B > C ' ສົ່ງຄືນ -1"

#. AABHv
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3153191\n"
"help.text"
msgid "vOut = B > A Eqv B > C ' returns 0"
msgstr "vOut = B > A Eqv B > C ' ສົ່ງຄືນ 0"

#. NzGSq
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3145799\n"
"help.text"
msgid "vOut = A > B Eqv B > D ' returns 0"
msgstr "vOut = A > B Eqv B > D ' ສົ່ງຄືນ 0"

#. Dj4eg
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3149412\n"
"help.text"
msgid "vOut = (B > D Eqv B > A) ' returns -1"
msgstr "vOut = (B > D Eqv B > A) ' ສົ່ງຄືນ -1"

#. 6UE66
#: 03060200.xhp
msgctxt ""
"03060200.xhp\n"
"par_id3149959\n"
"help.text"
msgid "vOut = B Eqv A ' returns -3"
msgstr "vOut = B Eqv A ' ສົ່ງຄືນ -3"

#. e6CH3
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"tit\n"
"help.text"
msgid "Imp Operator"
msgstr "ຕົວດຳເນີນການ Imp"

#. QBcCo
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"bm_id3156024\n"
"help.text"
msgid "<bookmark_value>Imp operator (logical)</bookmark_value>"
msgstr "<bookmark_value>ຕົວດຳເນີນການ Imp (ທາງຕັກກະສາດ)</bookmark_value>"

#. UMvpF
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"hd_id3156024\n"
"help.text"
msgid "<link href=\"text/sbasic/shared/03060300.xhp\">Imp Operator</link>"
msgstr "<link href=\"text/sbasic/shared/03060300.xhp\">ຕົວດຳເນີນການ Imp</link>"

#. Zk7uh
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3148947\n"
"help.text"
msgid "Performs a logical implication on two expressions."
msgstr "ເຮັດການຫາຜົນເນື່ອງທາງຕັກກະສາດ (logical implication) ໃນສອງສຳນວນ."

#. KSTDz
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"hd_id3148664\n"
"help.text"
msgid "Syntax:"
msgstr "ໄວຍາກອນ:"

#. pVyFU
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3149656\n"
"help.text"
msgid "Result = Expression1 Imp Expression2"
msgstr "ຜົນໄດ້ຮັບ = ສຳນວນ1 Imp ສຳນວນ2"

#. gDpsZ
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"hd_id3151212\n"
"help.text"
msgid "Parameters:"
msgstr "ພາຣາມີເຕີ:"

#. pDyKZ
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3154910\n"
"help.text"
msgid "<emph>Result:</emph> Any numeric variable that contains the result of the implication."
msgstr "<emph>ຜົນໄດ້ຮັບ:</emph> ຕົວປ່ຽນຕົວເລກໃດໜຶ່ງທີ່ມີຜົນຂອງການຫາຜົນເນື່ອງ."

#. Xb3AG
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3156281\n"
"help.text"
msgid "<emph>Expression1, Expression2:</emph> Any expressions that you want to evaluate with the Imp operator."
msgstr "<emph>ສຳນວນ1, ສຳນວນ2:</emph> ສຳນວນໃດໜຶ່ງທີ່ທ່ານຕ້ອງການປະເມີນດ້ວຍຕົວດຳເນີນການ Imp."

#. Co5Tp
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3150440\n"
"help.text"
msgid "If you use the Imp operator in Boolean expressions, False is only returned if the first expression evaluates to True and the second expression to False."
msgstr "ຖ້າທ່ານໃຊ້ຕົວດຳເນີນການ Imp ໃນສຳນວນ Boolean, ຄ່າ False ຈະຖືກສົ່ງຄືນກໍຕໍ່ເມື່ອສຳນວນທຳອິດເປັນ True ແລະ ສຳນວນທີສອງເປັນ False ເທົ່ານັ້ນ."

#. d8L7N
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3163710\n"
"help.text"
msgid "If you use the Imp operator in bit expressions, a bit is deleted from the result if the corresponding bit is set in the first expression and the corresponding bit is deleted in the second expression."
msgstr "ຖ້າທ່ານໃຊ້ຕົວດຳເນີນການ Imp ໃນສຳນວນບິດ, ບິດຈະຖືກລຶບອອກຈາກຜົນໄດ້ຮັບຖ້າບິດທີ່ກົງກັນຖືກກຳນົດໄວ້ໃນສຳນວນທຳອິດ ແລະ ບິດທີ່ກົງກັນຖືກລຶບອອກໃນສຳນວນທີສອງ."

#. 7yM6j
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"hd_id3147318\n"
"help.text"
msgid "Example:"
msgstr "ຕົວຢ່າງ:"

#. dcfRL
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3145750\n"
"help.text"
msgid "vOut = A > B Imp B > C ' returns -1"
msgstr "vOut = A > B Imp B > C ' ສົ່ງຄືນ -1"

#. xKfkN
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3156441\n"
"help.text"
msgid "vOut = B > A Imp B > C ' returns -1"
msgstr "vOut = B > A Imp B > C ' ສົ່ງຄືນ -1"

#. tRwwC
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3152596\n"
"help.text"
msgid "vOut = A > B Imp B > D ' returns 0"
msgstr "vOut = A > B Imp B > D ' ສົ່ງຄືນ 0"

#. rNBo3
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3154942\n"
"help.text"
msgid "vOut = (B > D Imp B > A) ' returns -1"
msgstr "vOut = (B > D Imp B > A) ' ສົ່ງຄືນ -1"

#. VMGQS
#: 03060300.xhp
msgctxt ""
"03060300.xhp\n"
"par_id3154492\n"
"help.text"
msgid "vOut = B Imp A ' returns -1"
msgstr "vOut = B Imp A ' ສົ່ງຄືນ -1"

#. QbLzR
#: 03060400.xhp
msgctxt ""
"03060400.xhp\n"
"tit\n"
"help.text"
msgid "Not Operator"
msgstr "ຕົວດຳເນີນການ Not"

#. UfoBn
#: 03060400.xhp
msgctxt ""
