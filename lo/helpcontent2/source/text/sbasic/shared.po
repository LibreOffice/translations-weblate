msgctxt ""
"01170103.xhp\n"
"par_id3148837\n"
"help.text"
msgid "<ahelp hid=\"HID_EVT_KEYTYPED\">This event occurs when the user presses any key while the control has the focus.</ahelp>"
msgstr "<ahelp hid=\"HID_EVT_KEYTYPED\">ເຫດການນີ້ຈະເກີດຂຶ້ນ ເມື່ອຜູ້ໃຊ້ກົດປຸ່ມໃດໜຶ່ງ ໃນຂະນະທີ່ການຄວບຄຸມນັ້ນກຳລັງໄດ້ຮັບໂຟກັສ.</ahelp>"

#. MsbEr
