msgstr "ຊື່ບໍລິການ (ServiceName)"

#. oAwUV
#: CreateUnoSvcWithArgs.xhp
msgctxt ""
"CreateUnoSvcWithArgs.xhp\n"
"par_id111744665754544\n"
"help.text"
msgid "The UNO service name to be created."
msgstr "ຊື່ຂອງບໍລິການ UNO ທີ່ຈະສ້າງ."

#. trHkj
