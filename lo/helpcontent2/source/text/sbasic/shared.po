msgstr "<bookmark_value>ຟັງຊັນ Mid</bookmark_value>"

#. AVYiv
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"hd_id3143268\n"
"help.text"
msgid "<link href=\"text/sbasic/shared/03120306.xhp\">Mid Function</link>"
msgstr "<link href=\"text/sbasic/shared/03120306.xhp\">ຟັງຊັນ Mid</link>"

#. oizxF
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3148473\n"
"help.text"
msgid "Returns the specified portion of a string expression (<emph>Mid function</emph>), or replaces the portion of a string expression with another string (<emph>Mid subroutine</emph>)."
msgstr "ສົ່ງຄືນສ່ວນທີ່ລະບຸຂອງນິພົດສະຕຣິງ (<emph>ຟັງຊັນ Mid</emph>), ຫຼື ແທນທີ່ບາງສ່ວນຂອງນິພົດສະຕຣິງດ້ວຍສະຕຣິງອື່ນ (<emph>ຄຳສັ່ງຍ່ອຍ Mid</emph>)."

#. dhBUa
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3147530\n"
"help.text"
msgid "Mid(string As String, Start As Long [, Length As Long]) As String"
msgstr "Mid(string As String, Start As Long [, Length As Long]) As String"

#. qxQdZ
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3147540\n"
"help.text"
msgid "Mid([ByRef] string As String, Start As Long, [Length As Long], Text As String)"
msgstr "Mid([ByRef] string As String, Start As Long, [Length As Long], Text As String)"

#. 5MG4F
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3149295\n"
"help.text"
msgid "String (only by Function)"
msgstr "String (ສະເພາະໂດຍຟັງຊັນ)"

#. GmhW3
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3148664\n"
"help.text"
msgid "<emph>string:</emph> Any string expression that you want to extract (<emph>Mid function</emph>). Any text variable name that you want to modify (<emph>Mid subroutine</emph>)."
msgstr "<emph>string:</emph> ນິພົດສະຕຣິງໃດໆ ທີ່ທ່ານຕ້ອງການດຶງຂໍ້ມູນອອກມາ (<emph>ຟັງຊັນ Mid</emph>). ຊື່ຕົວປ່ຽນຂໍ້ຄວາມໃດໆ ທີ່ທ່ານຕ້ອງການແກ້ໄຂ (<emph>ຄຳສັ່ງຍ່ອຍ Mid</emph>)."

#. DGPaB
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3150359\n"
"help.text"
msgid "<emph>Start: </emph>Numeric expression that indicates the character position within the string where the string portion that you want to replace or to return begins. The minimum allowed value is 1. The maximum allowed value is 2,147,483,648."
msgstr "<emph>Start: </emph>ນິພົດຕົວເລກທີ່ລະບຸຕຳແໜ່ງຕົວອັກສອນໃນສະຕຣິງທີ່ສ່ວນຂອງສະຕຣິງທີ່ທ່ານຕ້ອງການແທນທີ່ ຫຼື ສົ່ງຄືນເລີ່ມຕົ້ນ. ຄ່າຕ່ຳສຸດແມ່ນ 1. ຄ່າສູງສຸດແມ່ນ 2,147,483,648."

#. dtyT5
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3148451\n"
"help.text"
msgid "<emph>Length:</emph> Numeric expression that returns the number of characters that you want to replace or return. The maximum allowed value is 2,147,483,648."
msgstr "<emph>Length:</emph> ນິພົດຕົວເລກທີ່ສົ່ງຄືນຈຳນວນຕົວອັກສອນທີ່ທ່ານຕ້ອງການແທນທີ່ ຫຼື ສົ່ງຄືນ. ຄ່າສູງສຸດແມ່ນ 2,147,483,648."

#. Cw9Ts
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3125864\n"
"help.text"
msgid "If the Length parameter in the <emph>Mid function</emph> is omitted, all characters in the string expression from the start position to the end of the string are returned."
msgstr "ຖ້າລະເວັ້ນພາຣາມິເຕີ Length ໃນ <emph>ຟັງຊັນ Mid</emph>, ຕົວອັກສອນທັງໝົດໃນນິພົດສະຕຣິງຕັ້ງແຕ່ຕຳແໜ່ງເລີ່ມຕົ້ນຈົນເຖິງທ້າຍສະຕຣິງຈະຖືກສົ່ງຄືນ."

#. xZtHf
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3144762\n"
"help.text"
msgid "If the Length parameter in the <emph>Mid subroutine</emph> is less than the length of the text that you want to replace, the text is reduced to the specified length."
msgstr "ຖ້າພາຣາມິເຕີ Length ໃນ <emph>ຄຳສັ່ງຍ່ອຍ Mid</emph> ໜ້ອຍກວ່າຄວາມຍາວຂອງຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການແທນທີ່, ຂໍ້ຄວາມຈະຖືກຕັດໃຫ້ເຫຼືອຕາມຄວາມຍາວທີ່ລະບຸ."

#. VJNon
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"par_id3150769\n"
"help.text"
msgid "<emph>Text:</emph> The string to replace the string expression (<emph>Mid subroutine</emph>)."
msgstr "<emph>Text:</emph> ສະຕຣິງທີ່ຈະນຳມາແທນທີ່ນິພົດສະຕຣິງ (<emph>ຄຳສັ່ງຍ່ອຍ Mid</emph>)."

#. i7G63
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"bas_id81731518142155\n"
"help.text"
msgid "MsgBox Mid(text, 13, 8)   ' returns the word \"original\""
msgstr "MsgBox Mid(text, 13, 8)   ' ສົ່ງຄືນຄຳວ່າ \"original\""

#. 24dMP
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"bas_id71731518142368\n"
"help.text"
msgid "MsgBox text               ' text is not modified"
msgstr "MsgBox text               ' text ຈະບໍ່ຖືກແກ້ໄຂ"

#. Wg8pU
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"bas_id51731518274333\n"
"help.text"
msgid "MsgBox text               ' returns \"This is the new Text\""
msgstr "MsgBox text               ' ສົ່ງຄືນ \"This is the new Text\""

#. 6FGfy
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"bas_id461725547890578\n"
"help.text"
msgid "MsgBox Mid(start:=10, string:=\"The quick brown fox ..\") ' shows \" brown fox ..\""
msgstr "MsgBox Mid(start:=10, string:=\"The quick brown fox ..\") ' ສະແດງ \" brown fox ..\""

#. c6TTN
#: 03120306.xhp
msgctxt ""
"03120306.xhp\n"
"bas_id31731517580882\n"
"help.text"
msgid "MsgBox text               ' returns \"This is a new Phrase\""
msgstr "MsgBox text               ' ສົ່ງຄືນ \"This is a new Phrase\""

