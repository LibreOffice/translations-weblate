"help.text"
msgid "<image id=\"img_id3157909\" src=\"cmd/lc_pushbutton.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3157909\">Icon Button</alt></image>"
msgstr "<image id=\"img_id3157909\" src=\"cmd/lc_pushbutton.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3157909\">ໄອຄອນ ປຸ່ມ</alt></image>"

#. pGofA
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3147530\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertPushbutton\">Adds a command button.</ahelp> You can use a command button to execute a command for a defined event, such as a mouse click."
msgstr "<ahelp hid=\".uno:InsertPushbutton\">ເພີ່ມປຸ່ມຄຳສັ່ງ.</ahelp> ທ່ານສາມາດໃຊ້ປຸ່ມຄຳສັ່ງເພື່ອປະຕິບັດຄຳສັ່ງສຳລັບເຫດການທີ່ກຳນົດໄວ້ ເຊັ່ນ: ການຄລິກເມົາສ໌."

#. GZHQC
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3154923\n"
"help.text"
msgid "If you want, you can add text or a graphic to the button."
msgstr "ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດເພີ່ມຂໍ້ຄວາມ ຫຼື ກຣາຟິກໃສ່ປຸ່ມໄດ້."

#. EFgyZ
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3148550\n"
"help.text"
msgid "Image Control"
msgstr "ຕົວຄວບຄຸມຮູບພາບ"

#. 9RtfG
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3154138\n"
"help.text"
msgid "<image id=\"img_id3144760\" src=\"cmd/lc_objectcatalog.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3144760\">Icon Image Control</alt></image>"
msgstr "<image id=\"img_id3144760\" src=\"cmd/lc_objectcatalog.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3144760\">ໄອຄອນ ຕົວຄວບຄຸມຮູບພາບ</alt></image>"

#. VFc83
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3151042\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertImageControl\">Adds a control that displays a graphic.</ahelp>"
msgstr "<ahelp hid=\".uno:InsertImageControl\">ເພີ່ມຕົວຄວບຄຸມທີ່ສະແດງກຣາຟິກ.</ahelp>"

#. bYtDg
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3150447\n"
"help.text"
msgid "Check Box"
msgstr "ຊ່ອງໝາຍ"

#. 3VoQu
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3155131\n"
"help.text"
msgid "<image id=\"img_id3150439\" src=\"cmd/lc_checkbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150439\">Icon Check Box</alt></image>"
msgstr "<image id=\"img_id3150439\" src=\"cmd/lc_checkbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150439\">ໄອຄອນ ຊ່ອງໝາຍ</alt></image>"

#. QWB7B
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3147317\n"
"help.text"
msgid "<ahelp hid=\".uno:Checkbox\">Adds a check box that you can use to turn a function on or off.</ahelp>"
msgstr "<ahelp hid=\".uno:Checkbox\">ເພີ່ມຊ່ອງໝາຍທີ່ທ່ານສາມາດໃຊ້ເພື່ອເປີດ ຫຼື ປິດຟັງຊັນໄດ້.</ahelp>"

#. gG6kh
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3150486\n"
"help.text"
msgid "Option Button"
msgstr "ປຸ່ມເລືອກ"

#. UqCSH
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3155856\n"
"help.text"
msgid "<image id=\"img_id3146921\" src=\"cmd/lc_radiobutton.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3146921\">Icon Option Button</alt></image>"
msgstr "<image id=\"img_id3146921\" src=\"cmd/lc_radiobutton.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3146921\">ໄອຄອນ ປຸ່ມເລືອກ</alt></image>"

#. FNGHF
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3153575\n"
"help.text"
msgid "<ahelp hid=\".uno:Radiobutton\">Adds a button that allows a user to select from a number of options.</ahelp> Grouped option buttons must have consecutive tab order. They are commonly encircled by a group box. If you have two groups of option buttons, you must insert a tab order between the tab orders of the two groups. For example, to the frame of the second group, or to any other control in the dialog, with the exception of another option button."
msgstr "<ahelp hid=\".uno:Radiobutton\">ເພີ່ມປຸ່ມທີ່ຊ່ວຍໃຫ້ຜູ້ໃຊ້ເລືອກຈາກຕົວເລືອກຕ່າງໆ.</ahelp> ປຸ່ມເລືອກທີ່ຈັດກຸ່ມໄວ້ຕ້ອງມີລຳດັບແທັບ (tab order) ຕໍ່ເນື່ອງກັນ. ປົກກະຕິແລ້ວພວກມັນຈະຖືກລ້ອມຮອບດ້ວຍກ່ອງຈັດກຸ່ມ. ຖ້າທ່ານມີປຸ່ມເລືອກສອງກຸ່ມ, ທ່ານຕ້ອງແຊກລຳດັບແທັບລະຫວ່າງລຳດັບແທັບຂອງທັງສອງກຸ່ມ. ຕົວຢ່າງ: ໃສ່ໄວ້ທີ່ຂອບຂອງກຸ່ມທີສອງ, ຫຼື ຕົວຄວບຄຸມອື່ນໆໃນໄດອາລັອກ ຍົກເວັ້ນປຸ່ມເລືອກອື່ນ."

#. DaRgN
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3154729\n"
"help.text"
msgid "Label Field"
msgstr "ຟີລປ້າຍຊື່"

#. dFoER
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3149300\n"
"help.text"
msgid "<image id=\"img_id3153415\" src=\"cmd/lc_insertfixedtext.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153415\">Icon Label Field</alt></image>"
msgstr "<image id=\"img_id3153415\" src=\"cmd/lc_insertfixedtext.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153415\">ໄອຄອນ ຟີລປ້າຍຊື່</alt></image>"

#. XA4Aw
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3156181\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertFixedText\">Adds a field for displaying text labels.</ahelp> These labels are only for displaying predefined text, and not for entering text."
msgstr "<ahelp hid=\".uno:InsertFixedText\">ເພີ່ມຟີລສຳລັບສະແດງປ້າຍຊື່ຂໍ້ຄວາມ.</ahelp> ປ້າຍຊື່ເຫຼົ່ານີ້ມີໄວ້ເພື່ອສະແດງຂໍ້ຄວາມທີ່ກຳນົດໄວ້ເທົ່ານັ້ນ, ບໍ່ແມ່ນສຳລັບປ້ອນຂໍ້ຄວາມ."

#. BupCK
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3149123\n"
"help.text"
msgid "Text Box"
msgstr "ກ່ອງຂໍ້ຄວາມ"

#. xNDkz
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3153766\n"
"help.text"
msgid "<image id=\"img_id3148996\" src=\"cmd/lc_edit.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3148996\">Icon Text Box</alt></image>"
msgstr "<image id=\"img_id3148996\" src=\"cmd/lc_edit.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3148996\">ໄອຄອນ ກ່ອງຂໍ້ຄວາມ</alt></image>"

#. ruGZ2
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3153712\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertEdit\">Adds an input box where you can enter and edit text.</ahelp>"
msgstr "<ahelp hid=\".uno:InsertEdit\">ເພີ່ມກ່ອງປ້ອນຂໍ້ມູນທີ່ທ່ານສາມາດປ້ອນ ແລະ ແກ້ໄຂຂໍ້ຄວາມໄດ້.</ahelp>"

#. zPAk2
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3154253\n"
"help.text"
msgid "List Box"
msgstr "ກ່ອງລາຍການ"

#. rGuc6
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3155959\n"
"help.text"
msgid "<image id=\"img_id3163808\" src=\"cmd/lc_listbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3163808\">Icon List Box</alt></image>"
msgstr "<image id=\"img_id3163808\" src=\"cmd/lc_listbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3163808\">ໄອຄອນ ກ່ອງລາຍການ</alt></image>"

#. CZ7M5
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3155176\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertListbox\">Adds a box where you can click an entry on a list.</ahelp>"
msgstr "<ahelp hid=\".uno:InsertListbox\">ເພີ່ມກ່ອງທີ່ທ່ານສາມາດຄລິກເລືອກລາຍການໃນລາຍການໄດ້.</ahelp>"

#. Beb2k
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3150644\n"
"help.text"
msgid "Combo Box"
msgstr "ກ່ອງຄອມໂບ"

#. HQbE9
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3148418\n"
"help.text"
msgid "<image id=\"img_id3153200\" src=\"cmd/lc_combobox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153200\">Icon Combo Box</alt></image>"
msgstr "<image id=\"img_id3153200\" src=\"cmd/lc_combobox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153200\">ໄອຄອນ ກ່ອງຄອມໂບ</alt></image>"

#. Vdn74
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3154199\n"
"help.text"
msgid "<ahelp hid=\".uno:Combobox\">Adds a combo box. A combo box is a one line list box that a user can click, and then choose an entry from the list.</ahelp> If you want, you can make the entries in the combo box \"read only\"."
msgstr "<ahelp hid=\".uno:Combobox\">ເພີ່ມກ່ອງຄອມໂບ. ກ່ອງຄອມໂບແມ່ນກ່ອງລາຍການແບບແຖວດຽວທີ່ຜູ້ໃຊ້ສາມາດຄລິກເພື່ອເລືອກລາຍການຈາກລາຍຊື່ໄດ້.</ahelp> ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດກຳນົດໃຫ້ລາຍການໃນກ່ອງຄອມໂບເປັນ \"ອ່ານຢ່າງດຽວ\" ໄດ້."

#. Q7efB
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3154585\n"
"help.text"
msgid "Horizontal Scrollbar"
msgstr "ແຖບເລື່ອນແນວນອນ"

#. bivNk
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3153781\n"
"help.text"
msgid "<image id=\"img_id3149530\" src=\"cmd/lc_hscrollbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149530\">Icon Horizontal Scrollbar</alt></image>"
msgstr "<image id=\"img_id3149530\" src=\"cmd/lc_hscrollbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149530\">ໄອຄອນ ແຖບເລື່ອນແນວນອນ</alt></image>"

#. Vbp2o
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3153232\n"
"help.text"
msgid "<ahelp hid=\".uno:HScrollbar\">Adds a horizontal scrollbar to the dialog.</ahelp>"
msgstr "<ahelp hid=\".uno:HScrollbar\">ເພີ່ມແຖບເລື່ອນແນວນອນໃຫ້ກັບໄດອາລັອກ.</ahelp>"

#. ECtLc
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3154119\n"
"help.text"
msgid "Vertical Scrollbar"
msgstr "ແຖບເລື່ອນແນວຕັ້ງ"

#. 3Xy56
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3150515\n"
"help.text"
msgid "<image id=\"img_id3150203\" src=\"cmd/lc_crollbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150203\">Icon Vertical Scrollbar</alt></image>"
msgstr "<image id=\"img_id3150203\" src=\"cmd/lc_crollbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150203\">ໄອຄອນ ແຖບເລື່ອນແນວຕັ້ງ</alt></image>"

#. NmKDo
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3155376\n"
"help.text"
msgid "<ahelp hid=\".uno:VScrollbar\">Adds a vertical scrollbar to the dialog.</ahelp>"
msgstr "<ahelp hid=\".uno:VScrollbar\">ເພີ່ມແຖບເລື່ອນແນວຕັ້ງໃຫ້ກັບໄດອາລັອກ.</ahelp>"

#. JmAgh
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3150313\n"
"help.text"
msgid "Group Box"
msgstr "ກ່ອງຈັດກຸ່ມ"

#. DuDGS
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3151184\n"
"help.text"
msgid "<image id=\"img_id3151335\" src=\"cmd/lc_groupbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3151335\">Icon Group Box</alt></image>"
msgstr "<image id=\"img_id3151335\" src=\"cmd/lc_groupbox.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3151335\">ໄອຄອນ ກ່ອງຈັດກຸ່ມ</alt></image>"

#. aMgsB
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3159622\n"
"help.text"
msgid "<ahelp hid=\".uno:Groupbox\">Adds a frame that you can use to visually group similar controls, such as option buttons.</ahelp>"
msgstr "<ahelp hid=\".uno:Groupbox\">ເພີ່ມຂອບທີ່ທ່ານສາມາດໃຊ້ເພື່ອຈັດກຸ່ມຕົວຄວບຄຸມທີ່ຄ້າຍຄືກັນ ເຊັ່ນ: ປຸ່ມເລືອກ ໃຫ້ເຫັນໄດ້ຊັດເຈນ.</ahelp>"

#. CQpDj
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3148820\n"
"help.text"
msgid "To define two different groups of option buttons, ensure that the tab index of the group frame is between the tab indices of the two groups."
msgstr "ເພື່ອຕັ້ງຄ່າປຸ່ມເລືອກສອງກຸ່ມທີ່ແຕກຕ່າງກັນ, ໃຫ້ແນ່ໃຈວ່າດັດຊະນີແທັບ (tab index) ຂອງຂອບກຸ່ມຢູ່ລະຫວ່າງດັດຊະນີແທັບຂອງທັງສອງກຸ່ມ."

#. qusDD
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3149330\n"
"help.text"
msgid "Progress Bar"
msgstr "ແຖບຄວາມຄືບໜ້າ"

#. 4aMf7
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3159093\n"
"help.text"
msgid "<image id=\"img_id3150318\" src=\"cmd/lc_progressbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150318\">Icon Progress Bar</alt></image>"
msgstr "<image id=\"img_id3150318\" src=\"cmd/lc_progressbar.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3150318\">ໄອຄອນ ແຖບຄວາມຄືບໜ້າ</alt></image>"

#. AUUic
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3157979\n"
"help.text"
msgid "<ahelp hid=\".uno:ProgressBar\">Adds a progress bar to the dialog.</ahelp>"
msgstr "<ahelp hid=\".uno:ProgressBar\">ເພີ່ມແຖບຄວາມຄືບໜ້າໃຫ້ກັບໄດອາລັອກ.</ahelp>"

#. 2xdUf
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3145654\n"
"help.text"
msgid "Horizontal Line"
msgstr "ເສັ້ນນອນ"

#. aFEXj
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3150888\n"
"help.text"
