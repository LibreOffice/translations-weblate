msgstr "<image id=\"img_id3152872\" src=\"cmd/lc_hfixedline.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3152872\">ໄອຄອນ ເສັ້ນນອນ</alt></image>"

#. rVrjy
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3151000\n"
"help.text"
msgid "<ahelp hid=\".uno:HFixedLine\">Adds a horizontal line to the dialog.</ahelp>"
msgstr "<ahelp hid=\".uno:HFixedLine\">ເພີ່ມເສັ້ນນອນໃຫ້ກັບໄດອາລັອກ.</ahelp>"

#. UcBeW
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"hd_id3155095\n"
"help.text"
msgid "Vertical Line"
msgstr "ເສັ້ນຕັ້ງ"

#. rcEEN
#: 20000000.xhp
msgctxt ""
"20000000.xhp\n"
"par_id3154913\n"
