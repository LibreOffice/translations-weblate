msgstr "ມາໂຄຣ"

#. Knnfd
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3152886\n"
"help.text"
msgid "<variable id=\"makro\"><ahelp hid=\".uno:ChooseMacro\">Opens the <emph>Macro</emph> dialog, where you can create, edit, organize, and run $[officename] Basic macros.</ahelp></variable>"
msgstr "<variable id=\"makro\"><ahelp hid=\".uno:ChooseMacro\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ມາໂຄຣ</emph>, ເຊິ່ງທ່ານສາມາດ ສ້າງ, ແກ້ໄຂ, ຈັດການ ແລະ ລັນ ມາໂຄຣ Basic ຂອງ $[officename] ໄດ້.</ahelp></variable>"

#. YFNsk
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3154145\n"
"help.text"
msgid "Macro name"
msgstr "ຊື່ມາໂຄຣ"

#. oAFgs
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3151116\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/macronameedit\">Displays the name of the selected macro. To create or to change the name of a macro, enter a name here.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/macronameedit\">ສະແດງຊື່ຂອງມາໂຄຣທີ່ເລືອກ. ເພື່ອສ້າງ ຫຼື ປ່ຽນຊື່ຂອງມາໂຄຣ, ໃຫ້ປ້ອນຊື່ໃສ່ທີ່ນີ້.</ahelp>"

#. bAnLi
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3153729\n"
"help.text"
msgid "Macro from / Save macro in"
msgstr "ມາໂຄຣຈາກ / ບັນທຶກມາໂຄຣໄວ້ໃນ"

#. VGm8h
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3153190\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/libraries\">Lists the libraries and the modules where you can open or save your macros. To save a macro with a particular document, open the document, and then open this dialog.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/libraries\">ລາຍຊື່ຄັງ ແລະ ໂມດູນ ທີ່ທ່ານສາມາດເປີດ ຫຼື ບັນທຶກມາໂຄຣຂອງທ່ານໄດ້. ເພື່ອບັນທຶກມາໂຄຣໄວ້ກັບເອກະສານໃດໜຶ່ງໂດຍສະເພາະ, ໃຫ້ເປີດເອກະສານນັ້ນ ແລ້ວຈຶ່ງເປີດກ່ອງໂຕ້ຕອບນີ້.</ahelp>"

#. DS2rV
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3146975\n"
"help.text"
msgid "Run / Save"
msgstr "ລັນ / ບັນທຶກ"

#. FNpEE
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3154791\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/ok\">Runs or saves the current macro.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/ok\">ລັນ ຫຼື ບັນທຶກ ມາໂຄຣປັດຈຸບັນ.</ahelp>"

#. q8TCE
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3153158\n"
"help.text"
msgid "Assign"
msgstr "ກຳນົດ"

#. oo9tG
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3149961\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/assign\">Opens the Customize dialog, where you can assign the selected macro to a menu command, a toolbar, or an event.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/assign\">ເປີດກ່ອງໂຕ້ຕອບການປັບແຕ່ງ, ເຊິ່ງທ່ານສາມາດກຳນົດມາໂຄຣທີ່ເລືອກ ໃຫ້ກັບຄຳສັ່ງເມນູ, ແຖບເຄື່ອງມື ຫຼື ເຫດການໃດໜຶ່ງ.</ahelp>"

#. FPBtn
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3145799\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. FRwKP
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3147127\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/edit\">Starts the $[officename] Basic editor and opens the selected macro for editing.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/edit\">ເລີ່ມຕົ້ນຕົວແກ້ໄຂ Basic ຂອງ $[officename] ແລະ ເປີດມາໂຄຣທີ່ເລືອກເພື່ອແກ້ໄຂ.</ahelp>"

#. RbUsU
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3149400\n"
"help.text"
msgid "New/Delete"
msgstr "ໃໝ່/ລຶບ"

#. 3eRrt
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3155602\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/delete\">Creates a new macro, or deletes the selected macro.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/delete\">ສ້າງມາໂຄຣໃໝ່ ຫຼື ລຶບມາໂຄຣທີ່ເລືອກ.</ahelp>"

#. XzjjH
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3149124\n"
"help.text"
msgid "To create a new macro, select the \"Standard\" module in the <emph>Macro from</emph> list, and then click <emph>New</emph>."
msgstr "ເພື່ອສ້າງມາໂຄຣໃໝ່, ໃຫ້ເລືອກໂມດູນ \"Standard\" ໃນລາຍຊື່ <emph>ມາໂຄຣຈາກ</emph>, ແລ້ວຄລິກ <emph>ໃໝ່</emph>."

#. Bpdkd
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3150749\n"
"help.text"
msgid "To delete a macro, select it, and then click <emph>Delete</emph>."
msgstr "ເພື່ອລຶບມາໂຄຣ, ໃຫ້ເລືອກມັນ ແລ້ວຄລິກ <emph>ລຶບ</emph>."

#. caLtQ
