msgid "Description"
msgstr "ຄຳອະທິບາຍ"

#. qnRDA
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id49160078807654\n"
"help.text"
msgid "No"
msgstr "ບໍ່"

#. LE27e
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id81600788076419\n"
"help.text"
msgid "Character used to define the access key of a menu item. The default character is \"~\"."
msgstr "ຕົວອັກສອນທີ່ໃຊ້ກຳນົດຄີເຂົ້າເຖິງຂອງລາຍການເມນູ. ຕົວອັກສອນເລີ່ມຕົ້ນແມ່ນ \"~\"."

#. GSJAG
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id311600788076756\n"
"help.text"
msgid "No"
msgstr "ບໍ່"

#. fb3iG
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id441600788076826\n"
"help.text"
msgid "Character or string that defines how menu items are nested. The default character is \">\"."
msgstr "ຕົວອັກສອນ ຫຼື ຂໍ້ຄວາມທີ່ກຳນົດວ່າລາຍການເມນູຖືກຊ້ອນກັນແນວໃດ. ຕົວອັກສອນເລີ່ມຕົ້ນແມ່ນ \">\"."

#. bDCZ8
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"hd_id181636719707892\n"
"help.text"
msgid "Menu and Submenus"
msgstr "ເມນູ ແລະ ເມນູຍ່ອຍ"

#. YE5FL
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id741636719725402\n"
"help.text"
msgid "To create a menu with submenus, use the character defined in the <literal>SubmenuCharacter</literal> property while creating the menu entry to define where it will be placed. For instance, consider the following menu/submenu hierarchy."
msgstr "ເພື່ອສ້າງເມນູທີ່ມີເມນູຍ່ອຍ, ໃຫ້ໃຊ້ຕົວອັກສອນທີ່ກຳນົດໃນຄຸນສົມບັດ <literal>SubmenuCharacter</literal> ໃນຂະນະທີ່ສ້າງລາຍການເມນູເພື່ອລະບຸຕຳແໜ່ງທີ່ມັນຈະຢູ່."

#. Y4ETY
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id211636720111489\n"
"help.text"
msgid "The code below uses the default submenu character \">\" to create the menu/submenu hierarchy defined above:"
msgstr "ລະຫັດດ້ານລຸ່ມນີ້ໃຊ້ຕົວອັກສອນເມນູຍ່ອຍເລີ່ມຕົ້ນ \">\" ເພື່ອສ້າງລຳດັບຊັ້ນຂອງເມນູ/ເມນູຍ່ອຍ:"

#. P8NHo
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id121636721243578\n"
"help.text"
msgid "The string <literal>---</literal> is used to define separator lines in menus or submenus."
msgstr "ຂໍ້ຄວາມ <literal>---</literal> ແມ່ນໃຊ້ເພື່ອສ້າງເສັ້ນຂັ້ນໃນເມນູ ຫຼື ເມນູຍ່ອຍ."

#. CYbLC
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"hd_id501582887473754\n"
"help.text"
msgid "Methods"
msgstr "ວິທີການ"

#. Lofgb
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id891611613601554\n"
"help.text"
msgid "List of Methods in the Menu Service"
msgstr "ລາຍຊື່ວິທີການໃນບໍລິການ Menu"

#. aDqJH
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id93158919969864\n"
"help.text"
msgid "Inserts a check box in the menu. Returns an integer value that identifies the inserted item."
msgstr "ແຊກຊ່ອງໝາຍໃນເມນູ. ສົ່ງຄືນຄ່າຕົວເລກທີ່ລະບຸລາຍການທີ່ແຊກເຂົ້າໄປ."

#. T8Fkq
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id821591631203996\n"
"help.text"
msgid "<emph>menuitem:</emph> Defines the text to be displayed in the menu. This argument also defines the hierarchy of the item inside the menu by using the submenu character."
msgstr "<emph>menuitem:</emph> ກຳນົດຂໍ້ຄວາມທີ່ຈະສະແດງໃນເມນູ. ອາກິວເມັນນີ້ຍັງກຳນົດລຳດັບຊັ້ນຂອງລາຍການໃນເມນູໂດຍໃຊ້ຕົວອັກສອນເມນູຍ່ອຍ."

#. SkMmC
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id821591631203116\n"
"help.text"
msgid "<emph>name:</emph> String value used to identify the menu item. By default, the last component of the menu hierarchy is used."
msgstr "<emph>name:</emph> ຄ່າຂໍ້ຄວາມທີ່ໃຊ້ລະບຸລາຍການເມນູ. ໂດຍເລີ່ມຕົ້ນ, ຈະໃຊ້ສ່ວນປະກອບສຸດທ້າຍຂອງລຳດັບຊັ້ນເມນູ."

#. 7zhpM
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id821591631203133\n"
"help.text"
msgid "<emph>status:</emph> Defines whether the item is selected when the menu is created (Default = <literal>False</literal>)."
msgstr "<emph>status:</emph> ກຳນົດວ່າລາຍການຈະຖືກເລືອກໃນຕອນສ້າງເມນູບໍ (ເລີ່ມຕົ້ນ = <literal>False</literal>)."

#. JPboo
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id11636721653313\n"
"help.text"
msgid "<emph>icon:</emph> Path and name of the icon to be displayed without the leading path separator. The actual icon shown depends on the icon set being used."
msgstr "<emph>icon:</emph> ເສັ້ນທາງ ແລະ ຊື່ຂອງໄອຄອນທີ່ຈະສະແດງ."

#. YzJwB
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id11636721653208\n"
"help.text"
msgid "<emph>tooltip:</emph> Text to be displayed as tooltip."
msgstr "<emph>tooltip:</emph> ຂໍ້ຄວາມທີ່ຈະສະແດງເປັນຄຳແນະນຳເຄື່ອງມື."

#. 3WPXT
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id11636721653328\n"
"help.text"
msgid "<emph>command:</emph> The name of a UNO command without the <literal>.uno:</literal> prefix. If the command name does not exist, nothing happens."
msgstr "<emph>command:</emph> ຊື່ຂອງຄຳສັ່ງ UNO ໂດຍບໍ່ມີຄຳນຳໜ້າ <literal>.uno:</literal>."

#. LaF26
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id11636721653107\n"
"help.text"
msgid "<emph>script:</emph> The URI for a Basic or Python script that will be executed when the item is clicked."
msgstr "<emph>script:</emph> URI ສຳລັບສະຄຣິບ Basic ຫຼື Python ທີ່ຈະເຮັດວຽກເມື່ອຄລິກລາຍການ."

#. PTXhK
#: sf_menu.xhp
msgctxt ""
"sf_menu.xhp\n"
"par_id31643198954204\n"
"help.text"
msgid "The arguments <literal>command</literal> and <literal>script</literal> are mutually exclusive, hence only one of them can be set for each menu item."
msgstr "ອາກິວເມັນ <literal>command</literal> ແລະ <literal>script</literal> ບໍ່ສາມາດໃຊ້ພ້ອມກັນໄດ້, ດັ່ງນັ້ນຈຶ່ງຕັ້ງໄດ້ພຽງຢ່າງດຽວສຳລັບແຕ່ລະລາຍການເມນູ."

#. iodMg
