msgctxt ""
"sf_textstream.xhp\n"
"hd_id83158533078741\n"
"help.text"
msgid "Service invocation"
msgstr "ການເອີ້ນໃຊ້ບໍລິການ"

#. AuQX2
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id351613598192725\n"
"help.text"
msgid "The examples below in Basic and Python use the <literal>OpenTextFile</literal> method to create an instance of the <literal>TextStream</literal> Service."
msgstr "ຕົວຢ່າງລຸ່ມນີ້ໃນ Basic ແລະ Python ແມ່ນການໃຊ້ເມທອດ <literal>OpenTextFile</literal> ເພື່ອສ້າງອິນສະແຕນຊ໌ຂອງບໍລິການ <literal>TextStream</literal>."

#. UUudg
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id371585330787197\n"
"help.text"
msgid "The file must be closed with the <literal>CloseFile</literal> method after all read or write operations have been executed:"
msgstr "ໄຟລ໌ຈະຕ້ອງຖືກປິດດ້ວຍເມທອດ <literal>CloseFile</literal> ຫຼັງຈາກການອ່ານ ຫຼື ຂຽນທັງໝົດສຳເລັດແລ້ວ:"

#. zNveN
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id891582733781994\n"
"help.text"
msgid "Optionally, the resources used by the <literal>TextStream</literal> instance can be released using the <literal>Dispose</literal> method:"
msgstr "ນອກຈາກນັ້ນ, ຊັບພະຍາກອນທີ່ໃຊ້ໂດຍອິນສະແຕນຊ໌ <literal>TextStream</literal> ສາມາດຖືກປ່ອຍອອກໄດ້ໂດຍໃຊ້ເມທອດ <literal>Dispose</literal>:"

#. L8vEQ
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id121612917368946\n"
"help.text"
msgid "The methods in the <literal>TextStream</literal> service are mostly based on the <link href=\"https://api.libreoffice.org/docs/idl/ref/interfacecom_1_1sun_1_1star_1_1io_1_1XTextInputStream.html\"><literal>XTextInputStream</literal></link> and <link href=\"https://api.libreoffice.org/docs/idl/ref/interfacecom_1_1sun_1_1star_1_1io_1_1XTextOutputStream.html\"><literal>XTextOutputStream</literal></link> UNO interfaces."
msgstr "ເມທອດຕ່າງໆໃນບໍລິການ <literal>TextStream</literal> ສ່ວນໃຫຍ່ແມ່ນອີງຕາມອິນເຕີເຟສ UNO <link href=\"https://api.libreoffice.org/docs/idl/ref/interfacecom_1_1sun_1_1star_1_1io_1_1XTextInputStream.html\"><literal>XTextInputStream</literal></link> ແລະ <link href=\"https://api.libreoffice.org/docs/idl/ref/interfacecom_1_1sun_1_1star_1_1io_1_1XTextOutputStream.html\"><literal>XTextOutputStream</literal></link>."

