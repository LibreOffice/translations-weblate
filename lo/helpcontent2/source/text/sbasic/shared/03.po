"help.text"
msgid "Methods"
msgstr "ວິທີການ"

#. mNZFS
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id891611613601554\n"
"help.text"
msgid "List of Methods in the Chart Service"
msgstr "ລາຍຊື່ວິທີການໃນບໍລິການ Chart"

#. WfVxL
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id93158919969864\n"
"help.text"
msgid "Saves the chart as an image file in a specified location. Returns <literal>True</literal> if the image file could be successfully created."
msgstr "ບັນທຶກແຜນພູມເປັນໄຟລ໌ຮູບພາບໃນຕຳແໜ່ງທີ່ກຳນົດ. ສົ່ງຄືນ <literal>True</literal> ຖ້າການສ້າງໄຟລ໌ຮູບພາບສຳເລັດ."

#. SAtUt
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631203996\n"
"help.text"
msgid "<emph>filename</emph>: Identifies the path and file name where the image will be saved. It must follow the notation defined in <literal>SF_FileSystem.FileNaming</literal>."
msgstr "<emph>filename</emph>: ລະບຸເສັ້ນທາງ ແລະ ຊື່ໄຟລ໌ທີ່ຈະບັນທຶກຮູບພາບ. ມັນຕ້ອງເປັນໄປຕາມຮູບແບບທີ່ກຳນົດໃນ <literal>SF_FileSystem.FileNaming</literal>."

#. 2YEEE
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631203116\n"
"help.text"
msgid "<emph>imagetype</emph>: The name of the image type to be created. The following values are accepted: \"gif\", \"jpeg\", \"png\" (default), \"svg\" and \"tiff\"."
msgstr "<emph>imagetype</emph>: ຊື່ປະເພດຮູບພາບທີ່ຈະສ້າງ. ສາມາດໃຊ້ຄ່າໃດໜຶ່ງດັ່ງນີ້: \"gif\", \"jpeg\", \"png\" (ຄ່າເລີ່ມຕົ້ນ), \"svg\" ແລະ \"tiff\"."

#. XRASx
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631203133\n"
"help.text"
msgid "<emph>overwrite</emph>: Specifies if the destination file can be overwritten (Default = <literal>False</literal>)."
msgstr "<emph>overwrite</emph>: ກຳນົດວ່າສາມາດຂຽນທັບໄຟລ໌ປາຍທາງໄດ້ຫຼືບໍ່ (ຄ່າເລີ່ມຕົ້ນ = <literal>False</literal>)."

#. MCGBa
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id93158919969165\n"
"help.text"
msgid "Changes the position of the chart in the current sheet and modifies its width and height. Returns <literal>True</literal> if resizing was successful."
msgstr "ປ່ຽນຕຳແໜ່ງຂອງແຜນພູມໃນແຜ່ນງານປັດຈຸບັນ ແລະ ປັບປ່ຽນຄວາມກວ້າງ ແລະ ຄວາມສູງຂອງມັນ. ສົ່ງຄືນ <literal>True</literal> ຖ້າການປ່ຽນຂະໜາດສຳເລັດ."

#. aMKE5
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631200626\n"
"help.text"
msgid "<emph>xpos, ypos:</emph> Specify the new X and Y positions of the chart. If any of these values are omitted or if negative values are provided, the corresponding positions are left unchanged."
msgstr "<emph>xpos, ypos:</emph> ກຳນົດຕຳແໜ່ງ X ແລະ Y ໃໝ່ຂອງແຜນພູມ. ຖ້າຂ້າມຄ່າເຫຼົ່ານີ້ ຫຼື ປ້ອນຄ່າລົບ, ຕຳແໜ່ງທີ່ກ່ຽວຂ້ອງຈະບໍ່ມີການປ່ຽນແປງ."

#. qvsYR
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631204288\n"
"help.text"
msgid "<emph>width:</emph> Specify the new width of the chart. If this argument is omitted or if a negative value is provided, the chart width is left unchanged."
msgstr "<emph>width:</emph> ກຳນົດຄວາມກວ້າງໃໝ່ຂອງແຜນພູມ. ຖ້າຂ້າມອາຄິວເມນນີ້ ຫຼື ປ້ອນຄ່າລົບ, ຄວາມກວ້າງຂອງແຜນພູມຈະບໍ່ມີການປ່ຽນແປງ."

#. nGioo
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id821591631203208\n"
"help.text"
msgid "<emph>height:</emph> Specify the new height of the chart. If this argument is omitted or if a negative value is provided, the chart height is left unchanged."
msgstr "<emph>height:</emph> ກຳນົດຄວາມສູງໃໝ່ຂອງແຜນພູມ. ຖ້າຂ້າມອາຄິວເມນນີ້ ຫຼື ປ້ອນຄ່າລົບ, ຄວາມສູງຂອງແຜນພູມຈະບໍ່ມີການປ່ຽນແປງ."

#. EyY7j
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"par_id301635340527472\n"
"help.text"
msgid "All arguments are provided as integer values that correspond to 1/100 of a millimeter."
msgstr "ທຸກອາຄິວເມນແມ່ນໃຫ້ມາໃນຮູບແບບເລກຖ້ວນ ເຊິ່ງກົງກັບ 1/100 ຂອງມິນລິແມັດ."

#. h7zov
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"bas_id431635340711712\n"
"help.text"
msgid "' Changes only X and Y position"
msgstr "' ປ່ຽນສະເພາະຕຳແໜ່ງ X ແລະ Y"

#. VHc2V
#: sf_chart.xhp
msgctxt ""
"sf_chart.xhp\n"
"bas_id241635340728398\n"
"help.text"
msgid "' Changes only the chart width and height"
msgstr "' ປ່ຽນສະເພາະຄວາມກວ້າງ ແລະ ຄວາມສູງຂອງແຜນພູມ"

#. BEAYa
#: sf_chart.xhp
msgctxt ""
