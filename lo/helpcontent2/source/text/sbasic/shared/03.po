"bas_id461619100382442\n"
"help.text"
msgid "Set oMenu = oSheet.CreateMenu(\"My Menu\", Before := \"Data\")"
msgstr "Set oMenu = oSheet.CreateMenu(\"My Menu\", Before := \"Data\")"

