msgstr "ຕົວອັກສອນຄວບຄຸມ (ລະຫັດ ASCII <= 0x1F) ກໍຖືກພິຈາລະນາເປັນຕົວອັກສອນທີ່ບໍ່ສາມາດພິມໄດ້ເຊັ່ນກັນ."

#. GfNfK
#: sf_string.xhp
msgctxt ""
"sf_string.xhp\n"
"hd_id661579604944268\n"
"help.text"
msgid "Quotes inside strings:"
msgstr "ເຄື່ອງໝາຍຄຳເວົ້າພາຍໃນສະຕຣິງ:"

#. 6KLF9
#: sf_string.xhp
msgctxt ""
"sf_string.xhp\n"
"par_id551579605035332\n"
"help.text"
msgid "To add quotes in strings use \\' (single quote) or \\\" (double quote). For example:"
msgstr "ເພື່ອເພີ່ມເຄື່ອງໝາຍຄຳເວົ້າໃນສະຕຣິງ ໃຫ້ໃຊ້ \\' (ເຄື່ອງໝາຍຄຳເວົ້າດ່ຽວ) ຫຼື \\\" (ເຄື່ອງໝາຍຄຳເວົ້າຄູ່). ຕົວຢ່າງ:"

#. BKoHN
#: sf_string.xhp
msgctxt ""
"sf_string.xhp\n"
"par_id201611949691285\n"
"help.text"
msgid "The string <literal>[str\\'i\\'ng]</literal> is interpreted as <literal>[str'i'ng]</literal>"
msgstr "ສະຕຣິງ <literal>[str\\'i\\'ng]</literal> ຈະຖືກຕີຄວາມໝາຍເປັນ <literal>[str'i'ng]</literal>"

#. eRosR
#: sf_string.xhp
msgctxt ""
"sf_string.xhp\n"
"par_id201611949691323\n"
"help.text"
msgid "The string <literal>[str\\\"i\\\"ng]</literal> is interpreted as <literal>[str\"i\"ng]</literal>"
msgstr "ສະຕຣິງ <literal>[str\\\"i\\\"ng]</literal> ຈະຖືກຕີຄວາມໝາຍເປັນ <literal>[str\"i\"ng]</literal>"

