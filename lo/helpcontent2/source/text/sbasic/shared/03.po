#. rdA5M
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id691585330787279\n"
"help.text"
msgid "Sets or returns the current delimiter to be inserted between two successive written lines. The default value is the native line delimiter in the current operating system."
msgstr "ຕັ້ງຄ່າ ຫຼື ສົ່ງຄືນຕົວຂັ້ນປັດຈຸບັນທີ່ຈະຖືກແຊກລະຫວ່າງສອງແຖວທີ່ຂຽນຕິດຕໍ່ກັນ. ຄ່າເລີ່ມຕົ້ນແມ່ນຕົວຂັ້ນແຖວດັ້ງເດີມໃນລະບົບປະຕິບັດການປັດຈຸບັນ."

#. veDBj
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id141613001281573\n"
"help.text"
msgid "To learn more about the names of character sets, visit <link href=\"https://www.iana.org/assignments/character-sets/character-sets.xhtml\">IANA's Character Set</link> page. Be aware that %PRODUCTNAME does not implement all existing character sets."
msgstr "ເພື່ອຮຽນຮູ້ເພີ່ມເຕີມກ່ຽວກັບຊື່ຂອງຊຸດຕົວອັກສອນ, ໃຫ້ເຂົ້າເບິ່ງໜ້າ <link href=\"https://www.iana.org/assignments/character-sets/character-sets.xhtml\">IANA's Character Set</link>. ກະລຸນາຮັບຊາບວ່າ %PRODUCTNAME ບໍ່ໄດ້ຮອງຮັບທຸກຊຸດຕົວອັກສອນທີ່ມີຢູ່."

#. hKJkD
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id891611613601554\n"
"help.text"
msgid "List of Methods in the TextStream Service"
msgstr "ລາຍການເມທອດໃນບໍລິການ TextStream"

#. DBBKM
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id421585330787675\n"
"help.text"
msgid "Closes the current input or output stream and empties the output buffer if relevant. Returns <literal>True</literal> if the file was successfully closed."
msgstr "ປິດສະຕຣີມ input ຫຼື output ປັດຈຸບັນ ແລະ ລ້າງບັບເຟີ (buffer) ຂາອອກຖ້າກ່ຽວຂ້ອງ. ສົ່ງຄືນ <literal>True</literal> ຖ້າປິດໄຟລ໌ສຳເລັດ."

#. MCW3q
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id65158533078799\n"
"help.text"
msgid "Returns all the remaining lines in the text stream as a single string. Line breaks are not removed."
msgstr "ສົ່ງຄືນແຖວທີ່ເຫຼືອທັງໝົດໃນສະຕຣີມຂໍ້ຄວາມເປັນສະຕຣິງດ່ຽວ. ການຂຶ້ນແຖວໃໝ່ຈະບໍ່ຖືກເອົາອອກ."

#. Vr34D
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id71613600347125\n"
"help.text"
msgid "The resulting string can be split in lines either by using the <literal>Split</literal> built-in Basic function if the line delimiter is known, or with the <literal>SF_String.SplitLines</literal> method."
msgstr "ສະຕຣິງຜົນລັບສາມາດຖືກແຍກເປັນແຖວໄດ້ໂດຍການໃຊ້ຟັງຊັນ <literal>Split</literal> ຂອງ Basic ຖ້າຮູ້ຕົວຂັ້ນແຖວ, ຫຼື ໃຊ້ເມທອດ <literal>SF_String.SplitLines</literal>."

#. VRLGn
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id91585330787373\n"
"help.text"
msgid "For large files, using the <literal>ReadAll</literal> method wastes memory resources. In such cases it is recommended to read the file line by line using the <literal>ReadLine</literal> method."
msgstr "ສຳລັບໄຟລ໌ຂະໜາດໃຫຍ່, ການໃຊ້ເມທອດ <literal>ReadAll</literal> ຈະສິ້ນເປືອງຊັບພະຍາກອນໜ່ວຍຄວາມຈຳ. ໃນກໍລະນີນັ້ນ ແນະນຳໃຫ້ອ່ານໄຟລ໌ເທື່ອລະແຖວໂດຍໃຊ້ເມທອດ <literal>ReadLine</literal>."

#. BuBVA
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id921613595637851\n"
"help.text"
msgid "Consider the text file \"Students.txt\" with the following contents (a name in each line):"
msgstr "ພິຈາລະນາໄຟລ໌ຂໍ້ຄວາມ \"Students.txt\" ທີ່ມີເນື້ອໃນດັ່ງຕໍ່ໄປນີ້ (ມີຊື່ໃນແຕ່ລະແຖວ):"

#. hk7q4
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id391613596019750\n"
"help.text"
msgid "The examples below in Basic and Python use the <literal>ReadAll</literal> and <literal>SplitLines</literal> methods to read the contents of the file into an array of strings:"
msgstr "ຕົວຢ່າງລຸ່ມນີ້ໃນ Basic ແລະ Python ແມ່ນການໃຊ້ເມທອດ <literal>ReadAll</literal> ແລະ <literal>SplitLines</literal> ເພື່ອອ່ານເນື້ອໃນຂອງໄຟລ໌ເຂົ້າໃນອາເຣຂອງສະຕຣິງ:"

#. BuRJE
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id251613595640550\n"
"help.text"
msgid "'Loads the FileSystem service"
msgstr "'ໂຫຼດບໍລິການ FileSystem"

#. L2a3D
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id181613595641087\n"
"help.text"
msgid "'Opens the text file with the names to be read"
msgstr "'ເປີດໄຟລ໌ຂໍ້ຄວາມທີ່ມີຊື່ທີ່ຈະອ່ານ"

#. rDCSD
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id711613595642109\n"
"help.text"
msgid "'Reads all the contents in the input file as a single string"
msgstr "'ອ່ານເນື້ອໃນທັງໝົດໃນໄຟລ໌ຂາເຂົ້າເປັນສະຕຣິງດ່ຽວ"

#. 6w73J
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id961613595643093\n"
"help.text"
msgid "'Splits the string into an array"
msgstr "'ແຍກສະຕຣິງອອກເປັນອາເຣ"

#. 7Fq9E
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id871585330787885\n"
"help.text"
msgid "Returns the next line in the text stream as a string. Line breaks are removed from the returned string."
msgstr "ສົ່ງຄືນແຖວຖັດໄປໃນສະຕຣີມຂໍ້ຄວາມເປັນສະຕຣິງ. ການຂຶ້ນແຖວໃໝ່ຈະຖືກເອົາອອກຈາກສະຕຣິງທີ່ສົ່ງຄືນມາ."

#. 6iDcF
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id431613600221626\n"
"help.text"
msgid "The <literal>AtEndOfStream</literal> test should precede the <literal>ReadLine</literal> method like in the example below."
msgstr "ຄວນກວດສອບດ້ວຍ <literal>AtEndOfStream</literal> ກ່ອນທີ່ຈະໃຊ້ເມທອດ <literal>ReadLine</literal> ຄືກັບໃນຕົວຢ່າງລຸ່ມນີ້."

#. GRRkq
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id171585330787774\n"
"help.text"
msgid "An error will be raised if the <literal>AtEndOfStream</literal> was reached during the previous <literal>ReadLine</literal> or <literal>SkipLine</literal> method call."
msgstr "ຈະເກີດຂໍ້ຜິດພາດຖ້າອ່ານຮອດ <literal>AtEndOfStream</literal> ແລ້ວໃນລະຫວ່າງການເອີ້ນໃຊ້ເມທອດ <literal>ReadLine</literal> ຫຼື <literal>SkipLine</literal> ກ່ອນໜ້ານີ້."

#. mAty4
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id11585330787847\n"
"help.text"
msgid "Skips the next line in the input stream when reading a <literal>TextStream</literal> file."
msgstr "ຂ້າມແຖວຖັດໄປໃນສະຕຣີມຂາເຂົ້າເມື່ອອ່ານໄຟລ໌ <literal>TextStream</literal>."

#. FDMJB
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id441613600704766\n"
"help.text"
msgid "This method can result in <literal>AtEndOfStream</literal> being set to <literal>True</literal>."
msgstr "ເມທອດນີ້ອາດຈະເຮັດໃຫ້ <literal>AtEndOfStream</literal> ຖືກຕັ້ງເປັນ <literal>True</literal>."

#. D4JVb
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id141585330787657\n"
"help.text"
msgid "Writes a specified number of empty lines to the output stream."
msgstr "ຂຽນແຖວວ່າງຕາມຈຳນວນທີ່ລະບຸລົງໃນສະຕຣີມຂາອອກ."

#. YsBUm
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id291585330787357\n"
"help.text"
msgid "<emph>lines</emph>: The number of empty lines to write to the file."
msgstr "<emph>lines</emph>: ຈຳນວນແຖວວ່າງທີ່ຈະຂຽນລົງໃນໄຟລ໌."

#. GCPCC
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id101585330787215\n"
"help.text"
msgid "Writes the given string to the output stream as a single line."
msgstr "ຂຽນສະຕຣິງທີ່ໃຫ້ມາລົງໃນສະຕຣີມຂາອອກເປັນແຖວດ່ຽວ."

#. Eska7
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id421613601002074\n"
"help.text"
msgid "The character defined in the <literal>NewLine</literal> property is used as the line delimiter."
msgstr "ຕົວອັກສອນທີ່ກຳນົດໃນຄຸນສົມບັດ <literal>NewLine</literal> ຈະຖືກໃຊ້ເປັນຕົວຂັ້ນແຖວ."

#. LXFPE
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id491585330787650\n"
"help.text"
msgid "<emph>line</emph>: The line to write, may be empty."
msgstr "<emph>line</emph>: ແຖວທີ່ຈະຂຽນ, ອາດຈະວ່າງເປົ່າກໍໄດ້."

#. PM5Bx
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"par_id821626894480105\n"
"help.text"
msgid "The examples below in Basic and Python create a text file in CSV format in which each line contains a value and its square until <literal>lastValue</literal> is reached."
msgstr "ຕົວຢ່າງລຸ່ມນີ້ໃນ Basic ແລະ Python ແມ່ນການສ້າງໄຟລ໌ຂໍ້ຄວາມໃນຮູບແບບ CSV ເຊິ່ງແຕ່ລະແຖວຈະປະກອບດ້ວຍຄ່າ ແລະ ຄ່າກຳລັງສອງຂອງມັນ ຈົນກວ່າຈະຮອດ <literal>lastValue</literal>."

#. 39u4o
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id21613321528612\n"
"help.text"
msgid "'Instantiates the FileSystem Service"
msgstr "'ສ້າງອິນສະແຕນຊ໌ຂອງບໍລິການ FileSystem"

#. FnTiG
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id191613321529277\n"
"help.text"
msgid "'Creates a text file"
msgstr "'ສ້າງໄຟລ໌ຂໍ້ຄວາມ"

#. f5RSB
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id641613321530181\n"
"help.text"
msgid "'Writes the Value and Value squared, separated by \";\""
msgstr "'ຂຽນຄ່າ (Value) ແລະ ຄ່າກຳລັງສອງ (Value squared), ໂດຍຂັ້ນດ້ວຍ \";\""

#. FCowk
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id141613321530960\n"
"help.text"
msgid "myFile.WriteLine(\"Value;Value Squared\")"
msgstr "myFile.WriteLine(\"Value;Value Squared\")"

#. m9Mo4
#: sf_textstream.xhp
msgctxt ""
"sf_textstream.xhp\n"
"bas_id881613321532598\n"
"help.text"
msgid "'Closes the file and free resources"
msgstr "'ປິດໄຟລ໌ ແລະ ປ່ອຍຊັບພະຍາກອນ"

#. PCSPY
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"tit\n"
"help.text"
msgid "ScriptForge.Timer service"
msgstr "ບໍລິການ ScriptForge.Timer"

#. uvCrq
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"hd_id731582733781114\n"
"help.text"
msgid "<variable id=\"TimerService\"><link href=\"text/sbasic/shared/03/sf_timer.xhp\"><literal>ScriptForge</literal>.<literal>Timer</literal> service</link></variable>"
msgstr "<variable id=\"TimerService\"><link href=\"text/sbasic/shared/03/sf_timer.xhp\">ບໍລິການ <literal>ScriptForge</literal>.<literal>Timer</literal></link></variable>"

#. WyVvH
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id961582733781662\n"
"help.text"
msgid "The <literal>Timer</literal> service measures the amount of time it takes to run user scripts."
msgstr "ບໍລິການ <literal>Timer</literal> ໃຊ້ວັດແທກໄລຍະເວລາທີ່ໃຊ້ໃນການປະມວນຜົນສະຄຣິບຂອງຜູ້ໃຊ້."

#. qDa8E
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id181582733781323\n"
"help.text"
msgid "A <literal>Timer</literal> measures <emph>durations</emph>. It can be:"
msgstr "<literal>Timer</literal> ໃຊ້ວັດແທກ <emph>ໄລຍະເວລາ (durations)</emph>. ມັນສາມາດ:"

#. ErpLm
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id711582733781252\n"
"help.text"
msgid "Started, to indicate when to start measuring time."
msgstr "ເລີ່ມຕົ້ນ (Started), ເພື່ອບົ່ງບອກວ່າຈະເລີ່ມວັດແທກເວລາຕອນໃດ."

#. NAAFg
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id631582733781431\n"
"help.text"
msgid "Suspended, to pause measuring running time."
msgstr "ຢຸດຊົ່ວຄາວ (Suspended), ເພື່ອພັກການວັດແທກເວລາ."

#. nt9Qc
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id691582733781498\n"
"help.text"
msgid "Resumed, to continue tracking running time after the Timer has been suspended."
msgstr "ກັບມາເຮັດວຽກຕໍ່ (Resumed), ເພື່ອວັດແທກເວລາຕໍ່ໄປຫຼັງຈາກທີ່ໄດ້ຢຸດຊົ່ວຄາວ."

#. DVCBM
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id31582733781344\n"
"help.text"
msgid "Restarted, which will cancel previous measurements and start the <literal>Timer</literal> at zero."
msgstr "ເລີ່ມໃໝ່ (Restarted), ເຊິ່ງຈະຍົກເລີກການວັດແທກກ່ອນໜ້ານີ້ ແລະ ເລີ່ມຕົ້ນ <literal>Timer</literal> ໃໝ່ຈາກສູນ."

#. dm7yA
#: sf_timer.xhp
msgctxt ""
"sf_timer.xhp\n"
"par_id991582733781280\n"
"help.text"
msgid "Durations are expressed in seconds with a precision of 3 decimal digits (milliseconds). A duration value of 12.345 means 12 seconds and 345 milliseconds"
msgstr "ໄລຍະເວລາຈະຖືກສະແດງເປັນວິນາທີ ດ້ວຍຄວາມລະອຽດທົດສະນິຍົມ 3 ຕຳແໜ່ງ (ມິນລິວິນາທີ). ຄ່າໄລຍະເວລາ 12.345 ໝາຍເຖິງ 12 ວິນາທີ ແລະ 345 ມິນລິວິນາທີ"

#. CVhDR
#: sf_timer.xhp
msgctxt ""
