msgctxt ""
"sf_region.xhp\n"
"par_id71621894832117\n"
"help.text"
msgid "Returns the offset between GMT and the given timezone and locale, in minutes."
msgstr "ສົ່ງຄືນຄ່າຊົດເຊີຍລະຫວ່າງ GMT ແລະ ເຂດເວລາທີ່ລະບຸ ເປັນນາທີ."

