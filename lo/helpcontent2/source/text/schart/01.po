msgctxt ""
"04060000.xhp\n"
"tit\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. zEuu4
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"bm_id3149400\n"
"help.text"
msgid "<bookmark_value>aligning; 2D charts</bookmark_value>         <bookmark_value>charts; aligning</bookmark_value>         <bookmark_value>pie charts;options</bookmark_value>"
msgstr "<bookmark_value>ການຈັດລຽງ; ແຜນພູມ 2D</bookmark_value> <bookmark_value>ແຜນພູມ; ການຈັດລຽງ</bookmark_value> <bookmark_value>ແຜນພູມວົງມົນ; ຕົວເລືອກ</bookmark_value>"

#. wGM8h
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3149400\n"
"help.text"
msgid "<link href=\"text/schart/01/04060000.xhp\">Options</link>"
msgstr "<link href=\"text/schart/01/04060000.xhp\">ຕົວເລືອກ</link>"

#. FFqBA
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3155067\n"
"help.text"
msgid "Use this dialog to define some options that are available for specific chart types. The contents of the Options dialog vary with the chart type."
msgstr "ໃຊ້ກ່ອງສົນທະນານີ້ເພື່ອ ກຳນົດບາງຕົວເລືອກທີ່ມີໃຫ້ສຳລັບແຜນພູມບາງປະເພດ. ເນື້ອໃນຂອງກ່ອງສົນທະນາ ຕົວເລືອກ ຈະແຕກຕ່າງກັນໄປຕາມປະເພດຂອງແຜນພູມ."

#. tAu88
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3150043\n"
"help.text"
msgid "Align data series to:"
msgstr "ຈັດລຽງຊຸດຂໍ້ມູນໃສ່:"

#. 2H5Bb
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3145228\n"
"help.text"
msgid "In this area you can choose between two Y axis scaling modes. The axes can only be scaled and given properties separately."
msgstr "ໃນສ່ວນນີ້ ທ່ານສາມາດເລືອກລະຫວ່າງສອງໂໝດການກຳນົດຂະໜາດຂອງແກນ Y. ແກນຕ່າງໆສາມາດຖືກກຳນົດຂະໜາດ ແລະ ຕັ້ງຄ່າຄຸນສົມບັດແຍກກັນໄດ້ເທົ່ານັ້ນ."

#. mV2z2
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3147346\n"
"help.text"
msgid "Primary Y axis"
msgstr "ແກນ Y ຫຼັກ"

#. WNkLE
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3147005\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/RBT_OPT_AXIS_1\">This option is active as default. All data series are aligned to the primary Y axis.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/RBT_OPT_AXIS_1\">ຕົວເລືອກນີ້ຈະຖືກເປີດໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນ. ຊຸດຂໍ້ມູນທັງໝົດຈະຖືກຈັດລຽງຕາມແກນ Y ຫຼັກ.</ahelp>"

#. opEF3
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3143221\n"
"help.text"
msgid "Secondary Y axis"
msgstr "ແກນ Y ສຳຮອງ"

#. uFYk8
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3154656\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/RBT_OPT_AXIS_2\">Changes the scaling of the Y axis. This axis is only visible when at least one data series is assigned to it and the axis view is active.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/RBT_OPT_AXIS_2\">ປ່ຽນການກຳນົດຂະໜາດຂອງແກນ Y. ແກນນີ້ຈະເຫັນໄດ້ກໍຕໍ່ເມື່ອມີຢ່າງໜ້ອຍໜຶ່ງຊຸດຂໍ້ມູນຖືກມອບໝາຍໃຫ້ມັນ ແລະ ມຸມມອງແກນຖືກເປີດໃຊ້ງານ.</ahelp>"

#. FFa8c
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3166423\n"
"help.text"
msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

#. NSFYJ
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3150365\n"
"help.text"
msgid "Define the settings for a bar chart in this area. Any changes apply to all data series of the chart, not to the selected data only."
msgstr "ກຳນົດການຕັ້ງຄ່າສຳລັບແຜນພູມແທ່ງໃນສ່ວນນີ້. ການປ່ຽນແປງໃດໆຈະຖືກໝູນໃຊ້ກັບທຸກຊຸດຂໍ້ມູນຂອງແຜນພູມ, ບໍ່ແມ່ນສະເພາະຂໍ້ມູນທີ່ເລືອກເທົ່ານັ້ນ."

#. w8uog
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3145584\n"
"help.text"
msgid "Spacing"
msgstr "ໄລຍະຫ່າງ"

#. ayXg8
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3155376\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/MT_GAP\">Defines the spacing between the columns in percent.</ahelp> The maximal spacing is 600%."
msgstr "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/MT_GAP\">ກຳນົດໄລຍະຫ່າງລະຫວ່າງຖັນເປັນເປີເຊັນ.</ahelp> ໄລຍະຫ່າງສູງສຸດແມ່ນ 600%."

#. o9k6R
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3145384\n"
"help.text"
msgid "Overlap"
msgstr "ວາງຊ້ອນກັນ"

#. YsvUy
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3156447\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/MT_OVERLAP\">Defines the necessary settings for overlapping data series.</ahelp> You can choose between -100 and +100%."
msgstr "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/MT_OVERLAP\">ກຳນົດການຕັ້ງຄ່າທີ່ຈຳເປັນສຳລັບການວາງຊ້ອນກັນຂອງຊຸດຂໍ້ມູນ.</ahelp> ທ່ານສາມາດເລືອກໄດ້ລະຫວ່າງ -100 ຫາ +100%."

#. 4wQHD
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3153305\n"
"help.text"
msgid "Connection Lines"
msgstr "ເສັ້ນເຊື່ອມຕໍ່"

#. CF4RX
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3148868\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/CB_CONNECTOR\">For \"stacked\" and \"percent\" column (vertical bar) charts, mark this check box to connect the column layers that belong together with lines.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_SeriesToAxis/CB_CONNECTOR\">ສຳລັບແຜນພູມຖັນແບບ \"ວາງຊ້ອນ\" ແລະ \"ເປີເຊັນ\" (ແທ່ງແນວຕັ້ງ), ໃຫ້ໝາຍຕິກໃນກ່ອງນີ້ເພື່ອເຊື່ອມຕໍ່ຊັ້ນຂອງຖັນທີ່ເປັນກຸ່ມດຽວກັນດ້ວຍເສັ້ນ.</ahelp>"

#. xX6CC
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id9842219\n"
"help.text"
msgid "Show bars side by side"
msgstr "ສະແດງແທ່ງຂ້າງກັນ"

#. T7xnJ
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id9800103\n"
"help.text"
msgid "If two axes are shown in a bar chart, and some data series are attached to the first axis, while some other data series are attached to the second axis, then both sets of data series are shown independently, overlapping each other."
msgstr "ຫາກມີການສະແດງສອງແກນໃນແຜນພູມແທ່ງ, ແລະ ບາງຊຸດຂໍ້ມູນຖືກຜູກໄວ້ກັບແກນທຳອິດ, ໃນຂະນະທີ່ບາງຊຸດຂໍ້ມູນອື່ນໆຖືກຜູກໄວ້ກັບແກນທີສອງ, ຊຸດຂໍ້ມູນທັງສອງກຸ່ມຈະຖືກສະແດງແຍກກັນຢ່າງເປັນອິດສະຫຼະ ແລະ ວາງຊ້ອນກັນ."

#. oLCGt
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id2144535\n"
"help.text"
msgid "As a result, bars attached to the first y-axis are partly or completely hidden by bars attached to the second y-axis. To avoid this, enable the option to display bars side by side. <ahelp hid=\".\">The bars from different data series are shown as if they were attached only to one axis.</ahelp>"
msgstr "ດ້ວຍເຫດນີ້, ແທ່ງທີ່ຜູກກັບແກນ y ທຳອິດອາດຈະຖືກປິດບັງບາງສ່ວນ ຫຼື ທັງໝົດໂດຍແທ່ງທີ່ຜູກກັບແກນ y ທີສອງ. ເພື່ອຫຼີກລ່ຽງບັນຫານີ້, ໃຫ້ເປີດຕົວເລືອກເພື່ອສະແດງແທ່ງຂ້າງກັນ. <ahelp hid=\".\">ແທ່ງຈາກຊຸດຂໍ້ມູນທີ່ແຕກຕ່າງກັນຈະຖືກສະແດງຄືກັບວ່າມັນຖືກຜູກໄວ້ກັບແກນດຽວກັນ.</ahelp>"

#. u8zZt
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id24414\n"
"help.text"
msgid "Clockwise direction"
msgstr "ທິດທາງຕາມເຂັມໂມງ"

#. Mnouh
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id2527237\n"
"help.text"
msgid "Available for pie and donut charts. <ahelp hid=\".\">The default direction in which the pieces of a pie chart are ordered is counterclockwise. Enable the <emph>Clockwise direction</emph> checkbox to draw the pieces in opposite direction.</ahelp>"
msgstr "ມີໃຫ້ໃຊ້ສຳລັບແຜນພູມວົງມົນ ແລະ ແຜນພູມໂດນັດ. <ahelp hid=\".\">ທິດທາງເລີ່ມຕົ້ນທີ່ຊິ້ນສ່ວນຂອງແຜນພູມວົງມົນຖືກຈັດລຽງແມ່ນແບບທວນເຂັມໂມງ. ໃຫ້ໝາຍຕິກໃນກ່ອງ <emph>ທິດທາງຕາມເຂັມໂມງ</emph> ເພື່ອແຕ້ມຊິ້ນສ່ວນໃນທິດທາງກົງກັນຂ້າມ.</ahelp>"

#. BiqZr
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id401013\n"
"help.text"
msgid "Starting angle"
msgstr "ມຸມເລີ່ມຕົ້ນ"

#. tGbuE
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id761131\n"
"help.text"
msgid "<ahelp hid=\".\">Drag the small dot along the circle or click any position on the circle to set the starting angle of a pie or donut chart. The starting angle is the mathematical angle position where the first piece is drawn. The value of 90 degrees draws the first piece at the 12 o'clock position. A value of 0 degrees starts at the 3 o'clock position.</ahelp>"
msgstr "<ahelp hid=\".\">ລາກຈຸດນ້ອຍໆຕາມວົງມົນ ຫຼື ຄລິກຕຳແໜ່ງໃດກໍໄດ້ໃນວົງມົນເພື່ອຕັ້ງຄ່າມຸມເລີ່ມຕົ້ນຂອງແຜນພູມວົງມົນ ຫຼື ໂດນັດ. ມຸມເລີ່ມຕົ້ນແມ່ນຕຳແໜ່ງມຸມທາງຄະນິດສາດທີ່ຊິ້ນສ່ວນທຳອິດຈະຖືກແຕ້ມ. ຄ່າ 90 ອົງສາ ຈະແຕ້ມຊິ້ນສ່ວນທຳອິດຢູ່ຕຳແໜ່ງ 12 ໂມງ. ຄ່າ 0 ອົງສາ ຈະເລີ່ມຢູ່ຕຳແໜ່ງ 3 ໂມງ.</ahelp>"

#. YFRMd
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id553910\n"
"help.text"
msgid "In 3D pie and donut charts that were created with older versions of the software, the starting angle is 0 degrees instead of 90 degrees. For old and new 2D charts the default starting angle is 90 degrees."
msgstr "ໃນແຜນພູມວົງມົນ ແລະ ໂດນັດແບບ 3D ທີ່ສ້າງດ້ວຍຊອບແວເວີຊັນເກົ່າ, ມຸມເລີ່ມຕົ້ນແມ່ນ 0 ອົງສາ ແທນທີ່ຈະເປັນ 90 ອົງສາ. ສຳລັບແຜນພູມ 2D ທັງແບບເກົ່າ ແລະ ໃໝ່, ມຸມເລີ່ມຕົ້ນເລີ່ມຕົ້ນແມ່ນ 90 ອົງສາ."

#. 9xzEe
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id1414838\n"
"help.text"
msgid "When you change the starting angle or the direction, only current versions of the software show the changed values. Older versions of the software display the same document using the default values: Always counterclockwise direction and a starting value of 90 degrees (2D pie charts) or 0 degrees (3D pie charts)."
msgstr "ເມື່ອທ່ານປ່ຽນມຸມເລີ່ມຕົ້ນ ຫຼື ທິດທາງ, ມີພຽງແຕ່ຊອບແວເວີຊັນປະຈຸບັນເທົ່ານັ້ນທີ່ຈະສະແດງຄ່າທີ່ປ່ຽນແປງ. ຊອບແວເວີຊັນເກົ່າຈະສະແດງເອກະສານດຽວກັນໂດຍໃຊ້ຄ່າເລີ່ມຕົ້ນ: ເປັນທິດທາງທວນເຂັມໂມງສະເໝີ ແລະ ຄ່າເລີ່ມຕົ້ນທີ່ 90 ອົງສາ (ແຜນພູມວົງມົນ 2D) ຫຼື 0 ອົງສາ (ແຜນພູມວົງມົນ 3D)."

#. hvgvC
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3179723\n"
"help.text"
msgid "Degrees"
msgstr "ອົງສາ"

#. asdVC
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id2164067\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the starting angle between 0 and 359 degrees. You can also click the arrows to change the displayed value.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນມຸມເລີ່ມຕົ້ນລະຫວ່າງ 0 ຫາ 359 ອົງສາ. ທ່ານຍັງສາມາດຄລິກທີ່ລູກສອນເພື່ອປ່ຽນຄ່າທີ່ສະແດງໄດ້.</ahelp>"

#. 9Dfjk
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524613\n"
"help.text"
msgid "Plot missing values"
msgstr "ແຕ້ມຄ່າທີ່ຂາດຫາຍໄປ"

#. RfNzm
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id0305200910524650\n"
"help.text"
msgid "Sometimes values are missing in a data series that is shown in a chart. You can select from different options how to plot the missing values. The options are available for some chart types only."
msgstr "ບາງຄັ້ງຄ່າຂໍ້ມູນອາດຈະຂາດຫາຍໄປໃນຊຸດຂໍ້ມູນທີ່ສະແດງໃນແຜນພູມ. ທ່ານສາມາດເລືອກຈາກຕົວເລືອກຕ່າງໆວ່າຈະໃຫ້ແຕ້ມຄ່າທີ່ຂາດຫາຍໄປແນວໃດ. ຕົວເລືອກເຫຼົ່ານີ້ມີໃຫ້ໃຊ້ສຳລັບແຜນພູມບາງປະເພດເທົ່ານັ້ນ."

#. iFsLL
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524823\n"
"help.text"
msgid "Leave gap"
msgstr "ປະວ່າງໄວ້"

#. A6KyD
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id0305200910524811\n"
"help.text"
msgid "<ahelp hid=\".\">For a missing value, no data will be shown. This is the default for chart types Column, Bar, Line, Net.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບຄ່າທີ່ຂາດຫາຍໄປ, ຈະບໍ່ມີການສະແດງຂໍ້ມູນໃດໆ. ນີ້ແມ່ນຄ່າເລີ່ມຕົ້ນສຳລັບແຜນພູມປະເພດ ຖັນ, ແທ່ງ, ເສັ້ນ, ແລະ ຕາໜ່າງ.</ahelp>"

#. uManw
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524811\n"
"help.text"
msgid "Assume zero"
msgstr "ສົມມຸດວ່າເປັນສູນ"

#. gz7cb
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id030520091052489\n"
"help.text"
msgid "<ahelp hid=\".\">For a missing value, the y-value will be shown as zero. This is the default for chart type Area.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບຄ່າທີ່ຂາດຫາຍໄປ, ຄ່າ y ຈະຖືກສະແດງເປັນສູນ. ນີ້ແມ່ນຄ່າເລີ່ມຕົ້ນສຳລັບແຜນພູມປະເພດ ພື້ນທີ່.</ahelp>"

#. rns6H
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524837\n"
"help.text"
msgid "Continue line"
msgstr "ເສັ້ນຕໍ່ເນື່ອງ"

#. A7Fse
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id0305200910524938\n"
"help.text"
msgid "<ahelp hid=\".\">For a missing value, the interpolation from the neighbor values will be shown. This is the default for chart type XY.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບຄ່າທີ່ຂາດຫາຍໄປ, ຈະມີການສະແດງຜົນການປະມານຄ່າຈາກຄ່າທີ່ຢູ່ຂ້າງຄຽງ. ນີ້ແມ່ນຄ່າເລີ່ມຕົ້ນສຳລັບແຜນພູມປະເພດ XY.</ahelp>"

#. GBLUU
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524937\n"
"help.text"
msgid "Include values from hidden cells"
msgstr "ລວມຄ່າຈາກຫ້ອງທີ່ເຊື່ອງໄວ້"

#. CYWe2
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id030520091052494\n"
"help.text"
msgid "<ahelp hid=\".\">Check to also show values of currently hidden cells within the source cell range.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍຕິກເພື່ອສະແດງຄ່າຂອງຫ້ອງທີ່ຖືກເຊື່ອງໄວ້ໃນປະຈຸບັນພາຍໃນຊ່ວງຫ້ອງແຫຼ່ງຂໍ້ມູນນຳ.</ahelp>"

#. QUETc
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id0305200910524938\n"
"help.text"
msgid "Hide legend entry"
msgstr "ເຊື່ອງລາຍການຄຳອະທິບາຍສັນຍະລັກ"

#. roeRi
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id030520091052495\n"
"help.text"
msgid "<ahelp hid=\".\">Do not show legend entry for the selected data series or data point.</ahelp>"
msgstr "<ahelp hid=\".\">ບໍ່ສະແດງລາຍການຄຳອະທິບາຍສັນຍະລັກສຳລັບຊຸດຂໍ້ມູນ ຫຼື ຈຸດຂໍ້ມູນທີ່ເລືອກ.</ahelp>"

#. WWrcn
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"tit\n"
"help.text"
msgid "Grids"
msgstr "ເສັ້ນຕາໜ່າງ"

#. 7Qu9B
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"bm_id3147434\n"
"help.text"
msgid "<bookmark_value>axes; inserting grids</bookmark_value>  <bookmark_value>grids; inserting in charts</bookmark_value>"
msgstr "<bookmark_value>ແກນ; ການແຊກເສັ້ນຕາໜ່າງ</bookmark_value> <bookmark_value>ເສັ້ນຕາໜ່າງ; ການແຊກໃນແຜນພູມ</bookmark_value>"

#. xYnZh
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id3147434\n"
"help.text"
msgid "Grids"
