msgctxt ""
"05020201.xhp\n"
"par_id3145114\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_axisLabel/odd\">Staggers numbers on the axis, even numbers lower than odd numbers.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_axisLabel/odd\">ຈັດສະຫຼັບຕົວເລກໃນແກນ, ໂດຍໃຫ້ເລກຄູ່ຢູ່ຕ່ຳກວ່າເລກຄີກ.</ahelp>"

#. BBZDA
#: 05020201.xhp
msgctxt ""
"05020201.xhp\n"
"hd_id3147250\n"
"help.text"
msgid "Stagger even"
msgstr "ຈັດສະຫຼັບເລກຄູ່"

#. EFakH
#: 05020201.xhp
msgctxt ""
"05020201.xhp\n"
"par_id3153958\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_axisLabel/even\">Stagger numbers on the axes, odd numbers lower than even numbers.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_axisLabel/even\">ຈັດສະຫຼັບຕົວເລກໃນແກນ, ໂດຍໃຫ້ເລກຄີກຢູ່ຕ່ຳກວ່າເລກຄູ່.</ahelp>"

#. Uf4fM
#: 05020201.xhp
msgctxt ""
