msgid "<ahelp hid=\"modules/schart/ui/insertaxisdlg/primaryZ\">Displays the Z axis as a line with subdivisions.</ahelp> This axis can only be displayed in 3D charts."
msgstr "<ahelp hid=\"modules/schart/ui/insertaxisdlg/primaryZ\">ສະແດງແກນ Z ເປັນເສັ້ນທີ່ມີການແບ່ງຍ່ອຍ.</ahelp> ແກນນີ້ສາມາດສະແດງໄດ້ສະເພາະໃນແຜນພູມ 3D ເທົ່ານັ້ນ."

#. d2Ec7
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3150206\n"
"help.text"
msgid "Secondary axis"
msgstr "ແກນສຳຮອງ"

#. QaGNX
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3166428\n"
"help.text"
msgid "Use this area to assign a second axis to your chart. If a data series is already assigned to this axis, $[officename] automatically displays the axis and the label. You can turn off these settings later on. If no data has been assigned to this axis and you activate this area, the values of the primary Y axis are applied to the secondary axis."
msgstr "ໃຊ້ພື້ນທີ່ນີ້ເພື່ອມອບໝາຍແກນທີສອງໃຫ້ກັບແຜນພູມຂອງທ່ານ. ຫາກມີຊຸດຂໍ້ມູນຖືກມອບໝາຍໃຫ້ແກນນີ້ແລ້ວ, $[officename] ຈະສະແດງແກນ ແລະ ປ້າຍຊື່ອັດຕະໂນມັດ. ທ່ານສາມາດປິດການຕັ້ງຄ່າເຫຼົ່ານີ້ໄດ້ໃນພາຍຫຼັງ. ຫາກບໍ່ມີຂໍ້ມູນຖືກມອບໝາຍໃຫ້ແກນນີ້ ແລະ ທ່ານເປີດໃຊ້ງານພື້ນທີ່ນີ້, ຄ່າຂອງແກນ Y ຫຼັກຈະຖືກໝູນໃຊ້ກັບແກນສຳຮອງ."

#. oEY8r
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"hd_id3152988\n"
"help.text"
msgid "X axis"
msgstr "ແກນ X"

#. hAMZB
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3156445\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryX\">Displays a secondary X axis in the chart.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryX\">ສະແດງແກນ X ສຳຮອງໃນແຜນພູມ.</ahelp>"

#. v2A28
