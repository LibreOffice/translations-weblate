msgid "<link href=\"text/scalc/01/04060107.xhp#Section7\">LOGEST</link> function"
msgstr "ຟັງຊັນ <link href=\"text/scalc/01/04060107.xhp#Section7\">LOGEST</link>"

#. 9otAR
#: 04050100.xhp
