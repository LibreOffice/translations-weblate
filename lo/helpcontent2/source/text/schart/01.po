msgstr "<image src=\"chart2/res/nostackdirect3d_52x60.svg\" id=\"img_id441747345088670\" width=\"0.6252in\" height=\"0.5417in\"><alt id=\"alt_id901747345088673\">ໄອຄອນ ເສັ້ນ 3 ມິຕິ</alt></image>"

