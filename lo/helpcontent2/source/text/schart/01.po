msgid "<image src=\"chart2/res/stockblock_52x60.svg\" id=\"img_id761747393651804\" width=\"0.6252in\" height=\"0.5417in\"><alt id=\"alt_id931747393651806\">Icon Stock Chart Type 2</alt></image>"
