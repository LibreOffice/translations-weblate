msgstr "ຟັງຊັນ <link href=\"text/scalc/01/04060107.xhp#Section8\">LINEST</link>"

#. hxCkj
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id4562216\n"
