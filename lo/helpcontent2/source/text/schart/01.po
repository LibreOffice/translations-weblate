"tit\n"
"help.text"
msgid "Data Labels"
msgstr "ປ້າຍຊື່ຂໍ້ມູນ"

#. hnFS9
#: 04030000.xhp
msgctxt ""
"04030000.xhp\n"
"bm_id3150275\n"
"help.text"
msgid "<bookmark_value>data labels in charts</bookmark_value>      <bookmark_value>labels; for charts</bookmark_value>      <bookmark_value>charts; data labels</bookmark_value>      <bookmark_value>data values in charts</bookmark_value>      <bookmark_value>chart legends; showing icons with labels</bookmark_value>"
msgstr "<bookmark_value>ປ້າຍຊື່ຂໍ້ມູນໃນແຜນພູມ</bookmark_value> <bookmark_value>ປ້າຍຊື່; ສຳລັບແຜນພູມ</bookmark_value> <bookmark_value>ແຜນພູມ; ປ້າຍຊື່ຂໍ້ມູນ</bookmark_value> <bookmark_value>ມູນຄ່າຂໍ້ມູນໃນແຜນພູມ</bookmark_value> <bookmark_value>ຄຳອະທິບາຍສັນຍະລັກແຜນພູມ; ການສະແດງໄອຄອນພ້ອມປ້າຍຊື່</bookmark_value>"

#. UKRDA
