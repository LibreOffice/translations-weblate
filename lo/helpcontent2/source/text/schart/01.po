msgctxt ""
"04040000.xhp\n"
"hd_id3152896\n"
"help.text"
msgid "Y axis"
msgstr "ແກນ Y"

#. VEXsg
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3153818\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryY\">Displays a secondary Y axis in the chart.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryY\">ສະແດງແກນ Y ສຳຮອງໃນແຜນພູມ.</ahelp>"

#. m6gyt
#: 04040000.xhp
msgctxt ""
"04040000.xhp\n"
"par_id3154762\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryY\">The major axis and the secondary axis can have different scaling. For example, you can scale one axis to 2 in. and the other to 1.5 in. </ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/insertaxisdlg/secondaryY\">ແກນຫຼັກ ແລະ ແກນສຳຮອງສາມາດມີການກຳນົດຂະໜາດທີ່ແຕກຕ່າງກັນໄດ້. ຕົວຢ່າງ: ທ່ານສາມາດກຳນົດຂະໜາດແກນໜຶ່ງເປັນ 2 ນິ້ວ ແລະ ອີກແກນໜຶ່ງເປັນ 1.5 ນິ້ວ. </ahelp>"

#. CQdYY
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"tit\n"
"help.text"
msgid "X/Y Error Bars"
msgstr "ແຖບຄວາມຜິດພາດ X/Y"

#. o7uyC
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3147428\n"
"help.text"
msgid "<link href=\"text/schart/01/04050000.xhp\">X/Y Error Bars</link>"
msgstr "<link href=\"text/schart/01/04050000.xhp\">ແຖບຄວາມຜິດພາດ X/Y</link>"

#. VufWr
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3149666\n"
"help.text"
msgid "<variable id=\"statistik\"><ahelp hid=\".\">Use the <emph>X or Y Error Bars</emph> dialog to display error bars for 2D charts.</ahelp></variable>"
msgstr "<variable id=\"statistik\"><ahelp hid=\".\">ໃຊ້ກ່ອງສົນທະນາ <emph>ແຖບຄວາມຜິດພາດ X ຫຼື Y</emph> ເພື່ອສະແດງແຖບຄວາມຜິດພາດສຳລັບແຜນພູມ 2D.</ahelp></variable>"

#. dw9Dz
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3401287\n"
"help.text"
msgid "An error bar is an indicator line that spans over a range from x/y - NegativeErrorValue to x/y + PositiveErrorValue. In this term, x or y is the value of the data point. When \"standard deviation\" is selected, x or y is the mean value of the data series. NegativeErrorValue and PositiveErrorValue are the amounts calculated by the error bar function or given explicitly."
msgstr "ແຖບຄວາມຜິດພາດແມ່ນເສັ້ນສະແດງທີ່ກວມເອົາຊ່ວງແຕ່ x/y - ຄ່າຄວາມຜິດພາດທາງລົບ ຈົນເຖິງ x/y + ຄ່າຄວາມຜິດພາດທາງບວກ. ໃນທີ່ນີ້, x ຫຼື y ແມ່ນຄ່າຂອງຈຸດຂໍ້ມູນ. ເມື່ອເລືອກ \"ຄ່າຜັນປ່ຽນມາດຕະຖານ\", x ຫຼື y ຈະແມ່ນຄ່າສະເລ່ຍຂອງຊຸດຂໍ້ມູນ. ຄ່າຄວາມຜິດພາດທາງລົບ ແລະ ທາງບວກ ແມ່ນຈຳນວນທີ່ຄິດໄລ່ໂດຍຟັງຊັນແຖບຄວາມຜິດພາດ ຫຼື ລະບຸໄວ້ໂດຍກົງ."

#. 2uEd3
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3153965\n"
"help.text"
msgid "The <emph>Insert - X/Y Error Bars</emph> menu command is only available for 2D charts."
msgstr "ຄຳສັ່ງເມນູ <emph>ແຊກ - ແຖບຄວາມຜິດພາດ X/Y</emph> ມີໃຫ້ໃຊ້ສະເພາະກັບແຜນພູມ 2D ເທົ່ານັ້ນ."

#. GE8Ux
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3150344\n"
"help.text"
msgid "Error category"
msgstr "ໝວດໝູ່ຄວາມຜິດພາດ"

#. 7x2ix
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3150202\n"
"help.text"
msgid "In the <emph>Error category</emph> area, you can choose different ways to display the error category."
msgstr "ໃນສ່ວນ <emph>ໝວດໝູ່ຄວາມຜິດພາດ</emph>, ທ່ານສາມາດເລືອກວິທີຕ່າງໆເພື່ອສະແດງໝວດໝູ່ຄວາມຜິດພາດໄດ້."

#. TFxgF
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3152989\n"
"help.text"
msgid "None"
msgstr "ບໍ່ມີ"

#. jUGgu
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3149409\n"
"help.text"
msgid "<ahelp hid=\".\">Does not show any error bars.</ahelp>"
msgstr "<ahelp hid=\".\">ບໍ່ສະແດງແຖບຄວາມຜິດພາດໃດໆ.</ahelp>"

#. G7ApU
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3145117\n"
"help.text"
msgid "Constant value"
msgstr "ຄ່າຄົງທີ່"

#. yFttn
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3151390\n"
"help.text"
msgid "<ahelp hid=\".\">Displays constant values that you specify in the Parameters area.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງຄ່າຄົງທີ່ທີ່ທ່ານລະບຸໄວ້ໃນສ່ວນພາຣາມິເຕີ.</ahelp>"

#. uPkhT
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3159204\n"
"help.text"
msgid "Percentage"
msgstr "ເປີເຊັນ"

#. pLWGy
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3150048\n"
"help.text"
msgid "<ahelp hid=\".\">Displays a percentage. The display refers to the corresponding data point. Set the percentage in the Parameters area.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງເປັນເປີເຊັນ. ການສະແດງຜົນຈະອ້າງອີງເຖິງຈຸດຂໍ້ມູນທີ່ກ່ຽວຂ້ອງ. ຕັ້ງຄ່າເປີເຊັນໃນສ່ວນພາຣາມິເຕີ.</ahelp>"

#. tsxNy
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id8977629\n"
"help.text"
msgid "Functions"
msgstr "ຟັງຊັນ"

#. JVDun
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id7109286\n"
"help.text"
msgid "<ahelp hid=\".\">Select a function to calculate the error bars.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຟັງຊັນເພື່ອຄິດໄລ່ແຖບຄວາມຜິດພາດ.</ahelp>"

#. wUD8K
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id5154576\n"
"help.text"
msgid "Standard Error: Displays the standard error."
msgstr "ຄວາມຜິດພາດມາດຕະຖານ: ສະແດງຄ່າຄວາມຜິດພາດມາດຕະຖານ."

#. 2t2XJ
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3157979\n"
"help.text"
msgid "Variance: Displays the variance calculated from the number of data points and respective values."
msgstr "ຄ່າຜັນປ່ຽນ: ສະແດງຄ່າຜັນປ່ຽນທີ່ຄິດໄລ່ຈາກຈຳນວນຈຸດຂໍ້ມູນ ແລະ ຄ່າທີ່ກ່ຽວຂ້ອງ."

#. DkMFd
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3153249\n"
"help.text"
msgid "Standard Deviation: Displays the standard deviation (square root of the variance). Unlike other functions, error bars are centered on the mean."
msgstr "ຄ່າຜັນປ່ຽນມາດຕະຖານ: ສະແດງຄ່າຜັນປ່ຽນມາດຕະຖານ (ຮາກຂັ້ນສອງຂອງຄ່າຜັນປ່ຽນ). ແຕກຕ່າງຈາກຟັງຊັນອື່ນ, ແຖບຄວາມຜິດພາດຈະຖືກຈັດໄວ້ກາງຄ່າສະເລ່ຍ."

#. GdCG9
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3149870\n"
"help.text"
msgid "Error Margin: Displays the highest error margin in percent according to the highest value of the data group. Set the percentage in the Parameters area."
msgstr "ຂອບເຂດຄວາມຜິດພາດ: ສະແດງຂອບເຂດຄວາມຜິດພາດທີ່ສູງສຸດເປັນເປີເຊັນຕາມຄ່າທີ່ສູງສຸດຂອງກຸ່ມຂໍ້ມູນ. ຕັ້ງຄ່າເປີເຊັນໃນສ່ວນພາຣາມິເຕີ."

#. ffQE4
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id350962\n"
"help.text"
msgid "Cell Range"
msgstr "ຊ່ວງຫ້ອງ"

#. BzcrF
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id6679586\n"
"help.text"
msgid "<ahelp hid=\".\">Click Cell Range and then specify a cell range from which to take the positive and negative error bar values.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກ ຊ່ວງຫ້ອງ ແລ້ວລະບຸຊ່ວງຫ້ອງທີ່ຈະນຳຄ່າແຖບຄວາມຜິດພາດທາງບວກ ແລະ ທາງລົບບາງສ່ວນມາໃຊ້.</ahelp>"

#. DQYC6
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3872188\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Click a button to shrink the dialog, then use the mouse to select the cell range in the spreadsheet. Click the button again to restore the dialog to full size.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຄລິກປຸ່ມເພື່ອຫຍໍ້ກ່ອງສົນທະນາ, ຈາກນັ້ນໃຊ້ເມົາສ໌ເພື່ອເລືອກຊ່ວງຫ້ອງໃນແຜ່ນງານ. ຄລິກປຸ່ມອີກຄັ້ງເພື່ອຄືນຂະໜາດກ່ອງສົນທະນາໃຫ້ເຕັມຄືເກົ່າ.</ahelp>"

#. XbnB2
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id2633747\n"
"help.text"
msgid "From Data Table"
msgstr "ຈາກຕາຕະລາງຂໍ້ມູນ"

#. CKWJ7
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id6633503\n"
"help.text"
msgid "<ahelp hid=\".\">For a chart with its own data, the error bar values can be entered in the chart data table. The Data Table dialog shows additional columns titled Positive X or Y-Error-Bars and Negative X or Y-Error-Bars.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບແຜນພູມທີ່ມີຂໍ້ມູນຂອງຕົນເອງ, ສາມາດປ້ອນຄ່າແຖບຄວາມຜິດພາດໃນຕາຕະລາງຂໍ້ມູນແຜນພູມໄດ້. ກ່ອງສົນທະນາ ຕາຕະລາງຂໍ້ມູນ ຈະສະແດງຖັນເພີ່ມເຕີມທີ່ຊື່ວ່າ ແຖບຄວາມຜິດພາດ X ຫຼື Y ທາງບວກ ແລະ ແຖບຄວາມຜິດພາດ X ຫຼື Y ທາງລົບ.</ahelp>"

#. 6Tjw9
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810573839\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the value to add to the displayed value as the positive error value.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຄ່າທີ່ຈະບວກໃສ່ຄ່າທີ່ສະແດງ ເປັນຄ່າຄວາມຜິດພາດທາງບວກ.</ahelp>"

#. YCbEY
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810573862\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the value to subtract from the displayed value as the negative error value.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຄ່າທີ່ຈະລົບອອກຈາກຄ່າທີ່ສະແດງ ເປັນຄ່າຄວາມຜິດພາດທາງລົບ.</ahelp>"

#. kRFcG
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810573844\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the address range from where to get the positive error values. Use the Shrink button to select the range from a sheet.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຊ່ວງທີ່ຢູ່ທີ່ຈະນຳຄ່າຄວາມຜິດພາດທາງບວກມາໃຊ້. ໃຊ້ປຸ່ມຫຍໍ້ເພື່ອເລືອກຊ່ວງຈາກແຜ່ນງານ.</ahelp>"

#. Qpys7
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810573970\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the address range from where to get the negative error values. Use the Shrink button to select the range from a sheet.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຊ່ວງທີ່ຢູ່ທີ່ຈະນຳຄ່າຄວາມຜິດພາດທາງລົບມາໃຊ້. ໃຊ້ປຸ່ມຫຍໍ້ເພື່ອເລືອກຊ່ວງຈາກແຜ່ນງານ.</ahelp>"

#. bcLoY
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id0428200810573977\n"
"help.text"
msgid "Same value for both"
msgstr "ໃຊ້ຄ່າດຽວກັນສຳລັບທັງສອງ"

#. FAXMR
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810573991\n"
"help.text"
msgid "<ahelp hid=\".\">Enable to use the positive error values also as negative error values. You can only change the value of the \"Positive (+)\" box. That value gets copied to the \"Negative (-)\" box automatically.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດໃຊ້ເພື່ອໃຊ້ຄ່າຄວາມຜິດພາດທາງບວກເປັນຄ່າຄວາມຜິດພາດທາງລົບນຳ. ທ່ານສາມາດປ່ຽນໄດ້ສະເພາະຄ່າໃນຫ້ອງ \"ບວກ (+)\". ຄ່ານັ້ນຈະຖືກສຳເນົາໃສ່ຫ້ອງ \"ລົບ (-)\" ໂດຍອັດຕະໂນມັດ.</ahelp>"

#. QZNgb
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3156396\n"
"help.text"
msgid "Error Indicator"
msgstr "ຕົວຊີ້ບອກຄວາມຜິດພາດ"

#. YmcEX
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3150539\n"
"help.text"
msgid "Specifies the error indicator."
msgstr "ລະບຸຕົວຊີ້ບອກຄວາມຜິດພາດ."

#. E4UCQ
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id0428200810574027\n"
"help.text"
msgid "Positive and Negative"
msgstr "ທາງບວກ ແລະ ທາງລົບ"

#. GfYAw
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0428200810574039\n"
"help.text"
msgid "<ahelp hid=\".\">Shows positive and negative error bars.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງແຖບຄວາມຜິດພາດທັງທາງບວກ ແລະ ທາງລົບ.</ahelp>"

#. r6Cp5
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id0428200810574031\n"
"help.text"
msgid "Positive"
msgstr "ທາງບວກ"

#. FUMP7
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id042820081057411\n"
"help.text"
msgid "<ahelp hid=\".\">Shows only positive error bars.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງສະເພາະແຖບຄວາມຜິດພາດທາງບວກເທົ່ານັ້ນ.</ahelp>"

#. 4w2iy
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id0428200810574138\n"
"help.text"
msgid "Negative"
msgstr "ທາງລົບ"

#. TZcmS
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0522200809110667\n"
"help.text"
msgid "<ahelp hid=\".\">Shows only negative error bars.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງສະເພາະແຖບຄວາມຜິດພາດທາງລົບເທົ່ານັ້ນ.</ahelp>"

#. 5TUMR
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"tit\n"
"help.text"
msgid "Trend Lines"
msgstr "ເສັ້ນທ່າອ່ຽງ"

#. dZSez
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"bm_id1744743\n"
"help.text"
msgid "<bookmark_value>calculating;regression curves</bookmark_value>  <bookmark_value>regression curves in charts</bookmark_value>  <bookmark_value>trend lines in charts</bookmark_value>  <bookmark_value>mean value lines in charts</bookmark_value>"
msgstr "<bookmark_value>ການຄິດໄລ່; ເສັ້ນໂຄ້ງການຖອຍຫຼັງ</bookmark_value> <bookmark_value>ເສັ້ນໂຄ້ງການຖອຍຫຼັງໃນແຜນພູມ</bookmark_value> <bookmark_value>ເສັ້ນທ່າອ່ຽງໃນແຜນພູມ</bookmark_value> <bookmark_value>ເສັ້ນຄ່າສະເລ່ຍໃນແຜນພູມ</bookmark_value>"

#. UDTw3
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id5409405\n"
"help.text"
msgid "<variable id=\"regression\"><link href=\"text/schart/01/04050100.xhp\">Trend Lines</link></variable>"
msgstr "<variable id=\"regression\"><link href=\"text/schart/01/04050100.xhp\">ເສັ້ນທ່າອ່ຽງ</link></variable>"

#. JF9Gb
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7272255\n"
"help.text"
msgid "<variable id=\"trendlinestext\"> <ahelp hid=\".\">Trend lines can be added to all 2D chart types except for Pie and Stock charts.</ahelp> </variable>"
msgstr "<variable id=\"trendlinestext\"> <ahelp hid=\".\">ສາມາດເພີ່ມເສັ້ນທ່າອ່ຽງໃສ່ແຜນພູມ 2D ໄດ້ທຸກປະເພດ ຍົກເວັ້ນແຜນພູມວົງມົນ ແລະ ແຜນພູມຮຸ້ນ.</ahelp> </variable>"

#. NF2z3
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5716727\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">A linear trend line is shown.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບເສັ້ນຊື່.</ahelp>"

#. o9Giz
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5840021\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">A logarithmic trend line is shown.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບໂລກາລິດ.</ahelp>"

#. CXJKD
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9417096\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">An exponential trend line is shown.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບເລກກຳລັງ.</ahelp>"

#. J8i6Q
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8482924\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">A power trend line is shown.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບກຳລັງ.</ahelp>"

#. ENpRE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161052123210\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">A polynomial trend line is shown with a given degree.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບພະຫຸນາມຕາມລະດັບຂັ້ນທີ່ກຳນົດ.</ahelp>"

#. 69csw
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161102568315\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Degree of polynomial trend line.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລະດັບຂັ້ນຂອງເສັ້ນທ່າອ່ຽງແບບພະຫຸນາມ.</ahelp>"

#. pBcbu
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161105546053\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">A moving average trend line is shown with a given period.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງເສັ້ນທ່າອ່ຽງແບບຄ່າສະເລ່ຍເຄື່ອນທີ່ຕາມຊ່ວງເວລາທີ່ກຳນົດ.</ahelp>"

#. 9QFZj
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161107537745\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Number of points to calculate average of moving average trend line.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຈຳນວນຈຸດເພື່ອຄິດໄລ່ຄ່າສະເລ່ຍຂອງເສັ້ນທ່າອ່ຽງແບບຄ່າສະເລ່ຍເຄື່ອນທີ່.</ahelp>"

#. 8racG
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161112599880\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Name of trend line in legend.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຊື່ຂອງເສັ້ນທ່າອ່ຽງໃນຄຳອະທິບາຍສັນຍະລັກ.</ahelp>"

#. YXXHr
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161117252261\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Trend line is extrapolated for higher x-values.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເສັ້ນທ່າອ່ຽງຖືກຄາດຄະເນສຳລັບຄ່າ x ທີ່ສູງຂຶ້ນ.</ahelp>"

#. LsExB
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id18082016111837138\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Trend line is extrapolated for lower x-values.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເສັ້ນທ່າອ່ຽງຖືກຄາດຄະເນສຳລັບຄ່າ x ທີ່ຕ່ຳລົງ.</ahelp>"

#. qsEYS
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161124272765\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">For linear, polynomial and exponential trend lines, intercept value is forced to a given value.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສຳລັບເສັ້ນທ່າອ່ຽງແບບເສັ້ນຊື່, ພະຫຸນາມ ແລະ ເລກກຳລັງ, ຄ່າຈຸດຕັດແກນຈະຖືກບັງຄັບໃຫ້ເປັນຄ່າທີ່ກຳນົດ.</ahelp>"

#. Fug2F
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161126064822\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Value of intercept if it is forced.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຄ່າຂອງຈຸດຕັດແກນ ຫາກມີການບັງຄັບຄ່າ.</ahelp>"

#. EsUHA
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8962370\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Shows the trend line equation next to the trend line.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງສົມຜົນເສັ້ນທ່າອ່ຽງຂ້າງເສັ້ນທ່າອ່ຽງ.</ahelp>"

#. 6FZGw
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id6889858\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Shows the coefficient of determination next to the trend line.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງສຳປະສິດການກຳນົດຂ້າງເສັ້ນທ່າອ່ຽງ.</ahelp>"

#. RtirG
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161133305870\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Name of X variable in trend line equation.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຊື່ຂອງຕົວປ່ຽນ X ໃນສົມຜົນເສັ້ນທ່າອ່ຽງ.</ahelp>"

#. eD68W
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161134155865\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Name of Y variable in trend line equation.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຊື່ຂອງຕົວປ່ຽນ Y ໃນສົມຜົນເສັ້ນທ່າອ່ຽງ.</ahelp>"

#. tpWGs
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8398998\n"
"help.text"
msgid "If you insert a trend line to a chart type that uses categories, like <emph>Line</emph> or <emph>Column</emph>, then the numbers 1, 2, 3, <emph>…</emph> are used as x-values to calculate the trend line. For such charts the XY chart type might be more suitable."
msgstr "ຫາກທ່ານແຊກເສັ້ນທ່າອ່ຽງໃສ່ແຜນພູມປະເພດທີ່ໃຊ້ໝວດໝູ່ ເຊັ່ນ <emph>ເສັ້ນ</emph> ຫຼື <emph>ຖັນ</emph>, ຕົວເລກ 1, 2, 3, <emph>…</emph> ຈະຖືກໃຊ້ເປັນຄ່າ x ເພື່ອຄິດໄລ່ເສັ້ນທ່າອ່ຽງ. ສຳລັບແຜນພູມດັ່ງກ່າວ, ແຜນພູມປະເພດ XY ອາດຈະເໝາະສົມກວ່າ."

#. E7mkV
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id4349192\n"
"help.text"
msgid "To insert a trend line for a data series, first double-click the chart to enter edit mode and select the data series in the chart to which a trend line is to be created."
msgstr "ເພື່ອແຊກເສັ້ນທ່າອ່ຽງສຳລັບຊຸດຂໍ້ມູນ, ທຳອິດໃຫ້ດັບເບິນຄລິກທີ່ແຜນພູມເພື່ອເຂົ້າສູ່ໂໝດແກ້ໄຂ ແລະ ເລືອກຊຸດຂໍ້ມູນໃນແຜນພູມທີ່ຕ້ອງການສ້າງເສັ້ນທ່າອ່ຽງ."

#. VLWvK
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id801630627531175\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Insert - Trend Line</item>, or right-click the data series to open the context menu, and choose <item type=\"menuitem\">Insert Trend Line</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ແຊກ - ເສັ້ນທ່າອ່ຽງ</item>, ຫຼື ຄລິກຂວາໃສ່ຊຸດຂໍ້ມູນເພື່ອເປີດເມນູລັດ, ແລ້ວເລືອກ <item type=\"menuitem\">ແຊກເສັ້ນທ່າອ່ຽງ</item>."

#. osECL
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161539033867\n"
"help.text"
msgid "Mean Value Lines are special trend lines that show the mean value. Use <item type=\"menuitem\">Insert - Mean Value Lines</item> to insert mean value lines for data series."
msgstr "ເສັ້ນຄ່າສະເລ່ຍແມ່ນເສັ້ນທ່າອ່ຽງພິເສດທີ່ສະແດງຄ່າສະເລ່ຍ. ໃຊ້ <item type=\"menuitem\">ແຊກ - ເສັ້ນຄ່າສະເລ່ຍ</item> ເພື່ອແຊກເສັ້ນຄ່າສະເລ່ຍສຳລັບຊຸດຂໍ້ມູນ."

#. B2FBY
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9337443\n"
"help.text"
msgid "To delete a trend line or mean value line, click the line, then press the Del key."
msgstr "ເພື່ອລຶບເສັ້ນທ່າອ່ຽງ ຫຼື ເສັ້ນຄ່າສະເລ່ຍ, ໃຫ້ຄລິກທີ່ເສັ້ນນັ້ນ, ແລ້ວກົດປຸ່ມ Del."

#. nbEcg
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id801630627733593\n"
"help.text"
msgid "The menu item <menuitem>Insert - Trend Line</menuitem> is only available when the chart is in edit mode. It will appear grayed out if the chart is in edit mode but no data series is selected."
msgstr "ລາຍການເມນູ <menuitem>ແຊກ - ເສັ້ນທ່າອ່ຽງ</menuitem> ຈະໃຊ້ໄດ້ກໍຕໍ່ເມື່ອແຜນພູມຢູ່ໃນໂໝດແກ້ໄຂເທົ່ານັ້ນ. ມັນຈະປະກົດເປັນສີເທົ່າຫາກແຜນພູມຢູ່ໃນໂໝດແກ້ໄຂແຕ່ບໍ່ໄດ້ເລືອກຊຸດຂໍ້ມູນ."

#. EFBBV
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9569689\n"
"help.text"
msgid "The trend line has the same color as the corresponding data series. To change the line properties, select the trend line and choose <item type=\"menuitem\">Format - Format Selection - Line</item>."
msgstr "ເສັ້ນທ່າອ່ຽງມີສີດຽວກັນກັບຊຸດຂໍ້ມູນທີ່ກ່ຽວຂ້ອງ. ເພື່ອປ່ຽນຄຸນສົມບັດຂອງເສັ້ນ, ໃຫ້ເລືອກເສັ້ນທ່າອ່ຽງແລ້ວເລືອກ <item type=\"menuitem\">ຈັດຮູບແບບ - ຈັດຮູບແບບການເລືອກ - ເສັ້ນ</item>."

#. JVZCk
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id296334\n"
"help.text"
msgid "A trend line is shown in the legend automatically. Its name can be defined in options of the trend line."
msgstr "ເສັ້ນທ່າອ່ຽງຈະຖືກສະແດງໃນຄຳອະທິບາຍສັນຍະລັກໂດຍອັດຕະໂນມັດ. ຊື່ຂອງມັນສາມາດກຳນົດໄດ້ໃນຕົວເລືອກຂອງເສັ້ນທ່າອ່ຽງ."

#. FAqAo
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id180820161534333508\n"
"help.text"
msgid "Trend Line Equation and Coefficient of Determination"
msgstr "ສົມຜົນເສັ້ນທ່າອ່ຽງ ແລະ ສຳປະສິດການກຳນົດ"

#. ArYKX
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8962065\n"
"help.text"
msgid "When the chart is in edit mode, %PRODUCTNAME gives you the equation of the trend line and the coefficient of determination R<sup>2</sup>, even if they are not shown: click on the trend line to see the information in the status bar."
msgstr "ເມື່ອແຜນພູມຢູ່ໃນໂໝດແກ້ໄຂ, %PRODUCTNAME ຈະໃຫ້ສົມຜົນຂອງເສັ້ນທ່າອ່ຽງ ແລະ ສຳປະສິດການກຳນົດ R<sup>2</sup>, ເຖິງແມ່ນວ່າມັນຈະບໍ່ໄດ້ສະແດງອອກມາ: ໃຫ້ຄລິກທີ່ເສັ້ນທ່າອ່ຽງເພື່ອເບິ່ງຂໍ້ມູນໃນແຖບສະຖານະ."

#. xHGhE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id846888\n"
"help.text"
msgid "<ahelp hid=\".\">To show the trend line equation, select the trend line in the chart, right-click to open the context menu, and choose <item type=\"menuitem\">Insert Trend Line Equation</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ເພື່ອສະແດງສົມຜົນເສັ້ນທ່າອ່ຽງ, ໃຫ້ເລືອກເສັ້ນທ່າອ່ຽງໃນແຜນພູມ, ຄລິກຂວາເພື່ອເປີດເມນູລັດ, ແລ້ວເລືອກ <item type=\"menuitem\">ແຊກສົມຜົນເສັ້ນທ່າອ່ຽງ</item>.</ahelp>"

#. ohXGJ
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8962066\n"
"help.text"
msgid "To change format of values (use less significant digits or scientific notation), select the equation in the chart, right-click to open the context menu, and choose <item type=\"menuitem\">Format Trend Line Equation - Numbers</item>."
msgstr "ເພື່ອປ່ຽນຮູບແບບຂອງຄ່າ (ໃຊ້ຕົວເລກທີ່ມີເລກນັຍໜ້ອຍລົງ ຫຼື ຮູບແບບວິທະຍາສາດ), ໃຫ້ເລືອກສົມຜົນໃນແຜນພູມ, ຄລິກຂວາເພື່ອເປີດເມນູລັດ, ແລ້ວເລືອກ <item type=\"menuitem\">ຈັດຮູບແບບສົມຜົນເສັ້ນທ່າອ່ຽງ - ຕົວເລືອກ</item>."

#. e957n
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161627109994\n"
"help.text"
msgid "Default equation uses <item type=\"literal\">x</item> for abscissa variable, and <item type=\"literal\">f(x)</item> for ordinate variable. To change these names, select the trend line, choose <item type=\"menuitem\">Format - Format Selection – Type</item> and enter names in <item type=\"literal\">X Variable Name</item> and <item type=\"literal\">Y Variable Name</item> edit boxes."
msgstr "ສົມຜົນເລີ່ມຕົ້ນໃຊ້ <item type=\"literal\">x</item> ສຳລັບຕົວປ່ຽນແກນນອນ, ແລະ <item type=\"literal\">f(x)</item> ສຳລັບຕົວປ່ຽນແກນຕັ້ງ. ເພື່ອປ່ຽນຊື່ເຫຼົ່ານີ້, ໃຫ້ເລືອກເສັ້ນທ່າອ່ຽງ, ເລືອກ <item type=\"menuitem\">ຈັດຮູບແບບ - ຈັດຮູບແບບການເລືອກ – ປະເພດ</item> ແລ້ວປ້ອນຊື່ໃນກ່ອງແກ້ໄຂ <item type=\"literal\">ຊື່ຕົວປ່ຽນ X</item> ແລະ <item type=\"literal\">ຊື່ຕົວປ່ຽນ Y</item>."

#. jAs3d
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id18082016163702791\n"
"help.text"
msgid "To show the coefficient of determination R<sup>2</sup>, select the equation in the chart, right-click to open the context menu, and choose <item type=\"menuitem\">Insert R</item><sup><item type=\"menuitem\">2</item></sup>."
msgstr "ເພື່ອສະແດງສຳປະສິດການກຳນົດ R<sup>2</sup>, ໃຫ້ເລືອກສົມຜົນໃນແຜນພູມ, ຄລິກຂວາເພື່ອເປີດເມນູລັດ, ແລ້ວເລືອກ <item type=\"menuitem\">ແຊກ R</item><sup><item type=\"menuitem\">2</item></sup>."

#. yfQY2
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161637028632\n"
"help.text"
msgid "If intercept is forced, coefficient of determination R<sup>2</sup> is not calculated in the same way as with free intercept. R<sup>2</sup> values can not be compared with forced or free intercept."
msgstr "ຫາກມີການບັງຄັບຈຸດຕັດແກນ, ສຳປະສິດການກຳນົດ R<sup>2</sup> ຈະບໍ່ຖືກຄິດໄລ່ໃນວິທີດຽວກັນກັບຈຸດຕັດແກນແບບອິດສະຫຼະ. ຄ່າ R<sup>2</sup> ບໍ່ສາມາດນຳມາປຽບທຽບກັນໄດ້ລະຫວ່າງການບັງຄັບ ຫຼື ບໍ່ບັງຄັບຈຸດຕັດແກນ."

#. 47ME7
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id180820161534333509\n"
"help.text"
msgid "Trend Lines Curve Types"
msgstr "ປະເພດເສັ້ນໂຄ້ງທ່າອ່ຽງ"

#. AB9tE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id18082016153820777\n"
"help.text"
msgid "The following regression types are available:"
msgstr "ມີປະເພດການຖອຍຫຼັງດັ່ງຕໍ່ໄປນີ້:"

#. FBpPx
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161604098009\n"
"help.text"
msgid "<emph>Linear</emph> trend line: regression through equation <item type=\"literal\">y=a∙x+b</item>. Intercept <item type=\"literal\">b</item> can be forced."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບເສັ້ນຊື່</emph>: ການຖອຍຫຼັງຜ່ານສົມຜົນ <item type=\"literal\">y=a∙x+b</item>. ຈຸດຕັດແກນ <item type=\"literal\">b</item> ສາມາດບັງຄັບຄ່າໄດ້."

#. 2cKaa
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161612524298\n"
"help.text"
msgid "<emph>Polynomial</emph> trend line: regression through equation <item type=\"literal\">y=Σ</item><sub><item type=\"literal\">i</item></sub><item type=\"literal\">(a</item><sub><item type=\"literal\">i</item></sub><item type=\"literal\">∙x</item><sup><item type=\"literal\">i</item></sup><item type=\"literal\">)</item>. Intercept <item type=\"literal\">a</item><sub><item type=\"literal\">0</item></sub> can be forced. Degree of polynomial must be given (at least 2)."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບພະຫຸນາມ</emph>: ການຖອຍຫຼັງຜ່ານສົມຜົນ <item type=\"literal\">y=Σ</item><sub><item type=\"literal\">i</item></sub><item type=\"literal\">(a</item><sub><item type=\"literal\">i</item></sub><item type=\"literal\">∙x</item><sup><item type=\"literal\">i</item></sup><item type=\"literal\">)</item>. ຈຸດຕັດແກນ <item type=\"literal\">a</item><sub><item type=\"literal\">0</item></sub> ສາມາດບັງຄັບຄ່າໄດ້. ຕ້ອງລະບຸລະດັບຂັ້ນຂອງພະຫຸນາມ (ຢ່າງໜ້ອຍແມ່ນ 2)."

#. srJXi
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161612525364\n"
"help.text"
msgid "<emph>Logarithmic</emph> trend line: regression through equation <item type=\"literal\">y=a∙ln(x)+b</item>."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບໂລກາລິດ</emph>: ການຖອຍຫຼັງຜ່ານສົມຜົນ <item type=\"literal\">y=a∙ln(x)+b</item>."

#. MLE4x
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161612526680\n"
"help.text"
msgid "<emph>Exponential</emph> trend line: regression through equation <item type=\"literal\">y=b∙exp(a∙x)</item>.This equation is equivalent to <item type=\"literal\">y=b∙m</item><sup><item type=\"literal\">x</item></sup> with <item type=\"literal\">m=exp(a)</item>. Intercept <item type=\"literal\">b</item> can be forced."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບເລກກຳລັງ</emph>: ການຖອຍຫຼັງຜ່ານສົມຜົນ <item type=\"literal\">y=b∙exp(a∙x)</item>. ສົມຜົນນີ້ທຽບເທົ່າກັບ <item type=\"literal\">y=b∙m</item><sup><item type=\"literal\">x</item></sup> ໂດຍທີ່ <item type=\"literal\">m=exp(a)</item>. ຈຸດຕັດແກນ <item type=\"literal\">b</item> ສາມາດບັງຄັບຄ່າໄດ້."

#. KoRSa
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161612527230\n"
"help.text"
msgid "<emph>Power</emph> trend line: regression through equation <item type=\"literal\">y=b∙x</item><sup><item type=\"literal\">a</item></sup>."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບກຳລັງ</emph>: ການຖອຍຫຼັງຜ່ານສົມຜົນ <item type=\"literal\">y=b∙x</item><sup><item type=\"literal\">a</item></sup>."

#. fnwKu
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id180820161617342768\n"
"help.text"
msgid "<emph>Moving average</emph> trend line: simple moving average is calculated with the <emph>n</emph> previous y-values, <emph>n</emph> being the period. No equation is available for this trend line."
msgstr "ເສັ້ນທ່າອ່ຽງ <emph>ແບບຄ່າສະເລ່ຍເຄື່ອນທີ່</emph>: ຄ່າສະເລ່ຍເຄື່ອນທີ່ແບບງ່າຍດາຍແມ່ນຄິດໄລ່ດ້ວຍຄ່າ y ກ່ອນໜ້າ <emph>n</emph> ຄ່າ, ໂດຍ <emph>n</emph> ແມ່ນຊ່ວງເວລາ. ບໍ່ມີສົມຜົນສຳລັບເສັ້ນທ່າອ່ຽງປະເພດນີ້."

#. kq2KM
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id9204077\n"
"help.text"
msgid "Constraints"
msgstr "ຂໍ້ຈຳກັດ"

#. Dv6wV
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7393719\n"
"help.text"
msgid "The calculation of the trend line considers only data pairs with the following values:"
msgstr "ການຄິດໄລ່ເສັ້ນທ່າອ່ຽງຈະພິຈາລະນາສະເພາະຄູ່ຂໍ້ມູນທີ່ມີຄ່າດັ່ງຕໍ່ໄປນີ້:"

#. F7VNE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7212744\n"
"help.text"
msgid "Logarithmic trend line: only positive x-values are considered."
msgstr "ເສັ້ນທ່າອ່ຽງແບບໂລກາລິດ: ພິຈາລະນາສະເພາະຄ່າ x ທີ່ເປັນບວກເທົ່ານັ້ນ."

#. GDEmX
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id1664479\n"
"help.text"
msgid "Exponential trend line: only positive y-values are considered, except if all y-values are negative: regression will then follow equation <item type=\"literal\">y=-b∙exp(a∙x)</item>."
msgstr "ເສັ້ນທ່າອ່ຽງແບບເລກກຳລັງ: ພິຈາລະນາສະເພາະຄ່າ y ທີ່ເປັນບວກເທົ່ານັ້ນ, ຍົກເວັ້ນຫາກຄ່າ y ທັງໝົດເປັນລົບ: ການຖອຍຫຼັງຈະເປັນໄປຕາມສົມຜົນ <item type=\"literal\">y=-b∙exp(a∙x)</item>."

#. 58RRD
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8734702\n"
"help.text"
msgid "Power trend line: only positive x-values are considered; only positive y-values are considered, except if all y-values are negative: regression will then follow equation<item type=\"literal\"> y=-b∙x</item><sup><item type=\"literal\">a</item></sup>."
msgstr "ເສັ້ນທ່າອ່ຽງແບບກຳລັງ: ພິຈາລະນາສະເພາະຄ່າ x ທີ່ເປັນບວກ ແລະ ຄ່າ y ທີ່ເປັນບວກເທົ່ານັ້ນ, ຍົກເວັ້ນຫາກຄ່າ y ທັງໝົດເປັນລົບ: ການຖອຍຫຼັງຈະເປັນໄປຕາມສົມຜົນ <item type=\"literal\"> y=-b∙x</item><sup><item type=\"literal\">a</item></sup>."

#. XWrNF
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id181279\n"
"help.text"
msgid "You should transform your data accordingly; it is best to work on a copy of the original data and transform the copied data."
msgstr "ທ່ານຄວນປ່ຽນແປງຂໍ້ມູນຂອງທ່ານໃຫ້ເໝາະສົມ; ທາງທີ່ດີທີ່ສຸດແມ່ນເຮັດວຽກໃນສຳເນົາຂອງຂໍ້ມູນຕົ້ນສະບັບ ແລະ ປ່ຽນແປງຂໍ້ມູນທີ່ສຳເນົາມານັ້ນ."

#. xrvYT
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id180820161528021520\n"
"help.text"
msgid "Calculate Parameters in Calc"
msgstr "ຄິດໄລ່ພາຣາມິເຕີໃນ Calc"

#. XS5FX
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7735221\n"
"help.text"
msgid "You can also calculate the parameters using Calc functions as follows."
msgstr "ທ່ານຍັງສາມາດຄິດໄລ່ພາຣາມິເຕີໂດຍໃຊ້ຟັງຊັນ Calc ໄດ້ດັ່ງນີ້."

#. KeyG7
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id5744193\n"
"help.text"
msgid "The linear regression equation"
msgstr "ສົມຜົນການຖອຍຫຼັງແບບເສັ້ນຊື່"

#. gvykK
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9251991\n"
"help.text"
msgid "The <emph>linear regression</emph> follows the equation <item type=\"literal\">y=m*x+b</item>."
msgstr "ການ <emph>ຖອຍຫຼັງແບບເສັ້ນຊື່</emph> ແມ່ນເປັນໄປຕາມສົມຜົນ <item type=\"literal\">y=m*x+b</item>."

#. sJhZJ
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7951902\n"
"help.text"
msgid "m = SLOPE(Data_Y;Data_X)"
msgstr "m = SLOPE(ຂໍ້ມູນ_Y;ຂໍ້ມູນ_X)"

#. ufTSt
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id6637165\n"
"help.text"
msgid "b = INTERCEPT(Data_Y ;Data_X)"
msgstr "b = INTERCEPT(ຂໍ້ມູນ_Y ;ຂໍ້ມູນ_X)"

#. MJUyE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7879268\n"
"help.text"
msgid "Calculate the coefficient of determination by"
msgstr "ຄິດໄລ່ສຳປະສິດການກຳນົດໂດຍ"

#. XdQ7G
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9244361\n"
"help.text"
msgid "r<sup>2</sup> = RSQ(Data_Y;Data_X)"
msgstr "r<sup>2</sup> = RSQ(ຂໍ້ມູນ_Y;ຂໍ້ມູນ_X)"

#. 3RFqQ
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id2083498\n"
"help.text"
msgid "Besides m, b and r<sup>2</sup> the array function <emph>LINEST</emph> provides additional statistics for a regression analysis."
msgstr "ນອກຈາກ m, b ແລະ r<sup>2</sup> ແລ້ວ, ຟັງຊັນອາເຣ <emph>LINEST</emph> ຍັງໃຫ້ສະຖິຕິເພີ່ມເຕີມສຳລັບການວິເຄາະການຖອຍຫຼັງ."

#. FQkBD
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id2538834\n"
"help.text"
msgid "The logarithmic regression equation"
msgstr "ສົມຜົນການຖອຍຫຼັງແບບໂລກາລິດ"

#. 4oEke
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id394299\n"
"help.text"
msgid "The <emph>logarithmic regression</emph> follows the equation <item type=\"literal\">y=a*ln(x)+b</item>."
msgstr "ການ <emph>ຖອຍຫຼັງແບບໂລກາລິດ</emph> ແມ່ນເປັນໄປຕາມສົມຜົນ <item type=\"literal\">y=a*ln(x)+b</item>."

#. Zundq
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id2134159\n"
"help.text"
msgid "a = SLOPE(Data_Y;LN(Data_X))"
msgstr "a = SLOPE(ຂໍ້ມູນ_Y;LN(ຂໍ້ມູນ_X))"

#. vqAFr
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5946531\n"
"help.text"
msgid "b = INTERCEPT(Data_Y ;LN(Data_X))"
msgstr "b = INTERCEPT(ຂໍ້ມູນ_Y ;LN(ຂໍ້ມູນ_X))"

#. CfpeX
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5649281\n"
"help.text"
msgid "r<sup>2</sup> = RSQ(Data_Y;LN(Data_X))"
msgstr "r<sup>2</sup> = RSQ(ຂໍ້ມູນ_Y;LN(ຂໍ້ມູນ_X))"

#. d372B
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id7874080\n"
"help.text"
msgid "The exponential regression equation"
msgstr "ສົມຜົນການຖອຍຫຼັງແບບເລກກຳລັງ"

#. QEb4f
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id4679097\n"
"help.text"
msgid "For exponential trend lines a transformation to a linear model takes place. The optimal curve fitting is related to the linear model and the results are interpreted accordingly."
msgstr "ສຳລັບເສັ້ນທ່າອ່ຽງແບບເລກກຳລັງ, ຈະມີການປ່ຽນຮູບໄປສູ່ແບບຈຳລອງເສັ້ນຊື່. ການປັບເສັ້ນໂຄ້ງໃຫ້ເໝາະສົມທີ່ສຸດແມ່ນກ່ຽວຂ້ອງກັບແບບຈຳລອງເສັ້ນຊື່ ແລະ ຜົນໄດ້ຮັບຈະຖືກຕີຄວາມໝາຍຕາມນັ້ນ."

#. LYGaX
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9112216\n"
"help.text"
msgid "The exponential regression follows the equation <item type=\"literal\">y=b*exp(a*x)</item> or <item type=\"literal\">y=b*m</item><sup><item type=\"literal\">x</item></sup>, which is transformed to <item type=\"literal\">ln(y)=ln(b)+a*x</item> or <item type=\"literal\">ln(y)=ln(b)+ln(m)*x</item> respectively."
msgstr "ການຖອຍຫຼັງແບບເລກກຳລັງແມ່ນເປັນໄປຕາມສົມຜົນ <item type=\"literal\">y=b*exp(a*x)</item> ຫຼື <item type=\"literal\">y=b*m</item><sup><item type=\"literal\">x</item></sup>, ເຊິ່ງຖືກປ່ຽນຮູບເປັນ <item type=\"literal\">ln(y)=ln(b)+a*x</item> ຫຼື <item type=\"literal\">ln(y)=ln(b)+ln(m)*x</item> ຕາມລຳດັບ."

#. NaM55
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id4416638\n"
"help.text"
msgid "a = SLOPE(LN(Data_Y);Data_X)"
msgstr "a = SLOPE(LN(ຂໍ້ມູນ_Y);ຂໍ້ມູນ_X)"

#. DNTZj
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id1039155\n"
"help.text"
msgid "The variables for the second variation are calculated as follows:"
msgstr "ຕົວປ່ຽນສຳລັບຮູບແບບທີສອງແມ່ນຄິດໄລ່ໄດ້ດັ່ງນີ້:"

#. NUado
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7184057\n"
"help.text"
msgid "m = EXP(SLOPE(LN(Data_Y);Data_X))"
msgstr "m = EXP(SLOPE(LN(ຂໍ້ມູນ_Y);ຂໍ້ມູນ_X))"

#. SPjRP
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id786767\n"
"help.text"
msgid "b = EXP(INTERCEPT(LN(Data_Y);Data_X))"
msgstr "b = EXP(INTERCEPT(LN(ຂໍ້ມູນ_Y);ຂໍ້ມູນ_X))"

#. 4YKvd
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id7127292\n"
"help.text"
msgid "Calculate the coefficient of determination by"
msgstr "ຄິດໄລ່ສຳປະສິດການກຳນົດໂດຍ"

#. wrZLx
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5437177\n"
"help.text"
msgid "r<sup>2</sup> = RSQ(LN(Data_Y);Data_X)"
msgstr "r<sup>2</sup> = RSQ(LN(ຂໍ້ມູນ_Y);ຂໍ້ມູນ_X)"

#. 5xosY
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id6946317\n"
"help.text"
msgid "Besides m, b and r<sup>2</sup> the array function <emph>LOGEST</emph> provides additional statistics for a regression analysis."
msgstr "ນອກຈາກ m, b ແລະ r<sup>2</sup> ແລ້ວ, ຟັງຊັນອາເຣ <emph>LOGEST</emph> ຍັງໃຫ້ສະຖິຕິເພີ່ມເຕີມສຳລັບການວິເຄາະການຖອຍຫຼັງ."

#. GKeKk
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id6349375\n"
"help.text"
msgid "The power regression equation"
msgstr "ສົມຜົນການຖອຍຫຼັງແບບກຳລັງ"

#. CobWD
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id1857661\n"
"help.text"
msgid "For <emph>power regression</emph> curves a transformation to a linear model takes place. The power regression follows the equation <item type=\"literal\">y=b*x</item><sup><item type=\"literal\">a</item></sup>, which is transformed to <item type=\"literal\">ln(y)=ln(b)+a*ln(x)</item>."
msgstr "ສຳລັບເສັ້ນໂຄ້ງ <emph>ການຖອຍຫຼັງແບບກຳລັງ</emph>, ຈະມີການປ່ຽນຮູບໄປສູ່ແບບຈຳລອງເສັ້ນຊື່. ການຖອຍຫຼັງແບບກຳລັງແມ່ນເປັນໄປຕາມສົມຜົນ <item type=\"literal\">y=b*x</item><sup><item type=\"literal\">a</item></sup>, ເຊິ່ງຖືກປ່ຽນຮູບເປັນ <item type=\"literal\">ln(y)=ln(b)+a*ln(x)</item>."

#. ETDqd
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8517105\n"
"help.text"
msgid "a = SLOPE(LN(Data_Y);LN(Data_X))"
msgstr "a = SLOPE(LN(ຂໍ້ມູນ_Y);LN(ຂໍ້ມູນ_X))"

#. CYELA
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id9827265\n"
"help.text"
msgid "b = EXP(INTERCEPT(LN(Data_Y);LN(Data_X))"
msgstr "b = EXP(INTERCEPT(LN(ຂໍ້ມູນ_Y);LN(ຂໍ້ມູນ_X))"

#. NFVfw
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id2357249\n"
"help.text"
msgid "r<sup>2</sup> = RSQ(LN(Data_Y);LN(Data_X))"
msgstr "r<sup>2</sup> = RSQ(LN(ຂໍ້ມູນ_Y);LN(ຂໍ້ມູນ_X))"

#. CGBsE
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"hd_id7907040\n"
"help.text"
msgid "The polynomial regression equation"
msgstr "ສົມຜົນການຖອຍຫຼັງແບບພະຫຸນາມ"

#. qAyRm
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8918729\n"
"help.text"
msgid "For <emph>polynomial regression</emph> curves a transformation to a linear model takes place."
msgstr "ສຳລັບເສັ້ນໂຄ້ງ <emph>ການຖອຍຫຼັງແບບພະຫຸນາມ</emph>, ຈະມີການປ່ຽນຮູບໄປສູ່ແບບຈຳລອງເສັ້ນຊື່."

#. DatEp
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id33875\n"
"help.text"
msgid "Create a table with the columns x, x<sup>2</sup>, x<sup>3</sup>, … , x<sup>n</sup>, y up to the desired degree n."
msgstr "ສ້າງຕາຕະລາງທີ່ມີຖັນ x, x<sup>2</sup>, x<sup>3</sup>, … , x<sup>n</sup>, y ຈົນເຖິງລະດັບຂັ້ນ n ທີ່ຕ້ອງການ."

#. wJrKC
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8720053\n"
"help.text"
msgid "Use the formula <item type=\"literal\">=LINEST(Data_Y,Data_X)</item> with the complete range x to x<sup>n</sup> (without headings) as Data_X."
msgstr "ໃຊ້ສູດ <item type=\"literal\">=LINEST(ຂໍ້ມູນ_Y,ຂໍ້ມູນ_X)</item> ໂດຍໃຊ້ຊ່ວງທີ່ສົມບູນຕັ້ງແຕ່ x ຈົນເຖິງ x<sup>n</sup> (ໂດຍບໍ່ລວມຫົວຂໍ້) ເປັນ ຂໍ້ມູນ_X."

#. 3zm3C
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id5068514\n"
"help.text"
msgid "The first row of the <emph>LINEST</emph> output contains the coefficients of the regression polynomial, with the coefficient of x<sup>n</sup> at the leftmost position."
msgstr "ແຖວທຳອິດຂອງຜົນໄດ້ຮັບ <emph>LINEST</emph> ປະກອບດ້ວຍສຳປະສິດຂອງພະຫຸນາມການຖອຍຫຼັງ, ໂດຍທີ່ສຳປະສິດຂອງ x<sup>n</sup> ຈະຢູ່ຕຳແໜ່ງຊ້າຍສຸດ."

#. pGA6a
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id8202154\n"
"help.text"
msgid "The first element of the third row of the <emph>LINEST</emph> output is the value of r<sup>2</sup>. See the <link href=\"text/scalc/01/04060107.xhp#Section8\"><emph>LINEST</emph></link> function for details on proper use and an explanation of the other output parameters."
msgstr "ອົງປະກອບທຳອິດຂອງແຖວທີສາມຂອງຜົນໄດ້ຮັບ <emph>LINEST</emph> ແມ່ນຄ່າຂອງ r<sup>2</sup>. ເບິ່ງຟັງຊັນ <link href=\"text/scalc/01/04060107.xhp#Section8\"><emph>LINEST</emph></link> ສຳລັບລາຍລະອຽດກ່ຽວກັບການນຳໃຊ້ທີ່ຖືກຕ້ອງ ແລະ ຄຳອະທິບາຍກ່ຽວກັບພາຣາມິເຕີຜົນໄດ້ຮັບອື່ນໆ."

#. RU3Fv
#: 04050100.xhp
msgctxt ""
"04050100.xhp\n"
"par_id4562211\n"
"help.text"
msgid "<link href=\"text/schart/01/04050000.xhp\">X/Y Error Bars</link>"
msgstr "<link href=\"text/schart/01/04050000.xhp\">ແຖບຄວາມຜິດພາດ X/Y</link>"

#. KL73b
#: 04050100.xhp
