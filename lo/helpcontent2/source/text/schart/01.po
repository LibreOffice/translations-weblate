msgid "<bookmark_value>scaling; axes</bookmark_value><bookmark_value>logarithmic scaling along axes</bookmark_value><bookmark_value>charts;scaling axes</bookmark_value><bookmark_value>X axes;scaling</bookmark_value><bookmark_value>Y axes; scaling</bookmark_value>"
msgstr "<bookmark_value>ການກຳນົດຂະໜາດ; ແກນ</bookmark_value><bookmark_value>ການກຳນົດຂະໜາດແບບໂລກາລິດຕາມແກນ</bookmark_value><bookmark_value>ແຜນພູມ; ການກຳນົດຂະໜາດແກນ</bookmark_value><bookmark_value>ແກນ X; ການກຳນົດຂະໜາດ</bookmark_value><bookmark_value>ແກນ Y; ການກຳນົດຂະໜາດ</bookmark_value>"

#. jwMAw
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3150868\n"
"help.text"
msgid "<link href=\"text/schart/01/05040201.xhp\">Scale</link>"
msgstr "<link href=\"text/schart/01/05040201.xhp\">ຂະໜາດ</link>"

#. ZGujx
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3154013\n"
"help.text"
msgid "Controls the scaling of the X or Y axis."
msgstr "ຄວບຄຸມການກຳນົດຂະໜາດຂອງແກນ X ຫຼື Y."

#. Y42fe
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3148576\n"
"help.text"
msgid "The axes are automatically scaled by $[officename] so that all values are optimally displayed."
msgstr "ແກນຕ່າງໆຈະຖືກກຳນົດຂະໜາດໂດຍອັດຕະໂນມັດໂດຍ $[officename] ເພື່ອໃຫ້ທຸກຄ່າສະແດງອອກມາໄດ້ດີທີ່ສຸດ."

#. uhBHq
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3149379\n"
"help.text"
msgid "To achieve specific results, you can manually change the axis scaling. For example, you can display only the top areas of the columns by shifting the zero line upwards."
msgstr "ເພື່ອໃຫ້ໄດ້ຜົນລັດສະເພາະເຈາະຈົງ, ທ່ານສາມາດປ່ຽນການກຳນົດຂະໜາດແກນໄດ້ດ້ວຍຕົນເອງ. ຕົວຢ່າງ: ທ່ານສາມາດສະແດງສະເພາະພື້ນທີ່ສ່ວນເທິງຂອງຖັນໂດຍການຍ້າຍເສັ້ນສູນຂຶ້ນເທິງ."

#. cqLQh
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3154730\n"
"help.text"
msgid "Scale"
msgstr "ຂະໜາດ"

#. TwRxL
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3149400\n"
"help.text"
msgid "You can enter values for subdividing axes in this area. You can automatically set the properties <emph>Minimum, Maximum, Major interval, Minor interval count</emph> and <emph>Reference value</emph>."
msgstr "ທ່ານສາມາດປ້ອນຄ່າສຳລັບການແບ່ງຍ່ອຍແກນໃນສ່ວນນີ້. ທ່ານສາມາດຕັ້ງຄ່າຄຸນສົມບັດ <emph>ຕ່ຳສຸດ, ສູງສຸດ, ໄລຍະຫ່າງຫຼັກ, ຈຳນວນໄລຍະຫ່າງຍ່ອຍ</emph> ແລະ <emph>ຄ່າອ້າງອີງ</emph> ແບບອັດຕະໂນມັດໄດ້."

#. 8DGor
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3150751\n"
"help.text"
msgid "Minimum"
msgstr "ຕ່ຳສຸດ"

#. FCMzw
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3153713\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_MIN\">Defines the minimum value for the beginning of the axis.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_MIN\">ກຳນົດຄ່າຕ່ຳສຸດສຳລັບຈຸດເລີ່ມຕົ້ນຂອງແກນ.</ahelp>"

#. SF9GW
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3156385\n"
"help.text"
msgid "Maximum"
msgstr "ສູງສຸດ"

#. fnonv
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3159266\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_MAX\">Defines the maximum value for the end of the axis.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_MAX\">ກຳນົດຄ່າສູງສຸດສຳລັບຈຸດສິ້ນສຸດຂອງແກນ.</ahelp>"

#. 2vVtv
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3155336\n"
"help.text"
msgid "Major interval"
msgstr "ໄລຍະຫ່າງຫຼັກ"

#. h82YW
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3143218\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_STEP_MAIN\">Defines the interval for the main division of the axes.</ahelp> The main interval cannot be larger than the value area."
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_STEP_MAIN\">ກຳນົດໄລຍະຫ່າງສຳລັບການແບ່ງຫຼັກຂອງແກນ.</ahelp> ໄລຍະຫ່າງຫຼັກບໍ່ສາມາດໃຫຍ່ກວ່າພື້ນທີ່ຂອງຄ່າໄດ້."

#. UNHpT
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3154020\n"
"help.text"
msgid "Minor interval count"
msgstr "ຈຳນວນໄລຍະຫ່າງຍ່ອຍ"

#. yCBZ8
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3154656\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/MT_STEPHELP\">Defines the interval for the subdivision of the axes.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/MT_STEPHELP\">ກຳນົດໄລຍະຫ່າງສຳລັບການແບ່ງຍ່ອຍຂອງແກນ.</ahelp>"

#. Rfip6
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3150089\n"
"help.text"
msgid "Reference value"
msgstr "ຄ່າອ້າງອີງ"

#. 4zEjX
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3152990\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_ORIGIN\">Specifies at which position to display the values along the axis.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/EDT_ORIGIN\">ລະບຸຕຳແໜ່ງທີ່ຈະສະແດງຄ່າຕ່າງໆຕາມແກນ.</ahelp>"

#. 2deCC
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3166432\n"
"help.text"
msgid "Automatic"
msgstr "ອັດຕະໂນມັດ"

#. vCDLV
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3145389\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/CBX_AUTO_ORIGIN\">You must first deselect the <emph>Automatic</emph> option in order to modify the values.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/CBX_AUTO_ORIGIN\">ທ່ານຕ້ອງຍົກເລີກການເລືອກຕົວເລືອກ <emph>ອັດຕະໂນມັດ</emph> ກ່ອນ ຈຶ່ງຈະສາມາດແກ້ໄຂຄ່າຕ່າງໆໄດ້.</ahelp>"

#. vbqNC
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3149129\n"
"help.text"
msgid "Disable this feature if you are working with \"fixed\" values, as it does not permit automatic scaling."
msgstr "ປິດຄຸນສົມບັດນີ້ຫາກທ່ານເຮັດວຽກກັບຄ່າທີ່ \"ຕາຍຕົວ\", ເພາະວ່າມັນຈະບໍ່ອະນຸຍາດໃຫ້ມີການກຳນົດຂະໜາດແບບອັດຕະໂນມັດ."

#. hATXR
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id3159206\n"
"help.text"
msgid "Logarithmic scale"
msgstr "ຂະໜາດແບບໂລກາລິດ"

#. Q56Yi
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3145360\n"
"help.text"
msgid "<ahelp hid=\"modules/schart/ui/tp_Scale/CBX_LOGARITHM\">Specifies that you want the axis to be subdivided logarithmically.</ahelp>"
msgstr "<ahelp hid=\"modules/schart/ui/tp_Scale/CBX_LOGARITHM\">ລະບຸວ່າທ່ານຕ້ອງການໃຫ້ແກນມີການແບ່ງຍ່ອຍແບບໂລກາລິດ.</ahelp>"

#. CCBLE
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3153956\n"
"help.text"
msgid "Use this feature if you are working with values that differ sharply from each other. You can use logarithmic scaling to make the grid lines of the axis equidistant but have values that may increase or decrease."
msgstr "ໃຊ້ຄຸນສົມບັດນີ້ຫາກທ່ານເຮັດວຽກກັບຄ່າທີ່ມີຄວາມແຕກຕ່າງກັນຫຼາຍ. ທ່ານສາມາດໃຊ້ການກຳນົດຂະໜາດແບບໂລກາລິດເພື່ອເຮັດໃຫ້ເສັ້ນຕາໜ່າງຂອງແກນມີໄລຍະຫ່າງເທົ່າກັນ ແຕ່ມີຄ່າທີ່ອາດຈະເພີ່ມຂຶ້ນ ຫຼື ຫຼຸດລົງຢ່າງໄວວາ."

#. qtLGA
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id9941404\n"
"help.text"
msgid "Reverse direction"
msgstr "ທິດທາງປີ້ນກັບ"

#. MaYvp
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id5581835\n"
"help.text"
msgid "<ahelp hid=\".\">Defines where the lower and where the higher values are displayed at the axis. The unchecked state is the mathematical direction.</ahelp> That means for Cartesian coordinate systems that the x-axis shows the lower values on the left and the y-axis shows the lower values at the bottom. For polar coordinate systems the mathematical angle axis direction is counterclockwise and the radial axis is from inner to outer."
msgstr "<ahelp hid=\".\">ກຳນົດບ່ອນທີ່ຈະສະແດງຄ່າທີ່ຕ່ຳກວ່າ ແລະ ຄ່າທີ່ສູງກວ່າໃນແກນ. ສະຖານະທີ່ບໍ່ໄດ້ໝາຍຕິກແມ່ນທິດທາງທາງຄະນິດສາດ.</ahelp> ນັ້ນໝາຍຄວາມວ່າສຳລັບລະບົບພິກັດຄາທີຊຽນ, ແກນ x ຈະສະແດງຄ່າທີ່ຕ່ຳກວ່າຢູ່ທາງຊ້າຍ ແລະ ແກນ y ຈະສະແດງຄ່າທີ່ຕ່ຳກວ່າຢູ່ທາງລຸ່ມ. ສຳລັບລະບົບພິກັດຂົ້ວໂລກ, ທິດທາງແກນມຸມທາງຄະນິດສາດແມ່ນແບບທວນເຂັມໂມງ ແລະ ແກນລັດສະໝີແມ່ນຈາກພາຍໃນອອກສູ່ພາຍນອກ."

#. CWJ7q
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"hd_id922204\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. gGNiw
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id59225\n"
"help.text"
msgid "<ahelp hid=\".\">For some types of axes, you can select to format an axis as text or date, or to detect the type automatically.</ahelp> For the axis type \"Date\" you can set the following options."
msgstr "<ahelp hid=\".\">ສຳລັບແກນບາງປະເພດ, ທ່ານສາມາດເລືອກຈັດຮູບແບບແກນເປັນຂໍ້ຄວາມ ຫຼື ວັນທີ, ຫຼື ໃຫ້ກວດຫາປະເພດໂດຍອັດຕະໂນມັດ.</ahelp> ສຳລັບແກນປະເພດ \"ວັນທີ\", ທ່ານສາມາດຕັ້ງຄ່າຕົວເລືອກຕໍ່ໄປນີ້ໄດ້."

#. ZDvDA
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id1159225\n"
"help.text"
msgid "Minimum and maximum value to be shown on the ends of the scale."
msgstr "ຄ່າຕ່ຳສຸດ ແລະ ສູງສຸດທີ່ຈະສະແດງຢູ່ປາຍຂອງຂະໜາດ."

#. q8gcL
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id2259225\n"
"help.text"
msgid "<ahelp hid=\".\">Resolution can be set to show days, months, or years as interval steps.</ahelp>"
msgstr "<ahelp hid=\".\">ສາມາດຕັ້ງຄ່າຄວາມລະອຽດໃຫ້ສະແດງເປັນ ວັນ, ເດືອນ, ຫຼື ປີ ເປັນຂັ້ນໄລຍະຫ່າງໄດ້.</ahelp>"

#. nHRde
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id3359225\n"
"help.text"
msgid "<ahelp hid=\".\">Major interval can be set to show a certain number of days, months, or years.</ahelp>"
msgstr "<ahelp hid=\".\">ສາມາດຕັ້ງຄ່າໄລຍະຫ່າງຫຼັກໃຫ້ສະແດງເປັນຈຳນວນ ວັນ, ເດືອນ, ຫຼື ປີ ທີ່ແນ່ນອນໄດ້.</ahelp>"

#. dzZVf
#: 05040201.xhp
msgctxt ""
"05040201.xhp\n"
"par_id4459225\n"
"help.text"
msgid "<ahelp hid=\".\">Minor interval can be set to show a certain number of days, months, or years.</ahelp>"
msgstr "<ahelp hid=\".\">ສາມາດຕັ້ງຄ່າໄລຍະຫ່າງຍ່ອຍໃຫ້ສະແດງເປັນຈຳນວນ ວັນ, ເດືອນ, ຫຼື ປີ ທີ່ແນ່ນອນໄດ້.</ahelp>"

#. qpZFF
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"tit\n"
"help.text"
msgid "Positioning"
msgstr "ການກຳນົດຕຳແໜ່ງ"

#. 8EdPg
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"bm_id3150869\n"
"help.text"
msgid "<bookmark_value>positioning; axes</bookmark_value><bookmark_value>charts;positioning axes</bookmark_value><bookmark_value>X axes;positioning</bookmark_value><bookmark_value>Y axes;positioning</bookmark_value><bookmark_value>axes;interval marks</bookmark_value>"
msgstr "<bookmark_value>ການຈັດວາງ; ແກນ</bookmark_value><bookmark_value>ແຜນພູມ;ການຈັດວາງແກນ</bookmark_value><bookmark_value>ແກນ X;ການຈັດວາງ</bookmark_value><bookmark_value>ແກນ Y;ການຈັດວາງ</bookmark_value><bookmark_value>ແກນ;ຂີດໝາຍໄລຍະຫ່າງ</bookmark_value>"

#. qxi6Y
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"hd_id3150868\n"
"help.text"
msgid "<link href=\"text/schart/01/05040202.xhp\">Positioning</link>"
msgstr "<link href=\"text/schart/01/05040202.xhp\">ການຈັດວາງ</link>"

#. sHVmL
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"par_id3154013\n"
"help.text"
msgid "Controls the positioning of the axis."
msgstr "ຄວບຄຸມການຈັດວາງຂອງແກນ."

#. mtSfT
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"hd_id1006200801024782\n"
"help.text"
msgid "Axis line"
msgstr "ເສັ້ນແກນ"

#. hSsca
#: 05040202.xhp
msgctxt ""
"05040202.xhp\n"
"par_id1006200801024970\n"
"help.text"
msgid "<ahelp hid=\".\">Select where to cross the other axis: at start, at end, at a specified value, or at a category.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກບ່ອນທີ່ຈະຕັດກັບແກນອື່ນ: ຢູ່ຈຸດເລີ່ມຕົ້ນ, ຢູ່ຈຸດສິ້ນສຸດ, ຢູ່ຄ່າທີ່ກຳນົດໄວ້, ຫຼື ຢູ່ປະເພດ.</ahelp>"

