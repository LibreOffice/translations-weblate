"tit\n"
"help.text"
msgid "Arranging, Aligning and Distributing Objects"
msgstr "ການຈັດລຽງ, ການຈັດແຖວ ແລະ ການກະຈາຍວັດຖຸ"

#. Be455
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"hd_id3149656\n"
"help.text"
msgid "<variable id=\"align_arrange\"><link href=\"text/sdraw/guide/align_arrange.xhp\">Arranging, Aligning and Distributing Objects</link></variable>"
msgstr "<variable id=\"align_arrange\"><link href=\"text/sdraw/guide/align_arrange.xhp\">ການຈັດລຽງ, ການຈັດແຖວ ແລະ ການກະຈາຍວັດຖຸ</link></variable>"

#. cXAFa
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"bm_id3125863\n"
"help.text"
msgid "<bookmark_value>arranging; objects (guide)</bookmark_value><bookmark_value>objects;aligning</bookmark_value><bookmark_value>distributing draw objects</bookmark_value><bookmark_value>aligning;draw objects</bookmark_value>"
msgstr "<bookmark_value>ການຈັດລຽງ; ວັດຖຸ (ຄູ່ມື)</bookmark_value><bookmark_value>ວັດຖຸ; ການຈັດແຖວ</bookmark_value><bookmark_value>ການກະຈາຍວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ການຈັດແຖວ; ວັດຖຸແຕ້ມ</bookmark_value>"

#. vmh3j
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"hd_id3125863\n"
"help.text"
msgid "Arranging Objects"
msgstr "ການຈັດລຽງວັດຖຸ"

#. RawJc
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3153727\n"
"help.text"
msgid "Each object that you place in your document is successively stacked on the preceding object. To re-arrange the stacking order of a selected object, proceed as follows."
msgstr "ແຕ່ລະວັດຖຸທີ່ທ່ານວາງໄວ້ໃນເອກະສານແມ່ນຈະຖືກຊ້ອນກັນຕາມລໍາດັບ. ເພື່ອຈັດລຽງລໍາດັບການຊ້ອນກັນຂອງວັດຖຸທີ່ເລືອກໃໝ່, ໃຫ້ປະຕິບັດດັ່ງນີ້."

#. 7er4p
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107D5\n"
"help.text"
msgid "Click the object whose position you want to change."
msgstr "ຄລິກໃສ່ວັດຖຸທີ່ທ່ານຕ້ອງການປ່ຽນຕຳແໜ່ງ."

#. C9vEK
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3150327\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Shape - Arrange</item> to bring up the context menu and choose one of the arrange options:"
msgstr "ເລືອກ <item type=\"menuitem\">ຮູບຊົງ - ຈັດລຽງ</item> ເພື່ອເປີດເມນູ ແລະ ເລືອກໜຶ່ງໃນຕົວເລືອກການຈັດລຽງ:"

#. CuUcp
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107E6\n"
"help.text"
msgid "<emph>Bring to Front</emph> places the object on top of all other objects"
msgstr "<emph>ນຳມາໄວ້ໜ້າສຸດ</emph> ວາງວັດຖຸໄວ້ເທິງສຸດຂອງວັດຖຸອື່ນໆທັງໝົດ"

#. BVaSC
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107EC\n"
"help.text"
msgid "<emph>Bring Forward</emph> places the object one place forward in the stack of objects"
msgstr "<emph>ນຳມາໄວ້ທາງໜ້າ</emph> ຍັບວັດຖຸຂຶ້ນມາໜຶ່ງລໍາດັບໃນຊັ້ນຂອງວັດຖຸ"

#. VwV66
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107F2\n"
"help.text"
msgid "<emph>Send Backward</emph> places the object one place back in the stack of objects"
msgstr "<emph>ສົ່ງໄປທາງຫຼັງ</emph> ຍັບວັດຖຸລົງໄປທາງຫຼັງໜຶ່ງລໍາດັບໃນຊັ້ນຂອງວັດຖຸ"

#. ssNCJ
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107F8\n"
"help.text"
msgid "<emph>Send to Back</emph> places the object behind all other objects"
msgstr "<emph>ສົ່ງໄປໄວ້ຫຼັງສຸດ</emph> ວາງວັດຖຸໄວ້ທາງຫຼັງສຸດຂອງວັດຖຸອື່ນໆທັງໝົດ"

#. C4LrR
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN107FE\n"
"help.text"
msgid "<emph>Behind Object</emph> places the object behind another object that you select"
msgstr "<emph>ໄວ້ທາງຫຼັງວັດຖຸ</emph> ວາງວັດຖຸໄວ້ທາງຫຼັງວັດຖຸອື່ນທີ່ທ່ານເລືອກ"

#. iSskT
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"hd_id3155766\n"
"help.text"
msgid "Arranging an Object Behind Another Object"
msgstr "ການຈັດວາງວັດຖຸໄວ້ທາງຫຼັງວັດຖຸອື່ນ"

#. CvgeS
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN10811\n"
"help.text"
msgid "Click the object whose position you want to change."
msgstr "ຄລິກໃສ່ວັດຖຸທີ່ທ່ານຕ້ອງການປ່ຽນຕຳແໜ່ງ."

#. B8MAR
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3154253\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Shape - Arrange</item> to open the context menu and choose <emph>Behind Object</emph>. The mouse pointer changes to a hand."
msgstr "ເລືອກ <item type=\"menuitem\">ຮູບຊົງ - ຈັດລຽງ</item> ເພື່ອເປີດເມນູ ແລະ ເລືອກ <emph>ໄວ້ທາງຫຼັງວັດຖຸ</emph>. ຕົວຊີ້ເມົາສ໌ຈະປ່ຽນເປັນຮູບມື."

#. nJDrE
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3149126\n"
"help.text"
msgid "Click the object behind which you want to place the selected object."
msgstr "ຄລິກໃສ່ວັດຖຸທີ່ທ່ານຕ້ອງການເອົາວັດຖຸທີ່ເລືອກໄປໄວ້ທາງຫຼັງ."

#. wWeF3
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"hd_id3145789\n"
"help.text"
msgid "Reversing The Stacking Order of Two Objects"
msgstr "ການກັບຄືນລໍາດັບການຊ້ອນກັນຂອງສອງວັດຖຸ"

#. CsWMA
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3154022\n"
"help.text"
msgid "Shift-click both objects to select them."
msgstr "ກົດ Shift ຄ້າງໄວ້ແລ້ວຄລິກທັງສອງວັດຖຸເພື່ອເລືອກພວກມັນ."

#. mfu4B
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3155114\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Shape - Arrange</item> to open the context menu and choose <emph>Reverse</emph>."
msgstr "ເລືອກ <item type=\"menuitem\">ຮູບຊົງ - ຈັດລຽງ</item> ເພື່ອເປີດເມນູ ແລະ ເລືອກ <emph>ກັບຄືນ</emph>."

#. D8jUy
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"hd_id3166425\n"
"help.text"
msgid "Aligning Objects"
msgstr "ການຈັດແຖວວັດຖຸ"

#. fuvKT
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3152994\n"
"help.text"
msgid "The <emph>Alignment</emph> function enables you to align objects relative to each other or relative to the page."
msgstr "ຟັງຊັນ <emph>ການຈັດແຖວ</emph> ຊ່ວຍໃຫ້ທ່ານສາມາດຈັດແຖວວັດຖຸທຽບໃສ່ກັນ ຫຼື ທຽບໃສ່ໜ້າເອກະສານ."

#. tdBWC
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108A3\n"
"help.text"
msgid "Select an object to align it to the page or select multiple objects to align them relative to each other."
msgstr "ເລືອກວັດຖຸໜຶ່ງເພື່ອຈັດແຖວມັນໃສ່ໜ້າເອກະສານ ຫຼື ເລືອກຫຼາຍວັດຖຸເພື່ອຈັດແຖວພວກມັນທຽບໃສ່ກັນ."

#. sBGnF
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108A7\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Shape - Align Objects</item> and select one of the alignment options."
msgstr "ເລືອກ <item type=\"menuitem\">ຮູບຊົງ - ຈັດແຖວວັດຖຸ</item> ແລະ ເລືອກໜຶ່ງໃນຕົວເລືອກການຈັດແຖວ."

#. ygENZ
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108AE\n"
"help.text"
msgid "Distributing Objects"
msgstr "ການກະຈາຍວັດຖຸ"

#. r48WD
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3151390\n"
"help.text"
msgid "If you select three or more objects in Draw, you can also use the <link href=\"text/shared/01/05360000.xhp\"><emph>Distribute selection</emph></link> command to distribute the vertical and horizontal spacing evenly between the objects."
msgstr "ຖ້າທ່ານເລືອກສາມວັດຖຸ ຫຼື ຫຼາຍກວ່ານັ້ນໃນ Draw, ທ່ານຍັງສາມາດໃຊ້ຄຳສັ່ງ <link href=\"text/shared/01/05360000.xhp\"><emph>ກະຈາຍສ່ວນທີ່ເລືອກ</emph></link> ເພື່ອກະຈາຍໄລຍະຫ່າງທາງຕັ້ງ ແລະ ທາງນອນໃຫ້ສະໝໍ່າສະເໝີກັນລະຫວ່າງວັດຖຸ."

#. R9tTg
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108CE\n"
"help.text"
msgid "Select three or more objects to be distributed."
msgstr "ເລືອກສາມວັດຖຸ ຫຼື ຫຼາຍກວ່ານັ້ນເພື່ອເຮັດການກະຈາຍ."

#. 92QKq
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108D2\n"
"help.text"
msgid "Choose <item type=\"menuitem\">Shape - Distribution</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ຮູບຊົງ - ການກະຈາຍ</item>."

#. faA9D
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_idN108DA\n"
"help.text"
msgid "Select the horizontal and vertical distribution option and click <emph>OK</emph>."
msgstr "ເລືອກຕົວເລືອກການກະຈາຍທາງນອນ ແລະ ທາງຕັ້ງ ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. cSeG5
#: align_arrange.xhp
msgctxt ""
"align_arrange.xhp\n"
"par_id3150535\n"
"help.text"
msgid "Selected objects are distributed evenly along the horizontal or vertical axis. The two outermost objects are used as reference points and do not move when the <emph>Distribution</emph> command is applied."
msgstr "ວັດຖຸທີ່ເລືອກຈະຖືກກະຈາຍຢ່າງສະໝໍ່າສະເໝີຕາມແກນນອນ ຫຼື ແກນຕັ້ງ. ວັດຖຸສອງອັນທີ່ຢູ່ນອກສຸດຈະຖືກໃຊ້ເປັນຈຸດອ້າງອີງ ແລະ ຈະບໍ່ເຄື່ອນທີ່ເມື່ອໃຊ້ຄຳສັ່ງ <emph>ການກະຈາຍ</emph>."

#. gpE73
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"tit\n"
"help.text"
msgid "Defining Custom Colors"
msgstr "ການກຳນົດສີກຳນົດເອງ"

#. XqCrJ
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"bm_id3149263\n"
"help.text"
msgid "<bookmark_value>colors; defining</bookmark_value>       <bookmark_value>user-defined colors</bookmark_value>       <bookmark_value>custom colors</bookmark_value>"
msgstr "<bookmark_value>ສີ; ການກຳນົດ</bookmark_value>       <bookmark_value>ສີທີ່ຜູ້ໃຊ້ກຳນົດເອງ</bookmark_value>       <bookmark_value>ສີກຳນົດເອງ</bookmark_value>"

#. JFGD3
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"hd_id3149263\n"
"help.text"
msgid "<variable id=\"color_define\"><link href=\"text/sdraw/guide/color_define.xhp\">Defining Custom Colors</link></variable>"
msgstr "<variable id=\"color_define\"><link href=\"text/sdraw/guide/color_define.xhp\">ການກຳນົດສີກຳນົດເອງ</link></variable>"

#. EWGDk
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id3154511\n"
"help.text"
msgid "Define custom colors and add them to the <emph>Custom</emph> color palette."
msgstr "ກຳນົດສີທີ່ຕ້ອງການເອງ ແລະ ເພີ່ມພວກມັນເຂົ້າໃນຈານສີ <emph>ກຳນົດເອງ</emph>."

#. PWNkJ
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"hd_id3155600\n"
"help.text"
msgid "To define a custom color"
msgstr "ວິທີການກຳນົດສີກຳນົດເອງ"

#. EzcHh
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id3150327\n"
"help.text"
msgid "Choose <emph>Format - Area</emph>, click the <emph>Area</emph> tab and press the <emph>Color</emph> button. A table of the predefined palette colors is displayed."
msgstr "ເລືອກ <emph>ຮູບແບບ - ພື້ນທີ່</emph>, ຄລິກແທັບ <emph>ພື້ນທີ່</emph> ແລະ ກົດປຸ່ມ <emph>ສີ</emph>. ຕາຕະລາງຂອງສີທີ່ມີຢູ່ແລ້ວຈະຖືກສະແດງອອກມາ."

#. 5WDjt
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id3154657\n"
"help.text"
msgid "Custom colors are saved in the <emph>Custom</emph> color palette."
msgstr "ສີກຳນົດເອງຈະຖືກບັນທຶກໄວ້ໃນຈານສີ <emph>ກຳນົດເອງ</emph>."

#. DEBQ8
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id3166425\n"
"help.text"
msgid "Click a color in the table that is similar to the one you want to define. You can select the similar color from any of the available color palettes in the <emph>Colors</emph> area on the left or the <emph>Recent colors</emph> in the list below the color table. The color appears in the <emph>New</emph> preview box to the right of the dialog."
msgstr "ຄລິກໃສ່ສີໃນຕາຕະລາງທີ່ຄ້າຍຄືກັບສີທີ່ທ່ານຕ້ອງການກຳນົດ. ທ່ານສາມາດເລືອກສີທີ່ຄ້າຍຄືກັນຈາກຈານສີທີ່ມີຢູ່ໃດໜຶ່ງໃນສ່ວນ <emph>ສີ</emph> ທາງເບື້ອງຊ້າຍ ຫຼື ຈາກ <emph>ສີທີ່ໃຊ້ຫວ່າງມໍ່ໆນີ້</emph> ໃນລາຍການລຸ່ມຕາຕະລາງສີ. ສີຈະປະກົດຂຶ້ນໃນຊ່ອງສະແດງຕົວຢ່າງ <emph>ໃໝ່</emph> ທາງເບື້ອງຂວາຂອງໜ້າຕ່າງ."

#. 3B2BX
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id41522705652544\n"
"help.text"
msgid "Click the <emph>Pick</emph> button to open the <link href=\"text/shared/optionen/01010501.xhp\">Pick a Color</link> dialog."
msgstr "ຄລິກປຸ່ມ <emph>ເລືອກ</emph> ເພື່ອເປີດໜ້າຕ່າງ <link href=\"text/shared/optionen/01010501.xhp\">ເລືອກສີ</link>."

#. 69QAE
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id4979705\n"
"help.text"
msgid "%PRODUCTNAME uses only the RGB color model for printing in color. The RGB values of the selected color are displayed below the preview boxes."
msgstr "%PRODUCTNAME ໃຊ້ພຽງແຕ່ຮູບແບບສີ RGB ສຳລັບການພິມສີ. ຄ່າ RGB ຂອງສີທີ່ເລືອກຈະຖືກສະແດງຢູ່ລຸ່ມຊ່ອງສະແດງຕົວຢ່າງ."

#. ou3sQ
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id691522706451849\n"
"help.text"
msgid "Press the <emph>Add</emph> button to add the custom color to the <emph>Custom</emph> color palette. A dialog box asking to enter a color name appears. Enter a unique name for the new color within all color names existing in the <emph>Custom</emph> color palette."
msgstr "ກົດປຸ່ມ <emph>ເພີ່ມ</emph> ເພື່ອເພີ່ມສີກຳນົດເອງເຂົ້າໃນຈານສີ <emph>ກຳນົດເອງ</emph>. ຈະມີໜ້າຕ່າງຖາມໃຫ້ປ້ອນຊື່ສີປະກົດຂຶ້ນ. ໃຫ້ປ້ອນຊື່ທີ່ບໍ່ຊ້ຳກັບຊື່ສີອື່ນທີ່ມີຢູ່ໃນຈານສີ <emph>ກຳນົດເອງ</emph>."

#. E9Gho
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id701522707038880\n"
"help.text"
msgid "To remove a color from the <emph>Custom</emph> color palette, select the <emph>Custom</emph> color palette in the <emph>Colors</emph> area, select the color to be deleted and click <emph>Delete</emph>."
msgstr "ເພື່ອລຶບສີອອກຈາກຈານສີ <emph>ກຳນົດເອງ</emph>, ໃຫ້ເລືອກຈານສີ <emph>ກຳນົດເອງ</emph> ໃນສ່ວນ <emph>ສີ</emph>, ເລືອກສີທີ່ຕ້ອງການລຶບ ແລ້ວຄລິກ <emph>ລຶບ</emph>."

#. beB2R
#: color_define.xhp
msgctxt ""
"color_define.xhp\n"
"par_id3145236\n"
"help.text"
msgid "<link href=\"text/shared/01/03170000.xhp\">Color bar</link>"
msgstr "<link href=\"text/shared/01/03170000.xhp\">ແຖບສີ</link>"

#. twEGx
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"tit\n"
"help.text"
msgid "Combining Objects and Constructing Shapes"
msgstr "ການຮ່ວມວັດຖຸ ແລະ ການສ້າງຮູບຊົງ"

#. 5vtFm
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"bm_id3156443\n"
"help.text"
msgid "<bookmark_value>combining; draw objects</bookmark_value><bookmark_value>merging; draw objects</bookmark_value><bookmark_value>connecting; draw objects</bookmark_value><bookmark_value>draw objects; combining</bookmark_value><bookmark_value>intersecting draw objects</bookmark_value><bookmark_value>polygons; intersecting/subtracting/merging</bookmark_value><bookmark_value>subtracting polygons</bookmark_value><bookmark_value>constructing shapes</bookmark_value>"
msgstr "<bookmark_value>ການຮ່ວມ; ວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ການໂຮມ; ວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ການເຊື່ອມຕໍ່; ວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ວັດຖຸແຕ້ມ; ການຮ່ວມ</bookmark_value><bookmark_value>ສ່ວນຕັດຂອງວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ຮູບຫຼາຍລ່ຽມ; ສ່ວນຕັດ/ລົບອອກ/ໂຮມ</bookmark_value><bookmark_value>ການລົບຮູບຫຼາຍລ່ຽມ</bookmark_value><bookmark_value>ການສ້າງຮູບຊົງ</bookmark_value>"

#. mXzkf
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3156443\n"
"help.text"
msgid "<variable id=\"combine_etc\"><link href=\"text/sdraw/guide/combine_etc.xhp\">Combining Objects and Constructing Shapes</link> </variable>"
msgstr "<variable id=\"combine_etc\"><link href=\"text/sdraw/guide/combine_etc.xhp\">ການຮ່ວມວັດຖຸ ແລະ ການສ້າງຮູບຊົງ</link> </variable>"

#. CgsxL
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3149020\n"
"help.text"
msgid "Combined drawing objects act as grouped objects, except that you cannot enter the group to edit the individual objects."
msgstr "ວັດຖຸແຕ້ມທີ່ຖືກຮ່ວມເຂົ້າກັນຈະເຮັດວຽກຄືກັບວັດຖຸທີ່ຈັດກຸ່ມ, ຍົກເວັ້ນແຕ່ທ່ານບໍ່ສາມາດເຂົ້າໄປໃນກຸ່ມເພື່ອແກ້ໄຂແຕ່ລະວັດຖຸແຍກກັນໄດ້."

#. UpuY6
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3154659\n"
"help.text"
msgid "You can only combine 2D objects."
msgstr "ທ່ານສາມາດຮ່ວມໄດ້ສະເພາະວັດຖຸ 2 ມິຕິ ເທົ່ານັ້ນ."

#. BSs4D
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3150344\n"
"help.text"
msgid "To combine 2D objects:"
msgstr "ວິທີການຮ່ວມວັດຖຸ 2 ມິຕິ:"

#. R5BDg
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3166428\n"
"help.text"
msgid "Select two or more 2D objects."
msgstr "ເລືອກສອງວັດຖຸ 2 ມິຕິ ຫຼື ຫຼາຍກວ່ານັ້ນ."

#. LZcTU
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3145587\n"
"help.text"
msgid "Choose <emph>Shape - Combine</emph>."
msgstr "ເລືອກ <emph>ຮູບຊົງ - ຮ່ວມ</emph>."

#. rhgSt
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3146978\n"
"help.text"
msgid "Unlike groups, a combined object takes on the properties of the lowermost object in the stacking order. You can split apart combined objects, but the original object properties are lost."
msgstr "ຕ່າງຈາກການຈັດກຸ່ມ, ວັດຖຸທີ່ຮ່ວມກັນຈະເອົາຄຸນສົມບັດຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລໍາດັບການຊ້ອນກັນ. ທ່ານສາມາດແຍກວັດຖຸທີ່ຮ່ວມກັນອອກໄດ້, ແຕ່ຄຸນສົມບັດເດີມຂອງວັດຖຸຈະເສຍໄປ."

#. hApF9
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3155088\n"
"help.text"
msgid "When you combine objects, holes appear where the objects overlap."
msgstr "ເມື່ອທ່ານຮ່ວມວັດຖຸ, ຈະເກີດມີຮູຂຶ້ນໃນບ່ອນທີ່ວັດຖຸຊ້ອນທັບກັນ."

#. GFmdU
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3156019\n"
"help.text"
msgid "<image id=\"img_id3157978\" src=\"media/helpimg/kombi1.png\" width=\"8.3646inch\" height=\"2.5inch\"><alt id=\"alt_id3157978\">Illustration for combining objects</alt></image>"
msgstr "<image id=\"img_id3157978\" src=\"media/helpimg/kombi1.png\" width=\"8.3646inch\" height=\"2.5inch\"><alt id=\"alt_id3157978\">ຮູບປະກອບການຮ່ວມວັດຖຸ</alt></image>"

#. nKm5v
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3153249\n"
"help.text"
msgid "In the illustration, the uncombined objects are on the left and the combined objects on the right."
msgstr "ໃນຮູບປະກອບ, ວັດຖຸທີ່ຍັງບໍ່ທັນຮ່ວມກັນຢູ່ເບື້ອງຊ້າຍ ແລະ ວັດຖຸທີ່ຮ່ວມກັນແລ້ວຢູ່ເບື້ອງຂວາ."

#. FFRim
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3159229\n"
"help.text"
msgid "Constructing Shapes"
msgstr "ການສ້າງຮູບຊົງ"

#. PQX6S
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150049\n"
"help.text"
msgid "You can construct shapes by applying the <link href=\"text/simpress/01/13180000.xhp\"><emph>Shapes</emph></link> <emph>- Merge, Subtract and Intersect</emph> commands to two or more drawing objects."
msgstr "ທ່ານສາມາດສ້າງຮູບຊົງໂດຍການໃຊ້ຄຳສັ່ງ <link href=\"text/simpress/01/13180000.xhp\"><emph>ຮູບຊົງ</emph></link> <emph>- ໂຮມ, ລົບອອກ ແລະ ສ່ວນຕັດ</emph> ກັບວັດຖຸແຕ້ມສອງອັນ ຫຼື ຫຼາຍກວ່ານັ້ນ."

#. ZciiC
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3147403\n"
"help.text"
msgid "Shape commands only work on 2D objects."
msgstr "ຄຳສັ່ງຮູບຊົງໃຊ້ໄດ້ສະເພາະກັບວັດຖຸ 2 ມິຕິ ເທົ່ານັ້ນ."

#. Ac4WC
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150539\n"
"help.text"
msgid "Constructed shapes take on the properties of the lowermost object in the stacking order."
msgstr "ຮູບຊົງທີ່ສ້າງຂຶ້ນຈະເອົາຄຸນສົມບັດຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລໍາດັບການຊ້ອນກັນ."

#. AxTYj
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3156402\n"
"help.text"
msgid "To construct a shape:"
msgstr "ວິທີການສ້າງຮູບຊົງ:"

#. 3oZFf
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3157874\n"
"help.text"
msgid "Select two or more 2D objects."
msgstr "ເລືອກສອງວັດຖຸ 2 ມິຕິ ຫຼື ຫຼາຍກວ່ານັ້ນ."

#. CdHwU
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150650\n"
"help.text"
msgid "Choose <emph>Shape</emph> and one of the following:"
msgstr "ເລືອກ <emph>ຮູບຊົງ</emph> ແລະ ໜຶ່ງໃນລາຍການຕໍ່ໄປນີ້:"

#. KwAnN
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3145829\n"
"help.text"
msgid "<emph>Merge</emph>"
msgstr "<emph>ໂຮມ</emph>"

#. sZzhM
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3154680\n"
"help.text"
msgid "<emph>Subtract</emph>"
msgstr "<emph>ລົບອອກ</emph>"

#. 9APE9
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3153034\n"
"help.text"
msgid "<emph>Intersect</emph>."
msgstr "<emph>ສ່ວນຕັດ</emph>."

#. bMdUM
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3145144\n"
"help.text"
msgid "Shape Commands"
msgstr "ຄຳສັ່ງຮູບຊົງ"

#. uCFAF
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3153931\n"
"help.text"
msgid "In the following illustrations, the original objects are on the left and the modified shapes on the right."
msgstr "ໃນຮູບປະກອບຕໍ່ໄປນີ້, ວັດຖຸເດີມຢູ່ເບື້ອງຊ້າຍ ແລະ ຮູບຊົງທີ່ຖືກແກ້ໄຂແລ້ວຢູ່ເບື້ອງຂວາ."

#. Zyb77
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3149950\n"
"help.text"
msgid "Shapes - Merge"
msgstr "ຮູບຊົງ - ໂຮມ"

#. 7DDCQ
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3148585\n"
"help.text"
msgid "<image id=\"img_id3145593\" src=\"media/helpimg/formvers.png\" width=\"3.4791inch\" height=\"1.3126inch\"><alt id=\"alt_id3145593\">Illustration for merging shapes</alt></image>"
msgstr "<image id=\"img_id3145593\" src=\"media/helpimg/formvers.png\" width=\"3.4791inch\" height=\"1.3126inch\"><alt id=\"alt_id3145593\">ຮູບປະກອບການໂຮມຮູບຊົງ</alt></image>"

#. eG7wD
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150001\n"
"help.text"
msgid "Adds the area of the selected objects to the area of the lowermost object in the stacking order."
msgstr "ເພີ່ມພື້ນທີ່ຂອງວັດຖຸທີ່ເລືອກເຂົ້າໃນພື້ນທີ່ຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລໍາດັບການຊ້ອນກັນ."

#. EiBAS
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3153002\n"
"help.text"
msgid "Shapes - Subtract"
msgstr "ຮູບຊົງ - ລົບອອກ"

#. DFWbE
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150338\n"
"help.text"
msgid "<image id=\"img_id3154505\" src=\"media/helpimg/formsubt.png\" width=\"3.4689inch\" height=\"1.3126inch\"><alt id=\"alt_id3154505\">Illustration for subtracting shapes</alt></image>"
msgstr "<image id=\"img_id3154505\" src=\"media/helpimg/formsubt.png\" width=\"3.4689inch\" height=\"1.3126inch\"><alt id=\"alt_id3154505\">ຮູບປະກອບການລົບຮູບຊົງ</alt></image>"

#. DAcuC
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150022\n"
"help.text"
msgid "Subtracts the area of the selected objects from the area of the lowermost object in the stacking order."
msgstr "ລົບພື້ນທີ່ຂອງວັດຖຸທີ່ເລືອກອອກຈາກພື້ນທີ່ຂອງວັດຖຸທີ່ຢູ່ລຸ່ມສຸດໃນລໍາດັບການຊ້ອນກັນ."

#. dQD4h
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"hd_id3147370\n"
"help.text"
msgid "Shapes - Intersect"
msgstr "ຮູບຊົງ - ສ່ວນຕັດ"

#. NB9tU
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3150570\n"
"help.text"
msgid "<image id=\"img_id3150658\" src=\"media/helpimg/formschn.png\" width=\"3.4272inch\" height=\"1.302inch\"><alt id=\"alt_id3150658\">Illustration for intersecting shapes</alt></image>"
msgstr "<image id=\"img_id3150658\" src=\"media/helpimg/formschn.png\" width=\"3.4272inch\" height=\"1.302inch\"><alt id=\"alt_id3150658\">ຮູບປະກອບສ່ວນຕັດຂອງຮູບຊົງ</alt></image>"

#. Zb4c7
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3157972\n"
"help.text"
msgid "The overlapping area of the selected objects creates the new shape."
msgstr "ພື້ນທີ່ທີ່ຊ້ອນທັບກັນຂອງວັດຖຸທີ່ເລືອກຈະສ້າງເປັນຮູບຊົງໃໝ່."

#. Sva6t
#: combine_etc.xhp
msgctxt ""
"combine_etc.xhp\n"
"par_id3151020\n"
"help.text"
msgid "The area outside the overlap is removed."
msgstr "ພື້ນທີ່ທີ່ຢູ່ນອກສ່ວນຊ້ອນທັບຈະຖືກລົບອອກ."

#. AEZcB
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"tit\n"
"help.text"
msgid "Cross-Fading Two Objects"
msgstr "ການໄລ່ຮູບຊົງລະຫວ່າງສອງວັດຖຸ"

#. a3jA4
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"bm_id3150715\n"
"help.text"
msgid "<bookmark_value>draw objects; cross-fading two objects</bookmark_value><bookmark_value>cross-fading; two draw objects</bookmark_value>"
msgstr "<bookmark_value>ວັດຖຸແຕ້ມ; ການໄລ່ຮູບຊົງລະຫວ່າງສອງວັດຖຸ</bookmark_value><bookmark_value>ການໄລ່ຮູບຊົງ; ສອງວັດຖຸແຕ້ມ</bookmark_value>"

#. CdpRk
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"hd_id3150715\n"
"help.text"
msgid "<variable id=\"cross_fading\"><link href=\"text/sdraw/guide/cross_fading.xhp\">Cross-Fading Two Objects</link></variable>"
msgstr "<variable id=\"cross_fading\"><link href=\"text/sdraw/guide/cross_fading.xhp\">ການໄລ່ຮູບຊົງລະຫວ່າງສອງວັດຖຸ</link></variable>"

#. kxr3E
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3154754\n"
"help.text"
msgid "Cross-fading creates shapes and distributes them by uniform increments between two drawing objects."
msgstr "ການໄລ່ຮູບຊົງຈະສ້າງຮູບຊົງ ແລະ ກະຈາຍພວກມັນຕາມລຳດັບຂັ້ນລະຫວ່າງວັດຖຸແຕ້ມສອງອັນ."

#. EHAqP
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3155112\n"
"help.text"
msgid "The cross-fading command is only available in $[officename] Draw. You can, however, copy and paste cross-faded objects into $[officename] Impress."
msgstr "ຄຳສັ່ງການໄລ່ຮູບຊົງມີໃຫ້ໃຊ້ສະເພາະໃນ $[officename] Draw. ຢ່າງໃດກໍຕາມ, ທ່ານສາມາດຄັດລອກ ແລະ ວາງວັດຖຸທີ່ໄລ່ຮູບຊົງແລ້ວລົງໃນ $[officename] Impress ໄດ້."

#. DCDGA
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"hd_id3149209\n"
"help.text"
msgid "To cross-fade two objects:"
msgstr "ວິທີການໄລ່ຮູບຊົງລະຫວ່າງສອງວັດຖຸ:"

#. svAGr
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3150370\n"
"help.text"
msgid "Hold down Shift and click each object."
msgstr "ກົດ Shift ຄ້າງໄວ້ແລ້ວຄລິກແຕ່ລະວັດຖຸ."

#. Dfyf6
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3166428\n"
"help.text"
msgid "Choose <emph>Shape - Cross-fading</emph>."
msgstr "ເລືອກ <emph>ຮູບຊົງ - ການໄລ່ຮູບຊົງ</emph>."

#. dmA2i
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3156450\n"
"help.text"
msgid "Enter a value to specify the number of objects between the start and end of the cross-fade in the <emph>Increments</emph> box."
msgstr "ປ້ອນຄ່າເພື່ອລະບຸຈຳນວນວັດຖຸລະຫວ່າງຈຸດເລີ່ມຕົ້ນ ແລະ ຈຸດສິ້ນສຸດຂອງການໄລ່ຮູບຊົງໃນຊ່ອງ <emph>ຂັ້ນຕອນ</emph>."

#. 9pKW6
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3149405\n"
"help.text"
msgid "Click <emph>OK</emph>."
msgstr "ຄລິກ <emph>ຕົກລົງ</emph>."

#. FEyjM
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3151240\n"
"help.text"
msgid "A group containing the two original objects and the specified number (increments) of cross-faded objects is displayed."
msgstr "ກຸ່ມທີ່ປະກອບດ້ວຍວັດຖຸເດີມສອງອັນ ແລະ ວັດຖຸທີ່ໄລ່ຮູບຊົງຕາມຈຳນວນທີ່ລະບຸ (ຂັ້ນຕອນ) ຈະຖືກສະແດງອອກມາ."

#. aBrFX
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3159203\n"
"help.text"
msgid "<image id=\"img_id3150210\" src=\"media/helpimg/ueberblenden.png\" width=\"74.88mm\" height=\"65.62mm\"><alt id=\"alt_id3150210\">Illustration for crossfading</alt></image>"
msgstr "<image id=\"img_id3150210\" src=\"media/helpimg/ueberblenden.png\" width=\"74.88mm\" height=\"65.62mm\"><alt id=\"alt_id3150210\">ຮູບປະກອບການໄລ່ຮູບຊົງ</alt></image>"

#. cev8y
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3154766\n"
"help.text"
msgid "You can edit the individual objects of a group by selecting the group and pressing F3. Press <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+F3 to exit the group editing mode."
msgstr "ທ່ານສາມາດແກ້ໄຂແຕ່ລະວັດຖຸໃນກຸ່ມໄດ້ໂດຍການເລືອກກຸ່ມແລ້ວກົດ F3. ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+F3 ເພື່ອອອກຈາກໂໝດແກ້ໄຂກຸ່ມ."

#. TQGju
#: cross_fading.xhp
msgctxt ""
"cross_fading.xhp\n"
"par_id3155760\n"
"help.text"
msgid "<link href=\"text/simpress/01/02150000.xhp\">Editing - Cross-fading</link>"
msgstr "<link href=\"text/simpress/01/02150000.xhp\">ການແກ້ໄຂ - ການໄລ່ຮູບຊົງ</link>"

#. uUD48
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"tit\n"
"help.text"
msgid "Drawing Sectors and Segments"
msgstr "ການແຕ້ມສ່ວນເສ້ຽວ ແລະ ສ່ວນເສັ້ນ"

#. CEEGe
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"bm_id3146974\n"
"help.text"
msgid "<bookmark_value>sectors of circles/ellipses</bookmark_value><bookmark_value>segments of circles/ellipses</bookmark_value><bookmark_value>circle segments</bookmark_value><bookmark_value>ellipses; segments</bookmark_value><bookmark_value>drawing; sectors and segments</bookmark_value>"
msgstr "<bookmark_value>ສ່ວນເສ້ຽວຂອງວົງມົນ/ວົງມົນຮີ</bookmark_value><bookmark_value>ສ່ວນເສັ້ນຂອງວົງມົນ/ວົງມົນຮີ</bookmark_value><bookmark_value>ສ່ວນເສັ້ນວົງມົນ</bookmark_value><bookmark_value>ວົງມົນຮີ; ສ່ວນເສັ້ນ</bookmark_value><bookmark_value>ການແຕ້ມ; ສ່ວນເສ້ຽວ ແລະ ສ່ວນເສັ້ນ</bookmark_value>"

#. 3q4aR
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"hd_id3146974\n"
"help.text"
msgid "<variable id=\"draw_sector\"><link href=\"text/sdraw/guide/draw_sector.xhp\">Drawing Sectors and Segments</link></variable>"
msgstr "<variable id=\"draw_sector\"><link href=\"text/sdraw/guide/draw_sector.xhp\">ການແຕ້ມສ່ວນເສ້ຽວ ແລະ ສ່ວນເສັ້ນ</link></variable>"

#. Zq2MQ
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3147396\n"
"help.text"
msgid "The <emph>Ellipse</emph> toolbar contains tools for drawing ellipses and circles. You can also draw segments and sectors of circles and ellipses."
msgstr "ແຖບເຄື່ອງມື <emph>ວົງມົນຮີ</emph> ປະກອບດ້ວຍເຄື່ອງມືສຳລັບແຕ້ມວົງມົນຮີ ແລະ ວົງມົນ. ທ່ານຍັງສາມາດແຕ້ມສ່ວນເສັ້ນ ແລະ ສ່ວນເສ້ຽວຂອງວົງມົນ ແລະ ວົງມົນຮີໄດ້ນຳ."

#. fawyC
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"hd_id3151075\n"
"help.text"
msgid "To draw a sector of a circle or an ellipse:"
msgstr "ວິທີການແຕ້ມສ່ວນເສ້ຽວຂອງວົງມົນ ຫຼື ວົງມົນຮີ:"

#. RRvtT
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3155335\n"
"help.text"
msgid "Open the <emph>Ellipses</emph> toolbar and click one of the <emph>Circle Pie</emph> or <emph>Ellipse Pie</emph> icons <image id=\"img_id3155768\" src=\"cmd/sc_circlepie_unfilled.png\" width=\"5.64mm\" height=\"5.64mm\"><alt id=\"alt_id3155768\">Icon</alt></image>. The mouse pointer changes to a cross hair with a small icon of a sector."
msgstr "ເປີດແຖບເຄື່ອງມື <emph>ວົງມົນຮີ</emph> ແລະ ຄລິກໃສ່ໄອຄອນ <emph>ວົງມົນຮູບພາຍ</emph> ຫຼື <emph>ວົງຮີຮູບພາຍ</emph> <image id=\"img_id3155768\" src=\"cmd/sc_circlepie_unfilled.png\" width=\"5.64mm\" height=\"5.64mm\"><alt id=\"alt_id3155768\">ໄອຄອນ</alt></image>. ຕົວຊີ້ເມົາສ໌ຈະປ່ຽນເປັນຮູບກາກະບາດພ້ອມກັບໄອຄອນສ່ວນເສ້ຽວນ້ອຍໆ."

#. ukJy5
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3150199\n"
"help.text"
msgid "Position the pointer at the edge of the circle you want to draw and drag to create the circle."
msgstr "ວາງຕົວຊີ້ໃສ່ຂອບຂອງວົງມົນທີ່ທ່ານຕ້ອງການແຕ້ມ ແລ້ວລາກເພື່ອສ້າງວົງມົນ."

#. uGdL9
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3148868\n"
"help.text"
msgid "To create a circle by dragging from the center, press <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline> while dragging."
msgstr "ເພື່ອສ້າງວົງມົນໂດຍການລາກອອກຈາກຈຸດສູນກາງ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Option</caseinline><defaultinline>Alt</defaultinline></switchinline> ຄ້າງໄວ້ໃນຂະນະທີ່ລາກ."

#. UUQDC
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3145361\n"
"help.text"
msgid "Release the mouse button when the circle has reached the size you want. A line corresponding to the circle radius appears in the circle."
msgstr "ປ່ອຍປຸ່ມເມົາສ໌ເມື່ອວົງມົນໄດ້ຂະໜາດທີ່ທ່ານຕ້ອງການ. ຈະມີເສັ້ນລັດສະໝີປະກົດຂຶ້ນໃນວົງມົນ."

#. rtAjM
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3149872\n"
"help.text"
msgid "Position the pointer where you want to place the first boundary of the sector and click."
msgstr "ວາງຕົວຊີ້ໃສ່ບ່ອນທີ່ທ່ານຕ້ອງການວາງຂອບທຳອິດຂອງສ່ວນເສ້ຽວ ແລ້ວຄລິກ."

#. y8EFu
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3157871\n"
"help.text"
msgid "As the radius line that follows the pointer is constrained to the circle boundaries, you can click anywhere in the document."
msgstr "ເນື່ອງຈາກເສັ້ນລັດສະໝີທີ່ເຄື່ອນທີ່ຕາມຕົວຊີ້ຈະຖືກຈຳກັດຢູ່ໃນຂອບເຂດຂອງວົງມົນ, ທ່ານສາມາດຄລິກໃສ່ບ່ອນໃດກໍໄດ້ໃນເອກະສານ."

#. qFPkT
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3146874\n"
"help.text"
msgid "Position the pointer where you want to place the second boundary of the sector and click. The completed sector is displayed."
msgstr "ວາງຕົວຊີ້ໃສ່ບ່ອນທີ່ທ່ານຕ້ອງການວາງຂອບທີສອງຂອງສ່ວນເສ້ຽວ ແລ້ວຄລິກ. ສ່ວນເສ້ຽວທີ່ສົມບູນຈະຖືກສະແດງອອກມາ."

#. QGWL2
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3148581\n"
"help.text"
msgid "To draw a segment of a circle or ellipse, follow the steps for creating a sector based on a circle."
msgstr "ເພື່ອແຕ້ມສ່ວນເສັ້ນຂອງວົງມົນ ຫຼື ວົງມົນຮີ, ໃຫ້ປະຕິບັດຕາມຂັ້ນຕອນການສ້າງສ່ວນເສ້ຽວຂອງວົງມົນ."

#. mmgkF
#: draw_sector.xhp
msgctxt ""
"draw_sector.xhp\n"
"par_id3153084\n"
"help.text"
msgid "To draw an arc based on an ellipse, choose one of the arc icons and follow the same steps for creating a sector based on a circle."
msgstr "ເພື່ອແຕ້ມເສັ້ນໂຄ້ງຈາກວົງມົນຮີ, ໃຫ້ເລືອກໜຶ່ງໃນໄອຄອນເສັ້ນໂຄ້ງ ແລະ ປະຕິບັດຕາມຂັ້ນຕອນດຽວກັນກັບການສ້າງສ່ວນເສ້ຽວຂອງວົງມົນ."

#. Frzkq
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"tit\n"
"help.text"
msgid "Duplicating Objects"
msgstr "ການເຮັດສຳເນົາວັດຖຸ"

#. EJQJE
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"bm_id3145750\n"
"help.text"
msgid "<bookmark_value>doubling draw objects</bookmark_value><bookmark_value>draw objects; duplicating</bookmark_value><bookmark_value>duplicating draw objects</bookmark_value><bookmark_value>multiplying draw objects</bookmark_value>"
msgstr "<bookmark_value>ການເຮັດໃຫ້ວັດຖຸແຕ້ມເປັນສອງເທົ່າ</bookmark_value><bookmark_value>ວັດຖຸແຕ້ມ; ການເຮັດສຳເນົາ</bookmark_value><bookmark_value>ການເຮັດສຳເນົາວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ການທະວີຄູນວັດຖຸແຕ້ມ</bookmark_value>"

#. tC9aU
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"hd_id3145750\n"
"help.text"
msgid "<variable id=\"duplicate_object\"><link href=\"text/sdraw/guide/duplicate_object.xhp\">Duplicating Objects</link></variable>"
msgstr "<variable id=\"duplicate_object\"><link href=\"text/sdraw/guide/duplicate_object.xhp\">ການເຮັດສຳເນົາວັດຖຸ</link></variable>"

#. rxVAA
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3149400\n"
"help.text"
msgid "You can create duplicate or multiple copies of an object. The copies can be identical or can differ in size, color, orientation and location."
msgstr "ທ່ານສາມາດສ້າງສຳເນົາອັນດຽວ ຫຼື ຫຼາຍອັນຂອງວັດຖຸໄດ້. ສຳເນົາເຫຼົ່ານັ້ນອາດຈະຄືກັນທຸກປະການ ຫຼື ອາດຈະແຕກຕ່າງກັນໃນເລື່ອງຂະໜາດ, ສີ, ທິດທາງ ແລະ ຕຳແໜ່ງ."

#. oJbsL
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3153415\n"
"help.text"
msgid "The following example creates a stack of coins by making multiple copies of a single ellipse."
msgstr "ຕົວຢ່າງຕໍ່ໄປນີ້ແມ່ນການສ້າງກອງຫຼຽນໂດຍການເຮັດສຳເນົາຫຼາຍອັນຈາກວົງມົນຮີອັນດຽວ."

#. xFdfE
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3149129\n"
"help.text"
msgid "Use the <emph>Ellipse</emph> tool to draw a solid yellow ellipse."
msgstr "ໃຊ້ເຄື່ອງມື <emph>ວົງມົນຮີ</emph> ເພື່ອແຕ້ມວົງມົນຮີທີ່ມີສີເຫຼືອງທຶບ."

#. EDqRb
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3149209\n"
"help.text"
msgid "Select the ellipse and choose <emph>Edit - Duplicate</emph>."
msgstr "ເລືອກວົງມົນຮີ ແລ້ວເລືອກ <emph>ແກ້ໄຂ - ສຳເນົາ</emph>."

#. SzCeR
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3145585\n"
"help.text"
msgid "Enter 12 as <emph>Number of copies.</emph>"
msgstr "ປ້ອນ 12 ໃນຊ່ອງ <emph>ຈຳນວນສຳເນົາ.</emph>"

#. GwMQB
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3151192\n"
"help.text"
msgid "Enter a negative value for the <emph>Width</emph> and <emph>Height</emph> so that the coins decrease in size as you go up the stack."
msgstr "ປ້ອນຄ່າລົບສຳລັບ <emph>ຄວາມກວ້າງ</emph> ແລະ <emph>ຄວາມສູງ</emph> ເພື່ອໃຫ້ຫຼຽນມີຂະໜາດນ້ອຍລົງເມື່ອມັນຊ້ອນກັນຂຶ້ນໄປ."

#. mKgZB
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3151387\n"
"help.text"
msgid "To define a color transition for the coins, select different colors in the <emph>Start</emph> and <emph>End</emph> boxes. The <emph>Start</emph> color is applied to the object that you are duplicating."
msgstr "ເພື່ອໃຫ້ມີການປ່ຽນສີຂອງຫຼຽນ, ໃຫ້ເລືອກສີທີ່ແຕກຕ່າງກັນໃນຊ່ອງ <emph>ເລີ່ມຕົ້ນ</emph> ແລະ <emph>ສິ້ນສຸດ</emph>. ສີ <emph>ເລີ່ມຕົ້ນ</emph> ຈະຖືກໃຊ້ກັບວັດຖຸທີ່ທ່ານກຳລັງເຮັດສຳເນົາ."

#. f4d5R
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3149947\n"
"help.text"
msgid "Click <emph>OK</emph> to create the duplicates."
msgstr "ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອສ້າງສຳເນົາ."

#. gjaqf
#: duplicate_object.xhp
msgctxt ""
"duplicate_object.xhp\n"
"par_id3153935\n"
"help.text"
msgid "<link href=\"text/simpress/01/02120000.xhp\">Edit - Duplicate</link>"
msgstr "<link href=\"text/simpress/01/02120000.xhp\">ແກ້ໄຂ - ສຳເນົາ</link>"

#. CEHEf
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"tit\n"
"help.text"
msgid "Replacing Colors"
msgstr "ການປ່ຽນແທນສີ"

#. 5vq7z
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"bm_id3147436\n"
"help.text"
msgid "<bookmark_value>eyedropper tool</bookmark_value><bookmark_value>colors; replacing</bookmark_value><bookmark_value>replacing;colors in bitmaps</bookmark_value><bookmark_value>metafiles;replacing colors</bookmark_value><bookmark_value>bitmaps;replacing colors</bookmark_value><bookmark_value>GIF images;replacing colors</bookmark_value>"
msgstr "<bookmark_value>ເຄື່ອງມືຫຼອດດູດສີ</bookmark_value><bookmark_value>ສີ; ການປ່ຽນແທນ</bookmark_value><bookmark_value>ການປ່ຽນແທນ; ສີໃນບິດແມັບ</bookmark_value><bookmark_value>ເມຕາໄຟລ໌; ການປ່ຽນແທນສີ</bookmark_value><bookmark_value>ບິດແມັບ; ການປ່ຽນແທນສີ</bookmark_value><bookmark_value>ຮູບພາບ GIF; ການປ່ຽນແທນສີ</bookmark_value>"

#. 5F3a9
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"hd_id3147436\n"
"help.text"
msgid "<variable id=\"eyedropper\"><link href=\"text/sdraw/guide/eyedropper.xhp\">Replacing Colors</link></variable>"
msgstr "<variable id=\"eyedropper\"><link href=\"text/sdraw/guide/eyedropper.xhp\">ການປ່ຽນແທນສີ</link></variable>"

#. 6nnwD
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3156286\n"
"help.text"
msgid "You can replace colors in bitmaps with the <emph>Color Replacer</emph> tool."
msgstr "ທ່ານສາມາດປ່ຽນແທນສີໃນບິດແມັບໄດ້ດ້ວຍເຄື່ອງມື <emph>ເຄື່ອງມືປ່ຽນແທນສີ</emph>."

#. ArA6H
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3154704\n"
"help.text"
msgid "Up to four colors can be replaced at once."
msgstr "ສາມາດປ່ຽນແທນໄດ້ສູງສຸດສີ່ສີໃນຄັ້ງດຽວ."

#. DmAhB
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3147344\n"
"help.text"
msgid "You can also use the <emph>Transparency</emph> option to replace the transparent areas of an image with a color."
msgstr "ທ່ານຍັງສາມາດໃຊ້ຕົວເລືອກ <emph>ຄວາມໂປ່ງໃສ</emph> ເພື່ອປ່ຽນແທນພື້ນທີ່ໂປ່ງໃສຂອງຮູບພາບດ້ວຍສີໃດໜຶ່ງ."

#. Ze6JL
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3148488\n"
"help.text"
msgid "Similarly, you can use the <emph>Color Replacer</emph> to make a color on your image transparent."
msgstr "ໃນທຳນອງດຽວກັນ, ທ່ານສາມາດໃຊ້ <emph>ເຄື່ອງມືປ່ຽນແທນສີ</emph> ເພື່ອເຮັດໃຫ້ສີໃນຮູບພາບຂອງທ່ານໂປ່ງໃສໄດ້."

#. ecY64
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"hd_id3150205\n"
"help.text"
msgid "To replace colors with the Color Replacer tool"
msgstr "ວິທີການປ່ຽນແທນສີດ້ວຍເຄື່ອງມືປ່ຽນແທນສີ"

#. vr8bG
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3154656\n"
"help.text"
msgid "Ensure that the image you are using is a bitmap (for example, BMP, GIF, JPG, or PNG) or a metafile (for example, WMF)."
msgstr "ກວດສອບໃຫ້ແນ່ໃຈວ່າຮູບພາບທີ່ທ່ານໃຊ້ແມ່ນບິດແມັບ (ເຊັ່ນ BMP, GIF, JPG, ຫຼື PNG) ຫຼື ເມຕາໄຟລ໌ (ເຊັ່ນ WMF)."

#. TAeSM
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3150202\n"
"help.text"
msgid "Choose <emph>Tools - Color Replacer</emph>."
msgstr "ເລືອກ <emph>ເຄື່ອງມື - ເຄື່ອງມືປ່ຽນແທນສີ</emph>."

#. gyRmY
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3155531\n"
"help.text"
msgid "Click the Color Replacer icon and position the mouse pointer over the color you want to replace in the image. The color appears in the box next to the icon."
msgstr "ຄລິກທີ່ໄອຄອນເຄື່ອງມືປ່ຽນແທນສີ ແລະ ວາງຕົວຊີ້ເມົາສ໌ໄວ້ເທິງສີທີ່ທ່ານຕ້ອງການປ່ຽນແທນໃນຮູບພາບ. ສີຈະປະກົດຂຶ້ນໃນຊ່ອງຂ້າງໄອຄອນ."

#. tpTWi
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3152985\n"
"help.text"
msgid "Click the color in the image. The color appears in the first <emph>Source color</emph> box and the check box next to the color is selected."
msgstr "ຄລິກໃສ່ສີໃນຮູບພາບ. ສີຈະປະກົດຂຶ້ນໃນຊ່ອງ <emph>ສີຕົ້ນສະບັບ</emph> ທຳອິດ ແລະ ຊ່ອງໝາຍຂ້າງສີຈະຖືກເລືອກ."

#. ZKeEk
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3148866\n"
"help.text"
msgid "In the <emph>Replace with</emph> box, select the new color."
msgstr "ໃນຊ່ອງ <emph>ປ່ຽນແທນດ້ວຍ</emph>, ໃຫ້ເລືອກສີໃໝ່."

#. ZZDJu
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3145362\n"
"help.text"
msgid "This replaces all occurrences of the <emph>Source color</emph> in the image."
msgstr "ການເຮັດແບບນີ້ຈະປ່ຽນແທນທຸກບ່ອນທີ່ມີ <emph>ສີຕົ້ນສະບັບ</emph> ໃນຮູບພາບ."

#. JM5GC
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3151191\n"
"help.text"
msgid "If you want to replace another color while the dialog is open, select the check box in front of <emph>Source color</emph> in the next row and repeat steps 3 to 5."
msgstr "ຖ້າທ່ານຕ້ອງການປ່ຽນແທນສີອື່ນໃນຂະນະທີ່ໜ້າຕ່າງຍັງເປີດຢູ່, ໃຫ້ເລືອກຊ່ອງໝາຍທາງໜ້າ <emph>ສີຕົ້ນສະບັບ</emph> ໃນແຖວຖັດໄປ ແລະ ເຮັດຄືນຂັ້ນຕອນທີ 3 ຫາ 5."

#. um4MR
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3149876\n"
"help.text"
msgid "Click <emph>Replace</emph>."
msgstr "ຄລິກ <emph>ປ່ຽນແທນ</emph>."

#. FEATG
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3157871\n"
"help.text"
msgid "If you want to expand or contract the color selection area, increase or decrease the tolerance of the <emph>Color Replacer</emph> tool and repeat your selection."
msgstr "ຖ້າທ່ານຕ້ອງການຂະຫຍາຍ ຫຼື ຫຼຸດພື້ນທີ່ການເລືອກສີ, ໃຫ້ເພີ່ມ ຫຼື ຫຼຸດຄ່າຄວາມຄາດເຄື່ອນ (tolerance) ຂອງ <emph>ເຄື່ອງມືປ່ຽນແທນສີ</emph> ແລ້ວເຮັດການເລືອກໃໝ່."

#. kVa8o
#: eyedropper.xhp
msgctxt ""
"eyedropper.xhp\n"
"par_id3146878\n"
"help.text"
msgid "<link href=\"text/shared/01/06030000.xhp\">Color Replacer</link>"
msgstr "<link href=\"text/shared/01/06030000.xhp\">ເຄື່ອງມືປ່ຽນແທນສີ</link>"

#. eY2vA
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"tit\n"
"help.text"
msgid "Creating Gradient Fills"
msgstr "ການສ້າງການເຕີມສີໄລ່ລະດັບ"

#. T4kWB
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"bm_id3150792\n"
"help.text"
msgid "<bookmark_value>gradients; applying and defining</bookmark_value><bookmark_value>editing;gradients</bookmark_value><bookmark_value>defining;gradients</bookmark_value><bookmark_value>custom gradients</bookmark_value><bookmark_value>transparency;adjusting</bookmark_value>"
msgstr "<bookmark_value>ການໄລ່ສີ; ການໃຊ້ ແລະ ການກຳນົດ</bookmark_value><bookmark_value>ການແກ້ໄຂ; ການໄລ່ສີ</bookmark_value><bookmark_value>ການກຳນົດ; ການໄລ່ສີ</bookmark_value><bookmark_value>ການໄລ່ສີກຳນົດເອງ</bookmark_value><bookmark_value>ຄວາມໂປ່ງໃສ; ການປັບແຕ່ງ</bookmark_value>"

#. 87fLQ
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3150792\n"
"help.text"
msgid "<variable id=\"gradient\"><link href=\"text/sdraw/guide/gradient.xhp\">Creating Gradient Fills</link> </variable>"
msgstr "<variable id=\"gradient\"><link href=\"text/sdraw/guide/gradient.xhp\">ການສ້າງການເຕີມສີໄລ່ລະດັບ</link> </variable>"

#. PpcyF
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3154012\n"
"help.text"
msgid "A gradient fill is an incremental blend of two different colors, or shades of the same color, that you can apply to a drawing object."
msgstr "ການເຕີມສີໄລ່ລະດັບແມ່ນການປະສົມສີລະຫວ່າງສອງສີທີ່ແຕກຕ່າງກັນ ຫຼື ສີດຽວກັນແຕ່ຄົນລະລະດັບຄວາມເຂັ້ມ, ເຊິ່ງທ່ານສາມາດນຳໃຊ້ກັບວັດຖຸແຕ້ມໄດ້."

#. dSZ6i
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3147436\n"
"help.text"
msgid "To apply a gradient:"
msgstr "ວິທີການໃຊ້ການໄລ່ສີ:"

#. KiLft
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3146974\n"
"help.text"
msgid "Select a drawing object."
msgstr "ເລືອກວັດຖຸແຕ້ມ."

#. ysaPv
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3154491\n"
"help.text"
msgid "Choose <emph>Format - Area</emph> and select <emph>Gradient</emph> as the <emph>Fill</emph> type."
msgstr "ເລືອກ <emph>ຮູບແບບ - ພື້ນທີ່</emph> ແລະ ເລືອກ <emph>ການໄລ່ສີ</emph> ເປັນປະເພດ <emph>ການເຕີມ</emph>."

#. sKFWJ
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3153415\n"
"help.text"
msgid "Select a gradient style from the list and click <emph>OK</emph>."
msgstr "ເລືອກຮູບແບບການໄລ່ສີຈາກລາຍການ ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. EHKGx
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3154702\n"
"help.text"
msgid "Creating Custom Gradients"
msgstr "ການສ້າງການໄລ່ສີກຳນົດເອງ"

#. B2vaE
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3145791\n"
"help.text"
msgid "You can define your own gradients and modify existing gradients, as well as save and load a list of gradient files."
msgstr "ທ່ານສາມາດກຳນົດການໄລ່ສີຂອງທ່ານເອງ ແລະ ແກ້ໄຂການໄລ່ສີທີ່ມີຢູ່ແລ້ວ, ລວມທັງບັນທຶກ ແລະ ເອີ້ນໃຊ້ລາຍການໄຟລ໌ການໄລ່ສີໄດ້."

#. zBYmy
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3145384\n"
"help.text"
msgid "To create a custom gradient:"
msgstr "ວິທີການສ້າງການໄລ່ສີກຳນົດເອງ:"

#. XtEuo
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3151242\n"
"help.text"
msgid "Choose <emph>Format - Area</emph> and click the <emph>Gradients</emph> tab."
msgstr "ເລືອກ <emph>ຮູບແບບ - ພື້ນທີ່</emph> ແລະ ຄລິກແທັບ <emph>ການໄລ່ສີ</emph>."

#. YvFEJ
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3150046\n"
"help.text"
msgid "Select a gradient from the list to use as the basis for your new gradient and click <emph>Add</emph>."
msgstr "ເລືອກການໄລ່ສີຈາກລາຍການເພື່ອໃຊ້ເປັນພື້ນຖານສຳລັບການໄລ່ສີໃໝ່ຂອງທ່ານ ແລ້ວຄລິກ <emph>ເພີ່ມ</emph>."

#. 7GYMG
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3145116\n"
"help.text"
msgid "Type a name for the gradient in the text box and click <emph>OK</emph>."
msgstr "ພິມຊື່ສຳລັບການໄລ່ສີໃນຊ່ອງຂໍ້ຄວາມ ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. b2ViM
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id6535843\n"
"help.text"
msgid "The name appears at the end of the gradient list and is selected for editing."
msgstr "ຊື່ຈະປະກົດຂຶ້ນຢູ່ທ້າຍລາຍການການໄລ່ສີ ແລະ ຈະຖືກເລືອກໄວ້ເພື່ອໃຫ້ແກ້ໄຂ."

#. YXqDN
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3150391\n"
"help.text"
msgid "Set the gradient properties and click <emph>Modify</emph> to save the gradient."
msgstr "ຕັ້ງຄ່າຄຸນສົມບັດການໄລ່ສີ ແລະ ຄລິກ <emph>ປັບປ່ຽນ</emph> ເພື່ອບັນທຶກການໄລ່ສີ."

#. yAcgt
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3156396\n"
"help.text"
msgid "Click <emph>OK.</emph>"
msgstr "ຄລິກ <emph>ຕົກລົງ.</emph>"

#. y7fAD
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3149947\n"
"help.text"
msgid "Using Gradients and Transparency"
msgstr "ການໃຊ້ການໄລ່ສີ ແລະ ຄວາມໂປ່ງໃສ"

#. GzsKF
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3157905\n"
"help.text"
msgid "You can adjust the properties of a gradient as well as the transparency of a drawing object with your mouse."
msgstr "ທ່ານສາມາດປັບແຕ່ງຄຸນສົມບັດຂອງການໄລ່ສີ ລວມທັງຄວາມໂປ່ງໃສຂອງວັດຖຸແຕ້ມໄດ້ດ້ວຍເມົາສ໌ຂອງທ່ານ."

#. V2GgK
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"hd_id3150653\n"
"help.text"
msgid "To adjust the gradient of a drawing object:"
msgstr "ວິທີການປັບການໄລ່ສີຂອງວັດຖຸແຕ້ມ:"

#. CKrAA
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3154844\n"
"help.text"
msgid "Select a drawing object with the gradient that you want to modify."
msgstr "ເລືອກວັດຖຸແຕ້ມທີ່ມີການໄລ່ສີທີ່ທ່ານຕ້ອງການປັບແຕ່ງ."

#. gseyv
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3145592\n"
"help.text"
msgid "Choose <emph>Format - Area</emph> and click the <emph>Gradients</emph> tab."
msgstr "ເລືອກ <emph>ຮູບແບບ - ພື້ນທີ່</emph> ແລະ ຄລິກແທັບ <emph>ການໄລ່ສີ</emph>."

#. BGDBn
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_idN107BE\n"
"help.text"
msgid "Adjust the values for the gradient to suit your needs and click <emph>OK</emph>."
msgstr "ປັບຄ່າຕ່າງໆສຳລັບການໄລ່ສີໃຫ້ກົງກັບຄວາມຕ້ອງການຂອງທ່ານ ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. VEbFT
#: gradient.xhp
msgctxt ""
"gradient.xhp\n"
"par_id3150659\n"
"help.text"
msgid "To adjust the transparency of an object, select the object, choose <emph>Format - Area</emph> and click the <emph>Transparency</emph> tab."
msgstr "ເພື່ອປັບຄວາມໂປ່ງໃສຂອງວັດຖຸ, ໃຫ້ເລືອກວັດຖຸ, ເລືອກ <emph>ຮູບແບບ - ພື້ນທີ່</emph> ແລະ ຄລິກແທັບ <emph>ຄວາມໂປ່ງໃສ</emph>."

#. KE8fj
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"tit\n"
"help.text"
msgid "Inserting Graphics"
msgstr "ການແຊກຮູບພາບ"

#. kGBzE
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"bm_id3156443\n"
"help.text"
msgid "<bookmark_value>pictures; inserting</bookmark_value><bookmark_value>images; inserting</bookmark_value><bookmark_value>files; inserting pictures</bookmark_value><bookmark_value>inserting;pictures</bookmark_value>"
msgstr "<bookmark_value>ຮູບພາບ; ການແຊກ</bookmark_value><bookmark_value>ຮູບພາບ; ການແຊກ</bookmark_value><bookmark_value>ໄຟລ໌; ການແຊກຮູບພາບ</bookmark_value><bookmark_value>ການແຊກ;ຮູບພາບ</bookmark_value>"

#. NGCwH
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"hd_id3156443\n"
"help.text"
msgid "<variable id=\"graphic_insert\"><link href=\"text/sdraw/guide/graphic_insert.xhp\">Inserting Pictures</link></variable>"
msgstr "<variable id=\"graphic_insert\"><link href=\"text/sdraw/guide/graphic_insert.xhp\">ການແຊກຮູບພາບ</link></variable>"

#. tGsxU
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"par_id3155600\n"
"help.text"
msgid "Choose <emph>Insert - Image</emph>."
msgstr "ເລືອກ <emph>ແຊກ - ຮູບພາບ</emph>."

#. PUNGQ
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"par_id3150749\n"
"help.text"
msgid "Locate the image you want to insert. Select the <emph>Link</emph> check box to insert only a link to the image. If you want to see the image before you insert it, select <emph>Preview</emph>."
msgstr "ຄົ້ນຫາຮູບພາບທີ່ທ່ານຕ້ອງການແຊກ. ເລືອກຊ່ອງໝາຍ <emph>ເຊື່ອມໂຍງ</emph> ເພື່ອແຊກພຽງແຕ່ລິ້ງໄປຫາຮູບພາບ. ຖ້າທ່ານຕ້ອງການເບິ່ງຕົວຢ່າງຮູບພາບກ່ອນແຊກ, ໃຫ້ເລືອກ <emph>ເບິ່ງຕົວຢ່າງ</emph>."

#. APuTg
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"par_id3155764\n"
"help.text"
msgid "After you insert a linked image, do not change the name of the source image or move the source image to another directory."
msgstr "ຫຼັງຈາກແຊກຮູບພາບແບບເຊື່ອມໂຍງແລ້ວ, ຫ້າມປ່ຽນຊື່ຮູບພາບຕົ້ນສະບັບ ຫຼື ຍ້າຍຮູບພາບຕົ້ນສະບັບໄປໄວ້ບ່ອນອື່ນ."

#. sGcHZ
#: graphic_insert.xhp
msgctxt ""
"graphic_insert.xhp\n"
"par_id3150044\n"
"help.text"
msgid "Click <emph>Open</emph> to insert the image."
msgstr "ຄລິກ <emph>ເປີດ</emph> ເພື່ອແຊກຮູບພາບ."

#. C9Faj
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"tit\n"
"help.text"
msgid "Grouping Objects"
msgstr "ການຈັດກຸ່ມວັດຖຸ"

#. rVAaE
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"bm_id3150793\n"
"help.text"
msgid "<bookmark_value>grouping; draw objects</bookmark_value><bookmark_value>draw objects; grouping</bookmark_value>"
msgstr "<bookmark_value>ການຈັດກຸ່ມ; ວັດຖຸແຕ້ມ</bookmark_value><bookmark_value>ວັດຖຸແຕ້ມ; ການຈັດກຸ່ມ</bookmark_value>"

#. 62Dsm
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"hd_id3150793\n"
"help.text"
msgid "<variable id=\"groups\"><link href=\"text/sdraw/guide/groups.xhp\">Grouping Objects</link></variable>"
msgstr "<variable id=\"groups\"><link href=\"text/sdraw/guide/groups.xhp\">ການຈັດກຸ່ມວັດຖຸ</link></variable>"

#. ZBEaH
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3153728\n"
"help.text"
msgid "You can combine several objects into a group so that they act as a single object. You can move and transform all objects in a group as a single unit. You can also change the properties (for example, line size, fill color) of all objects in a group as a whole or for individual objects in a group. Groups can be temporary or assigned:"
msgstr "ທ່ານສາມາດຮ່ວມວັດຖຸຫຼາຍອັນເຂົ້າເປັນກຸ່ມດຽວເພື່ອໃຫ້ພວກມັນເຮັດວຽກຄືກັບວັດຖຸດຽວ. ທ່ານສາມາດຍ້າຍ ແລະ ປັບປ່ຽນວັດຖຸທັງໝົດໃນກຸ່ມພ້ອມກັນໄດ້. ນອກຈາກນັ້ນ, ທ່ານຍັງສາມາດປ່ຽນຄຸນສົມບັດ (ເຊັ່ນ: ຂະໜາດເສັ້ນ, ສີເຕີມ) ຂອງທຸກວັດຖຸໃນກຸ່ມ ຫຼື ຂອງແຕ່ລະວັດຖຸໃນກຸ່ມໄດ້. ການຈັດກຸ່ມມີທັງແບບຊົ່ວຄາວ ແລະ ແບບຖາວອນ:"

#. WWeYC
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3147434\n"
"help.text"
msgid "Temporary - group only lasts as long as all of the combined objects are selected."
msgstr "ຊົ່ວຄາວ - ກຸ່ມຈະຄົງຢູ່ສະເພາະຕອນທີ່ວັດຖຸທັງໝົດຍັງຖືກເລືອກຢູ່."

#. CVj6T
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3154490\n"
"help.text"
msgid "Assigned - group lasts until it is ungrouped through a menu command."
msgstr "ຖາວອນ - ກຸ່ມຈະຄົງຢູ່ຈົນກວ່າຈະມີການແຍກກຸ່ມດ້ວຍຄຳສັ່ງເມນູ."

#. DmwjH
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3145252\n"
"help.text"
msgid "Groups can also be grouped in other groups. Actions applied to a group do not affect the relative position of the individual objects to each other in the group."
msgstr "ກຸ່ມສາມາດຖືກຈັດເຂົ້າເປັນກຸ່ມຊ້ອນກຸ່ມໄດ້ອີກ. ການກະທຳໃດໆກັບກຸ່ມຈະບໍ່ສົ່ງຜົນກະທົບຕໍ່ຕຳແໜ່ງຂອງວັດຖຸແຕ່ລະອັນທີ່ຢູ່ພາຍໃນກຸ່ມ."

#. m5GTv
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"hd_id3150716\n"
"help.text"
msgid "To group objects:"
msgstr "ວິທີການຈັດກຸ່ມວັດຖຸ:"

#. pdLV8
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3149018\n"
"help.text"
msgid "<image id=\"img_id3145643\" src=\"cmd/sc_formatgroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3145643\">Icon</alt></image>"
msgstr "<image id=\"img_id3145643\" src=\"cmd/sc_formatgroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3145643\">ໄອຄອນ</alt></image>"

#. 9Skiw
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3147346\n"
"help.text"
msgid "Select the objects you want to group and choose <emph>Shape - Group - Group</emph>."
msgstr "ເລືອກວັດຖຸທີ່ທ່ານຕ້ອງການຈັດກຸ່ມ ແລ້ວເລືອກ <emph>ຮູບຊົງ - ກຸ່ມ - ຈັດກຸ່ມ</emph>."

#. AYfMA
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3148485\n"
"help.text"
msgid "For example, you can group all of the objects in a company logo to move and resize the logo as a single object."
msgstr "ຕົວຢ່າງ: ທ່ານສາມາດຈັດກຸ່ມວັດຖຸທັງໝົດໃນໂລໂກ້ຂອງບໍລິສັດເພື່ອຍ້າຍ ແລະ ປ່ຽນຂະໜາດໂລໂກ້ຄືກັບວັດຖຸດຽວ."

#. kB7hM
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3147002\n"
"help.text"
msgid "After you have grouped objects, selecting any part of the group selects the entire group."
msgstr "ຫຼັງຈາກຈັດກຸ່ມວັດຖຸແລ້ວ, ການເລືອກສ່ວນໃດສ່ວນໜຶ່ງຂອງກຸ່ມຈະເປັນການເລືອກທັງກຸ່ມ."

#. CTTCD
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"hd_id3150205\n"
"help.text"
msgid "Selecting Objects in a Group"
msgstr "ການເລືອກວັດຖຸພາຍໃນກຸ່ມ"

#. bedSZ
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3150370\n"
"help.text"
msgid "<image id=\"img_id3155376\" src=\"cmd/sc_entergroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3155376\">Icon</alt></image>"
msgstr "<image id=\"img_id3155376\" src=\"cmd/sc_entergroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3155376\">ໄອຄອນ</alt></image>"

#. HrJDA
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3156450\n"
"help.text"
msgid "You can select single objects in a group by entering the group. Double-click a group to enter it and click on the object to select it. You can also add or delete objects to and from a group in this mode. The objects that are not part of the group are grayed out."
msgstr "ທ່ານສາມາດເລືອກວັດຖຸແຕ່ລະອັນພາຍໃນກຸ່ມໄດ້ໂດຍການເຂົ້າໄປໃນກຸ່ມ. ໃຫ້ດັບເບິນຄລິກທີ່ກຸ່ມເພື່ອເຂົ້າໄປ ແລະ ຄລິກທີ່ວັດຖຸເພື່ອເລືອກມັນ. ທ່ານຍັງສາມາດເພີ່ມ ຫຼື ລຶບວັດຖຸອອກຈາກກຸ່ມໃນໂໝດນີ້ໄດ້. ວັດຖຸທີ່ບໍ່ໄດ້ຢູ່ໃນກຸ່ມຈະກາຍເປັນສີເທົາ."

#. QTExY
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3151239\n"
"help.text"
msgid "<image id=\"img_id3155264\" src=\"cmd/sc_leavegroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3155264\">Icon</alt></image>"
msgstr "<image id=\"img_id3155264\" src=\"cmd/sc_leavegroup.png\" width=\"0.1665inch\" height=\"0.1665inch\"><alt id=\"alt_id3155264\">ໄອຄອນ</alt></image>"

#. ZBWCE
#: groups.xhp
msgctxt ""
"groups.xhp\n"
"par_id3150213\n"
"help.text"
msgid "To exit a group, double-click anywhere outside it."
msgstr "ເພື່ອອອກຈາກກຸ່ມ, ໃຫ້ດັບເບິນຄລິກໃສ່ບ່ອນໃດກໍໄດ້ທີ່ຢູ່ນອກກຸ່ມ."

#. FTtCf
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"tit\n"
"help.text"
msgid "Connecting Lines"
msgstr "ການເຊື່ອມຕໍ່ເສັ້ນ"

#. 7UcvY
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"bm_id3145799\n"
"help.text"
msgid "<bookmark_value>draw objects; connecting lines to</bookmark_value><bookmark_value>connecting; lines</bookmark_value><bookmark_value>lines; connecting objects</bookmark_value><bookmark_value>areas; from connected lines</bookmark_value>"
msgstr "<bookmark_value>ວັດຖຸແຕ້ມ; ການເຊື່ອມຕໍ່ເສັ້ນໃສ່</bookmark_value><bookmark_value>ການເຊື່ອມຕໍ່; ເສັ້ນ</bookmark_value><bookmark_value>ເສັ້ນ; ການເຊື່ອມຕໍ່ວັດຖຸ</bookmark_value><bookmark_value>ພື້ນທີ່; ຈາກເສັ້ນທີ່ເຊື່ອມຕໍ່</bookmark_value>"

#. 9v7a8
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"hd_id3145799\n"
"help.text"
msgid "<variable id=\"join_objects\"><link href=\"text/sdraw/guide/join_objects.xhp\">Connecting Lines</link></variable>"
msgstr "<variable id=\"join_objects\"><link href=\"text/sdraw/guide/join_objects.xhp\">ການເຊື່ອມຕໍ່ເສັ້ນ</link></variable>"

#. FUYtU
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"par_id3154512\n"
"help.text"
msgid "When you connect lines, lines are drawn between neighboring endpoints."
msgstr "ເມື່ອທ່ານເຊື່ອມຕໍ່ເສັ້ນ, ເສັ້ນຈະຖືກແຕ້ມລະຫວ່າງຈຸດປາຍທີ່ຢູ່ໃກ້ກັນ."

#. V9J7h
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"hd_id3150752\n"
"help.text"
msgid "To connect lines:"
msgstr "ວິທີການເຊື່ອມຕໍ່ເສັ້ນ:"

#. jYDcD
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"par_id3153714\n"
"help.text"
msgid "Select two or more lines."
msgstr "ເລືອກສອງເສັ້ນ ຫຼື ຫຼາຍກວ່ານັ້ນ."

#. UAfTT
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"par_id3156383\n"
"help.text"
msgid "Right-click and choose <emph>Shape - Connect</emph>."
msgstr "ຄລິກຂວາ ແລ້ວເລືອກ <emph>ຮູບຊົງ - ເຊື່ອມຕໍ່</emph>."

#. 8E32A
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"par_id3149257\n"
"help.text"
msgid "To create a closed object, right-click a line and choose <emph>Close Object</emph>."
msgstr "ເພື່ອສ້າງວັດຖຸແບບປິດ, ໃຫ້ຄລິກຂວາທີ່ເສັ້ນ ແລ້ວເລືອກ <emph>ປິດວັດຖຸ</emph>."

#. ZfCk8
#: join_objects.xhp
msgctxt ""
"join_objects.xhp\n"
"par_id3150363\n"
"help.text"
msgid "You can only use the <emph>Close Object</emph> command on connected lines, <emph>Freeform Lines </emph>and unfilled <emph>Curves</emph>."
msgstr "ທ່ານສາມາດໃຊ້ຄຳສັ່ງ <emph>ປິດວັດຖຸ</emph> ໄດ້ສະເພາະກັບເສັ້ນທີ່ເຊື່ອມຕໍ່ກັນ, <emph>ເສັ້ນແບບອິດສະຫຼະ</emph> ແລະ <emph>ເສັ້ນໂຄ້ງ</emph> ທີ່ບໍ່ມີການເຕີມສີ."

#. tsRYv
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"tit\n"
"help.text"
msgid "Assembling 3D Objects"
msgstr "ການປະກອບວັດຖຸ 3 ມິຕິ"

#. zKevj
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"bm_id3154014\n"
"help.text"
msgid "<bookmark_value>3D objects; assembling</bookmark_value><bookmark_value>assembled objects in 3D</bookmark_value><bookmark_value>combining;3D objects</bookmark_value><bookmark_value>joining;3D objects</bookmark_value>"
msgstr "<bookmark_value>ວັດຖຸ 3 ມິຕິ; ການປະກອບ</bookmark_value><bookmark_value>ວັດຖຸທີ່ປະກອບແລ້ວໃນ 3 ມິຕິ</bookmark_value><bookmark_value>ການຮ່ວມ; ວັດຖຸ 3 ມິຕິ</bookmark_value><bookmark_value>ການຕໍ່; ວັດຖຸ 3 ມິຕິ</bookmark_value>"

#. KA2cc
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"hd_id3156442\n"
"help.text"
msgid "<variable id=\"join_objects3d\"><link href=\"text/sdraw/guide/join_objects3d.xhp\">Assembling 3D Objects</link></variable>"
msgstr "<variable id=\"join_objects3d\"><link href=\"text/sdraw/guide/join_objects3d.xhp\">ການປະກອບວັດຖຸ 3 ມິຕິ</link></variable>"

#. spQiu
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3145251\n"
"help.text"
msgid "3D objects that each form a 3D scene can be combined into a single 3D scene."
msgstr "ວັດຖຸ 3 ມິຕິທີ່ແຕ່ລະອັນສ້າງເປັນສາກ 3 ມິຕິ ສາມາດຮ່ວມກັນເຂົ້າເປັນສາກ 3 ມິຕິດຽວໄດ້."

#. Cn8Mu
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"hd_id3150042\n"
"help.text"
msgid "To combine 3D objects:"
msgstr "ວິທີການຮ່ວມວັດຖຸ 3 ມິຕິ:"

#. aicit
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3154702\n"
"help.text"
msgid "Insert a 3D object from the <emph>3D Objects</emph> toolbar (for example, a cube)."
msgstr "ແຊກວັດຖຸ 3 ມິຕິຈາກແຖບເຄື່ອງມື <emph>ວັດຖຸ 3 ມິຕິ</emph> (ຕົວຢ່າງ: ຮູບກ້ອນສາກ)."

#. JcNRn
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3155335\n"
"help.text"
msgid "Insert a second slightly larger 3D object (for example, a sphere)."
msgstr "ແຊກວັດຖຸ 3 ມິຕິທີສອງທີ່ມີຂະໜາດໃຫຍ່ກວ່າໜ້ອຍໜຶ່ງ (ຕົວຢ່າງ: ຮູບຊົງມົນ)."

#. nKo5g
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3148488\n"
"help.text"
msgid "Select the second 3D object (sphere) and choose <emph>Edit - Cut</emph>."
msgstr "ເລືອກວັດຖຸ 3 ມິຕິທີສອງ (ຮູບຊົງມົນ) ແລ້ວເລືອກ <emph>ແກ້ໄຂ - ຕັດ</emph>."

#. TUtH4
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3149211\n"
"help.text"
msgid "Double-click the first object (cube) to enter its group."
msgstr "ດັບເບິນຄລິກທີ່ວັດຖຸທຳອິດ (ຮູບກ້ອນສາກ) ເພື່ອເຂົ້າໄປໃນກຸ່ມຂອງມັນ."

#. hEAys
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3154652\n"
"help.text"
msgid "Choose <emph>Edit - Paste</emph>. Both objects are now part of the same group. If you want, you can edit the individual objects or change their position within the group."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ວາງ</emph>. ຕອນນີ້ວັດຖຸທັງສອງຈະເປັນສ່ວນໜຶ່ງຂອງກຸ່ມດຽວກັນ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດແກ້ໄຂແຕ່ລະວັດຖຸ ຫຼື ປ່ຽນຕຳແໜ່ງຂອງພວກມັນພາຍໃນກຸ່ມໄດ້."

#. AbqoS
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3155376\n"
"help.text"
msgid "Double-click outside the group to exit the group."
msgstr "ດັບເບິນຄລິກໃສ່ທາງນອກກຸ່ມເພື່ອອອກຈາກກຸ່ມ."

#. taiS2
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3148606\n"
"help.text"
msgid "You cannot intersect or subtract 3D objects."
msgstr "ທ່ານບໍ່ສາມາດເຮັດສ່ວນຕັດ ຫຼື ລົບວັດຖຸ 3 ມິຕິໄດ້."

#. HRRBq
#: join_objects3d.xhp
msgctxt ""
"join_objects3d.xhp\n"
"par_id3154537\n"
"help.text"
msgid "<link href=\"text/simpress/02/10090000.xhp\">Objects in 3D</link>"
msgstr "<link href=\"text/simpress/02/10090000.xhp\">ວັດຖຸໃນ 3 ມິຕິ</link>"

#. F8CG3
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"tit\n"
"help.text"
msgid "Shortcut Keys for Drawing Objects"
msgstr "ປຸ່ມລັດສຳລັບວັດຖຸແຕ້ມ"

#. WaKgD
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"bm_id3155628\n"
"help.text"
msgid "<bookmark_value>accessibility; %PRODUCTNAME Draw</bookmark_value><bookmark_value>draw objects; text entry mode</bookmark_value><bookmark_value>text entry mode for draw objects</bookmark_value>"
msgstr "<bookmark_value>ການເຂົ້າເຖິງ; %PRODUCTNAME Draw</bookmark_value><bookmark_value>ວັດຖຸແຕ້ມ; ໂໝດປ້ອນຂໍ້ຄວາມ</bookmark_value><bookmark_value>ໂໝດປ້ອນຂໍ້ຄວາມສຳລັບວັດຖຸແຕ້ມ</bookmark_value>"

#. UtEww
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"hd_id3155628\n"
"help.text"
msgid "<variable id=\"keyboard\"><link href=\"text/sdraw/guide/keyboard.xhp\">Shortcut Keys for Drawing Objects</link></variable>"
msgstr "<variable id=\"keyboard\"><link href=\"text/sdraw/guide/keyboard.xhp\">ປຸ່ມລັດສຳລັບວັດຖຸແຕ້ມ</link></variable>"

#. A6rs7
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3148663\n"
"help.text"
msgid "You can create and edit drawing objects using the keyboard."
msgstr "ທ່ານສາມາດສ້າງ ແລະ ແກ້ໄຂວັດຖຸແຕ້ມໄດ້ໂດຍການໃຊ້ຄີບອດ."

#. YVvQs
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"hd_id3125863\n"
"help.text"
msgid "To Create and Edit a Drawing Object"
msgstr "ວິທີການສ້າງ ແລະ ແກ້ໄຂວັດຖຸແຕ້ມ"

#. iCmHN
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3153188\n"
"help.text"
msgid "Press <item type=\"keycode\">F6</item> to navigate to the <emph>Drawing</emph> bar."
msgstr "ກົດ <item type=\"keycode\">F6</item> ເພື່ອໄປທີ່ແຖບ <emph>ການແຕ້ມ</emph>."

#. 8Jf2p
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3146971\n"
"help.text"
msgid "Press the <item type=\"keycode\">Right</item> arrow key until you reach the toolbar icon of a drawing tool."
msgstr "ກົດປຸ່ມລູກສອນ <item type=\"keycode\">ຂວາ</item> ຈົນກວ່າຈະຮອດໄອຄອນເຄື່ອງມືແຕ້ມ."

#. FEfKD
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_idN106CD\n"
"help.text"
msgid "If there is an arrow next to the icon, the drawing tool opens a sub toolbar. Press the <item type=\"keycode\">Up</item> or <item type=\"keycode\">Down</item> arrow key to open the sub toolbar, then press the <item type=\"keycode\">Right</item> or <item type=\"keycode\">Left</item> key to select an icon."
msgstr "ຖ້າມີລູກສອນຢູ່ຂ້າງໄອຄອນ, ເຄື່ອງມືແຕ້ມຈະເປີດແຖບເຄື່ອງມືຍ່ອຍອອກມາ. ກົດປຸ່ມລູກສອນ <item type=\"keycode\">ຂຶ້ນ</item> ຫຼື <item type=\"keycode\">ລົງ</item> ເພື່ອເປີດແຖບເຄື່ອງມືຍ່ອຍ, ຈາກນັ້ນກົດປຸ່ມ <item type=\"keycode\">ຂວາ</item> ຫຼື <item type=\"keycode\">ຊ້າຍ</item> ເພື່ອເລືອກໄອຄອນ."

#. k2yNu
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3147338\n"
"help.text"
msgid "Press <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Enter</item>."
msgstr "ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Enter</item>."

#. cTDYF
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3154705\n"
"help.text"
msgid "The object is created at the center of the current document."
msgstr "ວັດຖຸຈະຖືກສ້າງຂຶ້ນຢູ່ກາງເອກະສານປັດຈຸບັນ."

#. Mnyk2
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3155962\n"
"help.text"
msgid "To return to the document, press <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+F6</item>."
msgstr "ເພື່ອເລືອກກັບມາທີ່ເອກະສານ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+F6</item>."

#. gQRPD
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"par_id3155062\n"
"help.text"
msgid "You can use the arrow keys to position the object where you want. To choose a command from the context menu for the object, press <item type=\"keycode\">Shift+F10</item>."
msgstr "ທ່ານສາມາດໃຊ້ປຸ່ມລູກສອນເພື່ອວາງຕຳແໜ່ງວັດຖຸຕາມທີ່ຕ້ອງການ. ເພື່ອເລືອກຄຳສັ່ງຈາກເມນູສຳລັບວັດຖຸ, ໃຫ້ກົດ <item type=\"keycode\">Shift+F10</item>."

#. g7CqK
#: keyboard.xhp
msgctxt ""
"keyboard.xhp\n"
"hd_id3150306\n"
"help.text"
