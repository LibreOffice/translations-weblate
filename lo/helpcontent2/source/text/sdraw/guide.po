msgstr "ການເພີ່ມກ່ອງຂໍ້ຄວາມ"

#. tkEEf
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3155266\n"
"help.text"
msgid "Click the <emph>Text</emph> icon<image id=\"img_id3156450\" src=\"cmd/sc_text.png\" width=\"0.1665in\" height=\"0.1665in\"><alt id=\"alt_id3156450\">Icon</alt></image> and move the mouse pointer to where you want to enter the text box."
msgstr "ຄລິກທີ່ໄອຄອນ <emph>ຂໍ້ຄວາມ</emph> <image id=\"img_id3156450\" src=\"cmd/sc_text.png\" width=\"0.1665in\" height=\"0.1665in\"><alt id=\"alt_id3156450\">ໄອຄອນ</alt></image> ແລະ ຍ້າຍຕົວຊີ້ເມົາສ໌ໄປບ່ອນທີ່ທ່ານຕ້ອງການສ້າງກ່ອງຂໍ້ຄວາມ."

#. dLN6f
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3149052\n"
"help.text"
msgid "Drag a text box to the size you want in your document."
msgstr "ລາກກ່ອງຂໍ້ຄວາມໃຫ້ໄດ້ຂະໜາດທີ່ທ່ານຕ້ອງການໃນເອກະສານ."

#. ACFJ7
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3151194\n"
"help.text"
msgid "Type or paste your text into the text box."
msgstr "ພິມ ຫຼື ວາງຂໍ້ຄວາມຂອງທ່ານລົງໃນກ່ອງຂໍ້ຄວາມ."

#. qLSZv
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3145118\n"
"help.text"
msgid "Double-click the text to edit it or to format text properties, such as font size or font color. Click the border of the text box to edit the object properties, such as border color or arranging in front or behind other objects."
msgstr "ດັບເບິນຄລິກທີ່ຂໍ້ຄວາມເພື່ອແກ້ໄຂ ຫຼື ຈັດຮູບແບບຄຸນສົມບັດຂໍ້ຄວາມ ເຊັ່ນ ຂະໜາດ ຫຼື ສີໂຕອັກສອນ. ຄລິກທີ່ຂອບຂອງກ່ອງຂໍ້ຄວາມເພື່ອແກ້ໄຂຄຸນສົມບັດວັດຖຸ ເຊັ່ນ ສີຂອບ ຫຼື ການຈັດລຽງໄວ້ທາງໜ້າ ຫຼື ທາງຫຼັງວັດຖຸອື່ນ."

#. CutFB
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"hd_id3150437\n"
"help.text"
msgid "Fitting Text to Frames"
msgstr "ການປັບຂໍ້ຄວາມໃຫ້ພໍດີກັບກອບ"

#. tPaD9
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3146877\n"
"help.text"
msgid "Create a text box as described in the steps above."
msgstr "ສ້າງກ່ອງຂໍ້ຄວາມຕາມຂັ້ນຕອນທີ່ອະທິບາຍໄວ້ຂ້າງເທິງ."

#. Q8BAz
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN108A3\n"
"help.text"
msgid "With the text object selected, choose <emph>Format - Text</emph>. The <emph>Text</emph> dialog opens."
msgstr "ໃນຂະນະທີ່ເລືອກວັດຖຸຂໍ້ຄວາມຢູ່, ໃຫ້ເລືອກ <emph>ຮູບແບບ - ຂໍ້ຄວາມ</emph>. ໜ້າຕ່າງ <emph>ຂໍ້ຄວາມ</emph> ຈະເປີດຂຶ້ນ."

#. D7Jw2
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN108AF\n"
"help.text"
msgid "On the <emph>Text</emph> tab page, clear the <emph>Fit height to text</emph> checkbox, then select the <emph>Fit to frame</emph> checkbox. Click <emph>OK</emph>."
msgstr "ໃນແທັບ <emph>ຂໍ້ຄວາມ</emph>, ໃຫ້ຍົກເລີກການເລືອກຊ່ອງ <emph>ປັບຄວາມສູງໃຫ້ພໍດີກັບຂໍ້ຄວາມ</emph>, ຈາກນັ້ນເລືອກຊ່ອງ <emph>ປັບໃຫ້ພໍດີກັບກອບ</emph>. ຄລິກ <emph>ຕົກລົງ</emph>."

#. j28Ed
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id0610200902133994\n"
"help.text"
msgid "Now you can resize the text box to change the size and shape of the text characters."
msgstr "ຕອນນີ້ທ່ານສາມາດປ່ຽນຂະໜາດກ່ອງຂໍ້ຄວາມເພື່ອປ່ຽນຂະໜາດ ແລະ ຮູບຊົງຂອງໂຕອັກສອນໄດ້."

#. qefTB
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"hd_id3155955\n"
"help.text"
msgid "Text Tied to a Graphic"
msgstr "ຂໍ້ຄວາມທີ່ຕິດກັບຮູບພາບ"

#. AVBRi
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10917\n"
"help.text"
msgid "You can add text to any graphic after double-clicking the graphic."
msgstr "ທ່ານສາມາດເພີ່ມຂໍ້ຄວາມໃສ່ຮູບພາບໃດໜຶ່ງໄດ້ໂດຍການດັບເບິນຄລິກທີ່ຮູບພາບນັ້ນ."

#. i9bRF
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id1827448\n"
"help.text"
msgid "To determine the position of the text, use the settings in <emph>Format - Text</emph>."
msgstr "ເພື່ອຕັ້ງຕຳແໜ່ງຂອງຂໍ້ຄວາມ, ໃຫ້ໃຊ້ການຕັ້ງຄ່າໃນ <emph>ຮູບແບບ - ຂໍ້ຄວາມ</emph>."

#. gifR8
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3147366\n"
"help.text"
msgid "For example, click the arrow next to the <emph>Callouts</emph> icon<image id=\"img_id3154508\" src=\"cmd/sc_calloutshapes.png\" width=\"0.1665in\" height=\"0.1665in\"><alt id=\"alt_id3154508\">Icon</alt></image> to open the Callouts toolbar."
msgstr "ຕົວຢ່າງ: ຄລິກທີ່ລູກສອນຂ້າງໄອຄອນ <emph>ກ່ອງຄຳອະທິບາຍ</emph> <image id=\"img_id3154508\" src=\"cmd/sc_calloutshapes.png\" width=\"0.1665in\" height=\"0.1665in\"><alt id=\"alt_id3154508\">ໄອຄອນ</alt></image> ເພື່ອເປີດແຖບເຄື່ອງມືກ່ອງຄຳອະທິບາຍ."

#. TBBEa
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN108FD\n"
"help.text"
msgid "Select a callout and move the mouse pointer to where you want the callout to start."
msgstr "ເລືອກກ່ອງຄຳອະທິບາຍ ແລະ ຍ້າຍຕົວຊີ້ເມົາສ໌ໄປບ່ອນທີ່ທ່ານຕ້ອງການໃຫ້ກ່ອງເລີ່ມຕົ້ນ."

#. yWMZf
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id3150272\n"
"help.text"
msgid "Drag to draw the callout."
msgstr "ລາກເພື່ອແຕ້ມກ່ອງຄຳອະທິບາຍ."

#. LACCd
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_id1978514\n"
"help.text"
msgid "Enter the text."
msgstr "ປ້ອນຂໍ້ຄວາມ."

#. C9fwC
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN1091A\n"
"help.text"
msgid "Copying Text"
msgstr "ການຄັດລອກຂໍ້ຄວາມ"

#. Jma6G
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10921\n"
"help.text"
msgid "Select the text in your Writer document."
msgstr "ເລືອກຂໍ້ຄວາມໃນເອກະສານ Writer ຂອງທ່ານ."

#. 9TSZh
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10925\n"
"help.text"
msgid "Copy the text to the clipboard (<emph>Edit - Copy</emph>)."
msgstr "ຄັດລອກຂໍ້ຄວາມໄປໄວ້ໃນຄລິບບອດ (<emph>ແກ້ໄຂ - ຄັດລອກ</emph>)."

#. xXHnT
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN1092D\n"
"help.text"
msgid "Click the page or slide where you want to paste the text."
msgstr "ຄລິກໃສ່ໜ້າ ຫຼື ສະໄລ້ບ່ອນທີ່ທ່ານຕ້ອງການວາງຂໍ້ຄວາມ."

#. GCpCF
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10931\n"
"help.text"
msgid "Paste the text using <emph>Edit - Paste</emph> or <emph>Edit - Paste special</emph>."
msgstr "ວາງຂໍ້ຄວາມໂດຍໃຊ້ <emph>ແກ້ໄຂ - ວາງ</emph> ຫຼື <emph>ແກ້ໄຂ - ວາງແບບພິເສດ</emph>."

#. xHxJp
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN1093C\n"
"help.text"
msgid "Using <emph>Paste special</emph>, you can choose the text format to be pasted. Depending on formats, you can copy different text attributes."
msgstr "ເມື່ອໃຊ້ <emph>ວາງແບບພິເສດ</emph>, ທ່ານສາມາດເລືອກຮູບແບບຂໍ້ຄວາມທີ່ຈະວາງໄດ້. ເຊິ່ງສາມາດຄັດລອກຄຸນລັກສະນະຂໍ້ຄວາມທີ່ແຕກຕ່າງກັນໄດ້ຕາມຮູບແບບທີ່ເລືອກ."

#. CwhNW
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN1093F\n"
"help.text"
msgid "Importing Text"
msgstr "ການນຳເຂົ້າຂໍ້ຄວາມ"

#. bCEdY
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10946\n"
"help.text"
msgid "Click the page or slide where you want to import the text."
msgstr "ຄລິກໃສ່ໜ້າ ຫຼື ສະໄລ້ບ່ອນທີ່ທ່ານຕ້ອງການນຳເຂົ້າຂໍ້ຄວາມ."

#. dRzar
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN1094A\n"
"help.text"
msgid "Choose <emph>Insert - File</emph>."
msgstr "ເລືອກ <emph>ແຊກ - ໄຟລ໌</emph>."

#. oWEEr
#: text_enter.xhp
msgctxt ""
"text_enter.xhp\n"
"par_idN10952\n"
"help.text"
msgid "Select a text file (*.txt) or an HTML file and click <emph>Insert</emph>. The <emph>Insert Text</emph> dialog opens. Click <emph>OK</emph> to insert the text."
msgstr "ເລືອກໄຟລ໌ຂໍ້ຄວາມ (*.txt) ຫຼື ໄຟລ໌ HTML ແລ້ວຄລິກ <emph>ແຊກ</emph>. ໜ້າຕ່າງ <emph>ແຊກຂໍ້ຄວາມ</emph> ຈະເປີດຂຶ້ນ. ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອແຊກຂໍ້ຄວາມ."
