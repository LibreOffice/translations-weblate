msgid "<variable id=\"defval\">Default Value</variable>"
msgstr "<variable id=\"defval\">ຄ່າເລີ່ມຕົ້ນ</variable>"

#. cV4E5
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id21682092689099\n"
"help.text"
msgid "If this property is set, it indicates the range of pages to be exported."
msgstr "ຖ້າຕັ້ງຄຸນສົມບັດນີ້, ມັນຈະລະບຸຊ່ວງຂອງໜ້າທີ່ຈະສົ່ງອອກ."

#. TtPCS
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id611682092936607\n"
"help.text"
msgid "To export all the pages, leave this property unset."
msgstr "ເພື່ອສົ່ງອອກທຸກໜ້າ, ໃຫ້ປະຄຸນສົມບັດນີ້ໄວ້ (ບໍ່ຕ້ອງຕັ້ງຄ່າ)."

#. DzQF3
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id481682092945791\n"
"help.text"
msgid "To export a selection, leave this property unset and set only the property <literal>Selection</literal>."
msgstr "ເພື່ອສົ່ງອອກສະເພາະສ່ວນທີ່ເລືອກ, ໃຫ້ຕັ້ງສະເພາະຄຸນສົມບັດ <literal>Selection</literal>."

#. 7GBX9
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id72682092689100\n"
"help.text"
msgid "Empty (all pages are exported)"
msgstr "ວ່າງ (ສົ່ງອອກທຸກໜ້າ)"

#. EP7tx
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id601682093114540\n"
"help.text"
msgid "An <emph>any</emph> corresponding to the current selection in the document."
msgstr "ຄ່າ <emph>any</emph> ທີ່ກົງກັບສ່ວນທີ່ເລືອກໃນເອກະສານ."

#. uG6Ez
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id191682094882341\n"
"help.text"
msgid "Specifies if images are exported to PDF using a lossless compression format like <emph>PNG</emph> or compressed using the <emph>JPEG</emph> format."
msgstr "ລະບຸວ່າຈະສົ່ງອອກຮູບພາບເປັນແບບບໍ່ສູນເສຍຄຸນນະພາບ (PNG) ຫຼື ແບບບີບອັດ (JPEG)."

#. LHD2T
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id821682095024852\n"
"help.text"
msgid "Specifies the quality of the JPG export. A higher value produces a higher-quality image and a larger file."
msgstr "ລະບຸຄຸນນະພາບຂອງ JPG. ຄ່າຍິ່ງສູງ ຄຸນນະພາບຍິ່ງດີ ແຕ່ໄຟລ໌ຈະໃຫຍ່ຂຶ້ນ."

#. 9XEdE
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id931682095141797\n"
"help.text"
msgid "Minimum inclusive value: 1. Represents the lowest value that can be used. The lower the value, the worse is the image quality and the smaller is the file size."
msgstr "ຄ່າຕ່ຳສຸດ: 1. ຄ່າຍິ່ງຕ່ຳ ຄຸນນະພາບຮູບຍິ່ງຫຼຸດລົງ ແລະ ໄຟລ໌ຈະນ້ອຍລົງ."

#. gmZ5r
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id791682095148125\n"
"help.text"
msgid "Maximum inclusive value: 100. Represents the highest value that can be used. The higher the value, the better is the image quality and the larger is the file size."
msgstr "ຄ່າສູງສຸດ: 100. ຄ່າຍິ່ງສູງ ຄຸນນະພາບຮູບຍິ່ງດີ ແລະ ໄຟລ໌ຈະໃຫຍ່ຂຶ້ນ."

#. zvtpL
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id281682095187331\n"
"help.text"
msgid "Specifies if the resolution of each image is reduced to the resolution specified by the property <literal>MaxImageResolution</literal>."
msgstr "ລະບຸວ່າຈະຫຼຸດຄວາມລະອຽດຂອງຮູບພາບລົງຕາມທີ່ກຳນົດໃນ <literal>MaxImageResolution</literal> ຫຼື ບໍ່."

#. QVA7F
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id201682095537396\n"
"help.text"
msgid "If the property <literal>ReduceImageResolution</literal> is set to true, all images will be reduced to the given value in DPI. Possible values are: 75, 150, 300, 600 and 1200."
msgstr "ຖ້າຕັ້ງ ReduceImageResolution ເປັນ true, ຮູບທັງໝົດຈະຖືກຫຼຸດຄວາມລະອຽດ (DPI) ຕາມຄ່າທີ່ກຳນົດ."

#. YA52W
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id701682095840341\n"
"help.text"
msgid "Specifies the PDF version to emit. Possible values are:"
msgstr "ລະບຸເວີຊັນຂອງ PDF. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. jSAc3
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id421682095915294\n"
"help.text"
msgid "0: PDF 1.7 (default choice)."
msgstr "0: PDF 1.7 (ຄ່າເລີ່ມຕົ້ນ)."

#. J6GGg
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id461682098105759\n"
"help.text"
msgid "Creates an accessible PDF file that follows the requirements of the PDF/UA (ISO 14289) specification."
msgstr "ສ້າງໄຟລ໌ PDF ທີ່ເຂົ້າເຖິງໄດ້ (Accessible PDF) ຕາມມາດຕະຖານ PDF/UA (ISO 14289)."

#. 6jnKY
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id301682096518885\n"
"help.text"
msgid "Determines if PDFs are created using special accessibility tags."
msgstr "ກຳນົດວ່າຈະສ້າງ PDF ໂດຍໃຊ້ແທັກພິເສດສຳລັບການເຂົ້າເຖິງ (Accessibility tags) ຫຼື ບໍ່."

#. sU7xg
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id511682096576792\n"
"help.text"
msgid "Specifies whether form fields are exported as widgets or only their fixed print representation is exported."
msgstr "ກຳນົດວ່າຈະສົ່ງອອກຟິວແບບຟອມເປັນວິດເຈັດ ຫຼື ສົ່ງອອກສະເພາະຮູບແບບການພິມທີ່ຄົງທີ່."

#. xWJcc
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id621682096666647\n"
"help.text"
msgid "Specifies the submit format of a PDF form. Possible values are:"
msgstr "ກຳນົດຮູບແບບການສົ່ງຂໍ້ມູນຂອງແບບຟອມ PDF. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. rvZyx
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id241682096785203\n"
"help.text"
msgid "0: Specifies that form type FDF is used."
msgstr "0: ກຳນົດໃຫ້ໃຊ້ຮູບແບບຟອມ FDF."

#. sjaDZ
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id451682096789430\n"
"help.text"
msgid "1: Specifies that form type PDF is used."
msgstr "1: ກຳນົດໃຫ້ໃຊ້ຮູບແບບຟອມ PDF."

#. SV4nK
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id431682096793624\n"
"help.text"
msgid "2: Specifies that form type HTML is used."
msgstr "2: ກຳນົດໃຫ້ໃຊ້ຮູບແບບຟອມ HTML."

#. e2vAz
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id871682096797498\n"
"help.text"
msgid "3: Specifies that form type XML is used."
msgstr "3: ກຳນົດໃຫ້ໃຊ້ຮູບແບບຟອມ XML."

#. xUePc
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id411682097005546\n"
"help.text"
msgid "Specifies whether multiple form fields exported are allowed to have the same field name."
msgstr "ກຳນົດວ່າອະນຸຍາດໃຫ້ຟິວແບບຟອມຫຼາຍອັນທີ່ສົ່ງອອກມີຊື່ຟິວດຽວກັນໄດ້ຫຼືບໍ່."

#. vQBTV
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id341682097068100\n"
"help.text"
msgid "Specifies if bookmarks are exported to PDF."
msgstr "ກຳນົດວ່າຈະສົ່ງອອກບຸກມາກໄປເປັນ PDF ຫຼືບໍ່."

#. GGvAH
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id331682129679539\n"
"help.text"
msgid "Export the placeholders fields visual markings only. The exported placeholder is ineffective."
msgstr "ສົ່ງອອກສະເພາະເຄື່ອງໝາຍທີ່ເບິ່ງເຫັນຂອງຟິວຕົວແທນເທົ່ານັ້ນ. ຕົວແທນທີ່ສົ່ງອອກຈະບໍ່ມີຜົນຫຍັງ."

#. cwShm
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id721682097116255\n"
"help.text"
msgid "Specifies if notes are exported to PDF."
msgstr "ກຳນົດວ່າຈະສົ່ງອອກບັນທຶກຊ່ວຍຈຳໄປເປັນ PDF ຫຼືບໍ່."

#. sJHAF
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id261682097156543\n"
"help.text"
msgid "Specifies if notes pages are exported to PDF. (Notes pages are available in Impress documents only)."
msgstr "ກຳນົດວ່າຈະສົ່ງອອກໜ້າບັນທຶກຊ່ວຍຈຳໄປເປັນ PDF ຫຼືບໍ່. (ໜ້າບັນທຶກຊ່ວຍຈຳມີໃຫ້ໃຊ້ສະເພາະໃນເອກະສານ Impress ເທົ່ານັ້ນ)."

#. jAPh6
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id411682098346420\n"
"help.text"
msgid "If the property <literal>ExportNotesPages</literal> is set to true, specifies if only notes pages are exported to PDF."
msgstr "ຖ້າຄຸນສົມບັດ <literal>ExportNotesPages</literal> ຖືກຕັ້ງເປັນ true, ຈະກຳນົດໃຫ້ສົ່ງອອກສະເພາະໜ້າບັນທຶກຊ່ວຍຈຳໄປເປັນ PDF."

#. GvGLs
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id1001682113531619\n"
"help.text"
msgid "Specifies if notes in margin are exported to PDF."
msgstr "ກຳນົດວ່າຈະສົ່ງອອກບັນທຶກຊ່ວຍຈຳຢູ່ຂອບເຈ້ຍໄປເປັນ PDF ຫຼືບໍ່."

#. f5Qfk
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id641682126441875\n"
"help.text"
msgid "For %PRODUCTNAME Impress, exports slides not included in slide shows."
msgstr "ສຳລັບ %PRODUCTNAME Impress, ໃຫ້ສົ່ງອອກສະໄລ້ທີ່ບໍ່ໄດ້ລວມຢູ່ໃນການສະແດງສະໄລ້."

#. s7ZTV
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id811682097206961\n"
"help.text"
msgid "Specifies that automatically inserted empty pages are suppressed. This option is active only if storing Writer documents."
msgstr "ກຳນົດໃຫ້ຍົກເລີກການແຊກໜ້າຫວ່າງໂດຍອັດຕະໂນມັດ. ຕົວເລືອກນີ້ຈະໃຊ້ໄດ້ສະເພາະຕອນບັນທຶກເອກະສານ Writer ເທົ່ານັ້ນ."

#. kBHwd
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id621682097268703\n"
"help.text"
msgid "Specifies whether to embed the 14 standard PDF fonts or not."
msgstr "ກຳນົດວ່າຈະຝັງຟອນ PDF ມາດຕະຖານທັງ 14 ຟອນ ຫຼື ບໍ່."

#. L6EfU
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id171682097328227\n"
"help.text"
msgid "Specifies that a stream is inserted to the PDF file which contains the original document for archiving purposes."
msgstr "ກຳນົດໃຫ້ແຊກສະຕຣີມ (stream) ລົງໃນໄຟລ໌ PDF ເຊິ່ງປະກອບມີເອກະສານຕົ້ນສະບັບເພື່ອຈຸດປະສົງໃນການເກັບມ້ຽນ."

#. R4f6x
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id631682097533264\n"
"help.text"
msgid "Specifies the text for a watermark to be drawn on every page of the exported PDF file."
msgstr "ກຳນົດຂໍ້ຄວາມສຳລັບລາຍນ້ຳ (watermark) ທີ່ຈະສະແດງຢູ່ໃນທຸກໆໜ້າຂອງໄຟລ໌ PDF ທີ່ສົ່ງອອກ."

#. BpGDK
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id971682122847914\n"
"help.text"
msgid "Specifies the color of the watermark text"
msgstr "ກຳນົດສີຂອງຂໍ້ຄວາມລາຍນ້ຳ"

#. erWJF
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id861682123372323\n"
"help.text"
msgid "Specifies the font height of the watermark text."
msgstr "ກຳນົດຄວາມສູງຂອງຟອນຂໍ້ຄວາມລາຍນ້ຳ."

#. xLqxD
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id931682124018260\n"
"help.text"
msgid "Specifies angle of the watermark text."
msgstr "ກຳນົດມຸມອຽງຂອງຂໍ້ຄວາມລາຍນ້ຳ."

#. aWVT6
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id461682124177026\n"
"help.text"
msgid "Specifies font name of the watermark text."
msgstr "ກຳນົດຊື່ຟອນຂອງຂໍ້ຄວາມລາຍນ້ຳ."

#. uzphD
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id421682124269900\n"
"help.text"
msgid "Specifies the tiled watermark text."
msgstr "ກຳນົດຂໍ້ຄວາມລາຍນ້ຳແບບລຽງຊ້ອນ (tiled)."

#. WGEgU
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id941682129849103\n"
"help.text"
msgid "When the option is enabled, then the reference XObject markup is used: this is a simple operation, but viewers have to support this markup to show vector images. Otherwise a fallback bitmap is shown in the viewer."
msgstr "ເມື່ອເປີດໃຊ້ຕົວເລືອກນີ້, ຈະໃຊ້ເຄື່ອງໝາຍ XObject ອ້າງອີງ: ນີ້ແມ່ນການເຮັດວຽກທີ່ງ່າຍດາຍ, ແຕ່ໂປຣແກຣມເບິ່ງ PDF ຕ້ອງຮອງຮັບເຄື່ອງໝາຍນີ້ເພື່ອສະແດງຮູບພາບເວັກເຕີ. ຖ້າບໍ່ດັ່ງນັ້ນ ຈະສະແດງເປັນຮູບພາບບິດແມັບ (bitmap) ແທນ."

#. CnAJS
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id641693492486689\n"
"help.text"
msgid "Ignores each sheet’s paper size, print ranges and shown/hidden status and puts every sheet (even hidden sheets) on exactly one page."
msgstr "ບໍ່ສົນໃຈຂະໜາດເຈ້ຍຂອງແຕ່ລະແຜ່ນ, ຊ່ວງການພິມ ແລະ ສະຖານະການສະແດງ/ເຊື່ອງ ແລະ ວາງທຸກໆແຜ່ນ (ລວມທັງແຜ່ນທີ່ເຊື່ອງໄວ້) ລົງໃນໜ້າດຽວພໍດີ."

#. CWgpi
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"hd_id651682101490073\n"
"help.text"
msgid "<variable id=\"initial_view\"><link href=\"text/shared/guide/pdf_params.xhp#initial_view\">Initial View</link></variable>"
msgstr "<variable id=\"initial_view\"><link href=\"text/shared/guide/pdf_params.xhp#initial_view\">ມຸມເບິ່ງເລີ່ມຕົ້ນ</link></variable>"

#. fTBNo
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id981682101522618\n"
"help.text"
msgid "Specifies how the PDF document should be displayed when opened. Possible values are:"
msgstr "ກຳນົດວິທີການສະແດງເອກະສານ PDF ເມື່ອເປີດຂຶ້ນ. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. SGrec
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id141682101963159\n"
"help.text"
msgid "0: Select the default viewer mode, neither outlines nor thumbnails."
msgstr "0: ເລືອກໂໝດການເບິ່ງແບບມາດຕະຖານ, ໂດຍບໍ່ມີທັງເຄົ້າຮ່າງ ຫຼື ຮູບຕົວຢ່າງ."

#. LGTNj
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id701682101968454\n"
"help.text"
msgid "1: The document is opened with outline pane opened"
msgstr "1: ເປີດເອກະສານພ້ອມກັບແຖບເຄົ້າຮ່າງ"

#. fDgWG
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id191682101972902\n"
"help.text"
msgid "2: The document is opened with thumbnail pane opened"
msgstr "2: ເປີດເອກະສານພ້ອມກັບແຖບຮູບຕົວຢ່າງ"

#. AoAbp
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id361682102130308\n"
"help.text"
msgid "Specifies the page on which a PDF document should be opened in the viewer application."
msgstr "ກຳນົດໜ້າທີ່ຈະໃຫ້ເອກະສານ PDF ເປີດຂຶ້ນໃນໂປຣແກຣມເບິ່ງ."

#. AjfVJ
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id581682102185257\n"
"help.text"
msgid "Specifies the action to be performed when the PDF document is opened. Possible values are:"
msgstr "ກຳນົດການກະທຳທີ່ຈະເຮັດເມື່ອເປີດເອກະສານ PDF. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. iXS9W
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id721682102242609\n"
"help.text"
msgid "0: Opens with default zoom magnification."
msgstr "0: ເປີດດ້ວຍອັດຕາການຂະຫຍາຍມາດຕະຖານ."

#. uAWjD
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id231682102247131\n"
"help.text"
msgid "1: Opens magnified to fit the entire page within the window."
msgstr "1: ເປີດໂດຍຂະຫຍາຍໃຫ້ພໍດີກັບໜ້າທັງໝົດພາຍໃນປ່ອງຢ້ຽມ."

#. 7GXcL
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id291682102252023\n"
"help.text"
msgid "2: Opens magnified to fit the entire page width within the window."
msgstr "2: ເປີດໂດຍຂະຫຍາຍໃຫ້ພໍດີກັບຄວາມກວ້າງຂອງໜ້າພາຍໃນປ່ອງຢ້ຽມ."

#. yMJXs
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id801682102257172\n"
"help.text"
msgid "3: Opens magnified to fit the entire width of its bounding box within the window (cuts out margins)."
msgstr "3: ເປີດໂດຍຂະຫຍາຍໃຫ້ພໍດີກັບຄວາມກວ້າງທັງໝົດຂອງຂອບເຂດເນື້ອຫາພາຍໃນປ່ອງຢ້ຽມ (ຕັດສ່ວນຂອບເຈ້ຍອອກ)."

#. aFHWi
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id681682102262481\n"
"help.text"
msgid "4: Opens with the zoom level specified in the Zoom property."
msgstr "4: ເປີດດ້ວຍລະດັບການຂະຫຍາຍທີ່ກຳນົດໄວ້ໃນຄຸນສົມບັດການຂະຫຍາຍ (Zoom)."

#. SdrKA
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id151682102284385\n"
"help.text"
msgid "Specifies the zoom level a PDF document is opened with. Only valid if <literal>Magnification</literal> is set to \"4\"."
msgstr "ກຳນົດລະດັບການຂະຫຍາຍທີ່ຈະໃຫ້ເອກະສານ PDF ເປີດຂຶ້ນ. ໃຊ້ໄດ້ສະເພາະເມື່ອ <literal>Magnification</literal> ຖືກຕັ້ງເປັນ \"4\" ເທົ່ານັ້ນ."

#. Rs82T
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id771682102357425\n"
"help.text"
msgid "Specifies the page layout to be used when the document is opened. Possible values are:"
msgstr "ກຳນົດການວາງຜັງໜ້າທີ່ຈະໃຊ້ເມື່ອເປີດເອກະສານ. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. Fj5yP
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id151682102404677\n"
"help.text"
msgid "0: Display the pages according to the reader configuration."
msgstr "0: ສະແດງໜ້າຕາມການຕັ້ງຄ່າຂອງໂປຣແກຣມອ່ານ."

#. uLGJr
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id671682102409679\n"
"help.text"
msgid "1: Display one page at a time."
msgstr "1: ສະແດງເທື່ອລະໜ້າ."

#. udbpj
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id331682102414339\n"
"help.text"
msgid "2: Display the pages in one column."
msgstr "2: ສະແດງໜ້າເປັນຖັນດຽວ."

#. VeRT9
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id921682102421537\n"
"help.text"
msgid "3: Display the pages in two columns odd pages on the right, to have the odd pages on the left the <literal>FirstPageOnLeft</literal> property should be used as well."
msgstr "3: ສະແດງໜ້າເປັນສອງຖັນ ໂດຍໃຫ້ໜ້າຄີກຢູ່ເບື້ອງຂວາ, ຖ້າຕ້ອງການໃຫ້ໜ້າຄີກຢູ່ເບື້ອງຊ້າຍ ຕ້ອງໃຊ້ຄຸນສົມບັດ <literal>FirstPageOnLeft</literal> ຄວບຄູ່ກັນ."

#. WQh3Z
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id531682102472806\n"
"help.text"
msgid "Used with the value 3 of the <literal>PageLayout</literal> property above, true if the first page (odd) should be on the left side of the screen."
msgstr "ໃຊ້ຮ່ວມກັບຄ່າ 3 ຂອງຄຸນສົມບັດ <literal>PageLayout</literal> ທາງເທິງ, ຕັ້ງເປັນ true ຖ້າຕ້ອງການໃຫ້ໜ້າທຳອິດ (ໜ້າຄີກ) ຢູ່ເບື້ອງຊ້າຍຂອງໜ້າຈໍ."

#. AhRNE
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"hd_id781682103094811\n"
"help.text"
msgid "<variable id=\"user_interface\"><link href=\"text/shared/guide/pdf_params.xhp#user_interface\">User Interface</link></variable>"
msgstr "<variable id=\"user_interface\"><link href=\"text/shared/guide/pdf_params.xhp#user_interface\">ສ່ວນຕິດຕໍ່ຜູ້ໃຊ້</link></variable>"

#. nyGzt
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id331682103608212\n"
"help.text"
msgid "Specifies that the PDF viewer window is opened showing whole initial page when the document is opened."
msgstr "ກຳນົດໃຫ້ປ່ອງຢ້ຽມເບິ່ງ PDF ເປີດຂຶ້ນໂດຍສະແດງໃຫ້ເຫັນໜ້າທຳອິດທັງໝົດເມື່ອເປີດເອກະສານ."

#. rRaEB
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id541682103675581\n"
"help.text"
msgid "Specifies that the PDF viewer window is centered to the screen when the PDF document is opened."
msgstr "ກຳນົດໃຫ້ປ່ອງຢ້ຽມເບິ່ງ PDF ຢູ່ກາງໜ້າຈໍເມື່ອເປີດເອກະສານ PDF."

#. eVWiN
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id751682103728428\n"
"help.text"
msgid "Specifies that the PDF viewer window is opened full screen, on top of all windows."
msgstr "ກຳນົດໃຫ້ປ່ອງຢ້ຽມເບິ່ງ PDF ເປີດຂຶ້ນແບບເຕັມໜ້າຈໍ ແລະ ຢູ່ເທິງສຸດຂອງທຸກໆປ່ອງຢ້ຽມ."

#. iBGa3
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id51682103770744\n"
"help.text"
msgid "Specifies that the title of the document, if present in the document properties, is displayed in the PDF viewer window title bar."
msgstr "ກຳນົດໃຫ້ສະແດງຊື່ເລື່ອງຂອງເອກະສານ (ຖ້າມີຢູ່ໃນຄຸນສົມບັດເອກະສານ) ຢູ່ແຖບຊື່ຂອງປ່ອງຢ້ຽມເບິ່ງ PDF."

#. YQa5f
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id101682103823403\n"
"help.text"
msgid "Specifies whether to hide the PDF viewer menubar when the document is active."
msgstr "ກຳນົດວ່າຈະເຊື່ອງແຖບເມນູຂອງໂປຣແກຣມເບິ່ງ PDF ຫຼືບໍ່ ໃນຂະນະທີ່ເອກະສານກຳລັງເຮັດວຽກຢູ່."

#. JkbDc
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id841682103876917\n"
"help.text"
msgid "Specifies whether to hide the PDF viewer toolbar when the document is active."
msgstr "ກຳນົດວ່າຈະເຊື່ອງແຖບເຄື່ອງມືຂອງໂປຣແກຣມເບິ່ງ PDF ຫຼືບໍ່ ໃນຂະນະທີ່ເອກະສານກຳລັງເຮັດວຽກຢູ່."

#. CtDon
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id491682103930314\n"
"help.text"
msgid "Specifies whether to hide the PDF viewer controls when the document is active."
msgstr "ກຳນົດວ່າຈະເຊື່ອງປຸ່ມຄວບຄຸມຂອງໂປຣແກຣມເບິ່ງ PDF ຫຼືບໍ່ ໃນຂະນະທີ່ເອກະສານກຳລັງເຮັດວຽກຢູ່."

#. 8NGRD
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id741682103984522\n"
"help.text"
msgid "Specifies slide transitions are exported to PDF. This option is active only if storing Impress documents."
msgstr "ກຳນົດໃຫ້ສົ່ງອອກຜົນກະທົບການປ່ຽນສະໄລ້ (slide transitions) ໄປເປັນ PDF. ຕົວເລືອກນີ້ໃຊ້ໄດ້ສະເພາະຕອນບັນທຶກເອກະສານ Impress ເທົ່ານັ້ນ."

#. HjEG9
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id731682104068266\n"
"help.text"
msgid "Specifies how many bookmark levels should be opened in the reader application when the PDF gets opened. Possible values are:"
msgstr "ກຳນົດວ່າຈະໃຫ້ເປີດບຸກມາກຈັກລະດັບໃນໂປຣແກຣມອ່ານເມື່ອເປີດ PDF. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. MugGi
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id131682104132952\n"
"help.text"
msgid "-1: all bookmark levels are opened"
msgstr "-1: ເປີດບຸກມາກທຸກລະດັບ"

#. QD5o2
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id441682104137875\n"
"help.text"
msgid "1–10: indicate a bookmark level (from 1 to 10)"
msgstr "1–10: ລະບຸລະດັບຂອງບຸກມາກ (ແຕ່ 1 ຫາ 10)"

#. 9Vni2
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"hd_id981682103099003\n"
"help.text"
msgid "<variable id=\"links\"><link href=\"text/shared/guide/pdf_params.xhp#links\">Links</link></variable>"
msgstr "<variable id=\"links\"><link href=\"text/shared/guide/pdf_params.xhp#links\">ການເຊື່ອມໂຍງ</link></variable>"

#. PLqRL
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id641682104332819\n"
"help.text"
msgid "Specifies that the bookmarks contained in the source %PRODUCTNAME file should be exported to the PDF file as Named Destination."
msgstr "ກຳນົດໃຫ້ສົ່ງອອກບຸກມາກທີ່ມີຢູ່ໃນໄຟລ໌ %PRODUCTNAME ຕົ້ນທາງ ໄປເປັນບ່ອນໝາຍປາຍທາງທີ່ມີຊື່ (Named Destination) ໃນໄຟລ໌ PDF."

#. 3WvUa
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id331682104419169\n"
"help.text"
msgid "Specifies that the target documents with .od[tpgs] extension, will have that extension changed to .pdf when the link is exported to PDF. The source document remains untouched."
msgstr "ກຳນົດໃຫ້ເອກະສານປາຍທາງທີ່ມີນາມສະກຸນ .od[tpgs] ປ່ຽນນາມສະກຸນເປັນ .pdf ເມື່ອມີການສົ່ງອອກລິ້ງໄປເປັນ PDF. ສ່ວນເອກະສານຕົ້ນທາງຈະບໍ່ມີການປ່ຽນແປງ."

#. gBKQg
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id911682104484869\n"
"help.text"
msgid "Specifies that the file system related hyperlinks (file:// protocol) present in the document will be exported as relative to the source document location."
msgstr "ກຳນົດໃຫ້ໄຮເປີລິ້ງທີ່ກ່ຽວຂ້ອງກັບລະບົບໄຟລ໌ (ໂປຣໂຕຄໍ file://) ທີ່ມີຢູ່ໃນເອກະສານ ຖືກສົ່ງອອກໂດຍອ້າງອີງຕາມຕຳແໜ່ງຂອງເອກະສານຕົ້ນທາງ."

#. z96J8
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id991682104540032\n"
"help.text"
msgid "Specifies the way the exported PDF will be viewed (experienced) by the user. Possible values are:"
msgstr "ກຳນົດວິທີການເບິ່ງ PDF ທີ່ສົ່ງອອກຂອງຜູ້ໃຊ້. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. jBFzq
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id681682104589018\n"
"help.text"
msgid "0: Specifies that the PDF will be exported with all the links external to the document treated as URI. This is the Default"
msgstr "0: ກຳນົດໃຫ້ສົ່ງອອກ PDF ໂດຍໃຫ້ລິ້ງພາຍນອກທັງໝົດຖືກຈັດການເປັນ URI. ນີ້ແມ່ນຄ່າມາດຕະຖານ."

#. 6GKvK
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id341682104594990\n"
"help.text"
msgid "1: Specifies that the PDF will be exported in order to be viewed through a PDF reader application only. Valid only if not exporting to PDF/A-1 (e.g. SelectPdfVersion not set to 1)."
msgstr "1: ກຳນົດໃຫ້ສົ່ງອອກ PDF ເພື່ອເບິ່ງຜ່ານໂປຣແກຣມອ່ານ PDF ເທົ່ານັ້ນ. ໃຊ້ໄດ້ສະເພາະເມື່ອບໍ່ໄດ້ສົ່ງອອກເປັນ PDF/A-1 (ຕົວຢ່າງ: ບໍ່ໄດ້ຕັ້ງ SelectPdfVersion ເປັນ 1)."

#. ECcRs
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id161682104601779\n"
"help.text"
msgid "2: Specifies that the PDF will be exported in order to be viewed through an Internet browser, using the PDF plug-in provided with it. The bookmark of the URI will be rendered compatible with the target bookmark generated with %PRODUCTNAME PDF Export feature (see <literal>ExportBookmarksToPDFDestination</literal>)."
msgstr "2: ກຳນົດໃຫ້ສົ່ງອອກ PDF ເພື່ອເບິ່ງຜ່ານບຣາວເຊີອິນເຕີເນັດ ໂດຍໃຊ້ປລັກອິນ PDF ທີ່ມາກັບບຣາວເຊີ. ບຸກມາກຂອງ URI ຈະຖືກສະແດງໃຫ້ຮອງຮັບກັບບຸກມາກປາຍທາງທີ່ສ້າງຂຶ້ນດ້ວຍຟີເຈີການສົ່ງອອກ PDF ຂອງ %PRODUCTNAME (ເບິ່ງ <literal>ExportBookmarksToPDFDestination</literal>)."

#. aoGHJ
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id11768251601081\n"
"help.text"
msgid "3: Specifies that the document will be exported to PDF without including external links."
msgstr "3: ກຳນົດໃຫ້ສົ່ງອອກເອກະສານເປັນ PDF ໂດຍບໍ່ລວມເອົາລິ້ງພາຍນອກ."

#. kxDNY
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"hd_id431682103103402\n"
"help.text"
msgid "<variable id=\"security\"><link href=\"text/shared/guide/pdf_params.xhp#security\">Security</link></variable>"
msgstr "<variable id=\"security\"><link href=\"text/shared/guide/pdf_params.xhp#security\">ຄວາມປອດໄພ</link></variable>"

#. QrCmH
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id561682110042451\n"
"help.text"
msgid "If true, selects to encrypt the PDF document with a password. The PDF file can be opened only when the user enters the correct password."
msgstr "ຖ້າເປັນ true, ຈະເລືອກເຂົ້າລະຫັດເອກະສານ PDF ດ້ວຍລະຫັດຜ່ານ. ໄຟລ໌ PDF ຈະເປີດໄດ້ກໍຕໍ່ເມື່ອຜູ້ໃຊ້ປ້ອນລະຫັດຜ່ານທີ່ຖືກຕ້ອງເທົ່ານັ້ນ."

#. AviDp
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id481682110120040\n"
"help.text"
msgid "This is the password that allows the user to open the PDF file when <literal>EncryptFile</literal> is set to true."
msgstr "ນີ້ແມ່ນລະຫັດຜ່ານທີ່ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ເປີດໄຟລ໌ PDF ເມື່ອ <literal>EncryptFile</literal> ຖືກຕັ້ງເປັນ true."

#. hEmrg
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id421682110204356\n"
"help.text"
msgid "If true, selects to restrict some permissions. The permissions can be changed only when the user enters the correct password."
msgstr "ຖ້າເປັນ true, ຈະເລືອກຈຳກັດການອະນຸຍາດບາງຢ່າງ. ການອະນຸຍາດສາມາດປ່ຽນແປງໄດ້ກໍຕໍ່ເມື່ອຜູ້ໃຊ້ປ້ອນລະຫັດຜ່ານທີ່ຖືກຕ້ອງເທົ່ານັ້ນ."

#. AYGFc
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id461682110251806\n"
"help.text"
msgid "This is the password that allows the user to access some permissions restricted if <literal>RestrictPermissions</literal> is set to true."
msgstr "ນີ້ແມ່ນລະຫັດຜ່ານທີ່ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ເຂົ້າເຖິງການອະນຸຍາດບາງຢ່າງທີ່ຖືກຈຳກັດໄວ້ ຖ້າ <literal>RestrictPermissions</literal> ຖືກຕັ້ງເປັນ true."

#. rnFXH
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id331682110333150\n"
"help.text"
msgid "Specifies what printing is allowed. Possible values are:"
msgstr "ກຳນົດການພິມທີ່ອະນຸຍາດ. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. ihQew
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id451682110379499\n"
"help.text"
msgid "0: The document cannot be printed."
msgstr "0: ເອກະສານບໍ່ສາມາດພິມໄດ້."

#. R67Dw
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id971682110383819\n"
"help.text"
msgid "1: The document can be printed at low resolution only."
msgstr "1: ເອກະສານສາມາດພິມໄດ້ສະເພາະຄວາມລະອຽດຕ່ຳເທົ່ານັ້ນ."

#. hhBsT
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id441682110387779\n"
"help.text"
msgid "2: The document can be printed at maximum resolution."
msgstr "2: ເອກະສານສາມາດພິມໄດ້ດ້ວຍຄວາມລະອຽດສູງສຸດ."

#. NLwwg
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id111682110417183\n"
"help.text"
msgid "Specifies the changes that can be made to the document. Possible values are:"
msgstr "ກຳນົດການປ່ຽນແປງທີ່ສາມາດເຮັດໄດ້ກັບເອກະສານ. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. z8ghG
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id791682110462123\n"
"help.text"
msgid "0: The document cannot be changed."
msgstr "0: ເອກະສານບໍ່ສາມາດປ່ຽນແປງໄດ້."

#. LHS7W
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id91682110466372\n"
"help.text"
msgid "1: Inserting deleting and rotating pages is allowed."
msgstr "1: ອະນຸຍາດໃຫ້ແຊກ, ລຶບ ແລະ ໝຸນໜ້າໄດ້."

#. yrEBR
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id301682110472022\n"
"help.text"
msgid "2: Filling of form field is allowed."
msgstr "2: ອະນຸຍາດໃຫ້ປ້ອນຂໍ້ມູນໃນຟິວແບບຟອມໄດ້."

#. w5Cru
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id461682110476540\n"
"help.text"
msgid "3: Both filling of form field and commenting is allowed."
msgstr "3: ອະນຸຍາດໃຫ້ທັງປ້ອນຂໍ້ມູນໃນຟິວແບບຟອມ ແລະ ການສະແດງຄວາມຄິດເຫັນ."

#. f4Bwv
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id491682110483959\n"
"help.text"
msgid "4: All the changes of the previous selections are permitted, with the only exclusion of page extraction (copy)."
msgstr "4: ອະນຸຍາດໃຫ້ປ່ຽນແປງໄດ້ທຸກຢ່າງຕາມຕົວເລືອກກ່ອນໜ້ານີ້, ຍົກເວັ້ນການດຶງຂໍ້ມູນໜ້າ (ຄັດລອກ)."

#. pum6c
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id271682110577552\n"
"help.text"
msgid "Specifies that the pages and the document content can be extracted to be used in other documents (copy and paste)."
msgstr "ກຳນົດໃຫ້ສາມາດດຶງຂໍ້ມູນໜ້າ ແລະ ເເນື້ອຫາເອກະສານໄປໃຊ້ໃນເອກະສານອື່ນໄດ້ (ຄັດລອກ ແລະ ວາງ)."

#. DX8NT
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id491682110633185\n"
"help.text"
msgid "Specifies that the document content can be extracted to be used in accessibility applications."
msgstr "ກຳນົດໃຫ້ສາມາດດຶງຂໍ້ມູນເນື້ອຫາເອກະສານໄປໃຊ້ໃນແອັບພລິເຄຊັນສຳລັບການເຂົ້າເຖິງ (accessibility)."

#. MbaEt
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"hd_id211682127014184\n"
"help.text"
msgid "<variable id=\"digital_signature\"><link href=\"text/shared/guide/pdf_params.xhp#digital_signature\">Digital Signature</link></variable>"
msgstr "<variable id=\"digital_signature\"><link href=\"text/shared/guide/pdf_params.xhp#digital_signature\">ລາຍເຊັນດິຈິຕອນ</link></variable>"

#. GUMxB
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id611682127040192\n"
"help.text"
msgid "If true, sign the PDF."
msgstr "ຖ້າເປັນ true, ໃຫ້ເຊັນຊື່ໃນ PDF."

#. wVBSA
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id621682127237508\n"
"help.text"
msgid "Additional information about the digital signature, location of the signatory."
msgstr "ຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບລາຍເຊັນດິຈິຕອນ, ສະຖານທີ່ຂອງຜູ້ເຊັນຊື່."

#. CHHzr
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id901682127621143\n"
"help.text"
msgid "Additional information about the digital signature, reason for signature."
msgstr "ຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບລາຍເຊັນດິຈິຕອນ, ເຫດຜົນໃນການເຊັນຊື່."

#. icBzP
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id121682127669860\n"
"help.text"
msgid "Additional information about the digital signature, signatory contact information."
msgstr "ຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບລາຍເຊັນດິຈິຕອນ, ຂໍ້ມູນຕິດຕໍ່ຂອງຜູ້ເຊັນຊື່."

#. E7ePZ
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id11682127786864\n"
"help.text"
msgid "Certificate password"
msgstr "ລະຫັດຜ່ານໃບຢັ້ງຢືນ"

#. U5tZD
#: pdf_params.xhp
msgctxt ""
"pdf_params.xhp\n"
"par_id1001682129138275\n"
"help.text"
msgid "During the PDF signing process, the timestamp authority URL will be used to obtain a digitally signed timestamp that is then embedded in the signature."
msgstr "ໃນລະຫວ່າງຂະບວນການເຊັນຊື່ PDF, ຈະມີການໃຊ້ URL ຂອງຜູ້ໃຫ້ບໍລິການປະທັບຕາເວລາ (timestamp authority) ເພື່ອຂໍເອົາການປະທັບຕາເວລາທີ່ເຊັນຊື່ແບບດິຈິຕອນ ແລ້ວຝັງລົງໃນລາຍເຊັນ."

#. SxTMY
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"tit\n"
"help.text"
msgid "Printing in Black and White"
msgstr "ການພິມເປັນສີຂາວດຳ"

#. FDei5
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"bm_id3150125\n"
"help.text"
msgid "<bookmark_value>printing; black and white</bookmark_value>      <bookmark_value>black and white printing</bookmark_value>      <bookmark_value>colors; not printing</bookmark_value>      <bookmark_value>text; printing in black</bookmark_value>"
msgstr "<bookmark_value>ການພິມ; ສີຂາວດຳ</bookmark_value>      <bookmark_value>ການພິມສີຂາວດຳ</bookmark_value>      <bookmark_value>ສີ; ບໍ່ພິມ</bookmark_value>      <bookmark_value>ຂໍ້ຄວາມ; ພິມເປັນສີດຳ</bookmark_value>"

#. SVSbG
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"hd_id3150125\n"
"help.text"
msgid "<variable id=\"print_blackwhite\"><link href=\"text/shared/guide/print_blackwhite.xhp\">Printing in Black and White</link></variable>"
msgstr "<variable id=\"print_blackwhite\"><link href=\"text/shared/guide/print_blackwhite.xhp\">ການພິມເປັນສີຂາວດຳ</link></variable>"

#. uAc5B
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"hd_id3150499\n"
"help.text"
msgid "Printing Text and Images in Black and White"
msgstr "ການພິມຂໍ້ຄວາມ ແລະ ຮູບພາບເປັນສີຂາວດຳ"

#. JEFQG
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3149346\n"
"help.text"
msgid "Choose <emph>File - Print</emph>. The <emph>General</emph> tab page of the dialog opens."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ພິມ</emph>. ແທັບ <emph>ທົ່ວໄປ</emph> ຂອງປ່ອງຢ້ຽມຈະເປີດຂຶ້ນ."

#. M2gZA
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3155892\n"
"help.text"
msgid "Click on <emph>Properties</emph>. This opens the Properties dialog for your printer."
msgstr "ຄລິກທີ່ <emph>ຄຸນສົມບັດ</emph>. ນີ້ຈະເປີດປ່ອງຢ້ຽມຄຸນສົມບັດສຳລັບເຄື່ອງພິມຂອງທ່ານ."

#. dQK2B
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3145313\n"
"help.text"
msgid "Select the option to print in black and white. For further information, refer to the user's manual of your printer."
msgstr "ເລືອກຕົວເລືອກເພື່ອພິມເປັນສີຂາວດຳ. ສຳລັບຂໍ້ມູນເພີ່ມເຕີມ, ໃຫ້ເບິ່ງຄູ່ມືການໃຊ້ງານຂອງເຄື່ອງພິມຂອງທ່ານ."

#. 3F6Cg
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3153345\n"
"help.text"
msgid "Confirm the <emph>Properties</emph> dialog and click <emph>Print</emph>."
msgstr "ຢືນຢັນປ່ອງຢ້ຽມ <emph>ຄຸນສົມບັດ</emph> ແລະ ຄລິກ <emph>ພິມ</emph>."

#. AnmuG
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3156113\n"
"help.text"
msgid "The current document will be printed in black and white."
msgstr "ເອກະສານປັດຈຸບັນຈະຖືກພິມເປັນສີຂາວດຳ."

#. GZk5M
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"hd_id3147653\n"
"help.text"
msgid "Printing in Black and White in <item type=\"productname\">%PRODUCTNAME</item> Impress and <item type=\"productname\">%PRODUCTNAME</item> Draw"
msgstr "ການພິມເປັນສີຂາວດຳໃນ <item type=\"productname\">%PRODUCTNAME</item> Impress ແລະ <item type=\"productname\">%PRODUCTNAME</item> Draw"

#. BHUpA
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3149233\n"
"help.text"
msgid "Choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress</menuitem> or <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Draw</menuitem>, as appropriate."
msgstr "ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ການຕັ້ງຄ່າ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress</menuitem> ຫຼື <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ການຕັ້ງຄ່າ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Draw</menuitem>, ຕາມຄວາມເໝາະສົມ."

#. E9NZ5
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3150275\n"
"help.text"
msgid "Then choose <emph>Print</emph>."
msgstr "ຈາກນັ້ນເລືອກ <emph>ພິມ</emph>."

#. uxocY
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3147573\n"
"help.text"
msgid "Under <emph>Quality,</emph> select either <emph>Grayscale</emph> or <emph>Black & white</emph> and click <emph>OK</emph>."
msgstr "ພາຍໃຕ້ <emph>ຄຸນນະພາບ,</emph> ໃຫ້ເລືອກເປັນ <emph>ແຖບສີເທົາ</emph> ຫຼື <emph>ຂາວດຳ</emph> ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. kGhaY
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3154307\n"
"help.text"
msgid "When either of these options is selected, all presentations or drawings will be printed without color. If you only want to print in black for the <emph>current</emph> print job, select the option in <emph>File - Print - %PRODUCTNAME Draw/Impress</emph>."
msgstr "ເມື່ອເລືອກຕົວເລືອກໃດໜຶ່ງໃນນີ້, ທຸກໆການນຳສະເໜີ ຫຼື ຮູບແຕ້ມຈະຖືກພິມໂດຍບໍ່ມີສີ. ຖ້າທ່ານຕ້ອງການພິມເປັນສີດຳສະເພາະງານພິມ <emph>ປັດຈຸບັນ</emph> ເທົ່ານັ້ນ, ໃຫ້ເລືອກຕົວເລືອກໃນ <emph>ໄຟລ໌ - ພິມ - %PRODUCTNAME Draw/Impress</emph>."

#. iPPGT
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3149786\n"
"help.text"
msgid "<emph>Grayscale</emph> converts all colors to a maximum of 256 gradations from black to white. All text will be printed in black. A background set by <emph>Format - Page Style - Background</emph> will not be printed."
msgstr "<emph>ແຖບສີເທົາ</emph> ຈະປ່ຽນທຸກສີໃຫ້ເປັນລະດັບຄວາມເຂັ້ມແຕ່ດຳຫາຂາວໄດ້ສູງສຸດ 256 ລະດັບ. ຂໍ້ຄວາມທັງໝົດຈະຖືກພິມເປັນສີດຳ. ພື້ນຫຼັງທີ່ຕັ້ງໄວ້ໃນ <emph>ຮູບແບບ - ຮູບແບບໜ້າ - ພື້ນຫຼັງ</emph> ຈະບໍ່ຖືກພິມອອກມາ."

#. ko8Dn
#: print_blackwhite.xhp
msgctxt ""
"print_blackwhite.xhp\n"
"par_id3145610\n"
"help.text"
msgid "<emph>Black & white</emph> converts all colors into the two values black and white. All borders around objects are printed black. All text will be printed in black. A background set by <emph>Format - Page Style - Background</emph> will not be printed."
msgstr "<emph>ຂາວດຳ</emph> ຈະປ່ຽນທຸກສີໃຫ້ເປັນພຽງສອງຄ່າຄື ດຳ ແລະ ຂາວ. ເສັ້ນຂອບອ້ອມວັດຖຸທັງໝົດຈະຖືກພິມເປັນສີດຳ. ຂໍ້ຄວາມທັງໝົດຈະຖືກພິມເປັນສີດຳ. ພື້ນຫຼັງທີ່ຕັ້ງໄວ້ໃນ <emph>ຮູບແບບ - ຮູບແບບໜ້າ - ພື້ນຫຼັງ</emph> ຈະບໍ່ຖືກພິມອອກມາ."

