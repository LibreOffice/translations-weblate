msgstr "<bookmark_value>ຖານຂໍ້ມູນ;ການນຳເຂົ້າ/ສົ່ງອອກ</bookmark_value>"

#. 9aKkt
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"hd_id4547257\n"
"help.text"
msgid "<variable id=\"data_im_export\"><link href=\"text/shared/guide/data_im_export.xhp\">Importing and Exporting Data in Base</link></variable>"
msgstr "<variable id=\"data_im_export\"><link href=\"text/shared/guide/data_im_export.xhp\">ການນຳເຂົ້າ ແລະ ສົ່ງອອກຂໍ້ມູນໃນ Base</link></variable>"

#. cA7te
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id2761314\n"
"help.text"
msgid "An easy method to import and export database tables uses Calc as a \"helper application\"."
msgstr "ວິທີທີ່ງ່າຍໃນການນຳເຂົ້າ ແລະ ສົ່ງອອກຕາຕະລາງຖານຂໍ້ມູນ ແມ່ນການໃຊ້ Calc ເປັນ \"ແອັບພລິເຄຊັນຊ່ວຍ\"."

#. fvpN7
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"hd_id3912778\n"
"help.text"
msgid "Exporting data from Base"
msgstr "ການສົ່ງອອກຂໍ້ມູນຈາກ Base"

#. uf96E
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id3163853\n"
"help.text"
msgid "You copy a table from Base to a new Calc sheet, then you can save or export the data to any file format that Calc supports."
msgstr "ທ່ານສຳເນົາຕາຕະລາງຈາກ Base ໃສ່ຊີດ Calc ໃໝ່, ຈາກນັ້ນທ່ານສາມາດບັນທຶກ ຫຼື ສົ່ງອອກຂໍ້ມູນໄປເປັນຮູບແບບໄຟລ໌ໃດກໍໄດ້ທີ່ Calc ຮອງຮັບ."

#. bA5bG
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id121158\n"
"help.text"
msgid "Open the database file that contains the database table to be exported. Click Tables to view the tables, or click Queries to view the queries."
msgstr "ເປີດໄຟລ໌ຖານຂໍ້ມູນທີ່ມີຕາຕະລາງທີ່ຕ້ອງການສົ່ງອອກ. ຄລິກ ຕາຕະລາງ ເພື່ອເບິ່ງຕາຕະລາງ, ຫຼື ຄລິກ ການສອບຖາມ ເພື່ອເບິ່ງການສອບຖາມ."

#. 2HDjC
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id4644306\n"
"help.text"
msgid "Choose <emph>File - New - Spreadsheet</emph>."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ໃໝ່ - ສະເປຣດຊີດ</emph>."

#. RcjVm
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id1331217\n"
"help.text"
msgid "In the Base window, right-click the name of the table to export. Choose <emph>Copy</emph> from the context menu."
msgstr "ໃນປ່ອງຢ້ຽມ Base, ໃຫ້ຄລິກຂວາໃສ່ຊື່ຕາຕະລາງທີ່ຕ້ອງການສົ່ງອອກ. ແລ້ວເລືອກ <emph>ສຳເນົາ</emph> ຈາກເມນູລັດ."

#. Briz6
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id3806878\n"
"help.text"
msgid "Click cell A1 in the new Calc window, then choose <emph>Edit - Paste</emph>."
msgstr "ຄລິກຫ້ອງ A1 ໃນປ່ອງຢ້ຽມ Calc ໃໝ່, ແລ້ວເລືອກ <emph>ແກ້ໄຂ - ວາງ</emph>."

#. xc9J9
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id130619\n"
"help.text"
msgid "Now you can save or export the data to many file types."
msgstr "ຕອນນີ້ທ່ານສາມາດບັນທຶກ ຫຼື ສົ່ງອອກຂໍ້ມູນໄປເປັນໄຟລ໌ຫຼາຍປະເພດໄດ້ແລ້ວ."

#. QdcHB
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"hd_id9999694\n"
"help.text"
msgid "Importing data to Base"
msgstr "ການນຳເຂົ້າຂໍ້ມູນໃສ່ Base"

#. T2VLP
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id8494521\n"
"help.text"
msgid "You can import text files, spreadsheet files, and your system address book in read-only mode only."
msgstr "ທ່ານສາມາດນຳເຂົ້າໄຟລ໌ຂໍ້ຄວາມ, ໄຟລ໌ສະເປຣດຊີດ ແລະ ສະໝຸດລາຍຊື່ຂອງລະບົບໄດ້ໃນໂໝດອ່ານຢ່າງດຽວເທົ່ານັ້ນ."

#. h7bWA
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id9579760\n"
"help.text"
msgid "When you import from a text or spreadsheet file, the file must have a first row of header information. The second row of the file is the first valid data row. The format of every field in the second row determines the format for the entire column. Any format information from a spreadsheet file gets lost when importing to Base."
msgstr "ເມື່ອທ່ານນຳເຂົ້າຈາກໄຟລ໌ຂໍ້ຄວາມ ຫຼື ສະເປຣດຊີດ, ໄຟລ໌ນັ້ນຕ້ອງມີແຖວທຳອິດເປັນຂໍ້ມູນຫົວຂໍ້."

#. SWrCA
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id325632\n"
"help.text"
msgid "For example, to ensure the first column has a text format, you must make sure that the first field of the first valid data row contains text. If a field in the first valid data row contains a number, the whole column is set to number format, and only numbers, no text, will be shown in that column."
msgstr "ຕົວຢ່າງ: ເພື່ອໃຫ້ແນ່ໃຈວ່າຖັນທຳອິດເປັນຮູບແບບຂໍ້ຄວາມ, ທ່ານຕ້ອງແນ່ໃຈວ່າຟິວທຳອິດຂອງແຖວຂໍ້ມູນທີ່ມີຜົນຕົວທຳອິດນັ້ນມີຂໍ້ຄວາມ."

#. 5u6rr
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id2216559\n"
"help.text"
msgid "Open a Base file of the database type that you want."
msgstr "ເປີດໄຟລ໌ Base ຂອງປະເພດຖານຂໍ້ມູນທີ່ທ່ານຕ້ອງການ."

#. fGBzV
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id7869502\n"
"help.text"
msgid "Either create a new Base file using the <link href=\"text/sdatabase/dabawiz01.xhp\">Database Wizard</link>, or open any existing Base file that is not read-only."
msgstr "ຈະສ້າງໄຟລ໌ Base ໃໝ່ໂດຍໃຊ້ <link href=\"text/sdatabase/dabawiz01.xhp\">ຕົວຊ່ວຍສ້າງຖານຂໍ້ມູນ</link>, ຫຼື ເປີດໄຟລ໌ Base ທີ່ມີຢູ່ແລ້ວທີ່ບໍ່ໄດ້ເປັນແບບອ່ານຢ່າງດຽວກໍໄດ້."

#. JHYC6
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id9852900\n"
"help.text"
msgid "Open the Calc file that contains the data to be imported to Base. You can open a *.dbf dBASE file or many other file types."
msgstr "ເປີດໄຟລ໌ Calc ທີ່ມີຂໍ້ມູນທີ່ຕ້ອງການນຳເຂົ້າໃສ່ Base. ທ່ານສາມາດເປີດໄຟລ໌ *.dbf dBASE ຫຼື ໄຟລ໌ປະເພດອື່ນໆຫຼາຍຢ່າງໄດ້."

#. ZnCh7
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id3791924\n"
"help.text"
msgid "Select the data to be copied to Base."
msgstr "ເລືອກຂໍ້ມູນທີ່ຕ້ອງການສຳເນົາໃສ່ Base."

#. Epgd2
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id6173894\n"
"help.text"
msgid "You can enter a range reference like A1:X500 in the Name Box if you don't want to scroll."
msgstr "ທ່ານສາມາດປ້ອນການອ້າງອີງຊ່ວງເຊັ່ນ A1:X500 ໃນຫ້ອງຊື່ (Name Box) ຖ້າຫາກທ່ານບໍ່ຕ້ອງການເລື່ອນເບິ່ງ."

#. FBsQ8
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id533768\n"
"help.text"
msgid "If you copy a dBASE sheet, include the top row that contains the header data."
msgstr "ຖ້າຫາກທ່ານສຳເນົາແຜ່ນງານ dBASE, ໃຫ້ລວມເອົາແຖວເທິງສຸດທີ່ມີຂໍ້ມູນຫົວເລື່ອງນຳ."

#. MQEaP
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id5669423\n"
"help.text"
msgid "Choose <emph>Edit - Copy</emph>."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ສຳເນົາ</emph>."

#. EfXM3
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id3619495\n"
"help.text"
msgid "In the Base window, click <emph>Tables</emph> to view the tables."
msgstr "ໃນໜ້າຕ່າງ Base, ຄລິກ <emph>ຕາຕະລາງ</emph> ເພື່ອເບິ່ງຕາຕະລາງ."

#. b4xrs
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id1175572\n"
"help.text"
msgid "In the Base window, choose <emph>Edit - Paste</emph>."
msgstr "ໃນໜ້າຕ່າງ Base, ເລືອກ <emph>ແກ້ໄຂ - ວາງ</emph>."

#. CVYD4
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id4815820\n"
"help.text"
msgid "You see the Copy Table dialog. Most databases need a primary key, so you may want to check the <emph>Create primary key</emph> box."
msgstr "ທ່ານຈະເຫັນກ່ອງໂຕ້ຕອບ ສຳເນົາຕາຕະລາງ. ຖານຂໍ້ມູນສ່ວນໃຫຍ່ຕ້ອງການຄີຫຼັກ, ດັ່ງນັ້ນທ່ານອາດຈະຕ້ອງໝາຍຕິກເອົາຫ້ອງ <emph>ສ້າງຄີຫຼັກ</emph>."

#. xnEs2
#: data_im_export.xhp
msgctxt ""
"data_im_export.xhp\n"
"par_id2584002\n"
"help.text"
msgid "On Windows systems, you can also use drag-and-drop instead of Copy and Paste. Also, for registered databases, you can open the datasource browser (press  <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> + Shift + F4 keys) instead of opening the Base window."
msgstr "ໃນລະບົບ Windows, ທ່ານຍັງສາມາດໃຊ້ວິທີການລາກແລ້ວວາງ ແທນການໃຊ້ ສຳເນົາ ແລະ ວາງ. ນອກຈາກນັ້ນ, ສຳລັບຖານຂໍ້ມູນທີ່ລົງທະບຽນແລ້ວ, ທ່ານສາມາດເປີດບຣາວເຊີແຫຼ່ງຂໍ້ມູນ (ກົດປຸ່ມ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> + Shift + F4) ແທນການເປີດໜ້າຕ່າງ Base."

