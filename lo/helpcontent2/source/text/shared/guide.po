msgstr "ການແຊກການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງ"

#. sLrje
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"bm_id6305734\n"
"help.text"
msgid "<bookmark_value>line breaks; in cells</bookmark_value>      <bookmark_value>cells; line breaks</bookmark_value>      <bookmark_value>text flow; in cells</bookmark_value>      <bookmark_value>text breaks in cells</bookmark_value>      <bookmark_value>wrapping text; in cells</bookmark_value>      <bookmark_value>words; wrapping in cells</bookmark_value>      <bookmark_value>automatic line breaks</bookmark_value>      <bookmark_value>new lines in cells</bookmark_value>      <bookmark_value>inserting;line breaks in cells</bookmark_value>      <bookmark_value>tables;inserting line breaks</bookmark_value>"
msgstr "<bookmark_value>ການຂຶ້ນແຖວໃໝ່; ໃນຫ້ອງ</bookmark_value>      <bookmark_value>ຫ້ອງ; ການຂຶ້ນແຖວໃໝ່</bookmark_value>      <bookmark_value>ການໄຫຼຂອງຂໍ້ຄວາມ; ໃນຫ້ອງ</bookmark_value>      <bookmark_value>ການຕັດຂໍ້ຄວາມໃນຫ້ອງ</bookmark_value>      <bookmark_value>ການຕັດຄຳ; ໃນຫ້ອງ</bookmark_value>      <bookmark_value>ການຂຶ້ນແຖວໃໝ່ອັດຕະໂນມັດ</bookmark_value>      <bookmark_value>ແຖວໃໝ່ໃນຫ້ອງ</bookmark_value>      <bookmark_value>ການແຊກ; ການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງ</bookmark_value>      <bookmark_value>ຕາຕະລາງ; ການແຊກການຂຶ້ນແຖວໃໝ່</bookmark_value>"

#. rx68A
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106D5\n"
"help.text"
msgid "<variable id=\"breaking_lines\"><link href=\"text/shared/guide/breaking_lines.xhp\">Inserting Line Breaks in Cells</link></variable>"
msgstr "<variable id=\"breaking_lines\"><link href=\"text/shared/guide/breaking_lines.xhp\">ການແຊກການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງ</link></variable>"

#. 9DPLA
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106D9\n"
"help.text"
msgid "Inserting line breaks in $[officename] Calc spreadsheet cells"
msgstr "ການແຊກການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງຕາຕະລາງຄຳນວນ $[officename] Calc"

#. E2hX5
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106E0\n"
"help.text"
msgid "To insert a line break in a spreadsheet cell, press the <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>Enter</keycode> keys."
msgstr "ເພື່ອແຊກການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງຕາຕະລາງຄຳນວນ, ໃຫ້ກົດປຸ່ມ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>Enter</keycode>."

#. y6vE4
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106E3\n"
"help.text"
msgid "This will work only with the text edit cursor inside the cell, not at the input line. So first double-click the cell, then single-click at the text position where you want the line break."
msgstr "ວິທີນີ້ຈະເຮັດວຽກໄດ້ສະເພາະຕອນທີ່ເຄີເຊີແກ້ໄຂຂໍ້ຄວາມຢູ່ພາຍໃນຫ້ອງເທົ່ານັ້ນ, ບໍ່ແມ່ນຢູ່ແຖບປ້ອນຂໍ້ມູນ. ດັ່ງນັ້ນ ກ່ອນອື່ນໃຫ້ດັບເບິນຄລິກທີ່ຫ້ອງ, ແລ້ວຄລິກທີ່ຕຳແໜ່ງຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການຂຶ້ນແຖວໃໝ່."

#. Bb95V
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_id0509200914160968\n"
"help.text"
msgid "You can search for a newline character in the Find & Replace dialog by searching for <literal>\\n</literal> as a regular expression. You can use the text function CHAR(10) to insert a newline character into a text formula."
msgstr ""
"ທ່ານສາມາດຄົ້ນຫາຕົວອັກສອນຂຶ້ນແຖວໃໝ່ໃນກ່ອງຂໍ້ຄວາມ ຄົ້ນຫາ ແລະ ແທນທີ່ ໂດຍການຄົ້ນຫາ <literal>\\n"
"</literal> ເປັນນິພົດປົກກະຕິ. ທ່ານສາມາດໃຊ້ຟັງຊັນຂໍ້ຄວາມ CHAR(10) ເພື່ອແຊກຕົວອັກສອນຂຶ້ນແຖວໃໝ່ເຂົ້າໃນສູດຂໍ້ຄວາມ."

#. BsAfw
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106E6\n"
"help.text"
msgid "Formatting $[officename] Calc cells for automatic line wrapping"
msgstr "ການຈັດຮູບແບບຫ້ອງ $[officename] Calc ສຳລັບການຕັດຄຳຂຶ້ນແຖວໃໝ່ອັດຕະໂນມັດ"

#. BRLgh
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106ED\n"
"help.text"
msgid "Select the cells for which you want an automatic line break."
msgstr "ເລືອກຫ້ອງທີ່ທ່ານຕ້ອງການໃຫ້ມີການຂຶ້ນແຖວໃໝ່ອັດຕະໂນມັດ."

#. qiLsG
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106F1\n"
"help.text"
msgid "Choose <menuitem>Format - Cells - Alignment</menuitem>."
msgstr "ເລືອກ <menuitem>ຮູບແບບ - ຫ້ອງ - ການຈັດວາງ</menuitem>."

#. jjEEf
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN106F9\n"
"help.text"
msgid "Select <emph>Wrap text automatically</emph>."
msgstr "ເລືອກ <emph>ຕັດຂໍ້ຄວາມອັດຕະໂນມັດ</emph>."

#. kdY87
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN10700\n"
"help.text"
msgid "Inserting line breaks in $[officename] Writer text document tables"
msgstr "ການແຊກການຂຶ້ນແຖວໃໝ່ໃນຕາຕະລາງເອກະສານຂໍ້ຄວາມ $[officename] Writer"

#. 4RYMp
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN10707\n"
"help.text"
msgid "To insert a line break in a text document table cell, press the <keycode>Enter</keycode> key."
msgstr "ເພື່ອແຊກການຂຶ້ນແຖວໃໝ່ໃນຫ້ອງຕາຕະລາງເອກະສານຂໍ້ຄວາມ, ໃຫ້ກົດປຸ່ມ <keycode>Enter</keycode>."

#. Gm3yj
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"par_idN1070A\n"
"help.text"
msgid "An automatic line break will be performed while you type across the end of each cell."
msgstr "ການຂຶ້ນແຖວໃໝ່ອັດຕະໂນມັດຈະເກີດຂຶ້ນໃນຂະນະທີ່ທ່ານພິມກາຍທ້າຍຂອງແຕ່ລະຫ້ອງ."

#. oiGGU
#: breaking_lines.xhp
msgctxt ""
