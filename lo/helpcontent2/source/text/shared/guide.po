"pdf_params.xhp\n"
"par_id231761251733348\n"
"help.text"
msgid "<variable id=\"version\">To set version 1.5 (instead of the default 1.7):</variable>"
msgstr "<variable id=\"version\">ເພື່ອຕັ້ງເວີຊັນເປັນ 1.5 (ແທນທີ່ຄ່າເລີ່ມຕົ້ນ 1.7):</variable>"

