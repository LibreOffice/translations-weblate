#. 5uGFT
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id3155066\n"
"help.text"
msgid "In a Writer document, you can insert a chart based on the values in a Writer table."
msgstr "ໃນເອກະສານ Writer, ທ່ານສາມາດແຊກແຜນພູມໂດຍອີງຕາມຄ່າໃນຕາຕະລາງ Writer ໄດ້."

#. Q6SNF
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id428479\n"
"help.text"
msgid "Click inside the Writer table."
msgstr "ຄລິກພາຍໃນຕາຕະລາງ Writer."

#. SGU3P
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id7236243\n"
"help.text"
msgid "Choose <emph>Insert - Chart</emph>."
msgstr "ເລືອກ <emph>ແຊກ - ແຜນພູມ</emph>."

#. FDQiF
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id6171452\n"
"help.text"
msgid "You see a chart preview and the Chart Wizard."
msgstr "ທ່ານຈະເຫັນຕົວຢ່າງແຜນພູມ ແລະ ຕົວຊ່ວຍສ້າງແຜນພູມ."

#. E525o
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id3145419\n"
"help.text"
