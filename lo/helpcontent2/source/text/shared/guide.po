msgstr "<image id=\"img_id3153527\" src=\"cmd/lc_removebullets.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3153527\">ໄອຄອນບໍ່ມີລາຍການ</alt></image>"

#. nFCu3
