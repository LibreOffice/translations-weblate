#. csKmQ
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1399578\n"
"help.text"
msgid "In %PRODUCTNAME, you can open and save documents that are stored on a WebDAV server, using the secure HTTPS protocol."
msgstr "ໃນ %PRODUCTNAME, ທ່ານສາມາດເປີດ ແລະ ບັນທຶກເອກະສານທີ່ເກັບໄວ້ໃນເຊີບເວີ WebDAV ໂດຍໃຊ້ໂປຣໂຕຄໍ HTTPS ທີ່ປອດໄພ."

#. EwHJJ
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id598162\n"
"help.text"
msgid "You must use the %PRODUCTNAME file dialogs to use WebDAV over HTTPS."
msgstr "ທ່ານຕ້ອງໃຊ້ກ່ອງໂຕ້ຕອບໄຟລ໌ຂອງ %PRODUCTNAME ເພື່ອໃຊ້ WebDAV ຜ່ານ HTTPS."

#. cXXrz
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id7309793\n"
"help.text"
msgid "Choose <switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - Preferences</caseinline><defaultinline>Tools - Options</defaultinline></switchinline> - <item type=\"menuitem\">%PRODUCTNAME - General</item>. Ensure that <emph>Use %PRODUCTNAME dialogs</emph> is enabled. Click <emph>OK</emph> to close the dialog box."
msgstr "ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - ຄວາມມັກ</caseinline><defaultinline>ເຄື່ອງມື - ຕົວເລືອກ</defaultinline></switchinline> - <item type=\"menuitem\">%PRODUCTNAME - ທົ່ວໄປ</item>. ກວດສອບໃຫ້ແນ່ໃຈວ່າໄດ້ເປີດໃຊ້ <emph>ໃຊ້ກ່ອງໂຕ້ຕອບ %PRODUCTNAME</emph> ແລ້ວ. ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອປິດກ່ອງໂຕ້ຕອບ."

#. XSwjj
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1227759\n"
"help.text"
msgid "Choose <item type=\"menuitem\">File - Open</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ໄຟລ໌ - ເປີດ</item>."

#. 5DtvG
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id7424237\n"
"help.text"
msgid "In the <emph>File name</emph> box, enter the path to the WebDAV folder. For example, enter <item type=\"literal\">https://192.168.1.1/webfolder</item> to open a secure connection to the WebDAV server at the IP address 192.168.1.1, and to list the contents of the <item type=\"literal\">webfolder</item> folder."
msgstr "ໃນຫ້ອງ <emph>ຊື່ໄຟລ໌</emph>, ໃຫ້ປ້ອນເສັ້ນທາງໄປຫາໂຟນເດີ WebDAV. ຕົວຢ່າງ: ປ້ອນ <item type=\"literal\">https://192.168.1.1/webfolder</item> ເພື່ອເປີດການເຊື່ອມຕໍ່ທີ່ປອດໄພໄປຫາເຊີບເວີ WebDAV ທີ່ໝາຍເລກ IP 192.168.1.1, ແລະ ເພື່ອສະແດງລາຍຊື່ເນື້ອໃນຂອງໂຟນເດີ <item type=\"literal\">webfolder</item>."

#. zzeAk
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1388592\n"
"help.text"
msgid "The first time you connect to a WebDAV server, you see the \"<emph>Website Certified by an Unknown Authority</emph>\" dialog."
msgstr "ຄັ້ງທຳອິດທີ່ທ່ານເຊື່ອມຕໍ່ກັບເຊີບເວີ WebDAV, ທ່ານຈະເຫັນກ່ອງໂຕ້ຕອບ \"<emph>ເວັບໄຊຖືກຢັ້ງຢືນໂດຍອົງກອນທີ່ບໍ່ຮູ້ຈັກ</emph>\"."

#. TfDz2
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id343943\n"
"help.text"
msgid "You should click the <emph>Examine Certificate</emph> button and examine the certificate."
msgstr "ທ່ານຄວນຄລິກປຸ່ມ <emph>ກວດສອບໃບຢັ້ງຢືນ</emph> ແລະ ກວດສອບລາຍລະອຽດຂອງໃບຢັ້ງຢືນນັ້ນ."

#. y4eUC
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id8726767\n"
"help.text"
msgid "If you accept the certificate, choose \"<emph>Accept this certificate temporarily for this session</emph>\" and click <emph>OK</emph>. Now you can open and save files from the WebDAV server without further questions, until you exit %PRODUCTNAME."
msgstr "ຖ້າທ່ານຍອມຮັບໃບຢັ້ງຢືນ, ໃຫ້ເລືອກ \"<emph>ຍອມຮັບໃບຢັ້ງຢືນນີ້ຊົ່ວຄາວສຳລັບເຊດຊັນນີ້</emph>\" ແລະ ຄລິກ <emph>ຕົກລົງ</emph>. ຕອນນີ້ທ່ານສາມາດເປີດ ແລະ ບັນທຶກໄຟລ໌ຈາກເຊີບເວີ WebDAV ໄດ້ໂດຍບໍ່ຕ້ອງຕອບຄຳຖາມໃດໆອີກ ຈົນກວ່າທ່ານຈະອອກຈາກ %PRODUCTNAME."

#. 8PMVb
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id691549\n"
"help.text"
msgid "If you do not trust the certificate, click <emph>Cancel</emph>."
msgstr "ຖ້າທ່ານບໍ່ໄວ້ວາງໃຈໃບຢັ້ງຢືນ, ໃຫ້ຄລິກ <emph>ຍົກເລີກ</emph>."

#. AqPZq
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id9909665\n"
"help.text"
msgid "If you did accept the certificate, you can now select the file name or file names you want to open and click <emph>Open</emph>."
msgstr "ຖ້າທ່ານຍອມຮັບໃບຢັ້ງຢືນແລ້ວ, ຕອນນີ້ທ່ານສາມາດເລືອກຊື່ໄຟລ໌ທີ່ທ່ານຕ້ອງການເປີດ ແລະ ຄລິກ <emph>ເປີດ</emph>."

#. ySgN9
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id3236182\n"
"help.text"
msgid "If there is a mismatch of the domain name given in the certificate and the domain name you entered in the file dialog, then you see a dialog that allows you to choose from any of the following options:"
msgstr "ຖ້າຊື່ໂດເມນໃນໃບຢັ້ງຢືນບໍ່ກົງກັບຊື່ໂດເມນທີ່ທ່ານປ້ອນໃນກ່ອງໂຕ້ຕອບໄຟລ໌, ທ່ານຈະເຫັນກ່ອງໂຕ້ຕອບທີ່ໃຫ້ທ່ານເລືອກຕົວເລືອກໃດໜຶ່ງຕໍ່ໄປນີ້:"

#. EPogr
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1251258\n"
"help.text"
msgid "<emph>View Certificate</emph> - <ahelp hid=\".\">Opens the View Certificate dialog.</ahelp>"
msgstr "<emph>ເບິ່ງໃບຢັ້ງຢືນ</emph> - <ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບການເບິ່ງໃບຢັ້ງຢືນ.</ahelp>"

#. BXyF3
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id8111819\n"
"help.text"
msgid "<emph>Continue</emph> - <ahelp hid=\".\">If you are sure both domains are the same, click the Continue button.</ahelp>"
msgstr "<emph>ດຳເນີນການຕໍ່</emph> - <ahelp hid=\".\">ຖ້າທ່ານໝັ້ນໃຈວ່າທັງສອງໂດເມນແມ່ນອັນດຽວກັນ, ໃຫ້ຄລິກປຸ່ມ ດຳເນີນການຕໍ່.</ahelp>"

#. HyY2o
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id9116794\n"
"help.text"
msgid "<emph>Cancel Connection</emph> - Cancels the connection."
msgstr "<emph>ຍົກເລີກການເຊື່ອມຕໍ່</emph> - ຍົກເລີກການເຊື່ອມຕໍ່."

#. xrFHe
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id4381847\n"
"help.text"
msgid "If you click <emph>Continue</emph>, you may see a dialog that asks you to enter your user name and password."
msgstr "ຖ້າທ່ານຄລິກ <emph>ດຳເນີນການຕໍ່</emph>, ທ່ານອາດຈະເຫັນກ່ອງໂຕ້ຕອບທີ່ຖາມຫາຊື່ຜູ້ໃຊ້ ແລະ ລະຫັດຜ່ານ."

#. sBMvT
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1336710\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter your user name to log on to the WebDAV server.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຊື່ຜູ້ໃຊ້ຂອງທ່ານເພື່ອເຂົ້າສູ່ລະບົບເຊີບເວີ WebDAV.</ahelp>"

#. w8wCu
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id1221655\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter your password.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນລະຫັດຜ່ານຂອງທ່ານ.</ahelp>"

#. vtDJd
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id3397320\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">If you enable <emph>Remember password till end of session</emph>, your password will be remembered for subsequent WebDAV connections until you exit %PRODUCTNAME.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຖ້າທ່ານເປີດໃຊ້ <emph>ຈື່ລະຫັດຜ່ານຈົນກວ່າຈະສິ້ນສຸດເຊດຊັນ</emph>, ລະຫັດຜ່ານຂອງທ່ານຈະຖືກຈົດຈຳໄວ້ສຳລັບການເຊື່ອມຕໍ່ WebDAV ຄັ້ງຕໍ່ໄປຈົນກວ່າທ່ານຈະອອກຈາກ %PRODUCTNAME.</ahelp>"

#. YAhkz
#: digitalsign_receive.xhp
msgctxt ""
"digitalsign_receive.xhp\n"
"par_id3204443\n"
