msgid "<variable id=\"border_table\"><link href=\"text/shared/guide/border_table.xhp\">Defining Borders for Tables and Table Cells</link></variable>"
msgstr "<variable id=\"border_table\"><link href=\"text/shared/guide/border_table.xhp\">ການກຳນົດຂອບສຳລັບຕາຕະລາງ ແລະ ຫ້ອງຕາຕະລາງ</link></variable>"

#. kvcWY
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"hd_id3147008\n"
"help.text"
msgid "Setting a Predefined Border Style"
msgstr "ການຕັ້ງຄ່າຮູບແບບຂອບທີ່ກຳນົດໄວ້ລ່ວງໜ້າ"

#. pGG8y
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3146957\n"
"help.text"
msgid "Select the table cells that you want to modify."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ທ່ານຕ້ອງການແກ້ໄຂ."

#. fuN3g
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3156346\n"
"help.text"
msgid "Click the <emph>Borders</emph> icon on the <emph>Table </emph>toolbar (Writer) or on the <emph>Line and Filling</emph> bar to open the <emph>Borders</emph> window."
msgstr "ຄລິກໄອຄອນ <emph>ຂອບ</emph> ໃນແຖບເຄື່ອງມື <emph>ຕາຕະລາງ</emph> (Writer) ຫຼື ໃນແຖບ <emph>ເສັ້ນ ແລະ ການເຕີມ</emph> ເພື່ອເປີດໜ້າຕ່າງ <emph>ຂອບ</emph>."

#. tsdz6
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3143270\n"
"help.text"
msgid "Click one of the predefined border styles."
msgstr "ຄລິກເລືອກໜຶ່ງໃນຮູບແບບຂອບທີ່ກຳນົດໄວ້ລ່ວງໜ້າ."

#. uoHXg
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3156156\n"
"help.text"
msgid "This <emph>adds</emph> the selected style to the current border style of the table cells. Select the blank border style at the top left of the <emph>Borders</emph> window to clear all border styles."
msgstr "ນີ້ຈະ <emph>ເພີ່ມ</emph> ຮູບແບບທີ່ເລືອກເຂົ້າໃນຮູບແບບຂອບປັດຈຸບັນຂອງຫ້ອງຕາຕະລາງ. ເລືອກຮູບແບບຂອບຫວ່າງເປົ່າຢູ່ທາງເທິງຊ້າຍຂອງໜ້າຕ່າງ <emph>ຂອບ</emph> ເພື່ອລຶບຮູບແບບຂອບທັງໝົດອອກ."

#. JJx8b
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"hd_id3153666\n"
"help.text"
msgid "Setting a Customized Border Style"
msgstr "ການຕັ້ງຄ່າຮູບແບບຂອບທີ່ກຳນົດເອງ"

#. Xjsba
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3152472\n"
"help.text"
msgid "Select the table cells that you want to modify."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ທ່ານຕ້ອງການແກ້ໄຂ."

#. wRfRi
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3147265\n"
"help.text"
msgid "Choose <emph>Table - Properties - Borders</emph> (Writer) or <emph>Format - Cells - Borders</emph> (Calc)."
msgstr "ເລືອກ <emph>ຕາຕະລາງ - ຄຸນສົມບັດ - ຂອບ</emph> (Writer) ຫຼື <emph>ຮູບແບບ - ຫ້ອງ - ຂອບ</emph> (Calc)."

#. mfLaM
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3159413\n"
"help.text"
msgid "In the <emph>User-defined</emph> area select the edge(s) that you want to appear in a common layout. Click on an edge in the preview to toggle the selection of an edge."
msgstr "ໃນສ່ວນ <emph>ກຳນົດເອງ</emph> ໃຫ້ເລືອກຂອບທີ່ທ່ານຕ້ອງການໃຫ້ສະແດງ. ຄລິກທີ່ຂອບໃນຕົວຢ່າງມຸມເບິ່ງເພື່ອເປີດ ຫຼື ປິດການເລືອກຂອບນັ້ນ."

#. Y3sAy
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id31594132\n"
"help.text"
msgid "If you select more than one row or column, you can change the middle lines between rows or columns. Select the middle markers in the <emph>User-defined</emph> area."
msgstr "ຖ້າທ່ານເລືອກຫຼາຍກວ່າໜຶ່ງແຖວ ຫຼື ຖັນ, ທ່ານສາມາດປ່ຽນເສັ້ນກາງລະຫວ່າງແຖວ ຫຼື ຖັນໄດ້. ເລືອກເຄື່ອງໝາຍກາງໃນສ່ວນ <emph>ກຳນົດເອງ</emph>."

#. 4Cnie
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3153526\n"
"help.text"
msgid "Select a line style and color for the selected border style in the <emph>Line</emph> area. These settings apply to all border lines that are included in the selected border style."
msgstr "ເລືອກຮູບແບບເສັ້ນ ແລະ ສີສຳລັບຮູບແບບຂອບທີ່ເລືອກໃນສ່ວນ <emph>ເສັ້ນ</emph>."

#. CFiNF
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3145606\n"
"help.text"
msgid "Repeat the last two steps for every border edge."
msgstr "ເຮັດຊ້ຳສອງຂັ້ນຕອນສຸດທ້າຍສຳລັບແຕ່ລະຂອບ."

#. 86nCT
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3156422\n"
"help.text"
msgid "Select the distance between the border lines and the page contents in the <emph>Padding</emph> area."
msgstr "ເລືອກໄລຍະຫ່າງລະຫວ່າງເສັ້ນຂອບ ແລະ ເນື້ອໃນໜ້າໃນສ່ວນ <emph>ໄລຍະຫ່າງຂອບ (Padding)</emph>."

#. Zx8qx
#: border_table.xhp
msgctxt ""
"border_table.xhp\n"
"par_id3149807\n"
"help.text"
msgid "Click <emph>OK</emph> to apply the changes."
msgstr "ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອນຳໃຊ້ການປ່ຽນແປງ."

#. FXQNC
#: breaking_lines.xhp
msgctxt ""
"breaking_lines.xhp\n"
"tit\n"
"help.text"
