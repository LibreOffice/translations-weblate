msgid "<bookmark_value>charts; inserting</bookmark_value><bookmark_value>plotting data as charts</bookmark_value><bookmark_value>inserting; charts</bookmark_value><bookmark_value>spreadsheets; inserting charts</bookmark_value><bookmark_value>charts; editing data</bookmark_value><bookmark_value>editing; chart data</bookmark_value>"
msgstr "<bookmark_value>ແຜນພູມ; ການແຊກ</bookmark_value><bookmark_value>ການພອດຂໍ້ມູນເປັນແຜນພູມ</bookmark_value><bookmark_value>ການແຊກ; ແຜນພູມ</bookmark_value><bookmark_value>ຕາຕະລາງຄຳນວນ; ການແຊກແຜນພູມ</bookmark_value><bookmark_value>ແຜນພູມ; ການແກ້ໄຂຂໍ້ມູນ</bookmark_value><bookmark_value>ການແກ້ໄຂ; ຂໍ້ມູນແຜນພູມ</bookmark_value>"

#. 2UDDc
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"hd_id3153910\n"
"help.text"
msgid "<variable id=\"chart_insert\"><link href=\"text/shared/guide/chart_insert.xhp\">Inserting Charts</link></variable>"
msgstr "<variable id=\"chart_insert\"><link href=\"text/shared/guide/chart_insert.xhp\">ການແຊກແຜນພູມ</link></variable>"

#. u6Vsh
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id3139133\n"
"help.text"
msgid "Different methods exist to start a chart:"
msgstr "ມີຫຼາຍວິທີໃນການເລີ່ມສ້າງແຜນພູມ:"

#. MGVL9
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id6772972\n"
"help.text"
msgid "Insert a chart based on data from cells in Calc or Writer."
msgstr "ແຊກແຜນພູມໂດຍອີງຕາມຂໍ້ມູນຈາກຫ້ອງໃນ Calc ຫຼື Writer."

#. phpV6
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id6049684\n"
"help.text"
msgid "These charts update automatically when the source data changes."
msgstr "ແຜນພູມເຫຼົ່ານີ້ຈະອັບເດດໂດຍອັດຕະໂນມັດເມື່ອຂໍ້ມູນຕົ້ນສະບັບມີການປ່ຽນແປງ."

#. 3WEyG
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id2356944\n"
"help.text"
msgid "Insert a chart with a default data set, and then use the Data Table dialog to enter your own data for that chart."
msgstr "ແຊກແຜນພູມດ້ວຍຊຸດຂໍ້ມູນເລີ່ມຕົ້ນ, ແລ້ວໃຊ້ກ່ອງຂໍ້ຄວາມ ຕາຕະລາງຂໍ້ມູນ ເພື່ອປ້ອນຂໍ້ມູນຂອງທ່ານເອງ."

#. mU7MB
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id866115\n"
"help.text"
msgid "These charts can be created in Writer, Impress and Draw."
msgstr "ແຜນພູມເຫຼົ່ານີ້ສາມາດສ້າງໄດ້ໃນ Writer, Impress ແລະ Draw."

#. yf4SJ
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id3146763\n"
"help.text"
msgid "Copy a chart from Calc or Writer into another document."
msgstr "ກັອບປີ້ແຜນພູມຈາກ Calc ຫຼື Writer ໄປໃສ່ເອກະສານອື່ນ."

#. bjYud
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id701315\n"
"help.text"
msgid "These charts are snapshots of the data at the time of copying. They do not change when the source data changes."
msgstr "ແຜນພູມເຫຼົ່ານີ້ແມ່ນພາບຖ່າຍຂອງຂໍ້ມູນໃນເວລາທີ່ກັອບປີ້. ພວກມັນຈະບໍ່ປ່ຽນແປງເມື່ອຂໍ້ມູນຕົ້ນສະບັບປ່ຽນແປງ."

#. u5Bfv
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id4439832\n"
"help.text"
msgid "In Calc, a chart is an object on a sheet that can be copied and pasted on another sheet of the same document, the data series will stay linked to the range on the other sheet. If it is pasted on another Calc document, it has its own chart data table and is no more linked to the original range."
msgstr "ໃນ Calc, ແຜນພູມແມ່ນວັດຖຸໃນແຜ່ນງານທີ່ສາມາດກັອບປີ້ ແລະ ວາງໃສ່ແຜ່ນງານອື່ນຂອງເອກະສານດຽວກັນໄດ້, ຊຸດຂໍ້ມູນຈະຍັງຄົງເຊື່ອມຕໍ່ກັບຊ່ວງຂໍ້ມູນໃນແຜ່ນງານອື່ນ. ຖ້າມັນຖືກວາງໃສ່ເອກະສານ Calc ອື່ນ, ມັນຈະມີຕາຕະລາງຂໍ້ມູນແຜນພູມຂອງມັນເອງ ແລະ ຈະບໍ່ເຊື່ອມຕໍ່ກັບຊ່ວງຂໍ້ມູນຕົ້ນສະບັບອີກຕໍ່ໄປ."

#. qQLu6
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"hd_id719931\n"
"help.text"
msgid "Chart in a Calc spreadsheet"
msgstr "ແຜນພູມໃນຕາຕະລາງຄຳນວນ Calc"

#. G9b8t
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id3150275\n"
"help.text"
msgid "Click inside the cell range that you want to present in your chart."
msgstr "ຄລິກພາຍໃນຊ່ວງຫ້ອງທີ່ທ່ານຕ້ອງການສະແດງໃນແຜນພູມ."

#. DQj3U
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id7211218\n"
"help.text"
msgid "Click the <emph>Insert Chart</emph> icon on the <emph>Standard</emph> toolbar."
msgstr "ຄລິກໄອຄອນ <emph>ແຊກແຜນພູມ</emph> ໃນແຖບເຄື່ອງມື <emph>ມາດຕະຖານ</emph>."

#. gKu2X
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id7549363\n"
"help.text"
msgid "You see a chart preview and the Chart Wizard."
msgstr "ທ່ານຈະເຫັນຕົວຢ່າງແຜນພູມ ແລະ ຕົວຊ່ວຍສ້າງແຜນພູມ."

#. 5yB5v
#: chart_insert.xhp
msgctxt ""
"chart_insert.xhp\n"
"par_id9091769\n"
"help.text"
msgid "Follow the instructions in the <link href=\"text/schart/01/wiz_chart_type.xhp\">Chart Wizard</link> to create the chart."
msgstr "ປະຕິບັດຕາມຄຳແນະນຳໃນ <link href=\"text/schart/01/wiz_chart_type.xhp\">ຕົວຊ່ວຍສ້າງແຜນພູມ</link> ເພື່ອສ້າງແຜນພູມ."

