#. 7Zvps
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3153730\n"
"help.text"
msgid "<ahelp hid=\".\">Sets the Hue component modifiable on the vertical color slider, and the Saturation and Brightness components in the two-dimensional color picker field. Values are expressed in degrees from 0 to 359.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຄ່າສ່ວນປະກອບຂອງສີ (Hue) ໃຫ້ສາມາດປ່ຽນແປງໄດ້ໃນແຖບເລື່ອນສີແນວຕັ້ງ, ແລະ ຄວາມອີ່ມຕົວ (Saturation) ແລະ ຄວາມສະຫວ່າງ (Brightness) ໃນພື້ນທີ່ເລືອກສີສອງມິຕິ. ຄ່າຈະຖືກສະແດງເປັນອົງສາຈາກ 0 ຫາ 359.</ahelp>"

#. fGAJ5
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3154729\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/colorpickerdialog/hueSpinbutton\" visibility=\"hidden\">Set the Hue directly in the HSB color model. Values are expressed in degrees from 0 to 359.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/colorpickerdialog/hueSpinbutton\" visibility=\"hidden\">ຕັ້ງຄ່າສີ (Hue) ໂດຍກົງໃນຮູບແບບສີ HSB. ຄ່າຈະຖືກສະແດງເປັນອົງສາຈາກ 0 ຫາ 359.</ahelp>"

#. C2bUG
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"hd_id3144766\n"
"help.text"
msgid "Saturation"
msgstr "ຄວາມອີ່ມຕົວ (Saturation)"

#. 7KBnT
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3153731\n"
"help.text"
msgid "<ahelp hid=\".\">Sets the Saturation component modifiable on the vertical color slider, and the Hue and Brightness components in the two-dimensional color picker field. Values are expressed in percent (0 to 100).</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຄ່າຄວາມອີ່ມຕົວ (Saturation) ໃຫ້ສາມາດປ່ຽນແປງໄດ້ໃນແຖບເລື່ອນສີແນວຕັ້ງ, ແລະ ສີ (Hue) ແລະ ຄວາມສະຫວ່າງ (Brightness) ໃນພື້ນທີ່ເລືອກສີສອງມິຕິ. ຄ່າຈະຖືກສະແດງເປັນເປີເຊັນ (0 ຫາ 100).</ahelp>"

#. cuCGT
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3153512\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/colorpickerdialog/satSpinbutton\" visibility=\"hidden\">Set the Saturation directly in the HSB color model. Values are expressed in percent (0 to 100).</ahelp>"
msgstr "<ahelp hid=\"cui/ui/colorpickerdialog/satSpinbutton\" visibility=\"hidden\">ຕັ້ງຄ່າຄວາມອີ່ມຕົວ (Saturation) ໂດຍກົງໃນຮູບແບບສີ HSB. ຄ່າຈະຖືກສະແດງເປັນເປີເຊັນ (0 ຫາ 100).</ahelp>"

#. cpAdC
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"hd_id3156180\n"
"help.text"
msgid "Brightness"
msgstr "ຄວາມສະຫວ່າງ (Brightness)"

#. NEpUE
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3153732\n"
"help.text"
msgid "<ahelp hid=\".\">Sets the Brightness component modifiable on the vertical color slider, and the Hue and Saturation components in the two-dimensional color picker field. Values are expressed in percent (0 to 100).</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຄ່າຄວາມສະຫວ່າງ (Brightness) ໃຫ້ສາມາດປ່ຽນແປງໄດ້ໃນແຖບເລື່ອນສີແນວຕັ້ງ, ແລະ ສີ (Hue) ແລະ ຄວາມອີ່ມຕົວ (Saturation) ໃນພື້ນທີ່ເລືອກສີສອງມິຕິ. ຄ່າຈະຖືກສະແດງເປັນເປີເຊັນ (0 ຫາ 100).</ahelp>"

#. uDLZu
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3146969\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/colorpickerdialog/brightSpinbutton\" visibility=\"hidden\">Set the Brightness directly in the HSB color model. Values are expressed in percent (0 to 100).</ahelp>"
msgstr "<ahelp hid=\"cui/ui/colorpickerdialog/brightSpinbutton\" visibility=\"hidden\">ຕັ້ງຄ່າຄວາມສະຫວ່າງ (Brightness) ໂດຍກົງໃນຮູບແບບສີ HSB. ຄ່າຈະຖືກສະແດງເປັນເປີເຊັນ (0 ຫາ 100).</ahelp>"

