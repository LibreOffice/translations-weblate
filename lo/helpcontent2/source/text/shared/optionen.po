msgstr "<link href=\"text/shared/optionen/01030300.xhp\">ຄວາມປອດໄພ</link>"

#. vVGCA
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id3153255\n"
"help.text"
msgid "<ahelp hid=\".\">Defines the security options for saving documents, for web connections, and for opening documents that contain macros.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຕົວເລືອກຄວາມປອດໄພສຳລັບການບັນທຶກເອກະສານ, ການເຊື່ອມຕໍ່ເວັບ ແລະ ການເປີດເອກະສານທີ່ມີມາໂຄຣ.</ahelp>"

#. R3Xf2
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN10640\n"
"help.text"
msgid "Security Options and Warnings"
msgstr "ຕົວເລືອກ ແລະ ຄຳເຕືອນຄວາມປອດໄພ"

#. j35gF
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN10644\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the \"Security Options and Warnings\" dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ \"ຕົວເລືອກ ແລະ ຄຳເຕືອນຄວາມປອດໄພ\".</ahelp>"

#. jDRj8
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"hd_id4076357\n"
"help.text"
msgid "Passwords for web connections"
msgstr "ລະຫັດຜ່ານສຳລັບການເຊື່ອມຕໍ່ເວັບ"

#. 8kRWx
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id8231757\n"
"help.text"
msgid "You can enter a master password to enable easy access to sites that require a user name and password."
msgstr "ທ່ານສາມາດປ້ອນລະຫັດຜ່ານຫຼັກ (master password) ເພື່ອໃຫ້ເຂົ້າເຖິງເວັບໄຊທີ່ຕ້ອງການຊື່ຜູ້ໃຊ້ ແລະ ລະຫັດຜ່ານໄດ້ງ່າຍຂຶ້ນ."

#. Srxem
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"hd_id3168736\n"
"help.text"
msgid "Persistently save passwords for web connections"
msgstr "ບັນທຶກລະຫັດຜ່ານສຳລັບການເຊື່ອມຕໍ່ເວັບແບບຖາວອນ"

#. LvZcG
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id1909848\n"
"help.text"
msgid "<ahelp hid=\".\">If enabled, %PRODUCTNAME will securely store all passwords that you use to access files from web servers. You can retrieve the passwords from the list after you enter the master password.</ahelp>"
msgstr "<ahelp hid=\".\">ຫາກເປີດໃຊ້ງານ, %PRODUCTNAME ຈະເກັບຮັກສາລະຫັດຜ່ານທັງໝົດທີ່ທ່ານໃຊ້ເພື່ອເຂົ້າເຖິງໄຟລ໌ຈາກເວັບເຊີເວີຢ່າງປອດໄພ. ທ່ານສາມາດດຶງລະຫັດຜ່ານຈາກລາຍການໄດ້ຫຼັງຈາກປ້ອນລະຫັດຜ່ານຫຼັກ.</ahelp>"

#. ERTPo
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id3149655\n"
"help.text"
msgid "Old configurations may contain weakly encrypted passwords, in this case an infobar is shown when the application starts to prompt to reenter the master password in order to resave them with stronger encryption."
msgstr "ການກຳນົດຄ່າແບບເກົ່າອາດມີລະຫັດຜ່ານທີ່ຖືກເຂົ້າລະຫັດແບບບໍ່ແໜ້ນໜາ, ໃນກໍລະນີນີ້ ແຖບຂໍ້ມູນຈະສະແດງຂຶ້ນເມື່ອເລີ່ມຕົ້ນແອັບພລິເຄຊັນເພື່ອໃຫ້ປ້ອນລະຫັດຜ່ານຫຼັກຄືນໃໝ່ ເພື່ອບັນທຶກພວກມັນຄືນດ້ວຍການເຂົ້າລະຫັດທີ່ແໜ້ນໜາກວ່າ."

#. TcKkK
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"hd_id3901791\n"
"help.text"
msgid "Protected by a master password (recommended)"
msgstr "ປ້ອງກັນດ້ວຍລະຫັດຜ່ານຫຼັກ (ແນະນຳ)"

#. 5nAWY
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id31527711486980\n"
"help.text"
msgid "Check to enable all connections' passwords to be protected by a master password."
msgstr "ເລືອກເພື່ອໃຫ້ລະຫັດຜ່ານຂອງທຸກການເຊື່ອມຕໍ່ຖືກປ້ອງກັນດ້ວຍລະຫັດຜ່ານຫຼັກ."

#. SioDQ
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"hd_id141527711343312\n"
"help.text"
msgid "Master Password"
msgstr "ລະຫັດຜ່ານຫຼັກ"

#. huKG4
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id4571977\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the Enter Master Password dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບການປ້ອນລະຫັດຜ່ານຫຼັກ.</ahelp>"

#. CaAgb
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id5216223\n"
"help.text"
msgid "<ahelp hid=\"uui/ui/setmasterpassworddlg/password1\" visibility=\"hidden\">Enter the master password.</ahelp>"
msgstr "<ahelp hid=\"uui/ui/setmasterpassworddlg/password1\" visibility=\"hidden\">ປ້ອນລະຫັດຜ່ານຫຼັກ.</ahelp>"

#. C24cQ
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id7067171\n"
"help.text"
msgid "<ahelp hid=\"uui/ui/setmasterpassworddlg/password2\" visibility=\"hidden\">Enter the master password again.</ahelp>"
msgstr "<ahelp hid=\"uui/ui/setmasterpassworddlg/password2\" visibility=\"hidden\">ປ້ອນລະຫັດຜ່ານຫຼັກຄືນໃໝ່.</ahelp>"

#. HKwHf
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id7499313\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the master password to continue.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນລະຫັດຜ່ານຫຼັກເພື່ອດຳເນີນການຕໍ່.</ahelp>"

#. AFYHK
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"hd_id3283486\n"
"help.text"
msgid "Connections"
msgstr "ການເຊື່ອມຕໍ່"

#. JHCMm
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id3472090\n"
"help.text"
msgid "<ahelp hid=\".\">Asks for the master password. If master password is correct, shows the Stored Web Connection Information dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ຖາມຫາລະຫັດຜ່ານຫຼັກ. ຫາກລະຫັດຜ່ານຫຼັກຖືກຕ້ອງ, ຈະສະແດງກ່ອງໂຕ້ຕອບຂໍ້ມູນການເຊື່ອມຕໍ່ເວັບທີ່ຖືກບັນທຶກໄວ້.</ahelp>"

#. QiepC
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id3289590\n"
"help.text"
msgid "The Stored Web Connection Information dialog shows a list of web sites and user names that you entered previously. You can select any entry and remove it from the list. You can view the password for the selected entry."
msgstr "ກ່ອງໂຕ້ຕອບຂໍ້ມູນການເຊື່ອມຕໍ່ເວັບທີ່ຖືກບັນທຶກໄວ້ຈະສະແດງລາຍການເວັບໄຊ ແລະ ຊື່ຜູ້ໃຊ້ທີ່ທ່ານເຄີຍປ້ອນມາກ່ອນ. ທ່ານສາມາດເລືອກລາຍການໃດໜຶ່ງ ແລະ ລຶບມັນອອກຈາກລາຍການໄດ້. ທ່ານສາມາດເບິ່ງລະຫັດຜ່ານສຳລັບລາຍການທີ່ເລືອກໄດ້."

#. LCmGZ
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id7499008\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Removes the selected entry from the list.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບລາຍການທີ່ເລືອກອອກຈາກລາຍການ.</ahelp>"

#. Zj6mt
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id7021088\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Removes all entries from the list.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບລາຍການທັງໝົດອອກຈາກລາຍການ.</ahelp>"

#. mxGYJ
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_id1981261\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Opens a dialog where you can view and change the password for the selected entry.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເປີດກ່ອງໂຕ້ຕອບທີ່ທ່ານສາມາດເບິ່ງ ແລະ ປ່ຽນແປງລະຫັດຜ່ານສຳລັບລາຍການທີ່ເລືອກໄດ້.</ahelp>"

#. ABoCE
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN10687\n"
"help.text"
msgid "Macro security"
msgstr "ຄວາມປອດໄພຂອງມາໂຄຣ"

#. 2rHSt
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN1068B\n"
"help.text"
msgid "Adjust the security level for executing macros and specify trusted macro authors."
msgstr "ປັບລະດັບຄວາມປອດໄພສຳລັບການເຮັດວຽກຂອງມາໂຄຣ ແລະ ລະບຸຜູ້ຂຽນມາໂຄຣທີ່ເຊື່ອຖືໄດ້."

#. rvs9J
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN1068E\n"
"help.text"
msgid "Macro Security"
msgstr "ຄວາມປອດໄພຂອງມາໂຄຣ"

#. ch6a2
#: 01030300.xhp
msgctxt ""
"01030300.xhp\n"
"par_idN10692\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optsecuritypage/macro\">Opens the <emph>Macro Security</emph> dialog.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optsecuritypage/macro\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ຄວາມປອດໄພຂອງມາໂຄຣ</emph>.</ahelp>"

#. cLpMK
