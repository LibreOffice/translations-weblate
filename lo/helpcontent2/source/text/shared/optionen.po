msgctxt ""
"01010400.xhp\n"
"hd_id3154307\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. 3PU3U
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3145673\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optlingupage/lingumodulesedit\">To edit a language module, select it and click <emph>Edit</emph>.</ahelp> The <link href=\"text/shared/optionen/01010401.xhp\"><emph>Edit Modules</emph></link> dialog appears."
msgstr "<ahelp hid=\"cui/ui/optlingupage/lingumodulesedit\">ເພື່ອແກ້ໄຂໂມດູນພາສາ, ໃຫ້ເລືອກມັນແລ້ວຄລິກ <emph>ແກ້ໄຂ</emph>.</ahelp> ກ່ອງສົນທະນາ <link href=\"text/shared/optionen/01010401.xhp\"><emph>ແກ້ໄຂໂມດູນ</emph></link> ຈະປະກົດຂຶ້ນ."

#. GBhhC
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3153348\n"
"help.text"
msgid "User-defined dictionaries"
msgstr "ພົດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງ"

#. HRXBC
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3155419\n"
"help.text"
msgid "<ahelp hid=\".\">Lists the available user dictionaries.</ahelp> Mark the user dictionaries that you want to use for spelling and hyphenation."
msgstr "<ahelp hid=\".\">ສະແດງລາຍຊື່ພົດຈະນານຸກົມຜູ້ໃຊ້ທີ່ມີຢູ່.</ahelp> ໝາຍໃສ່ພົດຈະນານຸກົມຜູ້ໃຊ້ທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບການສະກົດຄຳ ແລະ ການຍັດແຖວ."

#. hFB5J
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3144511\n"
"help.text"
msgid "New"
msgstr "ໃໝ່"

#. UyKAq
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3146794\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optlingupage/lingudictsnew\">Opens the <emph>New Dictionary</emph> dialog, in which you can name a new user-defined dictionary or dictionary of exceptions and specify the language.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optlingupage/lingudictsnew\">ເປີດກ່ອງສົນທະນາ <emph>ພົດຈະນານຸກົມໃໝ່</emph>, ເຊິ່ງທ່ານສາມາດຕັ້ງຊື່ພົດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງໃໝ່ ຫຼື ພົດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ ແລະ ລະບຸພາສາໄດ້.</ahelp>"

#. pMKyw
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3151054\n"
"help.text"
msgid "New Dictionary"
msgstr "ພົດຈະນານຸກົມໃໝ່"

#. 6zHg5
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3153360\n"
"help.text"
msgid "<ahelp hid=\".\">In the <emph>Dictionary</emph> section you can name a new user-defined dictionary or dictionary of exceptions and specify the language.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນສ່ວນ <emph>ພົດຈະນານຸກົມ</emph> ທ່ານສາມາດຕັ້ງຊື່ພົດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງໃໝ່ ຫຼື ພົດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ ແລະ ລະບຸພາສາໄດ້.</ahelp>"

#. Gr7vt
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150398\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. 22C7T
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3153192\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optnewdictionarydialog/nameedit\">Specifies the name of the new custom dictionary.</ahelp> The file extension \"*.DIC\" is automatically appended."
msgstr "<ahelp hid=\"cui/ui/optnewdictionarydialog/nameedit\">ລະບຸຊື່ຂອງພົດຈະນານຸກົມກຳນົດເອງໃໝ່.</ahelp> ນາມສະກຸນໄຟລ໌ \"*.DIC\" ຈະຖືກຕໍ່ທ້າຍໂດຍອັດຕະໂນມັດ."

#. wcybh
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150767\n"
"help.text"
msgid "Language"
msgstr "ພາສາ"

#. VTpXB
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3148920\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optnewdictionarydialog/language\">By selecting a certain language you can limit the use of the custom dictionary.</ahelp> By selecting <emph>All</emph> the custom dictionary is used independently of the current language."
msgstr "<ahelp hid=\"cui/ui/optnewdictionarydialog/language\">ໂດຍການເລືອກພາສາໃດໜຶ່ງ ທ່ານສາມາດຈຳກັດການນຳໃຊ້ພົດຈະນານຸກົມກຳນົດເອງໄດ້.</ahelp> ຖ້າເລືອກ <emph>ທັງໝົດ</emph> ພົດຈະນານຸກົມກຳນົດເອງຈະຖືກນຳໃຊ້ໂດຍບໍ່ຂຶ້ນກັບພາສາປັດຈຸບັນ."

#. DDSU6
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3153106\n"
"help.text"
msgid "Exceptions (-)"
msgstr "ຂໍ້ຍົກເວັ້ນ (-)"

#. APQJq
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3149561\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optnewdictionarydialog/except\">Specifies whether you wish to avoid certain words in your documents.</ahelp> In this way, you can create a custom dictionary of all the words to be avoided. If this exception dictionary is activated, during spellchecking you receive a corresponding note about any words which should be avoided."
msgstr "<ahelp hid=\"cui/ui/optnewdictionarydialog/except\">ລະບຸວ່າທ່ານຕ້ອງການຫຼີກເວັ້ນບາງຄຳສັບໃນເອກະສານຂອງທ່ານຫຼືບໍ່.</ahelp> ດ້ວຍວິທີນີ້, ທ່ານສາມາດສ້າງພົດຈະນານຸກົມກຳນົດເອງຂອງຄຳສັບທັງໝົດທີ່ຄວນຫຼີກເວັ້ນ. ຖ້າພົດຈະນານຸກົມຂໍ້ຍົກເວັ້ນນີ້ຖືກເປີດໃຊ້, ໃນລະຫວ່າງການກວດສອບການສະກົດຄຳ ທ່ານຈະໄດ້ຮັບການແຈ້ງເຕືອນກ່ຽວກັບຄຳສັບໃດໜຶ່ງທີ່ຄວນຫຼີກເວັ້ນ."

#. fwK2g
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3145785\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. MnrMo
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3152576\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optlingupage/lingudictsedit\">Opens the <emph>Edit custom dictionary</emph> dialog, in which you can add to your custom dictionary or edit existing entries.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optlingupage/lingudictsedit\">ເປີດກ່ອງສົນທະນາ <emph>ແກ້ໄຂພົດຈະນານຸກົມກຳນົດເອງ</emph>, ເຊິ່ງທ່ານສາມາດເພີ່ມຄຳສັບໃສ່ພົດຈະນານຸກົມກຳນົດເອງຂອງທ່ານ ຫຼື ແກ້ໄຂລາຍການທີ່ມີຢູ່ໄດ້.</ahelp>"

#. H5mNz
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3147436\n"
"help.text"
msgid "<ahelp hid=\".\">In the <emph>Edit Custom Dictionary</emph> dialog you have the option to enter new terms or edit existing entries.</ahelp> If you edit an exception dictionary, the dialog has the added facility of defining an exception for a word. During the spellcheck this exception is then listed as a suggestion."
msgstr "<ahelp hid=\".\">ໃນກ່ອງສົນທະນາ <emph>ແກ້ໄຂພົດຈະນານຸກົມກຳນົດເອງ</emph> ທ່ານມີຕົວເລືອກທີ່ຈະປ້ອນຄຳສັບໃໝ່ ຫຼື ແກ້ໄຂລາຍການທີ່ມີຢູ່.</ahelp> ຖ້າທ່ານແກ້ໄຂພົດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ, ກ່ອງສົນທະນາຈະມີຄວາມສາມາດເພີ່ມເຕີມໃນການກຳນົດຂໍ້ຍົກເວັ້ນສຳລັບຄຳສັບ. ໃນລະຫວ່າງການກວດສອບການສະກົດຄຳ ຂໍ້ຍົກເວັ້ນນີ້ຈະຖືກສະແດງເປັນຄຳແນະນຳ."

#. AkpMA
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3145750\n"
"help.text"
msgid "When a dictionary is edited, a check is made on the status of the file. If the file is write-protected, it cannot be changed. The buttons <emph>New</emph> and <emph>Delete</emph> are then deactivated."
msgstr "ເມື່ອມີການແກ້ໄຂພົດຈະນານຸກົມ, ຈະມີການກວດສອບສະຖານະຂອງໄຟລ໌. ຖ້າໄຟລ໌ຖືກປ້ອງກັນການຂຽນ, ມັນຈະບໍ່ສາມາດປ່ຽນແປງໄດ້. ປຸ່ມ <emph>ໃໝ່</emph> ແລະ <emph>ລຶບ</emph> ຈະຖືກປິດການໃຊ້ງານ."

#. yYKDD
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150116\n"
"help.text"
msgid "Book"
msgstr "ປຶ້ມ"

#. CVmCJ
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3147394\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editdictionarydialog/book\">Specifies the book to be edited.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editdictionarydialog/book\">ລະບຸປຶ້ມ (ພົດຈະນານຸກົມ) ທີ່ຈະແກ້ໄຂ.</ahelp>"

#. C7hDb
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3154730\n"
"help.text"
msgid "<variable id=\"ignore\">The <emph>List of Ignored Words (All)</emph> includes all words that have been marked with <emph>Ignore</emph> during spellcheck. This list is valid only for the current spellcheck.</variable>"
msgstr "<variable id=\"ignore\"><emph>ລາຍການຄຳສັບທີ່ຖືກລະເວັ້ນ (ທັງໝົດ)</emph> ລວມມີຄຳສັບທັງໝົດທີ່ຖືກໝາຍວ່າ <emph>ລະເວັ້ນ</emph> ໃນລະຫວ່າງການກວດສອບການສະກົດຄຳ. ລາຍການນີ້ມີຜົນສະເພາະສຳລັບການກວດສອບການສະກົດຄຳຄັ້ງປັດຈຸບັນເທົ່ານັ້ນ.</variable>"

#. rgJHG
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3154757\n"
"help.text"
msgid "The <emph>IgnoreAllList</emph> entry cannot be selected and cannot be deleted. Only the words included as content can be deleted. This happens automatically each time that $[officename] is closed."
msgstr "ລາຍການ <emph>IgnoreAllList</emph> ບໍ່ສາມາດເລືອກ ແລະ ບໍ່ສາມາດລຶບໄດ້. ສະເພາະຄຳສັບທີ່ລວມຢູ່ໃນເນື້ອຫາເທົ່ານັ້ນທີ່ສາມາດລຶບໄດ້. ສິ່ງນີ້ຈະເກີດຂຶ້ນໂດຍອັດຕະໂນມັດທຸກຄັ້ງທີ່ $[officename] ຖືກປິດ."

#. hR5Be
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3149018\n"
"help.text"
msgid "Language"
msgstr "ພາສາ"

#. nEeVZ
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3154255\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editdictionarydialog/lang\">Assigns a new language to the current custom dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editdictionarydialog/lang\">ກຳນົດພາສາໃໝ່ໃຫ້ກັບພົດຈະນານຸກົມກຳນົດເອງປັດຈຸບັນ.</ahelp>"

#. CygEN
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3151189\n"
"help.text"
msgid "Word"
msgstr "ຄຳສັບ"

#. DjBVy
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3151252\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editdictionarydialog/word\">You can type a new word for inclusion in the dictionary. In the list below you will see the contents of the current custom dictionary.</ahelp> If you select a word from this list it is displayed in the text field. If you type a word with a trailing = character, such as \"AutoComplete=\", the word is never automatically hyphenated and no hyphenation is suggested. Typing \"Auto=Complete\" results in the word being hyphenated, or a hyphenation suggested, where you insert the = sign."
msgstr "<ahelp hid=\"cui/ui/editdictionarydialog/word\">ທ່ານສາມາດພິມຄຳສັບໃໝ່ເພື່ອລວມເຂົ້າໃນພົດຈະນານຸກົມ. ໃນລາຍຊື່ຂ້າງລຸ່ມນີ້ ທ່ານຈະເຫັນເນື້ອຫາຂອງພົດຈະນານຸກົມກຳນົດເອງປັດຈຸບັນ.</ahelp> ຖ້າທ່ານເລືອກຄຳສັບຈາກລາຍຊື່ນີ້ ມັນຈະຖືກສະແດງໃນຊ່ອງຂໍ້ຄວາມ. ຖ້າທ່ານພິມຄຳສັບທີ່ມີເຄື່ອງໝາຍ = ຢູ່ທ້າຍ ເຊັ່ນ \"AutoComplete=\", ຄຳສັບນັ້ນຈະບໍ່ຖືກຍັດແຖວໂດຍອັດຕະໂນມັດ ແລະ ຈະບໍ່ມີການແນະນຳການຍັດແຖວ. ການພິມ \"Auto=Complete\" ຈະເຮັດໃຫ້ຄຳສັບຖືກຍັດແຖວ ຫຼື ມີການແນະນຳການຍັດແຖວຢູ່ບ່ອນທີ່ທ່ານໃສ່ເຄື່ອງໝາຍ =."

#. yWnTn
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3151253\n"
"help.text"
msgid "You can use a [] block instead of the = sign to specify character changes before the hyphenation break. Possible character changes: (1) Extra characters, for example <emph>tug[g]gumi</emph> results the correct hyphenation “tugg- gummi” of the Swedish word “tuggummi”. (2) Character removing specified by a digit, for example <emph>paral·[1]lel</emph> results correct hyphenation “paral- lel” of the Catalan word “paral·lel”, removing one character before the break point. (3) Both removed and extra characters, for example <emph>cafee[2é]tje</emph> results correct hyphenation “café- tje” of the Dutch word “cafeetje”, removing two characters before the break point, and adding an extra one."
msgstr "ທ່ານສາມາດໃຊ້ບລັອກ [] ແທນເຄື່ອງໝາຍ = ເພື່ອລະບຸການປ່ຽນແປງຕົວອັກສອນກ່ອນການຍັດແຖວ. ການປ່ຽນແປງຕົວອັກສອນທີ່ເປັນໄປໄດ້: (1) ຕົວອັກສອນເພີ່ມເຕີມ, ຕົວຢ່າງ <emph>tug[g]gumi</emph> ສົ່ງຜົນໃຫ້ການຍັດແຖວທີ່ຖືກຕ້ອງແມ່ນ “tugg- gummi” ຂອງຄຳສັບພາສາສະວີເດັນ “tuggummi”. (2) ການລຶບຕົວອັກສອນທີ່ລະບຸດ້ວຍຕົວເລກ, ຕົວຢ່າງ <emph>paral·[1]lel</emph> ສົ່ງຜົນໃຫ້ການຍັດແຖວທີ່ຖືກຕ້ອງແມ່ນ “paral- lel” ຂອງຄຳສັບພາສາກາຕາລັງ “paral·lel”, ໂດຍການລຶບຕົວອັກສອນໜຶ່ງຕົວກ່ອນຈຸດແຍກ. (3) ທັງລຶບອອກ ແລະ ເພີ່ມຕົວອັກສອນ, ຕົວຢ່າງ <emph>cafee[2é]tje</emph> ສົ່ງຜົນໃຫ້ການຍັດແຖວທີ່ຖືກຕ້ອງແມ່ນ “café- tje” ຂອງຄຳສັບພາສາດັດ “cafeetje”, ໂດຍການລຶບຕົວອັກສອນສອງຕົວກ່ອນຈຸດແຍກ ແລະ ເພີ່ມຕົວອັກສອນໃໝ່ເຂົ້າໄປ."

#. P5pVw
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3155175\n"
"help.text"
msgid "Replace By or Grammar By"
msgstr "ແທນທີ່ດ້ວຍ ຫຼື ໄວຍາກອນໂດຍ"

#. UEJxL
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3147323\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editdictionarydialog/replace\">This input field is only available if you are editing an exception dictionary or a language-dependent custom dictionary. In exception dictionaries, the field shows the alternative suggestion for the current word in the \"Word\" text box. In language-dependent custom dictionaries, the field contains a known root word, as a model of affixation of the new word or its usage in compound words. For example, in a German custom dictionary, the new word “Litschi” (lychee) with the model word “Gummi” (gum) will result recognition of “Litschis” (lychees), “Litschibaum” (lychee tree), “Litschifrucht” (lychee fruit) etc.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editdictionarydialog/replace\">ຊ່ອງປ້ອນຂໍ້ມູນນີ້ຈະໃຊ້ໄດ້ກໍຕໍ່ເມື່ອທ່ານກຳລັງແກ້ໄຂວັດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ ຫຼື ວັດຈະນານຸກົມກຳນົດເອງທີ່ຂຶ້ນກັບພາສາ. ໃນວັດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ, ຊ່ອງດັ່ງກ່າວຈະສະແດງຄຳແນະນຳທາງເລືອກສຳລັບຄຳສັບປັດຈຸບັນໃນກ່ອງຂໍ້ຄວາມ \"ຄຳສັບ\". ໃນວັດຈະນານຸກົມກຳນົດເອງທີ່ຂຶ້ນກັບພາສາ, ຊ່ອງນີ້ຈະບັນຈຸຄຳຮາກທີ່ຮູ້ຈັກ, ເພື່ອເປັນແບບຢ່າງໃນການຕື່ມວິພັດປັດໄຈຂອງຄຳສັບໃໝ່ ຫຼື ການນຳໃຊ້ໃນຄຳປະສົມ. ຕົວຢ່າງ, ໃນວັດຈະນານຸກົມກຳນົດເອງຂອງພາສາເຢຍລະມັນ, ຄຳສັບໃໝ່ \"Litschi\" (ໝາກລີ້ນຈີ່) ທີ່ມີຄຳແບບຢ່າງແມ່ນ \"Gummi\" (ຢາງ) ຈະສົ່ງຜົນໃຫ້ມີການຮັບຮູ້ຄຳວ່າ \"Litschis\", \"Litschibaum\" (ຕົ້ນລີ້ນຈີ່), \"Litschifrucht\" (ໝາກລີ້ນຈີ່) ແລະ ອື່ນໆ.</ahelp>"

#. SuYV9
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3147361\n"
"help.text"
msgid "New"
msgstr "ໃໝ່"

#. RBs57
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3163808\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editdictionarydialog/newreplace\">Adds the word in the <emph>Word</emph> text field to your current custom dictionary. The word in the <emph>Suggestion</emph> field is also added when working with exception dictionaries.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editdictionarydialog/newreplace\">ເພີ່ມຄຳສັບໃນຊ່ອງຂໍ້ຄວາມ <emph>ຄຳສັບ</emph> ໃສ່ໃນພົດຈະນານຸກົມກຳນົດເອງປັດຈຸບັນຂອງທ່ານ. ຄຳສັບໃນຊ່ອງ <emph>ຄຳແນະນຳ</emph> ຈະຖືກເພີ່ມເຂົ້າໄປນຳເມື່ອເຮັດວຽກກັບພົດຈະນານຸກົມຂໍ້ຍົກເວັ້ນ.</ahelp>"

#. BnYrE
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3145790\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Removes the marked word from the current custom dictionary.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເອົາຄຳສັບທີ່ໝາຍໄວ້ອອກຈາກພົດຈະນານຸກົມກຳນົດເອງປັດຈຸບັນ.</ahelp>"

#. Unsfn
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3151277\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Deletes the selected dictionary after a confirmation, provided it is not write-protected.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບພົດຈະນານຸກົມທີ່ເລືອກຫຼັງຈາກມີການຢືນຢັນ, ໂດຍມີເງື່ອນໄຂວ່າພົດຈະນານຸກົມນັ້ນຈະຕ້ອງບໍ່ຖືກປ້ອງກັນການຂຽນ.</ahelp>"

#. h7WRT
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3149032\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. owcVJ
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3145259\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optlingupage/linguoptions\">Defines the options for the spellcheck and hyphenation.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optlingupage/linguoptions\">ກຳນົດຕົວເລືອກສຳລັບການກວດສອບການສະກົດຄຳ ແລະ ການຍັດແຖວ.</ahelp>"

#. s6eeZ
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3149965\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. 2w8AR
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3153231\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optlingupage/linguoptionsedit\">If you want to change a value, select the entry and then click <emph>Edit</emph>.</ahelp> You will see a dialog for entering a new value."
msgstr "<ahelp hid=\"cui/ui/optlingupage/linguoptionsedit\">ຖ້າທ່ານຕ້ອງການປ່ຽນຄ່າ, ໃຫ້ເລືອກລາຍການນັ້ນແລ້ວຄລິກ <emph>ແກ້ໄຂ</emph>.</ahelp> ທ່ານຈະເຫັນກ່ອງສົນທະນາສຳລັບປ້ອນຄ່າໃໝ່."

#. D4KJG
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150983\n"
"help.text"
msgid "Check uppercase words"
msgstr "ກວດສອບຄຳສັບທີ່ເປັນຕົວພິມໃຫຍ່"

#. vBtGy
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3152582\n"
"help.text"
msgid "Specifies that capitalization is checked during spellcheck."
msgstr "ລະບຸໃຫ້ມີການກວດສອບຕົວພິມໃຫຍ່ໃນລະຫວ່າງການກວດສອບການສະກົດຄຳ."

#. 87fhY
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150826\n"
"help.text"
msgid "Check words with numbers."
msgstr "ກວດສອບຄຳສັບທີ່ມີຕົວເລກ."

#. CUMqd
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3150208\n"
"help.text"
msgid "Specifies that words that contain numbers as well as letters are to be checked."
msgstr "ລະບຸໃຫ້ມີການກວດສອບຄຳສັບທີ່ມີທັງຕົວເລກ ແລະ ຕົວອັກສອນ."

#. gBfL7
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3166424\n"
"help.text"
msgid "Check special regions"
msgstr "ກວດສອບສ່ວນພິເສດ"

#. EpaaL
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3150345\n"
"help.text"
msgid "Specifies that special regions, such as drawing text, are checked during spellcheck."
msgstr "ລະບຸໃຫ້ມີການກວດສອບສ່ວນພິເສດ ເຊັ່ນ ຂໍ້ຄວາມໃນຮູບແຕ້ມ ໃນລະຫວ່າງການກວດສອບການສະກົດຄຳ."

#. FPMMT
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3166429\n"
"help.text"
msgid "Check spelling as you type"
msgstr "ກວດສອບການສະກົດຄຳໃນຂະນະທີ່ພິມ"

#. 89nYM
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3155531\n"
"help.text"
msgid "<variable id=\"automatisch\"><ahelp hid=\".uno:SpellOnline\">Automatically checks spelling as you type, and underlines errors.</ahelp></variable>"
msgstr "<variable id=\"automatisch\"><ahelp hid=\".uno:SpellOnline\">ກວດສອບການສະກົດຄຳໂດຍອັດຕະໂນມັດໃນຂະນະທີ່ທ່ານພິມ, ແລະ ຂີດກ້ອງຄຳທີ່ຜິດ.</ahelp></variable>"

#. DxCYj
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3156291\n"
"help.text"
msgid "Typing errors are highlighted in the document with a red underline. If you place the cursor over a word marked in this way, you can open the context menu to obtain a list of corrections. Select a correction to replace the word. If you make the same mistake again while editing the document, it will be marked as an error again."
msgstr "ຄຳທີ່ພິມຜິດຈະຖືກເນັ້ນໃນເອກະສານດ້ວຍການຂີດກ້ອງສີແດງ. ຖ້າທ່ານວາງເຄີເຊີໄວ້ເທິງຄຳສັບທີ່ຖືກໝາຍໄວ້ແບບນັ້ນ, ທ່ານສາມາດເປີດເມນູຄລິກຂວາ (context menu) ເພື່ອເບິ່ງລາຍການຄຳທີ່ຖືກຕ້ອງ. ເລືອກຄຳທີ່ຖືກຕ້ອງເພື່ອແທນທີ່ຄຳຜິດ. ຖ້າທ່ານເຮັດຜິດແບບເດີມອີກໃນຂະນະທີ່ແກ້ໄຂເອກະສານ, ມັນຈະຖືກໝາຍວ່າຜິດອີກຄັ້ງ."

#. riFFL
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3153815\n"
"help.text"
msgid "To place the word pair in the <link href=\"text/shared/01/06040200.xhp\">AutoCorrect replacement table</link>, open the <link href=\"text/shared/01/06040500.xhp\">AutoCorrect context menu</link> and choose <emph>AutoCorrect</emph>. Make your selection from the submenu. The word is replaced and at the same time the word pair is placed in the replacement table."
msgstr "ເພື່ອໃສ່ຄູ່ຄຳສັບໃນ <link href=\"text/shared/01/06040200.xhp\">ຕາຕະລາງການແທນທີ່ຂອງການແກ້ຄຳຜິດອັດຕະໂນມັດ</link>, ໃຫ້ເປີດ <link href=\"text/shared/01/06040500.xhp\">ເມນູຄລິກຂວາຂອງການແກ້ຄຳຜິດອັດຕະໂນມັດ</link> ແລ້ວເລືອກ <emph>ແກ້ໄຂຄຳຜິດອັດຕະໂນມັດ</emph>. ເລືອກຈາກເມນູຍ່ອຍ. ຄຳສັບຈະຖືກແທນທີ່ ແລະ ໃນຂະນະດຽວກັນຄູ່ຄຳສັບນັ້ນຈະຖືກຈັດໄວ້ໃນຕາຕະລາງການແທນທີ່."

#. jX9FE
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3150111\n"
"help.text"
msgid "Minimal number of characters for hyphenation"
msgstr "ຈຳນວນຕົວອັກສອນຕໍ່າສຸດສຳລັບການຍັດແຖວ"

#. XBxeP
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3150316\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the minimum number of characters required for automatic hyphenation to be applied.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຈຳນວນຕົວອັກສອນຕໍ່າສຸດທີ່ຕ້ອງການ ເພື່ອໃຫ້ມີການຍັດແຖວອັດຕະໂນມັດ.</ahelp>"

#. 256wd
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3148823\n"
"help.text"
msgid "Characters before line break"
msgstr "ຕົວອັກສອນກ່ອນການຂຶ້ນແຖວໃໝ່"

#. fuRGi
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3156029\n"
"help.text"
msgid "<ahelp hid=\".\">Sets the minimum number of characters of the word to be hyphenated that must remain at the end of the line.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຄ່າຈຳນວນຕົວອັກສອນຕໍ່າສຸດຂອງຄຳສັບທີ່ຈະຖືກຍັດແຖວ ເຊິ່ງຈະຕ້ອງຍັງຄົງຄ້າງຢູ່ທ້າຍແຖວ.</ahelp>"

#. Gq63n
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3154956\n"
"help.text"
msgid "Characters after line break"
msgstr "ຕົວອັກສອນຫຼັງການຂຶ້ນແຖວໃໝ່"

#. me6ju
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3149439\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the minimum number of characters of a hyphenated word required at the next line.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຈຳນວນຕົວອັກສອນຕໍ່າສຸດຂອງຄຳສັບທີ່ຖືກຍັດແຖວ ທີ່ຕ້ອງການໃນແຖວຖັດໄປ.</ahelp>"

#. iY2yJ
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3156337\n"
"help.text"
msgid "Hyphenate without inquiry"
msgstr "ຍັດແຖວໂດຍບໍ່ຕ້ອງຖາມ"

#. PtFpp
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3151130\n"
"help.text"
msgid "Specifies that you will never be asked for a manual hyphenation. If the field is not marked, when a word is not recognized you will be presented with a dialog for entering hyphens."
msgstr "ລະບຸວ່າທ່ານຈະບໍ່ຖືກຖາມໃຫ້ຍັດແຖວດ້ວຍຕົນເອງ. ຖ້າຊ່ອງນີ້ບໍ່ໄດ້ຖືກໝາຍໄວ້, ເມື່ອລະບົບບໍ່ຮູ້ຈັກຄຳສັບໃດໜຶ່ງ ມັນຈະສະແດງກ່ອງສົນທະນາເພື່ອໃຫ້ທ່ານໃສ່ເຄື່ອງໝາຍຂີດຕໍ່ (hyphen) ເອງ."

#. cEiZf
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"hd_id3155900\n"
"help.text"
msgid "Hyphenate special regions"
msgstr "ຍັດແຖວໃນສ່ວນພິເສດ"

#. z7EA5
#: 01010400.xhp
msgctxt ""
"01010400.xhp\n"
"par_id3155098\n"
"help.text"
msgid "Specifies that hyphenation will also be carried out in footnotes, headers and footers."
msgstr "ລະບຸໃຫ້ມີການຍັດແຖວໃນເຊີງອັດ (footnote), ຫົວບົດ ແລະ ທ້າຍບົດນຳ."

#. xh8LV
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"tit\n"
"help.text"
msgid "Edit module"
msgstr "ແກ້ໄຂໂມດູນ"

#. cBBRb
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"bm_id3154230\n"
"help.text"
msgid "<bookmark_value>spellcheck; activating for a language</bookmark_value><bookmark_value>spelling; activating for a language</bookmark_value><bookmark_value>hyphenation; activating for a language</bookmark_value><bookmark_value>thesaurus; activating for a language</bookmark_value><bookmark_value>languages; activating modules</bookmark_value><bookmark_value>dictionaries;creating</bookmark_value><bookmark_value>user-defined dictionaries;creating</bookmark_value>"
msgstr "<bookmark_value>ກວດສອບການສະກົດຄຳ; ການເປີດໃຊ້ສຳລັບພາສາ</bookmark_value><bookmark_value>ການສະກົດຄຳ; ການເປີດໃຊ້ສຳລັບພາສາ</bookmark_value><bookmark_value>ການຍັດແຖວ; ການເປີດໃຊ້ສຳລັບພາສາ</bookmark_value><bookmark_value>ພົດຈະນານຸກົມຄຳພົວພັນ; ການເປີດໃຊ້ສຳລັບພາສາ</bookmark_value><bookmark_value>ພາສາ; ການເປີດໃຊ້ໂມດູນ</bookmark_value><bookmark_value>ພົດຈະນານຸກົມ; ການສ້າງ</bookmark_value><bookmark_value>ພົດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດ; ການສ້າງ</bookmark_value>"

#. UDsCJ
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3154046\n"
"help.text"
msgid "<variable id=\"edit_module_h1\"><link href=\"text/shared/optionen/01010401.xhp\">Edit module</link></variable>"
msgstr "<variable id=\"edit_module_h1\"><link href=\"text/shared/optionen/01010401.xhp\">ແກ້ໄຂໂມດູນ</link></variable>"

#. zdH9C
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3148685\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. xfrTM
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3148473\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editmodulesdialog/lingudicts\">Specifies the language and the available spelling, hyphenation and Thesaurus sub-modules for the selected module.</ahelp> You can arrange the sub-modules by priority."
msgstr "<ahelp hid=\"cui/ui/editmodulesdialog/lingudicts\">ລະບຸພາສາ ແລະ ໂມດູນຍ່ອຍສຳລັບການສະກົດຄຳ, ການຍັດແຖວ ແລະ ພົດຈະນານຸກົມຄຳພົວພັນ ທີ່ມີໃຫ້ໃຊ້ສຳລັບໂມດູນທີ່ເລືອກ.</ahelp> ທ່ານສາມາດຈັດລຳດັບຄວາມສຳຄັນຂອງໂມດູນຍ່ອຍໄດ້."

#. hxdgC
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3155449\n"
"help.text"
msgid "Select the language from the <emph>Language</emph> list."
msgstr "ເລືອກພາສາຈາກລາຍການ <emph>ພາສາ</emph>."

#. QrUXC
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3144510\n"
"help.text"
msgid "Mark all modules that are to be activated for this language under the headings Spelling, Hyphenation and Thesaurus."
msgstr "ໝາຍເອົາໂມດູນທັງໝົດທີ່ຈະຖືກເປີດໃຊ້ສຳລັບພາສານີ້ ພາຍໃຕ້ຫົວຂໍ້ ການສະກົດຄຳ, ການຍັດແຖວ ແລະ ພົດຈະນານຸກົມຄຳພົວພັນ."

#. RmC8D
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3154923\n"
"help.text"
msgid "As long as you have more than one sub-module available for one area, the sub-modules for spelling and the Thesaurus are processed in the sequence in which they are listed. You can change the sequence using the <emph>Move Up</emph> and <emph>Move Down</emph> buttons."
msgstr "ຕາບໃດທີ່ທ່ານມີໂມດູນຍ່ອຍຫຼາຍກວ່າໜຶ່ງໂມດູນສຳລັບແຕ່ລະດ້ານ, ໂມດູນຍ່ອຍສຳລັບການສະກົດຄຳ ແລະ ພົດຈະນານຸກົມຄຳພົວພັນ ຈະຖືກປະມວນຜົນຕາມລຳດັບທີ່ລະບຸໄວ້. ທ່ານສາມາດປ່ຽນລຳດັບໄດ້ໂດຍການໃຊ້ປຸ່ມ <emph>ຍ້າຍຂຶ້ນ</emph> ແລະ <emph>ຍ້າຍລົງ</emph>."

#. DbVZd
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3148663\n"
"help.text"
msgid "Only one sub-module can be activated under Hyphenation."
msgstr "ສາມາດເປີດໃຊ້ໄດ້ພຽງໂມດູນຍ່ອຍດຽວເທົ່ານັ້ນພາຍໃຕ້ ການຍັດແຖວ."

#. svUFH
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3150398\n"
"help.text"
msgid "Language"
msgstr "ພາສາ"

#. wBWkS
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3152933\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editmodulesdialog/language\">Specifies the language of the module.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editmodulesdialog/language\">ລະບຸພາສາຂອງໂມດູນ.</ahelp>"

#. iSXVF
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3156214\n"
"help.text"
msgid "For all language selection fields in <item type=\"productname\">%PRODUCTNAME</item>, the following applies:"
msgstr "ສຳລັບທຸກຊ່ອງເລືອກພາສາໃນ <item type=\"productname\">%PRODUCTNAME</item>, ຈະມີເງື່ອນໄຂດັ່ງນີ້:"

#. kG3XF
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3148922\n"
"help.text"
msgid "<variable id=\"sprachenfeld\">A language entry has a check mark in front of it if the spellcheck is activated for this language.</variable>"
msgstr "<variable id=\"sprachenfeld\">ລາຍການພາສາຈະມີເຄື່ອງໝາຍຖືກຢູ່ທາງໜ້າ ຖ້າການກວດສອບການສະກົດຄຳຖືກເປີດໃຊ້ສຳລັບພາສານັ້ນ.</variable>"

#. csACD
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3145419\n"
"help.text"
msgid "Move up"
msgstr "ຍ້າຍຂຶ້ນ"

#. kbiHq
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3154216\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editmodulesdialog/up\">Increases the priority of the module selected in the list box by one level.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editmodulesdialog/up\">ເພີ່ມລຳດັບຄວາມສຳຄັນຂອງໂມດູນທີ່ເລືອກໃນກ່ອງລາຍຊື່ຂຶ້ນໜຶ່ງລະດັບ.</ahelp>"

#. YMDeu
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3158407\n"
"help.text"
msgid "Move down"
msgstr "ຍ້າຍລົງ"

#. stUFL
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3155429\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editmodulesdialog/down\">Decreases the priority of the module selected in the list box by one level.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editmodulesdialog/down\">ຫຼຸດລຳດັບຄວາມສຳຄັນຂອງໂມດູນທີ່ເລືອກໃນກ່ອງລາຍຊື່ລົງໜຶ່ງລະດັບ.</ahelp>"

#. dHbGP
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"hd_id3161832\n"
"help.text"
msgid "Reset"
msgstr "ຄືນຄ່າໃໝ່"

#. dEDZC
#: 01010401.xhp
msgctxt ""
"01010401.xhp\n"
"par_id3155307\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/editmodulesdialog/back\">Click here to undo the current changes in the list box.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/editmodulesdialog/back\">ຄລິກບ່ອນນີ້ເພື່ອຍົກເລີກການປ່ຽນແປງປັດຈຸບັນໃນກ່ອງລາຍຊື່.</ahelp>"

#. M3rSX
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"tit\n"
"help.text"
msgid "Selecting a new color"
msgstr "ການເລືອກສີໃໝ່"

#. B6n3s
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"bm_id3150771\n"
"help.text"
msgid "<bookmark_value>pick color</bookmark_value><bookmark_value>color selector</bookmark_value>"
msgstr "<bookmark_value>ເລືອກສີ</bookmark_value><bookmark_value>ຕົວເລືອກສີ</bookmark_value>"

#. FExSo
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"hd_id3153126\n"
"help.text"
msgid "<variable id=\"colorpickerh1\"><link href=\"text/shared/optionen/01010501.xhp\">Selecting a new color</link></variable>"
msgstr "<variable id=\"colorpickerh1\"><link href=\"text/shared/optionen/01010501.xhp\">ການເລືອກສີໃໝ່</link></variable>"

#. 2DKci
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3150771\n"
"help.text"
msgid "<variable id=\"farbentext\"><ahelp hid=\".\">%PRODUCTNAME lets you define custom colors using a two-dimensional graphic and numerical gradient chart of the <emph>Pick a Color</emph> dialog.</ahelp></variable>"
msgstr "<variable id=\"farbentext\"><ahelp hid=\".\">%PRODUCTNAME ຊ່ວຍໃຫ້ທ່ານກຳນົດສີດ້ວຍຕົນເອງໂດຍໃຊ້ກຣາຟິກສອງມິຕິ ແລະ ແຜນພູມໄລ່ສີແບບຕົວເລກຂອງກ່ອງສົນທະນາ <emph>ເລືອກສີ</emph>.</ahelp></variable>"

#. EtMYc
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"hd_id3149514\n"
"help.text"
msgid "The Pick a Color Window"
msgstr "ໜ້າຕ່າງເລືອກສີ"

#. zKApW
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148943\n"
"help.text"
msgid "The GTK and Qt variants of %PRODUCTNAME on Linux use native system/toolkit dialogs (which are also used by other applications) by default to pick a color instead of the custom dialog that is described in more detail below. Use of the custom %PRODUCTNAME dialog instead of the native one can be enabled in the %PRODUCTNAME options."
msgstr "%PRODUCTNAME ລຸ້ນ GTK ແລະ Qt ເທິງ Linux ຈະໃຊ້ກ່ອງສົນທະນາຂອງລະບົບ/toolkit ເປັນຄ່າເລີ່ມຕົ້ນ (ເຊິ່ງແອັບພລິເຄຊັນອື່ນກໍໃຊ້ຄືກັນ) ເພື່ອເລືອກສີ ແທນທີ່ຈະໃຊ້ກ່ອງສົນທະນາທີ່ກຳນົດເອງເຊິ່ງຈະອະທິບາຍລະອຽດຂ້າງລຸ່ມນີ້. ການໃຊ້ກ່ອງສົນທະນາທີ່ກຳນົດເອງຂອງ %PRODUCTNAME ແທນທີ່ຂອງລະບົບ ສາມາດເປີດໃຊ້ໄດ້ໃນຕົວເລືອກຂອງ %PRODUCTNAME."

#. Xu7fM
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148944\n"
"help.text"
msgid "The Pick a Color dialog consists of four main areas."
msgstr "ກ່ອງສົນທະນາເລືອກສີປະກອບດ້ວຍສີ່ສ່ວນຕົ້ນຕໍ."

#. JA9HB
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148945\n"
"help.text"
msgid "The radio buttons select the color component of the color. This color component can be expressed in either RGB (Red, Green, Blue) or HSB (Hue, Saturation, Brightness) color models. The CMYK color model is not selectable and is provided only to ease the input of color values using CMYK notation."
msgstr "ປຸ່ມເລືອກ (Radio buttons) ໃຊ້ເພື່ອເລືອກສ່ວນປະກອບຂອງສີ. ສ່ວນປະກອບຂອງສີນີ້ສາມາດສະແດງອອກໃນຮູບແບບສີ RGB (ແດງ, ຂຽວ, ຟ້າ) ຫຼື HSB (ສີ, ຄວາມອີ່ມຕົວ, ຄວາມສະຫວ່າງ). ຮູບແບບສີ CMYK ບໍ່ສາມາດເລືອກໄດ້ ແລະ ມີໄວ້ເພື່ອໃຫ້ງ່າຍຕໍ່ການປ້ອນຄ່າສີໂດຍໃຊ້ຮູບແບບ CMYK ເທົ່ານັ້ນ."

#. FJTXy
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148946\n"
"help.text"
msgid "The spin buttons are for entering the numerical value of the color component."
msgstr "ປຸ່ມປັບຕົວເລກ (Spin buttons) ໃຊ້ສຳລັບປ້ອນຄ່າຕົວເລກຂອງສ່ວນປະກອບສີ."

#. LDVtQ
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148947\n"
"help.text"
msgid "<ahelp hid=\".\">With the vertical color component slider you can modify the value of each component of the color.</ahelp> With the large colored square you can select the color component approximately."
msgstr "<ahelp hid=\".\">ດ້ວຍແຖບເລື່ອນສ່ວນປະກອບສີແນວຕັ້ງ ທ່ານສາມາດແກ້ໄຂຄ່າຂອງແຕ່ລະສ່ວນປະກອບຂອງສີໄດ້.</ahelp> ດ້ວຍຮູບສີ່ຫຼ່ຽມສີຂະໜາດໃຫຍ່ ທ່ານສາມາດເລືອກສ່ວນປະກອບສີໄດ້ໂດຍປະມານ."

#. 7noqJ
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3148948\n"
"help.text"
msgid "The horizontal bottom color bar shows the current color and the new color, side by side."
msgstr "ແຖບສີແນວນອນຢູ່ດ້ານລຸ່ມສະແດງສີປັດຈຸບັນ ແລະ ສີໃໝ່ຄຽງຄູ່ກັນ."

#. TcRQF
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3153061\n"
"help.text"
msgid "<ahelp hid=\".\">Click in the big color area on the left to select a new color. Using this selector area you can modify two components of the color as represented in the RGB or HSB color models. Note that these are the two components not selected with the radio buttons on the right side of the dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກໃສ່ພື້ນທີ່ສີຂະໜາດໃຫຍ່ທາງດ້ານຊ້າຍເພື່ອເລືອກສີໃໝ່. ການໃຊ້ພື້ນທີ່ເລືອກນີ້ ທ່ານສາມາດແກ້ໄຂສອງສ່ວນປະກອບຂອງສີຕາມທີ່ສະແດງໃນຮູບແບບສີ RGB ຫຼື HSB. ໝາຍເຫດ: ສ່ວນປະກອບທັງສອງນີ້ແມ່ນສ່ວນທີ່ບໍ່ໄດ້ຖືກເລືອກດ້ວຍປຸ່ມເລືອກທາງດ້ານຂວາຂອງກ່ອງສົນທະນາ.</ahelp>"

#. Lnrj6
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3154164\n"
"help.text"
msgid "<ahelp hid=\".\">In the right part of the bottom bar, you will see the original color from the parent tab, <emph>Colors</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນສ່ວນຂວາຂອງແຖບດ້ານລຸ່ມ, ທ່ານຈະເຫັນສີເດີມຈາກແຖບຫຼັກ, <emph>ສີ</emph>.</ahelp>"

#. NGZzA
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id3154165\n"
"help.text"
msgid "<ahelp hid=\".\">In the left part of the bottom bar, the current result of your work in this dialog is visible.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນສ່ວນຊ້າຍຂອງແຖບດ້ານລຸ່ມ, ຜົນໄດ້ຮັບປັດຈຸບັນຈາກການເຮັດວຽກຂອງທ່ານໃນກ່ອງສົນທະນານີ້ຈະຖືກສະແດງໃຫ້ເຫັນ.</ahelp>"

#. pZFsP
#: 01010501.xhp
msgctxt ""
"01010501.xhp\n"
"par_id9701528\n"
"help.text"
msgid "%PRODUCTNAME uses only the RGB color model for printing in color. The CMYK controls are provided only to ease the input of color values using CMYK notation."
msgstr "%PRODUCTNAME ໃຊ້ສະເພາະຮູບແບບສີ RGB ເພື່ອພິມເປັນສີ. ສ່ວນການຄວບຄຸມ CMYK ແມ່ນມີໄວ້ເພື່ອໃຫ້ງ່າຍຕໍ່ການປ້ອນຄ່າສີໂດຍໃຊ້ຮູບແບບ CMYK ເທົ່ານັ້ນ."

