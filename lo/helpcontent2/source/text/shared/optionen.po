msgid "<variable id=\"relative_saving_option\">Save URLs relative to file system</variable>"
msgstr "<variable id=\"relative_saving_option\">ບັນທຶກ URL ແບບສຳພັດກັບລະບົບໄຟລ໌</variable>"

#. ffQwJ
