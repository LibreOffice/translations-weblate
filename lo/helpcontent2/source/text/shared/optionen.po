#. MCFEo
#: 01010800.xhp
msgctxt ""
"01010800.xhp\n"
"par_id3151127\n"
"help.text"
msgid "Clicking the middle mouse button pastes at the mouse pointer position."
msgstr "ການຄລິກປຸ່ມກາງຂອງເມົາສ໌ຈະວາງທີ່ຕຳແໜ່ງຕົວຊີ້ເມົາສ໌."

#. UBACD
#: 01010800.xhp
msgctxt ""
"01010800.xhp\n"
"par_id3159206\n"
"help.text"
msgid "<emph>Pasting into another document</emph>"
msgstr "<emph>ການວາງລົງໃນເອກະສານອື່ນ</emph>"

#. 9gJnG
#: 01010800.xhp
msgctxt ""
"01010800.xhp\n"
"par_id3148974\n"
"help.text"
msgid "No effect on the clipboard contents."
msgstr "ບໍ່ມີຜົນຕໍ່ເນື້ອຫາໃນຄລິບບອດ."

#. GxDgt
#: 01010800.xhp
msgctxt ""
"01010800.xhp\n"
"par_id3152870\n"
"help.text"
msgid "The last marked selection is the content of the selection clipboard."
msgstr "ສິ່ງທີ່ຖືກເລືອກ ແລະ ໝາຍໄວ້ຫຼ້າສຸດຈະເປັນເນື້ອຫາຂອງຄລິບບອດຈາກການເລືອກ."

#. WG8CG
#: 01010800.xhp
msgctxt ""
"01010800.xhp\n"
"par_idN10A1D\n"
"help.text"
msgid "<ahelp hid=\"20201\">Press <keycode>Shift+</keycode><switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+R</keycode> to restore or refresh the view of the current document.</ahelp>"
msgstr "<ahelp hid=\"20201\">ກົດ <keycode>Shift+</keycode><switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+R</keycode> ເພື່ອຄືນຄ່າ ຫຼື ຣີເຟຣຊມຸມມອງຂອງເອກະສານປັດຈຸບັນ.</ahelp>"

#. 9BPVM
