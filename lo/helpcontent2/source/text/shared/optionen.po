#. Kzk7B
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_idN106FA\n"
"help.text"
msgid "<ahelp hid=\".\">Displays a help text when you rest the cursor on an icon, a menu command, or a control on a dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງຂໍ້ຄວາມຊ່ວຍເຫຼືອເມື່ອທ່ານວາງເຄີເຊີຄ້າງໄວ້ທີ່ໄອຄອນ, ຄຳສັ່ງເມນູ ຫຼື ສ່ວນຄວບຄຸມໃນກ່ອງສົນທະນາ.</ahelp>"

#. BDwB4
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id971773867108617\n"
"help.text"
msgid "Warn if local help is not installed"
msgstr "ເຕືອນຖ້າບໍ່ໄດ້ຕິດຕັ້ງການຊ່ວຍເຫຼືອໃນເຄື່ອງ"

#. BGwkc
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id271773867808459\n"
"help.text"
msgid "If the offline help is not installed but you are connected to the internet, a dialog will appear offering the option to <emph>Read Help Online</emph>. Click <emph>OK</emph> to open your default web browser to the %PRODUCTNAME online help pages."
msgstr "ຖ້າບໍ່ໄດ້ຕິດຕັ້ງການຊ່ວຍເຫຼືອແບບອອບໄລນ໌ ແຕ່ທ່ານເຊື່ອມຕໍ່ອິນເຕີເນັດຢູ່, ກ່ອງສົນທະນາຈະປະກົດຂຶ້ນເພື່ອສະເໜີຕົວເລືອກ <emph>ອ່ານການຊ່ວຍເຫຼືອແບບອອນໄລນ໌</emph>. ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອເປີດເວັບບຣາວເຊີເລີ່ມຕົ້ນຂອງທ່ານໄປຫາໜ້າການຊ່ວຍເຫຼືອອອນໄລນ໌ຂອງ %PRODUCTNAME."

#. ZA7TU
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id911773868013472\n"
"help.text"
msgid "The dialog also includes a link to the <link href=\"text/shared/guide/builtin_help.xhp\">built-in help page</link>, which provides instructions for installing the built-in Help."
msgstr "ກ່ອງສົນທະນາຍັງປະກອບດ້ວຍລິ້ງໄປຫາ <link href=\"text/shared/guide/builtin_help.xhp\">ໜ້າການຊ່ວຍເຫຼືອທີ່ຕິດຕັ້ງມາພ້ອມເຄື່ອງ</link>, ເຊິ່ງໃຫ້ຄຳແນະນຳໃນການຕິດຕັ້ງ Help ດັ່ງກ່າວ."

#. FoLSB
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id861773867113281\n"
"help.text"
msgid "Show \"Tip of the Day\" on startup"
msgstr "ສະແດງ \"ຄຳແນະນຳປະຈຳວັນ\" ເມື່ອເລີ່ມໂປຣແກຣມ"

#. FyRFH
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id921773869027190\n"
"help.text"
msgid "Displays a small window with a random tip for using %PRODUCTNAME. This window appears when you open your first document of the day."
msgstr "ສະແດງໜ້າຕ່າງຂະໜາດນ້ອຍພ້ອມຄຳແນະນຳແບບສຸ່ມໃນການໃຊ້ %PRODUCTNAME. ໜ້າຕ່າງນີ້ຈະປະກົດຂຶ້ນເມື່ອທ່ານເປີດເອກະສານທຳອິດຂອງມື້ນັ້ນ."

#. UdFCN
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id691773869356508\n"
"help.text"
msgid "Dialogs"
msgstr "ກ່ອງສົນທະນາ"

#. rdCLY
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id91773869422988\n"
"help.text"
msgid "Use %PRODUCTNAME open/save dialogs"
msgstr "ໃຊ້ກ່ອງສົນທະນາ ເປີດ/ບັນທຶກ ຂອງ %PRODUCTNAME"

#. RGhSq
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id321773869635303\n"
"help.text"
msgid "Select this option to use the Open and Save dialogs supplied with %PRODUCTNAME. Deselect to use the standard Open and Save dialogs of the computer operating system."
msgstr "ເລືອກຕົວເລືອກນີ້ເພື່ອໃຊ້ກ່ອງສົນທະນາ ເປີດ ແລະ ບັນທຶກ ທີ່ມາພ້ອມກັບ %PRODUCTNAME. ຍົກເລີກການເລືອກເພື່ອໃຊ້ກ່ອງສົນທະນາ ເປີດ ແລະ ບັນທຶກ ມາດຕະຖານຂອງລະບົບປະຕິບັດການ."

#. R7fCQ
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id841773869427908\n"
"help.text"
msgid "Use %PRODUCTNAME color dialog"
msgstr "ໃຊ້ກ່ອງສົນທະນາສີຂອງ %PRODUCTNAME"

#. UqGEH
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id451773869818691\n"
"help.text"
msgid "Select this option to use the Color Picker dialog supplied with %PRODUCTNAME. Deselect to use the standard Color Picker dialog of the computer operating system."
msgstr "ເລືອກຕົວເລືອກນີ້ເພື່ອໃຊ້ກ່ອງສົນທະນາເລືອກສີທີ່ມາພ້ອມກັບ %PRODUCTNAME. ຍົກເລີກການເລືອກເພື່ອໃຊ້ກ່ອງສົນທະນາເລືອກສີມາດຕະຖານຂອງລະບົບປະຕິບັດການ."

#. 5mBwV
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id3148617\n"
"help.text"
msgid "Document status"
msgstr "ສະຖານະເອກະສານ"

#. t6PAo
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id3149299\n"
"help.text"
msgid "Printing sets \"document modified\" status"
msgstr "ການພິມຈະຕັ້ງສະຖານະເປັນ \"ເອກະສານຖືກແກ້ໄຂ\""

#. K2CGB
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id3145800\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optgeneralpage/docstatus\">Specifies whether the printing of the document counts as a modification.</ahelp> When this option is marked, the very next time the document is closed you are asked if the changes should be saved. The print date is then entered in the document properties as a change."
msgstr "<ahelp hid=\"cui/ui/optgeneralpage/docstatus\">ລະບຸວ່າການພິມເອກະສານຈະຖືວ່າເປັນການແກ້ໄຂເອກະສານຫຼືບໍ່.</ahelp> ເມື່ອໝາຍຕົວເລືອກນີ້, ໃນຄັ້ງຕໍ່ໄປທີ່ປິດເອກະສານ ທ່ານຈະຖືກຖາມວ່າຕ້ອງການບັນທຶກການປ່ຽນແປງຫຼືບໍ່. ວັນທີພິມຈະຖືກບັນທຶກໄວ້ໃນຄຸນສົມບັດຂອງເອກະສານເປັນການປ່ຽນແປງຄັ້ງໜຶ່ງ."

#. 3rs5u
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id3153561\n"
"help.text"
msgid "Year (two digits)"
msgstr "ປີ (ສອງຫຼັກ)"

#. ftr3B
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id3147530\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optgeneralpage/year\">Defines a date range, within which the system recognizes a two-digit year.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optgeneralpage/year\">ກຳນົດຊ່ວງວັນທີ ເຊິ່ງລະບົບຈະຮັບຮູ້ປີແບບສອງຫຼັກ.</ahelp>"

#. 4EBpQ
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id3156343\n"
"help.text"
msgid "In $[officename], years are indicated by four digits, so that the difference between 1/1/99 and 1/1/01 is two years. This <emph>Year (two digits)</emph> setting allows the user to define the years in which two-digit dates are added to 2000. To illustrate, if you specify a date of 1930 or later, the entry \"1/1/20\" is recognized as 2020-01-01 instead of 1920-01-01."
msgstr "ໃນ $[officename], ປີຈະຖືກລະບຸດ້ວຍຕົວເລກສີ່ຫຼັກ, ເພື່ອໃຫ້ຄວາມແຕກຕ່າງລະຫວ່າງ 1/1/99 ແລະ 1/1/01 ແມ່ນສອງປີ. ການຕັ້ງຄ່າ <emph>ປີ (ສອງຫຼັກ)</emph> ນີ້ຊ່ວຍໃຫ້ຜູ້ໃຊ້ກຳນົດປີທີ່ວັນທີແບບສອງຫຼັກຈະຖືກບວກເຂົ້າກັບປີ 2000. ຕົວຢ່າງ: ຖ້າທ່ານລະບຸວັນທີເປັນ 1930 ຫຼື ຫຼັງຈາກນັ້ນ, ການປ້ອນ \"1/1/20\" ຈະຖືກຮັບຮູ້ເປັນ 2020-01-01 ແທນທີ່ຈະເປັນ 1920-01-01."

#. iGjLN
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id3163561\n"
"help.text"
msgid "Help Improve %PRODUCTNAME"
msgstr "ຊ່ວຍປັບປຸງ %PRODUCTNAME"

#. rBPYn
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"hd_id3169299\n"
"help.text"
msgid "Prompt for sending crash reports to The Document Foundation"
msgstr "ຖາມກ່ອນສົ່ງລາຍງານການຂັດຂ້ອງໄປຍັງ The Document Foundation"

#. t9Vbx
#: 01010600.xhp
msgctxt ""
"01010600.xhp\n"
"par_id3167530\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optgeneralpage/crashreport\">Asks you whether to send a crash report to help developers improve the software’s reliability.</ahelp> Whenever %PRODUCTNAME crashes, you can opt to send a <link href=\"text/shared/guide/error_report.xhp#hd_id3150792\">report containing anonymous debugging information</link>, to help track down and eventually fix the root cause."
msgstr "<ahelp hid=\"cui/ui/optgeneralpage/crashreport\">ຖາມທ່ານວ່າຕ້ອງການສົ່ງລາຍງານການຂັດຂ້ອງເພື່ອຊ່ວຍໃຫ້ນັກພັດທະນາປັບປຸງຄວາມໜ້າເຊື່ອຖືຂອງຊອບແວຫຼືບໍ່.</ahelp> ທຸກຄັ້ງທີ່ %PRODUCTNAME ຂັດຂ້ອງ (crash), ທ່ານສາມາດເລືອກສົ່ງ <link href=\"text/shared/guide/error_report.xhp#hd_id3150792\">ລາຍງານທີ່ມີຂໍ້ມູນການແກ້ໄຂບັກແບບບໍ່ລະບຸຕົວຕົນ</link> ເພື່ອຊ່ວຍໃນການຄົ້ນຫາ ແລະ ແກ້ໄຂສາເຫດຫຼັກໃນທີ່ສຸດ."

