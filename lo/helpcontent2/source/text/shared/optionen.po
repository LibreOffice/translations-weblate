#. E3z4y
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3156410\n"
"help.text"
msgid "Defines general settings for spreadsheet documents."
msgstr "ກຳນົດການຕັ້ງຄ່າທົ່ວໄປສຳລັບເອກະສານສະເປຣດຊີດ."

#. fQoGV
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3155338\n"
"help.text"
msgid "Metrics"
msgstr "ການວັດແທກ"

#. 3uY8a
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3151110\n"
"help.text"
msgid "Measurement unit"
msgstr "ຫົວໜ່ວຍວັດແທກ"

#. CxNiB
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3150444\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/unitlb\">Defines the unit of measure in spreadsheets.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/unitlb\">ກຳນົດຫົວໜ່ວຍວັດແທກໃນສະເປຣດຊີດ.</ahelp>"

#. dRuLe
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3149795\n"
"help.text"
msgid "Tab stops"
msgstr "ຈຸດຢຸດແທັບ"

#. rHSQ8
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3150084\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/tabmf\">Defines the tab stops distance.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/tabmf\">ກຳນົດໄລຍະຫ່າງຂອງຈຸດຢຸດແທັບ.</ahelp>"

#. VqB4L
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3155135\n"
"help.text"
msgid "Input settings"
msgstr "ການຕັ້ງຄ່າການປ້ອນຂໍ້ມູນ"

#. XEdVE
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3148491\n"
"help.text"
msgid "Press Enter to move selection"
msgstr "ກົດ Enter ເພື່ອຍ້າຍການເລືອກ"

#. s9HGT
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3145119\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/alignlb\">Determines the direction that the cursor in the spreadsheet will move after you press the Enter key.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/alignlb\">ກຳນົດທິດທາງທີ່ເຄີເຊີໃນສະເປຣດຊີດຈະຍ້າຍໄປຫຼັງຈາກທີ່ທ່ານກົດປຸ່ມ Enter.</ahelp>"

#. LfHGq
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3154307\n"
"help.text"
msgid "Press Enter to switch to edit mode"
msgstr "ກົດ Enter ເພື່ອສະຫຼັບໄປຫາໂໝດແກ້ໄຂ"

#. jHBp2
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3148943\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/editmodecb\">Determines the behavior of the Enter key in a spreadsheet. Checking this option causes Enter to open cell contents for editing.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/editmodecb\">ກຳນົດພຶດຕິກຳຂອງປຸ່ມ Enter ໃນສະເປຣດຊີດ. ການໝາຍເອົາຕົວເລືອກນີ້ຈະເຮັດໃຫ້ການກົດ Enter ເປັນການເປີດເນື້ອໃນເຊວເພື່ອແກ້ໄຂ.</ahelp>"

#. NMaGC
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id291629751925288\n"
"help.text"
msgid "Uncheck this option to make the Enter key select the cell below the current cell."
msgstr "ຍົກເລີກການໝາຍຕົວເລືອກນີ້ເພື່ອໃຫ້ປຸ່ມ Enter ເລືອກເຊວທີ່ຢູ່ທາງລຸ່ມຂອງເຊວປັດຈຸບັນ."

#. GtCgC
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id391629752077203\n"
"help.text"
msgid "If a range of cells is selected, each time <keycode>Enter</keycode> is pressed it will select the next cell inside the range, according to the direction selected in <emph>Press Enter to move selection</emph>. Hence, enabling both options is useful when entering values into a range of cells sequentially."
msgstr "ຖ້າຫາກເລືອກຊ່ວງຂອງເຊວໄວ້, ທຸກໆຄັ້ງທີ່ກົດ <keycode>Enter</keycode> ມັນຈະເລືອກເຊວຖັດໄປພາຍໃນຊ່ວງນັ້ນ ຕາມທິດທາງທີ່ເລືອກໄວ້ໃນ <emph>ກົດ Enter ເພື່ອຍ້າຍການເລືອກ</emph>. ດັ່ງນັ້ນ, ການເປີດໃຊ້ງານທັງສອງຕົວເລືອກຈຶ່ງມີປະໂຫຍດເມື່ອມີການປ້ອນຄ່າລົງໃນຊ່ວງຂອງເຊວຕາມລຳດັບ."

#. aEMH5
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id371770636964162\n"
"help.text"
msgid "Press Enter to paste and clear clipboard"
msgstr "ກົດ Enter ເພື່ອວາງ ແລະ ລຶບຂໍ້ມູນໃນຄລິບບອດ"

#. 7TEd9
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id921770636970370\n"
"help.text"
msgid "Allows you to immediately paste the clipboard contents and clear it after pressing the <keycode>Enter</keycode> key."
msgstr "ອະນຸຍາດໃຫ້ທ່ານວາງເນື້ອໃນຈາກຄລິບບອດໄດ້ທັນທີ ແລະ ລຶບມັນອອກຫຼັງຈາກກົດປຸ່ມ <keycode>Enter</keycode>."

#. A3GcJ
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id441770637084408\n"
"help.text"
msgid "Uncheck this option if you frequently need to paste the same content into multiple cells."
msgstr "ຍົກເລີກການໝາຍຕົວເລືອກນີ້ ຖ້າຫາກທ່ານມີຄວາມຈຳເປັນຕ້ອງວາງເນື້ອໃນອັນດຽວກັນລົງໃນຫຼາຍໆເຊວເລື້ອຍໆ."

#. zqG2F
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3153896\n"
"help.text"
msgid "Expand formatting"
msgstr "ຂະຫຍາຍການຈັດຮູບແບບ"

#. 64K2o
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3150400\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/formatcb\">Specifies whether to automatically apply the formatting attributes of the selected cell to the empty adjacent cells.</ahelp> If, for example, the contents of the selected cell have the bold attribute, this bold attribute will also apply to adjacent cells. Cells that already have a special format will not be modified by this function. You can see the range in question by pressing the <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> + * (multiplication sign on the number pad) shortcut. This format also applies to all new values inserted within this range. The normal default settings apply to cells outside this range."
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/formatcb\">ກຳນົດວ່າຈະໃຫ້ໃຊ້ຄຸນລັກສະນະການຈັດຮູບແບບຂອງເຊວທີ່ເລືອກກັບເຊວວ່າງທີ່ຢູ່ຕິດກັນໂດຍອັດຕະໂນມັດຫຼືບໍ່.</ahelp> ຕົວຢ່າງ: ຖ້າເນື້ອໃນຂອງເຊວທີ່ເລືອກມີຄຸນລັກສະນະເປັນຕົວເຂັ້ມ, ຄຸນລັກສະນະຕົວເຂັ້ມນີ້ກໍຈະຖືກໃຊ້ກັບເຊວທີ່ຢູ່ຕິດກັນນຳ. ເຊວທີ່ມີການຈັດຮູບແບບພິເສດຢູ່ແລ້ວຈະບໍ່ຖືກປ່ຽນແປງໂດຍຟັງຊັນນີ້. ທ່ານສາມາດເບິ່ງຊ່ວງດັ່ງກ່າວໄດ້ໂດຍການກົດປຸ່ມລັດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> + * (ເຄື່ອງໝາຍຄູນຢູ່ແປ້ນຕົວເລກ). ຮູບແບບນີ້ຍັງຈະຖືກໃຊ້ກັບທຸກຄ່າໃໝ່ທີ່ປ້ອນລົງໃນຊ່ວງນີ້. ສ່ວນເຊວທີ່ຢູ່ນອກຊ່ວງນີ້ຈະໃຊ້ການຕັ້ງຄ່າເລີ່ມຕົ້ນປົກກະຕິ."

#. mAJf5
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3148451\n"
"help.text"
msgid "Expand references when new columns/rows are inserted"
msgstr "ຂະຫຍາຍການອ້າງອີງເມື່ອມີການແຊກຖັນ/ແຖວໃໝ່"

#. qaYcG
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3154684\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/exprefcb\">Specifies whether to expand references when inserting columns or rows adjacent to the reference range. This is only possible if the reference range, where the column or row is inserted, originally spanned at least two cells in the desired direction.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/exprefcb\">ກຳນົດວ່າຈະໃຫ້ຂະຫຍາຍການອ້າງອີງຫຼືບໍ່ ເມື່ອມີການແຊກຖັນ ຫຼື ແຖວທີ່ຢູ່ຕິດກັບຊ່ວງອ້າງອີງ. ສິ່ງນີ້ຈະເປັນໄປໄດ້ກໍຕໍ່ເມື່ອຊ່ວງອ້າງອີງບ່ອນທີ່ມີການແຊກຖັນ ຫຼື ແຖວນັ້ນ ກວມເອົາຢ່າງໜ້ອຍສອງເຊວໃນທິດທາງທີ່ຕ້ອງການມາແຕ່ຕົ້ນ.</ahelp>"

#. pUKU7
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3153194\n"
"help.text"
msgid "<emph>Example:</emph> If the range A1:B1 is referenced in a formula and you insert a new column after column B, the reference is expanded to A1:C1. If the range A1:B1 is referenced and a new row is inserted under row 1, the reference is not expanded, since there is only a single cell in the vertical direction."
msgstr "<emph>ຕົວຢ່າງ:</emph> ຖ້າຊ່ວງ A1:B1 ຖືກອ້າງອີງໃນສູດ ແລະ ທ່ານແຊກຖັນໃໝ່ຫຼັງຈາກຖັນ B, ການອ້າງອີງຈະຖືກຂະຫຍາຍເປັນ A1:C1. ແຕ່ຖ້າຊ່ວງ A1:B1 ຖືກອ້າງອີງ ແລະ ມີການແຊກແຖວໃໝ່ລຸ່ມແຖວ 1, ການອ້າງອີງຈະບໍ່ຖືກຂະຫຍາຍ ເພາະມີພຽງເຊວດຽວໃນແນວຕັ້ງ."

#. 8XFWb
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3150449\n"
"help.text"
msgid "If you insert rows or columns in the middle of a reference area, the reference is always expanded."
msgstr "ຖ້າທ່ານແຊກແຖວ ຫຼື ຖັນ ຢູ່ເຄິ່ງກາງຂອງພື້ນທີ່ອ້າງອີງ, ການອ້າງອີງຈະຖືກຂະຫຍາຍສະເໝີ."

#. 7mH7f
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3151176\n"
"help.text"
msgid "Highlight selection in column/row headings"
msgstr "ເນັ້ນການເລືອກໃນຫົວຖັນ/ຫົວແຖວ"

#. ChEGA
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3145171\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/markhdrcb\">Specifies whether to highlight column and row headers in the selected columns or rows.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/markhdrcb\">ກຳນົດວ່າຈະໃຫ້ເນັ້ນຫົວຖັນ ແລະ ຫົວແຖວ ໃນຖັນ ຫຼື ແຖວທີ່ຖືກເລືອກຫຼືບໍ່.</ahelp>"

#. WvdHF
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3146146\n"
"help.text"
msgid "Show overwrite warning when pasting data"
msgstr "ສະແດງຄຳເຕືອນການຂຽນທັບເມື່ອວາງຂໍ້ມູນ"

#. JyxjR
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id3150872\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/replwarncb\">Specifies that, when you paste cells from the clipboard to a cell range that is not empty, a warning appears.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/replwarncb\">ກຳນົດວ່າ ເມື່ອທ່ານວາງເຊວຈາກຄລິບບອດລົງໃນຊ່ວງເຊວທີ່ບໍ່ວ່າງ, ຈະມີຄຳເຕືອນປະກົດຂຶ້ນ.</ahelp>"

#. ADrdk
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"hd_id3146147\n"
"help.text"
msgid "Position cell reference with selection"
msgstr "ຕຳແໜ່ງການອ້າງອີງເຊວພ້ອມກັບການເລືອກ"

#. GpsAH
#: 01060300.xhp
msgctxt ""
"01060300.xhp\n"
"par_id31508727\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/scgeneralpage/legacy_cell_selection_cb\">With the option set, expanding a selection (with <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command  </item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>  +<item type=\"keycode\">Shift</item>+<item type=\"keycode\">Down/Up</item>) jumps to the end of the range in the column that was added as last to the initial selection. When the option is not set, expanding a selection (with <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>+<item type=\"keycode\">Shift  </item>+<item type=\"keycode\">Down/Up</item>) jumps to the end of the range in the column where selecting the cell range was started. The same of course applies when extending a selection on rows, with <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>+<item type=\"keycode\">  Shift</item>+<item type=\"keycode\">Left/Right</item>.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/scgeneralpage/legacy_cell_selection_cb\">ເມື່ອເລືອກຕົວເລືອກນີ້, ການຂະຫຍາຍການເລືອກ (ດ້ວຍ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>+<item type=\"keycode\">Shift</item>+<item type=\"keycode\">ລົງ/ຂຶ້ນ</item>) ຈະໂດດໄປຫາທ້າຍຊ່ວງໃນຖັນທີ່ຖືກເພີ່ມເຂົ້າເປັນອັນສຸດທ້າຍໃຫ້ກັບການເລືອກເລີ່ມຕົ້ນ. ເມື່ອບໍ່ໄດ້ເລືອກຕົວເລືອກນີ້, ການຂະຫຍາຍການເລືອກ (ດ້ວຍ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>+<item type=\"keycode\">Shift</item>+<item type=\"keycode\">ລົງ/ຂຶ້ນ</item>) ຈະໂດດໄປຫາທ້າຍຊ່ວງໃນຖັນບ່ອນທີ່ການເລືອກຊ່ວງຫ້ອງເລີ່ມຕົ້ນ. ແນ່ນອນວ່າ ສິ່ງດຽວກັນນີ້ຍັງໃຊ້ໄດ້ກັບການຂະຫຍາຍການເລືອກໃນແຖວ, ດ້ວຍ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline>+<item type=\"keycode\">Shift</item>+<item type=\"keycode\">ຊ້າຍ/ຂວາ</item>.</ahelp>"

#. VGEyo
