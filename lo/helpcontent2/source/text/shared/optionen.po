msgctxt ""
"expertconfig.xhp\n"
"par_id0609201523011613\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/aboutconfigdialog/searchEntry\">Type the preference you want to display in the text area</ahelp>. Then click in the Search button."
msgstr "<ahelp hid=\"cui/ui/aboutconfigdialog/searchEntry\">ພິມຄ່າທີ່ທ່ານຕ້ອງການສະແດງລົງໃນພື້ນທີ່ຂໍ້ຄວາມ</ahelp>. ຈາກນັ້ນຄລິກປຸ່ມ ຄົ້ນຫາ."

#. 4Gn4A
#: expertconfig.xhp
msgctxt ""
"expertconfig.xhp\n"
"hd_id0609201523011655\n"
"help.text"
msgid "Search button"
msgstr "ປຸ່ມຄົ້ນຫາ"

#. d2ZDc
#: expertconfig.xhp
msgctxt ""
"expertconfig.xhp\n"
"par_id0609201523011660\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/aboutconfigdialog/searchButton\">Click to search your preference text in the Preferences tree.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/aboutconfigdialog/searchButton\">ຄລິກເພື່ອຄົ້ນຫາຂໍ້ຄວາມການຕັ້ງຄ່າຂອງທ່ານໃນໂຄງສ້າງການຕັ້ງຄ່າ.</ahelp>"

#. dpkgf
