#. AhEio
#: java.xhp
msgctxt ""
"java.xhp\n"
"hd_id3148619\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optadvancedpage/experimental\"><variable id=\"enable_experimental_features_hd\">Enable experimental features</variable></ahelp>"
msgstr "<ahelp hid=\"cui/ui/optadvancedpage/experimental\"><variable id=\"enable_experimental_features_hd\">ເປີດໃຊ້ຄຸນສົມບັດທົດລອງ</variable></ahelp>"

#. CAEjc
#: java.xhp
msgctxt ""
"java.xhp\n"
"par_id3156344\n"
"help.text"
msgid "Enables features that are not yet complete or may contain known bugs. The list of these features is different version by version, or even it can be empty."
msgstr "ເປີດໃຊ້ຄຸນສົມບັດທີ່ຍັງບໍ່ທັນສົມບູນ ຫຼື ອາດມີຂໍ້ຜິດພາດ. ລາຍຊື່ຄຸນສົມບັດເຫຼົ່ານີ້ຈະແຕກຕ່າງກັນໄປຕາມແຕ່ລະເວີຊັນ ຫຼື ບາງຄັ້ງອາດຈະບໍ່ມີເລີຍ."

#. CkbmG
#: java.xhp
msgctxt ""
"java.xhp\n"
"hd_id3148610\n"
"help.text"
