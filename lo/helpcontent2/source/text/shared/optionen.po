msgstr "<ahelp hid=\"cui/ui/optsecuritypage/cert\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ເສັ້ນທາງໃບຢັ້ງຢືນ</emph>.</ahelp>"

#. tY5b3
#: 01030500.xhp
msgctxt ""
"01030500.xhp\n"
"tit\n"
"help.text"
msgid "HTML compatibility"
msgstr "ການເຂົ້າກັນໄດ້ກັບ HTML"

#. WJj8D
