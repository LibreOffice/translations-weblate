msgid "Drivers known in $[officename]"
msgstr "ໄດຣເວີທີ່ຮູ້ຈັກໃນ $[officename]"

#. QYL5w
#: 01160100.xhp
msgctxt ""
"01160100.xhp\n"
"par_id3149235\n"
"help.text"
msgid "Displays a list of defined drivers and connection data."
msgstr "ສະແດງລາຍການໄດຣເວີທີ່ກໍານົດໄວ້ ແລະ ຂໍ້ມູນການເຊື່ອມຕໍ່."

#. GBDA6
#: 01160100.xhp
msgctxt ""
"01160100.xhp\n"
"hd_id3153349\n"
