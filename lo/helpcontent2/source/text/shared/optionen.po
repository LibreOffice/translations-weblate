msgctxt ""
"01040400.xhp\n"
"par_id3159150\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether to include colors and objects that are inserted to the background of the page (Format - Page Style - Background) in the printed document.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດວ່າຈະລວມເອົາສີ ແລະ ວັດຖຸທີ່ແຊກຢູ່ໃນພື້ນຫຼັງຂອງໜ້າ (ການຈັດຮູບແບບ - ຮູບແບບໜ້າ - ພື້ນຫຼັງ) ເຂົ້າໃນເອກະສານທີ່ຈະພິມຫຼືບໍ່.</ahelp>"

#. UFYzB
