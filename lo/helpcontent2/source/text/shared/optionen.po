msgid "Page"
msgstr "ໜ້າ"

#. H2PBt
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3159149\n"
"help.text"
msgid "Charts"
msgstr "ແຜນພູມ"

#. SEe9k
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3150768\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/optgeneralpage/updatecharts\">Specifies whether to automatically update charts. Whenever a Writer table cell value changes and the cursor leaves that cell, the chart that displays the cell value is updated automatically.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/optgeneralpage/updatecharts\">ລະບຸວ່າຈະໃຫ້ອັບເດດແຜນພູມແບບອັດຕະໂນມັດ ຫຼື ບໍ່. ທຸກຄັ້ງທີ່ຄ່າໃນຫ້ອງຕາຕະລາງ Writer ປ່ຽນແປງ ແລະ ເຄີເຊີອອກຈາກຫ້ອງນັ້ນ, ແຜນພູມທີ່ສະແດງຄ່າຂອງຫ້ອງນັ້ນຈະຖືກອັບເດດໂດຍອັດຕະໂນມັດ.</ahelp>"

#. gyqY9
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3146976\n"
"help.text"
msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

#. 6i32W
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3153364\n"
"help.text"
msgid "Measurement unit"
msgstr "ຫົວໜ່ວຍວັດແທກ"

#. EbccA
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3146147\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/optgeneralpage/metric\">Specifies the <link href=\"text/shared/00/00000003.xhp#measurement_units\">unit of measurement</link> for text documents.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/optgeneralpage/metric\">ລະບຸ <link href=\"text/shared/00/00000003.xhp#measurement_units\">ຫົວໜ່ວຍວັດແທກ</link> ສຳລັບເອກະສານຂໍ້ຄວາມ.</ahelp>"

#. WmFn3
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3154944\n"
"help.text"
msgid "Tab stops"
msgstr "ຈຸດແທັບ"

#. QmhRA
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3150417\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/optgeneralpage/tab\">Specifies the spacing between the individual tab stops.</ahelp> The horizontal ruler displays the selected spacing."
msgstr "<ahelp hid=\"modules/swriter/ui/optgeneralpage/tab\">ລະບຸໄລຍະຫ່າງລະຫວ່າງແຕ່ລະຈຸດແທັບ.</ahelp> ໄມ້ບັນທັດແນວນອນຈະສະແດງໄລຍະຫ່າງທີ່ເລືອກ."

#. rdALd
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3154946\n"
"help.text"
msgid "Enable char unit"
msgstr "ເປີດໃຊ້ຫົວໜ່ວຍຕົວອັກສອນ"

#. GxDyi
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3150419\n"
"help.text"
msgid "<ahelp hid=\".\">When this setting is enabled, the measurement units of indents and spacing on <emph>Format - Paragraph - Indents & Spacing</emph> tab will be character (ch) and line.</ahelp>"
msgstr "<ahelp hid=\".\">ເມື່ອເປີດໃຊ້ການຕັ້ງຄ່ານີ້, ຫົວໜ່ວຍວັດແທກຂອງການຫຍໍ້ໜ້າ ແລະ ໄລຍະຫ່າງໃນແທັບ <emph>ຮູບແບບ - ຫຍໍ້ໜ້າ - ການຫຍໍ້ໜ້າ ແລະ ໄລຍະຫ່າງ</emph> ຈະເປັນຕົວອັກສອນ (ch) ແລະ ແຖວ.</ahelp>"

#. EhWRQ
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3154945\n"
"help.text"
msgid "Use square page mode for text grid"
msgstr "ໃຊ້ໂໝດໜ້າແບບສີ່ຫຼ່ຽມສຳລັບເສັ້ນຕາໜ່າງຂໍ້ຄວາມ"

#. vDnnX
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3150418\n"
"help.text"
msgid "<ahelp hid=\".\">When this setting is enabled, the text grid will look like square page.</ahelp> Square page is a kind of page layout which is used to train students to write articles in China and Japan."
msgstr "<ahelp hid=\".\">ເມື່ອເປີດໃຊ້ການຕັ້ງຄ່ານີ້, ເສັ້ນຕາໜ່າງຂໍ້ຄວາມຈະເບິ່ງຄືກັບໜ້າແບບສີ່ຫຼ່ຽມ.</ahelp> ໜ້າແບບສີ່ຫຼ່ຽມແມ່ນຮູບແບບການຈັດໜ້າຊະນິດໜຶ່ງທີ່ໃຊ້ໃນການເຝິກອົບຮົມນັກຮຽນຂຽນບົດຄວາມໃນປະເທດຈີນ ແລະ ຍີ່ປຸ່ນ."

#. axcqw
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3166976\n"
"help.text"
msgid "Word count"
msgstr "ການນັບຄຳ"

#. vfrbi
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id3166980\n"
"help.text"
msgid "Additional separators"
msgstr "ຕົວແບ່ງເພີ່ມເຕີມ"

#. GjhmD
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id3166985\n"
"help.text"
msgid "Specifies the characters that are considered as word separators when counting words, in addition to spaces, tabs and line and paragraph breaks."
msgstr "ລະບຸຕົວອັກສອນທີ່ຖືວ່າເປັນຕົວແບ່ງຄຳໃນເວລາທີ່ນັບຄຳ, ນອກເໜືອຈາກການຍະວ່າງ, ແທັບ ແລະ ການຂຶ້ນແຖວໃໝ່ ຫຼື ຂຶ້ນຫຍໍ້ໜ້າໃໝ່."

#. LBDBF
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id691599000315902\n"
"help.text"
msgid "Show standardized page count"
msgstr "ສະແດງການນັບໜ້າແບບມາດຕະຖານ"

#. DCAGD
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id581599002628645\n"
"help.text"
msgid "Editors and publishers often define a “standard” page as containing a specified number of characters or words. Mark this field to allow quick calculation of the number of these pages."
msgstr "ບັນນາທິການ ແລະ ຜູ້ຈັດພິມມັກຈະກຳນົດໜ້າ \"ມາດຕະຖານ\" ວ່າປະກອບດ້ວຍຈຳນວນຕົວອັກສອນ ຫຼື ຄຳ ທີ່ກຳນົດໄວ້. ໝາຍເອົາຊ່ອງນີ້ເພື່ອອະນຸຍາດໃຫ້ຄຳນວນຈຳນວນໜ້າເຫຼົ່ານີ້ໄດ້ໄວຂຶ້ນ."

#. eQjAd
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"hd_id511599000321915\n"
"help.text"
msgid "Characters per standardized page"
msgstr "ຕົວອັກສອນຕໍ່ໜ້າມາດຕະຖານ"

#. AFkck
#: 01040900.xhp
msgctxt ""
"01040900.xhp\n"
"par_id271599002636069\n"
"help.text"
msgid "Set the number of characters for the standardized page."
msgstr "ຕັ້ງຄ່າຈຳນວນຕົວອັກສອນສຳລັບໜ້າມາດຕະຖານ."

#. RPuAH
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"tit\n"
"help.text"
msgid "Compatibility"
msgstr "ຄວາມເຂົ້າກັນໄດ້"

#. tYGmh
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"bm_id3577990\n"
"help.text"
msgid "<bookmark_value>Word documents;compatibility</bookmark_value>      <bookmark_value>importing;compatibility settings for text import</bookmark_value>      <bookmark_value>options;compatibility (Writer)</bookmark_value>      <bookmark_value>compatibility settings for MS Word import</bookmark_value>      <bookmark_value>Microsoft Office;importing Word documents</bookmark_value>      <bookmark_value>layout;importing Word documents</bookmark_value>"
msgstr "<bookmark_value>ເອກະສານ Word; ຄວາມເຂົ້າກັນໄດ້</bookmark_value>      <bookmark_value>ການນຳເຂົ້າ; ການຕັ້ງຄ່າຄວາມເຂົ້າກັນໄດ້ສຳລັບການນຳເຂົ້າຂໍ້ຄວາມ</bookmark_value>      <bookmark_value>ຕົວເລືອກ; ຄວາມເຂົ້າກັນໄດ້ (Writer)</bookmark_value>      <bookmark_value>ການຕັ້ງຄ່າຄວາມເຂົ້າກັນໄດ້ສຳລັບການນຳເຂົ້າ MS Word</bookmark_value>      <bookmark_value>Microsoft Office; ການນຳເຂົ້າເອກະສານ Word</bookmark_value>      <bookmark_value>ການຈັດວາງ; ການນຳເຂົ້າເອກະສານ Word</bookmark_value>"

#. xvqun
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10607\n"
"help.text"
msgid "<variable id=\"compatibility_var\"><link href=\"text/shared/optionen/01041000.xhp\">Compatibility</link></variable>"
msgstr "<variable id=\"compatibility_var\"><link href=\"text/shared/optionen/01041000.xhp\">ຄວາມເຂົ້າກັນໄດ້</link></variable>"

#. VkHbz
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10625\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/optcompatpage/OptCompatPage\">Specifies compatibility settings for text documents. These options help in fine-tuning %PRODUCTNAME when importing Microsoft Word documents.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/optcompatpage/OptCompatPage\">ລະບຸການຕັ້ງຄ່າຄວາມເຂົ້າກັນໄດ້ສຳລັບເອກະສານຂໍ້ຄວາມ. ຕົວເລືອກເຫຼົ່ານີ້ຊ່ວຍໃນການປັບແຕ່ງ %PRODUCTNAME ໃຫ້ລະອຽດ ເມື່ອນຳເຂົ້າເອກະສານ Microsoft Word.</ahelp>"

#. xTqJF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3153876\n"
"help.text"
msgid "Some of the settings defined here are only valid for the current document and must be defined separately for each document."
msgstr "ບາງການຕັ້ງຄ່າທີ່ກຳນົດໄວ້ຢູ່ບ່ອນນີ້ ມີຜົນໃຊ້ໄດ້ສະເພາະກັບເອກະສານປັດຈຸບັນເທົ່ານັ້ນ ແລະ ຕ້ອງໄດ້ກຳນົດແຍກຕ່າງຫາກສຳລັບແຕ່ລະເອກະສານ."

#. J39oF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id3145640\n"
"help.text"
msgid "Add spacing between paragraphs and tables"
msgstr "ເພີ່ມໄລຍະຫ່າງລະຫວ່າງຫຍໍ້ໜ້າ ແລະ ຕາຕະລາງ"

#. TSr55
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3147339\n"
"help.text"
msgid "In $[officename] Writer, paragraph spacing is defined differently than in Microsoft Word documents. If you have defined spacing between two paragraphs or tables, spacing is also added in the corresponding Word documents."
msgstr "ໃນ $[officename] Writer, ໄລຍະຫ່າງຂອງຫຍໍ້ໜ້າຖືກກຳນົດໄວ້ແຕກຕ່າງຈາກເອກະສານ Microsoft Word. ຖ້າທ່ານໄດ້ກຳນົດໄລຍະຫ່າງລະຫວ່າງສອງຫຍໍ້ໜ້າ ຫຼື ຕາຕະລາງ, ໄລຍະຫ່າງນັ້ນກໍຈະຖືກເພີ່ມເຂົ້າໃນເອກະສານ Word ທີ່ກ່ຽວຂ້ອງນຳ."

#. kEFur
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3151250\n"
"help.text"
msgid "Specifies whether to add Microsoft Word-compatible spacing between paragraphs and tables in $[officename] Writer text documents."
msgstr "ລະບຸວ່າຈະເພີ່ມໄລຍະຫ່າງທີ່ເຂົ້າກັນໄດ້ກັບ Microsoft Word ລະຫວ່າງຫຍໍ້ໜ້າ ແລະ ຕາຕະລາງໃນເອກະສານຂໍ້ຄວາມ $[officename] Writer ຫຼື ບໍ່."

#. 2ZAcw
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id3146317\n"
"help.text"
msgid "Add paragraph and table spacing at top of first page and page breaks"
msgstr "ເພີ່ມໄລຍະຫ່າງຫຍໍ້ໜ້າ ແລະ ຕາຕະລາງ ທີ່ສ່ວນເທິງຂອງໜ້າທຳອິດ ແລະ ບ່ອນຂຶ້ນໜ້າໃໝ່"

#. U5bFW
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3155333\n"
"help.text"
msgid "Specifies whether paragraph spacing at the top of a page will also be effective at the beginning of a page or column if the paragraph is positioned on the first page of the document. The same applies for a page break."
msgstr "ລະບຸວ່າໄລຍະຫ່າງຫຍໍ້ໜ້າຢູ່ສ່ວນເທິງຂອງໜ້າຈະມີຜົນຢູ່ທີ່ຈຸດເລີ່ມຕົ້ນຂອງໜ້າ ຫຼື ຄໍລຳນຳ ຫຼື ບໍ່ ຖ້າຫຍໍ້ໜ້ານັ້ນຕັ້ງຢູ່ໃນໜ້າທຳອິດຂອງເອກະສານ. ເຊັ່ນດຽວກັນກັບກໍລະນີທີ່ມີການຂຶ້ນໜ້າໃໝ່."

#. qDmqR
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3145789\n"
"help.text"
msgid "If you import a Word document, the spaces are automatically added during the conversion."
msgstr "ຖ້າທ່ານນຳເຂົ້າເອກະສານ Word, ໄລຍະຫ່າງເຫຼົ່ານີ້ຈະຖືກເພີ່ມໂດຍອັດຕະໂນມັດໃນລະຫວ່າງການແປງໄຟລ໌."

#. DvDBF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id3149964\n"
"help.text"
msgid "Use OpenOffice.org 1.1 tab stop formatting"
msgstr "ໃຊ້ຮູບແບບຈຸດແທັບຂອງ OpenOffice.org 1.1"

#. PrcAD
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id3152777\n"
"help.text"
msgid "Specifies how to align text at tab stops beyond the right margin, how to handle decimal tab stops, and how to handle tab stops close to a line break. If this check box is not selected, tab stops are handled in the same way as in other Office applications."
msgstr "ລະບຸວິທີການຈັດຂໍ້ຄວາມຢູ່ຈຸດແທັບທີ່ກາຍຂອບຂວາອອກໄປ, ວິທີການຈັດການຈຸດແທັບທົດສະນິຍົມ, ແລະ ວິທີການຈັດການຈຸດແທັບທີ່ຢູ່ໃກ້ກັບບ່ອນຂຶ້ນແຖວໃໝ່. ຖ້າບໍ່ເລືອກຊ່ອງນີ້, ຈຸດແທັບຈະຖືກຈັດການໃນລັກສະນະດຽວກັນກັບໃນແອັບພລິເຄຊັນ Office ອື່ນໆ."

#. yCdZt
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10810\n"
"help.text"
msgid "In text documents created by your current version of Writer, the new tab stop handling is used by default. In text documents created by Writer versions prior to StarOffice 8 or OpenOffice.org 2.0, the old tab stop handling is applied."
msgstr "ໃນເອກະສານຂໍ້ຄວາມທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນປັດຈຸບັນຂອງທ່ານ, ການຈັດການຈຸດແທັບແບບໃໝ່ຈະຖືກໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນ. ສ່ວນໃນເອກະສານທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0, ການຈັດການຈຸດແທັບແບບເກົ່າຈະຖືກນຳໃຊ້."

#. u7RWi
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN107F9\n"
"help.text"
msgid "Do not add leading (extra space) between lines of text"
msgstr "ບໍ່ຕ້ອງເພີ່ມໄລຍະຫ່າງ (ພື້ນທີ່ພິເສດ) ລະຫວ່າງແຖວຂອງຂໍ້ຄວາມ"

#. sEKBN
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10806\n"
"help.text"
msgid "Specifies that additional leading (extra space) between lines of text is not added, even if the font in use contains the additional leading attribute."
msgstr "ລະບຸວ່າຈະບໍ່ເພີ່ມໄລຍະຫ່າງພິເສດລະຫວ່າງແຖວຂອງຂໍ້ຄວາມ, ເຖິງແມ່ນວ່າຟອນທີ່ໃຊ້ຈະມີຄຸນລັກສະນະໄລຍະຫ່າງພິເສດກໍຕາມ."

#. mHLfw
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10809\n"
"help.text"
msgid "In text documents created by your current version of Writer, the additional leading is used by default. In text documents created by Writer versions prior to StarOffice 8 or OpenOffice.org 2.0, the additional leading is not used."
msgstr "ໃນເອກະສານຂໍ້ຄວາມທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນປັດຈຸບັນຂອງທ່ານ, ໄລຍະຫ່າງພິເສດຈະຖືກໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນ. ສ່ວນໃນເອກະສານທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0, ຈະບໍ່ມີການໃຊ້ໄລຍະຫ່າງພິເສດນີ້."

#. AxZBU
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN107FF\n"
"help.text"
msgid "Use OpenOffice.org 1.1 line spacing"
msgstr "ໃຊ້ໄລຍະຫ່າງແຖວຂອງ OpenOffice.org 1.1"

#. mYpm4
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10815\n"
"help.text"
msgid "If the option is off, a new process for formatting text lines with proportional line spacing will be applied. If the option is on, the previous method of formatting of text lines with proportional line spacing will be applied."
msgstr "ຖ້າປິດຕົວເລືອກນີ້, ຈະມີການນຳໃຊ້ຂະບວນການໃໝ່ໃນການຈັດຮູບແບບແຖວຂໍ້ຄວາມດ້ວຍໄລຍະຫ່າງແຖວແບບໄດ້ສັດສ່ວນ. ຖ້າເປີດຕົວເລືອກນີ້, ວິທີການຈັດຮູບແບບແຖວຂໍ້ຄວາມແບບເກົ່າຈະຖືກນຳໃຊ້."

#. Mqo8E
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10818\n"
"help.text"
msgid "In text documents created by your current version of Writer and in Microsoft Word documents of recent versions, the new process is used. In text documents created by Writer versions prior to StarOffice 8 or OpenOffice.org 2.0, the previous process is used."
msgstr "ໃນເອກະສານຂໍ້ຄວາມທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນປັດຈຸບັນ ແລະ ໃນເອກະສານ Microsoft Word ເວີຊັນໃໝ່ໆ, ຂະບວນການໃໝ່ຈະຖືກນຳໃຊ້. ສ່ວນໃນເອກະສານທີ່ສ້າງຂຶ້ນດ້ວຍ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0, ຂະບວນການແບບເກົ່າຈະຖືກນຳໃຊ້."

#. T9tGK
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN1081B\n"
"help.text"
msgid "Add paragraph and table spacing at bottom of table cells"
msgstr "ເພີ່ມໄລຍະຫ່າງຫຍໍ້ໜ້າ ແລະ ຕາຕະລາງ ທີ່ສ່ວນລຸ່ມຂອງຫ້ອງຕາຕະລາງ"

#. N8tD8
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10846\n"
"help.text"
msgid "Specifies that the bottom spacing is added to a paragraph, even when it is the last paragraph in a table cell."
msgstr "ລະບຸວ່າຈະເພີ່ມໄລຍະຫ່າງດ້ານລຸ່ມໃຫ້ກັບຫຍໍ້ໜ້າ, ເຖິງແມ່ນວ່າມັນຈະເປັນຫຍໍ້ໜ້າສຸດທ້າຍໃນຫ້ອງຕາຕະລາງກໍຕາມ."

#. Kb6Gx
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10849\n"
"help.text"
msgid "If the option is off, table cells will be formatted as in Writer versions prior to StarOffice 8 or OpenOffice.org 2.0. If the option is on, an alternative method of formatting table cells will be applied. The option is on by default for new documents created with %PRODUCTNAME and for documents imported from Microsoft Word format."
msgstr "ຖ້າປິດຕົວເລືອກນີ້, ຫ້ອງຕາຕະລາງຈະຖືກຈັດຮູບແບບຄືກັບໃນ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0. ຖ້າເປີດຕົວເລືອກນີ້, ຈະມີການນຳໃຊ້ວິທີການອື່ນໃນການຈັດຮູບແບບຫ້ອງຕາຕະລາງ. ຕົວເລືອກນີ້ຖືກເປີດໄວ້ເປັນຄ່າເລີ່ມຕົ້ນສຳລັບເອກະສານໃໝ່ທີ່ສ້າງດ້ວຍ %PRODUCTNAME ແລະ ສຳລັບເອກະສານທີ່ນຳເຂົ້າຈາກຮູບແບບ Microsoft Word."

#. EVC55
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN1084C\n"
"help.text"
msgid "Use OpenOffice.org 1.1 object positioning"
msgstr "ໃຊ້ການກຳນົດຕຳແໜ່ງວັດຖຸຂອງ OpenOffice.org 1.1"

#. CVZ4z
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10864\n"
"help.text"
msgid "Specifies how to calculate the position of floating objects anchored to a character or paragraph with respect to the top and bottom paragraph spacing."
msgstr "ລະບຸວິທີການຄຳນວນຕຳແໜ່ງຂອງວັດຖຸລອຍທີ່ຍຶດຕິດກັບຕົວອັກສອນ ຫຼື ຫຍໍ້ໜ້າ ໂດຍອ້າງອີງຈາກໄລຍະຫ່າງຫຍໍ້ໜ້າດ້ານເທິງ ແລະ ດ້ານລຸ່ມ."

#. tV8wz
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10867\n"
"help.text"
msgid "If the option is on, the floating objects are positioned as in Writer versions prior to StarOffice 8 or OpenOffice.org 2.0. If the option is off, the floating objects are positioned using an alternative method that is similar to the method used by Microsoft Word."
msgstr "ຖ້າເປີດຕົວເລືອກນີ້, ວັດຖຸລອຍຈະຖືກວາງຕຳແໜ່ງຄືກັບໃນ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0. ຖ້າປິດຕົວເລືອກນີ້, ວັດຖຸລອຍຈະຖືກວາງຕຳແໜ່ງໂດຍໃຊ້ວິທີການອື່ນທີ່ຄ້າຍຄືກັບວິທີການທີ່ໃຊ້ໂດຍ Microsoft Word."

#. fLiAw
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN1086A\n"
"help.text"
msgid "The option will be set to off for new documents. For Writer documents created by a version prior to OpenOffice.org 2.0 the option is on."
msgstr "ຕົວເລືອກນີ້ຈະຖືກຕັ້ງເປັນ ປິດ ສຳລັບເອກະສານໃໝ່. ສຳລັບເອກະສານ Writer ທີ່ສ້າງຂຶ້ນໂດຍເວີຊັນກ່ອນ OpenOffice.org 2.0, ຕົວເລືອກນີ້ຈະຖືກເປີດໄວ້."

#. BTBF5
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10821\n"
"help.text"
msgid "Use OpenOffice.org 1.1 text wrapping around objects"
msgstr "ໃຊ້ການຕັດຂໍ້ຄວາມອ້ອມຮອບວັດຖຸຂອງ OpenOffice.org 1.1"

#. asD4C
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id171775515224987\n"
"help.text"
msgid "By default, page header and footer content, as well as footnote and endnote content, does not wrap around floating screen objects. This behavior mirrors how Microsoft Word handles these objects. To enable text wrapping around floating screen objects in headers/footers or footnotes/endnotes, turn on this option."
msgstr "ໂດຍຄ່າເລີ່ມຕົ້ນ, ເນື້ອຫາໃນຫົວເຈ້ຍ ແລະ ທ້າຍເຈ້ຍ, ລວມທັງເນື້ອຫາໃນເລກອ້າງອີງທ້າຍໜ້າ (footnote) ແລະ ເລກອ້າງອີງທ້າຍເອກະສານ (endnote), ຈະບໍ່ຕັດອ້ອມຮອບວັດຖຸລອຍ. ພຶດຕິກຳນີ້ແມ່ນຄືກັນກັບວິທີທີ່ Microsoft Word ຈັດການກັບວັດຖຸເຫຼົ່ານີ້. ເພື່ອເປີດໃຊ້ການຕັດຂໍ້ຄວາມອ້ອມຮອບວັດຖຸລອຍໃນສ່ວນເຫຼົ່ານັ້ນ, ໃຫ້ເປີດຕົວເລືອກນີ້."

#. vDj4r
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10892\n"
"help.text"
msgid "If the option is off, which is the default setting, the new text wrapping will be applied."
msgstr "ຖ້າປິດຕົວເລືອກນີ້, ເຊິ່ງເປັນການຕັ້ງຄ່າເລີ່ມຕົ້ນ, ການຕັດຂໍ້ຄວາມແບບໃໝ່ຈະຖືກນຳໃຊ້."

#. yGkwB
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN1092A\n"
"help.text"
msgid "Consider wrapping style when positioning objects"
msgstr "ພິຈາລະນາຮູບແບບການຕັດຂໍ້ຄວາມເມື່ອວາງຕຳແໜ່ງວັດຖຸ"

#. hf5MD
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10837\n"
"help.text"
msgid "Specifies how the complex process of positioning floating objects that are anchored to a character or paragraph should work. In Writer versions prior to StarOffice 8 or OpenOffice.org 2.0, an iterative process was used, while in current versions a straightforward process is used, which is similar to the same process in Microsoft Word."
msgstr "ລະບຸວ່າຂະບວນການທີ່ຊັບຊ້ອນຂອງການວາງຕຳແໜ່ງວັດຖຸລອຍທີ່ຍຶດຕິດກັບຕົວອັກສອນ ຫຼື ຫຍໍ້ໜ້າຄວນເຮັດວຽກແນວໃດ. ໃນ Writer ເວີຊັນກ່ອນ StarOffice 8 ຫຼື OpenOffice.org 2.0, ມີການໃຊ້ຂະບວນການແບບເຮັດຊ້ຳ (iterative), ໃນຂະນະທີ່ເວີຊັນປັດຈຸບັນໃຊ້ຂະບວນການແບບກົງໄປກົງມາ, ເຊິ່ງຄ້າຍຄືກັບຂະບວນການດຽວກັນໃນ Microsoft Word."

#. zcUDo
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10943\n"
"help.text"
msgid "If the option is off, the old %PRODUCTNAME iterative process of object positioning is used. If the option is on, the new straightforward process is used to ensure compatibility with Microsoft Word documents."
msgstr "ຖ້າປິດຕົວເລືອກນີ້, ຈະມີການໃຊ້ຂະບວນການວາງຕຳແໜ່ງວັດຖຸແບບເຮັດຊ້ຳຂອງ %PRODUCTNAME ແບບເກົ່າ. ຖ້າເປີດຕົວເລືອກນີ້, ຈະມີການໃຊ້ຂະບວນການແບບກົງໄປກົງມາແບບໃໝ່ເພື່ອຮັບປະກັນຄວາມເຂົ້າກັນໄດ້ກັບເອກະສານ Microsoft Word."

#. wncCm
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id5240028\n"
"help.text"
msgid "Justify lines with a manual line break in justified paragraphs"
msgstr "ຈັດຂໍ້ຄວາມໃຫ້ສະເໝີຂອບ (Justify) ສຳລັບແຖວທີ່ມີການຂຶ້ນແຖວດ້ວຍຕົນເອງໃນຫຍໍ້ໜ້າທີ່ຕັ້ງຄ່າສະເໝີຂອບໄວ້"

#. HiKzW
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id8599810\n"
"help.text"
msgid "If enabled, Writer adds spacing between words, in lines that end with Shift+Enter in justified paragraphs. If disabled, spacing between words will not be expanded to justify the lines."
msgstr "ຖ້າເປີດໃຊ້, Writer ຈະເພີ່ມໄລຍະຫ່າງລະຫວ່າງຄຳ ໃນແຖວທີ່ລົງທ້າຍດ້ວຍ Shift+Enter ໃນຫຍໍ້ໜ້າທີ່ຈັດໃຫ້ສະເໝີຂອບ. ຖ້າປິດໃຊ້, ໄລຍະຫ່າງລະຫວ່າງຄຳຈະບໍ່ຖືກຂະຫຍາຍອອກເພື່ອໃຫ້ແຖວນັ້ນສະເໝີຂອບ."

#. CkDJv
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id8012634\n"
"help.text"
msgid "This setting is on by default for .odt text documents. It will be saved and loaded with the document in the .odt text document format. This setting cannot be saved in old .sxw text documents, so this setting is off for .sxw text documents."
msgstr "ການຕັ້ງຄ່ານີ້ຖືກເປີດໄວ້ເປັນຄ່າເລີ່ມຕົ້ນສຳລັບເອກະສານຂໍ້ຄວາມ .odt. ມັນຈະຖືກບັນທຶກ ແລະ ໂຫລດພ້ອມກັບເອກະສານໃນຮູບແບບ .odt. ການຕັ້ງຄ່ານີ້ບໍ່ສາມາດບັນທຶກໄວ້ໃນເອກະສານ .sxw ແບບເກົ່າໄດ້, ດັ່ງນັ້ນການຕັ້ງຄ່ານີ້ຈຶ່ງຖືກປິດຕັ້ງແຕ່ເລີ່ມຕົ້ນສຳລັບເອກະສານ .sxw."

#. XyTCL
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id731775509387776\n"
"help.text"
msgid "Protect form (no longer protects whole document. Insert write protected section instead)"
msgstr "ປ້ອງກັນແບບຟອມ (ບໍ່ໄດ້ປ້ອງກັນທັງໝົດເອກະສານອີກຕໍ່ໄປ. ໃຫ້ແຊກສ່ວນທີ່ປ້ອງກັນການຂຽນແທນ)"

#. AHDuo
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id821775510970226\n"
"help.text"
msgid "When importing forms from Microsoft Word, the document content outside of form controls is locked and can only be imported as read-only. This setting allows you to edit the document by enclosing the form controls in protected sections."
msgstr "ເມື່ອນຳເຂົ້າແບບຟອມຈາກ Microsoft Word, ເນື້ອຫາເອກະສານທີ່ຢູ່ນອກຕົວຄວບຄຸມແບບຟອມຈະຖືກລັອກ ແລະ ສາມາດນຳເຂົ້າໄດ້ໃນຮູບແບບອ່ານໄດ້ຢ່າງດຽວເທົ່ານັ້ນ. ການຕັ້ງຄ່ານີ້ຊ່ວຍໃຫ້ທ່ານສາມາດແກ້ໄຂເອກະສານໄດ້ໂດຍການລວມຕົວຄວບຄຸມແບບຟອມໄວ້ໃນສ່ວນທີ່ໄດ້ຮັບການປ້ອງກັນ."

#. vMEcy
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id271775511404238\n"
"help.text"
msgid "Word-compatible trailing blanks"
msgstr "ຊ່ອງວ່າງທ້າຍແຖວທີ່ເຂົ້າກັນໄດ້ກັບ Word"

#. mcLf9
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id771775511546325\n"
"help.text"
msgid "Ensure trailing spaces and their highlighting are compatible with Microsoft Word. This option is enabled by default for imported Microsoft Word formats (.doc, .docx, .rtf). For ODF files, the option is disabled by default."
msgstr "ຮັບປະກັນວ່າຊ່ອງວ່າງທ້າຍແຖວ ແລະ ການເນັ້ນຂໍ້ຄວາມນັ້ນເຂົ້າກັນໄດ້ກັບ Microsoft Word. ຕົວເລືອກນີ້ຖືກເປີດໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນສຳລັບຮູບແບບ Microsoft Word ທີ່ນຳເຂົ້າ (.doc, .docx, .rtf). ສຳລັບໄຟລ໌ ODF, ຕົວເລືອກນີ້ຈະຖືກປິດຕັ້ງແຕ່ເລີ່ມຕົ້ນ."

#. UHPFr
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id5241028\n"
"help.text"
msgid "Tolerate white lines that may appear in PDF page backgrounds"
msgstr "ຍອມຮັບເສັ້ນສີຂາວທີ່ອາດຈະປາກົດຢູ່ໃນພື້ນຫຼັງໜ້າ PDF"

#. eFA8D
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id8112634\n"
"help.text"
msgid "Use %PRODUCTNAME 4.3 anchoring paint order and tolerate white lines that may appear in PDF page backgrounds created from legacy documents."
msgstr "ໃຊ້ລຳດັບການແຕ້ມການຍຶດຕິດຂອງ %PRODUCTNAME 4.3 ແລະ ຍອມຮັບເສັ້ນສີຂາວທີ່ອາດຈະປາກົດຢູ່ໃນພື້ນຫຼັງໜ້າ PDF ທີ່ສ້າງຂຶ້ນຈາກເອກະສານແບບເກົ່າ."

#. 5yEpF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id621775508845687\n"
"help.text"
msgid "Hide paragraphs of mail merge fields with empty value when generating merged documents"
msgstr "ເຊື່ອງຫຍໍ້ໜ້າຂອງຟີວຈົດໝາຍວຽນ (mail merge) ທີ່ມີຄ່າວ່າງ ເມື່ອສ້າງເອກະສານທີ່ລວມແລ້ວ"

#. JYBqz
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id341775509176468\n"
"help.text"
msgid "When this setting is active, database fields that expand to empty values are treated as hidden paragraph fields. The option is enabled by default and is automatically applied to non-ODF documents (to ensure compatibility with other office suites). For existing ODT documents, the option remains disabled if the setting was not previously configured, preserving the layout of legacy documents."
msgstr "ເມື່ອການຕັ້ງຄ່ານີ້ເຮັດວຽກ, ຟີວຖານຂໍ້ມູນທີ່ຂະຫຍາຍອອກເປັນຄ່າວ່າງຈະຖືກຖືວ່າເປັນຟີວຫຍໍ້ໜ້າທີ່ເຊື່ອງໄວ້. ຕົວເລືອກນີ້ຖືກເປີດໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນ ແລະ ຈະຖືກນຳໃຊ້ໂດຍອັດຕະໂນມັດກັບເອກະສານທີ່ບໍ່ແມ່ນ ODF (ເພື່ອຮັບປະກັນຄວາມເຂົ້າກັນໄດ້ກັບຊຸດໂປຣແກຣມອື່ນ). ສຳລັບເອກະສານ ODT ທີ່ມີຢູ່ແລ້ວ, ຕົວເລືອກນີ້ຈະຍັງຄົງປິດຢູ່ ຖ້າບໍ່ໄດ້ຕັ້ງຄ່າໄວ້ກ່ອນໜ້ານີ້ ເພື່ອຮັກສາຮູບແບບຂອງເອກະສານແບບເກົ່າໄວ້."

#. ytj2n
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id431775490598065\n"
"help.text"
msgid "Render non-breaking spaces (NBSP) as standard-space-width (off for fixed size)"
msgstr "ສະແດງຜົນຊ່ອງວ່າງທີ່ບໍ່ຕັດແຖວ (NBSP) ໃຫ້ມີຄວາມກວ້າງເທົ່າກັບຊ່ອງວ່າງມາດຕະຖານ (ປິດສຳລັບຂະໜາດຄົງທີ່)"

#. wYknQ
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id831775491137518\n"
"help.text"
msgid "When this option is enabled (opt-in for both old and new documents), non-breaking space character will no longer be strictly fixed in width. When disabled, the NBSP character has always the width of a standard space (U+0020) on the given line. This change is only noticeable when the paragraph is justified."
msgstr "ເມື່ອເປີດໃຊ້ຕົວເລືອກນີ້ (ມີຜົນທັງເອກະສານເກົ່າ ແລະ ໃໝ່), ຕົວອັກສອນຊ່ອງວ່າງທີ່ບໍ່ຕັດແຖວຈະບໍ່ມີຄວາມກວ້າງຄົງທີ່ອີກຕໍ່ໄປ. ເມື່ອປິດໃຊ້, ຕົວອັກສອນ NBSP ຈະມີຄວາມກວ້າງເທົ່າກັບຊ່ອງວ່າງມາດຕະຖານ (U+0020) ໃນແຖວນັ້ນສະເໝີ. ການປ່ຽນແປງນີ້ຈະສັງເກດເຫັນໄດ້ກໍຕໍ່ເມື່ອຫຍໍ້ໜ້າຖືກຈັດໃຫ້ສະເໝີຂອບເທົ່ານັ້ນ."

#. wi7np
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id861775491149468\n"
"help.text"
msgid "Additionally, when non-printable characters are displayed, a tilde (~) or degree symbol (°) will now appear in place of a non-breaking space (NBSP), as the gray field alone is often not visible."
msgstr "ນອກຈາກນີ້, ເມື່ອຕົວອັກສອນທີ່ພິມອອກບໍ່ໄດ້ຖືກສະແດງ, ເຄື່ອງໝາຍ () ຫຼື ເຄື່ອງໝາຍອົງສາ (°) ຈະປະກົດຂຶ້ນແທນທີ່ຍະຫວ່າງທີ່ບໍ່ຕັດແຖວ (NBSP), ເນື່ອງຈາກວ່າພື້ນສີເທົາພຽງຢ່າງດຽວມັກຈະເບິ່ງບໍ່ເຫັນ."

#. Y2aeF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id251775487542065\n"
"help.text"
msgid "Do not add an extra space after number in footnotes / endnotes with hanging first line"
msgstr "ບໍ່ຕ້ອງເພີ່ມຊ່ອງວ່າງພິເສດຫຼັງຕົວເລກໃນເລກອ້າງອີງທ້າຍໜ້າ / ທ້າຍເອກະສານ ທີ່ມີການຫຍໍ້ໜ້າແຖວທຳອິດແບບແຂວນ (hanging)"

#. tbbHS
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id61775487840770\n"
"help.text"
msgid "This option removes extra spacing between the footnote number and its text when the paragraph has a hanging indent, such as in Microsoft Word."
msgstr "ຕົວເລືອກນີ້ຈະລຶບໄລຍະຫ່າງພິເສດລະຫວ່າງຕົວເລກອ້າງອີງທ້າຍໜ້າ ແລະ ຂໍ້ຄວາມຂອງມັນ ເມື່ອຫຍໍ້ໜ້າມີການຫຍໍ້ໜ້າແບບແຂວນ, ຄືກັນກັບໃນ Microsoft Word."

#. 7UymC
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id351775502351232\n"
"help.text"
msgid "Set tabstops relative to indent of paragraph"
msgstr "ຕັ້ງຈຸດແທັບໂດຍອ້າງອີງຈາກການຫຍໍ້ໜ້າຂອງຫຍໍ້ໜ້າ"

#. rffo6
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id241775502386575\n"
"help.text"
msgid "This setting makes all paragraph tab positions relative to left page margin, not to the indent of the paragraph."
msgstr "ການຕັ້ງຄ່ານີ້ເຮັດໃຫ້ທຸກຕຳແໜ່ງແທັບຂອງຫຍໍ້ໜ້າອ້າງອີງຈາກຂອບເຈ້ຍດ້ານຊ້າຍ, ບໍ່ແມ່ນອ້າງອີງຈາກການຫຍໍ້ໜ້າຂອງຫຍໍ້ໜ້າ."

#. 7K5x6
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id831775502883657\n"
"help.text"
msgid "Allow tabs to extend beyond the right margin"
msgstr "ອະນຸຍາດໃຫ້ແທັບຂະຫຍາຍອອກໄປເກີນຂອບຂວາໄດ້"

#. qXiZX
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id801775504453500\n"
"help.text"
msgid "When this option is enabled, paragraph tab stops can extend beyond the right margin. When disabled, tab stops beyond the right margin are ignored."
msgstr "ເມື່ອເປີດໃຊ້ຕົວເລືອກນີ້, ຈຸດແທັບຂອງຫຍໍ້ໜ້າສາມາດຂະຫຍາຍອອກໄປເກີນຂອບຂວາໄດ້. ເມື່ອປິດໃຊ້, ຈຸດແທັບທີ່ຢູ່ເກີນຂອບຂວາຈະຖືກລະເວັ້ນ."

#. DcaNP
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id361775500718228\n"
"help.text"
msgid "Do not mirror drawing objects anchored in paragraphs with an RTL writing direction"
msgstr "ບໍ່ຕ້ອງສະທ້ອນ (mirror) ວັດຖຸແຕ້ມທີ່ຍຶດຕິດໃນຫຍໍ້ໜ້າທີ່ມີທິດທາງການຂຽນແບບຂວາຫາຊ້າຍ (RTL)"

#. Dn3CA
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id861775500931942\n"
"help.text"
msgid "Writer automatically mirrors drawing objects anchored in right-to-left (RTL) paragraphs, whereas Microsoft Word does not. When this option is enabled (intended for DOCX files), Writer will not automatically mirror the position of drawing objects simply because they are anchored in an RTL text node."
msgstr "Writer ຈະສະທ້ອນຕຳແໜ່ງວັດຖຸແຕ້ມທີ່ຍຶດຕິດໃນຫຍໍ້ໜ້າແບບຂວາຫາຊ້າຍ (RTL) ໂດຍອັດຕະໂນມັດ, ໃນຂະນະທີ່ Microsoft Word ບໍ່ເຮັດ. ເມື່ອເປີດໃຊ້ຕົວເລືອກນີ້ (ມີໄວ້ສຳລັບໄຟລ໌ DOCX), Writer ຈະບໍ່ສະທ້ອນຕຳແໜ່ງວັດຖຸແຕ້ມໂດຍອັດຕະໂນມັດ ພຽງເພາະວ່າມັນຍຶດຕິດຢູ່ໃນຂໍ້ຄວາມແບບ RTL."

#. GjsAR
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id181775505181987\n"
"help.text"
msgid "Render endnotes at the end of document inline, rather than on a separate page"
msgstr "ສະແດງຜົນເລກອ້າງອີງທ້າຍເອກະສານໄວ້ທີ່ທ້າຍເອກະສານຕໍ່ກັນໄປເລີຍ, ແທນທີ່ຈະຢູ່ໜ້າແຍກຕ່າງຫາກ"

#. vuAro
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id201775506024432\n"
"help.text"
msgid "By default, Writer places endnotes on one or more separate endnote pages, while Microsoft Word positions them inline at the end of the document, immediately following the body text. This setting creates a dedicated section at the layout level and places the endnotes within that section, effectively making them inline."
msgstr "ໂດຍຄ່າເລີ່ມຕົ້ນ, Writer ຈະວາງເລກອ້າງອີງທ້າຍເອກະສານ (endnotes) ໄວ້ໃນໜ້າແຍກຕ່າງຫາກໜຶ່ງໜ້າ ຫຼື ຫຼາຍໜ້າ, ໃນຂະນະທີ່ Microsoft Word ຈະວາງພວກມັນໄວ້ຕໍ່ຈາກເນື້ອຫາຫຼັກຢູ່ທ້າຍເອກະສານທັນທີ. ການຕັ້ງຄ່ານີ້ຈະສ້າງສ່ວນສະເພາະໃນລະດັບການຈັດວາງ ແລະ ວາງເລກອ້າງອີງທ້າຍເອກະສານໄວ້ໃນສ່ວນນັ້ນ ເພື່ອໃຫ້ພວກມັນສະແດງຜົນແບບຕໍ່ກັນໄປເລີຍ (inline)."

#. 7zuAf
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id551775488780326\n"
"help.text"
msgid "Use Word-compatible font metrics for text grid and Asian text"
msgstr "ໃຊ້ຂະໜາດຟອນ (font metrics) ທີ່ເຂົ້າກັນໄດ້ກັບ Word ສຳລັບເສັ້ນຕາໜ່າງຂໍ້ຄວາມ ແລະ ຂໍ້ຄວາມພາສາອາຊີ"

#. LajiR
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id841775513273336\n"
"help.text"
msgid "Whenever Microsoft Word uses a CJK font to lay out text, it applies an extra multiplier to the line height. This behavior depends solely on the font file itself—it does not matter whether the font is set as the East Asian font or if the text contains any CJK characters. The only determining factor is whether the font identifies itself as a CJK font."
msgstr "ທຸກຄັ້ງທີ່ Microsoft Word ໃຊ້ຟອນ CJK ໃນການຈັດວາງຂໍ້ຄວາມ, ມັນຈະນຳໃຊ້ຕົວຄູນພິເສດກັບຄວາມສູງຂອງແຖວ. ພຶດຕິກຳນີ້ຂຶ້ນຢູ່ກັບໄຟລ໌ຟອນນັ້ນໆ ເອງ — ບໍ່ວ່າຈະຕັ້ງຟອນນັ້ນເປັນຟອນອາຊີຕາເວັນອອກ ຫຼື ຂໍ້ຄວາມຈະມີຕົວອັກສອນ CJK ຫຼື ບໍ່ກໍຕາມ. ປັດໄຈດຽວທີ່ກຳນົດແມ່ນຟອນນັ້ນລະບຸວ່າຕົນເອງເປັນຟອນ CJK ຫຼື ບໍ່."

#. QFCiY
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id411775489088965\n"
"help.text"
msgid "If the font reports coverage for any of the following code pages, the line height multiplier is applied:"
msgstr "ຖ້າຟອນນັ້ນຮອງຮັບລະຫັດພາສາ (code pages) ໃດໜຶ່ງຕໍ່ໄປນີ້, ຕົວຄູນຄວາມສູງຂອງແຖວຈະຖືກນຳໃຊ້:"

#. kfbKu
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id911775488976633\n"
"help.text"
msgid "CP932 (JIS/Japan)"
msgstr "CP932 (JIS/ຍີ່ປຸ່ນ)"

#. KSKSN
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id971775488983325\n"
"help.text"
msgid "CP936 (Simplified Chinese)"
msgstr "CP936 (ຈີນຕົວຫຍໍ້)"

#. aZZ2f
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id991775488989671\n"
"help.text"
msgid "CP949 (Korean Wansung encoding)"
msgstr "CP949 (ການເຂົ້າລະຫັດ Wansung ຂອງເກົາຫຼີ)"

#. 3PD3u
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id561775488994718\n"
"help.text"
msgid "CP950 (Traditional Chinese)"
msgstr "CP950 (ຈີນຕົວເຕັມ)"

#. CvmdG
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id51775489095386\n"
"help.text"
msgid "Writer would respect the original font metrics when laying out DOC/DOCX files. This change makes Writer try to emulate Microsoft Word behavior instead, subject to a compatibility flag."
msgstr "Writer ຈະເຄົາລົບຂະໜາດຟອນຕົ້ນສະບັບເມື່ອຈັດວາງໄຟລ໌ DOC/DOCX. ການປ່ຽນແປງນີ້ເຮັດໃຫ້ Writer ພະຍາຍາມຮຽນແບບພຶດຕິກຳຂອງ Microsoft Word ແທນ, ໂດຍຂຶ້ນຢູ່ກັບເຄື່ອງໝາຍຄວາມເຂົ້າກັນໄດ້."

#. 6QsTF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id161775488337683\n"
"help.text"
msgid "Make whitespace character height not affect line height"
msgstr "ເຮັດໃຫ້ຄວາມສູງຂອງຕົວອັກສອນຊ່ອງວ່າງບໍ່ມີຜົນຕໍ່ຄວາມສູງຂອງແຖວ"

#. WqAzm
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id361775488397163\n"
"help.text"
msgid "Remove <keycode>space</keycode> and <keycode>tab</keycode> characters height value from line height calculation. This setting is enabled by default in Microsoft Word document file formats."
msgstr "ເອົາຄ່າຄວາມສູງຂອງຕົວອັກສອນ <keycode>ຍະວ່າງ (space)</keycode> ແລະ <keycode>ແທັບ (tab)</keycode> ອອກຈາກການຄຳນວນຄວາມສູງຂອງແຖວ. ການຕັ້ງຄ່ານີ້ຖືກເປີດໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນໃນຮູບແບບໄຟລ໌ເອກະສານ Microsoft Word."

#. gBQfy
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id111775484948655\n"
"help.text"
msgid "Underline Word-compatible trailing blanks"
msgstr "ຂີດກ້ອງຊ່ອງວ່າງທ້າຍແຖວທີ່ເຂົ້າກັນໄດ້ກັບ Word"

#. pgMDp
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id811775486012055\n"
"help.text"
msgid "Microsoft Word’s <literal>Underline Trailing Spaces</literal> compatibility option. Previously, the feature behaved as if this option was always enabled, while in Word it is disabled by default."
msgstr "ຕົວເລືອກຄວາມເຂົ້າກັນໄດ້ <literal>ຂີດກ້ອງຊ່ອງວ່າງທ້າຍແຖວ</literal> ຂອງ Microsoft Word. ກ່ອນໜ້ານີ້, ຄຸນສົມບັດນີ້ເຮັດວຽກຄືກັບວ່າມັນຖືກເປີດໃຊ້ຕະຫຼອດເວລາ, ໃນຂະນະທີ່ຢູ່ໃນ Word ມັນຈະຖືກປິດຕັ້ງແຕ່ເລີ່ມຕົ້ນ."

#. GuNdF
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id571775484561265\n"
"help.text"
msgid "Adjust spaces to half the width of ideographic spaces, using Word-compatible rules"
msgstr "ປັບຊ່ອງວ່າງໃຫ້ມີຄວາມກວ້າງເຄິ່ງໜຶ່ງຂອງຊ່ອງວ່າງແບບ ideographic, ໂດຍໃຊ້ກົດລະບຽບທີ່ເຂົ້າກັນໄດ້ກັບ Word"

#. x3aa9
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id491775484705021\n"
"help.text"
msgid "When enabled, Writer adjusts the width of certain normal space characters to one half the width of a CJK ideographic space. This adjustment is only applied to leading and trailing spaces, multiple sequential spaces, and spaces between CJK characters."
msgstr "ເມື່ອເປີດໃຊ້, Writer ຈະປັບຄວາມກວ້າງຂອງຕົວອັກສອນຊ່ອງວ່າງປົກກະຕິບາງຕົວໃຫ້ເປັນເຄິ່ງໜຶ່ງຂອງຄວາມກວ້າງຂອງຊ່ອງວ່າງແບບ CJK ideographic. ການປັບປຸງນີ້ຈະໃຊ້ກັບຊ່ອງວ່າງທາງໜ້າ ແລະ ທາງຫຼັງ, ຊ່ອງວ່າງທີ່ລຽງຕໍ່ກັນຫຼາຍຕົວ, ແລະ ຊ່ອງວ່າງລະຫວ່າງຕົວອັກສອນ CJK ເທົ່ານັ້ນ."

#. KjpFp
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id101775484792731\n"
"help.text"
msgid "This flag is enabled automatically when importing DOCX files with the <literal>w:balanceSingleByteDoubleByteWidth</literal> option enabled and also when importing DOC files with the <literal>fDntBlnSbDbWid</literal> compatibility flag unset."
msgstr "ເຄື່ອງໝາຍນີ້ຈະຖືກເປີດໃຊ້ໂດຍອັດຕະໂນມັດເມື່ອນຳເຂົ້າໄຟລ໌ DOCX ທີ່ມີຕົວເລືອກ <literal>w:balanceSingleByteDoubleByteWidth</literal> ເປີດຢູ່ ແລະ ເມື່ອນຳເຂົ້າໄຟລ໌ DOC ທີ່ບໍ່ໄດ້ຕັ້ງເຄື່ອງໝາຍຄວາມເຂົ້າກັນໄດ້ <literal>fDntBlnSbDbWid</literal> ໄວ້."

#. VD6WV
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id161775481889189\n"
"help.text"
msgid "Adjust line heights to grid height in table"
msgstr "ປັບຄວາມສູງຂອງແຖວໃຫ້ເທົ່າກັບຄວາມສູງຂອງເສັ້ນຕາໜ່າງໃນຕາຕະລາງ"

#. pMFyj
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id771775484297677\n"
"help.text"
msgid "For CJK text documents using a CJK Text Grid, the number of lines per page and the number of characters per line are specified in the page style. Typically, adjusting the number of lines per page also impacts tables. This compatibility option disables that behavior, ensuring tables remain unaffected by the grid lines per page setting. The option was introduced to match a similar feature in Microsoft Word, allowing these documents to be rendered accurately."
msgstr "ສຳລັບເອກະສານຂໍ້ຄວາມ CJK ທີ່ໃຊ້ເສັ້ນຕາໜ່າງຂໍ້ຄວາມ CJK, ຈຳນວນແຖວຕໍ່ໜ້າ ແລະ ຈຳນວນຕົວອັກສອນຕໍ່ແຖວແມ່ນຖືກກຳນົດໄວ້ໃນຮູບແບບໜ້າ. ໂດຍປົກກະຕິແລ້ວ, ການປັບຈຳນວນແຖວຕໍ່ໜ້າຈະມີຜົນຕໍ່ຕາຕະລາງນຳ. ຕົວເລືອກຄວາມເຂົ້າກັນໄດ້ນີ້ຈະປິດພຶດຕິກຳດັ່ງກ່າວ ເພື່ອຮັບປະກັນວ່າຕາຕະລາງຈະບໍ່ໄດ້ຮັບຜົນກະທົບຈາກການຕັ້ງຄ່າແຖວຕາໜ່າງຕໍ່ໜ້າ. ຕົວເລືອກນີ້ຖືກນຳເຂົ້າມາເພື່ອໃຫ້ກົງກັບຄຸນສົມບັດທີ່ຄ້າຍຄືກັນໃນ Microsoft Word, ເພື່ອໃຫ້ເອກະສານເຫຼົ່ານີ້ສະແດງຜົນໄດ້ຢ່າງຖືກຕ້ອງ."

#. jMfCM
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"hd_id441775479830046\n"
"help.text"
msgid "Ignore paragraph directions for list label alignment"
msgstr "ລະເວັ້ນທິດທາງຂອງຫຍໍ້ໜ້າສຳລັບການຈັດວາງປ້າຍລາຍການ (list label)"

#. exg65
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id481775481291887\n"
"help.text"
msgid "Writer now applies list label direction, ensuring that start and end label alignment match start and end paragraph alignment. When this option is enabled, Writer ignores paragraph direction for list labels, always using left-to-right alignment."
msgstr "ຕອນນີ້ Writer ນຳໃຊ້ທິດທາງປ້າຍລາຍການ ເພື່ອຮັບປະກັນວ່າການຈັດວາງປ້າຍທັງຕອນເລີ່ມຕົ້ນ ແລະ ຕອນທ້າຍຈະກົງກັບການຈັດວາງຫຍໍ້ໜ້າ. ເມື່ອເປີດໃຊ້ຕົວເລືອກນີ້, Writer ຈະລະເວັ້ນທິດທາງຂອງຫຍໍ້ໜ້າສຳລັບປ້າຍລາຍການ ແລະ ຈະໃຊ້ການຈັດວາງແບບຊ້າຍຫາຂວາສະເໝີ."

#. vG449
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_id531775481835567\n"
"help.text"
msgid "In order to preserve the layout of existing documents, this flag is enabled automatically when loading an ODF created with earlier versions of %PRODUCTNAME."
msgstr "ເພື່ອຮັກສາຮູບແບບຂອງເອກະສານທີ່ມີຢູ່ແລ້ວ, ເຄື່ອງໝາຍນີ້ຈະຖືກເປີດໃຊ້ໂດຍອັດຕະໂນມັດເມື່ອໂຫລດ ODF ທີ່ສ້າງດ້ວຍ %PRODUCTNAME ເວີຊັນກ່ອນໜ້ານີ້."

#. C3cmh
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10845\n"
"help.text"
msgid "Use as Default"
msgstr "ໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນ"

#. tLtsB
#: 01041000.xhp
msgctxt ""
"01041000.xhp\n"
"par_idN10848\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/optcompatpage/default\">Click to use the current settings on this tab page as the default for further sessions with %PRODUCTNAME.</ahelp>"
