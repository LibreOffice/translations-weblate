msgid "Treat as equal"
msgstr "ຖືວ່າເທົ່າກັນ"

#. E9U6m
#: 01150200.xhp
msgctxt ""
"01150200.xhp\n"
"par_id3154514\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/optjsearchpage/matchprolongedsoundmark\" visibility=\"visible\">Specifies the options to be treated as equal in a search.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/optjsearchpage/matchprolongedsoundmark\" visibility=\"visible\">ກໍານົດຕົວເລືອກທີ່ຈະໃຫ້ຖືວ່າເທົ່າກັນໃນການຄົ້ນຫາ.</ahelp>"

#. V5uxp
