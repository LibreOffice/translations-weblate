"par_id741715611637972\n"
"help.text"
msgid "Press <input>Alt+F12</input> then choose  <menuitem>%PRODUCTNAME Calc - View</menuitem>."
msgstr "ກົດ <input>Alt+F12</input> ຈາກນັ້ນເລືອກ <menuitem>%PRODUCTNAME Calc - ມຸມມອງ</menuitem>."

#. 4eD3Z
