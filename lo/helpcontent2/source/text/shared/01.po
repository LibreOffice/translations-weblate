"05200100.xhp\n"
"par_id3154586\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/linetabpage/LB_CAP_STYLE\">Select the style of the line end caps. The caps are added to inner dashes as well.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/linetabpage/LB_CAP_STYLE\">ເລືອກຮູບແບບຂອງຫົວປິດປາຍເສັ້ນ. ຫົວປິດຈະຖືກເພີ່ມເຂົ້າໃນເສັ້ນຂີດພາຍໃນນຳ.</ahelp>"

#. dgoUP
