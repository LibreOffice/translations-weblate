#. MvuEk
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id3394573\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies an exclusive upper bound for values.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຂອບເຂດສູງສຸດແບບບໍ່ລວມຄ່ານັ້ນສຳລັບຄ່າຕ່າງໆ.</ahelp>"

#. y33Fz
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id7594225\n"
"help.text"
msgid "Min. (inclusive)"
msgstr "ຕ່ຳສຸດ (ລວມຄ່ານີ້)"

#. ByUzo
