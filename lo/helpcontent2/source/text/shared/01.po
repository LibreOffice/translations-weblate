msgstr "ໄລຍະຫ່າງແຖວ 2"

#. HDPps
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3151206\n"
"help.text"
msgid "Proportional"
msgstr "ຕາມສັດສ່ວນ"

#. m3zDL
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3147494\n"
"help.text"
msgid "Select this option and then enter a percentage value in the box, where 100% corresponds to single line spacing."
msgstr "ເລືອກຕົວເລືອກນີ້ ແລ້ວປ້ອນຄ່າເປີເຊັນໃນຊ່ອງ, ໂດຍທີ່ 100% ຈະເທົ່າກັບໄລຍະຫ່າງແຖວດ່ຽວ."

#. N57s7
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3156332\n"
"help.text"
msgid "At Least"
msgstr "ຢ່າງໜ້ອຍ"

#. 4AHye
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3157965\n"
"help.text"
msgid "Sets the minimum line spacing to the value that you enter in the box."
msgstr "ກຳນົດໄລຍະຫ່າງແຖວຕໍ່າສຸດຕາມຄ່າທີ່ທ່ານປ້ອນໃນຊ່ອງ."

#. jBvFh
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3150744\n"
"help.text"
msgid "If you use different font sizes within a paragraph, the line spacing is automatically adjusted to the largest font size. If you prefer to have identical spacing for all lines, specify a value in <emph>At least</emph> that corresponds to the largest font size."
msgstr "ຖ້າທ່ານໃຊ້ຂະໜາດຟອນທີ່ແຕກຕ່າງກັນພາຍໃນຫຍໍ້ໜ້າດຽວ, ໄລຍະຫ່າງແຖວຈະຖືກປັບໃຫ້ເໝາະສົມກັບຂະໜາດຟອນທີ່ໃຫຍ່ທີ່ສຸດໂດຍອັດຕະໂນມັດ. ຖ້າທ່ານຕ້ອງການໃຫ້ທຸກແຖວມີໄລຍະຫ່າງເທົ່າກັນ, ໃຫ້ລະບຸຄ່າໃນ <emph>ຢ່າງໜ້ອຍ</emph> ໃຫ້ກົງກັບຂະໜາດຟອນທີ່ໃຫຍ່ທີ່ສຸດ."

#. EfD73
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3153927\n"
"help.text"
msgid "Leading"
msgstr "ໄລຍະຫ່າງລະຫວ່າງແຖວ (Leading)"

#. oCASo
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3153354\n"
"help.text"
msgid "Sets the height of the vertical space that is inserted between two lines."
msgstr "ກຳນົດຄວາມສູງຂອງໄລຍະຫ່າງແນວຕັ້ງທີ່ຈະແຊກລະຫວ່າງສອງແຖວ."

#. TDxWX
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3155443\n"
"help.text"
msgid "Fixed"
msgstr "ຄົງທີ່"

#. 7Dv79
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3153711\n"
"help.text"
msgid "Sets the line spacing to exactly match the value that you enter in the box. This can result in cropped characters."
msgstr "ກຳນົດໄລຍະຫ່າງແຖວໃຫ້ກົງກັບຄ່າທີ່ທ່ານປ້ອນໃນຊ່ອງຢ່າງແນ່ນອນ. ນີ້ອາດຈະເຮັດໃຫ້ຕົວອັກສອນຖືກຕັດອອກໄດ້."

#. sqTV8
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3156383\n"
"help.text"
msgid "of"
msgstr "ຂອງ"

#. AKCgU
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3154304\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paraindentspacing/spinED_LINEDISTMETRIC\">Enter the value to use for the line spacing.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paraindentspacing/spinED_LINEDISTMETRIC\">ປ້ອນຄ່າທີ່ຈະໃຊ້ສຳລັບໄລຍະຫ່າງແຖວ.</ahelp>"

#. WAUgf
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"hd_id3146316\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\">Activate page line-spacing</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\">ເປີດໃຊ້ໄລຍະຫ່າງແຖວຂອງໜ້າ</caseinline></switchinline>"

#. mRXvz
#: 05030100.xhp
msgctxt ""
"05030100.xhp\n"
"par_id3156315\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\"><ahelp hid=\"cui/ui/paraindentspacing/checkCB_REGISTER\">Aligns the baseline of each line of text to a vertical document grid, so that each line is the same height. To use this feature, you must first activate the <emph>Use page line-spacing</emph> option for the current page style. Choose <menuitem>Format - Page Style</menuitem>, click on the <emph>Page </emph>tab, and then select the <emph>Use page line-spacing</emph> box in the <emph>Layout settings</emph> section.</ahelp>            </caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\"><ahelp hid=\"cui/ui/paraindentspacing/checkCB_REGISTER\">ຈັດແນວເສັ້ນພື້ນຖານຂອງແຕ່ລະແຖວຂໍ້ຄວາມໃຫ້ກົງກັບເສັ້ນຕາຕະລາງແນວຕັ້ງຂອງເອກະສານ, ເພື່ອໃຫ້ແຕ່ລະແຖວມີຄວາມສູງເທົ່າກັນ. ເພື່ອໃຊ້ຄຸນສົມບັດນີ້, ກ່ອນອື່ນທ່ານຕ້ອງເປີດຕົວເລືອກ <emph>ໃຊ້ໄລຍະຫ່າງແຖວຂອງໜ້າ</emph> ສຳລັບຮູບແບບໜ້າປັດຈຸບັນ. ໃຫ້ເລືອກ <menuitem>ຮູບແບບ - ຮູບແບບໜ້າ</menuitem>, ຄລິກທີ່ແຖບ <emph>ໜ້າ</emph>, ແລ້ວເລືອກຊ່ອງ <emph>ໃຊ້ໄລຍະຫ່າງແຖວຂອງໜ້າ</emph> ໃນສ່ວນ <emph>ການຕັ້ງຄ່າການຈັດວາງ</emph>.</ahelp> </caseinline></switchinline>"

#. SNwP4
#: 05030100.xhp
msgctxt ""
