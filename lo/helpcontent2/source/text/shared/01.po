msgctxt ""
"01190000.xhp\n"
"par_id3149669\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/versionsofdialog/delete\">Deletes the selected version.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/versionsofdialog/delete\">ລຶບເວີຊັນທີ່ເລືອກ.</ahelp>"

#. nMEA6
