msgstr "ຊອກຫາຈາກຊ້າຍໄປຂວາຕາມແຖວ."

#. uc2h6
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"hd_id3156277\n"
"help.text"
msgid "Columns"
msgstr "ຖັນ"

#. jnUBj
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"par_id3145207\n"
"help.text"
msgid "Searches from top to bottom through the columns."
msgstr "ຊອກຫາຈາກເທິງລົງລຸ່ມຕາມຖັນ."

#. REFSz
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"hd_id3154944\n"
"help.text"
msgid "Search in"
msgstr "ຊອກຫາໃນ"

#. qd29r
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"hd_id3146925\n"
"help.text"
msgid "Formulas"
msgstr "ສູດ"

#. E2dRK
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"par_id301020161448509633\n"
"help.text"
msgid "Searches for the characters that you specify in formulas and in fixed (not calculated) values. For example, you could look for formulas that contain 'SUM'."
msgstr "ຊອກຫາໂຕອັກສອນທີ່ທ່ານລະບຸໃນສູດ ແລະ ໃນຄ່າຄົງທີ່ (ທີ່ບໍ່ໄດ້ຄຳນວນ). ຕົວຢ່າງ, ທ່ານສາມາດຊອກຫາສູດທີ່ມີ 'SUM' ຢູ່."

#. tacCS
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"hd_id3149400\n"
"help.text"
msgid "Values"
msgstr "ຄ່າ"

#. GzFnf
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"par_id3146969\n"
"help.text"
msgid "Searches for the characters that you specify in values and in the results of formulas."
msgstr "ຊອກຫາໂຕອັກສອນທີ່ທ່ານລະບຸໃນຄ່າ ແລະ ໃນຜົນລັບຂອງສູດ."

#. WQcC4
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"hd_id3145650\n"
"help.text"
msgid "Comments"
msgstr "ຄຳເຫັນ"

#. dGvDd
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"par_id3153947\n"
"help.text"
msgid "Searches for the characters that you specify in the comments that are attached to the cells."
msgstr "ຊອກຫາໂຕອັກສອນທີ່ທ່ານລະບຸໃນຄຳເຫັນທີ່ຕິດມາກັບຫ້ອງ."

#. S8hLy
#: 02100000.xhp
msgctxt ""
"02100000.xhp\n"
"par_id3151101\n"
"help.text"
msgid "After you close the <emph>Find & Replace</emph> dialog, you can still search using the last search criteria that you entered, by pressing <keycode>Shift+</keycode><switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+F</keycode>."
msgstr "ຫຼັງຈາກທີ່ທ່ານປິດກ່ອງໂຕ້ຕອບ <emph>ຊອກຫາ ແລະ ແທນທີ່</emph>, ທ່ານຍັງສາມາດຊອກຫາໂດຍໃຊ້ເງື່ອນໄຂການຊອກຫາຫຼ້າສຸດທີ່ທ່ານປ້ອນໄວ້ ໂດຍການກົດ <keycode>Shift+</keycode><switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+F</keycode>."

#. GspKW
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"tit\n"
"help.text"
msgid "List of Regular Expressions"
msgstr "ລາຍຊື່ຂອງນິພົດປົກກະຕິ"

#. 2zsev
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"bm_id3146765\n"
"help.text"
msgid "<bookmark_value>regular expressions; list of</bookmark_value><bookmark_value>regular expressions; new line</bookmark_value><bookmark_value>regular expressions; empty paragraph</bookmark_value><bookmark_value>regular expressions; begin of word</bookmark_value><bookmark_value>regular expressions; begin of paragraph</bookmark_value><bookmark_value>regular expressions; end of paragraph</bookmark_value><bookmark_value>lists; regular expressions</bookmark_value><bookmark_value>replacing; tab stops (regular expressions)</bookmark_value><bookmark_value>tab stops; regular expressions</bookmark_value><bookmark_value>concatenation, see ampersand symbol</bookmark_value><bookmark_value>ampersand symbol, see also operators</bookmark_value>"
msgstr "<bookmark_value>ນິພົດປົກກະຕິ; ລາຍການ</bookmark_value><bookmark_value>ນິພົດປົກກະຕິ; ແຖວໃໝ່</bookmark_value><bookmark_value>ນິພົດປົກກະຕິ; ຫຍໍ້ໜ້າວ່າງເປົ່າ</bookmark_value><bookmark_value>ນິພົດປົກກະຕິ; ຕົ້ນຄຳ</bookmark_value><bookmark_value>ນິພົດປົກກະຕິ; ຕົ້ນຫຍໍ້ໜ້າ</bookmark_value><bookmark_value>ນິພົດປົກກະຕິ; ທ້າຍຫຍໍ້ໜ້າ</bookmark_value><bookmark_value>ລາຍການ; ນິພົດປົກກະຕິ</bookmark_value><bookmark_value>ການແທນທີ່; ຈຸດແທັບ (ນິພົດປົກກະຕິ)</bookmark_value><bookmark_value>ຈຸດແທັບ; ນິພົດປົກກະຕິ</bookmark_value><bookmark_value>ການເຊື່ອມຕໍ່ກັນ, ເບິ່ງ ສັນຍະລັກ ampersand</bookmark_value><bookmark_value>ສັນຍະລັກ ampersand, ເບິ່ງ ຕົວດຳເນີນການ ນຳອີກ</bookmark_value>"

#. hKBwP
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"hd_id3146765\n"
"help.text"
msgid "<variable id=\"02100001\"><link href=\"text/shared/01/02100001.xhp\">List of Regular Expressions</link></variable>"
msgstr "<variable id=\"02100001\"><link href=\"text/shared/01/02100001.xhp\">ລາຍຊື່ຂອງນິພົດປົກກະຕິ</link></variable>"

#. Fsw8C
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id5311440\n"
"help.text"
msgid "For a full list of supported metacharacters and syntax, see <link href=\"https://unicode-org.github.io/icu/userguide/strings/regexp.html#regular-expression-metacharacters\">ICU Regular Expressions documentation</link>"
msgstr "ສຳລັບລາຍຊື່ທັງໝົດຂອງຕົວອັກສອນເມຕາ ແລະ ໄວຍາກອນທີ່ຮອງຮັບ, ໃຫ້ເບິ່ງ <link href=\"https://unicode-org.github.io/icu/userguide/strings/regexp.html#regular-expression-metacharacters\">ເອກະສານນິພົດປົກກະຕິ ICU</link>"

#. cMTUp
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3149741\n"
"help.text"
msgid "Term"
msgstr "ຄຳສັບ"

#. vESi8
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3155577\n"
"help.text"
msgid "Representation/Use"
msgstr "ການສະແດງຜົນ/ການໃຊ້ງານ"

#. UjXoc
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id6600543\n"
"help.text"
msgid "Any character"
msgstr "ຕົວອັກສອນໃດໆ"

#. gD8Gi
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id9824518.00000001\n"
"help.text"
msgid "The given character, unless it is a regular expression meta character. The list of meta characters follows in this table."
msgstr "ຕົວອັກສອນທີ່ກຳນົດໃຫ້, ຍົກເວັ້ນວ່າມັນແມ່ນຕົວອັກສອນພິເສດ (meta character) ຂອງ regular expression. ລາຍການຕົວອັກສອນພິເສດແມ່ນມີຢູ່ໃນຕາຕະລາງນີ້."

#. NoqA6
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3149031\n"
"help.text"
msgid "Any single character except a line break or a paragraph break. For example, the search term \"sh.rt\" matches both \"shirt\" and \"short\"."
msgstr "ຕົວອັກສອນດ່ຽວໃດໜຶ່ງ ຍົກເວັ້ນການຂຶ້ນແຖວໃໝ່ ຫຼື ການຍໍ້ໜ້າໃໝ່. ຕົວຢ່າງ: ຄຳຄົ້ນຫາ \"sh.rt\" ຈະກົງກັບທັງ \"shirt\" ແລະ \"short\"."

#. qMXRu
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3155351\n"
"help.text"
msgid "The beginning of a paragraph or cell. Special objects such as empty fields or character-anchored frames, at the beginning of a paragraph are ignored. Example: \"^Peter\" matches the word \"Peter\" only when it is the first word of a paragraph."
msgstr "ຈຸດເລີ່ມຕົ້ນຂອງການຍໍ້ໜ້າ ຫຼື ເຊວ (cell). ວັດຖຸພິເສດ ເຊັ່ນ: ຊ່ອງວ່າງ ຫຼື ຂອບທີ່ຢຶດກັບຕົວອັກສອນ ຢູ່ສ່ວນເລີ່ມຕົ້ນຂອງການຍໍ້ໜ້າຈະຖືກຂ້າມໄປ. ຕົວຢ່າງ: \"^Peter\" ຈະກົງກັບຄຳວ່າ \"Peter\" ສະເພາະຕອນທີ່ມັນເປັນຄຳທຳອິດຂອງການຍໍ້ໜ້າເທົ່ານັ້ນ."

#. NxhF9
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3152542\n"
"help.text"
msgid "The end of a paragraph or cell. Special objects such as empty fields or character-anchored frames at the end of a paragraph are ignored. Example: \"Peter$\" matches only when the word \"Peter\" is the last word of a paragraph, note \"Peter\" cannot be followed by a period."
msgstr "ສ່ວນທ້າຍຂອງການຍໍ້ໜ້າ ຫຼື ເຊວ. ວັດຖຸພິເສດ ເຊັ່ນ: ຊ່ອງວ່າງ ຫຼື ຂອບທີ່ຢຶດກັບຕົວອັກສອນ ຢູ່ສ່ວນທ້າຍຂອງການຍໍ້ໜ້າຈະຖືກຂ້າມໄປ. ຕົວຢ່າງ: \"Peter$\" ຈະກົງກໍຕໍ່ເມື່ອຄຳວ່າ \"Peter\" ເປັນຄຳສຸດທ້າຍຂອງການຍໍ້ໜ້າ, ສັງເກດວ່າ \"Peter\" ບໍ່ສາມາດມີຈ້ຳຕາມຫຼັງໄດ້."

#. oMTnF
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3152543\n"
"help.text"
msgid "$ on its own matches the end of a paragraph. This way it is possible to search and replace paragraph breaks."
msgstr "$ ດ້ວຍຕົວມັນເອງຈະກົງກັບສ່ວນທ້າຍຂອງການຍໍ້ໜ້າ. ດ້ວຍວິທີນີ້ ມັນເປັນໄປໄດ້ທີ່ຈະຄົ້ນຫາ ແລະ ແທນທີ່ການຍໍ້ໜ້າໃໝ່."

#. ssWM5
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3155555\n"
"help.text"
msgid "Zero or more of the regular expression term immediately preceding it. For example, \"Ab*c\" matches \"Ac\", \"Abc\", \"Abbc\", \"Abbbc\", and so on."
msgstr "ສູນ ຫຼື ຫຼາຍກວ່າ ຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ. ຕົວຢ່າງ: \"Ab*c\" ຈະກົງກັບ \"Ac\", \"Abc\", \"Abbc\", \"Abbbc\", ແລະ ຕໍ່ໆໄປ."

#. YUSaM
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3157958\n"
"help.text"
msgid "One or more of the regular expression term immediately preceding it. For example, \"AX.+4\" finds \"AXx4\", but not \"AX4\"."
msgstr "ໜຶ່ງ ຫຼື ຫຼາຍກວ່າ ຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ. ຕົວຢ່າງ: \"AX.+4\" ຈະພົບ \"AXx4\", ແຕ່ບໍ່ແມ່ນ \"AX4\"."

#. LMvcH
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3145313\n"
"help.text"
msgid "The longest possible string that matches this regular expression in a paragraph is always matched. If the paragraph contains the string \"AX 4 AX4\", the entire passage is highlighted."
msgstr "ຂໍ້ຄວາມທີ່ຍາວທີ່ສຸດທີ່ກົງກັບ regular expression ນີ້ໃນການຍໍ້ໜ້າໜຶ່ງຈະຖືກຈັບຄູ່ສະເໝີ. ຖ້າການຍໍ້ໜ້າມີຂໍ້ຄວາມ \"AX 4 AX4\", ຂໍ້ຄວາມທັງໝົດຈະຖືກເນັ້ນ."

#. mdVaj
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153684\n"
"help.text"
msgid "Zero or one of the regular expression term immediately preceding it. For example, \"Texts?\" matches \"Text\" and \"Texts\" and \"x(ab|c)?y\" finds \"xy\", \"xaby\", or \"xcy\"."
msgstr "ສູນ ຫຼື ໜຶ່ງ ຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ. ຕົວຢ່າງ: \"Texts?\" ຈະກົງກັບ \"Text\" ແລະ \"Texts\" ແລະ \"x(ab|c)?y\" ຈະພົບ \"xy\", \"xaby\", ຫຼື \"xcy\"."

#. zyaC5
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3147209\n"
"help.text"
msgid "The special character that follows it is interpreted as a normal character and not as a regular expression meta character (except for the combinations \"\\n\", \"\\t\", \"\\b\", \"\\>\" and \"\\<\"). For example, \"tree\\.\" matches \"tree.\", not \"treed\" or \"trees\"."
msgstr ""
"ຕົວອັກສອນພິເສດທີ່ຕາມຫຼັງມັນຈະຖືກຕີຄວາມໝາຍເປັນຕົວອັກສອນທຳມະດາ ແລະ ບໍ່ແມ່ນຕົວອັກສອນພິເສດຂອງ regular expression (ຍົກເວັ້ນການປະສົມ \"\\n"
"\", \"\\t\", \"\\b\", \"\\>\" ແລະ \"\\<\"). ຕົວຢ່າງ: \"tree\\.\" ຈະກົງກັບ \"tree.\", ບໍ່ແມ່ນ \"treed\" ຫຼື \"trees\"."

#. sWVTg
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153700\n"
"help.text"
msgid "When entered in the <widget>Find</widget> text box, finds a line break that was inserted with the <keycode>Shift+Enter</keycode> key combination in Writer, or the <keycode>Ctrl+Enter</keycode> key combination in a Calc cell."
msgstr "ເມື່ອປ້ອນໃສ່ໃນຊ່ອງຂໍ້ຄວາມ <widget>ຄົ້ນຫາ</widget>, ຈະພົບການຂຶ້ນແຖວໃໝ່ທີ່ຖືກແຊກດ້ວຍການປະສົມປຸ່ມ <keycode>Shift+Enter</keycode> ໃນ Writer, ຫຼື ການປະສົມປຸ່ມ <keycode>Ctrl+Enter</keycode> ໃນເຊວ Calc."

#. bGUjz
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id731559575258580\n"
"help.text"
msgid "When entered in the <widget>Replace</widget> text box in Writer, inserts a paragraph break that can be inserted with the <keycode>Enter</keycode> or <keycode>Return</keycode> key. It has no special meaning in Calc, and is treated literally there."
msgstr "ເມື່ອປ້ອນໃສ່ໃນຊ່ອງຂໍ້ຄວາມ <widget>ແທນທີ່</widget> ໃນ Writer, ຈະແຊກການຍໍ້ໜ້າໃໝ່ທີ່ສາມາດແຊກໄດ້ດ້ວຍປຸ່ມ <keycode>Enter</keycode> ຫຼື <keycode>Return</keycode>. ມັນບໍ່ມີຄວາມໝາຍພິເສດໃນ Calc, ແລະ ຈະຖືກປະຕິບັດເປັນຕົວອັກສອນທຳມະດາຢູ່ທີ່ນັ້ນ."

#. eHEZV
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id631559575338134\n"
"help.text"
msgid "To change line breaks into paragraph breaks in Writer, enter \\n in both the <widget>Find</widget> and <widget>Replace</widget> boxes, and then perform a search and replace."
msgstr ""
"ເພື່ອປ່ຽນການຂຶ້ນແຖວໃໝ່ໃຫ້ເປັນການຍໍ້ໜ້າໃໝ່ໃນ Writer, ໃຫ້ປ້ອນ \\n"
" ໃສ່ໃນທັງຊ່ອງ <widget>ຄົ້ນຫາ</widget> ແລະ <widget>ແທນທີ່</widget>, ແລ້ວດຳເນີນການຄົ້ນຫາ ແລະ ແທນທີ່."

#. UvYSH
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3157809\n"
"help.text"
msgid "A tab character. Can also be used in the <widget>Replace</widget> box."
msgstr "ຕົວອັກສອນແທັບ (tab). ສາມາດໃຊ້ໃນຊ່ອງ <widget>ແທນທີ່</widget> ໄດ້ຄືກັນ."

#. wimpC
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153666\n"
"help.text"
msgid "A word boundary. For example, \"\\bbook\" matches \"bookmark\" and \"book\" but not \"checkbook\" whereas \"book\\b\" matches \"checkbook\" and \"book\" but not \"bookmark\"."
msgstr "ຂອບເຂດຂອງຄຳ. ຕົວຢ່າງ: \"\\bbook\" ຈະກົງກັບ \"bookmark\" ແລະ \"book\" ແຕ່ບໍ່ແມ່ນ \"checkbook\" ໃນຂະນະທີ່ \"book\\b\" ຈະກົງກັບ \"checkbook\" ແລະ \"book\" ແຕ່ບໍ່ແມ່ນ \"bookmark\"."

#. rGGpb
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id851559575484466\n"
"help.text"
msgid "Note, this form replaces the obsolete (although they still work for now) forms \"\\>\" (match end of word) and \"\\<\" (match start of word)."
msgstr "ໝາຍເຫດ: ຮູບແບບນີ້ຈະມາແທນທີ່ຮູບແບບເກົ່າ (ເຖິງວ່າຍັງໃຊ້ໄດ້ໃນຕອນນີ້) ຄື \"\\>\" (ກົງກັບສ່ວນທ້າຍຂອງຄຳ) ແລະ \"\\<\" (ກົງກັບສ່ວນເລີ່ມຕົ້ນຂອງຄຳ)."

#. i5DEu
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id281726590074384\n"
"help.text"
msgid "Match a word character."
msgstr "ກົງກັບຕົວອັກສອນຂອງຄຳ."

#. 4LdoF
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id831726590155815\n"
"help.text"
msgid "Match a non-word character."
msgstr "ກົງກັບຕົວອັກສອນທີ່ບໍ່ແມ່ນຄຳ."

#. CLz2y
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3151245\n"
"help.text"
msgid "Finds an empty paragraph."
msgstr "ຄົ້ນຫາການຍໍ້ໜ້າທີ່ວ່າງເປົ່າ."

#. UWusC
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3159413\n"
"help.text"
msgid "Finds the first character of a paragraph."
msgstr "ຄົ້ນຫາຕົວອັກສອນທຳອິດຂອງການຍໍ້ໜ້າ."

#. uS3UZ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3147282\n"
"help.text"
msgid "& or $0"
msgstr "& ຫຼື $0"

#. aE5RW
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153961\n"
"help.text"
msgid "Adds the string that was found by the search criteria in the <widget>Find</widget> box to the term in the <widget>Replace</widget> box when you make a replacement."
msgstr "ເພີ່ມຂໍ້ຄວາມທີ່ພົບໂດຍເງື່ອນໄຂການຄົ້ນຫາໃນຊ່ອງ <widget>ຄົ້ນຫາ</widget> ໃສ່ໃນຄຳສັບໃນຊ່ອງ <widget>ແທນທີ່</widget> ເມື່ອທ່ານເຮັດການແທນທີ່."

#. GeEfv
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3149650\n"
"help.text"
msgid "For example, if you enter \"window\" in the <widget>Find</widget> box and \"&frame\" in the <widget>Replace</widget> box, the word \"window\" is replaced with \"windowframe\"."
msgstr "ຕົວຢ່າງ: ຖ້າທ່ານປ້ອນ \"window\" ໃນຊ່ອງ <widget>ຄົ້ນຫາ</widget> ແລະ \"&frame\" ໃນຊ່ອງ <widget>ແທນທີ່</widget>, ຄຳວ່າ \"window\" ຈະຖືກແທນທີ່ດ້ວຍ \"windowframe\"."

#. i8gW8
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150543\n"
"help.text"
msgid "You can also enter an \"&\" in the <widget>Replace</widget> box to modify the <emph>Attributes</emph> or the <emph>Format</emph> of the string found by the search criteria."
msgstr "ທ່ານຍັງສາມາດປ້ອນ \"&\" ໃນຊ່ອງ <widget>ແທນທີ່</widget> ເພື່ອປ່ຽນແປງ <emph>ຄຸນລັກສະນະ</emph> ຫຼື <emph>ຮູບແບບ</emph> ຂອງຂໍ້ຄວາມທີ່ພົບໂດຍເງື່ອນໄຂການຄົ້ນຫາ."

#. vQ3mE
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3154630\n"
"help.text"
msgid "Any single occurrence of any one of  the characters that are between the brackets. For example: \"[abc123]\" matches the characters ‘a’, ‘b’,  ’c’, ‘1’, ‘2’ and ‘3’. \"[a-e]\" matches single occurrences of the characters a through e, inclusive (the range must be specified with the character having the smallest Unicode code number first). \"[a-eh-x]\" matches any single occurrence of the characters that are in the ranges ‘a’ through ‘e’ and ‘h’ through ‘x’."
msgstr "ການປະກົດຂຶ້ນດ່ຽວໃດໜຶ່ງຂອງຕົວອັກສອນໃດໜຶ່ງທີ່ຢູ່ລະຫວ່າງວົງເລັບຫຼ່ຽມ. ຕົວຢ່າງ: \"[abc123]\" ຈະກົງກັບຕົວອັກສອນ ‘a’, ‘b’, ’c’, ‘1’, ‘2’ ແລະ ‘3’. \"[a-e]\" ຈະກົງກັບການປະກົດຂຶ້ນດ່ຽວຂອງຕົວອັກສອນ a ຫາ e (ຊ່ວງຕ້ອງຖືກກຳນົດໂດຍໃຫ້ຕົວອັກສອນທີ່ມີລະຫັດ Unicode ນ້ອຍທີ່ສຸດຂຶ້ນກ່ອນ). \"[a-eh-x]\" ຈະກົງກັບການປະກົດຂຶ້ນດ່ຽວຂອງຕົວອັກສອນທີ່ຢູ່ໃນຊ່ວງ ‘a’ ຫາ ‘e’ ແລະ ‘h’ ຫາ ‘x’."

#. VGtpx
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3149167\n"
"help.text"
msgid "Any single occurrence of a character, including Tab, Space and Line Break characters, that is not in the list of characters specified inclusive ranges are permitted. For example \"[^a-syz]\" matches all characters not in the inclusive range ‘a’ through ‘s’ or the characters ‘y’ and ‘z’."
msgstr "ການປະກົດຂຶ້ນດ່ຽວໃດໜຶ່ງຂອງຕົວອັກສອນ, ລວມທັງຕົວອັກສອນ Tab, Space ແລະ ຂຶ້ນແຖວໃໝ່, ທີ່ບໍ່ໄດ້ຢູ່ໃນລາຍການຕົວອັກສອນທີ່ກຳນົດໄວ້ (ອະນຸຍາດໃຫ້ໃຊ້ຊ່ວງຕົວອັກສອນໄດ້). ຕົວຢ່າງ: \"[^a-syz]\" ຈະກົງກັບທຸກຕົວອັກສອນທີ່ບໍ່ໄດ້ຢູ່ໃນຊ່ວງ ‘a’ ຫາ ‘s’ ຫຼື ຕົວອັກສອນ ‘y’ ແລະ ‘z’."

#. tNwDD
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153768\n"
"help.text"
msgid "The character represented by the four-digit hexadecimal Unicode code (XXXX)."
msgstr "ຕົວອັກສອນທີ່ແທນດ້ວຍລະຫັດ Unicode ເລກຖານສິບຫົກສີ່ຫຼັກ (XXXX)."

#. Xp9AR
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153769\n"
"help.text"
msgid "The character represented by the eight-digit hexadecimal Unicode code (XXXXXXXX)."
msgstr "ຕົວອັກສອນທີ່ແທນດ້ວຍລະຫັດ Unicode ເລກຖານສິບຫົກແປດຫຼັກ (XXXXXXXX)."

#. kC97E
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3159252\n"
"help.text"
msgid "For certain symbol fonts the symbol (glyph) that you see on screen may look related to a different Unicode code than what is actually used for it in the font. The Unicode codes can be viewed by choosing <menuitem>Insert - Special Character</menuitem>, or by using <link href=\"text/shared/04/01010000.xhp#unicode_shortcut\">Unicode conversion shortcut</link>."
msgstr "ສຳລັບຟອນສັນຍະລັກບາງຢ່າງ ສັນຍະລັກ (glyph) ທີ່ທ່ານເຫັນໃນໜ້າຈໍອາດຈະເບິ່ງຄືກ່ຽວຂ້ອງກັບລະຫັດ Unicode ທີ່ແຕກຕ່າງຈາກສິ່ງທີ່ໃຊ້ແທ້ໃນຟອນນັ້ນ. ສາມາດເບິ່ງລະຫັດ Unicode ໄດ້ໂດຍການເລືອກ <menuitem>ແຊກ - ຕົວອັກສອນພິເສດ</menuitem>, ຫຼື ໂດຍການໃຊ້ <link href=\"text/shared/04/01010000.xhp#unicode_shortcut\">ທາງລັດການແປງ Unicode</link>."

#. K8s5D
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id821680694984368\n"
"help.text"
msgid "\\N{UNICODE CHARACTER NAME}"
msgstr "\\N{ຊື່ຕົວອັກສອນ UNICODE}"

#. 6cAAB
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id271680694984369\n"
"help.text"
msgid "Match the Unicode named character."
msgstr "ກົງກັບຕົວອັກສອນ Unicode ຕາມຊື່."

#. ZhzCx
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id911680695810483\n"
"help.text"
msgid "Some remarkable Unicode named characters are   <literal>SPACE</literal>, <literal>NO-BREAK SPACE</literal>, <literal>SOFT HYPHEN</literal>, <literal>ACUTE ACCENT</literal>, <literal>CIRCUMFLEX ACCENT</literal>, <literal>GRAVE ACCENT</literal>."
msgstr "ຕົວອັກສອນ Unicode ຕາມຊື່ທີ່ໂດດເດັ່ນບາງຕົວແມ່ນ <literal>SPACE</literal>, <literal>NO-BREAK SPACE</literal>, <literal>SOFT HYPHEN</literal>, <literal>ACUTE ACCENT</literal>, <literal>CIRCUMFLEX ACCENT</literal>, <literal>GRAVE ACCENT</literal>."

#. hGGxa
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id361680709269316\n"
"help.text"
msgid "The Unicode character names can be searched and viewed by choosing <menuitem>Insert - Special Character</menuitem>."
msgstr "ຊື່ຕົວອັກສອນ Unicode ສາມາດຄົ້ນຫາ ແລະ ເບິ່ງໄດ້ໂດຍການເລືອກ <menuitem>ແຊກ - ຕົວອັກສອນພິເສດ</menuitem>."

#. 6Swuu
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3154985\n"
"help.text"
msgid "The infix operator delimiting alternatives. Matches the term preceding the \"|\" or the term following the \"|\". For example, \"this|that\" matches occurrences of both \"this\" and \"that\"."
msgstr "ຕົວດຳເນີນການ infix ທີ່ກຳນົດທາງເລືອກ. ຈະກົງກັບຄຳທີ່ຢູ່ຂ້າງໜ້າ \"|\" ຫຼື ຄຳທີ່ຢູ່ຂ້າງຫຼັງ \"|\". ຕົວຢ່າງ: \"this|that\" ຈະກົງກັບການປະກົດຂຶ້ນຂອງທັງ \"this\" ແລະ \"that\"."

#. 8RnED
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150103\n"
"help.text"
msgid "The post-fix repetition operator that specifies an exact number of occurrences (\"N\") of the regular expression term immediately preceding it must be present for a match to occur. For example, \"tre{2}\" matches \"tree\"."
msgstr "ຕົວດຳເນີນການຊ້ຳແບບ post-fix ທີ່ກຳນົດຈຳນວນການປະກົດຂຶ້ນທີ່ແນ່ນອນ (\"N\") ຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ ເພື່ອໃຫ້ເກີດການຈັບຄູ່. ຕົວຢ່າງ: \"tre{2}\" ຈະກົງກັບ \"tree\"."

#. EVGGD
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3147317\n"
"help.text"
msgid "The post-fix repetition operator that specifies a range (minimum of \"N\" to a maximum of \"M\") of occurrences of the regular expression term immediately preceding it that can be present for a match to occur. For example, \"tre{1,2}\" matches \"tre\" and \"tree\"."
msgstr "ຕົວດຳເນີນການຊ້ຳແບບ post-fix ທີ່ກຳນົດຊ່ວງ (ຕ່ຳສຸດ \"N\" ຫາ ສູງສຸດ \"M\") ຂອງການປະກົດຂຶ້ນຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ ເພື່ອໃຫ້ເກີດການຈັບຄູ່. ຕົວຢ່າງ: \"tre{1,2}\" ຈະກົງກັບ \"tre\" ແລະ \"tree\"."

#. Awzam
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id843836\n"
"help.text"
msgid "The post-fix repetition operator that specifies a range (minimum \"N\" to an unspecified maximum) of occurrences of the regular expression term immediately preceding it that can be present for a match to occur. (The maximum number of occurrences is limited only by the size of the document). For example, \"tre{2,}\" matches \"tree\", \"treee\", and \"treeeee\"."
msgstr "ຕົວດຳເນີນການຊ້ຳແບບ post-fix ທີ່ກຳນົດຊ່ວງ (ຕ່ຳສຸດ \"N\" ຫາ ສູງສຸດທີ່ບໍ່ໄດ້ກຳນົດ) ຂອງການປະກົດຂຶ້ນຂອງຄຳໃນ regular expression ທີ່ຢູ່ຂ້າງໜ້າມັນໂດຍກົງ ເພື່ອໃຫ້ເກີດການຈັບຄູ່. (ຈຳນວນການປະກົດຂຶ້ນສູງສຸດແມ່ນຈຳກັດພຽງແຕ່ຂະໜາດຂອງເອກະສານ). ຕົວຢ່າງ: \"tre{2,}\" ຈະກົງກັບ \"tree\", \"treee\", ແລະ \"treeeee\"."

#. yWFFT
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id91559576682961\n"
"help.text"
msgid "The grouping construct that serves three purposes."
msgstr "ໂຄງສ້າງການຈັດກຸ່ມທີ່ຮັບໃຊ້ສາມຈຸດປະສົງ."

#. A9ZHn
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id871559576709007\n"
"help.text"
msgid "To enclose a set of ‘|’ alternatives. For example, the regular expression \"b(oo|ac)k\" matches both \"book\" and \"back\"."
msgstr "ເພື່ອລວມຊຸດຂອງທາງເລືອກ ‘|’. ຕົວຢ່າງ: regular expression \"b(oo|ac)k\" ຈະກົງກັບທັງ \"book\" ແລະ \"back\"."

#. 8AwgQ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id891559576747109\n"
"help.text"
msgid "To group terms in a complex expression to be operated on by the post-fix operators: \"*\", \"+\" and \"?\" along with the post-fix repetition operators. For example, the regular expression \"a(bc)?d\" matches both \"ad\" and \"abcd\"; \"M(iss){2}ippi\" matches \"Mississippi\"."
msgstr "ເພື່ອຈັດກຸ່ມຄຳໃນນິພົດທີ່ຊັບຊ້ອນເພື່ອໃຫ້ຕົວດຳເນີນການ post-fix: \"*\", \"+\" ແລະ \"?\" ພ້ອມກັບຕົວດຳເນີນການຊ້ຳແບບ post-fix ເຮັດວຽກຮ່ວມກັນ. ຕົວຢ່າງ: regular expression \"a(bc)?d\" ຈະກົງກັບທັງ \"ad\" ແລະ \"abcd\"; \"M(iss){2}ippi\" ຈະກົງກັບ \"Mississippi\"."

#. GYnF7
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id801559576780692\n"
"help.text"
msgid "To reference the matched sub string inside the parentheses for later use. The \"\\N\" construct is used in the <widget>Find</widget> box, the \"$N\" construct is used in the <widget>Replace</widget> box. \"N\" being a digit, the reference to the first match is represented by \"\\1\" in the <widget>Find</widget> box and by \"$1\" in the <widget>Replace</widget> box; \"\\2\" and \"$2\" reference to the second matched, and so on."
msgstr "ເພື່ອອ້າງອີງຂໍ້ຄວາມຍ່ອຍທີ່ຈັບຄູ່ໄດ້ພາຍໃນວົງເລັບເພື່ອໃຊ້ໃນພາຍຫຼັງ. ໂຄງສ້າງ \"\\N\" ແມ່ນໃຊ້ໃນຊ່ອງ <widget>ຄົ້ນຫາ</widget>, ໂຄງສ້າງ \"$N\" ແມ່ນໃຊ້ໃນຊ່ອງ <widget>ແທນທີ່</widget>. ໂດຍທີ່ \"N\" ເປັນຕົວເລກ, ການອ້າງອີງເຖິງການຈັບຄູ່ຄັ້ງທຳອິດແມ່ນແທນດ້ວຍ \"\\1\" ໃນຊ່ອງ <widget>ຄົ້ນຫາ</widget> ແລະ ດ້ວຍ \"$1\" ໃນຊ່ອງ <widget>ແທນທີ່</widget>; \"\\2\" ແລະ \"$2\" ອ້າງອີງເຖິງການຈັບຄູ່ຄັ້ງທີສອງ, ແລະ ຕໍ່ໆໄປ."

#. WpQrk
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id951559576846997\n"
"help.text"
msgid "For example, the regular expression \"(890)xy\\1z\\1\" matches \"890xy890z890\"."
msgstr "ຕົວຢ່າງ: regular expression \"(890)xy\\1z\\1\" ຈະກົງກັບ \"890xy890z890\"."

#. DCFjT
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id561559576865734\n"
"help.text"
msgid "With the regular expression \"(fruit|truth)\\b\" in the Find box, and the replacement expression \"$1ful\" in the Replace box, occurrences of \"fruit\" and \"truth\" are replaced with \"fruitful\" and \"truthful\" respectively. Note: \"\\b\" prevents \"fruitfully\" or \"truthfully\" from matching."
msgstr "ດ້ວຍ regular expression \"(fruit|truth)\\b\" ໃນຊ່ອງຄົ້ນຫາ, ແລະ ນິພົດການແທນທີ່ \"$1ful\" ໃນຊ່ອງແທນທີ່, ຄຳວ່າ \"fruit\" ແລະ \"truth\" ຈະຖືກແທນທີ່ດ້ວຍ \"fruitful\" ແລະ \"truthful\" ຕາມລຳດັບ. ໝາຍເຫດ: \"\\b\" ຈະປ້ອງກັນບໍ່ໃຫ້ \"fruitfully\" ຫຼື \"truthfully\" ຖືກຈັບຄູ່."

#. rdpGK
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3147397\n"
"help.text"
msgid "Represents an alphabetic character. Use <emph>[:alpha:]</emph> to find one of them."
msgstr "ແທນຕົວອັກສອນພາສາ. ໃຊ້ <emph>[:alpha:]</emph> ເພື່ອຄົ້ນຫາໜຶ່ງໃນນັ້ນ."

#. XjY6K
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150010\n"
"help.text"
msgid "Represents a decimal digit. Use <emph>[:digit:]</emph> to find one of them."
msgstr "ແທນຕົວເລກຖານສິບ. ໃຊ້ <emph>[:digit:]</emph> ເພື່ອຄົ້ນຫາໜຶ່ງໃນນັ້ນ."

#. sDfFW
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3153281\n"
"help.text"
msgid "Represents an alphanumeric character ([:alpha:] and [:digit:])."
msgstr "ແທນຕົວອັກສອນ ແລະ ຕົວເລກ ([:alpha:] ແລະ [:digit:])."

#. hzCEE
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150961\n"
"help.text"
msgid "Represents a space character (but not other whitespace characters)."
msgstr "ແທນຕົວອັກສອນຍະວ່າງ (ແຕ່ບໍ່ແມ່ນຕົວອັກສອນຊ່ອງວ່າງອື່ນໆ)."

#. ABFBQ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150872\n"
"help.text"
msgid "Represents a printable character."
msgstr "ແທນຕົວອັກສອນທີ່ພິມໄດ້."

#. PpQEZ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3152576\n"
"help.text"
msgid "Represents a nonprinting character."
msgstr "ແທນຕົວອັກສອນທີ່ພິມບໍ່ໄດ້."

#. YCGiZ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3145730\n"
"help.text"
msgid "Represents a lowercase character if <emph>Match case</emph> is selected in <emph>Options</emph>."
msgstr "ແທນຕົວອັກສອນພິມນ້ອຍ ຖ້າ <emph>ກົງກັບຕົວພິມໃຫຍ່/ນ້ອຍ</emph> ຖືກເລືອກໃນ <emph>ຕົວເລືອກ</emph>."

#. EVkR9
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id3150092\n"
"help.text"
msgid "Represents an uppercase character if <emph>Match case</emph> is selected in <emph>Options</emph>."
msgstr "ແທນຕົວອັກສອນພິມໃຫຍ່ ຖ້າ <emph>ກົງກັບຕົວພິມໃຫຍ່/ນ້ອຍ</emph> ຖືກເລືອກໃນ <emph>ຕົວເລືອກ</emph>."

#. HvC9Q
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id261559577375317\n"
"help.text"
msgid "Regular expression terms can be combined to form complex and sophisticated regular expressions for searches as show in the following examples."
msgstr "ຄຳໃນ Regular expression ສາມາດຮວມກັນເພື່ອສ້າງເປັນ regular expressions ທີ່ຊັບຊ້ອນ ແລະ ລະອຽດອ່ອນສຳລັບການຄົ້ນຫາ ດັ່ງທີ່ສະແດງໃນຕົວຢ່າງຕໍ່ໄປນີ້."

#. piA3n
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"hd_id5311441\n"
"help.text"
msgid "Examples"
msgstr "ຕົວຢ່າງ"

#. U2Chi
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id901559577400292\n"
"help.text"
msgid "Expression"
msgstr "ນິພົດ"

#. bxE4P
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id381559577400292\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. ySBpJ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id621559577542068\n"
"help.text"
msgid "An empty paragraph."
msgstr "ການຍໍ້ໜ້າທີ່ວ່າງເປົ່າ."

#. LhRmN
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id311559577563701\n"
"help.text"
msgid "<variable id=\"startpar\">^ specifies that the match must be at the start of a paragraph,</variable>"
msgstr "<variable id=\"startpar\">^ ກຳນົດວ່າການຈັບຄູ່ຕ້ອງຢູ່ທີ່ສ່ວນເລີ່ມຕົ້ນຂອງການຍໍ້ໜ້າ,</variable>"

#. Dtryp
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id391559577592658\n"
"help.text"
msgid "<variable id=\"endpar\">$ specifies that a paragraph mark or the end of a cell must follow the matched string.</variable>"
msgstr "<variable id=\"endpar\">$ ກຳນົດວ່າເຄື່ອງໝາຍຍໍ້ໜ້າ ຫຼື ສ່ວນທ້າຍຂອງເຊວຕ້ອງຕາມຫຼັງຂໍ້ຄວາມທີ່ຈັບຄູ່.</variable>"

#. xuz38
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id771559577837101\n"
"help.text"
msgid "The first character of a paragraph."
msgstr "ຕົວອັກສອນທຳອິດຂອງການຍໍ້ໜ້າ."

#. DwGtk
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id171559577924884\n"
"help.text"
msgid ". specifies any single character."
msgstr ". ກຳນົດຕົວອັກສອນດ່ຽວໃດໜຶ່ງ."

#. cJukB
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id471559577961403\n"
"help.text"
msgid "Matches \"e\" by itself or an \"e\" followed by one digit."
msgstr "ກົງກັບ \"e\" ດ້ວຍຕົວມັນເອງ ຫຼື \"e\" ທີ່ຕາມຫຼັງດ້ວຍຕົວເລກໜຶ່ງຫຼັກ."

#. kFwGK
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id421559578050163\n"
"help.text"
msgid "e specifies the character \"e\","
msgstr "e ກຳນົດຕົວອັກສອນ \"e\","

#. D5zng
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id591559578054502\n"
"help.text"
msgid "<variable id=\"digit\">[:digit:] specifies any decimal digit,</variable>"
msgstr "<variable id=\"digit\">[:digit:] ກຳນົດຕົວເລກຖານສິບໃດໜຶ່ງ,</variable>"

#. 7TE4A
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id341559578058972\n"
"help.text"
msgid "? specifies zero or one occurrences of [:digit:]."
msgstr "? ກຳນົດການປະກົດຂຶ້ນສູນ ຫຼື ໜຶ່ງ ຄັ້ງຂອງ [:digit:]."

#. My3BF
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id551559578087559\n"
"help.text"
msgid "Matches a paragraph or cells containing exactly one digit."
msgstr "ກົງກັບການຍໍ້ໜ້າ ຫຼື ເຊວທີ່ມີຕົວເລກພຽງໜຶ່ງຫຼັກພໍດີ."

#. iF9o3
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id771559578184372\n"
"help.text"
msgid "Matches a paragraph or cell containing only three digit numbers"
msgstr "ກົງກັບການຍໍ້ໜ້າ ຫຼື ເຊວທີ່ມີຕົວເລກສາມຫຼັກເທົ່ານັ້ນ"

#. Pu2qz
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id401559578501329\n"
"help.text"
msgid "{3} specifies that [:digit:] must occur three times,"
msgstr "{3} ກຳນົດວ່າ [:digit:] ຕ້ອງປະກົດຂຶ້ນສາມຄັ້ງ,"

#. y6MUw
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id131559578728924\n"
"help.text"
msgid "\\bconst(itu|ruc)tion\\b"
msgstr "\\bconst(itu|ruc)tion\\b"

#. 22cNV
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id891559578728925\n"
"help.text"
msgid "Matches the words \"constitution\" and \"construction\" but not the word \"constitutional.\""
msgstr "ກົງກັບຄຳວ່າ \"constitution\" ແລະ \"construction\" ແຕ່ບໍ່ແມ່ນຄຳວ່າ \"constitutional.\""

#. 9CxUF
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id381559578787403\n"
"help.text"
msgid "\\b specifies that the match must begin at a word boundary,"
msgstr "\\b ກຳນົດວ່າການຈັບຄູ່ຕ້ອງເລີ່ມຕົ້ນທີ່ຂອບເຂດຂອງຄຳ,"

#. WavE9
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id721559578792194\n"
"help.text"
msgid "const specifies the characters \"const\","
msgstr "const ກຳນົດຕົວອັກສອນ \"const\","

#. 5YEKT
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id941559578797721\n"
"help.text"
msgid "( starts the group,"
msgstr "( ເລີ່ມຕົ້ນກຸ່ມ,"

#. 3ZGiA
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id641559578802269\n"
"help.text"
msgid "itu specifies the characters \"itu\","
msgstr "itu ກຳນົດຕົວອັກສອນ \"itu\","

#. 4AJBD
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id271559578807054\n"
"help.text"
msgid "| specifies the alternative,"
msgstr "| ກຳນົດທາງເລືອກ,"

#. HogR2
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id801559578813944\n"
"help.text"
msgid "ruc specifies the characters \"ruc\","
msgstr "ruc ກຳນົດຕົວອັກສອນ \"ruc\","

#. gUAB3
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id421559578820595\n"
"help.text"
msgid ") ends the group,"
msgstr ") ສິ້ນສຸດກຸ່ມ,"

#. AWN9H
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id621559578825464\n"
"help.text"
msgid "tion specifies the characters \"tion\","
msgstr "tion ກຳນົດຕົວອັກສອນ \"tion\","

#. TkAoJ
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id91559578832058\n"
"help.text"
msgid "\\b specifies that the match must end at a word boundary."
msgstr "\\b ກຳນົດວ່າການຈັບຄູ່ຕ້ອງສິ້ນສຸດທີ່ຂອບເຂດຂອງຄຳ."

#. HHFdG
#: 02100001.xhp
msgctxt ""
"02100001.xhp\n"
"par_id421680698947038\n"
"help.text"
msgid "<link href=\"https://unicode-org.github.io/icu/userguide/strings/regexp.html#regular-expression-metacharacters\">ICU Regular Expressions documentation</link>"
msgstr "<link href=\"https://unicode-org.github.io/icu/userguide/strings/regexp.html#regular-expression-metacharacters\">ເອກະສານປະກອບຂອງ ICU Regular Expressions</link>"

