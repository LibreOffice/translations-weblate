msgctxt ""
"06040100.xhp\n"
"tit\n"
"help.text"
msgid "Options (AutoCorrect)"
msgstr "ຕົວເລືອກ (ການແກ້ໄຂອັດຕະໂນມັດ)"

#. v98PZ
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"bm_id3155620\n"
"help.text"
msgid "<bookmark_value>AutoCorrect function; options</bookmark_value>         <bookmark_value>replacement options</bookmark_value>         <bookmark_value>words; automatically replacing</bookmark_value>         <bookmark_value>abbreviation replacement</bookmark_value>         <bookmark_value>capital letters; AutoCorrect function</bookmark_value>         <bookmark_value>spaces; ignoring double</bookmark_value>         <bookmark_value>numbering; using automatically</bookmark_value>         <bookmark_value>paragraphs; numbering automatically</bookmark_value>         <bookmark_value>tables in text; creating automatically</bookmark_value>         <bookmark_value>titles; formatting automatically</bookmark_value>         <bookmark_value>empty paragraph removal</bookmark_value>         <bookmark_value>paragraphs; removing blank ones</bookmark_value>         <bookmark_value>styles; replacing automatically</bookmark_value>         <bookmark_value>user-defined styles; automatically replacing</bookmark_value>         <bookmark_value>bullets; replacing</bookmark_value>         <bookmark_value>paragraphs; joining</bookmark_value>         <bookmark_value>joining; paragraphs</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນການແກ້ໄຂອັດຕະໂນມັດ; ຕົວເລືອກ</bookmark_value>         <bookmark_value>ຕົວເລືອກການປ່ຽນແທນ</bookmark_value>         <bookmark_value>ຄຳສັບ; ການປ່ຽນແທນອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ການປ່ຽນແທນຄຳຫຍໍ້</bookmark_value>         <bookmark_value>ຕົວອັກສອນໃຫຍ່; ຟັງຊັນການແກ້ໄຂອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ຊ່ອງວ່າງ; ການຂ້າມຊ່ອງວ່າງຄູ່</bookmark_value>         <bookmark_value>ລຳດັບເລກ; ການໃຊ້ແບບອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ວັກ; ໃສ່ເລກລຳດັບອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ຕາຕະລາງໃນຂໍ້ຄວາມ; ການສ້າງອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ຫົວຂໍ້; ຈັດຮູບແບບອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ການລຶບວັກວ່າງ</bookmark_value>         <bookmark_value>ວັກ; ການລຶບວັກທີ່ວ່າງເປົ່າ</bookmark_value>         <bookmark_value>ຮູບແບບ; ການປ່ຽນແທນອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ຮູບແບບທີ່ຜູ້ໃຊ້ກຳນົດເອງ; ການປ່ຽນແທນອັດຕະໂນມັດ</bookmark_value>         <bookmark_value>ຫົວຂໍ້ຍ່ອຍ; ການປ່ຽນແທນ</bookmark_value>         <bookmark_value>ວັກ; ການລວມວັກ</bookmark_value>         <bookmark_value>ການລວມ; ວັກ</bookmark_value>"

#. geiHV
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3155620\n"
"help.text"
msgid "<link href=\"text/shared/01/06040100.xhp\">Options</link>"
msgstr "<link href=\"text/shared/01/06040100.xhp\">ຕົວເລືອກ</link>"

#. PXGqK
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3146946\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/applyautofmtpage/ApplyAutoFmtPage\">Select the options for automatically correcting errors as you type, and then click <emph>OK</emph>.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/applyautofmtpage/ApplyAutoFmtPage\">ເລືອກຕົວເລືອກສຳລັບການແກ້ໄຂຂໍ້ຜິດພາດໂດຍອັດຕະໂນມັດໃນຂະນະທີ່ທ່ານພິມ, ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>.</ahelp>"

#. RiA4T
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3153124\n"
"help.text"
msgid "In text documents, you can choose to apply [T] AutoCorrect options while you type. Enable this feature by using <menuitem>Tools - AutoCorrect - While Typing</menuitem>."
msgstr "ໃນເອກະສານຂໍ້ຄວາມ, ທ່ານສາມາດເລືອກໃຊ້ຕົວເລືອກການແກ້ໄຂອັດຕະໂນມັດ [T] ໃນຂະນະທີ່ທ່ານພິມ. ເປີດໃຊ້ຄຸນສົມບັດນີ້ໄດ້ໂດຍໄປທີ່ <menuitem>ເຄື່ອງມື - ແກ້ໄຂອັດຕະໂນມັດ - ໃນຂະນະທີ່ພິມ</menuitem>."

#. K2tJr
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id141612013807625\n"
"help.text"
msgid "You can also apply [M] AutoCorrect options to a selection or a whole document of existing text by using <menuitem>Tools - AutoCorrect - Apply</menuitem>."
msgstr "ທ່ານຍັງສາມາດໃຊ້ຕົວເລືອກການແກ້ໄຂອັດຕະໂນມັດ [M] ກັບສ່ວນທີ່ເລືອກ ຫຼື ທັງເອກະສານທີ່ມີຂໍ້ຄວາມຢູ່ແລ້ວ ໂດຍການໃຊ້ <menuitem>ເຄື່ອງມື - ແກ້ໄຂອັດຕະໂນມັດ - ນຳໃຊ້</menuitem>."

#. C8cAH
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id291612211857255\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\">[M] and [T] options</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\">ຕົວເລືອກ [M] ແລະ [T]</caseinline></switchinline>"

#. W2qGH
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3154398\n"
"help.text"
msgid "Use replacement table"
msgstr "ໃຊ້ຕາຕະລາງການປ່ຽນແທນ"

#. FHXGV
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3151234\n"
"help.text"
msgid "If you type a letter combination that matches a shortcut in the <link href=\"text/shared/01/06040200.xhp\">replacement table</link>, the letter combination is replaced with the replacement text."
msgstr "ຫາກທ່ານພິມກຸ່ມຕົວອັກສອນທີ່ກົງກັບຄຳສັ່ງລັດໃນ <link href=\"text/shared/01/06040200.xhp\">ຕາຕະລາງການປ່ຽນແທນ</link>, ກຸ່ມຕົວອັກສອນນັ້ນຈະຖືກປ່ຽນແທນດ້ວຍຂໍ້ຄວາມໃໝ່."

#. ZhaW7
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3150144\n"
"help.text"
msgid "Correct TWo INitial CApitals"
msgstr "ແກ້ໄຂຕົວອັກສອນໃຫຍ່ສອງຕົວທຳອິດ"

#. KJmYG
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3149177\n"
"help.text"
msgid "If you type two uppercase letters at the beginning of a \"WOrd\", the second uppercase letter is automatically replaced with a lowercase letter."
msgstr "ຫາກທ່ານພິມຕົວອັກສອນໃຫຍ່ສອງຕົວຢູ່ຕົ້ນຄຳສັບ, ຕົວອັກສອນໃຫຍ່ຕົວທີສອງຈະຖືກປ່ຽນເປັນຕົວອັກສອນນ້ອຍໂດຍອັດຕະໂນມັດ."

#. KxAjJ
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id831613131464106\n"
"help.text"
msgid "No corrections are made to entries found in an applicable spelling dictionary."
msgstr "ຈະບໍ່ມີການແກ້ໄຂໃດໆສຳລັບຄຳສັບທີ່ພົບໃນວັດຈະນານຸກົມການກວດຕົວສະກົດທີ່ກ່ຽວຂ້ອງ."

#. Z9y6a
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3156426\n"
"help.text"
msgid "Capitalize first letter of every sentence."
msgstr "ປ່ຽນຕົວອັກສອນທຳອິດຂອງທຸກປະໂຫຍກໃຫ້ເປັນຕົວໃຫຍ່."

#. ydgCD
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3155339\n"
"help.text"
msgid "Capitalizes the first letter of every sentence"
msgstr "ປ່ຽນຕົວອັກສອນທຳອິດຂອງທຸກປະໂຫຍກໃຫ້ເປັນຕົວໃຫຍ່"

#. xDBFC
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id5240028\n"
"help.text"
msgid "The first letter in a Calc cell will never be capitalized automatically."
msgstr "ຕົວອັກສອນທຳອິດໃນຫ້ອງ Calc ຈະບໍ່ຖືກປ່ຽນເປັນຕົວໃຫຍ່ໂດຍອັດຕະໂນມັດ."

#. E9hNd
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"bm_id811645041244683\n"
"help.text"
msgid "<bookmark_value>bold; AutoFormat function</bookmark_value><bookmark_value>bold; using * when typing</bookmark_value><bookmark_value>underlining; AutoFormat function</bookmark_value><bookmark_value>underlining; using _ when typing</bookmark_value><bookmark_value>italic; AutoFormat function</bookmark_value><bookmark_value>italic; using / when typing</bookmark_value><bookmark_value>strikeout; AutoFormat function</bookmark_value><bookmark_value>strikeout; using - when typing</bookmark_value>"
msgstr "<bookmark_value>ຕົວໜາ; ຟັງຊັນການຈັດຮູບແບບອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຕົວໜາ; ການໃຊ້ * ເມື່ອພິມ</bookmark_value><bookmark_value>ຂີດກ້ອງ; ຟັງຊັນການຈັດຮູບແບບອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຂີດກ້ອງ; ການໃຊ້ _ ເມື່ອພິມ</bookmark_value><bookmark_value>ຕົວເນັ້ນ; ຟັງຊັນການຈັດຮູບແບບອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຕົວເນັ້ນ; ການໃຊ້ / ເມື່ອພິມ</bookmark_value><bookmark_value>ຂີດຂ້າ; ຟັງຊັນການຈັດຮູບແບບອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຂີດຂ້າ; ການໃຊ້ - ເມື່ອພິມ</bookmark_value>"

#. FvyG2
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3145072\n"
"help.text"
msgid "Automatic *bold*, /italic/, -strikeout- and _underline_"
msgstr "ຕົວໜາ *bold*, ຕົວເນັ້ນ /italic/, ຂີດຂ້າ -strikeout- ແລະ ຂີດກ້ອງ _underline_ ອັດຕະໂນມັດ"

#. sP6BC
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3153577\n"
"help.text"
msgid "Automatically applies bold, italic, strikethrough or underline formatting to text enclosed by asterisks (*), slashes (/), hyphens (-), and underscores (_), respectively. These characters disappear after the formatting is applied."
msgstr "ໃຊ້ຮູບແບບຕົວໜາ, ຕົວເນັ້ນ, ຂີດຂ້າ ຫຼື ຂີດກ້ອງ ໂດຍອັດຕະໂນມັດກັບຂໍ້ຄວາມທີ່ຖືກລ້ອມຮອບດ້ວຍດອກຈັນ (*), ສະແລັດ (/), ເຄື່ອງໝາຍລົບ (-), ແລະ ຂີດກ້ອງ (_) ຕາມລຳດັບ. ຕົວອັກສອນເຫຼົ່ານີ້ຈະຫາຍໄປຫຼັງຈາກໃຊ້ຮູບແບບແລ້ວ."

#. by9ff
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3153127\n"
"help.text"
msgid "This feature does not work if the formatting characters <item type=\"literal\">* / - _</item> are entered with an <link href=\"text/shared/00/00000005.xhp#IME\">Input Method Editor</link>."
msgstr "ຄຸນສົມບັດນີ້ຈະບໍ່ເຮັດວຽກ ຫາກຕົວອັກສອນຈັດຮູບແບບ <item type=\"literal\">* / - _</item> ຖືກປ້ອນດ້ວຍ <link href=\"text/shared/00/00000005.xhp#IME\">ເຄື່ອງມືປ້ອນພາສາ (IME)</link>."

#. NVnSW
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"bm_id341761650272817\n"
"help.text"
msgid "<bookmark_value>URL;automatic recognition</bookmark_value><bookmark_value>autocorrection option;URL links</bookmark_value>"
msgstr "<bookmark_value>URL; ການກວດຫາອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຕົວເລືອກການແກ້ໄຂອັດຕະໂນມັດ; ການເຊື່ອມຕໍ່ URL</bookmark_value>"

#. tA7S7
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3150275\n"
"help.text"
msgid "URL Recognition"
msgstr "ການກວດຫາ URL"

#. zuWCY
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3158430\n"
"help.text"
msgid "Automatically creates a hyperlink when you type a <link href=\"text/shared/00/00000002.xhp#url\">URL</link>."
msgstr "ສ້າງໄຮເປີລິ້ງໂດຍອັດຕະໂນມັດເມື່ອທ່ານພິມ <link href=\"text/shared/00/00000002.xhp#url\">URL</link>."

#. ENTKC
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"bm_id371761650241304\n"
"help.text"
msgid "<bookmark_value>DOI;automatic recognition</bookmark_value><bookmark_value>autocorrection option;DOI citation</bookmark_value>"
msgstr "<bookmark_value>DOI; ການກວດຫາອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຕົວເລືອກການແກ້ໄຂອັດຕະໂນມັດ; ການອ້າງອີງ DOI</bookmark_value>"

#. syrfB
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id771761648408587\n"
"help.text"
msgid "DOI citation recognition"
msgstr "ການກວດຫາການອ້າງອີງ DOI"

#. CDP2Q
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id871761649956614\n"
"help.text"
msgid "Automatically creates a hyperlink when you type a <link href=\"text/shared/00/00000002.xhp#doi\">DOI</link> reference. For example, typing <literal>doi:10.1259/bjr.20190594</literal> creates the hyperlink <literal>https://doi.org/10.1259/bjr.20190594</literal>."
msgstr "ສ້າງໄຮເປີລິ້ງໂດຍອັດຕະໂນມັດເມື່ອທ່ານພິມການອ້າງອີງ <link href=\"text/shared/00/00000002.xhp#doi\">DOI</link>. ຕົວຢ່າງ: ການພິມ <literal>doi:10.1259/bjr.20190594</literal> ຈະສ້າງໄຮເປີລິ້ງ <literal>https://doi.org/10.1259/bjr.20190594</literal>."

#. FD7DC
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"hd_id3148473\n"
"help.text"
msgid "Replace Dashes"
msgstr "ປ່ຽນແທນເຄື່ອງໝາຍຂີດ"

#. rRyja
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id3144439\n"
"help.text"
msgid "Replaces one or two hyphens with a long dash (see the following table)."
msgstr "ປ່ຽນແທນເຄື່ອງໝາຍລົບໜຶ່ງ ຫຼື ສອງຕົວ ດ້ວຍຂີດຍາວ (ເບິ່ງໃນຕາຕະລາງລຸ່ມນີ້)."

#. 4XwMG
#: 06040100.xhp
msgctxt ""
"06040100.xhp\n"
"par_id87282\n"
"help.text"
msgid "Text will be replaced after you type a trailing white space (space, tab, or return). In the following table, the A and B represent text consisting of letters A to z or digits 0 to 9. N represents digits only."
msgstr "ຂໍ້ຄວາມຈະຖືກປ່ຽນແທນຫຼັງຈາກທີ່ທ່ານພິມຊ່ອງວ່າງຕາມຫຼັງ (ຊ່ອງວ່າງ, ແທັບ, ຫຼື ຂຶ້ນແຖວໃໝ່). ໃນຕາຕະລາງລຸ່ມນີ້, A ແລະ B ແທນຂໍ້ຄວາມທີ່ປະກອບດ້ວຍຕົວອັກສອນ A ເຖິງ z ຫຼື ຕົວເລກ 0 ເຖິງ 9. ສ່ວນ N ແທນສະເພາະຕົວເລກ."

#. BFA33
