msgctxt ""
"06130000.xhp\n"
"par_id3150355\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/edit\">Starts the $[officename] Basic editor and opens the selected macro or dialog for editing.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/edit\">ເລີ່ມຕົ້ນຕົວແກ້ໄຂ Basic ຂອງ $[officename] ແລະ ເປີດມາກໂຄຣ ຫຼື ໄດອາລັອກທີ່ເລືອກເພື່ອແກ້ໄຂ.</ahelp>"

