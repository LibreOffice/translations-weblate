"01100400.xhp\n"
"hd_id641526904710590\n"
"help.text"
msgid "Formula groups:"
msgstr "ກຸ່ມສູດ:"

#. QDcds
#: 01100400.xhp
msgctxt ""
"01100400.xhp\n"
"par_id541526903668055\n"
"help.text"
msgid "Number of contiguous ranges in a column with same formula."
msgstr "ຈຳນວນຊ່ວງທີ່ຕໍ່ເນື່ອງກັນໃນຖັນທີ່ມີສູດດຽວກັນ."

#. LU85G
#: 01100400.xhp
msgctxt ""
"01100400.xhp\n"
"hd_id3147210\n"
"help.text"
msgid "Images:"
msgstr "ຮູບພາບ:"

#. uvwn8
#: 01100400.xhp
msgctxt ""
"01100400.xhp\n"
"par_id3166411\n"
"help.text"
msgid "Number of images in the file. This statistic <emph>does not</emph> include images that were inserted as <link href=\"text/shared/00/00000005.xhp#ole\"><emph>OLE</emph></link> objects."
msgstr "ຈຳນວນຮູບພາບໃນໄຟລ໌. ສະຖິຕິນີ້ <emph>ບໍ່ລວມ</emph> ຮູບພາບທີ່ຖືກແຊກເປັນວັດຖຸ <link href=\"text/shared/00/00000005.xhp#ole\"><emph>OLE</emph></link>."

#. UBabs
#: 01100400.xhp
msgctxt ""
"01100400.xhp\n"
"hd_id3147618\n"
"help.text"
msgid "OLE Objects:"
msgstr "ວັດຖຸ OLE:"

#. xjuF5
#: 01100400.xhp
msgctxt ""
"01100400.xhp\n"
"par_id3149820\n"
