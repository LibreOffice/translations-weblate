msgid "<emph>Odd and even pages</emph>:"
msgstr "<emph>ໜ້າຄີກ ແລະ ໜ້າຄູ່</emph>:"

#. fevn9
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id421619222542753\n"
"help.text"
msgid "Prints the entire document."
msgstr "ພິມເອກະສານທັງໝົດ."

#. 4EEe3
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id881619225348934\n"
"help.text"
msgid "From which"
msgstr "ຈາກອັນໃດ"

#. tHVZf
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id35\n"
"help.text"
msgid "<ahelp hid=\".\">Select the source of sheet content to be printed.</ahelp> Possible values are <emph>Print all sheets</emph> and <emph>Print selected sheets</emph>."
msgstr "<ahelp hid=\".\">ເລືອກແຫຼ່ງຂອງເນື້ອໃນແຜ່ນງານທີ່ຈະພິມ.</ahelp> ຄ່າທີ່ເປັນໄປໄດ້ຄື <emph>ພິມທຸກແຜ່ນງານ</emph> ແລະ <emph>ພິມແຜ່ນງານທີ່ເລືອກ</emph>."

#. fGCJk
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id681619223767221\n"
"help.text"
msgid "Paper sides"
msgstr "ໜ້າເຈ້ຍ"

#. KPPih
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150772\n"
"help.text"
msgid "<ahelp hid=\".\">If the printer is capable of duplex printing it's possible to choose between using only one side of the paper or both.</ahelp>"
msgstr "<ahelp hid=\".\">ຖ້າເຄື່ອງພິມສາມາດພິມສອງໜ້າໄດ້, ທ່ານສາມາດເລືອກລະຫວ່າງການພິມພຽງໜ້າດຽວ ຫຼື ພິມທັງສອງໜ້າເຈ້ຍ.</ahelp>"

#. cnnat
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id851619223781119\n"
"help.text"
msgid "Number of copies"
msgstr "ຈຳນວນສຳເນົາ"

#. qCXzM
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3145069\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the number of copies that you want to print.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຈຳນວນສຳເນົາທີ່ທ່ານຕ້ອງການພິມ.</ahelp>"

#. rLgis
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id931619223793984\n"
"help.text"
msgid "Collate"
msgstr "ຮວບຮວມ"

#. 8NLFW
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150865\n"
"help.text"
msgid "<ahelp hid=\".\">Preserves the page order of the original document.</ahelp>"
msgstr "<ahelp hid=\".\">ຮັກສາລຳດັບໜ້າຂອງເອກະສານຕົ້ນສະບັບ.</ahelp>"

#. Um8wH
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id681619223806762\n"
"help.text"
msgid "Create separated prints jobs for collated output"
msgstr "ສ້າງວຽກພິມແຍກຕ່າງຫາກສຳລັບການພິມແບບຮວບຮວມ"

#. AzCAN
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id38\n"
"help.text"
msgid "<ahelp hid=\".\">Check to not rely on the printer to create collated copies but create a print job for each copy instead.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍຕິກເພື່ອບໍ່ໃຫ້ອາໄສເຄື່ອງພິມໃນການສ້າງສຳເນົາແບບຮວບຮວມ ແຕ່ໃຫ້ສ້າງວຽກພິມສຳລັບແຕ່ລະສຳເນົາແທນ.</ahelp>"

#. GLMNy
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id741619223818619\n"
"help.text"
msgid "Print in reverse order"
msgstr "ພິມແບບລຽງລຳດັບຖອຍຫຼັງ"

#. PqdCW
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id40\n"
"help.text"
msgid "<ahelp hid=\".\">Check to print pages in reverse order.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍຕິກເພື່ອພິມໜ້າແບບລຽງລຳດັບຖອຍຫຼັງ.</ahelp>"

#. RbXJE
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id0818200912285112\n"
"help.text"
msgid "Page Layout"
msgstr "ການຈັດວາງໜ້າ"

#. AERDJ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912285150\n"
"help.text"
msgid "The <emph>Page Layout</emph> section can be used to save some sheets of paper by printing several pages onto each sheet of paper. You define the arrangement and size of output pages on the physical paper."
msgstr "ສ່ວນ <emph>ການຈັດວາງໜ້າ</emph> ສາມາດໃຊ້ເພື່ອປະຢັດເຈ້ຍໂດຍການພິມຫຼາຍໜ້າລົງໃນເຈ້ຍແຜ່ນດຽວ. ທ່ານສາມາດກຳນົດການຈັດວາງ ແລະ ຂະໜາດຂອງໜ້າທີ່ຈະອອກໃນເຈ້ຍແຜ່ນຈິງ."

#. eYRqB
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200904164735\n"
"help.text"
msgid "<ahelp hid=\".\">Change the arrangement of pages to be printed on every sheet of paper. The preview shows how every final sheet of paper will look.</ahelp>"
msgstr "<ahelp hid=\".\">ປ່ຽນການຈັດວາງໜ້າທີ່ຈະພິມລົງໃນເຈ້ຍທຸກແຜ່ນ. ຕົວຢ່າງກ່ອນພິມຈະສະແດງໃຫ້ເຫັນວ່າເຈ້ຍແຕ່ລະແຜ່ນທີ່ສຳເລັດແລ້ວຈະເປັນແນວໃດ.</ahelp>"

#. nVr7X
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200904102987\n"
"help.text"
msgid "For some document types, you can choose to print a brochure."
msgstr "ສຳລັບເອກະສານບາງປະເພດ, ທ່ານສາມາດເລືອກພິມເປັນແຜ່ນພັບ (brochure) ໄດ້."

#. nC9sR
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id671619223836561\n"
"help.text"
msgid "Paper size"
msgstr "ຂະໜາດເຈ້ຍ"

#. BhLDa
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id67\n"
"help.text"
msgid "<ahelp hid=\".\">Set the paper size you would like to use. The preview will show how the document would look on a paper of the given size.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຂະໜາດເຈ້ຍທີ່ທ່ານຕ້ອງການໃຊ້. ຕົວຢ່າງກ່ອນພິມຈະສະແດງໃຫ້ເຫັນວ່າເອກະສານຈະເປັນແນວໃດໃນເຈ້ຍຂະໜາດນັ້ນ.</ahelp>"

#. t4E2n
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id761619223624028\n"
"help.text"
msgid "Orientation"
msgstr "ແນວວາງ"

#. kYfn6
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id54\n"
"help.text"
msgid "<ahelp hid=\".\">Select the orientation of the paper.</ahelp> Possible values are <emph>Portrait</emph> and <emph>Landscape</emph>."
msgstr "<ahelp hid=\".\">ເລືອກແນວວາງຂອງເຈ້ຍ.</ahelp> ຄ່າທີ່ເປັນໄປໄດ້ຄື <emph>ແນວຕັ້ງ</emph> ແລະ <emph>ແນວນອນ</emph>."

#. f9QFr
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id361619224024788\n"
"help.text"
msgid "Pages per sheet"
msgstr "ຈຳນວນໜ້າຕໍ່ແຜ່ນ"

#. BhErW
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id66\n"
"help.text"
msgid "<ahelp hid=\".\">Print multiple pages per sheet of paper.</ahelp> Select how many pages to print per sheet of paper."
msgstr "<ahelp hid=\".\">ພິມຫຼາຍໜ້າລົງໃນເຈ້ຍແຜ່ນດຽວ.</ahelp> ເລືອກວ່າຈະພິມຈັກໜ້າຕໍ່ເຈ້ຍໜຶ່ງແຜ່ນ."

#. DXCMz
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id571737393322943\n"
"help.text"
msgid "Special case of custom page per sheet"
msgstr "ກໍລະນີພິເສດຂອງການກຳນົດໜ້າຕໍ່ແຜ່ນເອງ"

#. jCgFq
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id64\n"
"help.text"
msgid "When the number of pages is set to <emph>Custom</emph>, then the following settings appears:"
msgstr "ເມື່ອຈຳນວນໜ້າຖືກຕັ້ງເປັນ <emph>ກຳນົດເອງ</emph>, ການຕັ້ງຄ່າຕໍ່ໄປນີ້ຈະປາກົດຂຶ້ນ:"

#. FjtoQ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id601619252410880\n"
"help.text"
msgid "Pages"
msgstr "ໜ້າ"

#. GFW9D
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id60\n"
"help.text"
msgid "<ahelp hid=\".\">Select number of rows.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຈຳນວນແຖວ.</ahelp>"

#. LLnTE
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id171619252415823\n"
"help.text"
msgid "By"
msgstr "ໂດຍ"

#. SwKoG
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id62\n"
"help.text"
msgid "<ahelp hid=\".\">Select number of columns.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຈຳນວນຖັນ.</ahelp>"

#. UWUeY
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id821619252526953\n"
"help.text"
msgid "Margin"
msgstr "ຂອບ"

#. CNbo4
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id56\n"
"help.text"
msgid "<ahelp hid=\".\">Select margin between the printed pages and paper edge.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກໄລຍະຫ່າງຂອບລະຫວ່າງໜ້າທີ່ພິມ ແລະ ຂອບເຈ້ຍ.</ahelp>"

#. 3DJq7
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id571619252531670\n"
"help.text"
msgid "Distance"
msgstr "ໄລຍະຫ່າງ"

#. KLGHJ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id58\n"
"help.text"
msgid "<ahelp hid=\".\">Select margin between individual pages on each sheet of paper.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກໄລຍະຫ່າງລະຫວ່າງແຕ່ລະໜ້າໃນເຈ້ຍແຕ່ລະແຜ່ນ.</ahelp>"

#. uA962
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id361619224237112\n"
"help.text"
msgid "Order"
msgstr "ລຳດັບ"

#. wbSAY
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id52\n"
"help.text"
msgid "<ahelp hid=\".\">Select order in which pages are to be printed.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກລຳດັບທີ່ຈະພິມໜ້າຕ່າງໆ.</ahelp>"

#. YZyuh
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id441619224400473\n"
"help.text"
msgid "Draw a border on each page"
msgstr "ແຕ້ມເສັ້ນຂອບໃນແຕ່ລະໜ້າ"

#. u2CAQ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id50\n"
"help.text"
msgid "<ahelp hid=\".\">Check to draw a border around each page.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍຕິກເພື່ອແຕ້ມເສັ້ນຂອບອ້ອມຮອບແຕ່ລະໜ້າ.</ahelp>"

#. 4pXmQ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id721619225074805\n"
"help.text"
msgid "Brochure"
msgstr "ແຜ່ນພັບ"

#. AAxay
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id46\n"
"help.text"
msgid "<ahelp hid=\".\">Select the Brochure option to print the document in brochure format.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຕົວເລືອກແຜ່ນພັບເພື່ອພິມເອກະສານໃນຮູບແບບແຜ່ນພັບ.</ahelp>"

#. pXDQy
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id301619226508197\n"
"help.text"
msgid "%PRODUCTNAME Writer"
msgstr "%PRODUCTNAME Writer"

#. kL5L3
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id151619228134803\n"
"help.text"
msgid "Contents"
msgstr "ເນື້ອໃນ"

#. dmGqR
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id281619228113353\n"
"help.text"
msgid "Page Background"
msgstr "ພື້ນຫຼັງໜ້າ"

#. UHGhG
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id2\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether to print colors and objects that are inserted to the background of the page, which you have specified under <emph>Format - Page Style - Background</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸວ່າຈະພິມສີ ແລະ ວັດຖຸທີ່ແຊກໄວ້ໃນພື້ນຫຼັງຂອງໜ້າຫຼືບໍ່, ເຊິ່ງທ່ານໄດ້ກຳນົດໄວ້ໃນ <emph>ຮູບແບບ - ຮູບແບບໜ້າ - ພື້ນຫຼັງ</emph>.</ahelp>"

#. XFGTG
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id901619228194194\n"
"help.text"
msgid "Images and other graphic objects"
msgstr "ຮູບພາບ ແລະ ວັດຖຸຮູບພາບອື່ນໆ"

#. EdPqS
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id4\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether the graphics and drawings or OLE objects of your text document are printed.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸວ່າຈະພິມຮູບພາບ, ຮູບແຕ້ມ ຫຼື ວັດຖຸ OLE ຂອງເອກະສານຂໍ້ຄວາມຂອງທ່ານຫຼືບໍ່.</ahelp>"

#. EnnB3
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id611619228309367\n"
"help.text"
msgid "Hidden text"
msgstr "ຂໍ້ຄວາມທີ່ຊ່ອນໄວ້"

#. u6pRd
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id6\n"
"help.text"
msgid "<ahelp hid=\".\">Enable this option to print text that is marked as hidden.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດຕົວເລືອກນີ້ເພື່ອພິມຂໍ້ຄວາມທີ່ຖືກໝາຍວ່າຊ່ອນໄວ້.</ahelp>"

#. zzL7D
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id191619228341147\n"
"help.text"
msgid "Text placeholders"
msgstr "ຕົວແທນຂໍ້ຄວາມ"

#. nzAik
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id8\n"
"help.text"
msgid "<ahelp hid=\".\">Enable this option to print text placeholders. Disable this option to leave the text placeholders blank in the printout.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດຕົວເລືອກນີ້ເພື່ອພິມຕົວແທນຂໍ້ຄວາມ. ປິດຕົວເລືອກນີ້ເພື່ອປ່ອຍຕົວແທນຂໍ້ຄວາມໃຫ້ວ່າງໃນການພິມ.</ahelp>"

#. Z4n9R
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id331619228370432\n"
"help.text"
msgid "Form controls"
msgstr "ການຄວບຄຸມຟອມ"

#. PNxji
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id10\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether the form control fields of the text document are printed.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸວ່າຈະພິມຟິວຄວບຄຸມຟອມຂອງເອກະສານຂໍ້ຄວາມຫຼືບໍ່.</ahelp>"

#. CRYB6
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id471619228416830\n"
"help.text"
msgid "Comments"
msgstr "ຄຳເຫັນ"

#. e6uax
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id16\n"
"help.text"
msgid "<ahelp hid=\".\">Specify where to print comments (if any).</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸບ່ອນທີ່ຈະພິມຄຳເຫັນ (ຖ້າມີ).</ahelp>"

#. APiC3
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id321619228471188\n"
"help.text"
msgid "Color"
msgstr "ສີ"

#. 3DMF7
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id541619228499071\n"
"help.text"
msgid "Print text in black"
msgstr "ພິມຂໍ້ຄວາມເປັນສີດຳ"

#. axxMA
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id12\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies whether to always print text in black.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸວ່າຈະພິມຂໍ້ຄວາມເປັນສີດຳສະເໝີຫຼືບໍ່.</ahelp>"

#. LibL9
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id161619228522978\n"
"help.text"
msgid "Pages"
msgstr "ໜ້າ"

#. XFLzA
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id281619228561327\n"
"help.text"
msgid "Print automatically inserted blank pages"
msgstr "ພິມໜ້າວ່າງທີ່ແຊກໃຫ້ໂດຍອັດຕະໂນມັດ"

#. CJP6W
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id14\n"
"help.text"
msgid "<ahelp hid=\".\">If this option is enabled automatically inserted blank pages are printed. This is best if you are printing double-sided. For example, in a book, a \"chapter\" paragraph style has been set to always start with an odd numbered page. If the previous chapter ends on an odd page, %PRODUCTNAME inserts an even numbered blank page. This option controls whether to print that even numbered page.</ahelp>"
msgstr "<ahelp hid=\".\">ຖ້າເປີດຕົວເລືອກນີ້, ໜ້າວ່າງທີ່ຖືກແຊກໂດຍອັດຕະໂນມັດຈະຖືກພິມອອກມາ. ນີ້ແມ່ນດີທີ່ສຸດຫາກທ່ານພິມແບບສອງໜ້າ. ຕົວຢ່າງ, ໃນປື້ມ, ຮູບແບບຫຍໍ້ໜ້າ \"ບົດ\" ໄດ້ຖືກຕັ້ງໃຫ້ເລີ່ມດ້ວຍໜ້າໝາຍເລກຄີກສະເໝີ. ຖ້າບົດກ່ອນໜ້າສິ້ນສຸດໃນໜ້າຄີກ, %PRODUCTNAME ຈະແຊກໜ້າວ່າງໝາຍເລກຄູ່. ຕົວເລືອກນີ້ຄວບຄຸມວ່າຈະພິມໜ້າໝາຍເລກຄູ່ທີ່ວ່າງນັ້ນຫຼືບໍ່.</ahelp>"

#. ZuEDx
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id871619229199189\n"
"help.text"
msgid "%PRODUCTNAME Calc"
msgstr "%PRODUCTNAME Calc"

#. BfvLp
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id621619229204878\n"
"help.text"
msgid "Pages"
msgstr "ໜ້າ"

#. BJyDF
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id631619229209903\n"
"help.text"
msgid "Suppress output of empty pages"
msgstr "ລະງັບການອອກຂອງໜ້າວ່າງ"

#. bgYTe
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id34\n"
"help.text"
msgid "<ahelp hid=\".\">If checked empty pages that have no cell contents or draw objects are not printed.</ahelp>"
msgstr "<ahelp hid=\".\">ຖ້າໝາຍຕິກ, ໜ້າວ່າງທີ່ບໍ່ມີເນື້ອໃນໃນຫ້ອງ ຫຼື ວັດຖຸຮູບແຕ້ມຈະບໍ່ຖືກພິມ.</ahelp>"

#. pEqzQ
