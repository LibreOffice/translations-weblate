#. pTkZE
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3149748\n"
"help.text"
msgid "<ahelp hid=\".\">Specify the AutoCorrect options for quotation marks and for options that are specific to the language of the text.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຕົວເລືອກການແກ້ໄຂອັດຕະໂນມັດສຳລັບເຄື່ອງໝາຍຄຳເວົ້າ ແລະ ສຳລັບຕົວເລືອກສະເພາະສຳລັບພາສາຂອງຂໍ້ຄວາມ.</ahelp>"

#. Luaaq
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id31537173\n"
"help.text"
msgid "<ahelp hid=\".\">Select to apply the replacements while you type [T], or when you modify existing text [M].</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກເພື່ອໃຊ້ການແທນທີ່ໃນຂະນະທີ່ທ່ານພິມ [T], ຫຼື ເມື່ອທ່ານແກ້ໄຂຂໍ້ຄວາມທີ່ມີຢູ່ແລ້ວ [M].</ahelp>"

#. iVaEY
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3159300\n"
"help.text"
msgid "Add non-breaking space before specific punctuation marks in French text"
msgstr "ເພີ່ມຍະຫວ່າງທີ່ບໍ່ແຍກກັນກ່ອນເຄື່ອງໝາຍວັກຕອນສະເພາະໃນຂໍ້ຄວາມພາສາຝຣັ່ງ"

#. 63xsu
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3153173\n"
"help.text"
msgid "Inserts a non breaking space before \";\", \"!\", \"?\", \":\" and \"%\" when the character language is set to French (France, Belgium, Luxembourg, Monaco, or Switzerland) and before \":\" only when the character language is set to French (Canada)."
msgstr "ແຊກຍະຫວ່າງທີ່ບໍ່ແຍກກັນກ່ອນ \";\", \"!\", \"?\", \":\" ແລະ \"%\" ເມື່ອພາສາຂອງຕົວອັກສອນຖືກຕັ້ງເປັນພາສາຝຣັ່ງ (ຝຣັ່ງ, ເບລຢຽມ, ລັກເຊັມເບີກ, ໂມນາໂກ, ຫຼື ສະວິດເຊີແລນ) ແລະ ກ່ອນ \":\" ເທົ່ານັ້ນເມື່ອພາສາຂອງຕົວອັກສອນຖືກຕັ້ງເປັນພາສາຝຣັ່ງ (ການາດາ)."

#. V5jP3
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3159400\n"
"help.text"
msgid "Format ordinal number suffixes (1st ... 1<sup>st</sup>)"
msgstr "ຈັດຮູບແບບຄຳຕໍ່ທ້າຍຕົວເລກລຳດັບ (1st ... 1<sup>st</sup>)"

#. 2mAod
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3154173\n"
"help.text"
msgid "Formats the text characters of ordinals, such as 1st, 2nd, or 3rd, as superscripts. For example, in English text, 1st will be converted to 1<sup>st</sup>."
msgstr "ຈັດຮູບແບບຕົວອັກສອນຂອງຕົວເລກລຳດັບ, ເຊັ່ນ 1st, 2nd, ຫຼື 3rd, ໃຫ້ເປັນຕົວຫ້ອຍເທິງ. ຕົວຢ່າງ, ໃນຂໍ້ຄວາມພາສາອັງກິດ, 1st ຈະຖືກປ່ຽນເປັນ 1<sup>st</sup>."

#. oU5Sr
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_idNoteNotAllLang\n"
"help.text"
msgid "Note that this only applies to languages that have the convention of formatting ordinal numbers as superscript."
msgstr "ໝາຍເຫດວ່າສິ່ງນີ້ໃຊ້ໄດ້ກັບພາສາທີ່ມີທຳນຽມການຈັດຮູບແບບຕົວເລກລຳດັບເປັນຕົວຫ້ອຍເທິງເທົ່ານັ້ນ."

#. 2BgnM
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3159500\n"
"help.text"
msgid "Transliterate to Old Hungarian if the text direction is from right to left"
msgstr "ຖ່າຍທອດຕົວອັກສອນເປັນພາສາຮັງກາຣີບູຮານ ຖ້າທິດທາງຂອງຂໍ້ຄວາມແມ່ນຈາກຂວາຫາຊ້າຍ"

#. WYyWs
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3155173\n"
"help.text"
msgid "Words and numbers are transliterated to Old Hungarian script, if the text direction is from right to left using complex text layout."
msgstr "ຄຳ ແລະ ຕົວເລກຈະຖືກຖ່າຍທອດເປັນຕົວອັກສອນຮັງກາຣີບູຮານ, ຖ້າທິດທາງຂອງຂໍ້ຄວາມແມ່ນຈາກຂວາຫາຊ້າຍໂດຍໃຊ້ການຈັດວາງຂໍ້ຄວາມທີ່ຊັບຊ້ອນ."

#. hYXVf
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3159600\n"
"help.text"
msgid "Replace << and >> with angle quotes"
msgstr "ແທນທີ່ << ແລະ >> ດ້ວຍເຄື່ອງໝາຍຄຳເວົ້າແບບມຸມ"

#. iNK4q
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3155273\n"
"help.text"
msgid "Automatically replaces double less-than and greater-than signs with double angle quotes « and » in several languages, and with single angle quotes ‹ and › in Swiss French."
msgstr "ແທນທີ່ເຄື່ອງໝາຍນ້ອຍກວ່າ ແລະ ໃຫຍ່ກວ່າແບບຄູ່ດ້ວຍເຄື່ອງໝາຍຄຳເວົ້າແບບມຸມຄູ່ « ແລະ » ໂດຍອັດຕະໂນມັດໃນຫຼາຍພາສາ, ແລະ ດ້ວຍເຄື່ອງໝາຍຄຳເວົ້າແບບມຸມດ່ຽວ ‹ ແລະ › ໃນພາສາຝຣັ່ງສະວິດ."

#. YRQQD
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3154682\n"
"help.text"
msgid "Single Quotes / Double Quotes"
msgstr "ເຄື່ອງໝາຍຄຳເວົ້າດ່ຽວ / ເຄື່ອງໝາຍຄຳເວົ້າຄູ່"

#. AGGYH
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3152363\n"
"help.text"
msgid "Specify the replacement characters to use for single or double quotation marks."
msgstr "ກຳນົດຕົວອັກສອນແທນທີ່ເພື່ອໃຊ້ສຳລັບເຄື່ອງໝາຍຄຳເວົ້າດ່ຽວ ຫຼື ຄູ່."

#. NUbU8
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3156553\n"
"help.text"
msgid "Replace"
msgstr "ແທນທີ່"

#. AaFcH
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3155616\n"
"help.text"
msgid "<ahelp hid=\".\">Automatically replaces the default system symbol for the given type of quotation marks with the special character that you specify.</ahelp>"
msgstr "<ahelp hid=\".\">ແທນທີ່ສັນຍະລັກເລີ່ມຕົ້ນຂອງລະບົບສຳລັບເຄື່ອງໝາຍຄຳເວົ້າປະເພດທີ່ກຳນົດດ້ວຍຕົວອັກສອນພິເສດທີ່ທ່ານກຳນົດໂດຍອັດຕະໂນມັດ.</ahelp>"

#. boiQB
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3153750\n"
"help.text"
msgid "Start quote"
msgstr "ເຄື່ອງໝາຍຄຳເວົ້າເລີ່ມຕົ້ນ"

#. 2RniE
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3152425\n"
"help.text"
msgid "<ahelp hid=\".\">Select the <link href=\"text/shared/01/04100000.xhp\">special character</link> that will automatically replace the current opening quotation mark in your document when you choose <emph>Tools - AutoCorrect - Apply</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ <link href=\"text/shared/01/04100000.xhp\">ຕົວອັກສອນພິເສດ</link> ທີ່ຈະແທນທີ່ເຄື່ອງໝາຍຄຳເວົ້າເປີດປັດຈຸບັນໃນເອກະສານຂອງທ່ານໂດຍອັດຕະໂນມັດ ເມື່ອທ່ານເລືອກ <emph>ເຄື່ອງມື - ແກ້ໄຂອັດຕະໂນມັດ - ນຳໃຊ້</emph>.</ahelp>"

#. rmnSr
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3159233\n"
"help.text"
msgid "End quote"
msgstr "ເຄື່ອງໝາຍຄຳເວົ້າສິ້ນສຸດ"

#. EBP74
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3147008\n"
"help.text"
msgid "<ahelp hid=\".\">Select the <link href=\"text/shared/01/04100000.xhp\">special character</link> that will automatically replace the current closing quotation mark in your document when you choose <emph>Tools - AutoCorrect - Apply</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ <link href=\"text/shared/01/04100000.xhp\">ຕົວອັກສອນພິເສດ</link> ທີ່ຈະແທນທີ່ເຄື່ອງໝາຍຄຳເວົ້າປິດປັດຈຸບັນໃນເອກະສານຂອງທ່ານໂດຍອັດຕະໂນມັດ ເມື່ອທ່ານເລືອກ <emph>ເຄື່ອງມື - ແກ້ໄຂອັດຕະໂນມັດ - ນຳໃຊ້</emph>.</ahelp>"

#. fzTrp
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"hd_id3147089\n"
"help.text"
msgid "Default"
msgstr "ເລີ່ມຕົ້ນ"

#. GAAfQ
#: 06040400.xhp
msgctxt ""
"06040400.xhp\n"
"par_id3166460\n"
"help.text"
msgid "<ahelp hid=\".\">Resets the quotation marks to the default symbols.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັ້ງຄ່າເຄື່ອງໝາຍຄຳເວົ້າຄືນເປັນສັນຍະລັກເລີ່ມຕົ້ນ.</ahelp>"

#. F9Eqa
