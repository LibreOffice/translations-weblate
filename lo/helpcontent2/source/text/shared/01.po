"02180100.xhp\n"
"hd_id3153577\n"
"help.text"
msgid "Category"
msgstr "ໝວດໝູ່"

#. BabNk
#: 02180100.xhp
msgctxt ""
"02180100.xhp\n"
"par_id3146958\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/linkeditdialog/category\">Lists the section or object that the link refers to in the source file. If you want, you can enter a new section or object here.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/linkeditdialog/category\">ສະແດງລາຍການພາກສ່ວນ ຫຼື ວັດຖຸທີ່ການເຊື່ອມຕໍ່ອ້າງອີງເຖິງໃນໄຟລ໌ຕົ້ນສະບັບ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດປ້ອນພາກສ່ວນ ຫຼື ວັດຖຸໃໝ່ໃສ່ນີ້ໄດ້.</ahelp>"

