msgstr "<variable id=\"degrees_hd\">ອົງສາ</variable>"

#. 4QsLK
#: 05340300.xhp
msgctxt ""
"05340300.xhp\n"
"par_id3153194\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/cellalignment/spinDegrees\">Enter the rotation angle from 0 to 360 for the text in the selected cell(s).</ahelp>"
msgstr "<ahelp hid=\"cui/ui/cellalignment/spinDegrees\">ປ້ອນມຸມການໝູນແຕ່ 0 ຫາ 360 ສຳລັບຂໍ້ຄວາມໃນເຊລທີ່ເລືອກ.</ahelp>"

#. 9Z2vH
#: 05340300.xhp
msgctxt ""
"05340300.xhp\n"
"hd_id3150497\n"
