#. VUYtJ
#: 01110400.xhp
msgctxt ""
"01110400.xhp\n"
"par_id3144415\n"
"help.text"
msgid "<ahelp hid=\".uno:OpenTemplate\">Opens a dialog where you can select a template for editing.</ahelp>"
msgstr "<ahelp hid=\".uno:OpenTemplate\">ເປີດກ່ອງໂຕ້ຕອບເພື່ອໃຫ້ທ່ານເລືອກແມ່ແບບສຳລັບການແກ້ໄຂ.</ahelp>"

#. ozGAg
#: 01110400.xhp
msgctxt ""
"01110400.xhp\n"
"par_id01110401\n"
"help.text"
msgid "Choose <menuitem>File - Templates - Edit Template</menuitem>."
msgstr "ເລືອກ <menuitem>ໄຟລ໌ - ແມ່ແບບ - ແກ້ໄຂແມ່ແບບ</menuitem>."

