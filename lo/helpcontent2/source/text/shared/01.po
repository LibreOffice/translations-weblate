msgctxt ""
"05020300.xhp\n"
"par_id3147219\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/numberingformatpage/add\">Adds the number format code that you entered to the user-defined category.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/numberingformatpage/add\">ເພີ່ມລະຫັດຮູບແບບຕົວເລກທີ່ທ່ານປ້ອນເຂົ້າໃນໝວດໝູ່ທີ່ຜູ້ໃຊ້ກຳນົດເອງ.</ahelp>"

