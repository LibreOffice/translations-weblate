msgctxt ""
"search_commands.xhp\n"
"par_id3155069\n"
"help.text"
msgid "<variable id=\"SearchCommands_intro\"><ahelp hid=\".uno:CommandPopup\">Allows to search and execute all commands available in application menus by their names.</ahelp></variable>"
msgstr "<variable id=\"SearchCommands_intro\"><ahelp hid=\".uno:CommandPopup\">ອະນຸຍາດໃຫ້ຄົ້ນຫາ ແລະ ປະຕິບັດຄຳສັ່ງທັງໝົດທີ່ມີຢູ່ໃນເມນູແອັບພລິເຄຊັນດ້ວຍຊື່ຂອງພວກມັນ.</ahelp></variable>"

#. XFXXZ
#: search_commands.xhp
msgctxt ""
"search_commands.xhp\n"
"par_id41628622450782\n"
"help.text"
msgid "This feature is available in Writer, Calc, Impress and Draw."
msgstr "ຄຸນສົມບັດນີ້ມີຢູ່ໃນ Writer, Calc, Impress ແລະ Draw."

#. heTMY
