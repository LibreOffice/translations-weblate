"ref_pdf_export.xhp\n"
"par_id3146975\n"
"help.text"
msgid "<ahelp hid=\".\">Exports the current file in PDF format.</ahelp>"
msgstr "<ahelp hid=\".\">ສົ່ງອອກໄຟລ໌ປັດຈຸບັນໃນຮູບແບບ PDF.</ahelp>"

