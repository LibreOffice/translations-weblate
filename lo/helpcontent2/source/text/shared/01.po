msgid "Automatic file name extension"
msgstr "ສ່ວນຂະຫຍາຍຊື່ໄຟລ໌ອັດຕະໂນມັດ"

#. 9uYkK
#: 01070000.xhp
msgctxt ""
"01070000.xhp\n"
"par_id651669393564026\n"
"help.text"
msgid "Enforces the Open Document Format (ODF) when checked."
msgstr "ບັງຄັບໃຊ້ຮູບແບບເອກະສານເປີດ (ODF) ເມື່ອຖືກເລືອກ."

#. aUBUe
#: 01070000.xhp
msgctxt ""
"01070000.xhp\n"
"hd_id41543592332834\n"
"help.text"
msgid "Encrypt with GPG key"
msgstr "ເຂົ້າລະຫັດດ້ວຍກະແຈ GPG"

#. asWLE
#: 01070000.xhp
msgctxt ""
"01070000.xhp\n"
"par_id71543592343227\n"
"help.text"
msgid "Use <link href=\"text/shared/guide/openpgp.xml\">OpenPGP</link> public keys to encrypt documents."
msgstr "ໃຊ້ກະແຈສາທາລະນະ <link href=\"text/shared/guide/openpgp.xml\">OpenPGP</link> ເພື່ອເຂົ້າລະຫັດເອກະສານ."

#. SqPSp
