#. 9h83z
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"bm_id791603045631184\n"
"help.text"
msgid "<bookmark_value>PDF export;Universal Accessibility</bookmark_value>"
msgstr "<bookmark_value>ການສົ່ງອອກ PDF; ການເຂົ້າເຖິງແບບສາກົນ</bookmark_value>"

#. EJegu
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"hd_id711602623643384\n"
"help.text"
msgid "<link href=\"text/shared/01/ref_pdf_export_universal_accessibility.xhp\">Universal Accessibility (PDF/UA)</link>"
msgstr "<link href=\"text/shared/01/ref_pdf_export_universal_accessibility.xhp\">ການເຂົ້າເຖິງແບບສາກົນ (PDF/UA)</link>"

#. v6gzG
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id221602623934399\n"
"help.text"
msgid "Creates a universal accessibility-complying PDF file that follows the requirements of PDF/UA (ISO 14289) specifications."
msgstr "ສ້າງໄຟລ໌ PDF ທີ່ສອດຄ່ອງກັບການເຂົ້າເຖິງແບບສາກົນ ຕາມຂໍ້ກຳນົດຂອງ PDF/UA (ISO 14289)."

#. QrgUF
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id641736278008973\n"
"help.text"
msgid "Tagged PDF is automatically enabled and cannot be disabled when PDF/UA is selected."
msgstr "PDF ແບບຕິດແທັກຈະຖືກເປີດໃຊ້ໂດຍອັດຕະໂນມັດ ແລະ ບໍ່ສາມາດປິດໄດ້ເມື່ອເລືອກ PDF/UA."

#. 69kZa
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id891603046173838\n"
"help.text"
msgid "then choose <emph>Universal Accessibility (PDF/UA)</emph>."
msgstr "ຈາກນັ້ນເລືອກ <emph>ການເຂົ້າເຖິງແບບສາກົນ (PDF/UA)</emph>."

#. zBYd6
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id151603044639549\n"
"help.text"
msgid "The specification defines the required structure and formatting of a document and PDF features that are better suited for accessibility. This specification can also be used to produce documents that achieve W3C's Web Content Accessibility Guidelines 2.0 (WCAG 2.0)."
msgstr "ຂໍ້ກຳນົດນີ້ໄດ້ລະບຸໂຄງສ້າງ ແລະ ການຈັດຮູບແບບເອກະສານທີ່ຈຳເປັນ ລວມທັງຄຸນສົມບັດ PDF ທີ່ເໝາະສົມກັບການເຂົ້າເຖິງຫຼາຍຂຶ້ນ. ຂໍ້ກຳນົດນີ້ຍັງສາມາດໃຊ້ເພື່ອສ້າງເອກະສານທີ່ສອດຄ່ອງກັບແນວທາງການເຂົ້າເຖິງເນື້ອໃນເວັບ 2.0 (WCAG 2.0) ຂອງ W3C ໄດ້ອີກດ້ວຍ."

#. V8cE4
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id701603046818148\n"
"help.text"
msgid "The present implementation (January 2020) checks the following:"
msgstr "ການຈັດຕັ້ງປະຕິບັດໃນປັດຈຸບັນ (ມັງກອນ 2020) ຈະກວດສອບສິ່ງຕໍ່ໄປນີ້:"

#. ry6NT
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id601603042936801\n"
"help.text"
msgid "The document title is set."
msgstr "ມີການກຳນົດຫົວເລື່ອງຂອງເອກະສານ."

#. Buz6f
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id951603042978520\n"
"help.text"
msgid "The document language is set, or all styles in use have the language property set."
msgstr "ມີການກຳນົດພາສາຂອງເອກະສານ ຫຼື ທຸກຮູບແບບທີ່ໃຊ້ມີການກຳນົດຄຸນສົມບັດພາສາໄວ້."

#. fEd8D
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id951603042984032\n"
"help.text"
msgid "All images, graphics, OLE objects have an alternate (alt) text or a title."
msgstr "ຮູບພາບ, ກຣາຟິກ, ວັດຖຸ OLE ທັງໝົດມີຂໍ້ຄວາມທົດແທນ (alt text) ຫຼື ຫົວເລື່ອງ."

#. BJVkG
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id341603042991177\n"
"help.text"
msgid "Tables do not contain split or merged cells."
msgstr "ຕາຕະລາງບໍ່ມີການແບ່ງ ຫຼື ຮວມຫ້ອງຕາຕະລາງ."

#. EB7P5
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id481603043007920\n"
"help.text"
msgid "Only integrated numbering is used, no manual numbering. For example, do not type \"1.\", \"2.\", \"3.\" at the beginning of paragraphs."
msgstr "ໃຊ້ສະເພາະການໃຫ້ໝາຍເລກແບບປະສົມປະສານເທົ່ານັ້ນ, ຫ້າມໃຫ້ໝາຍເລກດ້ວຍຕົນເອງ. ຕົວຢ່າງ: ຫ້າມພິມ \"1.\", \"2.\", \"3.\" ທີ່ຕອນເລີ່ມຕົ້ນຂອງຍໍ້ໜ້າ."

#. EJHYF
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id521603043012471\n"
"help.text"
msgid "Hyperlink texts without the underlying hyperlinks."
msgstr "ຂໍ້ຄວາມໄຮເປີລິ້ງທີ່ບໍ່ມີໄຮເປີລິ້ງຢູ່ເບື້ອງຫຼັງ."

#. XCS8t
#: ref_pdf_export_universal_accessibility.xhp
msgctxt ""
"ref_pdf_export_universal_accessibility.xhp\n"
"par_id521603043019328\n"
"help.text"
msgid "The contrast between text and the background meets the WCAG specification."
