msgctxt ""
"05340300.xhp\n"
"par_id3153665\n"
"help.text"
msgid "<variable id=\"blocktext\"><ahelp hid=\".uno:AlignBlock\">Aligns the contents of the cell to the left and to the right cell borders.</ahelp>        </variable>"
msgstr "<variable id=\"blocktext\"><ahelp hid=\".uno:AlignBlock\">ຈັດວາງເນື້ອໃນຂອງເຊລໃຫ້ສະເໝີຂອບທັງເບື້ອງຊ້າຍ ແລະ ເບື້ອງຂວາ.</ahelp></variable>"

