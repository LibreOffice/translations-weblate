"help.text"
msgid "<bookmark_value>hiding; characters</bookmark_value><bookmark_value>characters; hiding</bookmark_value><bookmark_value>font effects; hiding characters</bookmark_value><bookmark_value>fonts; hiding characters</bookmark_value><bookmark_value>fonts; effects</bookmark_value><bookmark_value>formatting; font effects</bookmark_value><bookmark_value>characters; font effects</bookmark_value><bookmark_value>text; font effects</bookmark_value><bookmark_value>effects; fonts</bookmark_value><bookmark_value>underlining; text</bookmark_value><bookmark_value>capital letters; font effects</bookmark_value><bookmark_value>lowercase letters; font effects</bookmark_value><bookmark_value>titles; font effects</bookmark_value><bookmark_value>small capitals</bookmark_value><bookmark_value>strikethrough; font effects</bookmark_value><bookmark_value>fonts; strikethrough</bookmark_value><bookmark_value>outlines; font effects</bookmark_value><bookmark_value>fonts; outlines</bookmark_value><bookmark_value>shadows; characters</bookmark_value><bookmark_value>fonts; shadows</bookmark_value><bookmark_value>fonts; color ignored</bookmark_value><bookmark_value>ignored font colors</bookmark_value><bookmark_value>colors; ignored text color</bookmark_value>"
msgstr "<bookmark_value>ການຊ່ອນ; ອັກສອນ</bookmark_value><bookmark_value>ອັກສອນ; ການຊ່ອນ</bookmark_value><bookmark_value>ເອັບເຟັກຟອນ; ການຊ່ອນອັກສອນ</bookmark_value><bookmark_value>ຟອນ; ການຊ່ອນອັກສອນ</bookmark_value><bookmark_value>ຟອນ; ເອັບເຟັກ</bookmark_value><bookmark_value>ການຈັດຮູບແບບ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ອັກສອນ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຂໍ້ຄວາມ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ເອັບເຟັກ; ຟອນ</bookmark_value><bookmark_value>ການຂີດກ້ອງ; ຂໍ້ຄວາມ</bookmark_value><bookmark_value>ຕົວພິມໃຫຍ່; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຕົວພິມນ້ອຍ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຫົວຂໍ້; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຕົວພິມໃຫຍ່ຂະໜາດນ້ອຍ</bookmark_value><bookmark_value>ການຂີດຂ້າ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຟອນ; ການຂີດຂ້າ</bookmark_value><bookmark_value>ເສັ້ນຂອບ; ເອັບເຟັກຟອນ</bookmark_value><bookmark_value>ຟອນ; ເສັ້ນຂອບ</bookmark_value><bookmark_value>ເງົາ; ອັກສອນ</bookmark_value><bookmark_value>ຟອນ; ເງົາ</bookmark_value><bookmark_value>ຟອນ; ສີທີ່ຖືກລະເລີຍ</bookmark_value><bookmark_value>ສີຟອນທີ່ຖືກລະເລີຍ</bookmark_value><bookmark_value>ສີ; ສີຂໍ້ຄວາມທີ່ຖືກລະເລີຍ</bookmark_value>"

#. Eutga
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3153514\n"
"help.text"
msgid "<variable id=\"font_effects_h1\"><link href=\"text/shared/01/05020200.xhp\">Font Effects</link></variable>"
msgstr "<variable id=\"font_effects_h1\"><link href=\"text/shared/01/05020200.xhp\">ເອັບເຟັກຟອນ</link></variable>"

#. BGt5t
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3149205\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/EffectsPage\">Specify the font effects that you want to use.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/EffectsPage\">ລະບຸເອັບເຟັກຟອນທີ່ທ່ານຕ້ອງການໃຊ້.</ahelp>"

#. cmpKA
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id531711633095294\n"
"help.text"
msgid "Choose <menuitem>Home</menuitem> then click the <menuitem>Home</menuitem> dropdown on the right-hand side of the tab and choose <menuitem>Character</menuitem>."
msgstr "ເລືອກ <menuitem>ໜ້າທຳອິດ</menuitem> ແລ້ວຄລິກທີ່ລາຍການແບບເລື່ອນລົງ <menuitem>ໜ້າທຳອິດ</menuitem> ຢູ່ເບື້ອງຂວາຂອງແທັບ ແລະ ເລືອກ <menuitem>ອັກສອນ</menuitem>."

#. LXs3D
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id891711633731822\n"
"help.text"
msgid "Choose <menuitem>Character - Character</menuitem>"
msgstr "ເລືອກ <menuitem>ອັກສອນ - ອັກສອນ</menuitem>"

#. arFUu
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3149482\n"
"help.text"
msgid "<variable id=\"font_color_hd\"><link href=\"text/shared/01/05020200.xhp#FontColor\">Font Color</link></variable>"
msgstr "<variable id=\"font_color_hd\"><link href=\"text/shared/01/05020200.xhp#FontColor\">ສີຟອນ</link></variable>"

#. dWZuD
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id151749669193334\n"
"help.text"
msgid "Sets the current cell or cells selection font color."
msgstr "ຕັ້ງຄ່າສີຟອນຂອງຫ້ອງປັດຈຸບັນ ຫຼື ຫ້ອງທີ່ເລືອກ."

#. y6HdY
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3146924\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/fontcolorlb\">Sets the color for the selected text. Click to apply the current font color to the selected characters or to the word where the cursor is placed.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/fontcolorlb\">ຕັ້ງຄ່າສີສໍາລັບຂໍ້ຄວາມທີ່ເລືອກ. ຄລິກເພື່ອວາງສີຟອນປັດຈຸບັນໃຫ້ກັບອັກສອນທີ່ເລືອກ ຫຼື ຄຳທີ່ມີເຄີເຊີຢູ່.</ahelp>"

#. AqcnX
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id981749669360716\n"
"help.text"
msgid "If you select <emph>Automatic</emph>, the text color is set to black for light backgrounds and to white for dark backgrounds."
msgstr "ຫາກທ່ານເລືອກ <emph>ອັດຕະໂນມັດ</emph>, ສີຂໍ້ຄວາມຈະຖືກຕັ້ງເປັນສີດຳສໍາລັບພື້ນຫຼັງທີ່ເປັນສີອ່ອນ ແລະ ເປັນສີຂາວສໍາລັບພື້ນຫຼັງທີ່ເປັນສີເຂັ້ມ."

#. ScU6M
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_idN10CC2\n"
"help.text"
msgid "To change the color of a text selection, select the text that you want to change, and click the <emph>Font Color</emph> icon. To apply a different color, click the arrow next to the <emph>Font Color</emph> icon, and then select the color that you want to use."
msgstr "ເພື່ອປ່ຽນສີຂອງຂໍ້ຄວາມທີ່ເລືອກ, ໃຫ້ເລືອກຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການປ່ຽນ, ແລ້ວຄລິກໄອຄອນ <emph>ສີຟອນ</emph>. ເພື່ອນຳໃຊ້ສີອື່ນ, ໃຫ້ຄລິກທີ່ລູກສອນຂ້າງໄອຄອນ <emph>ສີຟອນ</emph>, ແລ້ວເລືອກສີທີ່ທ່ານຕ້ອງການໃຊ້."

#. XqzQT
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3150037\n"
"help.text"
msgid "The text color is ignored when printing, if the <emph>Print text in black</emph> check box is selected in <link href=\"text/shared/optionen/01040400.xhp\"><emph>%PRODUCTNAME Writer - Print</emph></link> in the <emph>Options</emph> dialog box."
msgstr "ສີຂໍ້ຄວາມຈະຖືກລະເລີຍເມື່ອພິມ, ຫາກເລືອກຊ່ອງ <emph>ພິມຂໍ້ຄວາມເປັນສີດຳ</emph> ໃນ <link href=\"text/shared/optionen/01040400.xhp\"><emph>%PRODUCTNAME Writer - ພິມ</emph></link> ໃນກ່ອງໂຕ້ຕອບ <emph>ຕົວເລືອກ</emph>."

#. tFhVN
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id7613757\n"
"help.text"
msgid "The text color is ignored on screen, if the <emph>Use automatic font color for screen display</emph> check box is selected in <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01013000.xhp\"><emph>%PRODUCTNAME - Accessibility</emph></link>."
msgstr "ສີຂໍ້ຄວາມຈະຖືກລະເລີຍໃນໜ້າຈໍ, ຫາກເລືອກຊ່ອງ <emph>ໃຊ້ສີຟອນອັດຕະໂນມັດສໍາລັບການສະແດງຜົນທາງໜ້າຈໍ</emph> ໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ຄ່າກຳນົດ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01013000.xhp\"><emph>%PRODUCTNAME - ການເຂົ້າເຖິງ</emph></link>."

#. tCazN
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3144766\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\"><variable id=\"textfarbe\">Click to apply the current font color to the selected characters. Click the arrow next to the icon to open the <emph>Font color</emph> palette tool. </variable></ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\"><variable id=\"textfarbe\">ຄລິກເພື່ອວາງສີຟອນປັດຈຸບັນໃຫ້ກັບອັກສອນທີ່ເລືອກ. ຄລິກທີ່ລູກສອນຂ້າງໄອຄອນເພື່ອເປີດເຄື່ອງມືຖາດ <emph>ສີຟອນ</emph>. </variable></ahelp>"

#. Yvw3j
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id0123200902243377\n"
"help.text"
msgid "Transparency"
msgstr "ຄວາມໂປ່ງໃສ"

#. xbjmo
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3146925\n"
"help.text"
msgid "Sets the transparency of the character text. The value 100% means entirely transparent, while 0% means not transparent at all."
msgstr "ຕັ້ງຄ່າຄວາມໂປ່ງໃສຂອງຂໍ້ຄວາມອັກສອນ. ຄ່າ 100% ໝາຍເຖິງໂປ່ງໃສທັງໝົດ, ໃນຂະນະທີ່ 0% ໝາຍເຖິງບໍ່ໂປ່ງໃສເລີຍ."

#. NUXSY
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id941582477457694\n"
"help.text"
msgid "Transparency cannot be set for Paragraph Style and Character Style."
msgstr "ບໍ່ສາມາດຕັ້ງຄ່າຄວາມໂປ່ງໃສສໍາລັບ ສະໄຕລ໌ຫຍໍ້ໜ້າ ແລະ ສະໄຕລ໌ອັກສອນ ໄດ້."

#. DopC6
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id91580568371950\n"
"help.text"
msgid "Text Decoration"
msgstr "ການຕົກແຕ່ງຂໍ້ຄວາມ"

#. yLgGs
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id0123200902243376\n"
"help.text"
msgid "Overlining"
msgstr "ການຂີດເທິງ"

#. AgLqC
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id0123200902243343\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/overlinelb\">Select the overlining style that you want to apply. To apply the overlining to words only, select the <emph>Individual Words</emph> box.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/overlinelb\">ເລືອກສະໄຕລ໌ການຂີດເທິງທີ່ທ່ານຕ້ອງການນຳໃຊ້. ເພື່ອນຳໃຊ້ການຂີດເທິງສະເພາະແຕ່ລະຄຳ, ໃຫ້ເລືອກຊ່ອງ <emph>ແຍກແຕ່ລະຄຳ</emph>.</ahelp>"

#. hjGmq
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id0123200902243470\n"
"help.text"
msgid "Overline color"
msgstr "ສີການຂີດເທິງ"

#. Qj5QS
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id0123200902243466\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/overlinecolorlb\">Select the color for the overlining.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/overlinecolorlb\">ເລືອກສີສໍາລັບການຂີດເທິງ.</ahelp>"

#. exFYD
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3150400\n"
"help.text"
msgid "Strikethrough"
msgstr "ການຂີດຂ້າ"

#. GhmxB
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3145203\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/strikeoutlb\">Select a strikethrough style for the selected text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/strikeoutlb\">ເລືອກສະໄຕລ໌ການຂີດຂ້າສໍາລັບຂໍ້ຄວາມທີ່ເລືອກ.</ahelp>"

#. 8KFk2
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3150496\n"
"help.text"
msgid "If you save your document in Microsoft Word format, all of the strikethrough styles are converted to the single line style."
msgstr "ຫາກທ່ານບັນທຶກເອກະສານໃນຮູບແບບ Microsoft Word, ສະໄຕລ໌ການຂີດຂ້າທັງໝົດຈະຖືກປ່ຽນເປັນສະໄຕລ໌ເສັ້ນດ່ຽວ."

#. ojwCR
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3151226\n"
"help.text"
msgid "Underlining"
msgstr "ການຂີດກ້ອງ"

#. WedNX
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3147576\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/underlinelb\">Select the underlining style that you want to apply. To apply the underlining to words only, select the <emph>Individual Words</emph> box.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/underlinelb\">ເລືອກສະໄຕລ໌ການຂີດກ້ອງທີ່ທ່ານຕ້ອງການນຳໃຊ້. ເພື່ອນຳໃຊ້ການຂີດກ້ອງສະເພາະແຕ່ລະຄຳ, ໃຫ້ເລືອກຊ່ອງ <emph>ແຍກແຕ່ລະຄຳ</emph>.</ahelp>"

#. E5TPY
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3153147\n"
"help.text"
msgid "If you apply underlining to a superscript text, the underlining is raised to the level of the superscript. If the superscript is contained in a word with normal text, the underlining is not raised."
msgstr "ຫາກທ່ານນຳໃຊ້ການຂີດກ້ອງກັບຂໍ້ຄວາມຕົວຫ້ອຍເທິງ (superscript), ການຂີດກ້ອງຈະຖືກຍົກຂຶ້ນໄປໃນລະດັບຂອງຕົວຫ້ອຍເທິງ. ຫາກຕົວຫ້ອຍເທິງຢູ່ໃນຄຳທີ່ມີຂໍ້ຄວາມປົກກະຕິ, ການຂີດກ້ອງຈະບໍ່ຖືກຍົກຂຶ້ນ."

#. PssvR
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3148642\n"
"help.text"
msgid "Underline color"
msgstr "ສີການຂີດກ້ອງ"

#. iFDaB
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3150254\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/underlinecolorlb\">Select the color for the underlining.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/underlinecolorlb\">ເລືອກສີສໍາລັບການຂີດກ້ອງ.</ahelp>"

#. vCnQY
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3153104\n"
"help.text"
msgid "Individual words"
msgstr "ແຍກແຕ່ລະຄຳ"

#. LifTi
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3152935\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/individualwordscb\">Applies the selected effect only to words and ignores spaces.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/individualwordscb\">ນຳໃຊ້ເອັບເຟັກທີ່ເລືອກສະເພາະກັບຄຳ ແລະ ລະເລີຍຊ່ອງວ່າງ.</ahelp>"

#. giEeL
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3146137\n"
"help.text"
msgid "Effects"
msgstr "ເອັບເຟັກ"

#. gFDAo
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3150084\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/effectslb\">Select the font effects that you want to apply.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/effectslb\">ເລືອກເອັບເຟັກຟອນທີ່ທ່ານຕ້ອງການນຳໃຊ້.</ahelp>"

#. jbxYs
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3149575\n"
"help.text"
msgid "Case"
msgstr "ຕົວພິມ"

#. G2gCr
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3148944\n"
"help.text"
msgid "The following capitalization effects are available:"
msgstr "ເອັບເຟັກຕົວພິມໃຫຍ່ທີ່ມີໃຫ້ໃຊ້ມີດັ່ງນີ້:"

#. kNTy9
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3155922\n"
"help.text"
msgid "<emph>Without</emph> - No effect is applied."
msgstr "<emph>ບໍ່ມີ</emph> - ບໍ່ມີເອັບເຟັກໃດໆຖືກນຳໃຊ້."

#. 3FEXm
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3154280\n"
"help.text"
msgid "<emph>UPPERCASE</emph> - <variable id=\"uppercase\">Changes the selected lowercase characters to uppercase characters.</variable>"
msgstr "<emph>ຕົວພິມໃຫຍ່</emph> - <variable id=\"uppercase\">ປ່ຽນອັກສອນຕົວພິມນ້ອຍທີ່ເລືອກໃຫ້ເປັນອັກສອນຕົວພິມໃຫຍ່.</variable>"

#. iRaV4
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3148947\n"
"help.text"
msgid "<emph>lowercase</emph> - <variable id=\"lowercase\">Changes the selected uppercase characters to lower characters.</variable>"
msgstr "<emph>ຕົວພິມນ້ອຍ</emph> - <variable id=\"lowercase\">ປ່ຽນອັກສອນຕົວພິມໃຫຍ່ທີ່ເລືອກໃຫ້ເປັນອັກສອນຕົວພິມນ້ອຍ.</variable>"

#. FEVh9
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3149456\n"
"help.text"
msgid "<emph>Capitalize Every Word</emph> - <variable id=\"capitalizeeveryword\">Changes the first character of each selected word to an uppercase character.</variable>"
msgstr "<emph>ຂຶ້ນຕົ້ນດ້ວຍຕົວພິມໃຫຍ່ທຸກຄຳ</emph> - <variable id=\"capitalizeeveryword\">ປ່ຽນອັກສອນຕົວທຳອິດຂອງແຕ່ລະຄຳທີ່ເລືອກໃຫ້ເປັນອັກສອນຕົວພິມໃຫຍ່.</variable>"

#. GBuCC
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3154937\n"
"help.text"
msgid "<emph>Small capitals</emph> - <variable id=\"smallcapitals\">Changes the selected lowercase characters to uppercase characters, and then reduces their size.</variable>"
msgstr "<emph>ຕົວພິມໃຫຍ່ຂະໜາດນ້ອຍ</emph> - <variable id=\"smallcapitals\">ປ່ຽນອັກສອນຕົວພິມນ້ອຍທີ່ເລືອກໃຫ້ເປັນອັກສອນຕົວພິມໃຫຍ່, ແລ້ວຫຼຸດຂະໜາດຂອງພວກມັນລົງ.</variable>"

#. B3MEb
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_idN10B81\n"
"help.text"
msgid "Hidden"
msgstr "ຊ່ອນໄວ້"

#. g7urB
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_idN10B85\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/hiddencb\">Hides the selected characters.</ahelp> To display the hidden text, ensure that <menuitem>Formatting Marks</menuitem> is selected in the <emph>View</emph> menu. You can also choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem>                              </caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><emph> - %PRODUCTNAME Writer - Formatting Aids</emph> and select <emph>Hidden characters</emph>."
msgstr "<ahelp hid=\"cui/ui/effectspage/hiddencb\">ຊ່ອນອັກສອນທີ່ເລືອກ.</ahelp> ເພື່ອສະແດງຂໍ້ຄວາມທີ່ຊ່ອນໄວ້, ໃຫ້ກວດເບິ່ງວ່າ <menuitem>ເຄື່ອງໝາຍການຈັດຮູບແບບ</menuitem> ຖືກເລືອກຢູ່ໃນເມນູ <emph>ເບິ່ງ</emph>. ທ່ານຍັງສາມາດເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄ່າກຳນົດ</menuitem> </caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><emph> - %PRODUCTNAME Writer - ຕົວຊ່ວຍການຈັດຮູບແບບ</emph> ແລະ ເລືອກ <emph>ອັກສອນທີ່ຊ່ອນໄວ້</emph>."

#. iAwbr
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3154129\n"
"help.text"
msgid "Relief"
msgstr "ຕົວນູນ"

#. iXCe4
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3146974\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/relieflb\">Select a <emph>relief</emph> effect to apply to the selected text. The <emph>embossed</emph> relief makes the characters appear as if they are raised above the page. The <emph>engraved</emph> relief makes the characters appear as if they are pressed into the page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/relieflb\">ເລືອກເອັບເຟັກ <emph>ຕົວນູນ</emph> ເພື່ອນຳໃຊ້ກັບຂໍ້ຄວາມທີ່ເລືອກ. ແບບ <emph>ນູນຂຶ້ນ</emph> ຈະເຮັດໃຫ້ອັກສອນປາກົດຄືກັບວ່າມັນຟູຂຶ້ນມາຈາກໜ້າເຈ້ຍ. ແບບ <emph>ນູນລົງ</emph> ຈະເຮັດໃຫ້ອັກສອນປາກົດຄືກັບວ່າມັນຖືກກົດຈົມລົງໄປໃນໜ້າເຈ້ຍ.</ahelp>"

#. BhRXq
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3147287\n"
"help.text"
msgid "Outline"
msgstr "ເສັ້ນຂອບ"

#. pPmRf
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3159126\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/outlinecb\">Displays the outline of the selected characters. This effect does not work with every font.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/outlinecb\">ສະແດງເສັ້ນຂອບຂອງອັກສອນທີ່ເລືອກ. ເອັບເຟັກນີ້ບໍ່ສາມາດໃຊ້ໄດ້ກັບທຸກຟອນ.</ahelp>"

#. Z8LKE
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3163714\n"
"help.text"
msgid "<variable id=\"shadow_hd\">Shadow</variable>"
msgstr "<variable id=\"shadow_hd\">ເງົາ</variable>"

#. 3ATPy
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3150962\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/shadowcb\">Adds a shadow that casts below and to the right of the selected characters.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/shadowcb\">ເພີ່ມເງົາທີ່ຕົກລົງທາງລຸ່ມ ແລະ ທາງຂວາຂອງອັກສອນທີ່ເລືອກ.</ahelp>"

#. L7M9i
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id781724712661493\n"
"help.text"
msgid "<image src=\"cmd/32/shadowed.svg\" id=\"img_id161724712661493\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id361724712661494\">Icon Shadow</alt></image>"
msgstr "<image src=\"cmd/32/shadowed.svg\" id=\"img_id161724712661493\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id361724712661494\">ໄອຄອນເງົາ</alt></image>"

#. idLJj
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id631724712661494\n"
"help.text"
msgid "Shadow"
msgstr "ເງົາ"

#. 7qD3W
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3150332\n"
"help.text"
msgid "Emphasis mark"
msgstr "ເຄື່ອງໝາຍເນັ້ນ"

#. v3dTW
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3152576\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/emphasislb\">Select a character to display over or below the entire length of the selected text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/emphasislb\">ເລືອກອັກສອນທີ່ຈະສະແດງຢູ່ເທິງ ຫຼື ຢູ່ລຸ່ມຂໍ້ຄວາມທີ່ເລືອກທັງໝົດ.</ahelp>"

#. Fuu9V
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"hd_id3152460\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. 44rBr
#: 05020200.xhp
msgctxt ""
"05020200.xhp\n"
"par_id3147436\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/effectspage/positionlb\">Specify where to display the emphasis marks.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/effectspage/positionlb\">ລະບຸບ່ອນທີ່ຈະສະແດງເຄື່ອງໝາຍເນັ້ນ.</ahelp>"

#. BzbXS
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"tit\n"
"help.text"
msgid "Numbers / Format"
msgstr "ຕົວເລກ / ຮູບແບບ"

#. AJdV8
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"bm_id3152942\n"
"help.text"
msgid "<bookmark_value>formats; number and currency formats</bookmark_value><bookmark_value>number formats; formats</bookmark_value><bookmark_value>currencies;format codes</bookmark_value><bookmark_value>defaults; number formats</bookmark_value>"
msgstr "<bookmark_value>ຮູບແບບ; ຮູບແບບຕົວເລກ ແລະ ສະກຸນເງິນ</bookmark_value><bookmark_value>ຮູບແບບຕົວເລກ; ຮູບແບບ</bookmark_value><bookmark_value>ສະກຸນເງິນ; ລະຫັດຮູບແບບ</bookmark_value><bookmark_value>ຄ່າເລີ່ມຕົ້ນ; ຮູບແບບຕົວເລກ</bookmark_value>"

#. HDxCA
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3162942\n"
"help.text"
msgid "<variable id=\"NumbersLink\"><link href=\"text/shared/01/05020300.xhp\">Numbers</link></variable>"
msgstr "<variable id=\"NumbersLink\"><link href=\"text/shared/01/05020300.xhp\">ຕົວເລກ</link></variable>"

#. z8GFZ
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3145071\n"
"help.text"
msgid "<variable id=\"zahlen\"><ahelp hid=\".uno:TableNumberFormatDialog\">Specify the formatting options for the selected cell(s).</ahelp></variable>"
msgstr "<variable id=\"zahlen\"><ahelp hid=\".uno:TableNumberFormatDialog\">ລະບຸຕົວເລືອກການຈັດຮູບແບບສໍາລັບຫ້ອງທີ່ເລືອກ.</ahelp></variable>"

#. JAXnx
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3152942\n"
"help.text"
msgid "<link href=\"text/shared/01/05020300.xhp\">Number Format</link>"
msgstr "<link href=\"text/shared/01/05020300.xhp\">ຮູບແບບຕົວເລກ</link>"

#. NtAVK
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3145086\n"
"help.text"
msgid "Specify the formatting option for the selected variable or table cell with numeric value."
msgstr "ລະບຸຕົວເລືອກການຈັດຮູບແບບສໍາລັບຕົວປ່ຽນທີ່ເລືອກ ຫຼື ຫ້ອງຕາຕະລາງທີ່ມີຄ່າເປັນຕົວເລກ."

#. KqXXP
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3155392\n"
"help.text"
msgid "Category"
msgstr "ໝວດໝູ່"

#. CknnB
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3150774\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/numberingformatpage/categorylb\">Select a category from the list, and then select a formatting style in the <emph>Format</emph> box.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/numberingformatpage/categorylb\">ເລືອກໝວດໝູ່ຈາກລາຍຊື່, ແລ້ວເລືອກສະໄຕລ໌ການຈັດຮູບແບບໃນກ່ອງ <emph>ຮູບແບບ</emph>.</ahelp>"

#. NwGUJ
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3145416\n"
"help.text"
msgid "The default currency format for a cell is determined by the regional settings of your operating system."
msgstr "ຮູບແບບສະກຸນເງິນເລີ່ມຕົ້ນສໍາລັບຫ້ອງແມ່ນຖືກກຳນົດໂດຍການຕັ້ງຄ່າທ້ອງຖິ່ນຂອງລະບົບປະຕິບັດການຂອງທ່ານ."

#. BSW6C
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3155342\n"
"help.text"
msgid "<variable id=\"format_hd\">Format</variable>"
msgstr "<variable id=\"format_hd\">ຮູບແບບ</variable>"

#. igSKQ
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3148491\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/numberingformatpage/formatlb\">Select how you want the contents of the selected <switchinline select=\"appl\"><caseinline select=\"CALC\">cell(s) </caseinline><defaultinline>field</defaultinline></switchinline> to be displayed.</ahelp> The code for the selected option is displayed in the <emph>Format code</emph> box."
msgstr "<ahelp hid=\"cui/ui/numberingformatpage/formatlb\">ເລືອກວິທີທີ່ທ່ານຕ້ອງການໃຫ້ເນື້ອຫາຂອງ <switchinline select=\"appl\"><caseinline select=\"CALC\">ຫ້ອງ </caseinline><defaultinline>ຟີລດ໌</defaultinline></switchinline> ທີ່ເລືອກສະແດງອອກມາ.</ahelp> ລະຫັດສໍາລັບຕົວເລືອກທີ່ເລືອກຈະສະແດງຢູ່ໃນກ່ອງ <emph>ລະຫັດຮູບແບບ</emph>."

#. U8AEv
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3154811\n"
"help.text"
msgid "<variable id=\"currencylb_hd\">Currency category list boxes</variable>"
msgstr "<variable id=\"currencylb_hd\">ກ່ອງລາຍຊື່ໝວດໝູ່ສະກຸນເງິນ</variable>"

#. YGghf
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3148563\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/numberingformatpage/currencylb\">Select a currency, and then scroll to the top of the <emph>Format</emph> list to view the formatting options for the currency.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/numberingformatpage/currencylb\">ເລືອກສະກຸນເງິນ, ແລ້ວເລື່ອນຂຶ້ນເທິງສຸດຂອງລາຍຊື່ <emph>ຮູບແບບ</emph> ເພື່ອເບິ່ງຕົວເລືອກການຈັດຮູບແບບສໍາລັບສະກຸນເງິນນັ້ນ.</ahelp>"

#. UnPNs
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3150866\n"
"help.text"
msgid "The format code for currencies uses the form [$xxx-nnn], where xxx is the currency symbol, and nnn the country code. Special banking symbols, such as EUR (for Euro), do not require the country code. The currency format is not dependent on the language that you select in the<emph> Language</emph> box."
msgstr "ລະຫັດຮູບແບບສໍາລັບສະກຸນເງິນໃຊ້ຮູບແບບ [$xxx-nnn], ໂດຍທີ່ xxx ແມ່ນສັນຍະລັກສະກຸນເງິນ ແລະ nnn ແມ່ນລະຫັດປະເທດ. ສັນຍະລັກທະນາຄານພິເສດ ເຊັ່ນ EUR (ສໍາລັບ Euro) ບໍ່ຈຳເປັນຕ້ອງໃຊ້ລະຫັດປະເທດ. ຮູບແບບສະກຸນເງິນບໍ່ຂຶ້ນກັບພາສາທີ່ທ່ານເລືອກໃນກ່ອງ <emph>ພາສາ</emph>."

#. AqLq2
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"hd_id3154071\n"
"help.text"
msgid "<variable id=\"languagelb_hd\">Language</variable>"
msgstr "<variable id=\"languagelb_hd\">ພາສາ</variable>"

#. FAyN2
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3154138\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/numberingformatpage/languagelb\">    <switchinline select=\"appl\">        <caseinline select=\"WRITER\">            Specifies the language setting for the selected fields. With the language set to <emph>Default</emph>, $[officename] automatically applies the number formats associated with the system default language.        </caseinline>        <caseinline select=\"CALC\">            Specifies the language setting for the selected cells.        </caseinline>        <defaultinline>Specifies the language setting for the selected field.</defaultinline>    </switchinline>    </ahelp>"
msgstr "<ahelp hid=\"cui/ui/numberingformatpage/languagelb\"> <switchinline select=\"appl\"> <caseinline select=\"WRITER\"> ລະບຸການຕັ້ງຄ່າພາສາສໍາລັບຟີລດ໌ທີ່ເລືອກ. ເມື່ອຕັ້ງຄ່າພາສາເປັນ <emph>ຄ່າເລີ່ມຕົ້ນ</emph>, $[officename] ຈະນຳໃຊ້ຮູບແບບຕົວເລກທີ່ກ່ຽວຂ້ອງກັບພາສາເລີ່ມຕົ້ນຂອງລະບົບໂດຍອັດຕະໂນມັດ. </caseinline> <caseinline select=\"CALC\"> ລະບຸການຕັ້ງຄ່າພາສາສໍາລັບຫ້ອງທີ່ເລືອກ. </caseinline> <defaultinline>ລະບຸການຕັ້ງຄ່າພາສາສໍາລັບຟີລດ໌ທີ່ເລືອກ.</defaultinline> </switchinline> </ahelp>"

#. K29ZG
#: 05020300.xhp
msgctxt ""
"05020300.xhp\n"
"par_id3157320\n"
"help.text"
msgid "The language setting ensures that date and currency formats, as well as decimal and thousands separators, are preserved even when the document is opened in an operating system that uses a different default language setting."
msgstr "ການຕັ້ງຄ່າພາສາຈະຊ່ວຍໃຫ້ໝັ້ນໃຈວ່າຮູບແບບວັນທີ ແລະ ສະກຸນເງິນ, ລວມທັງຕົວຂັ້ນທົດສະນິຍົມ ແລະ ຫຼັກພັນ ຈະຖືກຮັກສາໄວ້ ເຖິງແມ່ນວ່າຈະເປີດເອກະສານໃນລະບົບປະຕິບັດການທີ່ໃຊ້ການຕັ້ງຄ່າພາສາເລີ່ມຕົ້ນທີ່ແຕກຕ່າງກັນ."

#. RbcVq
