"par_id3146856\n"
"help.text"
msgid "<variable id=\"speichernuntertext\"><ahelp hid=\".\">Saves the current document in a different location, or with a different file name or file type.</ahelp></variable>"
msgstr "<variable id=\"speichernuntertext\"><ahelp hid=\".\">ບັນທຶກເອກະສານປັດຈຸບັນໄວ້ໃນສະຖານທີ່ອື່ນ, ຫຼື ດ້ວຍຊື່ໄຟລ໌ ຫຼື ປະເພດໄຟລ໌ອື່ນ.</ahelp></variable>"

#. JDKKZ
#: 01070000.xhp
