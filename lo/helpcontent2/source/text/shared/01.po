"help.text"
msgid "<link href=\"text/shared/01/05220000.xhp\">Text</link>"
msgstr "<link href=\"text/shared/01/05220000.xhp\">ຂໍ້ຄວາມ</link>"

#. cBEMC
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3150279\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/TextAttributesPage\">Sets the layout and anchoring properties for text in the selected drawing or text object.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/TextAttributesPage\">ຕັ້ງຄ່າການຈັດວາງ ແລະ ຄຸນສົມບັດການຢຶດສຳລັບຂໍ້ຄວາມໃນວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມທີ່ເລືອກ.</ahelp>"

#. M7viB
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3154794\n"
"help.text"
msgid "The text is positioned relative to the edges of the drawing or text object."
msgstr "ຂໍ້ຄວາມຖືກຈັດຕຳແໜ່ງໃຫ້ສອດຄ່ອງກັບຂອບຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ."

#. WcxTm
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3149031\n"
"help.text"
msgid "Drawing Object Text"
msgstr "ຂໍ້ຄວາມວັດຖຸການແຕ້ມ"

#. ep3BQ
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3150445\n"
"help.text"
msgid "Fit width to text"
msgstr "ປັບຄວາມກວ້າງໃຫ້ເຂົ້າກັບຂໍ້ຄວາມ"

#. GTHsX
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3145629\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/TSB_AUTOGROW_WIDTH\">Expands the width of the object to the width of the text, if the object is smaller than the text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/TSB_AUTOGROW_WIDTH\">ຂະຫຍາຍຄວາມກວ້າງຂອງວັດຖຸໃຫ້ເທົ່າກັບຄວາມກວ້າງຂອງຂໍ້ຄວາມ, ຖ້າວັດຖຸນ້ອຍກວ່າຂໍ້ຄວາມ.</ahelp>"

#. 25jDY
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3149511\n"
"help.text"
msgid "Fit height to text"
msgstr "ປັບຄວາມສູງໃຫ້ເຂົ້າກັບຂໍ້ຄວາມ"

#. tPxAt
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3149640\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/TSB_AUTOGROW_HEIGHT\">Expands the height of the object to the height of the text, if the object is smaller than the text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/TSB_AUTOGROW_HEIGHT\">ຂະຫຍາຍຄວາມສູງຂອງວັດຖຸໃຫ້ເທົ່າກັບຄວາມສູງຂອງຂໍ້ຄວາມ, ຖ້າວັດຖຸນ້ອຍກວ່າຂໍ້ຄວາມ.</ahelp>"

#. DBz4z
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3152867\n"
"help.text"
msgid "Fit to frame"
msgstr "ປັບໃຫ້ເຂົ້າກັບກອບ"

#. PHCtm
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3147834\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/TSB_FIT_TO_SIZE\">Resizes the text to fit the entire area of the drawing or text object.</ahelp> This control is available only when the other \"fit\" controls are not selected."
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/TSB_FIT_TO_SIZE\">ປ່ຽນຂະໜາດຂໍ້ຄວາມໃຫ້ພໍດີກັບພື້ນທີ່ທັງໝົດຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ.</ahelp> ການຄວບຄຸມນີ້ສາມາດໃຊ້ໄດ້ສະເພາະເມື່ອຕົວຄວບຄຸມ \"ປັບ\" ອື່ນໆບໍ່ຖືກເລືອກ."

#. ZCxA3
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3155892\n"
"help.text"
msgid "Adjust to contour"
msgstr "ປັບຕາມເສັ້ນຂອບຮູບ"

#. ZEHLZ
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3153577\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/TSB_CONTOUR\">Adapts the text flow so that it matches the contours of the selected drawing object.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/TSB_CONTOUR\">ປັບການໄຫຼຂອງຂໍ້ຄວາມໃຫ້ສອດຄ່ອງກັບເສັ້ນຂອບຂອງວັດຖຸການແຕ້ມທີ່ເລືອກ.</ahelp>"

#. LRVR9
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3149376\n"
"help.text"
msgid "Custom Shape Text"
msgstr "ຂໍ້ຄວາມຮູບຊົງກຳນົດເອງ"

#. BfUAu
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_idN10705\n"
"help.text"
msgid "Word wrap text in shape"
msgstr "ຕັດຄຳຂໍ້ຄວາມໃນຮູບຊົງ"

#. 24nPp
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_idN10709\n"
"help.text"
msgid "<ahelp hid=\".\">Wraps the text that you add after double-clicking a custom shape to fit inside the shape.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັດຄຳຂໍ້ຄວາມທີ່ທ່ານເພີ່ມຫຼັງຈາກດັບເບິນຄລິກຮູບຊົງກຳນົດເອງໃຫ້ພໍດີພາຍໃນຮູບຊົງ.</ahelp>"

#. C9z8b
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_idN10720\n"
"help.text"
msgid "Resize shape to fit text"
msgstr "ປ່ຽນຂະໜາດຮູບຊົງໃຫ້ພໍດີກັບຂໍ້ຄວາມ"

#. TdDbb
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_idN10724\n"
"help.text"
msgid "<ahelp hid=\".\">Resizes a custom shape to fit the text that you enter after double-clicking the shape.</ahelp>"
msgstr "<ahelp hid=\".\">ປ່ຽນຂະໜາດຮູບຊົງກຳນົດເອງໃຫ້ພໍດີກັບຂໍ້ຄວາມທີ່ທ່ານປ້ອນຫຼັງຈາກດັບເບິນຄລິກຮູບຊົງ.</ahelp>"

#. TaxGS
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3154288\n"
"help.text"
msgid "Spacing to borders"
msgstr "ໄລຍະຫ່າງຫາຂອບ"

#. Df2Gs
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3151265\n"
"help.text"
msgid "Specify the amount of space to leave between the edges of the drawing or text object and the borders of the text."
msgstr "ລະບຸປະລິມານໄລຍະຫ່າງທີ່ຕ້ອງການປະໄວ້ລະຫວ່າງຂອບຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ ແລະ ຂອບຂອງຂໍ້ຄວາມ."

#. CdKeZ
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3150443\n"
"help.text"
msgid "Left"
msgstr "ຊ້າຍ"

#. gWCLw
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3156113\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/MTR_FLD_LEFT\">Enter the amount of space to leave between the left edge of the drawing or text object and the left border of the text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/MTR_FLD_LEFT\">ປ້ອນປະລິມານໄລຍະຫ່າງທີ່ຕ້ອງການປະໄວ້ລະຫວ່າງຂອບຊ້າຍຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ ແລະ ຂອບຊ້າຍຂອງຂໍ້ຄວາມ.</ahelp>"

#. MetRA
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3155419\n"
"help.text"
msgid "Right"
msgstr "ຂວາ"

#. QUbSu
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3155388\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/MTR_FLD_RIGHT\">Enter the amount of space to leave between the right edge of the drawing or text object and the right border of the text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/MTR_FLD_RIGHT\">ປ້ອນປະລິມານໄລຍະຫ່າງທີ່ຕ້ອງການປະໄວ້ລະຫວ່າງຂອບຂວາຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ ແລະ ຂອບຂວາຂອງຂໍ້ຄວາມ.</ahelp>"

#. WMtSB
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3148926\n"
"help.text"
msgid "Top"
msgstr "ເທິງ"

