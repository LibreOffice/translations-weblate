"help.text"
msgid "Normally in a mixed text selection made of Hangul and Hanja characters, all Hangul characters will be converted to Hanja and all Hanja characters will be converted to Hangul. If you want to convert a mixed text selection only in one direction, use the following conversion options."
msgstr "ໂດຍປົກກະຕິໃນການເລືອກຂໍ້ຄວາມທີ່ມີທັງຕົວອັກສອນ ຮັນກຶລ ແລະ ຮັນຈາ ປະປົນກັນ, ຕົວອັກສອນ ຮັນກຶລ ທັງໝົດຈະຖືກແປງເປັນ ຮັນຈາ ແລະ ຕົວອັກສອນ ຮັນຈາ ທັງໝົດຈະຖືກແປງເປັນ ຮັນກຶລ. ຖ້າທ່ານຕ້ອງການແປງຂໍ້ຄວາມທີ່ມີການປະປົນກັນພຽງແຕ່ທິດທາງດຽວ, ໃຫ້ໃຊ້ຕົວເລືອກການແປງຕໍ່ໄປນີ້."

#. TEgnJ
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3153585\n"
"help.text"
msgid "Hangul only"
msgstr "ຮັນກຶລ ເທົ່ານັ້ນ"

#. xfyFv
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3154142\n"
"help.text"
msgid "<ahelp hid=\".\">Check to convert only Hangul. Do not convert Hanja.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍເລືອກເພື່ອແປງສະເພາະ ຮັນກຶລ. ບໍ່ຕ້ອງແປງ ຮັນຈາ.</ahelp>"

#. ps5DC
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3150823\n"
"help.text"
msgid "Hanja only"
msgstr "ຮັນຈາ ເທົ່ານັ້ນ"

#. VWjwM
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3156023\n"
"help.text"
msgid "<ahelp hid=\".\">Check to convert only Hanja. Do not convert Hangul.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍເລືອກເພື່ອແປງສະເພາະ ຮັນຈາ. ບໍ່ຕ້ອງແປງ ຮັນກຶລ.</ahelp>"

#. iVmhT
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3152360\n"
"help.text"
msgid "Ignore"
msgstr "ລະເວັ້ນ"

#. CEcrh
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3153896\n"
"help.text"
msgid "<ahelp hid=\".\">No changes will be made to the current selection. The next word or character will be selected for conversion.</ahelp>"
msgstr "<ahelp hid=\".\">ຈະບໍ່ມີການປ່ຽນແປງໃດໆ ກັບຂໍ້ຄວາມທີ່ເລືອກໃນປັດຈຸບັນ. ຄຳສັບ ຫຼື ຕົວອັກສອນຖັດໄປຈະຖືກເລືອກເພື່ອການແປງ.</ahelp>"

#. 4vAhE
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3148550\n"
"help.text"
msgid "Always Ignore"
msgstr "ລະເວັ້ນສະເໝີ"

#. dFeqA
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3154937\n"
"help.text"
msgid "<ahelp hid=\".\">No changes will be made to the current selection, and every time the same selection is detected it will be skipped automatically.</ahelp> The next word or character will be selected for conversion. The list of ignored text is valid for the current $[officename] session."
msgstr "<ahelp hid=\".\">ຈະບໍ່ມີການປ່ຽນແປງໃດໆ ກັບຂໍ້ຄວາມທີ່ເລືອກໃນປັດຈຸບັນ, ແລະ ທຸກຄັ້ງທີ່ກວດພົບຂໍ້ຄວາມດຽວກັນນີ້ ມັນຈະຖືກຂ້າມໄປໂດຍອັດຕະໂນມັດ.</ahelp> ຄຳສັບ ຫຼື ຕົວອັກສອນຖັດໄປຈະຖືກເລືອກເພື່ອການແປງ. ລາຍການຂໍ້ຄວາມທີ່ລະເວັ້ນຈະມີຜົນສຳລັບເຊດຊັນ $[officename] ປັດຈຸບັນ."

#. HWDsf
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3151056\n"
"help.text"
msgid "Replace"
msgstr "ປ່ຽນແທນ"

#. 5w8zc
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3148403\n"
"help.text"
msgid "<ahelp hid=\".\">Replaces the selection with the suggested characters or word according to the format options.</ahelp> The next word or character will be selected for conversion."
msgstr "<ahelp hid=\".\">ປ່ຽນແທນຂໍ້ຄວາມທີ່ເລືອກດ້ວຍຕົວອັກສອນ ຫຼື ຄຳສັບທີ່ແນະນຳຕາມຕົວເລືອກຮູບແບບ.</ahelp> ຄຳສັບ ຫຼື ຕົວອັກສອນຖັດໄປຈະຖືກເລືອກເພື່ອການແປງ."

#. UmBHG
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3153360\n"
"help.text"
msgid "Always Replace"
msgstr "ປ່ຽນແທນສະເໝີ"

#. 95yCh
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3153338\n"
"help.text"
msgid "<ahelp hid=\".\">Replaces the selection with the suggested characters or word according to the format options. Every time the same selection is detected it will be replaced automatically.</ahelp> The next word or character will be selected for conversion. The list of replacement text is valid for the current $[officename] session."
msgstr "<ahelp hid=\".\">ປ່ຽນແທນຂໍ້ຄວາມທີ່ເລືອກດ້ວຍຕົວອັກສອນ ຫຼື ຄຳສັບທີ່ແນະນຳຕາມຕົວເລືອກຮູບແບບ. ທຸກຄັ້ງທີ່ກວດພົບຂໍ້ຄວາມດຽວກັນນີ້ ມັນຈະຖືກປ່ຽນແທນໂດຍອັດຕະໂນມັດ.</ahelp> ຄຳສັບ ຫຼື ຕົວອັກສອນຖັດໄປຈະຖືກເລືອກເພື່ອການແປງ. ລາຍການຂໍ້ຄວາມປ່ຽນແທນຈະມີຜົນສຳລັບເຊດຊັນ $[officename] ປັດຈຸບັນ."

#. s9pTB
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"hd_id3149290\n"
"help.text"
msgid "Replace by character"
msgstr "ປ່ຽນແທນທີລະຕົວອັກສອນ"

#. nFekB
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_id3145154\n"
"help.text"
msgid "<ahelp hid=\".\">Check to move character-by-character through the selected text. If not checked, full words are replaced.</ahelp>"
msgstr "<ahelp hid=\".\">ໝາຍເລືອກເພື່ອຍ້າຍໄປທີລະຕົວອັກສອນຜ່ານຂໍ້ຄວາມທີ່ເລືອກ. ຖ້າບໍ່ໄດ້ໝາຍເລືອກ, ຄຳສັບທັງໝົດຈະຖືກປ່ຽນແທນ.</ahelp>"

#. LSenp
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_idN10969\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. BDDAa
#: 06200000.xhp
msgctxt ""
"06200000.xhp\n"
"par_idN1096D\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the <link href=\"text/shared/01/06201000.xhp\">Hangul/Hanja Options</link> dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/06201000.xhp\">ຕົວເລືອກ ຮັນກຶລ/ຮັນຈາ</link>.</ahelp>"

#. fEEqK
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"tit\n"
"help.text"
msgid "Hangul/Hanja Options"
msgstr "ຕົວເລືອກ ຮັນກຶລ/ຮັນຈາ"

#. xmePQ
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10542\n"
"help.text"
msgid "Hangul/Hanja Options"
msgstr "ຕົວເລືອກ ຮັນກຶລ/ຮັນຈາ"

#. yHGNb
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10546\n"
"help.text"
msgid "Define options for the <link href=\"text/shared/01/06200000.xhp\">Hangul/Hanja conversion</link>."
msgstr "ກຳນົດຕົວເລືອກສຳລັບ <link href=\"text/shared/01/06200000.xhp\">ການແປງ ຮັນກຶລ/ຮັນຈາ</link>."

#. EqybG
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN1055F\n"
"help.text"
msgid "User-defined dictionaries"
msgstr "ວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງ"

#. kFzq7
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10563\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaadddialog/HangulHanjaAddDialog\">Lists all user-defined dictionaries. Select the check box next to the dictionary that you want to use. Clear the check box next to the dictionary that you do not want to use.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaadddialog/HangulHanjaAddDialog\">ສະແດງລາຍການວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງທັງໝົດ. ໝາຍເລືອກກ່ອງໝາຍຂ້າງວັດຈະນານຸກົມທີ່ທ່ານຕ້ອງການໃຊ້. ຍົກເລີກການໝາຍກ່ອງໝາຍຂ້າງວັດຈະນານຸກົມທີ່ທ່ານບໍ່ຕ້ອງການໃຊ້.</ahelp>"

#. CbfrL
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN1057A\n"
"help.text"
msgid "New"
msgstr "ໃໝ່"

#. t8MW2
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN1057E\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/new\">Opens the New dictionary dialog box, where you can create a new dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/new\">ເປີດກ່ອງໂຕ້ຕອບ ວັດຈະນານຸກົມໃໝ່, ເຊິ່ງທ່ານສາມາດສ້າງວັດຈະນານຸກົມໃໝ່ໄດ້.</ahelp>"

#. fwA94
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10595\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. dZkuD
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10599\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaadddialog/entry\">Enter a name for the dictionary.</ahelp> To display the new dictionary in the <emph>User-defined dictionaries</emph> list box, click <emph>OK</emph>."
msgstr "<ahelp hid=\"cui/ui/hangulhanjaadddialog/entry\">ປ້ອນຊື່ສຳລັບວັດຈະນານຸກົມ.</ahelp> ເພື່ອສະແດງວັດຈະນານຸກົມໃໝ່ໃນກ່ອງລາຍການ <emph>ວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງ</emph>, ໃຫ້ຄລິກ <emph>ຕົກລົງ</emph>."

#. xWEZk
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105B5\n"
"help.text"
msgid "Edit"
msgstr "ແກ້ໄຂ"

#. htGCV
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105B9\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/edit\">Opens the <link href=\"text/shared/01/06202000.xhp\">Edit Custom Dictionary</link> dialog where you can edit any user-defined dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/edit\">ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/06202000.xhp\">ແກ້ໄຂວັດຈະນານຸກົມທີ່ປັບແຕ່ງເອງ</link> ເຊິ່ງທ່ານສາມາດແກ້ໄຂວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງໄດ້.</ahelp>"

#. BLaEH
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105DE\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. WXq6D
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105E2\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/delete\">Deletes the selected user-defined dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/delete\">ລຶບວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງທີ່ເລືອກໄວ້.</ahelp>"

#. NgCgF
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105F1\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. jompr
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN105F5\n"
"help.text"
msgid "Specifies additional options for all dictionaries."
msgstr "ກຳນົດຕົວເລືອກເພີ່ມເຕີມສຳລັບວັດຈະນານຸກົມທັງໝົດ."

#. DCWGB
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10600\n"
"help.text"
msgid "Ignore post-positional word"
msgstr "ລະເວັ້ນຄຳສັບຫຼັງຕຳແໜ່ງ"

#. oLoV7
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10604\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/ignorepost\">Ignores positional characters at the end of Korean words when you search a dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/ignorepost\">ລະເວັ້ນຕົວອັກສອນທີ່ບອກຕຳແໜ່ງຢູ່ທ້າຍຄຳສັບພາສາເກົາຫຼີເມື່ອທ່ານຄົ້ນຫາໃນວັດຈະນານຸກົມ.</ahelp>"

#. c8vEK
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10636\n"
"help.text"
msgid "Show entries recently used first"
msgstr "ສະແດງລາຍການທີ່ໃຊ້ຫຼ້າສຸດກ່ອນ"

#. v5DQe
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN1063A\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/showrecentfirst\">Shows the replacement suggestion that you selected the last time as the first entry on the list.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/showrecentfirst\">ສະແດງຄຳແນະນຳການປ່ຽນແທນທີ່ທ່ານເລືອກຄັ້ງຫຼ້າສຸດເປັນລາຍການທຳອິດໃນລາຍການ.</ahelp>"

#. xzahj
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10651\n"
"help.text"
msgid "Replace all unique entries automatically"
msgstr "ປ່ຽນແທນລາຍການທີ່ບໍ່ຊ້ຳກັນທັງໝົດໂດຍອັດຕະໂນມັດ"

#. JLhTF
#: 06201000.xhp
msgctxt ""
"06201000.xhp\n"
"par_idN10655\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/autoreplaceunique\">Automatically replaces words that only have one suggested word replacement.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/hangulhanjaoptdialog/autoreplaceunique\">ປ່ຽນແທນຄຳສັບທີ່ມີພຽງແຕ່ຄຳສັບແນະນຳດຽວໂດຍອັດຕະໂນມັດ.</ahelp>"

#. mTBV7
#: 06202000.xhp
msgctxt ""
"06202000.xhp\n"
"tit\n"
"help.text"
msgid "Edit Custom Dictionary"
