msgid "Gradient"
msgstr "ສີໄລ່ລະດັບ"

#. eyRRB
#: 05210300.xhp
msgctxt ""
"05210300.xhp\n"
"par_id971584574359838\n"
"help.text"
msgid "Lists the available gradients. You can also modify or create your own gradients."
