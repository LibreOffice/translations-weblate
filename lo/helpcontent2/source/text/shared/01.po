#. m9p8k
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id3156042\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/descriptioninfopage/title\">Enter a title for the document.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/descriptioninfopage/title\">ປ້ອນຊື່ເລື່ອງສຳລັບເອກະສານ.</ahelp>"

#. AfJNA
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id291714416716612\n"
"help.text"
msgid "<emph>DCMI Definition: </emph>A name given to the resource."
msgstr "<emph>ຄຳນິຍາມ DCMI: </emph>ຊື່ທີ່ຕັ້ງໃຫ້ກັບຊັບພະຍາກອນ."

#. mirp7
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id3145669\n"
"help.text"
msgid "<variable id=\"subject_h3\">Subject</variable>"
msgstr "<variable id=\"subject_h3\">ຫົວຂໍ້</variable>"

#. aPM28
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id3147571\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/descriptioninfopage/subject\">Enter a subject for the document. You can use a subject to group documents with similar contents.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/descriptioninfopage/subject\">ປ້ອນຫົວຂໍ້ສຳລັບເອກະສານ. ທ່ານສາມາດໃຊ້ຫົວຂໍ້ເພື່ອຈັດກຸ່ມເອກະສານທີ່ມີເນື້ອຫາຄ້າຍຄືກັນ.</ahelp>"

#. CwTLv
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id781714416090632\n"
"help.text"
msgid "<emph>DCMI Definition: </emph>The topic of the resource."
msgstr "<emph>ຄຳນິຍາມ DCMI: </emph>ຫົວຂໍ້ຂອງຊັບພະຍາກອນ."

#. ntXMN
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id3156426\n"
"help.text"
msgid "<variable id=\"keywords_h3\">Keywords</variable>"
msgstr "<variable id=\"keywords_h3\">ຄຳສຳຄັນ</variable>"

#. 4pHTt
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id3155338\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/descriptioninfopage/keywords\">Enter the words that you want to use to index the content of your document. Keywords must be separated by commas. A keyword can contain white space characters or semicolons.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/descriptioninfopage/keywords\">ປ້ອນຄຳສັບທີ່ທ່ານຕ້ອງການໃຊ້ເພື່ອເຮັດດັດຊະນີເນື້ອຫາຂອງເອກະສານຂອງທ່ານ. ຄຳສຳຄັນຕ້ອງຖືກແຍກດ້ວຍຈຸດ. ຄຳສຳຄັນສາມາດມີຕົວອັກສອນຍະຫວ່າງ ຫຼື ຈຸດຈ້ຳ (semicolons).</ahelp>"

#. pkTCC
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id991712331471026\n"
"help.text"
msgid "<variable id=\"contributor_h3\">Contributor</variable>"
msgstr "<variable id=\"contributor_h3\">ຜູ້ປະກອບສ່ວນ</variable>"

#. BejA7
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id1001712331484014\n"
"help.text"
msgid "Enter the names of the people, organizations, or other entities that have made contributions to the document. For example, the names of the document’s authors, or team members who contributed data to it."
msgstr "ປ້ອນຊື່ຂອງບຸກຄົນ, ອົງການຈັດຕັ້ງ, ຫຼື ໜ່ວຍງານອື່ນໆທີ່ມີສ່ວນຮ່ວມໃນເອກະສານ. ຕົວຢ່າງ: ຊື່ຂອງຜູ້ຂຽນເອກະສານ, ຫຼື ສະມາຊິກທີມທີ່ປະກອບສ່ວນຂໍ້ມູນໃຫ້."

#. CicCF
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id341714417205026\n"
"help.text"
msgid "<emph>DCMI Definition: </emph>An entity responsible for making contributions to the resource."
msgstr "<emph>ຄຳນິຍາມ DCMI: </emph>ໜ່ວຍງານທີ່ຮັບຜິດຊອບໃນການປະກອບສ່ວນໃຫ້ກັບຊັບພະຍາກອນ."

#. 9HoTd
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id291712331494279\n"
"help.text"
msgid "<variable id=\"coverage_h3\">Coverage</variable>"
msgstr "<variable id=\"coverage_h3\">ຂອບເຂດ</variable>"

#. vCizD
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id961712331502781\n"
"help.text"
msgid "Enter the time, place, or jurisdiction that the document is relevant to. For example, a range of dates, a place, or an institution that the document applies to."
msgstr "ປ້ອນເວລາ, ສະຖານທີ່, ຫຼື ເຂດອຳນາດທີ່ເອກະສານກ່ຽວຂ້ອງ. ຕົວຢ່າງ: ຊ່ວງວັນທີ, ສະຖານທີ່, ຫຼື ສະຖາບັນທີ່ເອກະສານນຳໃຊ້."

#. 3NGzr
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id751714417027700\n"
"help.text"
msgid "<emph>DCMI Definition: </emph>The spatial or temporal topic of the resource, the spatial applicability of the resource, or the jurisdiction under which the resource is relevant."
msgstr "<emph>ຄຳນິຍາມ DCMI: </emph>ຫົວຂໍ້ທາງດ້ານພື້ນທີ່ ຫຼື ເວລາຂອງຊັບພະຍາກອນ, ການນຳໃຊ້ທາງດ້ານພື້ນທີ່ຂອງຊັບພະຍາກອນ, ຫຼື ເຂດອຳນາດທີ່ຊັບພະຍາກອນກ່ຽວຂ້ອງ."

#. oCXtb
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id91712331508846\n"
"help.text"
msgid "<variable id=\"identifier_h3\">Identifier</variable>"
msgstr "<variable id=\"identifier_h3\">ຕົວລະບຸ</variable>"

#. knfFR
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id311712331541857\n"
"help.text"
msgid "Enter a unique and unambiguous identifier for the document. For example, a document number or ISBN."
msgstr "ປ້ອນຕົວລະບຸທີ່ເປັນເອກະລັກ ແລະ ຊັດເຈນສຳລັບເອກະສານ. ຕົວຢ່າງ: ເລກທີເອກະສານ ຫຼື ISBN."

#. ifeVh
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id951714414695195\n"
"help.text"
msgid "<emph>DCMI Definition: </emph>An unambiguous reference to the document within a specific context."
msgstr "<emph>ຄຳນິຍາມ DCMI: </emph>ການອ້າງອີງທີ່ຊັດເຈນເຖິງເອກະສານພາຍໃນບໍລິບົດສະເພາະ."

#. xXzCz
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"hd_id941712331544480\n"
"help.text"
msgid "<variable id=\"publisher_h3\">Publisher</variable>"
msgstr "<variable id=\"publisher_h3\">ຜູ້ຈັດພິມ</variable>"

#. 3CXu4
#: 01100100.xhp
msgctxt ""
"01100100.xhp\n"
"par_id971712331610892\n"
"help.text"
msgid "Enter the name of the entity that is making the document available. For example, a company, university, or government body."
msgstr "ປ້ອນຊື່ຂອງໜ່ວຍງານທີ່ເຮັດໃຫ້ເອກະສານນີ້ມີໃຫ້ໃຊ້. ຕົວຢ່າງ: ບໍລິສັດ, ມະຫາວິທະຍາໄລ, ຫຼື ໜ່ວຍງານລັດຖະບານ."

