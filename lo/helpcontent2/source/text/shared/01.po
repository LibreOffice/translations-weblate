msgctxt ""
"05200100.xhp\n"
"hd_id3154582\n"
"help.text"
msgid "Corner style"
msgstr "ຮູບແບບມຸມ"

#. ieEoG
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"par_id3154583\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/linetabpage/LB_EDGE_STYLE\">Select the shape to be used at the corners of the line. In case of a small angle between lines, a mitered shape is replaced with a beveled shape.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/linetabpage/LB_EDGE_STYLE\">ເລືອກຮູບຊົງທີ່ຈະໃຊ້ຢູ່ມຸມຂອງເສັ້ນ. ໃນກໍລະນີທີ່ມີມຸມນ້ອຍລະຫວ່າງເສັ້ນ, ຮູບຊົງແບບຕັດມຸມຈະຖືກແທນທີ່ດ້ວຍຮູບຊົງແບບປາດມຸມ.</ahelp>"

#. XhFr3
