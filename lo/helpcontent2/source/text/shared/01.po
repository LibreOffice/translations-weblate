msgctxt ""
"02230401.xhp\n"
"hd_id3156543\n"
"help.text"
msgid "Reject"
msgstr "ປະຕິເສດ"

#. yCxtY
#: 02230401.xhp
msgctxt ""
"02230401.xhp\n"
"par_id3150441\n"
