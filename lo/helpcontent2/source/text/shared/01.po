"help.text"
msgid "No-break space"
msgstr "ຍະຫວ່າງບໍ່ແຍກແຖວ"

#. GHcb4
#: formatting_mark.xhp
msgctxt ""
"formatting_mark.xhp\n"
"par_id8326975\n"
"help.text"
msgid "<ahelp hid=\".\">Inserts a space that will keep bordering characters together on line breaks.</ahelp>"
msgstr "<ahelp hid=\".\">ແຊກຍະຫວ່າງທີ່ຈະຮັກສາຕົວອັກສອນທີ່ຢູ່ຕິດກັນໄວ້ດ້ວຍກັນເມື່ອມີການຂຶ້ນແຖວໃໝ່.</ahelp>"

#. VU75A
