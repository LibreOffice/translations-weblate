#. gwTHy
#: 01070000.xhp
msgctxt ""
"01070000.xhp\n"
"par_id3152883\n"
"help.text"
msgid "<ahelp hid=\"HID_FILESAVE_CUSTOMIZEFILTER\">Allows you to set the spreadsheet saving options for some types of data files.</ahelp>"
msgstr "<ahelp hid=\"HID_FILESAVE_CUSTOMIZEFILTER\">ອະນຸຍາດໃຫ້ທ່ານຕັ້ງຄ່າຕົວເລືອກການບັນທຶກສະເປຣດຊີດສຳລັບໄຟລ໌ຂໍ້ມູນບາງປະເພດ.</ahelp>"

#. GjLcH
