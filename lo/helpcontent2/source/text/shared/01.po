#. RWaK6
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3153394\n"
"help.text"
msgid "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/libraries\">Lists the libraries and the modules where you can open or save your macros. To save a macro with a particular document, open the document, and then open this dialog.</ahelp>"
msgstr "<ahelp hid=\"modules/BasicIDE/ui/basicmacrodialog/libraries\">ສະແດງລາຍຊື່ຫ້ອງສະໝຸດ ແລະ ໂມດູນທີ່ທ່ານສາມາດເປີດ ຫຼື ບັນທຶກມາກໂຄຣຂອງທ່ານໄດ້. ເພື່ອບັນທຶກມາກໂຄຣໄວ້ກັບເອກະສານໃດໜຶ່ງ, ໃຫ້ເປີດເອກະສານນັ້ນ ແລ້ວຈຶ່ງເປີດໄດອາລັອກນີ້.</ahelp>"

#. 7oBKv
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3147373\n"
"help.text"
msgid "Run / Save"
msgstr "ລັນ (Run) / ບັນທຶກ"

