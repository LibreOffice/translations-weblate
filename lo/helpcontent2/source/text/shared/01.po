#. fyUJY
#: addsignatureline.xhp
msgctxt ""
"addsignatureline.xhp\n"
"par_id701526467979209\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the title of the signer. The title is displayed in the signature line graphic box.</ahelp>"
