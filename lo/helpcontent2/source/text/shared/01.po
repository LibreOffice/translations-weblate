msgctxt ""
"01130000.xhp\n"
"bm_id3154621\n"
"help.text"
msgid "<bookmark_value>printing; documents</bookmark_value><bookmark_value>documents; printing</bookmark_value><bookmark_value>text documents; printing</bookmark_value><bookmark_value>spreadsheets; printing</bookmark_value><bookmark_value>presentations; print menu</bookmark_value><bookmark_value>drawings; printing</bookmark_value><bookmark_value>choosing printers</bookmark_value><bookmark_value>printers; choosing</bookmark_value><bookmark_value>print area selection</bookmark_value><bookmark_value>selecting; print areas</bookmark_value><bookmark_value>pages; selecting one to print</bookmark_value><bookmark_value>printing; selections</bookmark_value><bookmark_value>printing; copies</bookmark_value><bookmark_value>copies; printing</bookmark_value><bookmark_value>spoolfiles with Xprinter</bookmark_value>"
msgstr "<bookmark_value>ການພິມ; ເອກະສານ</bookmark_value><bookmark_value>ເອກະສານ; ການພິມ</bookmark_value><bookmark_value>ເອກະສານຂໍ້ຄວາມ; ການພິມ</bookmark_value><bookmark_value>ຕາຕະລາງຄຳນວນ; ການພິມ</bookmark_value><bookmark_value>ການນຳສະເໜີ; ເມນູການພິມ</bookmark_value><bookmark_value>ຮູບແຕ້ມ; ການພິມ</bookmark_value><bookmark_value>ການເລືອກເຄື່ອງພິມ</bookmark_value><bookmark_value>ເຄື່ອງພິມ; ການເລືອກ</bookmark_value><bookmark_value>ການເລືອກພື້ນທີ່ການພິມ</bookmark_value><bookmark_value>ການເລືອກ; ພື້ນທີ່ການພິມ</bookmark_value><bookmark_value>ໜ້າ; ການເລືອກເພື່ອພິມ</bookmark_value><bookmark_value>ການພິມ; ສ່ວນທີ່ເລືອກ</bookmark_value><bookmark_value>ການພິມ; ສຳເນົາ</bookmark_value><bookmark_value>ສຳເນົາ; ການພິມ</bookmark_value><bookmark_value>ໄຟລ໌ສະພູນດ້ວຍ Xprinter</bookmark_value>"

#. woR6C
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id3154621\n"
"help.text"
msgid "<link href=\"text/shared/01/01130000.xhp\">Print</link>"
msgstr "<link href=\"text/shared/01/01130000.xhp\">ພິມ</link>"

#. 3xkrS
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3146946\n"
"help.text"
msgid "<variable id=\"druckentext\"><ahelp hid=\".uno:Print\">Prints the current document, selection, or the pages that you specify. You can also set the print options for the current document.</ahelp>                </variable> The printing options can vary according to the printer and the operating system that you use."
msgstr "<variable id=\"druckentext\"><ahelp hid=\".uno:Print\">ພິມເອກະສານປັດຈຸບັນ, ສ່ວນທີ່ເລືອກ, ຫຼື ໜ້າທີ່ທ່ານລະບຸ. ທ່ານຍັງສາມາດຕັ້ງຄ່າຕົວເລືອກການພິມສຳລັບເອກະສານປັດຈຸບັນໄດ້.</ahelp></variable> ຕົວເລືອກການພິມອາດແຕກຕ່າງກັນໄປຕາມເຄື່ອງພິມ ແລະ ລະບົບປະຕິບັດການທີ່ທ່ານໃຊ້."

#. Y8AZi
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912284853\n"
"help.text"
msgid "The <emph>Print</emph> dialog consists of three main parts: A preview with navigation buttons, tab pages with control elements specific to the current document type, and the <emph>Print</emph>, <emph>Cancel</emph> and <emph>Help</emph> buttons."
msgstr "ກ່ອງໂຕ້ຕອບ <emph>ພິມ</emph> ປະກອບດ້ວຍສາມສ່ວນຫຼັກ: ຕົວຢ່າງກ່ອນພິມພ້ອມປຸ່ມນຳທາງ, ໜ້າແຖບທີ່ມີອົງປະກອບຄວບຄຸມສະເພາະສຳລັບປະເພດເອກະສານປັດຈຸບັນ, ແລະ ປຸ່ມ <emph>ພິມ</emph>, <emph>ຍົກເລີກ</emph> ແລະ <emph>ຊ່ວຍເຫຼືອ</emph>."

#. KGLDV
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200901193992\n"
"help.text"
msgid "If you just want to know how to print your document, click any of the following links."
msgstr "ຖ້າທ່ານຕ້ອງການຮູ້ວິທີການພິມເອກະສານຂອງທ່ານ, ໃຫ້ຄລິກທີ່ລິ້ງໃດໜຶ່ງຕໍ່ໄປນີ້."

#. mQg9e
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912531416\n"
"help.text"
msgid "<emph>Printing text documents</emph>:"
msgstr "<emph>ການພິມເອກະສານຂໍ້ຄວາມ</emph>:"

#. x2xfg
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912531487\n"
"help.text"
msgid "<emph>Printing spreadsheets</emph>:"
msgstr "<emph>ການພິມສະເປຣດຊີດ</emph>:"

#. 4ATQW
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912531410\n"
"help.text"
msgid "<emph>Printing presentations</emph>:"
msgstr "<emph>ການພິມການນຳສະເໜີ</emph>:"

#. bpAMH
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912531449\n"
"help.text"
msgid "<emph>General printing</emph>:"
msgstr "<emph>ການພິມທົ່ວໄປ</emph>:"

#. bau4s
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912284952\n"
"help.text"
msgid "The settings that you define in the <emph>Print</emph> dialog are valid <emph>only</emph> for the current print job that you start by clicking the <emph>Print</emph> button. If you want to change some options permanently, open <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME (application name) - Print</menuitem>."
msgstr "ການຕັ້ງຄ່າທີ່ທ່ານກຳນົດໃນກ່ອງໂຕ້ຕອບ <emph>ພິມ</emph> ຈະມີຜົນ <emph>ສະເພາະ</emph> ສຳລັບວຽກພິມປັດຈຸບັນທີ່ທ່ານເລີ່ມໂດຍການຄລິກປຸ່ມ <emph>ພິມ</emph> ເທົ່ານັ້ນ. ຖ້າທ່ານຕ້ອງການປ່ຽນຕົວເລືອກບາງຢ່າງແບບຖາວອນ, ໃຫ້ເປີດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME (ຊື່ແອັບພລິເຄຊັນ) - ພິມ</menuitem>."

#. GxHH7
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3156080\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\">To set the default <item type=\"productname\">%PRODUCTNAME</item> printer options for text documents, choose <link href=\"text/shared/optionen/01040400.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Writer - Print</menuitem></link>.</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\">ເພື່ອຕັ້ງຕົວເລືອກເຄື່ອງພິມເລີ່ມຕົ້ນຂອງ <item type=\"productname\">%PRODUCTNAME</item> ສຳລັບເອກະສານຂໍ້ຄວາມ, ໃຫ້ເລືອກ <link href=\"text/shared/optionen/01040400.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Writer - ພິມ</menuitem></link>.</caseinline></switchinline>"

#. zWTod
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_idN1099E\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"CALC\">To set the default <item type=\"productname\">%PRODUCTNAME</item> printer options for spreadsheet documents, choose <link href=\"text/shared/optionen/01060700.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Calc - Print</menuitem></link>.</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"CALC\">ເພື່ອຕັ້ງຕົວເລືອກເຄື່ອງພິມເລີ່ມຕົ້ນຂອງ <item type=\"productname\">%PRODUCTNAME</item> ສຳລັບເອກະສານສະເປຣດຊີດ, ໃຫ້ເລືອກ <link href=\"text/shared/optionen/01060700.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Calc - ພິມ</menuitem></link>.</caseinline></switchinline>"

#. UADCd
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_idN109CD\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"IMPRESS\">To set the default <item type=\"productname\">%PRODUCTNAME</item> printer options for presentation documents, choose <link href=\"text/shared/optionen/01070400.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - Print</menuitem></link>.</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ເພື່ອຕັ້ງຕົວເລືອກເຄື່ອງພິມເລີ່ມຕົ້ນຂອງ <item type=\"productname\">%PRODUCTNAME</item> ສຳລັບເອກະສານການນຳສະເໜີ, ໃຫ້ເລືອກ <link href=\"text/shared/optionen/01070400.xhp\"><switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Impress - ພິມ</menuitem></link>.</caseinline></switchinline>"

#. bEFFQ
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200901194137\n"
"help.text"
msgid "Press <emph>Shift+F1</emph> or choose <item type=\"menuitem\">Help - What's This?</item> and point to any control element in the <emph>Print</emph> dialog to see an extended help text."
msgstr "ກົດ <emph>Shift+F1</emph> ຫຼື ເລືອກ <item type=\"menuitem\">ຊ່ວຍເຫຼືອ - ນີ້ແມ່ນຫຍັງ?</item> ແລ້ວຊີ້ໄປທີ່ອົງປະກອບຄວບຄຸມໃດໜຶ່ງໃນກ່ອງໂຕ້ຕອບ <emph>ພິມ</emph> ເພື່ອເບິ່ງຂໍ້ຄວາມຊ່ວຍເຫຼືອເພີ່ມເຕີມ."

#. 5V5He
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id0818200912284914\n"
"help.text"
msgid "Preview"
msgstr "ຕົວຢ່າງກ່ອນພິມ"

#. GY9Uv
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id081820091228505\n"
"help.text"
msgid "<ahelp hid=\".\">The preview shows how each sheet of paper will look. You can browse through all sheets of paper with the buttons below the preview.</ahelp>"
msgstr "<ahelp hid=\".\">ຕົວຢ່າງກ່ອນພິມຈະສະແດງໃຫ້ເຫັນວ່າແຜ່ນເຈ້ຍແຕ່ລະແຜ່ນຈະເປັນແນວໃດ. ທ່ານສາມາດເບິ່ງແຜ່ນເຈ້ຍທັງໝົດໄດ້ດ້ວຍປຸ່ມທີ່ຢູ່ລຸ່ມຕົວຢ່າງກ່ອນພິມ.</ahelp>"

#. bkEuD
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id691619139072776\n"
"help.text"
msgid "Preview checkbox"
msgstr "ຊ່ອງໝາຍຕົວຢ່າງກ່ອນພິມ"

#. FbBW7
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150776\n"
"help.text"
msgid "<ahelp hid=\".\">Turn on or off display of the print preview.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດ ຫຼື ປິດການສະແດງຕົວຢ່າງກ່ອນພິມ.</ahelp>"

#. VupTf
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id931619139079209\n"
"help.text"
msgid "Preview navigation box"
msgstr "ກ່ອງນຳທາງຕົວຢ່າງກ່ອນພິມ"

#. uGPRE
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150773\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the number of page to be shown in the preview in the box or use the arrow buttons to display pages in the preview.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນໝາຍເລກໜ້າທີ່ຈະສະແດງໃນຕົວຢ່າງກ່ອນພິມເຂົ້າໃນກ່ອງ ຫຼື ໃຊ້ປຸ່ມລູກສອນເພື່ອສະແດງໜ້າຕ່າງໆໃນຕົວຢ່າງກ່ອນພິມ.</ahelp>"

#. Zg7aE
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150774\n"
"help.text"
msgid "<ahelp hid=\".\"><widget>🡆</widget> Shows preview of the next page.</ahelp>"
msgstr "<ahelp hid=\".\"><widget>🡆</widget> ສະແດງຕົວຢ່າງຂອງໜ້າຖັດໄປ.</ahelp>"

#. fAR3e
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id131619140182489\n"
"help.text"
msgid "<widget>⯮</widget> Shows preview of the last page."
msgstr "<widget>⯮</widget> ສະແດງຕົວຢ່າງຂອງໜ້າສຸດທ້າຍ."

#. Ge5HC
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150775\n"
"help.text"
msgid "<ahelp hid=\".\"><widget>🡄</widget> Shows preview of the previous page.</ahelp>"
msgstr "<ahelp hid=\".\"><widget>🡄</widget> ສະແດງຕົວຢ່າງຂອງໜ້າກ່ອນໜ້າ.</ahelp>"

#. mBis5
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id711619140188690\n"
"help.text"
msgid "<widget>⯬</widget> Shows preview of the first page."
msgstr "<widget>⯬</widget> ສະແດງຕົວຢ່າງຂອງໜ້າທຳອິດ."

#. y5JqS
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id0818200912285056\n"
"help.text"
msgid "General"
msgstr "ທົ່ວໄປ"

#. vgrqb
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id0818200912285064\n"
"help.text"
msgid "On the <emph>General</emph> tab page, you find the most important control elements for printing. You can define which contents of your document are to be printed. You can select the printer and open the <emph>Printer Settings</emph> dialog."
msgstr "ໃນໜ້າແຖບ <emph>ທົ່ວໄປ</emph>, ທ່ານຈະພົບເຫັນອົງປະກອບຄວບຄຸມທີ່ສຳຄັນທີ່ສຸດສຳລັບການພິມ. ທ່ານສາມາດກຳນົດໄດ້ວ່າຈະພິມເນື້ອໃນໃດຂອງເອກະສານ. ທ່ານສາມາດເລືອກເຄື່ອງພິມ ແລະ ເປີດກ່ອງໂຕ້ຕອບ <emph>ການຕັ້ງຄ່າເຄື່ອງພິມ</emph> ໄດ້."

#. 5cGHt
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id861619196034872\n"
"help.text"
msgid "Printer"
msgstr "ເຄື່ອງພິມ"

#. 5hiFP
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3149511\n"
"help.text"
msgid "<ahelp hid=\".\">The list box shows the installed printers. Click the printer to use for the current print job.</ahelp>"
msgstr "<ahelp hid=\".\">ກ່ອງລາຍຊື່ສະແດງເຄື່ອງພິມທີ່ຕິດຕັ້ງໄວ້. ຄລິກເລືອກເຄື່ອງພິມທີ່ຈະໃຊ້ສຳລັບວຽກພິມປັດຈຸບັນ.</ahelp>"

#. 9CQRU
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id111619248846947\n"
"help.text"
msgid "Status"
msgstr "ສະຖານະ"

#. Kfwra
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id42\n"
"help.text"
msgid "<ahelp hid=\".\">Shows the availability of the selected printer.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງຄວາມພ້ອມໃຊ້ງານຂອງເຄື່ອງພິມທີ່ເລືອກ.</ahelp>"

#. vEyiG
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id851619198158428\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. ZMfYb
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3156113\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the <emph>Printer Properties</emph> dialog. The printer properties vary according to the printer that you select.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ <emph>ຄຸນສົມບັດເຄື່ອງພິມ</emph>. ຄຸນສົມບັດເຄື່ອງພິມຈະແຕກຕ່າງກັນໄປຕາມເຄື່ອງພິມທີ່ທ່ານເລືອກ.</ahelp>"

#. TXTqq
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id301619196931584\n"
"help.text"
msgid "Range and copies"
msgstr "ຊ່ວງ ແລະ ຈຳນວນສຳເນົາ"

#. CjmAo
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id411619223685491\n"
"help.text"
msgid "All pages"
msgstr "ທຸກໜ້າ"

#. REG4m
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3149164\n"
"help.text"
msgid "<ahelp hid=\".\">Prints the entire document.</ahelp>"
msgstr "<ahelp hid=\".\">ພິມເອກະສານທັງໝົດ.</ahelp>"

#. miCEv
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id471619223699982\n"
"help.text"
msgid "Pages"
msgstr "ໜ້າ"

#. TzCg9
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3152944\n"
"help.text"
msgid "<ahelp hid=\".\">Prints only the pages or slides that you specify in the <emph>Pages</emph> box.</ahelp>"
msgstr "<ahelp hid=\".\">ພິມສະເພາະໜ້າ ຫຼື ສະໄລ້ທີ່ທ່ານລະບຸໃນກ່ອງ <emph>ໜ້າ</emph>.</ahelp>"

#. qBArg
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id991619223714871\n"
"help.text"
msgid "Selection"
msgstr "ສ່ວນທີ່ເລືອກ"

#. Abtm6
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3150244\n"
"help.text"
msgid "<ahelp hid=\".\">Prints only the selected area(s) or object(s) in the current document.</ahelp>"
msgstr "<ahelp hid=\".\">ພິມສະເພາະພື້ນທີ່ ຫຼື ວັດຖຸທີ່ເລືອກໃນເອກະສານປັດຈຸບັນ.</ahelp>"

#. T9g4h
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3146848\n"
"help.text"
msgid "<ahelp hid=\".\">To print a range of pages, use a format like <item type=\"input\">3-6</item>. To print single pages, use a format like <item type=\"input\">7;9;11</item>. You can print a combination of page ranges and single pages, by using a format like <item type=\"input\">3-6;8;10;12</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ເພື່ອພິມຊ່ວງຂອງໜ້າ, ໃຫ້ໃຊ້ຮູບແບບເຊັ່ນ <item type=\"input\">3-6</item>. ເພື່ອພິມແຕ່ລະໜ້າ, ໃຫ້ໃຊ້ຮູບແບບເຊັ່ນ <item type=\"input\">7;9;11</item>. ທ່ານສາມາດພິມແບບປະສົມທັງຊ່ວງໜ້າ ແລະ ໜ້າດຽວໄດ້ ໂດຍໃຊ້ຮູບແບບເຊັ່ນ <item type=\"input\">3-6;8;10;12</item>.</ahelp>"

#. cWoxT
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"hd_id461619223744867\n"
"help.text"
msgid "Include"
msgstr "ລວມມີ"

#. gaieA
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id271619217217310\n"
"help.text"
msgid "Select the subset of pages to print. Possible values are:"
msgstr "ເລືອກກຸ່ມຍ່ອຍຂອງໜ້າທີ່ຈະພິມ. ຄ່າທີ່ເປັນໄປໄດ້ຄື:"

#. JKSDi
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id911619217484736\n"
"help.text"
msgid "<emph>Even pages</emph>:"
msgstr "<emph>ໜ້າຄູ່</emph>:"

#. sXLHa
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3152945\n"
"help.text"
msgid "<ahelp hid=\".\">Prints only even numbered pages or slides.</ahelp>"
msgstr "<ahelp hid=\".\">ພິມສະເພາະໜ້າ ຫຼື ສະໄລ້ທີ່ມີໝາຍເລກຄູ່.</ahelp>"

#. RJUdz
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id41619217998664\n"
"help.text"
msgid "<emph>Odd pages</emph>:"
msgstr "<emph>ໜ້າຄີກ</emph>:"

#. xkay5
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id3152946\n"
"help.text"
msgid "<ahelp hid=\".\">Prints only odd numbered pages or slides.</ahelp>"
msgstr "<ahelp hid=\".\">ພິມສະເພາະໜ້າ ຫຼື ສະໄລ້ທີ່ມີໝາຍເລກຄີກ.</ahelp>"

#. oYaBB
#: 01130000.xhp
msgctxt ""
"01130000.xhp\n"
"par_id171619218364989\n"
