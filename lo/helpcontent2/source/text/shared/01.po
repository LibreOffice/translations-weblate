#. JS88G
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"tit\n"
"help.text"
msgid "Extension Update"
msgstr "ການອັບເດດສ່ວນເສີມ"

#. gFZiV
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"hd_id9688100\n"
"help.text"
msgid "Extension Update"
msgstr "ການອັບເດດສ່ວນເສີມ"

#. xW3EV
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id5084688\n"
"help.text"
msgid "<ahelp hid=\".\">Click the <emph>Check for Updates</emph> button in the <link href=\"text/shared/01/packagemanager.xhp\">Extensions dialog</link> to check for online updates for all installed extensions. To check for online updates for only the selected extension, right-click to open the context menu, then choose <emph>Update</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກປຸ່ມ <emph>ກວດສອບການອັບເດດ</emph> ໃນ <link href=\"text/shared/01/packagemanager.xhp\">ກ່ອງໂຕ້ຕອບສ່ວນເສີມ</link> ເພື່ອກວດສອບການອັບເດດອອນລາຍສຳລັບສ່ວນເສີມທີ່ຕິດຕັ້ງທັງໝົດ. ເພື່ອກວດສອບການອັບເດດອອນລາຍສະເພາະສ່ວນເສີມທີ່ເລືອກ, ໃຫ້ຄລິກຂວາເພື່ອເປີດເມນູລັດ, ແລ້ວເລືອກ <emph>ອັບເດດ</emph>.</ahelp>"

#. j6Gfk
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id6401257\n"
"help.text"
msgid "When you click the <item type=\"menuitem\">Check for Updates</item> button or choose the <item type=\"menuitem\">Update</item> command, the Extension Update dialog is displayed and the check for availability of updates starts immediately."
msgstr "ເມື່ອທ່ານຄລິກປຸ່ມ <item type=\"menuitem\">ກວດສອບການອັບເດດ</item> ຫຼື ເລືອກຄຳສັ່ງ <item type=\"menuitem\">ອັບເດດ</item>, ກ່ອງໂຕ້ຕອບການອັບເດດສ່ວນເສີມຈະປາກົດຂຶ້ນ ແລະ ການກວດສອບການອັບເດດຈະເລີ່ມຕົ້ນທັນທີ."

#. tzbHd
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id5841242\n"
"help.text"
msgid "<ahelp hid=\".\">While checking for updates, you see a progress indicator. Wait for some messages to show up in the dialog, or click Cancel to abort the update check.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນຂະນະທີ່ກວດສອບການອັບເດດ, ທ່ານຈະເຫັນແຖບສະແດງຄວາມຄືບໜ້າ. ລໍຖ້າໃຫ້ຂໍ້ຄວາມບາງຢ່າງປາກົດຂຶ້ນໃນກ່ອງໂຕ້ຕອບ, ຫຼື ຄລິກ ຍົກເລີກ ເພື່ອຍົກເລີກການກວດສອບການອັບເດດ.</ahelp>"

#. h6SwU
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id6794030\n"
"help.text"
msgid "If no updates are available, the message in the dialog tells you there are no updates. Close the dialog."
msgstr "ຖ້າບໍ່ມີການອັບເດດໃໝ່, ຂໍ້ຄວາມໃນກ່ອງໂຕ້ຕອບຈະບອກທ່ານວ່າບໍ່ມີການອັບເດດ. ໃຫ້ປິດກ່ອງໂຕ້ຕອບ."

#. yGuPA
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id7096774\n"
"help.text"
msgid "If updates are available, the updates can either be installed automatically, or you must respond with some action:"
msgstr "ຖ້າມີການອັບເດດ, ການອັບເດດສາມາດຕິດຕັ້ງໄດ້ໂດຍອັດຕະໂນມັດ ຫຼື ທ່ານຕ້ອງດຳເນີນການບາງຢ່າງ:"

#. Nahde
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id6420484\n"
"help.text"
msgid "The Extension Update dialog may contain entries which are not selectable and hence no automatic update can be performed."
msgstr "ກ່ອງໂຕ້ຕອບການອັບເດດສ່ວນເສີມອາດຈະປະກອບມີລາຍການທີ່ບໍ່ສາມາດເລືອກໄດ້ ແລະ ດັ່ງນັ້ນຈຶ່ງບໍ່ສາມາດດຳເນີນການອັບເດດອັດຕະໂນມັດໄດ້."

#. XAmPE
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id6986602\n"
"help.text"
msgid "Dependencies are not fulfilled (the update needs some more or newer files to be installed)."
msgstr "ບໍ່ຄົບຖ້ວນຕາມເງື່ອນໄຂທີ່ຕ້ອງການ (ການອັບເດດຕ້ອງການໄຟລ໌ເພີ່ມເຕີມ ຫຼື ໄຟລ໌ທີ່ໃໝ່ກວ່າເພື່ອຕິດຕັ້ງ)."

#. 9TexY
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id616779\n"
"help.text"
msgid "Insufficient user rights (the Extensions dialog was started from the menu, but shared extensions can only be modified when %PRODUCTNAME does not run, and only by a user with appropriate rights). See <link href=\"text/shared/01/packagemanager.xhp\">Extensions dialog</link> for details."
msgstr "ສິດທິຜູ້ໃຊ້ບໍ່ພຽງພໍ (ກ່ອງໂຕ້ຕອບສ່ວນເສີມຖືກເລີ່ມຈາກເມນູ, ແຕ່ສ່ວນເສີມທີ່ໃຊ້ຮ່ວມກັນສາມາດແກ້ໄຂໄດ້ເມື່ອ %PRODUCTNAME ບໍ່ໄດ້ເຮັດວຽກເທົ່ານັ້ນ, ແລະ ໂດຍຜູ້ໃຊ້ທີ່ມີສິດທິທີ່ເໝາະສົມ). ເບິ່ງ <link href=\"text/shared/01/packagemanager.xhp\">ກ່ອງໂຕ້ຕອບສ່ວນເສີມ</link> ສຳລັບລາຍລະອຽດ."

#. BfdJ5
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id791039\n"
"help.text"
msgid "A manual update is necessary."
msgstr "ຈຳເປັນຕ້ອງມີການອັບເດດດ້ວຍຕົນເອງ."

#. BoHt9
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id757469\n"
"help.text"
msgid "<ahelp hid=\".\">When you click the Install button the Download and Installation dialog is displayed.</ahelp>"
msgstr "<ahelp hid=\".\">ເມື່ອທ່ານຄລິກປຸ່ມ ຕິດຕັ້ງ, ກ່ອງໂຕ້ຕອບການດາວໂຫຼດ ແລະ ການຕິດຕັ້ງຈະປາກົດຂຶ້ນ.</ahelp>"

#. mTQC4
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id5189062\n"
"help.text"
msgid "All extensions which can be directly downloaded are downloaded now. The progress is shown in the Download and Installation dialog. If an extension cannot be downloaded, a message is displayed. The operation continues for the remaining extensions."
msgstr "ສ່ວນເສີມທັງໝົດທີ່ສາມາດດາວໂຫຼດໄດ້ໂດຍກົງຈະຖືກດາວໂຫຼດໃນເວລານີ້. ຄວາມຄືບໜ້າຈະຖືກສະແດງຢູ່ໃນກ່ອງໂຕ້ຕອບການດາວໂຫຼດ ແລະ ການຕິດຕັ້ງ. ຖ້າບໍ່ສາມາດດາວໂຫຼດສ່ວນເສີມໃດໜຶ່ງໄດ້, ຂໍ້ຄວາມຈະປາກົດຂຶ້ນ. ການດຳເນີນການຈະສືບຕໍ່ສຳລັບສ່ວນເສີມທີ່ເຫຼືອ."

#. rssTh
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id3949095\n"
"help.text"
msgid "Some extensions may be marked with the phrase “browser-based update”. These extensions cannot be downloaded by the Extensions dialog. A web browser must be opened to download the extension update from a particular web site. That site may require several more user interaction to download the extension. After downloading you must install the extension manually, for example by double-clicking the extension's icon in a file browser."
msgstr "ສ່ວນເສີມບາງຢ່າງອາດຈະຖືກໝາຍດ້ວຍຂໍ້ຄວາມ “ການອັບເດດຜ່ານບຣາວເຊີ”. ສ່ວນເສີມເຫຼົ່ານີ້ບໍ່ສາມາດດາວໂຫຼດໄດ້ຜ່ານກ່ອງໂຕ້ຕອບສ່ວນເສີມ. ຕ້ອງເປີດເວັບບຣາວເຊີເພື່ອດາວໂຫຼດການອັບເດດສ່ວນເສີມຈາກເວັບໄຊສະເພາະ. ເວັບໄຊນັ້ນອາດຈະຕ້ອງການການຕອບໂຕ້ຈາກຜູ້ໃຊ້ຕື່ມອີກເພື່ອດາວໂຫຼດສ່ວນເສີມ. ຫຼັງຈາກດາວໂຫຼດແລ້ວ ທ່ານຕ້ອງຕິດຕັ້ງສ່ວນເສີມດ້ວຍຕົນເອງ, ຕົວຢ່າງ: ໂດຍການດັບເບິນຄລິກທີ່ໄອຄອນສ່ວນເສີມໃນຕົວທ່ອງເວັບໄຟລ໌."

#. c6aLz
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id3729056\n"
"help.text"
msgid "For extensions marked as “browser-based update”, the Extensions dialog will open your web browser on the respective web site. This happens when you close the dialog, after downloading any other extension updates. If there are no extensions which can be directly downloaded then the web browser is started immediately."
msgstr "ສຳລັບສ່ວນເສີມທີ່ຖືກໝາຍວ່າ “ການອັບເດດຜ່ານບຣາວເຊີ”, ກ່ອງໂຕ້ຕອບສ່ວນເສີມຈະເປີດເວັບບຣາວເຊີຂອງທ່ານໄປຍັງເວັບໄຊທີ່ກ່ຽວຂ້ອງ. ສິ່ງນີ້ຈະເກີດຂຶ້ນເມື່ອທ່ານປິດກ່ອງໂຕ້ຕອບ, ຫຼັງຈາກດາວໂຫຼດການອັບເດດສ່ວນເສີມອື່ນໆແລ້ວ. ຖ້າບໍ່ມີສ່ວນເສີມໃດທີ່ສາມາດດາວໂຫຼດໄດ້ໂດຍກົງ, ເວັບບຣາວເຊີຈະເລີ່ມຕົ້ນທັນທີ."

#. yBbmW
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id6854457\n"
"help.text"
msgid "After the last extension has been downloaded, the installation begins. First all installed extensions for which an update could be downloaded successfully, are removed. Then the updated extensions are installed. If an error occurs, a message that the installation failed is displayed, but the operation proceeds."
msgstr "ຫຼັງຈາກທີ່ດາວໂຫຼດສ່ວນເສີມສຸດທ້າຍແລ້ວ, ການຕິດຕັ້ງຈະເລີ່ມຕົ້ນ. ທຳອິດ ສ່ວນເສີມທີ່ຕິດຕັ້ງໄວ້ທັງໝົດທີ່ມີການດາວໂຫຼດອັບເດດສຳເລັດແລ້ວຈະຖືກເອົາອອກ. ຈາກນັ້ນສ່ວນເສີມທີ່ອັບເດດໃໝ່ຈະຖືກຕິດຕັ້ງ. ຖ້າມີຂໍ້ຜິດພາດເກີດຂຶ້ນ, ຂໍ້ຄວາມແຈ້ງວ່າການຕິດຕັ້ງຫຼົ້ມເຫຼວຈະປາກົດຂຶ້ນ, ແຕ່ການດຳເນີນການຈະສືບຕໍ່ໄປ."

#. g5mDM
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id3372295\n"
"help.text"
msgid "If all updates have been processed the Download and Installation dialog shows that it has finished. You can abort the download and installation process by clicking the <emph>Abort Update</emph> button."
msgstr "ຖ້າການອັບເດດທັງໝົດໄດ້ຮັບການປະມວນຜົນແລ້ວ, ກ່ອງໂຕ້ຕອບການດາວໂຫຼດ ແລະ ການຕິດຕັ້ງຈະສະແດງວ່າສຳເລັດແລ້ວ. ທ່ານສາມາດຍົກເລີກຂະບວນການດາວໂຫຼດ ແລະ ການຕິດຕັ້ງໄດ້ໂດຍການຄລິກປຸ່ມ <emph>ຍົກເລີກການອັບເດດ</emph>."

#. hhXJc
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"hd_id5699942\n"
"help.text"
msgid "Show all Updates"
msgstr "ສະແດງການອັບເດດທັງໝົດ"

#. q8XGs
#: extensionupdate.xhp
msgctxt ""
"extensionupdate.xhp\n"
"par_id641193\n"
"help.text"
msgid "<ahelp hid=\".\">By default, only the downloadable extensions are shown in the dialog. Mark <emph>Show all Updates</emph> to see also other extensions and error messages.</ahelp>"
msgstr "<ahelp hid=\".\">ໂດຍຄ່າເລີ່ມຕົ້ນ, ຈະມີພຽງແຕ່ສ່ວນເສີມທີ່ສາມາດດາວໂຫຼດໄດ້ເທົ່ານັ້ນທີ່ຈະສະແດງໃນກ່ອງໂຕ້ຕອບ. ໃຫ້ໝາຍເອົາ <emph>ສະແດງການອັບເດດທັງໝົດ</emph> ເພື່ອເບິ່ງສ່ວນເສີມອື່ນໆ ແລະ ຂໍ້ຄວາມຂໍ້ຜິດພາດນຳ.</ahelp>"

