#. rBEjd
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3154381\n"
"help.text"
msgid "Graphic field"
msgstr "ຟີວຊຸດຄຳສັ່ງກຣາຟິກ"

#. Mb858
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3155504\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/textattrtabpage/CTL_POSITION\">Click where you want to place the anchor for the text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/textattrtabpage/CTL_POSITION\">ຄລິກບ່ອນທີ່ທ່ານຕ້ອງການວາງການຢຶດສຳລັບຂໍ້ຄວາມ.</ahelp>"

#. SAAJ5
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"hd_id3155323\n"
"help.text"
msgid "Full width"
msgstr "ເຕັມຄວາມກວ້າງ"

#. iDqz6
#: 05220000.xhp
msgctxt ""
"05220000.xhp\n"
"par_id3150244\n"
"help.text"
msgid "<ahelp hid=\".\">Anchors the text to the full width of the drawing object or text object.</ahelp>"
msgstr "<ahelp hid=\".\">ຢຶດຂໍ້ຄວາມຕາມຄວາມກວ້າງທັງໝົດຂອງວັດຖຸການແຕ້ມ ຫຼື ວັດຖຸຂໍ້ຄວາມ.</ahelp>"

#. 2aBQA
