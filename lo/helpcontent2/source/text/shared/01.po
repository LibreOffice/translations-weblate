msgctxt ""
"ref_pdf_export_security.xhp\n"
"hd_id2927335\n"
"help.text"
msgid "Set passwords"
msgstr "ຕັ້ງລະຫັດຜ່ານ"

#. 6ixp9
#: ref_pdf_export_security.xhp
msgctxt ""
"ref_pdf_export_security.xhp\n"
"par_id2107303\n"
"help.text"
msgid "<ahelp hid=\".\">Click to open a dialog where you enter the passwords.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກເພື່ອເປີດໜ້າຈໍສຳລັບປ້ອນລະຫັດຜ່ານ.</ahelp>"

#. fSFwW
#: ref_pdf_export_security.xhp
msgctxt ""
"ref_pdf_export_security.xhp\n"
"par_id41123951\n"
"help.text"
msgid "You can specify a password needed to view the PDF. You can enter an optional password that allows the person viewing the PDF to edit and/or print the document."
msgstr "ທ່ານສາມາດກຳນົດລະຫັດຜ່ານທີ່ຈຳເປັນໃນການເບິ່ງ PDF. ທ່ານຍັງສາມາດປ້ອນລະຫັດຜ່ານເສີມເພື່ອອະນຸຍາດໃຫ້ຜູ້ເບິ່ງ PDF ສາມາດແກ້ໄຂ ແລະ/ຫຼື ພິມເອກະສານໄດ້."

