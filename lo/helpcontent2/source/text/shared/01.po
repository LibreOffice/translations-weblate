msgctxt ""
"05210700.xhp\n"
"par_id3155892\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/transparencytabpage/MTR_TRANSPARENT\">Adjusts the transparency of the current fill color. Enter a number between 0% (opaque) and 100% (transparent).</ahelp>"
msgstr "<ahelp hid=\"cui/ui/transparencytabpage/MTR_TRANSPARENT\">ປັບຄວາມໂປ່ງໃສຂອງສີເຕີມປັດຈຸບັນ. ປ້ອນຕົວເລກລະຫວ່າງ 0% (ທຶບແສງ) ແລະ 100% (ໂປ່ງໃສ).</ahelp>"

