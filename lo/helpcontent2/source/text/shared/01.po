msgctxt ""
"05030500.xhp\n"
"hd_id3150767\n"
"help.text"
msgid "Bottom"
msgstr "ລຸ່ມ"

#. rBoFR
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3158410\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/bottommf\">Enter the distance that you want to have between the bottom border and the contents of the selection.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/bottommf\">ປ້ອນໄລຍະຫ່າງທີ່ທ່ານຕ້ອງການໃຫ້ມີລະຫວ່າງເສັ້ນຂອບທາງລຸ່ມ ແລະ ເນື້ອໃນຂອງສ່ວນທີ່ເລືອກ.</ahelp>"

#. Y66FH
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"hd_id3155429\n"
"help.text"
msgid "Synchronize"
msgstr "ເຮັດໃຫ້ກົງກັນ"

#. iYW2h
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3154299\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/sync\">Applies the same <emph>padding</emph> setting to all four borders when you enter a new distance.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/sync\">ນຳໃຊ້ການຕັ້ງຄ່າ <emph>ໄລຍະຫ່າງຈາກຂອບ</emph> ດຽວກັນກັບເສັ້ນຂອບທັງສີ່ດ້ານ ເມື່ອທ່ານປ້ອນໄລຍະຫ່າງໃໝ່.</ahelp>"

#. cxwBF
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"bm_id3155855\n"
"help.text"
msgid "<bookmark_value>shadows; borders</bookmark_value><bookmark_value>borders; shadows</bookmark_value><bookmark_value>margins; shadows</bookmark_value>"
msgstr "<bookmark_value>ເງົາ; ເສັ້ນຂອບ</bookmark_value><bookmark_value>ເສັ້ນຂອບ; ເງົາ</bookmark_value><bookmark_value>ຂອບໜ້າເຈ້ຍ; ເງົາ</bookmark_value>"

#. E7G4N
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"hd_id3155855\n"
"help.text"
msgid "Shadow style"
msgstr "ຮູບແບບເງົາ"

#. dKdZS
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3146975\n"
"help.text"
msgid "You can also apply a shadow effect to borders. For the best results, only apply this effect when all four borders are visible."
msgstr "ທ່ານຍັງສາມາດນຳໃຊ້ເອັບເຟັກເງົາໃຫ້ກັບເສັ້ນຂອບໄດ້. ເພື່ອຜົນລັບທີ່ດີທີ່ສຸດ, ຄວນນຳໃຊ້ເອັບເຟັກນີ້ເມື່ອເຫັນເສັ້ນຂອບທັງສີ່ດ້ານເທົ່ານັ້ນ."

#. tF3Am
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3157309\n"
"help.text"
msgid "Graphics or objects that are anchored to a frame in the document cannot exceed the size of the frame. If you apply a shadow to the borders of an object that fills an entire frame, the size of the object is reduced to display the shadows."
msgstr "ຮູບພາບ ຫຼື ວັດຖຸທີ່ຍຶດຕິດກັບກອບ (frame) ໃນເອກະສານ ຈະບໍ່ສາມາດມີຂະໜາດໃຫຍ່ກວ່າກອບໄດ້. ຖ້າທ່ານນຳໃຊ້ເງົາໃຫ້ກັບເສັ້ນຂອບຂອງວັດຖຸທີ່ເຕັມກອບທັງໝົດ, ຂະໜາດຂອງວັດຖຸຈະຖືກຫຼຸດລົງເພື່ອໃຫ້ສາມາດສະແດງເງົາໄດ້."

#. ngTH2
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"hd_id3153728\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. Thyf2
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3153364\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/shadows\">Click a shadow style for the selected borders.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/shadows\">ຄລິກຮູບແບບເງົາສຳລັບເສັ້ນຂອບທີ່ເລືອກ.</ahelp>"

#. 343Gk
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"hd_id3156444\n"
"help.text"
msgid "Distance"
msgstr "ໄລຍະຫ່າງ"

#. qZbsk
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3156060\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/distancemf\">Enter the width of the shadow.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/distancemf\">ປ້ອນຄວາມກວ້າງຂອງເງົາ.</ahelp>"

#. KhLvp
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"hd_id3155307\n"
"help.text"
msgid "Color"
msgstr "ສີ"

#. VQrRT
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_id3146147\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/shadowcolorlb\">Select a color for the shadow.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/shadowcolorlb\">ເລືອກສີສຳລັບເງົາ.</ahelp>"

#. CpzfE
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN10A2B\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. V548E
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN10A2F\n"
"help.text"
msgid "Specifies the properties for the current paragraph or the selected paragraphs."
msgstr "ລະບຸຄຸນສົມບັດສຳລັບຫຍໍ້ໜ້າປັດຈຸບັນ ຫຼື ຫຍໍ້ໜ້າທີ່ເລືອກ."

#. zBokE
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN10A3A\n"
"help.text"
msgid "Merge with next paragraph"
msgstr "ຮວມເຂົ້າກັບຫຍໍ້ໜ້າຖັດໄປ"

#. 7cHHA
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN10A3E\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/mergewithnext\">Merges the border style and the shadow style of the current paragraph with the next paragraph.</ahelp> These styles are only merged if the indent, border, and shadow styles of the next paragraph are the same as the current paragraph. This option is also available for Paragraph Styles."
msgstr "<ahelp hid=\"cui/ui/borderpage/mergewithnext\">ຮວມຮູບແບບເສັ້ນຂອບ ແລະ ຮູບແບບເງົາຂອງຫຍໍ້ໜ້າປັດຈຸບັນເຂົ້າກັບຫຍໍ້ໜ້າຖັດໄປ.</ahelp> ຮູບແບບເຫຼົ່ານີ້ຈະຖືກຮວມເຂົ້າກັນກໍຕໍ່ເມື່ອການຍໍ້ໜ້າ, ເສັ້ນຂອບ ແລະ ຮູບແບບເງົາຂອງຫຍໍ້ໜ້າຖັດໄປຄືກັນກັບຫຍໍ້ໜ້າປັດຈຸບັນ. ຕົວເລືອກນີ້ຍັງມີໃຫ້ໃຊ້ສຳລັບຮູບແບບຫຍໍ້ໜ້າ (Paragraph Styles) ນຳອີກ."

#. pXbGD
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN109BA\n"
"help.text"
msgid "Merge adjacent line styles"
msgstr "ຮວມຮູບແບບເສັ້ນທີ່ຢູ່ຕິດກັນ"

#. xBTmG
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN109BE\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/borderpage/mergeadjacent\">Merges two different border styles of adjacent cells in a Writer table into one border style. This property is valid for a whole table in a Writer document.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/borderpage/mergeadjacent\">ຮວມຮູບແບບເສັ້ນຂອບສອງແບບທີ່ແຕກຕ່າງກັນຂອງຫ້ອງທີ່ຕິດກັນໃນຕາຕະລາງ Writer ໃຫ້ເປັນຮູບແບບເສັ້ນຂອບດຽວ. ຄຸນສົມບັດນີ້ໃຊ້ໄດ້ກັບຕາຕະລາງທັງໝົດໃນເອກະສານ Writer.</ahelp>"

#. HjTFD
#: 05030500.xhp
msgctxt ""
"05030500.xhp\n"
"par_idN109C1\n"
"help.text"
msgid "The rules can be condensed to the statement that the stronger attribute wins. If, for example, one cell has a red border of 2 point width, and the adjacent cell has a blue border of 3 point width, then the common border between these two cells will be blue with 3 point width."
msgstr "ກົດເກນສາມາດສະຫຼຸບໄດ້ວ່າ ຄຸນລັກສະນະທີ່ແຂງແຮງກວ່າຈະຊະນະ. ຕົວຢ່າງ: ຖ້າຫ້ອງໜຶ່ງມີເສັ້ນຂອບສີແດງກວ້າງ 2 ພອຍ (point), ແລະ ຫ້ອງຕິດກັນມີເສັ້ນຂອບສີຟ້າກວ້າງ 3 ພອຍ, ເສັ້ນຂອບຮ່ວມລະຫວ່າງສອງຫ້ອງນີ້ຈະກາຍເປັນສີຟ້າທີ່ມີຄວາມກວ້າງ 3 ພອຍ."

#. iXWcd
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"tit\n"
"help.text"
msgid "Alignment"
msgstr "ການຈັດວາງ"

#. byrwg
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"bm_id3150008\n"
"help.text"
msgid "<bookmark_value>aligning; paragraphs</bookmark_value>        <bookmark_value>paragraphs; alignment</bookmark_value>        <bookmark_value>lines of text; alignment</bookmark_value>        <bookmark_value>left alignment of paragraphs</bookmark_value>        <bookmark_value>right alignment of paragraphs</bookmark_value>        <bookmark_value>centered text</bookmark_value>        <bookmark_value>justifying text</bookmark_value>"
msgstr "<bookmark_value>ການຈັດວາງ; ຫຍໍ້ໜ້າ</bookmark_value> <bookmark_value>ຫຍໍ້ໜ້າ; ການຈັດວາງ</bookmark_value> <bookmark_value>ແຖວຂໍ້ຄວາມ; ການຈັດວາງ</bookmark_value> <bookmark_value>ການຈັດວາງຫຍໍ້ໜ້າທາງຊ້າຍ</bookmark_value> <bookmark_value>ການຈັດວາງຫຍໍ້ໜ້າທາງຂວາ</bookmark_value> <bookmark_value>ຂໍ້ຄວາມຢູ່ເຄິ່ງກາງ</bookmark_value> <bookmark_value>ການຈັດຂໍ້ຄວາມໃຫ້ສະເໝີຂອບ</bookmark_value>"

#. 2Ayti
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3150008\n"
"help.text"
msgid "<variable id=\"alignment_h1\"><link href=\"text/shared/01/05030700.xhp\">Alignment</link></variable>"
msgstr "<variable id=\"alignment_h1\"><link href=\"text/shared/01/05030700.xhp\">ການຈັດວາງ</link></variable>"

#. EYRFX
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3147399\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paragalignpage/ParaAlignPage\">Sets the alignment of the paragraph relative to the margins of page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paragalignpage/ParaAlignPage\">ກຳນົດການຈັດວາງຂອງຫຍໍ້ໜ້າໃຫ້ສອດຄ່ອງກັບຂອບໜ້າເຈ້ຍ.</ahelp>"

#. DQeLQ
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3143268\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. zEFM8
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3147008\n"
"help.text"
msgid "Set the alignment options for the current paragraph."
msgstr "ກຳນົດຕົວເລືອກການຈັດວາງສຳລັບຫຍໍ້ໜ້າປັດຈຸບັນ."

#. uV6ED
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3153681\n"
"help.text"
msgid "<variable id=\"align_left_hd\">Start</variable>"
msgstr "<variable id=\"align_left_hd\">ເລີ່ມຕົ້ນ</variable>"

#. rw5C5
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3153031\n"
"help.text"
msgid "<variable id=\"linkstext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_LEFTALIGN\">Aligns the paragraph to the beginning of the line in the reading direction. For top-to-bottom text, this means alignment to the top.</ahelp></variable>"
msgstr "<variable id=\"linkstext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_LEFTALIGN\">ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຈຸດເລີ່ມຕົ້ນຂອງແຖວຕາມທິດທາງການອ່ານ. ສຳລັບຂໍ້ຄວາມແນວຕັ້ງ (ເທິງລົງລຸ່ມ), ນີ້ໝາຍເຖິງການຈັດວາງໃຫ້ກົງກັບທາງເທິງ.</ahelp></variable>"

#. xEpUf
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id701764323726394\n"
"help.text"
msgid "Force Left"
msgstr "ບັງຄັບໃຫ້ຢູ່ຊ້າຍ"

#. SAc6X
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id71764323744449\n"
"help.text"
msgid "Aligns the paragraph to the left page margin."
msgstr "ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຂອບໜ້າເຈ້ຍເບື້ອງຊ້າຍ."

#. 4GeRt
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id461764323731912\n"
"help.text"
msgid "Force Left/Top"
msgstr "ບັງຄັບໃຫ້ຢູ່ຊ້າຍ/ເທິງ"

#. X98gZ
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id411764323739649\n"
"help.text"
msgid "For Asian languages, aligns the paragraph to the top left page margin."
msgstr "ສຳລັບພາສາອາຊີ, ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຂອບໜ້າເຈ້ຍດ້ານເທິງຊ້າຍ."

#. XzFMf
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3154142\n"
"help.text"
msgid "<variable id=\"align_right_hd\">End</variable>"
msgstr "<variable id=\"align_right_hd\">ສິ້ນສຸດ</variable>"

#. QiDem
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3156326\n"
"help.text"
msgid "<variable id=\"rechtstext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_RIGHTALIGN\">Aligns the paragraph to the end of the line in the reading direction. For top-to-bottom text, this means alignment to the bottom.</ahelp></variable>"
msgstr "<variable id=\"rechtstext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_RIGHTALIGN\">ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຈຸດສິ້ນສຸດຂອງແຖວຕາມທິດທາງການອ່ານ. ສຳລັບຂໍ້ຄວາມແນວຕັ້ງ (ເທິງລົງລຸ່ມ), ນີ້ໝາຍເຖິງການຈັດວາງໃຫ້ກົງກັບທາງລຸ່ມ.</ahelp></variable>"

#. GSHgk
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id531764323752720\n"
"help.text"
msgid "Force Right"
msgstr "ບັງຄັບໃຫ້ຢູ່ຂວາ"

#. oGpuJ
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id481764323767776\n"
"help.text"
msgid "Aligns the paragraph to the right page margin."
msgstr "ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຂອບໜ້າເຈ້ຍເບື້ອງຂວາ."

#. pEEkt
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id751764323758432\n"
"help.text"
msgid "Force Right/Bottom"
msgstr "ບັງຄັບໃຫ້ຢູ່ຂວາ/ລຸ່ມ"

#. PJSCK
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id461764323772457\n"
"help.text"
msgid "For Asian languages, aligns the paragraph to the bottom right page margin."
msgstr "ສຳລັບພາສາອາຊີ, ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບຂອບໜ້າເຈ້ຍດ້ານລຸ່ມຂວາ."

#. sucZn
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3148642\n"
"help.text"
msgid "<variable id=\"centered_hd\">Centered</variable>"
msgstr "<variable id=\"centered_hd\">ຢູ່ເຄິ່ງກາງ</variable>"

#. DnoAS
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3153257\n"
"help.text"
msgid "<variable id=\"zentrierttext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_CENTERALIGN\">Centers the contents of the paragraph on the page.</ahelp></variable>"
msgstr "<variable id=\"zentrierttext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_CENTERALIGN\">ຈັດເນື້ອໃນຂອງຫຍໍ້ໜ້າໃຫ້ຢູ່ເຄິ່ງກາງຂອງໜ້າເຈ້ຍ.</ahelp></variable>"

#. dzJQB
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3149415\n"
"help.text"
msgid "<variable id=\"justify_hd\">Justify</variable>"
msgstr "<variable id=\"justify_hd\">ສະເໝີຂອບ</variable>"

#. X9hpY
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3152474\n"
"help.text"
msgid "<variable id=\"blocksatztext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_JUSTIFYALIGN\">Aligns the paragraph to the left and to the right page margins.</ahelp></variable>"
msgstr "<variable id=\"blocksatztext\"><ahelp hid=\"cui/ui/paragalignpage/radioBTN_JUSTIFYALIGN\">ຈັດຫຍໍ້ໜ້າໃຫ້ສະເໝີທັງຂອບໜ້າເຈ້ຍເບື້ອງຊ້າຍ ແລະ ເບື້ອງຂວາ.</ahelp></variable>"

#. 2qpeH
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3145068\n"
"help.text"
msgid "Last Line"
msgstr "ແຖວສຸດທ້າຍ"

#. YEXUS
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3154280\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paragalignpage/comboLB_LASTLINE\">Specify the alignment for the last line in the paragraph.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paragalignpage/comboLB_LASTLINE\">ລະບຸການຈັດວາງສຳລັບແຖວສຸດທ້າຍໃນຫຍໍ້ໜ້າ.</ahelp>"

#. cpYEP
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3154936\n"
"help.text"
msgid "Expand single word"
msgstr "ຂະຫຍາຍຄຳດ່ຽວ"

#. ni4eq
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3154224\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paragalignpage/checkCB_EXPAND\">If the last line of a justified paragraph consists of one word, the word is stretched to the width of the paragraph.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paragalignpage/checkCB_EXPAND\">ຖ້າແຖວສຸດທ້າຍຂອງຫຍໍ້ໜ້າທີ່ຈັດແບບສະເໝີຂອບມີພຽງແຕ່ຄຳດຽວ, ຄຳນັ້ນຈະຖືກຢືດອອກໃຫ້ເຕັມຄວາມກວ້າງຂອງຫຍໍ້ໜ້າ.</ahelp>"

#. zLR4E
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3150495\n"
"help.text"
msgid "Snap to text grid (if active)"
msgstr "ຈັດໃຫ້ກົງກັບເສັ້ນຕາຕະລາງຂໍ້ຄວາມ (ຖ້າເປີດໃຊ້)"

#. RDF2f
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3154331\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paragalignpage/checkCB_SNAP\">Aligns the paragraph to a text grid. To activate the text grid, choose <link href=\"text/swriter/01/05040800.xhp\"><emph>Format - Page Style - Text Grid</emph></link>.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paragalignpage/checkCB_SNAP\">ຈັດຫຍໍ້ໜ້າໃຫ້ກົງກັບເສັ້ນຕາຕະລາງຂໍ້ຄວາມ. ເພື່ອເປີດໃຊ້ເສັ້ນຕາຕະລາງຂໍ້ຄວາມ, ໃຫ້ເລືອກ <link href=\"text/swriter/01/05040800.xhp\"><emph>ຮູບແບບ - ຮູບແບບໜ້າ - ເສັ້ນຕາຕະລາງຂໍ້ຄວາມ</emph></link>.</ahelp>"

#. 8fVGt
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3148672\n"
"help.text"
msgid "Text-to-text"
msgstr "ຂໍ້ຄວາມຫາຂໍ້ຄວາມ"

#. CvZ85
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3154451\n"
"help.text"
msgid "Alignment"
msgstr "ການຈັດວາງ"

#. rARSM
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3149807\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paragalignpage/comboLB_VERTALIGN\">Select an alignment option for oversized or undersized characters in the paragraph relative to the rest of the text in the paragraph.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paragalignpage/comboLB_VERTALIGN\">ເລືອກຕົວເລືອກການຈັດວາງສຳລັບຕົວອັກສອນທີ່ມີຂະໜາດໃຫຍ່ເກີນໄປ ຫຼື ນ້ອຍເກີນໄປໃນຫຍໍ້ໜ້າ ເມື່ອທຽບກັບຂໍ້ຄວາມສ່ວນທີ່ເຫຼືອໃນຫຍໍ້ໜ້ານັ້ນ.</ahelp>"

#. xFaFm
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3144434\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. YqaeT
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id3154631\n"
"help.text"
msgid "Text direction"
msgstr "ທິດທາງຂໍ້ຄວາມ"

#. RdNS9
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id3157960\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/columnpage/textdirectionlb\">Specify the text direction for a paragraph that uses complex text layout (CTL). This feature is only available if complex text layout support is enabled.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/columnpage/textdirectionlb\">ລະບຸທິດທາງຂໍ້ຄວາມສຳລັບຫຍໍ້ໜ້າທີ່ໃຊ້ການຈັດວາງຂໍ້ຄວາມແບບຊັບຊ້ອນ (CTL). ຄຸນສົມບັດນີ້ມີໃຫ້ໃຊ້ກໍຕໍ່ເມື່ອເປີດການຮອງຮັບການຈັດວາງຂໍ້ຄວາມແບບຊັບຊ້ອນເທົ່ານັ້ນ.</ahelp>"

#. zDoAn
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id391764330735254\n"
"help.text"
msgid "Automatically set direction"
msgstr "ຕັ້ງທິດທາງໂດຍອັດຕະໂນມັດ"

#. C3LuK
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id121764331614810\n"
"help.text"
msgid "Specifies to adjust the writing direction of the paragraph based on its content whenever the content is edited."
msgstr "ລະບຸໃຫ້ປັບທິດທາງການຂຽນຂອງຫຍໍ້ໜ້າໂດຍອີງຕາມເນື້ອໃນ ທຸກຄັ້ງທີ່ມີການແກ້ໄຂເນື້ອໃນນັ້ນ."

#. mCjPV
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id51746473089992\n"
"help.text"
msgid "Justification"
msgstr "ການຈັດໃຫ້ສະເໝີຂອບ"

#. ndZBr
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id131746474919005\n"
"help.text"
msgid "To prevent rivers - uneven white space that can appear between words in a justified paragraph - as well as excessive hyphenation, adjust the desired word spacing of a justified paragraph in relation to the width of the space character."
msgstr "ເພື່ອປ້ອງກັນ \"rivers\" - ຄືຊ່ອງຫວ່າງທີ່ບໍ່ສະເໝີກັນລະຫວ່າງຄຳສັບໃນຫຍໍ້ໜ້າທີ່ຈັດແບບສະເໝີຂອບ - ລວມທັງການຕັດຄຳດ້ວຍຂີດຕໍ່ທີ່ຫຼາຍເກີນໄປ, ໃຫ້ປັບໄລຍະຫ່າງລະຫວ່າງຄຳທີ່ຕ້ອງການຂອງຫຍໍ້ໜ້າທີ່ຈັດແບບສະເໝີຂອບ ໃຫ້ສອດຄ່ອງກັບຄວາມກວ້າງຂອງຕົວອັກສອນຊ່ອງຫວ່າງ."

#. 7EFGs
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"hd_id311746473240012\n"
"help.text"
msgid "Word spacing"
msgstr "ໄລຍະຫ່າງລະຫວ່າງຄຳ"

#. EUEFZ
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id171746473174986\n"
"help.text"
msgid "<emph>Minimum</emph>: adjusts the minimum word spacing. Enter a number between 0% (no word spacing) and 250% (two and a half times the width of the space character)."
msgstr "<emph>ຕໍ່າສຸດ</emph>: ປັບໄລຍະຫ່າງລະຫວ່າງຄຳຕໍ່າສຸດ. ປ້ອນຕົວເລກລະຫວ່າງ 0% (ບໍ່ມີໄລຍະຫ່າງລະຫວ່າງຄຳ) ຫາ 250% (ສອງເທົ່າເຄິ່ງຂອງຄວາມກວ້າງຂອງຕົວອັກສອນຊ່ອງຫວ່າງ)."

#. VH2a4
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id581746473181108\n"
"help.text"
msgid "<emph>Desired</emph>: adjusts the desired word spacing. Enter a number between 0% and 250%."
msgstr "<emph>ທີ່ຕ້ອງການ</emph>: ປັບໄລຍະຫ່າງລະຫວ່າງຄຳທີ່ຕ້ອງການ. ປ້ອນຕົວເລກລະຫວ່າງ 0% ຫາ 250%."

#. nnktE
#: 05030700.xhp
msgctxt ""
"05030700.xhp\n"
"par_id11746473185963\n"
"help.text"
msgid "<emph>Maximum</emph>: adjusts the maximum word spacing. Enter a number between 0% and 250%"
msgstr "<emph>ສູງສຸດ</emph>: ປັບໄລຍະຫ່າງລະຫວ່າງຄຳສູງສຸດ. ປ້ອນຕົວເລກລະຫວ່າງ 0% ຫາ 250%."

#. Re6Eu
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"tit\n"
"help.text"
msgid "Crop Image"
msgstr "ຕັດຮູບພາບ"

#. McF76
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"bm_id3148585\n"
"help.text"
msgid "<bookmark_value>cropping pictures</bookmark_value><bookmark_value>pictures; cropping and zooming</bookmark_value><bookmark_value>zooming; pictures</bookmark_value><bookmark_value>scaling;pictures</bookmark_value><bookmark_value>sizes; pictures</bookmark_value><bookmark_value>original size;restoring after cropping</bookmark_value>"
msgstr "<bookmark_value>ການຕັດຮູບພາບ</bookmark_value><bookmark_value>ຮູບພາບ; ການຕັດ ແລະ ການຊູມ</bookmark_value><bookmark_value>ການຊູມ; ຮູບພາບ</bookmark_value><bookmark_value>ການປັບຂະໜາດ;ຮູບພາບ</bookmark_value><bookmark_value>ຂະໜາດ; ຮູບພາບ</bookmark_value><bookmark_value>ຂະໜາດເດີມ;ການຄືນຄ່າມາຫຼັງຈາກການຕັດ</bookmark_value>"

#. MCZ5C
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"hd_id3154044\n"
"help.text"
msgid "<link href=\"text/shared/01/05030800.xhp\">Crop</link>"
msgstr "<link href=\"text/shared/01/05030800.xhp\">ຕັດຮູບ</link>"

#. QFkBW
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"par_id3150603\n"
"help.text"
msgid "<ahelp hid=\".\">Trims or scales the selected graphic. You can also restore the graphic to its original size.</ahelp>"
msgstr "<ahelp hid=\".\">ຕັດ ຫຼື ປັບຂະໜາດຮູບພາບທີ່ເລືອກ. ທ່ານຍັງສາມາດຄືນຄ່າຮູບພາບໃຫ້ເປັນຂະໜາດເດີມໄດ້.</ahelp>"

#. zz7rt
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"hd_id3148585\n"
"help.text"
msgid "Crop"
msgstr "ຕັດຮູບ"

#. JARd6
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"par_id3152372\n"
"help.text"
msgid "Use this area to trim or scale the selected graphic, or to add white space around the graphic."
msgstr "ໃຊ້ບໍລິເວນນີ້ເພື່ອຕັດ ຫຼື ປັບຂະໜາດຮູບພາບທີ່ເລືອກ, ຫຼື ເພື່ອເພີ່ມຊ່ອງຫວ່າງອ້ອມຮອບຮູບພາບ."

#. WDdBz
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"hd_id3145669\n"
"help.text"
msgid "Keep scale"
msgstr "ຮັກສາອັດຕາສ່ວນ"

#. nN7qn
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"par_id3149346\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/croppage/keepscale\">Maintains the original scale of the graphic when you crop, so that only the size of the graphic changes.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/croppage/keepscale\">ຮັກສາອັດຕາສ່ວນເດີມຂອງຮູບພາບໃນເວລາທີ່ທ່ານຕັດຮູບ, ເພື່ອໃຫ້ມີພຽງແຕ່ຂະໜາດຂອງຮູບພາບເທົ່ານັ້ນທີ່ປ່ຽນແປງ.</ahelp>"

#. 3BaLG
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"hd_id3156426\n"
"help.text"
msgid "Keep image size"
msgstr "ຮັກສາຂະໜາດຮູບພາບ"

#. s52PC
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"par_id3155892\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/croppage/keepsize\">Maintains the original size of the graphic when you crop, so that only the scale of the graphic changes. To reduce the scale of the graphic, select this option and enter negative values in the cropping boxes. To increase the scale of the graphic, enter positive values in the cropping boxes.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/croppage/keepsize\">ຮັກສາຂະໜາດເດີມຂອງຮູບພາບໃນເວລາທີ່ທ່ານຕັດຮູບ, ເພື່ອໃຫ້ມີພຽງແຕ່ອັດຕາສ່ວນຂອງຮູບພາບເທົ່ານັ້ນທີ່ປ່ຽນແປງ. ເພື່ອຫຼຸດອັດຕາສ່ວນຂອງຮູບພາບ, ໃຫ້ເລືອກຕົວເລືອກນີ້ ແລະ ປ້ອນຄ່າລົບໃນຊ່ອງຕັດຮູບ. ເພື່ອເພີ່ມອັດຕາສ່ວນຂອງຮູບພາບ, ໃຫ້ປ້ອນຄ່າບວກໃນຊ່ອງຕັດຮູບ.</ahelp>"

#. DVwFC
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"hd_id3153683\n"
"help.text"
msgid "Left"
msgstr "ຊ້າຍ"

#. 2xdux
#: 05030800.xhp
msgctxt ""
"05030800.xhp\n"
"par_id3145313\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/croppage/left\">If the <emph>Keep Scale</emph> option is selected, enter a positive amount to trim the left edge of the graphic, or a negative amount to add white space to the left of the graphic. If the <emph>Keep image size</emph> option is selected, enter a positive amount to increase the horizontal scale of the graphic, or a negative amount to decrease the horizontal scale of the graphic.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/croppage/left\">ຖ້າເລືອກຕົວເລືອກ <emph>ຮັກສາອັດຕາສ່ວນ</emph>, ໃຫ້ປ້ອນຄ່າບວກເພື່ອຕັດຂອບເບື້ອງຊ້າຍຂອງຮູບພາບ, ຫຼື ປ້ອນຄ່າລົບເພື່ອເພີ່ມຊ່ອງຫວ່າງທາງເບື້ອງຊ້າຍຂອງຮູບພາບ. ຖ້າເລືອກຕົວເລືອກ <emph>ຮັກສາຂະໜາດຮູບພາບ</emph>, ໃຫ້ປ້ອນຄ່າບວກເພື່ອເພີ່ມອັດຕາສ່ວນແນວນອນຂອງຮູບພາບ, ຫຼື ປ້ອນຄ່າລົບເພື່ອຫຼຸດອັດຕາສ່ວນແນວນອນຂອງຮູບພາບ.</ahelp>"

