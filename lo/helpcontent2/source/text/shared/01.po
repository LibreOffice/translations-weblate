#: 05230100.xhp
msgctxt ""
"05230100.xhp\n"
"par_id3149811\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/possizetabpage/MTR_FLD_WIDTH\">Enter a width for the selected object.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/possizetabpage/MTR_FLD_WIDTH\">ປ້ອນຄວາມກວ້າງສຳລັບວັດຖຸທີ່ເລືອກ.</ahelp>"

#. nz7Tu
#: 05230100.xhp
msgctxt ""
"05230100.xhp\n"
"hd_id3150443\n"
"help.text"
msgid "Height"
msgstr "ຄວາມສູງ"

