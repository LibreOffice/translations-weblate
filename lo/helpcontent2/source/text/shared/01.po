"05030100.xhp\n"
"par_id3163823\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/paraindentspacing/checkCB_CONTEXTUALSPACING\">Makes any space specified before or after this paragraph not be applied when the preceding and following paragraphs are of the same paragraph style.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/paraindentspacing/checkCB_CONTEXTUALSPACING\">ເຮັດໃຫ້ໄລຍະຫ່າງທີ່ກຳນົດໄວ້ກ່ອນ ຫຼື ຫຼັງຫຍໍ້ໜ້ານີ້ບໍ່ຖືກນຳໃຊ້ ເມື່ອຫຍໍ້ໜ້າກ່ອນໜ້າ ແລະ ຫຍໍ້ໜ້າຖັດໄປມີຮູບແບບຫຍໍ້ໜ້າດຽວກັນ.</ahelp>"

