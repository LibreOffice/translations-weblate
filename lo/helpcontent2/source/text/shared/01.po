msgctxt ""
"02110000.xhp\n"
"par_id3159198\n"
"help.text"
msgid "<ahelp hid=\"HID_GLBLTREE_INS_FILE\">Inserts one or more existing files into the master document.</ahelp>"
msgstr "<ahelp hid=\"HID_GLBLTREE_INS_FILE\">ແຊກໄຟລ໌ທີ່ມີຢູ່ແລ້ວໜຶ່ງໄຟລ໌ ຫຼື ຫຼາຍກວ່ານັ້ນລົງໃນເອກະສານຫຼັກ.</ahelp>"

#. dDuad
