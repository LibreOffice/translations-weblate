msgctxt ""
"05230100.xhp\n"
"par_id31507749753\n"
"help.text"
msgid "Specify the size of the selected object."
msgstr "ລະບຸຂະໜາດຂອງວັດຖຸທີ່ເລືອກ."

#. oaVxX
#: 05230100.xhp
msgctxt ""
"05230100.xhp\n"
"par_id3150774\n"
"help.text"
msgid "Resize the selected object to the chosen width and height relative to the selected base point."
msgstr "ປ່ຽນຂະໜາດວັດຖຸທີ່ເລືອກຕາມຄວາມກວ້າງ ແລະ ຄວາມສູງທີ່ເລືອກໂດຍທຽບກັບຈຸດພື້ນຖານທີ່ເລືອກ."

#. gfmHb
#: 05230100.xhp
msgctxt ""
"05230100.xhp\n"
"hd_id3143267\n"
"help.text"
msgid "Width"
msgstr "ຄວາມກວ້າງ"

