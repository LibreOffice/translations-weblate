#. mvaxo
#: 05290200.xhp
msgctxt ""
"05290200.xhp\n"
"par_id3156116\n"
"help.text"
msgid "<variable id=\"aufhebentext\"><ahelp hid=\".uno:FormatUngroup\" visibility=\"visible\">Breaks apart the selected group into individual objects.</ahelp></variable>"
msgstr "<variable id=\"aufhebentext\"><ahelp hid=\".uno:FormatUngroup\" visibility=\"visible\">ແຍກກຸ່ມທີ່ເລືອກໄວ້ອອກເປັນວັດຖຸແຕ່ລະອັນ.</ahelp></variable>"

#. MZp6H
#: 05290200.xhp
msgctxt ""
"05290200.xhp\n"
"par_id3146067\n"
"help.text"
msgid "To break apart the nested groups within a group, you must repeat this command on each subgroup."
msgstr "ເພື່ອແຍກກຸ່ມທີ່ຊ້ອນກັນຢູ່, ທ່ານຕ້ອງເຮັດຄຳສັ່ງນີ້ຊ້ຳໆ ກັບແຕ່ລະກຸ່ມຍ່ອຍ."

