"help.text"
msgid "This command is only available for drawing objects that can contain text, for example for rectangles, but not for lines."
msgstr "ຄຳສັ່ງນີ້ໃຊ້ໄດ້ສະເພາະກັບວັດຖຸແຕ້ມທີ່ສາມາດບັນຈຸຂໍ້ຄວາມໄດ້ ເຊັ່ນ ຮູບສີ່ແຈສາກ, ແຕ່ບໍ່ສາມາດໃຊ້ກັບເສັ້ນໄດ້."

#. dFrio
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"tit\n"
"help.text"
msgid "Spelling"
msgstr "ການກວດຕົວສະກົດ"

#. hBBXG
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"bm_id3149047\n"
"help.text"
msgid "<bookmark_value>dictionaries; spellcheck</bookmark_value><bookmark_value>spellcheck; dialog</bookmark_value><bookmark_value>dictionaries; spelling</bookmark_value><bookmark_value>spelling; dialog</bookmark_value><bookmark_value>languages; spellcheck</bookmark_value><bookmark_value>languages; spelling</bookmark_value>"
msgstr "<bookmark_value>ວັດຈະນານຸກົມ; ກວດຕົວສະກົດ</bookmark_value><bookmark_value>ກວດຕົວສະກົດ; ກ່ອງໂຕ້ຕອບ</bookmark_value><bookmark_value>ວັດຈະນານຸກົມ; ການສະກົດຄຳ</bookmark_value><bookmark_value>ການສະກົດຄຳ; ກ່ອງໂຕ້ຕອບ</bookmark_value><bookmark_value>ພາສາ; ກວດຕົວສະກົດ</bookmark_value><bookmark_value>ພາສາ; ການສະກົດຄຳ</bookmark_value>"

#. Fqb6C
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3153882\n"
"help.text"
msgid "<link href=\"text/shared/01/06010000.xhp\">Spelling</link>"
msgstr "<link href=\"text/shared/01/06010000.xhp\">ການກວດຕົວສະກົດ</link>"

#. WLdXq
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3154682\n"
"help.text"
msgid "<variable id=\"recht\"><ahelp hid=\".\">Checks the document or the current selection for spelling errors. If a grammar checking extension is installed, the dialog also checks for grammar errors.</ahelp></variable>"
msgstr "<variable id=\"recht\"><ahelp hid=\".\">ກວດສອບເອກະສານ ຫຼື ສ່ວນທີ່ເລືອກເພື່ອຫາຂໍ້ຜິດພາດໃນການສະກົດຄຳ. ຫາກມີການຕິດຕັ້ງສ່ວນຂະຫຍາຍກວດສອບໄວຍາກອນ, ກ່ອງໂຕ້ຕອບຈະກວດສອບຂໍ້ຜິດພາດທາງໄວຍາກອນນຳດ້ວຍ.</ahelp></variable>"

#. y8GCg
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_idN1064B\n"
"help.text"
msgid "The spellcheck starts at the current cursor position and advances to the end of the document or selection. You can then choose to continue the spellcheck from the beginning of the document."
msgstr "ການກວດຕົວສະກົດຈະເລີ່ມຈາກຕຳແໜ່ງເຄີເຊີປັດຈຸບັນໄປຈົນຮອດທ້າຍເອກະສານ ຫຼື ສ່ວນທີ່ເລືອກ. ທ່ານສາມາດເລືອກກວດຕົວສະກົດຕໍ່ໄດ້ໂດຍເລີ່ມຈາກຕົ້ນເອກະສານ."

#. Kf8uj
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3166445\n"
"help.text"
msgid "Spelling looks for misspelled words and gives you the option of adding an unknown word to a user dictionary. When the first misspelled word is found, the <emph>Spelling</emph> dialog opens."
msgstr "ລະບົບຈະກວດຫາຄຳທີ່ສະກົດຜິດ ແລະ ໃຫ້ທາງເລືອກໃນການເພີ່ມຄຳທີ່ບໍ່ຮູ້ຈັກເຂົ້າໃນວັດຈະນານຸກົມສ່ວນຕົວ. ເມື່ອພົບຄຳທີ່ສະກົດຜິດຄຳທຳອິດ, ກ່ອງໂຕ້ຕອບ <emph>ການກວດຕົວສະກົດ</emph> ຈະເປີດຂຶ້ນ."

#. oYUuw
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id1022200801300654\n"
"help.text"
msgid "Spelling errors are underlined in red, grammar errors in blue."
msgstr "ຂໍ້ຜິດພາດໃນການສະກົດຄຳຈະຖືກຂີດກ້ອງດ້ວຍສີແດງ, ສ່ວນຂໍ້ຜິດພາດທາງໄວຍາກອນຈະເປັນສີຟ້າ."

#. bLDyq
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3145087\n"
"help.text"
msgid "Text Language"
msgstr "ພາສາຂອງຂໍ້ຄວາມ"

#. NCqyn
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3144422\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/languagelb\">Specifies the language to use to check the spelling.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/languagelb\">ລະບຸພາສາທີ່ຈະໃຊ້ໃນການກວດຕົວສະກົດ.</ahelp>"

#. mVFSy
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3149511\n"
"help.text"
msgid "Not in Dictionary"
msgstr "ບໍ່ມີໃນວັດຈະນານຸກົມ"

#. CENQq
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3149798\n"
"help.text"
msgid "<ahelp hid=\".\">Displays the sentence with the misspelled word highlighted. Edit the word or the sentence, or click one of the suggestions in the text box below.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງປະໂຫຍກພ້ອມເນັ້ນຄຳທີ່ສະກົດຜິດ. ທ່ານສາມາດແກ້ໄຂຄຳສັບ ຫຼື ປະໂຫຍກ, ຫຼື ຄລິກເລືອກຄຳແນະນຳໃນກ່ອງຂໍ້ຄວາມລຸ່ມນີ້.</ahelp>"

#. BFSCj
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3155994\n"
"help.text"
msgid "Ignore Once"
msgstr "ຂ້າມຄັ້ງນີ້"

#. GaNW7
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3148920\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/ignore\">Skips the unknown word and continues with the spellcheck.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/ignore\">ຂ້າມຄຳທີ່ບໍ່ຮູ້ຈັກ ແລະ ດຳເນີນການກວດຕົວສະກົດຕໍ່.</ahelp>"

#. GmjpL
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_idN107CB\n"
"help.text"
msgid "This label of this button changes to <emph>Resume</emph> if you leave the Spelling dialog open when you return to your document. To continue the spellcheck from the current position of the cursor, click <emph>Resume</emph>."
msgstr "ປ້າຍຊື່ຂອງປຸ່ມນີ້ຈະປ່ຽນເປັນ <emph>ດຳເນີນການຕໍ່ (Resume)</emph> ຫາກທ່ານເປີດກ່ອງໂຕ້ຕອບການກວດຕົວສະກົດຄ້າງໄວ້ໃນຂະນະທີ່ກັບໄປຫາເອກະສານ. ເພື່ອກວດຕົວສະກົດຕໍ່ຈາກຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ, ໃຫ້ຄລິກ <emph>ດຳເນີນການຕໍ່</emph>."

#. RZhbH
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3150740\n"
"help.text"
msgid "Ignore All"
msgstr "ຂ້າມທັງໝົດ"

#. hECo2
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3145318\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/ignoreall\">Skips all occurrences of the unknown word until the end of the current %PRODUCTNAME session and continues with the spellcheck.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/ignoreall\">ຂ້າມຄຳທີ່ບໍ່ຮູ້ຈັກນີ້ໃນທຸກໆບ່ອນ ຈົນກວ່າຈະສິ້ນສຸດການໃຊ້ງານ %PRODUCTNAME ໃນຄັ້ງນີ້ ແລະ ດຳເນີນການກວດຕົວສະກົດຕໍ່.</ahelp>"

#. xyCXY
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id1024200804091149\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">While performing a grammar check, click Ignore Rule to ignore the rule that is currently flagged as a grammar error.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ໃນຂະນະທີ່ກວດສອບໄວຍາກອນ, ໃຫ້ຄລິກ ຂ້າມກົດເກນ ເພື່ອຂ້າມກົດເກນທີ່ຖືກລະບຸວ່າເປັນຂໍ້ຜິດພາດທາງໄວຍາກອນໃນຕອນນີ້.</ahelp>"

#. AF8pP
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id781611832449329\n"
"help.text"
msgid "Ignore Rule"
msgstr "ຂ້າມກົດເກນ"

#. 52TyF
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id941611832460742\n"
"help.text"
msgid "Appears when checking grammar. Click to ignore the suggested grammatical change."
msgstr "ຈະປະກົດຂຶ້ນເມື່ອກວດສອບໄວຍາກອນ. ຄລິກເພື່ອຂ້າມການປ່ຽນແປງທາງໄວຍາກອນທີ່ລະບົບແນະນຳ."

#. 2ADwc
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3153353\n"
"help.text"
msgid "Add to Dictionary"
msgstr "ເພີ່ມໃສ່ວັດຈະນານຸກົມ"

#. 9o3ZT
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3144432\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/add\">Adds the unknown word to a user-defined dictionary.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/add\">ເພີ່ມຄຳທີ່ບໍ່ຮູ້ຈັກເຂົ້າໃນວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງ.</ahelp>"

#. RcmYq
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id151611827607301\n"
"help.text"
msgid "To add a new dictionary, press <emph>Options</emph>, then press <emph>New</emph>. After %PRODUCTNAME is restarted, multiple user-defined dictionaries are shown when <emph>Add to Dictionary</emph> is pressed. Select which dictionary should receive the added word."
msgstr "ເພື່ອເພີ່ມວັດຈະນານຸກົມໃໝ່, ໃຫ້ກົດ <emph>ຕົວເລືອກ</emph>, ແລ້ວກົດ <emph>ໃໝ່</emph>. ຫຼັງຈາກເລີ່ມຕົ້ນ %PRODUCTNAME ໃໝ່, ວັດຈະນານຸກົມທີ່ຜູ້ໃຊ້ກຳນົດເອງຫຼາຍອັນຈະປະກົດຂຶ້ນເມື່ອກົດ <emph>ເພີ່ມໃສ່ວັດຈະນານຸກົມ</emph>. ໃຫ້ເລືອກວັດຈະນານຸກົມທີ່ທ່ານຕ້ອງການເພີ່ມຄຳສັບໃສ່."

#. aREHP
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3149885\n"
"help.text"
msgid "Suggestions"
msgstr "ຄຳແນະນຳ"

#. XKCg2
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3155628\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/suggestionslb\">Lists suggested words to replace the misspelled word. Select the word that you want to use, and then click <emph>Correct</emph> or <emph>Correct All</emph>.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/suggestionslb\">ສະແດງລາຍການຄຳສັບທີ່ແນະນຳເພື່ອປ່ຽນແທນຄຳທີ່ສະກົດຜິດ. ເລືອກຄຳສັບທີ່ທ່ານຕ້ອງການໃຊ້, ແລ້ວຄລິກ <emph>ແກ້ໄຂ</emph> ຫຼື <emph>ແກ້ໄຂທັງໝົດ</emph>.</ahelp>"

#. nDQnx
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3153056\n"
"help.text"
msgid "Correct"
msgstr "ແກ້ໄຂ"

#. DYuBb
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3148559\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/change\">Replaces the unknown word with the current suggestion. If you changed more than just the misspelled word, the entire sentence is replaced.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/change\">ປ່ຽນຄຳທີ່ບໍ່ຮູ້ຈັກດ້ວຍຄຳແນະນຳປັດຈຸບັນ. ຫາກທ່ານແກ້ໄຂຫຼາຍກວ່າພຽງແຕ່ຄຳທີ່ສະກົດຜິດ, ປະໂຫຍກທັງໝົດຈະຖືກປ່ຽນແທນ.</ahelp>"

#. gBMY9
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3145787\n"
"help.text"
msgid "Correct All"
msgstr "ແກ້ໄຂທັງໝົດ"

#. Z5jNB
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3144446\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/spellingdialog/changeall\">Replaces all occurrences of the unknown word with the current suggestion.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/spellingdialog/changeall\">ປ່ຽນຄຳທີ່ບໍ່ຮູ້ຈັກນີ້ໃນທຸກໆບ່ອນດ້ວຍຄຳແນະນຳປັດຈຸບັນ.</ahelp>"

#. VB8iV
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id3154071\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\">Add to AutoCorrect</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\">ເພີ່ມໃສ່ການແກ້ໄຂອັດຕະໂນມັດ</caseinline></switchinline>"

#. ea48F
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id3153798\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\"><ahelp hid=\"cui/ui/spellingdialog/autocorrect\">Adds the current combination of the incorrect word and the selected replacement suggestion to the AutoCorrect replacement table, but does not make any change in the document.</ahelp></caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\"><ahelp hid=\"cui/ui/spellingdialog/autocorrect\">ເພີ່ມຄູ່ຄຳສັບທີ່ຜິດ ແລະ ຄຳປ່ຽນແທນທີ່ເລືອກໄວ້ ເຂົ້າໃນຕາຕະລາງການປ່ຽນແທນຂອງການແກ້ໄຂອັດຕະໂນມັດ, ແຕ່ຈະບໍ່ມີການປ່ຽນແປງໃດໆໃນເອກະສານ.</ahelp></caseinline></switchinline>"

#. NkSGx
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"hd_id861611567018048\n"
"help.text"
msgid "Check grammar"
msgstr "ກວດສອບໄວຍາກອນ"

#. ABHYi
#: 06010000.xhp
msgctxt ""
"06010000.xhp\n"
"par_id1022200801354366\n"
"help.text"
msgid "<ahelp hid=\".\">Enable to work first on all spelling errors, then on all grammar errors.</ahelp>"
