"05340300.xhp\n"
"par_id3150506\n"
"help.text"
msgid "<variable id=\"linkstext\"><ahelp hid=\".uno:AlignLeft\">Aligns the contents of the cell to the left.</ahelp>        </variable>"
msgstr "<variable id=\"linkstext\"><ahelp hid=\".uno:AlignLeft\">ຈັດວາງເນື້ອໃນຂອງເຊລໄວ້ເບື້ອງຊ້າຍ.</ahelp></variable>"

