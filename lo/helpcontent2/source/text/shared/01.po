msgctxt ""
"01190000.xhp\n"
"hd_id3147530\n"
"help.text"
msgid "Show"
msgstr "ສະແດງ"

#. YkB3Y
#: 01190000.xhp
msgctxt ""
"01190000.xhp\n"
"par_id3153061\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/versionsofdialog/show\">Displays the entire comment for the selected version.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/versionsofdialog/show\">ສະແດງຄຳເຫັນທັງໝົດສຳລັບເວີຊັນທີ່ເລືອກ.</ahelp>"

#. WsCjQ
#: 01190000.xhp
msgctxt ""
"01190000.xhp\n"
"hd_id3154923\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. ZCgpA
