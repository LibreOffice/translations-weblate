"hd_id371715\n"
"help.text"
msgid "Reset"
msgstr "ຕັ້ງຄ່າໃໝ່"

#. iivF7
#: 03990000.xhp
msgctxt ""
"03990000.xhp\n"
"par_id1886654\n"
"help.text"
msgid "<ahelp hid=\".\">Choose <item type=\"menuitem\">View - Toolbars - Reset</item> to reset the toolbars to their default context sensitive behavior. Now some toolbars will be shown automatically, dependent on the context.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກ <item type=\"menuitem\">ມຸມມອງ - ແຖບເຄື່ອງມື - ຕັ້ງຄ່າໃໝ່</item> ເພື່ອຕັ້ງຄ່າແຖບເຄື່ອງມືຄືນໃໝ່ໃຫ້ເປັນໄປຕາມພຶດຕິກຳທີ່ຂຶ້ນກັບບໍລິບົດເລີ່ມຕົ້ນ. ຕອນນີ້ບາງແຖບເຄື່ອງມືຈະຖືກສະແດງໂດຍອັດຕະໂນມັດ ໂດຍຂຶ້ນກັບບໍລິບົດ.</ahelp>"

#. avLUb
#: 03990000.xhp
msgctxt ""
"03990000.xhp\n"
"hd_id671690981676209\n"
"help.text"
msgid "Lock Toolbars"
msgstr "ລັອກແຖບເຄື່ອງມື"

#. ocYUZ
#: 03990000.xhp
msgctxt ""
"03990000.xhp\n"
"par_id471690981720059\n"
"help.text"
msgid "Indicates whether visible toolbars can be moved using the mouse."
msgstr "ລະບຸວ່າແຖບເຄື່ອງມືທີ່ເບິ່ງເຫັນໄດ້ນັ້ນສາມາດຍ້າຍໄດ້ໂດຍການໃຊ້ເມົາສ໌ຫຼືບໍ່."

#. VyFa8
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"tit\n"
"help.text"
msgid "Comments"
msgstr "ຄຳເຫັນ"

#. Mzeni
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"bm_id3154100\n"
"help.text"
msgid "<bookmark_value>comments;inserting/editing/deleting/printing/resolving</bookmark_value>        <bookmark_value>comments;hide resolved</bookmark_value>        <bookmark_value>comments;resolve in text documents</bookmark_value>        <bookmark_value>inserting; comments</bookmark_value>        <bookmark_value>editing; comments</bookmark_value>        <bookmark_value>deleting;comments</bookmark_value>        <bookmark_value>Navigator;comments</bookmark_value>        <bookmark_value>printing;comments</bookmark_value>        <bookmark_value>resolving;comments</bookmark_value>        <bookmark_value>records; inserting comments </bookmark_value>        <bookmark_value>remarks, see also comments</bookmark_value>"
msgstr "<bookmark_value>ຄຳເຫັນ;ການແຊກ/ການແກ້ໄຂ/ການລຶບ/ການພິມ/ການແກ້ໄຂບັນຫາ</bookmark_value>        <bookmark_value>ຄຳເຫັນ;ເຊື່ອງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ</bookmark_value>        <bookmark_value>ຄຳເຫັນ;ແກ້ໄຂບັນຫາໃນເອກະສານຂໍ້ຄວາມ</bookmark_value>        <bookmark_value>ການແຊກ; ຄຳເຫັນ</bookmark_value>        <bookmark_value>ການແກ້ໄຂ; ຄຳເຫັນ</bookmark_value>        <bookmark_value>ການລຶບ;ຄຳເຫັນ</bookmark_value>        <bookmark_value>ຕົວນຳທາງ;ຄຳເຫັນ</bookmark_value>        <bookmark_value>ການພິມ;ຄຳເຫັນ</bookmark_value>        <bookmark_value>ການແກ້ໄຂບັນຫາ;ຄຳເຫັນ</bookmark_value>        <bookmark_value>ບັນທຶກ; ການແຊກຄຳເຫັນ </bookmark_value>        <bookmark_value>ຂໍ້ສັງເກດ, ເບິ່ງຄຳເຫັນນຳ</bookmark_value>"

#. nhCGe
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3154100\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/shared/01/04050000.xhp\">Comment</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/shared/01/04050000.xhp\">ຄຳເຫັນ</link></variable>"

#. B5Lac
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3151100\n"
"help.text"
msgid "<variable id=\"notizbearbeitentext\"><ahelp hid=\".\">Inserts a comment around the selected text, presentation slide, drawing page or at the current spreadsheet cursor position.</ahelp></variable>"
msgstr "<variable id=\"notizbearbeitentext\"><ahelp hid=\".\">ແຊກຄຳເຫັນໃສ່ຂໍ້ຄວາມທີ່ເລືອກ, ສະໄລ້ການນຳສະເໜີ, ໜ້າຮູບແຕ້ມ ຫຼື ທີ່ຕຳແໜ່ງເຄີເຊີຂອງສະເປຣດຊີດປັດຈຸບັນ.</ahelp></variable>"

#. TCEw8
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id6718649\n"
"help.text"
msgid "The comments by different authors get different colors. Choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME - User Data</menuitem> to enter your name so that it can show up as the comment author."
msgstr "ຄຳເຫັນໂດຍຜູ້ຂຽນທີ່ແຕກຕ່າງກັນຈະໄດ້ຮັບສີທີ່ແຕກຕ່າງກັນ. ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ສິ່ງທີ່ມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME - ຂໍ້ມູນຜູ້ໃຊ້</menuitem> ເພື່ອປ້ອນຊື່ຂອງທ່ານເພື່ອໃຫ້ມັນສາມາດສະແດງເປັນຜູ້ຂຽນຄຳເຫັນ."

#. BerbA
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id0915200910571612\n"
"help.text"
msgid "Comments in spreadsheets"
msgstr "ຄຳເຫັນໃນສະເປຣດຊີດ"

#. p3bv5
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3166460\n"
"help.text"
msgid "When you attach a comment to a cell, a callout appears where you can enter your text. A small square in the upper right corner of a cell marks the position of a comment. To display the comment permanently, right-click the cell, and choose <emph>Show Comment</emph>."
msgstr "ເມື່ອທ່ານຄັດຕິດຄຳເຫັນໃສ່ຫ້ອງ, ປ້າຍຄຳເວົ້າຈະປະກົດຂຶ້ນເຊິ່ງທ່ານສາມາດປ້ອນຂໍ້ຄວາມຂອງທ່ານໄດ້. ຮູບສີ່ຫຼ່ຽມມົນນ້ອຍໆຢູ່ມຸມຂວາເທິງຂອງຫ້ອງຈະໝາຍຕຳແໜ່ງຂອງຄຳເຫັນ. ເພື່ອສະແດງຄຳເຫັນແບບຖາວອນ, ໃຫ້ຄລິກຂວາໃສ່ຫ້ອງນັ້ນ, ແລ້ວເລືອກ <emph>ສະແດງຄຳເຫັນ</emph>."

#. RCBDq
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id101565954872022\n"
"help.text"
msgid "<image src=\"media/helpimg/sc_cell_with_comment_displayed.png\" id=\"img_id901565954872022\" width=\"451px\" height=\"173px\"><alt id=\"alt_id771565954872022\">Cell with comment displayed</alt></image>"
msgstr "<image src=\"media/helpimg/sc_cell_with_comment_displayed.png\" id=\"img_id901565954872022\" width=\"451px\" height=\"173px\"><alt id=\"alt_id771565954872022\">ຫ້ອງທີ່ມີຄຳເຫັນສະແດງຢູ່</alt></image>"

#. HgUDA
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id8336741\n"
"help.text"
msgid "To change the object properties of a comment, for example the background color, choose <emph>Show Comment</emph> as above, then right-click the comment. Do <emph>not</emph> double-click the text!"
msgstr "ເພື່ອປ່ຽນຄຸນລັກສະນະວັດຖຸຂອງຄຳເຫັນ, ຕົວຢ່າງເຊັ່ນ: ສີພື້ນຫຼັງ, ໃຫ້ເລືອກ <emph>ສະແດງຄຳເຫັນ</emph> ດັ່ງຂ້າງເທິງ, ຈາກນັ້ນຄລິກຂວາໃສ່ຄຳເຫັນ. <emph>ຫ້າມ</emph> ຄລິກສອງຄັ້ງໃສ່ຂໍ້ຄວາມ!"

#. ABcp4
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3155390\n"
"help.text"
msgid "To edit a shown comment, double-click the comment text. To edit a comment that is not shown permanently, right-click in the cell that contains the comment, and then choose <emph>Edit Comment</emph>. To specify the formatting of the comment text, right-click the comment text in edit mode."
msgstr ""

#. GeVZN
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_idN107A1\n"
"help.text"
msgid "To change the position or size of a comment, drag a border or corner of the comment box."
msgstr "ເພື່ອປ່ຽນຕຳແໜ່ງ ຫຼື ຂະໜາດຂອງຄຳເຫັນ, ໃຫ້ລາກຂອບ ຫຼື ມຸມຂອງກ່ອງຄຳເຫັນ."

#. J2Lbi
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id9499496\n"
"help.text"
msgid "To delete a comment, right-click the cell, then choose <emph>Delete Comment</emph>."
msgstr "ເພື່ອລຶບຄຳເຫັນ, ໃຫ້ຄລິກຂວາໃສ່ຫ້ອງນັ້ນ, ແລ້ວເລືອກ <emph>ລຶບຄຳເຫັນ</emph>."

#. fcqBs
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id2036805\n"
"help.text"
msgid "You can also right-click a comment name in the <emph>Navigator</emph> window to choose <emph>Edit Comment</emph> or <emph>Delete Comment</emph>."
msgstr "ທ່ານຍັງສາມາດຄລິກຂວາໃສ່ຊື່ຄຳເຫັນໃນປ່ອງຢ້ຽມ <emph>ຕົວນຳທາງ</emph> ເພື່ອເລືອກ <emph>ແກ້ໄຂຄຳເຫັນ</emph> ຫຼື <emph>ລຶບຄຳເຫັນ</emph>."

#. nJQe4
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id3153716\n"
"help.text"
msgid "To set the printing options for comments in your spreadsheet, choose <menuitem>Format - Page Style</menuitem>, and then click the <emph>Sheet</emph> tab."
msgstr "ເພື່ອຕັ້ງຄ່າຕົວເລືອກການພິມສຳລັບຄຳເຫັນໃນສະເປຣດຊີດຂອງທ່ານ, ໃຫ້ເລືອກ <menuitem>ຮູບແບບ - ຮູບແບບໜ້າ</menuitem>, ແລ້ວຄລິກທີ່ແຖບ <emph>ແຜ່ນງານ</emph>."

#. Rwgo7
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id1001565974085289\n"
"help.text"
msgid "Inserting Comments in Presentations"
msgstr "ການແຊກຄຳເຫັນໃນການນຳສະເໜີ"

#. 6sk3F
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id901565974475262\n"
"help.text"
msgid "Use the command <menuitem>Insert - Comment</menuitem> or the key combination above to insert a comment anchor to the current <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">slide</caseinline><caseinline select=\"DRAW\">page</caseinline></switchinline>. A colored comment box is shown at the top left corner, to enter the text of the comment. A small colored box -  the anchor - in the top left of the <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">slide</caseinline><caseinline select=\"DRAW\">page</caseinline></switchinline> contains the initials of the author name, followed by a sequential number. Click on the anchor to open or close the corresponding comment."
msgstr "ໃຊ້ຄຳສັ່ງ <menuitem>ແຊກ - ຄຳເຫັນ</menuitem> ຫຼື ປຸ່ມປະສົມຂ້າງເທິງເພື່ອແຊກຈຸດຢຶດຄຳເຫັນໃສ່ໃນ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><caseinline select=\"DRAW\">ໜ້າ</caseinline></switchinline> ປັດຈຸບັນ. ກ່ອງຄຳເຫັນທີ່ມີສີຈະຖືກສະແດງຢູ່ມຸມຊ້າຍເທິງ, ເພື່ອປ້ອນຂໍ້ຄວາມຄຳເຫັນ. ກ່ອງສີນ້ອຍໆ - ຈຸດຢຶດ - ຢູ່ເບື້ອງຊ້າຍເທິງຂອງ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><caseinline select=\"DRAW\">ໜ້າ</caseinline></switchinline> ຈະປະກອບດ້ວຍຕົວອັກສອນຫຍໍ້ຂອງຊື່ຜູ້ຂຽນ, ຕາມດ້ວຍໝາຍເລກລຳດັບ. ຄລິກທີ່ຈຸດຢຶດເພື່ອເປີດ ຫຼື ປິດຄຳເຫັນທີ່ກ່ຽວຂ້ອງ."

#. GRqag
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id521565974498192\n"
"help.text"
msgid "The author name and the comment creation date and time is shown at the bottom of the comment box."
msgstr "ຊື່ຜູ້ຂຽນ ແລະ ວັນທີ ແລະ ເວລາການສ້າງຄຳເຫັນຈະຖືກສະແດງຢູ່ດ້ານລຸ່ມຂອງກ່ອງຄຳເຫັນ."

#. BCd4y
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id2571794\n"
"help.text"
msgid "The comment box contains a button with a down arrow. Click the icon to open a menu with commands for comment management."
msgstr "ກ່ອງຄຳເຫັນປະກອບດ້ວຍປຸ່ມທີ່ມີລູກສອນຊີ້ລົງ. ຄລິກທີ່ໄອຄອນເພື່ອເປີດເມນູທີ່ມີຄຳສັ່ງສຳລັບການຈັດການຄຳເຫັນ."

#. oB8vA
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id561345967371982\n"
"help.text"
msgid "<image src=\"media/helpimg/si_presentation_with_comment.png\" id=\"img_id23465967371982\" width=\"598px\" height=\"291px\"><alt id=\"alt_id481565967371982\">Comments in Presentations</alt></image>"
msgstr "<image src=\"media/helpimg/si_presentation_with_comment.png\" id=\"img_id23465967371982\" width=\"598px\" height=\"291px\"><alt id=\"alt_id481565967371982\">ຄຳເຫັນໃນການນຳສະເໜີ</alt></image>"

#. PFLfE
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id491566054901283\n"
"help.text"
msgid "Inserting Comments in Drawings"
msgstr "ການແຊກຄຳເຫັນໃນຮູບແຕ້ມ"

#. HXJiy
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id561345998371982\n"
"help.text"
msgid "<image src=\"media/helpimg/sd_drawing_with_comment.png\" id=\"img_id23465967371982\" width=\"413px\" height=\"293px\"><alt id=\"alt_id481565967371982\">Comments in Drawings</alt></image>"
msgstr "<image src=\"media/helpimg/sd_drawing_with_comment.png\" id=\"img_id23465967371982\" width=\"413px\" height=\"293px\"><alt id=\"alt_id481565967371982\">ຄຳເຫັນໃນຮູບແຕ້ມ</alt></image>"

#. b3J3Q
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id9851680\n"
"help.text"
msgid "Inserting Comments in Text Documents"
msgstr "ການແຊກຄຳເຫັນໃນເອກະສານຂໍ້ຄວາມ"

#. CigQE
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id1830500\n"
"help.text"
msgid "Use the command <menuitem>Insert - Comment</menuitem> or the <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode>+<keycode>Option</keycode></caseinline><defaultinline><keycode>Ctrl</keycode>+<keycode>Alt</keycode></defaultinline></switchinline>+<keycode>C</keycode> key combination to insert a comment anchor at the current cursor position. A colored comment box is shown at the page margin, to enter the text of the comment. A line connects the anchor to the comment box. If a text range is selected, the comment is attached to the text range. The commented text range is shadowed."
msgstr "ໃຊ້ຄຳສັ່ງ <menuitem>ແຊກ - ຄຳເຫັນ</menuitem> ຫຼື ປຸ່ມປະສົມ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode>+<keycode>Option</keycode></caseinline><defaultinline><keycode>Ctrl</keycode>+<keycode>Alt</keycode></defaultinline></switchinline>+<keycode>C</keycode> ເພື່ອແຊກຈຸດຢຶດຄຳເຫັນທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ. ກ່ອງຄຳເຫັນທີ່ມີສີຈະຖືກສະແດງຢູ່ຂອບໜ້າ, ເພື່ອປ້ອນຂໍ້ຄວາມຄຳເຫັນ. ເສັ້ນຈະເຊື່ອມຕໍ່ຈຸດຢຶດຫາສາມກ່ອງຄຳເຫັນ. ຖ້າຊ່ວງຂໍ້ຄວາມຖືກເລືອກໄວ້, ຄຳເຫັນຈະຖືກຄັດຕິດໃສ່ຊ່ວງຂໍ້ຄວາມນັ້ນ. ຊ່ວງຂໍ້ຄວາມທີ່ມີຄຳເຫັນຈະຖືກເຮັດເປັນເງົາ."

#. ro9G3
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id561565967371982\n"
"help.text"
msgid "<image src=\"media/helpimg/sw_text_with_comment.png\" id=\"img_id21565967371982\" width=\"834px\" height=\"244px\"><alt id=\"alt_id481565967371982\">Comments in text documents</alt></image>"
msgstr "<image src=\"media/helpimg/sw_text_with_comment.png\" id=\"img_id21565967371982\" width=\"834px\" height=\"244px\"><alt id=\"alt_id481565967371982\">ຄຳເຫັນໃນເອກະສານຂໍ້ຄວາມ</alt></image>"

#. EufpM
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id2929166\n"
"help.text"
msgid "Editing comments"
msgstr "ການແກ້ໄຂຄຳເຫັນ"

#. WjcPZ
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id5201879\n"
"help.text"
msgid "Every user with write permission to the document can edit and delete comments of all authors. You can use the <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode>+<keycode>Option</keycode></caseinline><defaultinline><keycode>Ctrl</keycode>+<keycode>Alt</keycode></defaultinline></switchinline>+<keycode>C</keycode> key combination to edit a comment at the current cursor position."
msgstr "ຜູ້ໃຊ້ທຸກຄົນທີ່ມີສິດຂຽນລົງໃນເອກະສານສາມາດແກ້ໄຂ ແລະ ລຶບຄຳເຫັນຂອງຜູ້ຂຽນທັງໝົດໄດ້. ທ່ານສາມາດໃຊ້ປຸ່ມປະສົມ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode>+<keycode>Option</keycode></caseinline><defaultinline><keycode>Ctrl</keycode>+<keycode>Alt</keycode></defaultinline></switchinline>+<keycode>C</keycode> ເພື່ອແກ້ໄຂຄຳເຫັນທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ."

#. qJE7L
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0302200901430918\n"
"help.text"
msgid "In the <emph>Find & Replace</emph> dialog of text documents, you can select to include the comments texts in your searches."
msgstr "ໃນກ່ອງໂຕ້ຕອບ <emph>ຊອກຫາ ແລະ ແທນທີ່</emph> ຂອງເອກະສານຂໍ້ຄວາມ, ທ່ານສາມາດເລືອກທີ່ຈະລວມຂໍ້ຄວາມຄຳເຫັນເຂົ້າໃນການຄົ້ນຫາຂອງທ່ານ."

#. dEJTD
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id601573488847729\n"
"help.text"
msgid "<variable id=\"replycomments_hd\">Replying to comments</variable>"
msgstr "<variable id=\"replycomments_hd\">ການຕອບຄຳເຫັນ</variable>"

#. XjKE5
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0305200911090684\n"
"help.text"
msgid "If the comment in a text document was written by another author, there is a <emph>Reply</emph> command in the context menu. <ahelp hid=\".\">This command inserts a new comment adjacent to the comment to which you want to reply.</ahelp> The comment anchor is the same for both comments. Type your reply text in the new comment. Save and send your document to other authors, then those authors can add replies, too."
msgstr "ຖ້າຄຳເຫັນໃນເອກະສານຂໍ້ຄວາມຖືກຂຽນໂດຍຜູ້ຂຽນຄົນອື່ນ, ຈະມີຄຳສັ່ງ <emph>ຕອບ</emph> ໃນເມນູທາງລັດ. <ahelp hid=\".\">ຄຳສັ່ງນີ້ຈະແຊກຄຳເຫັນໃໝ່ຢູ່ຕິດກັບຄຳເຫັນທີ່ທ່ານຕ້ອງການຕອບ.</ahelp> ຈຸດຢຶດຄຳເຫັນຈະເປັນອັນດຽວກັນສຳລັບທັງສອງຄຳເຫັນ. ພິມຂໍ້ຄວາມຕອບຂອງທ່ານໃນຄຳເຫັນໃໝ່. ບັນທຶກ ແລະ ສົ່ງເອກະສານຂອງທ່ານໃຫ້ຜູ້ຂຽນຄົນອື່ນໆ, ຈາກນັ້ນຜູ້ຂຽນເຫຼົ່ານັ້ນກໍສາມາດເພີ່ມການຕອບໄດ້ຄືກັນ."

#. FD6oN
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id201573491050815\n"
"help.text"
msgid "Marking comments as resolved"
msgstr "ການໝາຍຄຳເຫັນວ່າແກ້ໄຂແລ້ວ"

#. F4jJK
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id961573491046250\n"
"help.text"
msgid "When the document has been reviewed and commented and requires your action in its contents, you can mark the comment  <emph>Resolved</emph> or <emph>Unresolved</emph>. Open the comment context menu or click on the comment dropdown list to mark the Resolved checkbox. When you mark the comment resolved, the word <literal>Resolved</literal> is inserted under the date in the comment box. When marking unresolved, the word <literal>Resolved</literal> is removed."
msgstr "ເມື່ອເອກະສານໄດ້ຖືກກວດສອບ ແລະ ໃຫ້ຄຳເຫັນແລ້ວ ແລະ ຕ້ອງການການດຳເນີນການຂອງທ່ານໃນເນື້ອໃນ, ທ່ານສາມາດໝາຍຄຳເຫັນວ່າ <emph>ແກ້ໄຂແລ້ວ</emph> ຫຼື <emph>ຍັງບໍ່ໄດ້ແກ້ໄຂ</emph>. ເປີດເມນູທາງລັດຂອງຄຳເຫັນ ຫຼື ຄລິກທີ່ລາຍການແບບເລື່ອນລົງຂອງຄຳເຫັນເພື່ອໝາຍທີ່ຊ່ອງ ແກ້ໄຂແລ້ວ. ເມື່ອທ່ານໝາຍຄຳເຫັນວ່າແກ້ໄຂແລ້ວ, ຄຳວ່າ <literal>Resolved</literal> (ແກ້ໄຂແລ້ວ) ຈະຖືກແຊກຢູ່ກ້ອງວັນທີໃນກ່ອງຄຳເຫັນ. ເມື່ອໝາຍວ່າຍັງບໍ່ໄດ້ແກ້ໄຂ, ຄຳວ່າ <literal>Resolved</literal> ຈະຖືກລຶບອອກ."

#. UBwT2
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id521573491035753\n"
"help.text"
msgid "You can toggle the display of all resolved comments in the document. Hidden resolved comments are not displayed in the page margin but are not deleted. You can display back all hidden comments. Choose and mark <menuitem>View - Resolved comments</menuitem> to display the resolved comments. Unmark to hide resolved comments. The default is to display all resolved comments."
msgstr "ທ່ານສາມາດສະຫຼັບການສະແດງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວທັງໝົດໃນເອກະສານໄດ້. ຄຳເຫັນທີ່ແກ້ໄຂແລ້ວທີ່ຖືກເຊື່ອງໄວ້ຈະບໍ່ຖືກສະແດງໃນຂອບໜ້າ ແຕ່ຈະບໍ່ຖືກລຶບອອກ. ທ່ານສາມາດສະແດງຄຳເຫັນທີ່ເຊື່ອງໄວ້ທັງໝົດຄືນມາໄດ້. ເລືອກ ແລະ ໝາຍ <menuitem>ມຸມມອງ - ຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ</menuitem> ເພື່ອສະແດງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ. ຍົກເລີກການໝາຍເພື່ອເຊື່ອງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ. ຄ່າເລີ່ມຕົ້ນແມ່ນການສະແດງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວທັງໝົດ."

#. SJFLT
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id3445539\n"
"help.text"
msgid "Navigating from comment to comment in text documents"
msgstr "ການນຳທາງຈາກຄຳເຫັນຫາຄຳເຫັນໃນເອກະສານຂໍ້ຄວາມ"

#. xYA7F
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id4271370\n"
"help.text"
msgid "When the cursor is inside a comment, you can press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph>+<emph>Option</emph></caseinline><defaultinline><emph>Ctrl</emph>+<emph>Alt</emph></defaultinline></switchinline>+<emph>Page Down</emph> to jump to the next comment, or press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph>+<emph>Option</emph></caseinline><defaultinline><emph>Ctrl</emph>+<emph>Alt</emph></defaultinline></switchinline>+<emph>Page Up</emph> to jump to the previous comment."
msgstr "ເມື່ອເຄີເຊີຢູ່ໃນຄຳເຫັນ, ທ່ານສາມາດກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph>+<emph>Option</emph></caseinline><defaultinline><emph>Ctrl</emph>+<emph>Alt</emph></defaultinline></switchinline>+<emph>Page Down</emph> ເພື່ອໂດດໄປຫາຄຳເຫັນຖັດໄປ, ຫຼື ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph>+<emph>Option</emph></caseinline><defaultinline><emph>Ctrl</emph>+<emph>Alt</emph></defaultinline></switchinline>+<emph>Page Up</emph> ເພື່ອໂດດໄປຫາຄຳເຫັນກ່ອນໜ້າ."

#. asYhr
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id2116153\n"
"help.text"
msgid "When the cursor is inside the normal text, press the above mentioned keys to jump to the next or previous comment anchor."
msgstr "ເມື່ອເຄີເຊີຢູ່ໃນຂໍ້ຄວາມປົກກະຕິ, ໃຫ້ກົດປຸ່ມທີ່ກ່າວມາຂ້າງເທິງເພື່ອໂດດໄປຫາຈຸດຢຶດຄຳເຫັນຖັດໄປ ຫຼື ກ່ອນໜ້າ."

#. yCdcN
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id5381328\n"
"help.text"
msgid "You can also open the <emph>Navigator</emph> to see a list of all comments. Right-click a comment name in the Navigator to edit or delete the comment."
msgstr "ທ່ານຍັງສາມາດເປີດ <emph>ຕົວນຳທາງ</emph> ເພື່ອເບິ່ງລາຍຊື່ຄຳເຫັນທັງໝົດໄດ້. ຄລິກຂວາໃສ່ຊື່ຄຳເຫັນໃນຕົວນຳທາງເພື່ອແກ້ໄຂ ຫຼື ລຶບຄຳເຫັນ."

#. AmLks
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0522200809383431\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Delete the current comment.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບຄຳເຫັນປັດຈຸບັນ.</ahelp>"

#. HsmR5
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0522200809383485\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Delete all comments by this author in the current document.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບຄຳເຫັນທັງໝົດຂອງຜູ້ຂຽນຄົນນີ້ໃນເອກະສານປັດຈຸບັນ.</ahelp>"

#. BVqcC
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0522200809383428\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Delete all comments in the current document.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບຄຳເຫັນທັງໝົດໃນເອກະສານປັດຈຸບັນ.</ahelp>"

#. M44G3
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id51565980483588\n"
"help.text"
msgid "Viewing Comments"
msgstr "ການເບິ່ງຄຳເຫັນ"

#. UAKqv
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id61565980600884\n"
"help.text"
msgid "Use <menuitem>View - Comments</menuitem> to show or hide all comments in spreadsheets."
msgstr "ໃຊ້ <menuitem>ມຸມມອງ - ຄຳເຫັນ</menuitem> ເພື່ອສະແດງ ຫຼື ເຊື່ອງຄຳເຫັນທັງໝົດໃນສະເປຣດຊີດ."

#. PsCjS
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id171565980454842\n"
"help.text"
msgid "Use <menuitem>View - Comments</menuitem> to show or hide all anchor comments on the top of the page."
msgstr "ໃຊ້ <menuitem>ມຸມມອງ - ຄຳເຫັນ</menuitem> ເພື່ອສະແດງ ຫຼື ເຊື່ອງຄຳເຫັນຈຸດຢຶດທັງໝົດຢູ່ເບື້ອງເທິງຂອງໜ້າ."

#. zBnvM
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id821565980437922\n"
"help.text"
msgid "Use <menuitem>View - Comments</menuitem> to show or hide all anchor comments on the top of the slide."
msgstr "ໃຊ້ <menuitem>ມຸມມອງ - ຄຳເຫັນ</menuitem> ເພື່ອສະແດງ ຫຼື ເຊື່ອງຄຳເຫັນຈຸດຢຶດທັງໝົດຢູ່ເບື້ອງເທິງຂອງສະໄລ້."

#. pCzYa
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id0804200803435883\n"
"help.text"
msgid "Use <menuitem>View - Comments</menuitem> or click on the Comment button on the right of the horizontal ruler to show or hide all comments."
msgstr "ໃຊ້ <menuitem>ມຸມມອງ - ຄຳເຫັນ</menuitem> ຫຼື ຄລິກທີ່ປຸ່ມ ຄຳເຫັນ ທາງເບື້ອງຂວາຂອງບັນທັດແນວນອນເພື່ອສະແດງ ຫຼື ເຊື່ອງຄຳເຫັນທັງໝົດ."

#. UYcmU
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"hd_id5664235\n"
"help.text"
msgid "Printing comments"
msgstr "ການພິມຄຳເຫັນ"

#. CA7V5
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id231565982070288\n"
"help.text"
msgid "You cannot print the comments of the slides."
msgstr "ທ່ານບໍ່ສາມາດພິມຄຳເຫັນຂອງສະໄລ້ໄດ້."

#. XGcLv
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id2419507\n"
"help.text"
msgid "You can choose to use the <emph>Notes view</emph> to write a page of notes for every slide."
msgstr "ທ່ານສາມາດເລືອກໃຊ້ <emph>ມຸມມອງບັນທຶກ</emph> ເພື່ອຂຽນໜ້າບັນທຶກສຳລັບແຕ່ລະສະໄລ້ໄດ້."

#. wiFGN
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id671565982126756\n"
"help.text"
msgid "You cannot print the comments of the drawing pages."
msgstr "ທ່ານບໍ່ສາມາດພິມຄຳເຫັນຂອງໜ້າຮູບແຕ້ມໄດ້."

#. YeKDs
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id461565984972664\n"
"help.text"
msgid "Comments are printed when they are made visible."
msgstr "ຄຳເຫັນຈະຖືກພິມອອກເມື່ອພວກມັນຖືກເຮັດໃຫ້ເຫັນ."

#. hsCKo
#: 04050000.xhp
msgctxt ""
"04050000.xhp\n"
"par_id2254402\n"
"help.text"
msgid "To change the printing option for comments for all your text documents, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Writer - Print</menuitem>."
msgstr "ເພື່ອປ່ຽນຕົວເລືອກການພິມສຳລັບຄຳເຫັນສຳລັບເອກະສານຂໍ້ຄວາມທັງໝົດຂອງທ່ານ, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ສິ່ງທີ່ມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME Writer - ພິມ</menuitem>."

#. vm68C
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"tit\n"
"help.text"
msgid "Scan"
msgstr "ສະແກນ"

#. MumDm
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3146902\n"
"help.text"
msgid "<link href=\"text/shared/01/04060000.xhp\">Scan</link>"
msgstr "<link href=\"text/shared/01/04060000.xhp\">ສະແກນ</link>"

#. oHtoh
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3154926\n"
"help.text"
msgid "<variable id=\"scan\"><ahelp hid=\".uno:Scan\">Inserts a scanned image into your document.</ahelp></variable>"
msgstr "<variable id=\"scan\"><ahelp hid=\".uno:Scan\">ແຊກຮູບພາບທີ່ສະແກນແລ້ວເຂົ້າໃນເອກະສານຂອງທ່ານ.</ahelp></variable>"

#. sRD8M
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"par_id3153124\n"
"help.text"
msgid "To insert a scanned image, the driver for your scanner must be installed. <switchinline select=\"sys\"><caseinline select=\"UNIX\">Under UNIX systems, install the SANE package found at <link href=\"http://www.sane-project.org\">http://www.sane-project.org</link>. The SANE package must use the same libc as $[officename].</caseinline></switchinline>"
msgstr "ເພື່ອແຊກຮູບພາບທີ່ສະແກນແລ້ວ, ໄດຣເວີສຳລັບເຄື່ອງສະແກນຂອງທ່ານຕ້ອງຖືກຕິດຕັ້ງໄວ້ກ່ອນ. <switchinline select=\"sys\"><caseinline select=\"UNIX\">ພາຍໃຕ້ລະບົບ UNIX, ໃຫ້ຕິດຕັ້ງແພັກເກັດ SANE ທີ່ພົບຢູ່ <link href=\"http://www.sane-project.org\">http://www.sane-project.org</link>. ແພັກເກັດ SANE ຕ້ອງໃຊ້ libc ດຽວກັນກັບ $[officename].</caseinline></switchinline>"

#. wPwmM
#: 04060000.xhp
msgctxt ""
"04060000.xhp\n"
"hd_id3152801\n"
"help.text"
msgid "<link href=\"text/shared/01/04060200.xhp\">Request</link>"
msgstr "<link href=\"text/shared/01/04060200.xhp\">ຮ້ອງຂໍ</link>"

#. AMvoY
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"tit\n"
"help.text"
msgid "Select Source"
msgstr "ເລືອກແຫຼ່ງຂໍ້ມູນ"

#. fmG2R
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id3150758\n"
"help.text"
msgid "<link href=\"text/shared/01/04060100.xhp#selectsource\">Select Source</link>"
msgstr "<link href=\"text/shared/01/04060100.xhp#selectsource\">ເລືອກແຫຼ່ງຂໍ້ມູນ</link>"

#. HezxN
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id3152823\n"
"help.text"
msgid "<variable id=\"quellaus\"><ahelp hid=\".uno:TwainSelect\" visibility=\"visible\">Selects the scanner that you want to use.</ahelp></variable>"
msgstr "<variable id=\"quellaus\"><ahelp hid=\".uno:TwainSelect\" visibility=\"visible\">ເລືອກເຄື່ອງສະແກນທີ່ທ່ານຕ້ອງການໃຊ້.</ahelp></variable>"

#. AJ5Lv
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id661633376449596\n"
"help.text"
msgid "The dialog displays settings for the selected scanner and the scan job."
msgstr "ກ່ອງໂຕ້ຕອບຈະສະແດງການຕັ້ງຄ່າສຳລັບເຄື່ອງສະແກນທີ່ເລືອກ ແລະ ວຽກການສະແກນ."

#. t6BMj
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id721633369239013\n"
"help.text"
msgid "Sources"
msgstr "ແຫຼ່ງຂໍ້ມູນ"

#. GvcAB
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id361633369288384\n"
"help.text"
msgid "Displays a list of available scanners detected in your system. Click on a scanner in the list and press <emph>Select</emph> to open the scanner configuration dialog. The configuration dialog depends on the scanner driver installed."
msgstr "ສະແດງລາຍຊື່ເຄື່ອງສະແກນທີ່ມີຢູ່ໃນລະບົບຂອງທ່ານ. ຄລິກທີ່ເຄື່ອງສະແກນໃນລາຍຊື່ແລ້ວກົດ <emph>ເລືອກ</emph> ເພື່ອເປີດກ່ອງໂຕ້ຕອບການຕັ້ງຄ່າເຄື່ອງສະແກນ. ກ່ອງໂຕ້ຕອບການຕັ້ງຄ່າແມ່ນຂຶ້ນກັບໄດຣເວີເຄື່ອງສະແກນທີ່ຕິດຕັ້ງໄວ້."

#. Caooc
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id511633368095174\n"
"help.text"
msgid "Scan Area"
msgstr "ເຂດການສະແກນ"

#. vYcZn
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id991633368100151\n"
"help.text"
msgid "Left, right, top, bottom"
msgstr "ຊ້າຍ, ຂວາ, ເທິງ, ລຸ່ມ"

#. mncAH
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id561633368111347\n"
"help.text"
msgid "Set the margins of the scan area."
msgstr "ຕັ້ງຄ່າຂອບຂອງເຂດການສະແກນ."

#. wmUp5
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id81633368116162\n"
"help.text"
msgid "Preview"
msgstr "ຕົວຢ່າງ"

#. GFTiz
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id811633368127119\n"
"help.text"
msgid "Displays a preview of the scanned image. The preview area contains eight handles. Drag the handles to adjust the scan area or enter a value in the corresponding margin spin box."
msgstr "ສະແດງຕົວຢ່າງຂອງຮູບພາບທີ່ສະແກນ. ພື້ນທີ່ຕົວຢ່າງປະກອບດ້ວຍແຂນຈັບແປດຈຸດ. ລາກແຂນຈັບເພື່ອປັບເຂດການສະແກນ ຫຼື ປ້ອນຄ່າໃນຫ້ອງປັບຄ່າຂອບທີ່ກ່ຽວຂ້ອງ."

#. SQG8n
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id181633369359784\n"
"help.text"
msgid "Device used"
msgstr "ອຸປະກອນທີ່ໃຊ້"

#. vtMfF
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id311633371297646\n"
"help.text"
msgid "Select the scanner device in the list of devices detected by your system."
msgstr "ເລືອກອຸປະກອນເຄື່ອງສະແກນໃນລາຍຊື່ອຸປະກອນທີ່ລະບົບຂອງທ່ານກວດພົບ."

#. PAHaK
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id161633369549370\n"
"help.text"
msgid "Resolution [DPI]"
msgstr "ຄວາມລະອຽດ [DPI]"

#. jTyuD
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id401633369701424\n"
"help.text"
msgid "Select the resolution in dots per inch for the scan job. The available resolutions depends on the scanner driver."
msgstr "ເລືອກຄວາມລະອຽດເປັນຈຸດຕໍ່ນິ້ວ (DPI) ສຳລັບວຽກການສະແກນ. ຄວາມລະອຽດທີ່ມີໃຫ້ໃຊ້ແມ່ນຂຶ້ນກັບໄດຣເວີເຄື່ອງສະແກນ."

#. F5SoB
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id351633369697474\n"
"help.text"
msgid "Show advanced options"
msgstr "ສະແດງຕົວເລືອກຂັ້ນສູງ"

#. Hj5EW
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id771633369733491\n"
"help.text"
msgid "Mark this checkbox to display more configuration options for the scanner device. The set of options is displayed in the <emph>Options</emph> box and depends on the scanner driver."
msgstr "ໝາຍທີ່ຊ່ອງນີ້ເພື່ອສະແດງຕົວເລືອກການຕັ້ງຄ່າເພີ່ມເຕີມສຳລັບອຸປະກອນເຄື່ອງສະແກນ. ຊຸດຕົວເລືອກຈະຖືກສະແດງຢູ່ໃນຫ້ອງ <emph>ຕົວເລືອກ</emph> ແລະ ຂຶ້ນກັບໄດຣເວີເຄື່ອງສະແກນ."

#. 6qqQP
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id461633370147200\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. JtCux
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id761633371067498\n"
"help.text"
msgid "Displays the list of available scanner driver advanced options. Double click an option to display its contents just below. The option and its values depends on the scanner driver."
msgstr "ສະແດງລາຍຊື່ຕົວເລືອກຂັ້ນສູງຂອງໄດຣເວີເຄື່ອງສະແກນທີ່ມີຢູ່. ດັບເບິນຄລິກທີ່ຕົວເລືອກເພື່ອສະແດງເນື້ອໃນຂອງມັນຢູ່ຂ້າງລຸ່ມ. ຕົວເລືອກ ແລະ ຄ່າຂອງມັນແມ່ນຂຶ້ນກັບໄດຣເວີເຄື່ອງສະແກນ."

#. DFbzA
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id461633371554790\n"
"help.text"
msgid "About Device"
msgstr "ກ່ຽວກັບອຸປະກອນ"

#. 2DSpo
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id821633371816925\n"
"help.text"
msgid "Displays a popup window with information obtained from the scanner driver: device address, vendor, scanner model and type of scanner."
msgstr "ສະແດງປ່ອງຢ້ຽມປັອບອັບພ້ອມຂໍ້ມູນທີ່ໄດ້ຮັບຈາກໄດຣເວີເຄື່ອງສະແກນ: ທີ່ຢູ່ອຸປະກອນ, ຜູ້ຈຳໜ່າຍ, ລຸ້ນເຄື່ອງສະແກນ ແລະ ປະເພດຂອງເຄື່ອງສະແກນ."

#. HCSD9
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id971633371559920\n"
"help.text"
msgid "Create preview"
msgstr "ສ້າງຕົວຢ່າງ"

#. T4Tgs
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id431633375721518\n"
"help.text"
msgid "Scans and displays the document in the preview area. Use the <emph>Create Preview</emph> command to view a sample of the scanned document and set the scan job properties."
msgstr "ສະແກນ ແລະ ສະແດງເອກະສານໃນເຂດຕົວຢ່າງ. ໃຊ້ຄຳສັ່ງ <emph>ສ້າງຕົວຢ່າງ</emph> ເພື່ອເບິ່ງຕົວຢ່າງຂອງເອກະສານທີ່ສະແກນ ແລະ ຕັ້ງຄ່າຄຸນສົມບັດວຽກການສະແກນ."

#. YL3KE
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"hd_id151633371565195\n"
"help.text"
msgid "Scan"
msgstr "ສະແກນ"

#. zWLcX
#: 04060100.xhp
msgctxt ""
"04060100.xhp\n"
"par_id851633375846639\n"
"help.text"
msgid "Scans an image, and then inserts the result into the document and closes the dialog."
msgstr "ສະແກນຮູບພາບ, ແລ້ວແຊກຜົນທີ່ໄດ້ເຂົ້າໃນເອກະສານ ແລະ ປິດກ່ອງໂຕ້ຕອບ."

#. qDEzX
#: 04060200.xhp
msgctxt ""
"04060200.xhp\n"
"tit\n"
"help.text"
msgid "Request"
msgstr "ຮ້ອງຂໍ"

#. i24GA
#: 04060200.xhp
msgctxt ""
"04060200.xhp\n"
"hd_id3153514\n"
"help.text"
msgid "<link href=\"text/shared/01/04060200.xhp#request\">Request</link>"
msgstr "<link href=\"text/shared/01/04060200.xhp#request\">ຮ້ອງຂໍ</link>"

#. 2C9QF
#: 04060200.xhp
msgctxt ""
"04060200.xhp\n"
"par_id3150278\n"
"help.text"
msgid "<variable id=\"anford\"><ahelp hid=\".uno:TwainTransfer\" visibility=\"visible\">Scans an image, and then inserts the result into the document. The scanning dialog is provided by the manufacturer of the scanner.</ahelp></variable> For an explanation of the dialog please refer to the documentation on your scanner."
msgstr "<variable id=\"anford\"><ahelp hid=\".uno:TwainTransfer\" visibility=\"visible\">ສະແກນຮູບພາບ, ແລ້ວແຊກຜົນທີ່ໄດ້ເຂົ້າໃນເອກະສານ. ກ່ອງໂຕ້ຕອບການສະແກນແມ່ນສະໜອງໃຫ້ໂດຍຜູ້ຜະລິດເຄື່ອງສະແກນ.</ahelp></variable> ສຳລັບຄຳອະທິບາຍກ່ຽວກັບກ່ອງໂຕ້ຕອບ ກະລຸນາເບິ່ງເອກະສານຄູ່ມືເຄື່ອງສະແກນຂອງທ່ານ."

#. GVD56
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"tit\n"
"help.text"
msgid "Special Character"
msgstr "ຕົວອັກສອນພິເສດ"

#. 4Qsom
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"hd_id3152937\n"
"help.text"
msgid "<link href=\"text/shared/01/04100000.xhp\">Special Character</link>"
msgstr "<link href=\"text/shared/01/04100000.xhp\">ອັກສອນພິເສດ</link>"

#. CBACQ
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"par_id3150838\n"
"help.text"
msgid "<variable id=\"sonder\"><ahelp hid=\".\">Allows a user to insert characters from the range of symbols found in the installed fonts.</ahelp></variable>"
msgstr "<variable id=\"sonder\"><ahelp hid=\".\">ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ແຊກອັກສອນຈາກກຸ່ມສັນຍະລັກທີ່ມີຢູ່ໃນຟອນທີ່ຕິດຕັ້ງແລ້ວ.</ahelp></variable>"

#. gzkiW
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"par_id3152372\n"
"help.text"
msgid "When you click a character in the <emph>Special Characters</emph> dialog, a preview and the corresponding numerical code for the character is displayed."
msgstr "ເມື່ອທ່ານຄລິກອັກສອນໃນກ່ອງໂຕ້ຕອບ <emph>ອັກສອນພິເສດ</emph>, ຕົວຢ່າງເບິ່ງກ່ອນ ແລະ ລະຫັດຕົວເລກທີ່ກົງກັນຂອງອັກສອນນັ້ນຈະສະແດງຂຶ້ນ."

#. AQsdj
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"hd_id451614794558893\n"
"help.text"
msgid "Search"
msgstr "ຄົ້ນຫາ"

#. JGCeA
#: 04100000.xhp
msgctxt ""
"04100000.xhp\n"
"par_id741614794572948\n"
"help.text"
msgid "Enter the UTF-8 name or part of the name of the character to display the UTF-8 character in the top left square of the grid. The name of the character cannot be translated. For example, enter <literal>tilde</literal> to display <literal>~</literal> and enter <literal>latin capital letter O with circumflex</literal> to display <literal>Ô</literal>."
msgstr "ປ້ອນຊື່ UTF-8 ຫຼື ສ່ວນໃດສ່ວນໜຶ່ງຂອງຊື່ຂອງອັກສອນເພື່ອສະແດງອັກສອນ UTF-8 ໃນຫ້ອງສີ່ລ່ຽມເທິງຊ້າຍຂອງຕາຕະລາງ. ຊື່ຂອງອັກສອນບໍ່ສາມາດແປໄດ້. ຕົວຢ່າງ, ປ້ອນ <literal>tilde</literal> ເພື່ອສະແດງ <literal>~</literal> ແລະ ປ້ອນ <literal>latin capital letter O with circumflex</literal> ເພື່ອສະແດງ <literal>Ô</literal>."

