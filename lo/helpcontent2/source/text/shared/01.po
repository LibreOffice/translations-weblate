msgstr "<ahelp hid=\"cui/ui/linetabpage/MTR_FLD_END_WIDTH\">ປ້ອນຄວາມກວ້າງໃຫ້ກັບຫົວລູກສອນ.</ahelp>"

#. XhAhR
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"hd_id3154935\n"
"help.text"
msgid "Center"
msgstr "ກາງ"

#. J96mW
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"par_id3153526\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/linetabpage/TSB_CENTER_END\">Places the center of the arrowhead(s) on the endpoint(s) of the selected line.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/linetabpage/TSB_CENTER_END\">ວາງຈຸດໃຈກາງຂອງຫົວລູກສອນໃສ່ຈຸດປາຍຂອງເສັ້ນທີ່ເລືອກ.</ahelp>"

#. 6CxtP
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"hd_id3154072\n"
"help.text"
msgid "Synchronize ends"
msgstr "ປະສານງານສ່ວນປາຍ"

#. RfRmR
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"par_id3154365\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/linetabpage/CBX_SYNCHRONIZE\">Automatically updates both arrowhead settings when you enter a different width, select a different arrowhead style,or center an arrowhead.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/linetabpage/CBX_SYNCHRONIZE\">ປັບປຸງການຕັ້ງຄ່າຫົວລູກສອນທັງສອງໂດຍອັດຕະໂນມັດ ເມື່ອທ່ານປ້ອນຄວາມກວ້າງທີ່ຕ່າງກັນ, ເລືອກຮູບແບບຫົວລູກສອນທີ່ຕ່າງກັນ ຫຼື ວາງຫົວລູກສອນໄວ້ກາງ.</ahelp>"

#. UxexT
#: 05200100.xhp
msgctxt ""
"05200100.xhp\n"
"hd_id3154580\n"
"help.text"
msgid "Corner and cap styles"
msgstr "ຮູບແບບມຸມ ແລະ ຫົວປິດ"

#. GEsVi
