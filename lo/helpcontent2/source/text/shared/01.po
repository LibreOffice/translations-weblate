#: 01010200.xhp
msgctxt ""
"01010200.xhp\n"
"par_id3145071\n"
"help.text"
msgid "<variable id=\"etikett\"><ahelp hid=\".uno:InsertLabels\">Allows you to create labels. Labels are created in a text document.</ahelp> You can print labels using a predefined or a custom paper format.</variable>"
msgstr "<variable id=\"etikett\"><ahelp hid=\".uno:InsertLabels\">ອະນຸຍາດໃຫ້ທ່ານສ້າງປ້າຍຊື່. ປ້າຍຊື່ຖືກສ້າງຂຶ້ນໃນເອກະສານຂໍ້ຄວາມ.</ahelp> ທ່ານສາມາດພິມປ້າຍຊື່ໂດຍໃຊ້ຮູບແບບເຈ້ຍທີ່ກໍານົດໄວ້ລ່ວງໜ້າ ຫຼື ແບບກໍານົດເອງ.</variable>"

#. zHTFz
#: 01010200.xhp
msgctxt ""
"01010200.xhp\n"
"par_id3145314\n"
"help.text"
msgid "You can also print a single label or an entire sheet of labels."
msgstr "ທ່ານຍັງສາມາດພິມປ້າຍຊື່ອັນດຽວ ຫຼື ປ້າຍຊື່ທັງໝົດແຜ່ນໄດ້."

#. GREF4
#: 01010200.xhp
msgctxt ""
"01010200.xhp\n"
"hd_id3145383\n"
"help.text"
msgid "New Document"
msgstr "ເອກະສານໃໝ່"

#. nzh5v
#: 01010200.xhp
msgctxt ""
"01010200.xhp\n"
"par_id3154810\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/labeldialog/ok\">Creates a new document for editing.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/labeldialog/ok\">ສ້າງເອກະສານໃໝ່ເພື່ອແກ້ໄຂ.</ahelp>"

#. gKCyo
#: 01010200.xhp
msgctxt ""
"01010200.xhp\n"
"par_id3144438\n"
"help.text"
msgid "<link href=\"text/shared/guide/labels.xhp\">Creating labels</link>"
msgstr "<link href=\"text/shared/guide/labels.xhp\">ການສ້າງປ້າຍຊື່</link>"

#. hAQJr
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"tit\n"
"help.text"
msgid "Labels"
msgstr "ປ້າຍຊື່"

#. fqUEK
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3149987\n"
"help.text"
msgid "<link href=\"text/shared/01/01010201.xhp\">Labels</link>"
msgstr "<link href=\"text/shared/01/01010201.xhp\">ປ້າຍຊື່</link>"

#. BVUFA
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3152952\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/CardMediumPage\">Specify the label text and choose the paper size for the label.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/CardMediumPage\">ລະບຸຂໍ້ຄວາມປ້າຍຊື່ ແລະ ເລືອກຂະໜາດເຈ້ຍສໍາລັບປ້າຍຊື່.</ahelp>"

#. iFEBm
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3158397\n"
"help.text"
msgid "Inscription"
msgstr "ຂໍ້ຄວາມເທິງປ້າຍ"

#. 4JwqL
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3154350\n"
"help.text"
msgid "Enter or insert the text that you want to appear on the label(s)."
msgstr "ປ້ອນ ຫຼື ແຊກຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ປາກົດຢູ່ໃນປ້າຍຊື່."

#. BF73a
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3147294\n"
"help.text"
msgid "Label text"
msgstr "ຂໍ້ຄວາມປ້າຍຊື່"

#. tWpfy
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3150838\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/textview\">Enter the text that you want to appear on the label. You can also insert a database field.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/textview\">ປ້ອນຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການໃຫ້ປາກົດຢູ່ໃນປ້າຍຊື່. ທ່ານຍັງສາມາດແຊກຟີວຖານຂໍ້ມູນໄດ້.</ahelp>"

#. fKrBC
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3150603\n"
"help.text"
msgid "Address"
msgstr "ທີ່ຢູ່"

#. a8FaF
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3153089\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/address\">Creates a label with your return address. Text that is currently in the <emph>Label text</emph> box is overwritten.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/address\">ສ້າງປ້າຍຊື່ທີ່ມີທີ່ຢູ່ສົ່ງຄືນຂອງທ່ານ. ຂໍ້ຄວາມທີ່ຢູ່ໃນກ່ອງ <emph>ຂໍ້ຄວາມປ້າຍຊື່</emph> ໃນປັດຈຸບັນຈະຖືກຂຽນທັບ.</ahelp>"

#. 3sB9b
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3155555\n"
"help.text"
msgid "To change your return address, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01010100.xhp\"><emph>%PRODUCTNAME</emph></link>, and then click on the <emph>User Data</emph> tab."
msgstr "ເພື່ອປ່ຽນທີ່ຢູ່ສົ່ງຄືນຂອງທ່ານ, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ຄວາມມັກ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - </emph><link href=\"text/shared/optionen/01010100.xhp\"><emph>%PRODUCTNAME</emph></link>, ແລ້ວຄລິກທີ່ແຖບ <emph>ຂໍ້ມູນຜູ້ໃຊ້</emph>."

#. J7aAs
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3147557\n"
"help.text"
msgid "Database"
msgstr "ຖານຂໍ້ມູນ"

#. SpC3e
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3148620\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/database\">Select the database that you want to use as the data source for your label.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/database\">ເລືອກຖານຂໍ້ມູນທີ່ທ່ານຕ້ອງການໃຊ້ເປັນແຫຼ່ງຂໍ້ມູນສໍາລັບປ້າຍຊື່ຂອງທ່ານ.</ahelp>"

#. fySCS
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3149388\n"
"help.text"
msgid "Table"
msgstr "ຕາຕະລາງ"

#. Gg9dS
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3149827\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/table\">Select the database table containing the field(s) that you want to use in your label.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/table\">ເລືອກຕາຕະລາງຖານຂໍ້ມູນທີ່ມີຟີວທີ່ທ່ານຕ້ອງການໃຊ້ໃນປ້າຍຊື່ຂອງທ່ານ.</ahelp>"

#. pRqak
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3155391\n"
"help.text"
msgid "Database field"
msgstr "ຟີວຖານຂໍ້ມູນ"

#. EbjAB
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3149750\n"
"help.text"
msgid "<ahelp hid=\".\">Select the database field that you want, and then click the arrow to the left of this box to insert the field into the <emph>Label text</emph> box.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຟີວຖານຂໍ້ມູນທີ່ທ່ານຕ້ອງການ, ແລ້ວຄລິກທີ່ລູກສອນທາງຊ້າຍຂອງກ່ອງນີ້ເພື່ອແຊກຟີວເຂົ້າໃນກ່ອງ <emph>ຂໍ້ຄວາມປ້າຍຊື່</emph>.</ahelp>"

#. BKEkN
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3152780\n"
"help.text"
msgid "The name of the database field is bounded by brackets in the <emph>Label text</emph> box. If you want, you can separate database fields with spaces. Press <emph>Enter</emph> to insert a database field on a new line."
msgstr "ຊື່ຂອງຟີວຖານຂໍ້ມູນຈະຖືກລ້ອມຮອບດ້ວຍວົງຂໍໃນກ່ອງ <emph>ຂໍ້ຄວາມປ້າຍຊື່</emph>. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດແຍກຟີວຖານຂໍ້ມູນດ້ວຍຍະຫວ່າງ. ກົດ <emph>Enter</emph> ເພື່ອແຊກຟີວຖານຂໍ້ມູນໃນແຖວໃໝ່."

#. x3AQU
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3147653\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. KXRDA
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3149762\n"
"help.text"
msgid "You can select a predefined size format for your label or a size format that you specify on the <emph>Format</emph> tab."
msgstr "ທ່ານສາມາດເລືອກຮູບແບບຂະໜາດທີ່ກຳນົດໄວ້ລ່ວງໜ້າສຳລັບປ້າຍຊື່ຂອງທ່ານ ຫຼື ຮູບແບບຂະໜາດທີ່ທ່ານລະບຸໄວ້ໃນແຖບ <emph>ຮູບແບບ</emph>."

#. uboZk
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3154143\n"
"help.text"
msgid "Continuous"
msgstr "ຕໍ່ເນື່ອງ"

#. Cm3vB
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3151339\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/continuous\">Prints labels on continuous paper.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/continuous\">ພິມປ້າຍຊື່ໃສ່ເຈ້ຍຕໍ່ເນື່ອງ.</ahelp>"

#. 74edJ
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3150131\n"
"help.text"
msgid "Sheet"
msgstr "ແຜ່ນ"

#. cB3Yn
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3159167\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/sheet\">Prints labels on individual sheets.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/sheet\">ພິມປ້າຍຊື່ໃສ່ແຜ່ນແຍກຕ່າງຫາກ.</ahelp>"

#. KtWVV
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3156327\n"
"help.text"
msgid "Brand"
msgstr "ຍີ່ຫໍ້"

#. UmzFt
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3150466\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/brand\">Select the brand of paper that you want to use.</ahelp> Each brand has its own size formats."
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/brand\">ເລືອກຍີ່ຫໍ້ເຈ້ຍທີ່ທ່ານຕ້ອງການໃຊ້.</ahelp> ແຕ່ລະຍີ່ຫໍ້ມີຮູບແບບຂະໜາດຂອງຕົນເອງ."

#. BdKaj
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3153821\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. 7BjGj
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3149235\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/cardmediumpage/type\">Select the size format that you want to use. The available formats depend on the brand on what you selected in the <emph>Brand</emph> list. If you want to use a custom label format, select <emph>[User]</emph>, and then click the <link href=\"text/shared/01/01010202.xhp\"><emph>Format</emph></link> tab to define the format.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/cardmediumpage/type\">ເລືອກຮູບແບບຂະໜາດທີ່ທ່ານຕ້ອງການໃຊ້. ຮູບແບບທີ່ມີໃຫ້ຂຶ້ນກັບຍີ່ຫໍ້ທີ່ທ່ານເລືອກໃນລາຍການ <emph>ຍີ່ຫໍ້</emph>. ຖ້າທ່ານຕ້ອງການໃຊ້ຮູບແບບປ້າຍຊື່ແບບກໍານົດເອງ, ໃຫ້ເລືອກ <emph>[ຜູ້ໃຊ້]</emph>, ແລ້ວຄລິກທີ່ແຖບ <link href=\"text/shared/01/01010202.xhp\"><emph>ຮູບແບບ</emph></link> ເພື່ອກຳນົດຮູບແບບ.</ahelp>"

#. ndEoL
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"hd_id3153828\n"
"help.text"
msgid "Info"
msgstr "ຂໍ້ມູນ"

#. UDVnD
#: 01010201.xhp
msgctxt ""
"01010201.xhp\n"
"par_id3152349\n"
"help.text"
msgid "The paper type, the dimensions of the label and the labels grid are displayed at the bottom of the <emph>Format</emph> area."
msgstr "ປະເພດເຈ້ຍ, ຂະໜາດຂອງປ້າຍຊື່ ແລະ ຕາຕາລາງປ້າຍຊື່ຈະຖືກສະແດງຢູ່ທາງລຸ່ມຂອງພື້ນທີ່ <emph>ຮູບແບບ</emph>."

#. 4RW4s
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"tit\n"
"help.text"
msgid "Format"
msgstr "ຮູບແບບ"

#. UTYLn
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"hd_id3151260\n"
"help.text"
msgid "<link href=\"text/shared/01/01010202.xhp\">Format</link>"
msgstr "<link href=\"text/shared/01/01010202.xhp\">ຮູບແບບ</link>"

#. bNzeF
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"par_id3153255\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/labelformatpage/LabelFormatPage\">Set paper formatting options.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/labelformatpage/LabelFormatPage\">ຕັ້ງຄ່າຕົວເລືອກການຈັດຮູບແບບເຈ້ຍ.</ahelp>"

#. V9kbG
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"hd_id3159194\n"
"help.text"
msgid "Horizontal pitch"
msgstr "ໄລຍະຫ່າງລວງນອນ"

#. QfbC5
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"par_id3154186\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/labelformatpage/hori\">Displays the distance between the left edges of adjacent labels or business cards. If you are defining a custom format, enter a value here.</ahelp>"
msgstr "<ahelp hid=\"modules/swriter/ui/labelformatpage/hori\">ສະແດງໄລຍະຫ່າງລະຫວ່າງຂອບຊ້າຍຂອງປ້າຍຊື່ ຫຼື ນາມບັດທີ່ຢູ່ຕິດກັນ. ຖ້າທ່ານກຳລັງກຳນົດຮູບແບບເອງ, ໃຫ້ປ້ອນຄ່າຢູ່ທີ່ນີ້.</ahelp>"

#. C2ZWV
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"hd_id3155555\n"
"help.text"
msgid "Vertical pitch"
msgstr "ໄລຍະຫ່າງລວງຕັ້ງ"

#. NdNAA
#: 01010202.xhp
msgctxt ""
"01010202.xhp\n"
"par_id3152425\n"
"help.text"
msgid "<ahelp hid=\"modules/swriter/ui/labelformatpage/vert\">Displays the distance between the top edges of adjacent labels or business cards. If you are defining a custom format, enter a value here.</ahelp>"
