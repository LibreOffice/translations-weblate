msgid "On the <emph>Track Changes</emph> toolbar, click"
msgstr ""

#. RncNB
#: 02240000.xhp
msgctxt ""
"02240000.xhp\n"
"par_id3153662\n"
"help.text"
msgid "The contents of footnotes, headers, frames and fields are ignored."
msgstr "ເນື້ອໃນຂອງເຊິງອັດ, ຫົວເອກະສານ, ເຟຣມ ແລະ ເຂດຂໍ້ມູນຈະຖືກລະເລີຍ."

#. X7CFt
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"tit\n"
"help.text"
msgid "Bibliography Database"
msgstr "ຖານຂໍ້ມູນບັນນານຸກົມ"

#. A9yEA
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3150999\n"
"help.text"
msgid "<link href=\"text/shared/01/02250000.xhp\">Bibliography Database</link>"
msgstr "<link href=\"text/shared/01/02250000.xhp\">ຖານຂໍ້ມູນບັນນານຸກົມ</link>"

#. 9GNiP
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3149119\n"
"help.text"
msgid "<variable id=\"litdattext\"><ahelp hid=\"modules/sbibliography/ui/toolbar/TBC_BT_COL_ASSIGN\">Insert, delete, edit, and organize records in the bibliography database.</ahelp></variable>"
msgstr "<variable id=\"litdattext\"><ahelp hid=\"modules/sbibliography/ui/toolbar/TBC_BT_COL_ASSIGN\">ແຊກ, ລຶບ, ແກ້ໄຂ ແລະ ຈັດລະບຽບບັນທຶກໃນຖານຂໍ້ມູນບັນນານຸກົມ.</ahelp></variable>"

#. KN7Zq
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3149346\n"
"help.text"
msgid "If the fields in your database are read-only, ensure that the data source view is closed."
msgstr "ຖ້າເຂດຂໍ້ມູນໃນຖານຂໍ້ມູນຂອງທ່ານເປັນແບບອ່ານຢ່າງດຽວ, ໃຫ້ແນ່ໃຈວ່າການເບິ່ງແຫຼ່ງຂໍ້ມູນນັ້ນຖືກປິດໄວ້."

#. EnCzF
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3150506\n"
"help.text"
msgid "The supplied bibliography database contains sample records of books."
msgstr "ຖານຂໍ້ມູນບັນນານຸກົມທີ່ໃຫ້ມານັ້ນປະກອບດ້ວຍຕົວຢ່າງບັນທຶກຂອງປຶ້ມ."

#. RMrxZ
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3155356\n"
"help.text"
msgid "Use the toolbar to select a table in the bibliography database, to search for records, or to sort the records using filters."
msgstr "ໃຊ້ແຖບເຄື່ອງມືເພື່ອເລືອກຕາຕະລາງໃນຖານຂໍ້ມູນບັນນານຸກົມ, ເພື່ອຄົ້ນຫາບັນທຶກ, ຫຼື ເພື່ອຈັດລຽງບັນທຶກໂດຍການໃຊ້ຕົວຕອງ."

#. nWNGW
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3163802\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the available tables in the current database. Click a name in the list to display the records for that table.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລາຍຊື່ຕາຕະລາງທີ່ມີຢູ່ໃນຖານຂໍ້ມູນປັດຈຸບັນ. ຄລິກທີ່ຊື່ໃນລາຍຊື່ເພື່ອສະແດງບັນທຶກສຳລັບຕາຕະລາງນັ້ນ.</ahelp>"

#. 27ffQ
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3158432\n"
"help.text"
msgid "<ahelp hid=\"SVX_HID_GRID_TRAVEL_FIRST\" visibility=\"hidden\">Go to the first record in the table.</ahelp>"
msgstr "<ahelp hid=\"SVX_HID_GRID_TRAVEL_FIRST\" visibility=\"hidden\">ໄປຫາບັນທຶກທຳອິດໃນຕາຕະລາງ.</ahelp>"

#. ScjDp
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3149192\n"
"help.text"
msgid "<ahelp hid=\"SVX_HID_GRID_TRAVEL_PREV\" visibility=\"hidden\">Go to the previous record in the table.</ahelp>"
msgstr "<ahelp hid=\"SVX_HID_GRID_TRAVEL_PREV\" visibility=\"hidden\">ໄປຫາບັນທຶກກ່ອນໜ້າໃນຕາຕະລາງ.</ahelp>"

#. ZCdyB
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3146795\n"
"help.text"
msgid "<ahelp hid=\"SVX_HID_GRID_TRAVEL_NEXT\" visibility=\"hidden\">Go to the next record in the table.</ahelp>"
msgstr "<ahelp hid=\"SVX_HID_GRID_TRAVEL_NEXT\" visibility=\"hidden\">ໄປຫາບັນທຶກຖັດໄປໃນຕາຕະລາງ.</ahelp>"

#. nwCYw
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3144760\n"
"help.text"
msgid "<ahelp hid=\"SVX_HID_GRID_TRAVEL_LAST\" visibility=\"hidden\">Go to the last record in the table.</ahelp>"
msgstr "<ahelp hid=\"SVX_HID_GRID_TRAVEL_LAST\" visibility=\"hidden\">ໄປຫາບັນທຶກສຸດທ້າຍໃນຕາຕະລາງ.</ahelp>"

#. 9yCHD
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3157960\n"
"help.text"
msgid "<ahelp hid=\"SVX_HID_GRID_TRAVEL_ABSOLUTE\" visibility=\"hidden\">Type the number of the record that you want to display, and then press <emph>Enter</emph>.</ahelp>"
msgstr "<ahelp hid=\"SVX_HID_GRID_TRAVEL_ABSOLUTE\" visibility=\"hidden\">ພິມໝາຍເລກຂອງບັນທຶກທີ່ທ່ານຕ້ອງການໃຫ້ສະແດງ, ແລ້ວກົດ <emph>Enter</emph>.</ahelp>"

#. AKRDd
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3150868\n"
"help.text"
msgid "Inserting a New Record"
msgstr "ການແຊກບັນທຶກໃໝ່"

#. 5kaPe
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3149168\n"
"help.text"
msgid "<ahelp hid=\"HID_GRID_TRAVEL_NEW\" visibility=\"hidden\">Inserts a new record into the current table.</ahelp> To create a record, click the asterisk (<emph>*</emph>) button at the bottom of the table view. An empty row is added at the end of the table."
msgstr "<ahelp hid=\"HID_GRID_TRAVEL_NEW\" visibility=\"hidden\">ແຊກບັນທຶກໃໝ່ເຂົ້າໃນຕາຕະລາງປັດຈຸບັນ.</ahelp> ເພື່ອສ້າງບັນທຶກ, ໃຫ້ຄລິກທີ່ປຸ່ມດອກຈັນ (<emph>*</emph>) ຢູ່ດ້ານລຸ່ມຂອງມຸມມອງຕາຕະລາງ. ແຖວຫວ່າງຈະຖືກເພີ່ມເຂົ້າໃນທ້າຍຕາຕະລາງ."

#. fQWEB
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3152920\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select the type of record that you want to create. $[officename] inserts a number in the <emph>Type</emph> column of the record that corresponds to the type that you select here.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກປະເພດຂອງບັນທຶກທີ່ທ່ານຕ້ອງການສ້າງ. $[officename] ຈະແຊກໝາຍເລກໃນຖັນ <emph>ປະເພດ</emph> ຂອງບັນທຶກທີ່ກົງກັບປະເພດທີ່ທ່ານເລືອກຢູ່ນີ້.</ahelp>"

#. mF9iu
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3156423\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter a short name for the record. The short name appears in the <emph>Identifier</emph> column in the list of records.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຊື່ຫຍໍ້ສຳລັບບັນທຶກ. ຊື່ຫຍໍ້ຈະປະກົດຂຶ້ນໃນຖັນ <emph>ຕົວລະບຸ</emph> ໃນລາຍຊື່ຂອງບັນທຶກ.</ahelp>"

#. JhooP
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3155994\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter additional information for the selected record. If you want, you can also enter the information in the corresponding field in the table.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຂໍ້ມູນເພີ່ມເຕີມສຳລັບບັນທຶກທີ່ເລືອກ. ຖ້າທ່ານຕ້ອງການ, ທ່ານຍັງສາມາດປ້ອນຂໍ້ມູນໃນເຂດຂໍ້ມູນທີ່ກ່ຽວຂ້ອງໃນຕາຕະລາງໄດ້.</ahelp>"

#. N4J92
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3163716\n"
"help.text"
msgid "Finding and Filtering Records"
msgstr "ການຄົ້ນຫາ ແລະ ການຕອງບັນທຶກ"

#. njWSY
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3147478\n"
"help.text"
msgid "You can search for records by matching a keyword to a field entry."
msgstr "ທ່ານສາມາດຄົ້ນຫາບັນທຶກໄດ້ໂດຍການຈັບຄູ່ຄຳສຳຄັນກັບຂໍ້ມູນທີ່ປ້ອນໃນເຂດຂໍ້ມູນ."

#. xFSJ3
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3159181\n"
"help.text"
msgid "Entering Search key"
msgstr "ການປ້ອນຄີການຄົ້ນຫາ"

#. tRAvm
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3159125\n"
"help.text"
msgid "<ahelp hid=\".uno:Bib/query\">Type the information that you want to search for, and then press <emph>Enter</emph>. To change the filter options for the search, long-click the <emph>AutoFilter</emph> icon, and then select a different data field. You can use wildcards such as <emph>%</emph> or <emph>*</emph> for any number of characters, and <emph>_</emph> or <emph>?</emph> for one character in your search. To display all of the records in the table, clear this box, and then press <emph>Enter</emph>. </ahelp>"
msgstr "<ahelp hid=\".uno:Bib/query\">ພິມຂໍ້ມູນທີ່ທ່ານຕ້ອງການຄົ້ນຫາ, ແລ້ວກົດ <emph>Enter</emph>. ເພື່ອປ່ຽນຕົວເລືອກຕົວຕອງສຳລັບການຄົ້ນຫາ, ໃຫ້ຄລິກຄ້າງທີ່ໄອຄອນ <emph>ຕົວຕອງອັດຕະໂນມັດ</emph>, ແລ້ວເລືອກເຂດຂໍ້ມູນທີ່ແຕກຕ່າງ. ທ່ານສາມາດໃຊ້ຕົວແທນເຊັ່ນ <emph>%</emph> ຫຼື <emph>*</emph> ສຳລັບຕົວອັກສອນໃດໆກໍໄດ້, ແລະ <emph>_</emph> ຫຼື <emph>?</emph> ສຳລັບຕົວອັກສອນດຽວໃນການຄົ້ນຫາຂອງທ່ານ. ເພື່ອສະແດງບັນທຶກທັງໝົດໃນຕາຕະລາງ, ໃຫ້ລຶບຂໍ້ມູນໃນຫ້ອງນີ້ອອກ, ແລ້ວກົດ <emph>Enter</emph>. </ahelp>"

#. sHnff
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3155511\n"
"help.text"
msgid "AutoFilter"
msgstr "ຕົວຕອງອັດຕະໂນມັດ"

#. VbBBf
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3146975\n"
"help.text"
msgid "<ahelp hid=\".uno:Bib/autoFilter\">Long-click to select the data field that you want to search using the term that you entered in the <emph>Search Key</emph> box. You can only search one data field.</ahelp>"
msgstr "<ahelp hid=\".uno:Bib/autoFilter\">ຄລິກຄ້າງເພື່ອເລືອກເຂດຂໍ້ມູນທີ່ທ່ານຕ້ອງການຄົ້ນຫາໂດຍໃຊ້ຄຳສັບທີ່ທ່ານປ້ອນເຂົ້າໃນຫ້ອງ <emph>ຄີການຄົ້ນຫາ</emph>. ທ່ານສາມາດຄົ້ນຫາໄດ້ພຽງເຂດຂໍ້ມູນດຽວເທົ່ານັ້ນ.</ahelp>"

#. bsAEt
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3149664\n"
"help.text"
msgid "The list of table records is automatically updated to match the new filter settings."
msgstr "ລາຍຊື່ຂອງບັນທຶກໃນຕາຕະລາງຈະຖືກອັບເດດໂດຍອັດຕະໂນມັດເພື່ອໃຫ້ກົງກັບການຕັ້ງຄ່າຕົວຕອງໃໝ່."

#. CSNFG
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3145590\n"
"help.text"
msgid "<ahelp hid=\".\">Use the <emph>Standard Filter</emph> to refine and to combine <emph>AutoFilter</emph> search options.</ahelp>"
msgstr "<ahelp hid=\".\">ໃຊ້ <emph>ຕົວຕອງມາດຕະຖານ</emph> ເພື່ອປັບປຸງ ແລະ ເພື່ອຮວມຕົວເລືອກການຄົ້ນຫາຂອງ <emph>ຕົວຕອງອັດຕະໂນມັດ</emph>.</ahelp>"

#. J6rp7
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3155311\n"
"help.text"
msgid "<ahelp hid=\".\">To display all of the records in a table, click the <emph>Reset Filter</emph> icon.</ahelp>"
msgstr "<ahelp hid=\".\">ເພື່ອສະແດງບັນທຶກທັງໝົດໃນຕາຕະລາງ, ໃຫ້ຄລິກທີ່ໄອຄອນ <emph>ຕັ້ງຄ່າຕົວຕອງໃໝ່</emph>.</ahelp>"

#. 2CDge
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3147580\n"
"help.text"
msgid "Deleting a Record"
msgstr "ການລຶບບັນທຶກ"

#. WH2dG
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3154471\n"
"help.text"
msgid "To delete a record in the current table, right-click the row header of the record, and then select <emph>Delete</emph>. <ahelp hid=\"SID_FM_DELETEROWS\" visibility=\"hidden\">Deletes the selected record.</ahelp>"
msgstr "ເພື່ອລຶບບັນທຶກໃນຕາຕະລາງປັດຈຸບັນ, ໃຫ້ຄລິກຂວາທີ່ຫົວແຖວຂອງບັນທຶກ, ແລ້ວເລືອກ <emph>ລຶບ</emph>. <ahelp hid=\"SID_FM_DELETEROWS\" visibility=\"hidden\">ລຶບບັນທຶກທີ່ເລືອກ.</ahelp>"

#. 2aBAM
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3152941\n"
"help.text"
msgid "Changing the data source"
msgstr "ການປ່ຽນແຫຼ່ງຂໍ້ມູນ"

#. nYyBQ
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3147214\n"
"help.text"
msgid "Data Source"
msgstr "ແຫຼ່ງຂໍ້ມູນ"

#. hkGWp
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3151118\n"
"help.text"
msgid "<ahelp hid=\".uno:Bib/sdbsource\">Select the data source for the bibliography database.</ahelp>"
msgstr "<ahelp hid=\".uno:Bib/sdbsource\">ເລືອກແຫຼ່ງຂໍ້ມູນສຳລັບຖານຂໍ້ມູນບັນນານຸກົມ.</ahelp>"

#. h2RiF
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"hd_id3145645\n"
"help.text"
msgid "Column Arrangement"
msgstr "ການຈັດລຽງຖັນ"

#. sjtG2
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3151282\n"
"help.text"
msgid "<ahelp hid=\".uno:Bib/Mapping\">Lets you map the column headings to data fields from a different data source. To define a different data source for your bibliography, click the <emph>Data Source</emph> button on the record's <emph>Object</emph> bar.</ahelp>"
msgstr "<ahelp hid=\".uno:Bib/Mapping\">ຊ່ວຍໃຫ້ທ່ານຈັບຄູ່ຫົວຂໍ້ຖັນກັບເຂດຂໍ້ມູນຈາກແຫຼ່ງຂໍ້ມູນທີ່ແຕກຕ່າງກັນ. ເພື່ອຂຶ້ນທະບຽນແຫຼ່ງຂໍ້ມູນທີ່ແຕກຕ່າງສຳລັບບັນນານຸກົມຂອງທ່ານ, ໃຫ້ຄລິກທີ່ປຸ່ມ <emph>ແຫຼ່ງຂໍ້ມູນ</emph> ເທິງແຖບ <emph>ວັດຖຸ</emph> ຂອງບັນທຶກ.</ahelp>"

#. vEPVr
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3144767\n"
"help.text"
msgid "<ahelp hid=\"modules/sbibliography/ui/mappingdialog/MappingDialog\">Select the data field that you want to map to the current <emph>Column name</emph>. To change the available data fields, select a different data source for your bibliography.</ahelp>"
msgstr "<ahelp hid=\"modules/sbibliography/ui/mappingdialog/MappingDialog\">ເລືອກເຂດຂໍ້ມູນທີ່ທ່ານຕ້ອງການຈັບຄູ່ກັບ <emph>ຊື່ຖັນ</emph> ປັດຈຸບັນ. ເພື່ອປ່ຽນເຂດຂໍ້ມູນທີ່ມີຢູ່, ໃຫ້ເລືອກແຫຼ່ງຂໍ້ມູນທີ່ແຕກຕ່າງສຳລັບບັນນານຸກົມຂອງທ່ານ.</ahelp>"

#. WCn4f
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3153947\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Deletes the current record.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບບັນທຶກປັດຈຸບັນ.</ahelp>"

#. 2BL5R
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3151019\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lets you choose a different data source for your bibliography.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຊ່ວຍໃຫ້ທ່ານເລືອກແຫຼ່ງຂໍ້ມູນທີ່ແຕກຕ່າງສຳລັບບັນນານຸກົມຂອງທ່ານ.</ahelp>"

#. Fb8Wc
#: 02250000.xhp
msgctxt ""
"02250000.xhp\n"
"par_id3153730\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Inserts a new record into the current table.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ແຊກບັນທຶກໃໝ່ເຂົ້າໃນຕາຕະລາງປັດຈຸບັນ.</ahelp>"

