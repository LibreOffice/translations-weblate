"help.text"
msgid "Click on the hamburger icon and then choose Add to add a new toolbar."
msgstr "ຄລິກທີ່ໄອຄອນສາມຂີດ (hamburger) ແລ້ວເລືອກ ເພີ່ມ ເພື່ອເພີ່ມແຖບເຄື່ອງມືໃໝ່."

#. DW7iQ
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id651514304289436\n"
"help.text"
msgid "Delete"
msgstr "ລຶບ"

#. EsQEM
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id61514304306614\n"
"help.text"
msgid "Click on the hamburger icon and then choose Delete to delete the toolbar."
msgstr "ຄລິກທີ່ໄອຄອນສາມຂີດ (hamburger) ແລ້ວເລືອກ ລຶບ ເພື່ອລຶບແຖບເຄື່ອງມື."

#. VQG5w
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_idN10910\n"
"help.text"
msgid "You can only delete custom toolbar and custom toolbar entries."
msgstr "ທ່ານສາມາດລຶບໄດ້ສະເພາະແຖບເຄື່ອງມືທີ່ປັບແຕ່ງເອງ ແລະ ລາຍການໃນແຖບເຄື່ອງມືທີ່ປັບແຕ່ງເອງເທົ່ານັ້ນ."

#. kELAT
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id961514303975994\n"
"help.text"
msgid "Right Arrow button"
msgstr "ປຸ່ມລູກສອນຂວາ"

#. zGmTS
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id941514303982378\n"
"help.text"
msgid "Click on the right arrow button to select a function on the left display box and copy to the right display box. This will add the function to the selected toolbar."
msgstr "ຄລິກທີ່ປຸ່ມລູກສອນຂວາເພື່ອເລືອກຟັງຊັນຈາກກ່ອງສະແດງຜົນທາງຊ້າຍ ແລະ ສຳເນົາໄປຍັງກ່ອງສະແດງຜົນທາງຂວາ. ນີ້ຈະເປັນການເພີ່ມຟັງຊັນເຂົ້າໃນແຖບເຄື່ອງມືທີ່ເລືອກ."

#. rUgGC
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id161514303992615\n"
"help.text"
msgid "Left Arrow button"
msgstr "ປຸ່ມລູກສອນຊ້າຍ"

#. LT4yP
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id361514304000470\n"
"help.text"
msgid "Click on the left arrow button to remove the selected command from the current toolbar."
msgstr "ຄລິກທີ່ປຸ່ມລູກສອນຊ້າຍເພື່ອລຶບຄຳສັ່ງທີ່ເລືອກອອກຈາກແຖບເຄື່ອງມືປັດຈຸບັນ."

#. gotpL
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id761514304005994\n"
"help.text"
msgid "Up and Down Arrow buttons"
msgstr "ປຸ່ມລູກສອນຂຶ້ນ ແລະ ລົງ"

#. byaLD
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id761514304011466\n"
"help.text"
msgid "Click on the Up or Down arrows on the right to move the selected command upward or downward in the list of displayed toolbar commands."
msgstr "ຄລິກທີ່ລູກສອນຂຶ້ນ ຫຼື ລົງທາງດ້ານຂວາເພື່ອຍ້າຍຄຳສັ່ງທີ່ເລືອກຂຶ້ນ ຫຼື ລົງໃນລາຍການຄຳສັ່ງແຖບເຄື່ອງມືທີ່ສະແດງ."

#. aadzx
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id301514305066046\n"
"help.text"
msgid "You can drag and drop the selected command to move it to the position you want."
msgstr "ທ່ານສາມາດລາກ ແລະ ວາງຄຳສັ່ງທີ່ເລືອກເພື່ອຍ້າຍມັນໄປຍັງຕຳແໜ່ງທີ່ທ່ານຕ້ອງການ."

#. h8djb
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id321514310951605\n"
"help.text"
msgid "Insert"
msgstr "ແຊກ"

#. JnskE
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id981514310786648\n"
"help.text"
msgid "<emph>Insert Separator</emph>: Add a separator mark to improve toolbar readability and to group commands by subject."
msgstr "<emph>ແຊກຕົວແບ່ງ</emph>: ເພີ່ມເຄື່ອງໝາຍຕົວແບ່ງເພື່ອໃຫ້ແຖບເຄື່ອງມືອ່ານງ່າຍຂຶ້ນ ແລະ ເພື່ອຈັດກຸ່ມຄຳສັ່ງຕາມຫົວຂໍ້."

#. ZPoWt
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id341514311059169\n"
"help.text"
msgid "Modify"
msgstr "ແກ້ໄຂ"

#. YAB2z
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id111514311020590\n"
"help.text"
msgid "<emph>Rename</emph>: Rename the entry."
msgstr "<emph>ປ່ຽນຊື່</emph>: ປ່ຽນຊື່ລາຍການ."

#. oyCC6
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_idN106B2\n"
"help.text"
msgid "<emph>Change Icon</emph>: Opens the <link href=\"text/shared/01/06140402.xhp\">Change Icon</link> dialog, where you can assign a different icon to the current command."
msgstr "<emph>ປ່ຽນໄອຄອນ</emph>: ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/06140402.xhp\">ປ່ຽນໄອຄອນ</link>, ເຊິ່ງທ່ານສາມາດກຳນົດໄອຄອນອື່ນໃຫ້ກັບຄຳສັ່ງປັດຈຸບັນ."

#. Gja5A
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_idN106B8\n"
"help.text"
msgid "<emph>Reset Icon</emph>: Resets the icon to the default icon."
msgstr "<emph>ຕັ້ງຄ່າໄອຄອນໃໝ່</emph>: ຕັ້ງຄ່າໄອຄອນກັບຄືນເປັນໄອຄອນເລີ່ມຕົ້ນ."

#. iABdR
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id371514386517453\n"
"help.text"
msgid "<emph>Restore Default Command</emph>: Restores the default command."
msgstr "<emph>ຄືນຄ່າຄຳສັ່ງເລີ່ມຕົ້ນ</emph>: ຄືນຄ່າໃຫ້ກັບຄຳສັ່ງເລີ່ມຕົ້ນ."

#. UcFYP
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"hd_id641514311180774\n"
"help.text"
msgid "Defaults"
msgstr "ຄ່າເລີ່ມຕົ້ນ"

#. 9mh9d
#: 06140400.xhp
msgctxt ""
"06140400.xhp\n"
"par_id851514311086417\n"
"help.text"
msgid "Deletes all changes previously made to this toolbar."
msgstr "ລຶບການປ່ຽນແປງທັງໝົດທີ່ເຄີຍເຮັດກັບແຖບເຄື່ອງມືນີ້."

#. svntD
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"tit\n"
"help.text"
msgid "Change Icon"
msgstr "ປ່ຽນໄອຄອນ"

#. VF9df
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN10543\n"
"help.text"
msgid "Change Icon"
msgstr "ປ່ຽນໄອຄອນ"

#. jWouu
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN10547\n"
"help.text"
msgid "Icons"
msgstr "ໄອຄອນ"

#. BRfDs
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN1054B\n"
"help.text"
msgid "Displays the available icons in %PRODUCTNAME. To replace the icon that you selected in the <link href=\"text/shared/01/06140400.xhp\">Customize</link> dialog, click an icon, then click the <emph>OK</emph> button."
msgstr "ສະແດງໄອຄອນທີ່ມີໃຫ້ໃຊ້ໃນ %PRODUCTNAME. ເພື່ອປ່ຽນແທນໄອຄອນທີ່ທ່ານເລືອກໃນກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/06140400.xhp\">ປັບແຕ່ງ</link>, ໃຫ້ຄລິກທີ່ໄອຄອນໃດໜຶ່ງ, ແລ້ວຄລິກປຸ່ມ <emph>ຕົກລົງ</emph>."

#. mwUb4
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN1055C\n"
"help.text"
msgid "Import"
msgstr "ນຳເຂົ້າ"

#. Huhmu
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN10560\n"
"help.text"
msgid "<ahelp hid=\".\">Adds new icons to the list of icons. You see the Open dialog that imports the selected icon or icons into the internal icon directory of %PRODUCTNAME.</ahelp>"
msgstr "<ahelp hid=\".\">ເພີ່ມໄອຄອນໃໝ່ເຂົ້າໃນລາຍການໄອຄອນ. ທ່ານຈະເຫັນກ່ອງໂຕ້ຕອບ ເປີດ ເພື່ອນຳເຂົ້າໄອຄອນທີ່ເລືອກໄປຍັງໄດເຣັກທໍຣີໄອຄອນພາຍໃນຂອງ %PRODUCTNAME.</ahelp>"

#. 3qKnr
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_idN10575\n"
"help.text"
msgid "You can only import icons that are in the PNG file format and that are 16 × 16 or 24 × 24 pixels in size."
msgstr "ທ່ານສາມາດນຳເຂົ້າໄດ້ສະເພາະໄອຄອນທີ່ຢູ່ໃນຮູບແບບໄຟລ໌ PNG ແລະ ມີຂະໜາດ 16 × 16 ຫຼື 24 × 24 ພິກເຊວເທົ່ານັ້ນ."

#. RLa8G
#: 06140402.xhp
msgctxt ""
"06140402.xhp\n"
"par_id8224433\n"
"help.text"
msgid "<ahelp hid=\".\">Click to remove the selected icon from the list. Only user-defined icons can be removed.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກເພື່ອລຶບໄອຄອນທີ່ເລືອກອອກຈາກລາຍການ. ສາມາດລຶບໄດ້ສະເພາະໄອຄອນທີ່ຜູ້ໃຊ້ກຳນົດເອງເທົ່ານັ້ນ.</ahelp>"

#. XErij
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"tit\n"
"help.text"
msgid "Events"
msgstr "ເຫດການ"

#. BWUKy
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"bm_id3152427\n"
"help.text"
msgid "<bookmark_value>customizing; events</bookmark_value>    <bookmark_value>events; customizing</bookmark_value>"
msgstr "<bookmark_value>ການປັບແຕ່ງ; ເຫດການ</bookmark_value>    <bookmark_value>ເຫດການ; ການປັບແຕ່ງ</bookmark_value>"

#. Aa42F
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"hd_id3152427\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/shared/01/06140500.xhp\">Events</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/shared/01/06140500.xhp\">ເຫດການ</link></variable>"

#. LtwjV
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_id3152937\n"
"help.text"
msgid "<variable id=\"assignaction\"><ahelp hid=\".\">Assigns macros to program events. The assigned macro runs automatically every time the selected event occurs.</ahelp></variable>"
msgstr "<variable id=\"assignaction\"><ahelp hid=\".\">ກຳນົດມາໂຄຣໃຫ້ກັບເຫດການຂອງໂປຣແກຣມ. ມາໂຄຣທີ່ກຳນົດຈະເຮັດວຽກໂດຍອັດຕະໂນມັດທຸກຄັ້ງທີ່ເຫດການທີ່ເລືອກເກີດຂຶ້ນ.</ahelp></variable>"

#. jN5RR
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_idN1060A\n"
"help.text"
msgid "Save In"
msgstr "ບັນທຶກໄວ້ໃນ"

#. vvFwG
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_idN1060E\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/eventsconfigpage/savein\">Select first where to save the event binding, in the current document or in %PRODUCTNAME.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/eventsconfigpage/savein\">ເລືອກກ່ອນວ່າຈະບັນທຶກການເຊື່ອມໂຍງເຫດການໄວ້ໃສ, ໃນເອກະສານປັດຈຸບັນ ຫຼື ໃນ %PRODUCTNAME.</ahelp>"

#. wbCSX
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_id3153662\n"
"help.text"
msgid "A macro that is saved with a document can only be run when that document is opened."
msgstr "ມາໂຄຣທີ່ບັນທຶກໄວ້ກັບເອກະສານສາມາດເຮັດວຽກໄດ້ສະເພາະຕອນທີ່ເອກະສານນັ້ນຖືກເປີດຢູ່ເທົ່ານັ້ນ."

#. Ge58b
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_idN1061A\n"
"help.text"
msgid "<ahelp hid=\".\">The big list box lists the events and the assigned macros. After you selected the location in the <emph>Save In</emph> list box, select an event in the big list box. Then click <emph>Assign Macro</emph>.</ahelp>"
msgstr "<ahelp hid=\".\">ກ່ອງລາຍການຂະໜາດໃຫຍ່ຈະສະແດງລາຍການເຫດການ ແລະ ມາໂຄຣທີ່ກຳນົດໄວ້. ຫຼັງຈາກທີ່ທ່ານເລືອກຕຳແໜ່ງໃນກ່ອງລາຍການ <emph>ບັນທຶກໄວ້ໃນ</emph> ແລ້ວ, ໃຫ້ເລືອກເຫດການໃນກ່ອງລາຍການໃຫຍ່. ຈາກນັ້ນຄລິກ <emph>ກຳນົດມາໂຄຣ</emph>.</ahelp>"

#. fWHza
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"hd_id3159258\n"
"help.text"
msgid "Assign Macro"
msgstr "ກຳນົດມາໂຄຣ"

#. FCntY
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_id3156152\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the <link href=\"text/shared/01/06130020.xhp\">Macro Selector</link> dialog to assign a macro to the selected event.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/06130020.xhp\">ຕົວເລືອກມາໂຄຣ</link> ເພື່ອກຳນົດມາໂຄຣໃຫ້ກັບເຫດການທີ່ເລືອກ.</ahelp>"

#. 6a78S
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"hd_id751568966764822\n"
"help.text"
msgid "Assign Component..."
msgstr "ກຳນົດຄອມໂພເນນ..."

#. PdgEw
#: 06140500.xhp
msgctxt ""
"06140500.xhp\n"
"par_id111568966885228\n"
"help.text"
msgid "Opens the <literal>Assign Component</literal> dialog to set a <link href=\"text/sbasic/python/python_handler.xhp\">custom UNO command</link> for the selected event."
msgstr "ເປີດກ່ອງໂຕ້ຕອບ <literal>ກຳນົດຄອມໂພເນນ</literal> ເພື່ອຕັ້ງຄ່າ <link href=\"text/sbasic/python/python_handler.xhp\">ຄຳສັ່ງ UNO ທີ່ປັບແຕ່ງເອງ</link> ສຳລັບເຫດການທີ່ເລືອກ."

