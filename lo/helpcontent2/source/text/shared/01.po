#. MYuar
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id2107303\n"
"help.text"
msgid "<ahelp hid=\".\">Click the button to open a dialog where you can enter the name of a new user-defined data type. The new data type inherits all facets from the currently selected data type.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກທີ່ປຸ່ມເພື່ອເປີດກ່ອງໂຕ້ຕອບທີ່ທ່ານສາມາດປ້ອນຊື່ຂອງປະເພດຂໍ້ມູນໃໝ່ທີ່ຜູ້ໃຊ້ກຳນົດເອງ. ປະເພດຂໍ້ມູນໃໝ່ຈະສືບທອດຄຸນລັກສະນະທັງໝົດຈາກປະເພດຂໍ້ມູນທີ່ເລືອກໃນປັດຈຸບັນ.</ahelp>"

#. Suwnq
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id4071779\n"
"help.text"
msgid "The following lists all facets that are valid for data types. Some facets are only available for some data types."
msgstr "ຕໍ່ໄປນີ້ແມ່ນລາຍຊື່ facets ທັງໝົດທີ່ໃຊ້ໄດ້ກັບປະເພດຂໍ້ມູນ. ບາງ facets ແມ່ນມີໃຫ້ສະເພາະບາງປະເພດຂໍ້ມູນເທົ່ານັ້ນ."

#. MDsE2
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id4313791\n"
"help.text"
msgid "Whitespaces"
msgstr "ຊ່ອງຫວ່າງ"

#. V5GAw
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id4331797\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies how whitespaces are to be handled when a string of the current data type is being processed. Possible values are \"Preserve\", \"Replace\", and \"Collapse\". The semantics follow the definition at <link href=\"https://www.w3.org/TR/xmlschema-2/#rf-whiteSpace\"><emph>https://www.w3.org/TR/xmlschema-2/#rf-whiteSpace</emph></link>.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸວິທີການຈັດການກັບຊ່ອງຫວ່າງເມື່ອສະຕຣິງຂອງປະເພດຂໍ້ມູນປັດຈຸບັນຖືກປະມວນຜົນ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ \"Preserve\", \"Replace\", ແລະ \"Collapse\". ຄວາມໝາຍແມ່ນເປັນໄປຕາມຄຳນິຍາມທີ່ <link href=\"https://www.w3.org/TR/xmlschema-2/#rf-whiteSpace\"><emph>https://www.w3.org/TR/xmlschema-2/#rf-whiteSpace</emph></link>.</ahelp>"

#. EmBf7
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id4191717\n"
"help.text"
msgid "Pattern"
msgstr "ຮູບແບບ"

#. GBqSw
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id2318796\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies a regular expression pattern. Strings validated against the data type must conform to this pattern to be valid. The XSD data type syntax for regular expressions is different from the regular expression syntax used elsewhere in %PRODUCTNAME, for example in the <emph>Find & Replace</emph> dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຮູບແບບນິພົດປົກກະຕິ. ສະຕຣິງທີ່ຖືກກວດສອບກັບປະເພດຂໍ້ມູນຕ້ອງສອດຄ່ອງກັບຮູບແບບນີ້ຈຶ່ງຈະຖືວ່າຖືກຕ້ອງ. ໄວຍາກອນປະເພດຂໍ້ມູນ XSD ສຳລັບນິພົດປົກກະຕິແມ່ນແຕກຕ່າງຈາກໄວຍາກອນນິພົດປົກກະຕິທີ່ໃຊ້ໃນບ່ອນອື່ນໆໃນ %PRODUCTNAME, ເຊັ່ນ: ໃນກ່ອງໂຕ້ຕອບ <emph>ຊອກຫາ ແລະ ແທນທີ່</emph>.</ahelp>"

#. rjLF5
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id399182\n"
"help.text"
msgid "Digits (total)"
msgstr "ຕົວເລກ (ທັງໝົດ)"

#. iBuCE
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id5298318\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the maximum total number of digits that values of the decimal data type can have.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຈຳນວນຕົວເລກທັງໝົດສູງສຸດທີ່ຄ່າຂອງປະເພດຂໍ້ມູນທົດສະນິຍົມສາມາດມີໄດ້.</ahelp>"

#. YxNjr
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id7588732\n"
"help.text"
msgid "Digits (fraction)"
msgstr "ຕົວເລກ (ເສດສ່ວນ)"

#. ADefS
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id95828\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the maximum total number of fractional digits that values of the decimal data type can have.</ahelp>"
msgstr "<ahelp hid=\".\">ລະບຸຈຳນວນຕົວເລກຫຼັງຈຸດທົດສະນິຍົມທັງໝົດສູງສຸດທີ່ຄ່າຂອງປະເພດຂໍ້ມູນທົດສະນິຍົມສາມາດມີໄດ້.</ahelp>"

#. LkwFf
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"hd_id3496200\n"
"help.text"
msgid "Max. (inclusive)"
msgstr "ສູງສຸດ (ລວມຄ່ານີ້)"

#. kJ4TM
#: xformsdatatab.xhp
msgctxt ""
"xformsdatatab.xhp\n"
"par_id7599108\n"
