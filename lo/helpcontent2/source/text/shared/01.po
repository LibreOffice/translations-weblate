"par_id3151210\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/baselinksdialog/MANUAL\">Only updates the link when you click the <emph>Update</emph> button.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/baselinksdialog/MANUAL\">ຈະອັບເດດການເຊື່ອມຕໍ່ກໍຕໍ່ເມື່ອທ່ານຄລິກປຸ່ມ <emph>ອັບເດດ</emph> ເທົ່ານັ້ນ.</ahelp>"

#. F9APc
