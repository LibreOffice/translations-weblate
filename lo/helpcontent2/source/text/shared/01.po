msgctxt ""
"05250400.xhp\n"
"par_id3156116\n"
"help.text"
msgid "<ahelp hid=\".uno:SendToBack\" visibility=\"visible\">Moves the selected object to the bottom of the stacking order, so that it is behind the other objects.</ahelp>"
