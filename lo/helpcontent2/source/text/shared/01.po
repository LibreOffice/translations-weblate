"help.text"
msgid "<emph>Text direction</emph> only appears if <emph>Asian</emph> or <emph>Complex text layout</emph> is set in <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - Language Setting - Languages</menuitem>."
msgstr "<emph>ທິດທາງຂໍ້ຄວາມ</emph> ຈະປາກົດຂຶ້ນກໍຕໍ່ເມື່ອ <emph>ອາຊີ</emph> ຫຼື <emph>ການຈັດວາງຂໍ້ຄວາມແບບຊັບຊ້ອນ</emph> ຖືກຕັ້ງຄ່າໄວ້ໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ການຕັ້ງຄ່າ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - ການຕັ້ງຄ່າພາສາ - ພາສາ</menuitem>."

#. MR8zP
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3156327\n"
"help.text"
msgid "Paper tray"
msgstr "ຖາດໃສ່ເຈ້ຍ"

#. iqaKx
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3150771\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/comboPaperTray\">Select the paper source for your printer. If you want, you can assign different paper trays to different page styles. For example, assign a different tray to the First Page style and load the tray with your company's letterhead paper.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/comboPaperTray\">ເລືອກແຫຼ່ງທີ່ມາຂອງເຈ້ຍສຳລັບເຄື່ອງພິມຂອງທ່ານ. ຖ້າທ່ານຕ້ອງການ, ທ່ານສາມາດກຳນົດຖາດເຈ້ຍທີ່ແຕກຕ່າງກັນໃຫ້ກັບຮູບແບບໜ້າທີ່ແຕກຕ່າງກັນໄດ້. ຕົວຢ່າງ: ກຳນົດຖາດອື່ນໃຫ້ກັບຮູບແບບໜ້າທຳອິດ ແລະ ໃສ່ເຈ້ຍທີ່ມີຫົວຈົດໝາຍຂອງບໍລິສັດທ່ານໃນຖາດນັ້ນ.</ahelp>"

#. iMQhm
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3150275\n"
"help.text"
msgid "<variable id=\"margins_hd\">Margins</variable>"
msgstr "<variable id=\"margins_hd\">ຂອບໜ້າເຈ້ຍ</variable>"

#. wPv56
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3153348\n"
"help.text"
msgid "Specify the amount of space to leave between the edges of the page and the document text."
msgstr "ລະບຸຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບຂອງໜ້າເຈ້ຍ ແລະ ຂໍ້ຄວາມໃນເອກະສານ."

#. D2mZT
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3153061\n"
"help.text"
msgid "Left <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>/ Inner</defaultinline></switchinline>"
msgstr "ຊ້າຍ <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>/ ດ້ານໃນ</defaultinline></switchinline>"

#. 2FbPb
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3151384\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/spinMargLeft\">Enter the amount of space to leave between the left edge of the page and the document text. <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>If you are using the <emph>Mirrored</emph> page layout, enter the amount of space to leave between the inner text margin and the inner edge of the page.</defaultinline></switchinline></ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/spinMargLeft\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບເບື້ອງຊ້າຍຂອງໜ້າເຈ້ຍ ແລະ ຂໍ້ຄວາມເອກະສານ. <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>ຖ້າທ່ານກຳລັງໃຊ້ການຈັດວາງໜ້າແບບ <emph>ສ່ອງແວ່ນ (Mirrored)</emph>, ໃຫ້ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບຂໍ້ຄວາມດ້ານໃນ ແລະ ຂອບດ້ານໃນຂອງໜ້າເຈ້ຍ.</defaultinline></switchinline></ahelp>"

#. GvkRk
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3154923\n"
"help.text"
msgid "Right <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>/ Outer</defaultinline></switchinline>"
msgstr "ຂວາ <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>/ ດ້ານນອກ</defaultinline></switchinline>"

#. Pgp68
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3147304\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/spinMargRight\">Enter the amount of space to leave between the right edge of the page and the document text. <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>If you are using the <emph>Mirrored</emph> page layout, enter the amount of space to leave between the outer text margin and the outer edge of the page.</defaultinline></switchinline></ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/spinMargRight\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບເບື້ອງຂວາຂອງໜ້າເຈ້ຍ ແລະ ຂໍ້ຄວາມເອກະສານ. <switchinline select=\"appl\"><caseinline select=\"DRAW\"/><caseinline select=\"IMPRESS\"/><defaultinline>ຖ້າທ່ານກຳລັງໃຊ້ການຈັດວາງໜ້າແບບ <emph>ສ່ອງແວ່ນ (Mirrored)</emph>, ໃຫ້ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບຂໍ້ຄວາມດ້ານນອກ ແລະ ຂອບດ້ານນອກຂອງໜ້າເຈ້ຍ.</defaultinline></switchinline></ahelp>"

#. pDxeH
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3145745\n"
"help.text"
msgid "Gutter"
msgstr "ຂອບເຍັບປຶ້ມ (Gutter)"

#. rvmBG
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3147305\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/spinMargGut\">Enter the amount of space to leave between the left edge of the page and the left margin. If you are using the <emph>Mirrored</emph> page layout, enter the amount of space to leave between the inner page margin and the inner edge of the page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/spinMargGut\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບເບື້ອງຊ້າຍຂອງໜ້າເຈ້ຍ ແລະ ຂອບຊ້າຍ. ຖ້າທ່ານກຳລັງໃຊ້ການຈັດວາງໜ້າແບບ <emph>ສ່ອງແວ່ນ (Mirrored)</emph>, ໃຫ້ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບໜ້າດ້ານໃນ ແລະ ຂອບດ້ານໃນຂອງໜ້າເຈ້ຍ.</ahelp>"

#. EPeDb
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3161657\n"
"help.text"
msgid "Top"
msgstr "ເທິງ"

#. UaW6n
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3154226\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/spinMargTop\">Enter the amount of space to leave between the upper edge of the page and the document text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/spinMargTop\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບດ້ານເທິງຂອງໜ້າເຈ້ຍ ແລະ ຂໍ້ຄວາມເອກະສານ.</ahelp>"

#. CAEYF
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3153381\n"
"help.text"
msgid "Bottom"
msgstr "ລຸ່ມ"

#. rG5k8
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3154138\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/spinMargBot\">Enter the amount of space to leave between the lower edge of the page and the document text.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/spinMargBot\">ປ້ອນຈຳນວນໄລຍະຫ່າງທີ່ຈະປະໄວ້ລະຫວ່າງຂອບດ້ານລຸ່ມຂອງໜ້າເຈ້ຍ ແລະ ຂໍ້ຄວາມເອກະສານ.</ahelp>"

#. qBGYY
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3147381\n"
"help.text"
msgid "Layout settings"
msgstr "ການຕັ້ງຄ່າການຈັດວາງ"

#. yveUv
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3145744\n"
"help.text"
msgid "<variable id=\"page_layout_hd\">Page layout</variable>"
msgstr "<variable id=\"page_layout_hd\">ການຈັດວາງໜ້າ</variable>"

#. DMwZG
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3154218\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/comboPageLayout\">Specify whether the current style should show odd pages, even pages, or both odd and even pages.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/comboPageLayout\">ລະບຸວ່າຮູບແບບປັດຈຸບັນຄວນສະແດງໜ້າຄີກ, ໜ້າຄູ່ ຫຼື ທັງໜ້າຄີກ ແລະ ໜ້າຄູ່.</ahelp>"

#. GTUc7
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3154946\n"
"help.text"
msgid "Right and left"
msgstr "ຂວາ ແລະ ຊ້າຍ"

#. PHbNi
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3153058\n"
"help.text"
msgid "The current page style shows both odd and even pages with left and right margins as specified."
msgstr "ຮູບແບບໜ້າປັດຈຸບັນຈະສະແດງທັງໜ້າຄີກ ແລະ ໜ້າຄູ່ ໂດຍມີຂອບຊ້າຍ ແລະ ຂວາຕາມທີ່ລະບຸໄວ້."

#. GDCeb
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3147287\n"
"help.text"
msgid "Mirrored"
msgstr "ແບບສ່ອງແວ່ນ (Mirrored)"

#. Nz3A7
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3147317\n"
"help.text"
msgid "The current page style shows both odd and even pages with inner and outer margins as specified. Use this layout if you want to bind the printed pages like a book. Enter the binding space as the \"Inner\" margin."
msgstr "ຮູບແບບໜ້າປັດຈຸບັນຈະສະແດງທັງໜ້າຄີກ ແລະ ໜ້າຄູ່ ໂດຍມີຂອບດ້ານໃນ ແລະ ດ້ານນອກຕາມທີ່ລະບຸໄວ້. ໃຊ້ການຈັດວາງນີ້ຖ້າທ່ານຕ້ອງການເຍັບເຫຼັ້ມໜ້າທີ່ພິມອອກມາຄືກັບປຶ້ມ. ໃຫ້ປ້ອນໄລຍະຫ່າງສຳລັບເຍັບປຶ້ມເປັນຂອບ \"ດ້ານໃນ\"."

#. HPAak
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3155308\n"
"help.text"
msgid "Only right"
msgstr "ສະເພາະເບື້ອງຂວາ"

#. kxhBx
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3152885\n"
"help.text"
msgid "The current page style shows only odd (right) pages. Even pages are shown as blank pages."
msgstr "ຮູບແບບໜ້າປັດຈຸບັນຈະສະແດງສະເພາະໜ້າຄີກ (ຂວາ) ເທົ່ານັ້ນ. ສ່ວນໜ້າຄູ່ຈະສະແດງເປັນໜ້າຫວ່າງ."

#. VxnGV
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3157309\n"
"help.text"
msgid "Only left"
msgstr "ສະເພາະເບື້ອງຊ້າຍ"

#. 839AF
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3147326\n"
"help.text"
msgid "The current page style shows only even (left) pages. Odd pages are shown as blank pages."
msgstr "ຮູບແບບໜ້າປັດຈຸບັນຈະສະແດງສະເພາະໜ້າຄູ່ (ຊ້າຍ) ເທົ່ານັ້ນ. ສ່ວນໜ້າຄີກຈະສະແດງເປັນໜ້າຫວ່າງ."

#. noe6b
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id341721772045333\n"
"help.text"
msgid "<variable id=\"page_numbers_hd\"><switchinline select=\"appl\"><caseinline select=\"IMPRESS\">Slide</caseinline><defaultinline>Page</defaultinline></switchinline> Numbers</variable>"
msgstr "<variable id=\"page_numbers_hd\">ລຳດັບ <switchinline select=\"appl\"><caseinline select=\"IMPRESS\">ສະໄລ້</caseinline><defaultinline>ໜ້າ</defaultinline></switchinline></variable>"

#. 8Gvk9
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id371587747950454\n"
"help.text"
msgid "Select the slide numbering format that you want to use for the current slide style."
msgstr "ເລືອກຮູບແບບລຳດັບເລກສະໄລ້ທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບຮູບແບບສະໄລ້ປັດຈຸບັນ."

#. GnD6W
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3153745\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/comboLayoutFormat\">Select the page numbering format that you want to use for the current page style.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/comboLayoutFormat\">ເລືອກຮູບແບບລຳດັບເລກໜ້າທີ່ທ່ານຕ້ອງການໃຊ້ສຳລັບຮູບແບບໜ້າປັດຈຸບັນ.</ahelp>"

#. ja4mB
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3150686\n"
"help.text"
msgid "Reference Style"
msgstr "ຮູບແບບອ້າງອີງ"

#. hrqZy
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3146146\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/comboRegisterStyle\">Select the Paragraph Style that you want to use as a reference for lining up the text on the selected Page style. The height of the font that is specified in the reference style sets the spacing of the vertical page grid.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/comboRegisterStyle\">ເລືອກຮູບແບບຫຍໍ້ໜ້າທີ່ທ່ານຕ້ອງການໃຊ້ເປັນບ່ອນອ້າງອີງສຳລັບການຈັດແນວຂໍ້ຄວາມໃນຮູບແບບໜ້າທີ່ເລືອກ. ຄວາມສູງຂອງຟອນທີ່ລະບຸໄວ້ໃນຮູບແບບອ້າງອີງຈະເປັນຕົວຕັ້ງຄ່າໄລຍະຫ່າງຂອງເສັ້ນຕາຕະລາງໜ້າແນວຕັ້ງ.</ahelp>"

#. cqiqD
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3150488\n"
"help.text"
msgid "Use page line-spacing"
msgstr "ໃຊ້ໄລຍະຫ່າງແຖວຂອງໜ້າ"

#. xRZFb
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3151112\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/checkRegisterTrue\">Aligns the text on the selected Page Style to a vertical page grid.</ahelp> The spacing of the grid is defined by the <emph>Reference Style</emph>."
msgstr "<ahelp hid=\"cui/ui/pageformatpage/checkRegisterTrue\">ຈັດວາງຂໍ້ຄວາມໃນຮູບແບບໜ້າທີ່ເລືອກໃຫ້ກົງກັບເສັ້ນຕາຕະລາງໜ້າແນວຕັ້ງ.</ahelp> ໄລຍະຫ່າງຂອງເສັ້ນຕາຕະລາງແມ່ນຖືກກຳນົດໂດຍ <emph>ຮູບແບບອ້າງອີງ</emph>."

#. GQ3P2
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id0522200809473732\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select the Paragraph Style that you want to use as a reference for lining up the text on the selected Page style. The height of the font that is specified in the reference style sets the spacing of the vertical page grid. </ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກຮູບແບບຫຍໍ້ໜ້າທີ່ທ່ານຕ້ອງການໃຊ້ເປັນບ່ອນອ້າງອີງສຳລັບການຈັດແນວຂໍ້ຄວາມໃນຮູບແບບໜ້າທີ່ເລືອກ. ຄວາມສູງຂອງຟອນທີ່ລະບຸໄວ້ໃນຮູບແບບອ້າງອີງຈະເປັນຕົວຕັ້ງຄ່າໄລຍະຫ່າງຂອງເສັ້ນຕາຕະລາງໜ້າແນວຕັ້ງ. </ahelp>"

#. opCCC
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3150489\n"
"help.text"
msgid "Gutter position"
msgstr "ຕຳແໜ່ງຂອບເຍັບປຶ້ມ"

#. Gs9qT
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id0522200809473733\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/comboGutterPosition\">Allows choosing if the current document's gutter shall be positioned at the left of the document's pages (default) or at top of the document's pages when the document is displayed.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/comboGutterPosition\">ອະນຸຍາດໃຫ້ເລືອກວ່າຂອບເຍັບປຶ້ມຂອງເອກະສານປັດຈຸບັນຄວນຈະຢູ່ທາງຊ້າຍຂອງໜ້າເອກະສານ (ເລີ່ມຕົ້ນ) ຫຼື ຢູ່ທາງເທິງຂອງໜ້າເອກະສານ ເມື່ອເອກະສານຖືກສະແດງຜົນ.</ahelp>"

#. niqBy
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3147480\n"
"help.text"
msgid "Table alignment"
msgstr "ການຈັດວາງຕາຕະລາງ"

#. 2fKA6
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3150417\n"
"help.text"
msgid "Specify the alignment options for the cells on a printed page."
msgstr "ລະບຸຕົວເລືອກການຈັດວາງສຳລັບຫ້ອງຕາຕະລາງໃນໜ້າທີ່ພິມ."

#. Rz6jD
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id0522200809473845\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Centers the cells horizontally on the printed page.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຈັດຫ້ອງຕາຕະລາງໃຫ້ຢູ່ເຄິ່ງກາງຕາມແນວນອນໃນໜ້າທີ່ພິມ.</ahelp>"

#. CMpSv
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3147047\n"
"help.text"
msgid "Horizontal"
msgstr "ແນວນອນ"

#. eARTv
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3153878\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/checkbuttonHorz\">Centers the cells horizontally on the printed page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/checkbuttonHorz\">ຈັດຫ້ອງຕາຕະລາງໃຫ້ຢູ່ເຄິ່ງກາງຕາມແນວນອນໃນໜ້າທີ່ພິມ.</ahelp>"

#. TxE3H
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id0522200809473811\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Centers the cells vertically on the printed page.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຈັດຫ້ອງຕາຕະລາງໃຫ້ຢູ່ເຄິ່ງກາງຕາມແນວຕັ້ງໃນໜ້າທີ່ພິມ.</ahelp>"

#. WkDEo
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3153522\n"
"help.text"
msgid "Vertical"
msgstr "ແນວຕັ້ງ"

#. o9bGn
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3149413\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/checkbuttonVert\">Centers the cells vertically on the printed page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/checkbuttonVert\">ຈັດຫ້ອງຕາຕະລາງໃຫ້ຢູ່ເຄິ່ງກາງຕາມແນວຕັ້ງໃນໜ້າທີ່ພິມ.</ahelp>"

#. 4eiX9
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"hd_id3151318\n"
"help.text"
msgid "Fit object to paper format"
msgstr "ປັບວັດຖຸໃຫ້ພໍດີກັບຮູບແບບເຈ້ຍ"

#. AEasi
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3144746\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pageformatpage/checkAdaptBox\">Resizes the drawing objects so that they fit on the paper format that you select. The arrangement of the drawing objects is preserved.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pageformatpage/checkAdaptBox\">ປັບຂະໜາດວັດຖຸຮູບແຕ້ມເພື່ອໃຫ້ພໍດີກັບຮູບແບບເຈ້ຍທີ່ທ່ານເລືອກ. ໂດຍທີ່ການຈັດວາງຂອງວັດຖຸຮູບແຕ້ມຍັງຄົງຮັກສາໄວ້ຄືເກົ່າ.</ahelp>"

#. FeZ3F
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3149123\n"
"help.text"
msgid "<link href=\"text/shared/00/00000003.xhp#measurement_units\">Changing measurement units</link>"
msgstr "<link href=\"text/shared/00/00000003.xhp#measurement_units\">ການປ່ຽນຫົວໜ່ວຍວັດແທກ</link>"

#. 89WT8
#: 05040200.xhp
msgctxt ""
"05040200.xhp\n"
"par_id3153730\n"
"help.text"
msgid "<link href=\"text/swriter/guide/registertrue.xhp\">Printing with Page line-spacing (register-true)</link>"
msgstr "<link href=\"text/swriter/guide/registertrue.xhp\">ການພິມດ້ວຍໄລຍະຫ່າງແຖວຂອງໜ້າ (register-true)</link>"

#. 8CcQd
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"tit\n"
"help.text"
msgid "Header"
msgstr "ສ່ວນຫົວໜ້າ"

#. h5Fp8
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3155599\n"
"help.text"
msgid "<variable id=\"header_h1\"><link href=\"text/shared/01/05040300.xhp\">Header</link></variable>"
msgstr "<variable id=\"header_h1\"><link href=\"text/shared/01/05040300.xhp\">ສ່ວນຫົວໜ້າ</link></variable>"

#. CHjxs
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3156027\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/HFormatPage\">Adds a header to the current page style. A header is an area in the top page margin, where you can add text or graphics.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/HFormatPage\">ເພີ່ມສ່ວນຫົວໜ້າໃຫ້ກັບຮູບແບບໜ້າປັດຈຸບັນ. ສ່ວນຫົວໜ້າແມ່ນບໍລິເວນໃນຂອບໜ້າເຈ້ຍດ້ານເທິງ, ບ່ອນທີ່ທ່ານສາມາດເພີ່ມຂໍ້ຄວາມ ຫຼື ຮູບພາບໄດ້.</ahelp>"

#. AiAZ8
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3150693\n"
"help.text"
msgid "If you want, you can also add borders or a background fill to a header."
msgstr "ຖ້າທ່ານຕ້ອງການ, ທ່ານຍັງສາມາດເພີ່ມເສັ້ນຂອບ ຫຼື ການຕື່ມສີພື້ນຫຼັງໃຫ້ກັບສ່ວນຫົວໜ້າໄດ້."

#. ovdFj
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3153821\n"
"help.text"
msgid "<switchinline select=\"appl\"><caseinline select=\"WRITER\">To add a header to the current page style, select <emph>Header on</emph>, and then click <emph>OK</emph>.</caseinline></switchinline>"
msgstr "<switchinline select=\"appl\"><caseinline select=\"WRITER\">ເພື່ອເພີ່ມຫົວເຈ້ຍໃຫ້ກັບຮູບແບບໜ້າປັດຈຸບັນ, ໃຫ້ເລືອກ <emph>ເປີດຫົວເຈ້ຍ</emph>, ແລ້ວກົດ <emph>ຕົກລົງ</emph>.</caseinline></switchinline>"

#. fiqjQ
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3153827\n"
"help.text"
msgid "If you want to extend a header into the page margins, insert a frame into the header."
msgstr "ຫາກທ່ານຕ້ອງການຂະຫຍາຍຫົວເຈ້ຍເຂົ້າໄປໃນຂອບໜ້າ, ໃຫ້ແຊກກອບເຂົ້າໄປໃນຫົວເຈ້ຍ."

#. meTFw
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3154046\n"
"help.text"
msgid "To quickly move the text cursor from the document text to the header or footer, press <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Page Up or Page Down. Press the same key again to move the text cursor back into the document text."
msgstr "ເພື່ອຍ້າຍຕົວຊີ້ບອກຂໍ້ຄວາມຈາກເນື້ອໃນເອກະສານໄປຫາຫົວເຈ້ຍ ຫຼື ທ້າຍເຈ້ຍຢ່າງໄວວາ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Page Up ຫຼື Page Down. ກົດປຸ່ມເດີມອີກຄັ້ງເພື່ອຍ້າຍຕົວຊີ້ບອກຂໍ້ຄວາມກັບຄືນໄປຫາເນື້ອໃນເອກະສານ."

#. uCVzR
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3152360\n"
"help.text"
msgid "Header"
msgstr "ຫົວເຈ້ຍ"

#. iqZhF
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3154924\n"
"help.text"
msgid "Set the properties of the header."
msgstr "ຕັ້ງຄ່າຄຸນສົມບັດຂອງຫົວເຈ້ຍ."

#. WNH7q
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3147304\n"
"help.text"
msgid "Header on"
msgstr "ເປີດຫົວເຈ້ຍ"

#. qFkEJ
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3154388\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/checkHeaderOn\">Adds a header to the current page style.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/checkHeaderOn\">ເພີ່ມຫົວເຈ້ຍໃຫ້ກັບຮູບແບບໜ້າປັດຈຸບັນ.</ahelp>"

#. pqAWn
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3154936\n"
"help.text"
msgid "<variable id=\"same_lr_header_hd\">Same content left/right</variable>"
msgstr "<variable id=\"same_lr_header_hd\">ເນື້ອໃນຄືກັນ ຊ້າຍ/ຂວາ</variable>"

#. E4fZv
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3154938\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/checkSameLR\">Even and odd pages share the same content.<switchinline select=\"appl\"><caseinline select=\"CALC\"> To assign a different header to even and odd pages, clear this option, and then click <emph>Edit</emph>.</caseinline></switchinline></ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/checkSameLR\">ໜ້າຄູ່ ແລະ ໜ້າຄີກໃຊ້ເນື້ອໃນດຽວກັນ.<switchinline select=\"appl\"><caseinline select=\"CALC\"> ເພື່ອຕັ້ງຄ່າຫົວເຈ້ຍທີ່ແຕກຕ່າງກັນສຳລັບໜ້າຄູ່ ແລະ ໜ້າຄີກ, ໃຫ້ຍົກເລີກຕົວເລືອກນີ້, ແລ້ວກົດ <emph>ແກ້ໄຂ</emph>.</caseinline></switchinline></ahelp>"

#. gELWV
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3154937\n"
"help.text"
msgid "<variable id=\"same_fp_header_hd\">Same content on first page</variable>"
msgstr "<variable id=\"same_fp_header_hd\">ເນື້ອໃນດຽວກັນໃນໜ້າທຳອິດ</variable>"

#. CvC9L
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3154939\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/checkSameFP\">First and even/odd pages share the same content.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/checkSameFP\">ໜ້າທຳອິດ ແລະ ໜ້າຄູ່/ຄີກໃຊ້ເນື້ອໃນດຽວກັນ.</ahelp>"

#. 6fAx5
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3145202\n"
"help.text"
msgid "Left margin"
msgstr "ຂອບຊ້າຍ"

#. J7H5c
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3150449\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/spinMargLeft\">Enter the amount of space to leave between the left page margin and the left edge of the header.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/spinMargLeft\">ປ້ອນໄລຍະຫ່າງທີ່ຕ້ອງການປະໄວ້ລະຫວ່າງຂອບໜ້າເບື້ອງຊ້າຍ ແລະ ຂອບຊ້າຍຂອງຫົວເຈ້ຍ.</ahelp>"

#. nUA2y
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3153351\n"
"help.text"
msgid "Right margin"
msgstr "ຂອບຂວາ"

#. FcWFA
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3157322\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/spinMargRight\">Enter the amount of space to leave between the right page margin and the right edge of the header.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/headfootformatpage/spinMargRight\">ປ້ອນໄລຍະຫ່າງທີ່ຕ້ອງການປະໄວ້ລະຫວ່າງຂອບໜ້າເບື້ອງຂວາ ແລະ ຂອບຂວາຂອງຫົວເຈ້ຍ.</ahelp>"

#. H4TZM
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"hd_id3148672\n"
"help.text"
msgid "<variable id=\"spacing_hd\">Spacing</variable>"
msgstr "<variable id=\"spacing_hd\">ໄລຍະຫ່າງ</variable>"

#. CNYDF
#: 05040300.xhp
msgctxt ""
"05040300.xhp\n"
"par_id3153970\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/headfootformatpage/spinSpacing\">Enter the amount of space that you want to maintain between the bottom edge of the header and the top edge of the document text.</ahelp>"
