msgstr "<link href=\"text/shared/01/02210101.xhp\">ຄຸນສົມບັດຂອງຂອບລອຍ</link>"

#. GZN7r
#: 02210101.xhp
msgctxt ""
"02210101.xhp\n"
"par_id3149031\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/insertfloatingframe/InsertFloatingFrameDialog\">Changes the properties of the selected floating frame. Floating frames work best when they contain an html document, and when they are inserted in another html document.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/insertfloatingframe/InsertFloatingFrameDialog\">ປ່ຽນແປງຄຸນສົມບັດຂອງຂອບລອຍ (floating frame) ທີ່ເລືອກ. ຂອບລອຍຈະເຮັດວຽກໄດ້ດີທີ່ສຸດເມື່ອມັນບັນຈຸເອກະສານ html, ແລະ ເມື່ອມັນຖືກແຊກລົງໃນເອກະສານ html ອື່ນ.</ahelp>"

#. huLin
#: 02210101.xhp
msgctxt ""
"02210101.xhp\n"
"hd_id3155364\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

