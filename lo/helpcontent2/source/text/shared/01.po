msgstr "ປ່ຽນແປງ"

#. 9DzTG
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id3154125\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/baselinksdialog/CHANGE_SOURCE\">Change the source file for the selected link.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/baselinksdialog/CHANGE_SOURCE\">ປ່ຽນໄຟລ໌ຕົ້ນສະບັບສຳລັບການເຊື່ອມຕໍ່ທີ່ເລືອກ.</ahelp>"

#. gcVUQ
