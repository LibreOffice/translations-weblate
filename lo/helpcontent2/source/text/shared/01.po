"hd_id3152876\n"
"help.text"
msgid "<link href=\"text/shared/01/02050000.xhp\">Copy</link>"
msgstr "<link href=\"text/shared/01/02050000.xhp\">ສຳເນົາ</link>"

#. nmrES
#: 02050000.xhp
msgctxt ""
"02050000.xhp\n"
"par_id3154682\n"
"help.text"
msgid "<ahelp hid=\".uno:Copy\">Copies the selection to the clipboard.</ahelp>"
msgstr "<ahelp hid=\".uno:Copy\">ສຳເນົາສ່ວນທີ່ເລືອກໄປໄວ້ໃນຄລິບບອດ.</ahelp>"

#. QqVZa
#: 02050000.xhp
msgctxt ""
"02050000.xhp\n"
"par_id3155552\n"
"help.text"
msgid "Each time you copy, the existing content of the clipboard is overwritten."
msgstr "ທຸກໆຄັ້ງທີ່ທ່ານສຳເນົາ, ເນື້ອໃນທີ່ມີຢູ່ໃນຄລິບບອດຈະຖືກຂຽນທັບ."

#. 2QeMJ
#: 02050000.xhp
msgctxt ""
"02050000.xhp\n"
"par_id3154824\n"
"help.text"
msgid "<switchinline select=\"sys\"><caseinline select=\"UNIX\"><variable id=\"unixkopieren\">$[officename] also supports the clipboard under Unix; however, you must use the <emph>$[officename]</emph> commands, such as <emph>Ctrl</emph>+<emph>C</emph>.</variable></caseinline></switchinline>"
msgstr "<switchinline select=\"sys\"><caseinline select=\"UNIX\"><variable id=\"unixkopieren\">$[officename] ຍັງຮອງຮັບຄລິບບອດພາຍໃຕ້ Unix; ແນວໃດກໍຕາມ, ທ່ານຕ້ອງໃຊ້ຄຳສັ່ງ <emph>$[officename]</emph>, ເຊັ່ນ <emph>Ctrl</emph>+<emph>C</emph>.</variable></caseinline></switchinline>"

#. 6cWvs
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"tit\n"
"help.text"
msgid "Paste"
msgstr "ວາງ"

#. c63JD
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"bm_id3149031\n"
"help.text"
msgid "<bookmark_value>pasting; cell ranges</bookmark_value><bookmark_value>clipboard; pasting</bookmark_value><bookmark_value>cells; pasting</bookmark_value><bookmark_value>pasting; Enter key</bookmark_value><bookmark_value>pasting; Ctrl+V shortcut</bookmark_value>"
msgstr "<bookmark_value>ການວາງ; ຊ່ວງຫ້ອງ</bookmark_value><bookmark_value>ຄລິບບອດ; ການວາງ</bookmark_value><bookmark_value>ຫ້ອງ; ການວາງ</bookmark_value><bookmark_value>ການວາງ; ປຸ່ມ Enter</bookmark_value><bookmark_value>ການວາງ; ປຸ່ມລັດ Ctrl+V</bookmark_value>"

#. tSGK5
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"hd_id3149031\n"
"help.text"
msgid "<link href=\"text/shared/01/02060000.xhp\">Paste</link>"
msgstr "<link href=\"text/shared/01/02060000.xhp\">ວາງ</link>"

#. 5V5zS
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id3149511\n"
"help.text"
msgid "<ahelp hid=\".uno:Paste\">Inserts the contents of the clipboard at the location of the cursor, and replaces any selected text or objects.</ahelp>"
msgstr "<ahelp hid=\".uno:Paste\">ແຊກເນື້ອໃນຂອງຄລິບບອດລົງໃນຕຳແໜ່ງຂອງເຄີເຊີ, ແລະ ແທນທີ່ຂໍ້ຄວາມ ຫຼື ວັດຖຸໃດໜຶ່ງທີ່ເລືອກໄວ້.</ahelp>"

#. Na5CY
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id551521061448109\n"
"help.text"
msgid "Press the <emph>Enter</emph> key."
msgstr "ກົດປຸ່ມ <emph>Enter</emph>."

#. VXjYp
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id3147834\n"
"help.text"
msgid "In a spreadsheet, when you paste a range of cells from the clipboard, the result depends on the current selection: If only one cell is selected, the cell range will be pasted started from that cell. If you mark a cell range wider than the cell range in the clipboard, the cell range will be pasted repeatedly to fill the selected cell range."
msgstr "ໃນສະເປຣດຊີດ, ເມື່ອທ່ານວາງຊ່ວງຫ້ອງຈາກຄລິບບອດ, ຜົນລັບຈະຂຶ້ນກັບການເລືອກປັດຈຸບັນ: ຖ້າເລືອກພຽງຫ້ອງດຽວ, ຊ່ວງຫ້ອງຈະຖືກວາງເລີ່ມຈາກຫ້ອງນັ້ນ. ຖ້າທ່ານໝາຍຊ່ວງຫ້ອງທີ່ກວ້າງກວ່າຊ່ວງຫ້ອງໃນຄລິບບອດ, ຊ່ວງຫ້ອງຈະຖືກວາງຊ້ຳໆ ເພື່ອຕື່ມໃສ່ຊ່ວງຫ້ອງທີ່ເລືອກ."

#. DfGUG
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"hd_id221521057740108\n"
"help.text"
msgid "Pasting contents in %PRODUCTNAME Calc"
msgstr "ການວາງເນື້ອໃນໃນ %PRODUCTNAME Calc"

#. rUVnH
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id271521057645962\n"
"help.text"
msgid "When copying a cell or a range in %PRODUCTNAME Calc the selection is marked with blinking dashes around the range (the \"marching ants\") to indicate what was being selected during the clipboard operation."
msgstr "ເມື່ອສຳເນົາຫ້ອງ ຫຼື ຊ່ວງໃນ %PRODUCTNAME Calc, ສ່ວນທີ່ເລືອກຈະຖືກໝາຍດ້ວຍເສັ້ນຂີດກະພິບອ້ອມຮອບຊ່ວງນັ້ນ ເພື່ອບົ່ງບອກວ່າອັນໃດຖືກເລືອກໄວ້ໃນລະຫວ່າງການເຮັດວຽກຂອງຄລິບບອດ."

#. xGXym
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id481521058175847\n"
"help.text"
msgid "<image src=\"media/helpimg/sw_paste_range.png\" id=\"img_id541521058175847\" width=\"153\" height=\"60\"><alt id=\"alt_id221521058175847\">Marching ants mark for Calc clipboard</alt></image>"
msgstr "<image src=\"media/helpimg/sw_paste_range.png\" id=\"img_id541521058175847\" width=\"153\" height=\"60\"><alt id=\"alt_id221521058175847\">ເສັ້ນຂີດກະພິບໝາຍສຳລັບຄລິບບອດ Calc</alt></image>"

#. x7oBY
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id861521058166011\n"
"help.text"
msgid "There are two ways to paste the clipboard contents in a spreadsheet document:"
msgstr "ມີສອງວິທີໃນການວາງເນື້ອໃນຄລິບບອດໃນເອກະສານສະເປຣດຊີດ:"

#. TAfBs
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id561521057687471\n"
"help.text"
msgid "Using <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+V</keycode> shortcut, the <emph>Paste</emph> icon in the toolbar or choose <menuitem>Edit - Paste</menuitem>: The contents of the clipboard is pasted in the target location and the clipboard keeps the contents for more paste operations. The copied selection mark stays active."
msgstr "ການໃຊ້ປຸ່ມລັດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline><keycode>+V</keycode>, ໄອຄອນ <emph>ວາງ</emph> ໃນແຖບເຄື່ອງມື ຫຼື ເລືອກ <menuitem>ແກ້ໄຂ - ວາງ</menuitem>: ເນື້ອໃນຂອງຄລິບບອດຈະຖືກວາງໃນຕຳແໜ່ງເປົ້າໝາຍ ແລະ ຄລິບບອດຍັງຄົງຮັກສາເນື້ອໃນໄວ້ສຳລັບການວາງຄັ້ງຕໍ່ໆ ໄປ. ເຄື່ອງໝາຍການເລືອກທີ່ສຳເນົາໄວ້ຈະຍັງຄົງເຮັດວຽກຢູ່."

#. 33eAD
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id811521057699468\n"
"help.text"
msgid "Using <emph>Enter</emph> key: the clipboard contents is pasted once and cleared. No further paste is possible with the clipboard contents. The copied selection mark is disabled."
msgstr "ການໃຊ້ປຸ່ມ <emph>Enter</emph>: ເນື້ອໃນຄລິບບອດຈະຖືກວາງພຽງຄັ້ງດຽວແລ້ວຖືກລ້າງອອກ. ຈະບໍ່ສາມາດວາງເນື້ອໃນຄລິບບອດນັ້ນໄດ້ອີກ. ເຄື່ອງໝາຍການເລືອກທີ່ສຳເນົາໄວ້ຈະຖືກປິດການໃຊ້ງານ."

#. BVBac
#: 02060000.xhp
msgctxt ""
"02060000.xhp\n"
"par_id531521057600924\n"
"help.text"
msgid "To deactivate the copied selection mark press the <emph>Esc</emph> key. The clipboard contents is not cleared."
msgstr "ເພື່ອປິດການເຮັດວຽກຂອງເຄື່ອງໝາຍການເລືອກທີ່ສຳເນົາໄວ້ ໃຫ້ກົດປຸ່ມ <emph>Esc</emph>. ເນື້ອໃນຄລິບບອດຈະບໍ່ຖືກລ້າງອອກ."

#. nDnfv
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"tit\n"
"help.text"
msgid "Paste Special"
msgstr "ວາງແບບພິເສດ"

#. 8xMcK
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"bm_id591736114105911\n"
"help.text"
msgid "<bookmark_value>paste;paste special</bookmark_value><bookmark_value>copy;paste special</bookmark_value><bookmark_value>paste special</bookmark_value>"
msgstr "<bookmark_value>ວາງ;ວາງແບບພິເສດ</bookmark_value><bookmark_value>ສຳເນົາ;ວາງແບບພິເສດ</bookmark_value><bookmark_value>ວາງແບບພິເສດ</bookmark_value>"

#. KcyHo
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"hd_id3147477\n"
"help.text"
msgid "<variable id=\"paste_specialh1\"><link href=\"text/shared/01/02070000.xhp\">Paste Special</link></variable>"
msgstr "<variable id=\"paste_specialh1\"><link href=\"text/shared/01/02070000.xhp\">ວາງແບບພິເສດ</link></variable>"

#. 2xiJU
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"par_id3147143\n"
"help.text"
msgid "<variable id=\"inhalteeinfuegentext\"><ahelp hid=\".uno:PasteSpecial\">Inserts the contents of the clipboard into the current file in a format that you can specify.</ahelp></variable>"
msgstr "<variable id=\"inhalteeinfuegentext\"><ahelp hid=\".uno:PasteSpecial\">ແຊກເນື້ອໃນຂອງຄລິບບອດລົງໃນໄຟລ໌ປັດຈຸບັນໃນຮູບແບບທີ່ທ່ານສາມາດລະບຸໄດ້.</ahelp></variable>"

#. uZccp
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"hd_id3147576\n"
"help.text"
msgid "Source"
msgstr "ແຫຼ່ງຂໍ້ມູນ"

#. NFaLQ
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"par_id3149388\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pastespecial/source\">Displays the source of the clipboard contents.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pastespecial/source\">ສະແດງແຫຼ່ງທີ່ມາຂອງເນື້ອໃນຄລິບບອດ.</ahelp>"

#. fqXBq
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"hd_id3153684\n"
"help.text"
msgid "Selection"
msgstr "ສ່ວນທີ່ເລືອກ"

#. KVhBz
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"par_id3149812\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/pastespecial/list\">Select a format for the clipboard contents that you want to paste. The available format depends on the copied or cut source format.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/pastespecial/list\">ເລືອກຮູບແບບສຳລັບເນື້ອໃນຄລິບບອດທີ່ທ່ານຕ້ອງການວາງ. ຮູບແບບທີ່ມີໃຫ້ໃຊ້ຈະຂຶ້ນກັບຮູບແບບຕົ້ນສະບັບທີ່ຖືກສຳເນົາ ຫຼື ຕັດມາ.</ahelp>"

#. 95aCW
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"hd_id631739723778181\n"
"help.text"
msgid "Use Text Import dialog"
msgstr "ໃຊ້ກ່ອງໂຕ້ຕອບນຳເຂົ້າຂໍ້ຄວາມ"

#. rEGEV
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"par_id351739723768701\n"
"help.text"
msgid "Opens the <link href=\"text/shared/00/00000208.xhp\">Text Import</link> dialog to set the import options for delimited data."
msgstr "ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/00/00000208.xhp\">ນຳເຂົ້າຂໍ້ຄວາມ</link> ເພື່ອຕັ້ງຕົວເລືອກການນຳເຂົ້າສຳລັບຂໍ້ມູນທີ່ມີຕົວຂັ້ນ."

#. HzshB
#: 02070000.xhp
msgctxt ""
"02070000.xhp\n"
"par_id3147653\n"
"help.text"
msgid "When you paste HTML data into a text document, you can choose \"<emph>HTML format</emph>\" or \"<emph>HTML format without comments</emph>\". The second choice is the default; it pastes all HTML data, but no comments."
msgstr "ເມື່ອທ່ານວາງຂໍ້ມູນ HTML ລົງໃນເອກະສານຂໍ້ຄວາມ, ທ່ານສາມາດເລືອກ \"<emph>ຮູບແບບ HTML</emph>\" ຫຼື \"<emph>ຮູບແບບ HTML ທີ່ບໍ່ມີຄຳເຫັນ</emph>\". ຕົວເລືອກທີສອງແມ່ນຄ່າເລີ່ມຕົ້ນ; ມັນຈະວາງຂໍ້ມູນ HTML ທັງໝົດ ແຕ່ບໍ່ລວມຄຳເຫັນ."

#. 2fEf3
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"tit\n"
"help.text"
msgid "Select All"
msgstr "ເລືອກທັງໝົດ"

#. jjEMm
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"hd_id3145138\n"
"help.text"
msgid "<link href=\"text/shared/01/02090000.xhp\">Select All</link>"
msgstr "<link href=\"text/shared/01/02090000.xhp\">ເລືອກທັງໝົດ</link>"

#. TZK3G
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"par_idN105DB\n"
"help.text"
msgid "<ahelp hid=\".\">Selects all entries, including subfolders, in the lower part of the database window.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກທຸກລາຍການ, ລວມທັງໂຟນເດີຍ່ອຍ, ໃນສ່ວນລຸ່ມຂອງໜ້າຕ່າງຖານຂໍ້ມູນ.</ahelp>"

#. PDEFv
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"par_id3149999\n"
"help.text"
msgid "<variable id=\"allestext\"><ahelp hid=\".\">Selects the entire content of the current file, frame, or text object.</ahelp></variable>"
msgstr "<variable id=\"allestext\"><ahelp hid=\".\">ເລືອກເນື້ອໃນທັງໝົດຂອງໄຟລ໌, ເຟຣມ ຫຼື ວັດຖຸຂໍ້ຄວາມປັດຈຸບັນ.</ahelp></variable>"

#. rvjqF
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"par_id3155261\n"
"help.text"
msgid "To select all of the cells on a sheet, click the button at the intersection of the column and row header in the top left corner of the sheet."
msgstr "ເພື່ອເລືອກທຸກຫ້ອງໃນແຜ່ນງານ, ໃຫ້ຄລິກທີ່ປຸ່ມຈຸດຕັດກັນລະຫວ່າງຫົວຖັນ ແລະ ຫົວແຖວ ຢູ່ມຸມເທິງຊ້າຍຂອງແຜ່ນງານ."

#. 452c4
#: 02090000.xhp
msgctxt ""
"02090000.xhp\n"
"par_id3154046\n"
"help.text"
msgid "To select all of the sheets in a spreadsheet file, right-click the name tab of a sheet, and then choose <emph>Select All Sheets</emph>."
msgstr "ເພື່ອເລືອກທຸກແຜ່ນງານໃນໄຟລ໌ສະເປຣດຊີດ, ໃຫ້ຄລິກຂວາທີ່ແຖບຊື່ແຜ່ນງານ, ແລ້ວເລືອກ <emph>ເລືອກທຸກແຜ່ນງານ</emph>."

#. C8Qow
