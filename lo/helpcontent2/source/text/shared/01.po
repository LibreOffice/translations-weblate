"help.text"
msgid "<link href=\"text/shared/01/05210300.xhp\">Gradient</link>"
msgstr "<link href=\"text/shared/01/05210300.xhp\">ສີໄລ່ລະດັບ</link>"

#. jFoGv
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id3153716\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/areatabpage/btngradient\">Fills the object with a gradient selected on this page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/areatabpage/btngradient\">ເຕີມວັດຖຸດ້ວຍສີໄລ່ລະດັບທີ່ເລືອກໃນໜ້ານີ້.</ahelp>"

#. zE5v4
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"hd_id3154047\n"
"help.text"
msgid "<link href=\"text/shared/01/05210400.xhp\">Hatch</link>"
msgstr "<link href=\"text/shared/01/05210400.xhp\">ເສັ້ນຂີດສານ</link>"

#. uBWuP
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id3153698\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/areatabpage/btnhatch\">Fills the object with a hatching pattern selected on this page.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/areatabpage/btnhatch\">ເຕີມວັດຖຸດ້ວຍລວດລາຍເສັ້ນຂີດສານທີ່ເລືອກໃນໜ້ານີ້.</ahelp>"

#. PHhMR
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id3148548\n"
"help.text"
msgid "You can quickly select fill options from the list boxes on the <emph>Drawing Object Properties</emph> toolbar."
msgstr "ທ່ານສາມາດເລືອກຕົວເລືອກການເຕີມໄດ້ຢ່າງວ່ອງໄວຈາກກ່ອງລາຍການໃນແຖບເຄື່ອງມື <emph>ຄຸນສົມບັດວັດຖຸການແຕ້ມ</emph>."

#. VXtH8
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"hd_id571693919143757\n"
"help.text"
msgid "Use Background"
msgstr "ໃຊ້ພື້ນຫຼັງ"

#. shJ58
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id191693919151752\n"
"help.text"
msgid "Use the slide background as a fill. This differs from \"None\" in that the area is actually filled with the slide background at that location, instead of simply showing what is behind the shape."
msgstr "ໃຊ້ພື້ນຫຼັງຂອງສະໄລ້ເປັນການເຕີມ. ນີ້ແຕກຕ່າງຈາກ \"ບໍ່ມີ\" ບ່ອນທີ່ພື້ນທີ່ຖືກເຕີມດ້ວຍພື້ນຫຼັງຂອງສະໄລ້ໃນຕຳແໜ່ງນັ້ນແທ້ໆ, ແທນທີ່ຈະພຽງແຕ່ສະແດງສິ່ງທີ່ຢູ່ເບື້ອງຫຼັງຮູບຊົງ."

#. fHkWx
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id661696079947729\n"
"help.text"
msgid "<image src=\"media/helpimg/sdraw/area-fill-none-same-vs-background.png\" id=\"img_id871696079947730\" width=\"700px\" height=\"392px\"><alt id=\"alt_id991696079947732\">Illustration of different fill styles.</alt></image>"
msgstr "<image src=\"media/helpimg/sdraw/area-fill-none-same-vs-background.png\" id=\"img_id871696079947730\" width=\"700px\" height=\"392px\"><alt id=\"alt_id991696079947732\">ພາບປະກອບຂອງຮູບແບບການເຕີມທີ່ແຕກຕ່າງກັນ.</alt></image>"

#. bGYMC
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id221696080666194\n"
"help.text"
msgid "<emph>Use Background</emph>: the object area is filled with the background fill. The object covers the blue circle."
msgstr "<emph>ໃຊ້ພື້ນຫຼັງ</emph>: ພື້ນທີ່ວັດຖຸຖືກເຕີມດ້ວຍການເຕີມພື້ນຫຼັງ. ວັດຖຸປິດທັບວົງມົນສີຟ້າ."

#. mPeAP
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id331696080747331\n"
"help.text"
msgid "<emph>Fill</emph>: The object uses the same gradient fill of the background. The object covers the blue circle."
msgstr "<emph>ເຕີມ</emph>: ວັດຖຸໃຊ້ການເຕີມສີໄລ່ລະດັບດຽວກັນກັບພື້ນຫຼັງ. ວັດຖຸປິດທັບວົງມົນສີຟ້າ."

#. BtnCt
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id991696080772879\n"
"help.text"
msgid "<emph>None</emph>: the object does not have a fill. The blue circle is visible though the object."
msgstr "<emph>ບໍ່ມີ</emph>: ວັດຖຸບໍ່ມີການເຕີມ. ສາມາດເຫັນວົງມົນສີຟ້າຜ່ານວັດຖຸໄດ້."

#. CiGCw
#: 05210100.xhp
msgctxt ""
"05210100.xhp\n"
"par_id3154673\n"
"help.text"
msgid "<variable id=\"sytext\"><ahelp hid=\".uno:FillStyle\">Select the type of fill that you want to apply to the selected drawing object.</ahelp></variable>"
msgstr "<variable id=\"sytext\"><ahelp hid=\".uno:FillStyle\">ເລືອກປະເພດການເຕີມທີ່ທ່ານຕ້ອງການນຳໃຊ້ກັບວັດຖຸການແຕ້ມທີ່ເລືອກ.</ahelp></variable>"

#. GUfm5
