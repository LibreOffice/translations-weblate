msgstr "<variable id=\"picktitle\"><link href=\"text/shared/01/01990000.xhp\">ເອກະສານຫຼ້າສຸດ</link></variable>"

#. doka7
#: 01990000.xhp
msgctxt ""
"01990000.xhp\n"
"par_id3154794\n"
"help.text"
msgid "<ahelp hid=\".\">Lists the most recently opened files. To open a file in the list, click its name.</ahelp>"
msgstr "<ahelp hid=\".\">ລາຍຊື່ໄຟລ໌ທີ່ເປີດຫຼ້າສຸດ. ເພື່ອເປີດໄຟລ໌ໃນລາຍຊື່, ໃຫ້ຄລິກທີ່ຊື່ໄຟລ໌ນັ້ນ.</ahelp>"

#. KWWCZ
#: 01990000.xhp
msgctxt ""
"01990000.xhp\n"
"par_id4154794\n"
"help.text"
msgid "The number of files that are listed can be changed in the <link href=\"text/shared/optionen/expertconfig.xhp\">Expert configuration</link> by setting the property <emph>/org.openoffice.Office.Common/History PickListSize</emph>."
msgstr "ຈຳນວນໄຟລ໌ທີ່ສະແດງໃນລາຍຊື່ສາມາດປ່ຽນແປງໄດ້ໃນ <link href=\"text/shared/optionen/expertconfig.xhp\">ການກຳນົດຄ່າແບບຊ່ຽວຊານ</link> ໂດຍການຕັ້ງຄ່າຄຸນສົມບັດ <emph>/org.openoffice.Office.Common/History PickListSize</emph>."

#. MNVq8
#: 01990000.xhp
msgctxt ""
"01990000.xhp\n"
"par_id3159079\n"
"help.text"
msgid "The file is opened by the <item type=\"productname\">%PRODUCTNAME</item> module that saved it."
msgstr "ໄຟລ໌ຈະຖືກເປີດໂດຍໂມດູນ <item type=\"productname\">%PRODUCTNAME</item> ທີ່ໄດ້ບັນທຶກມັນໄວ້."

#. m3ctR
#: 02010000.xhp
