"par_id3145606\n"
"help.text"
msgid "<link href=\"text/swriter/guide/anchor_object.xhp\">Positioning Objects</link>"
msgstr "<link href=\"text/swriter/guide/anchor_object.xhp\">ການຈັດຕຳແໜ່ງວັດຖຸ</link>"

#. wT2dE
