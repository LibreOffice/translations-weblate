"par_id3154840\n"
"help.text"
msgid "<variable id=\"object_text\"><ahelp hid=\".uno:ObjectMenue\">Lets you edit a selected OLE object that you inserted from the <menuitem>Insert - OLE Object</menuitem> submenu.</ahelp></variable>"
msgstr "<variable id=\"object_text\"><ahelp hid=\".uno:ObjectMenue\">ຊ່ວຍໃຫ້ທ່ານແກ້ໄຂວັດຖຸ OLE ທີ່ເລືອກ ເຊິ່ງທ່ານໄດ້ແຊກມາຈາກເມນູຍ່ອຍ <menuitem>ແຊກ - ວັດຖຸ OLE</menuitem>.</ahelp></variable>"

#. APiJh
