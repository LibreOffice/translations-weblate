#. Aj9D7
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"tit\n"
"help.text"
msgid "Similarity Search"
msgstr "ການຄົ້ນຫາແບບຄ້າຍຄືກັນ"

#. t6yWA
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"bm_id3156045\n"
"help.text"
msgid "<bookmark_value>similarity search</bookmark_value><bookmark_value>finding; similarity search</bookmark_value>"
msgstr "<bookmark_value>ການຄົ້ນຫາແບບຄ້າຍຄືກັນ</bookmark_value><bookmark_value>ການຄົ້ນຫາ; ການຄົ້ນຫາແບບຄ້າຍຄືກັນ</bookmark_value>"

#. zrPe5
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3156045\n"
"help.text"
msgid "<variable id=\"similarity_search\"><link href=\"text/shared/01/02100100.xhp\">Similarity Search</link></variable>"
msgstr "<variable id=\"similarity_search\"><link href=\"text/shared/01/02100100.xhp\">ການຄົ້ນຫາແບບຄ້າຍຄືກັນ</link></variable>"

#. cMi8S
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3146856\n"
"help.text"
msgid "<ahelp hid=\"svx/ui/findreplacedialog/similarity\">Find terms that are similar to the <emph>Find</emph> text. Select this checkbox, and then click the <emph>Similarities</emph> button to define the similarity options.</ahelp>"
msgstr "<ahelp hid=\"svx/ui/findreplacedialog/similarity\">ຄົ້ນຫາຄຳສັບທີ່ຄ້າຍຄືກັບຂໍ້ຄວາມ <emph>ຄົ້ນຫາ</emph>. ເລືອກຊ່ອງໝາຍນີ້, ແລ້ວຄລິກປຸ່ມ <emph>ຄວາມຄ້າຍຄືກັນ</emph> ເພື່ອກຳນົດຕົວເລືອກຄວາມຄ້າຍຄືກັນ.</ahelp>"

#. PGhDm
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3149551\n"
"help.text"
msgid "For example, a similarity search can find words that differ from the <emph>Find</emph> text by two characters."
msgstr "ຕົວຢ່າງ: ການຄົ້ນຫາແບບຄ້າຍຄືກັນສາມາດຄົ້ນຫາຄຳສັບທີ່ແຕກຕ່າງຈາກຂໍ້ຄວາມ <emph>ຄົ້ນຫາ</emph> ໄດ້ສອງຕົວອັກສອນ."

#. AxQVS
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3149511\n"
"help.text"
msgid "Similarities"
msgstr "ຄວາມຄ້າຍຄືກັນ"

#. ZeAFT
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3152594\n"
"help.text"
msgid "Define the criteria for determining if a word is similar to the search term."
msgstr "ກຳນົດເງື່ອນໄຂສຳລັບການພິຈາລະນາວ່າຄຳສັບໃດໜຶ່ງຄ້າຍຄືກັບຄຳຄົ້ນຫາຫຼືບໍ່."

#. cMdSn
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3153551\n"
"help.text"
msgid "Exchange characters"
msgstr "ປ່ຽນແປງຕົວອັກສອນ"

#. zcrkK
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3152551\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/similaritysearchdialog/otherfld\">Enter the number of characters in the search term that can be exchanged.</ahelp> For example, if you specify 2 exchanged characters, \"sweep\" and \"creep\" are considered similar, when exchanging \"sw\" and \"cr\"."
msgstr "<ahelp hid=\"cui/ui/similaritysearchdialog/otherfld\">ປ້ອນຈຳນວນຕົວອັກສອນໃນຄຳຄົ້ນຫາທີ່ສາມາດປ່ຽນແປງໄດ້.</ahelp> ຕົວຢ່າງ: ຖ້າທ່ານກຳນົດການປ່ຽນແປງຕົວອັກສອນ 2 ຕົວ, \"sweep\" ແລະ \"creep\" ຈະຖືກຖືວ່າຄ້າຍຄືກັນ, ເມື່ອປ່ຽນ \"sw\" ແລະ \"cr\"."

#. kAF4X
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3147010\n"
"help.text"
msgid "Add characters"
msgstr "ເພີ່ມຕົວອັກສອນ"

#. oB3SG
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3109847\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/similaritysearchdialog/longerfld\">Enter the maximum number of characters by which a word can exceed the number of characters in the search term.</ahelp> For example, if you specify 3 additional characters, \"long\" and \"longest\" are considered similar, but not \"longitude\"."
msgstr "<ahelp hid=\"cui/ui/similaritysearchdialog/longerfld\">ປ້ອນຈຳນວນຕົວອັກສອນສູງສຸດທີ່ຄຳສັບໜຶ່ງສາມາດມີເກີນຈຳນວນຕົວອັກສອນໃນຄຳຄົ້ນຫາ.</ahelp> ຕົວຢ່າງ: ຖ້າທ່ານກຳນົດໃຫ້ເພີ່ມຕົວອັກສອນໄດ້ 3 ຕົວ, \"long\" ແລະ \"longest\" ຈະຖືກຖືວ່າຄ້າຍຄືກັນ, ແຕ່ບໍ່ແມ່ນ \"longitude\"."

#. Fit8C
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3166460\n"
"help.text"
msgid "Remove characters"
msgstr "ລຶບຕົວອັກສອນ"

#. ejxAG
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3148685\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/similaritysearchdialog/shorterfld\">Enter the number of characters by which a word can be shorter than the search term.</ahelp>For example, if you specify 3 removed characters, \"longitude\" and \"longest\" are considered similar, but not \"long\"."
msgstr "<ahelp hid=\"cui/ui/similaritysearchdialog/shorterfld\">ປ້ອນຈຳນວນຕົວອັກສອນທີ່ຄຳສັບໜຶ່ງສາມາດສັ້ນກວ່າຄຳຄົ້ນຫາ.</ahelp> ຕົວຢ່າງ: ຖ້າທ່ານກຳນົດການລຶບຕົວອັກສອນ 3 ຕົວ, \"longitude\" ແລະ \"longest\" ຈະຖືກຖືວ່າຄ້າຍຄືກັນ, ແຕ່ບໍ່ແມ່ນ \"long\"."

#. KGAr5
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"hd_id3153700\n"
"help.text"
msgid "Combine"
msgstr "ຮວມກັນ"

#. FfPQC
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id3156553\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/similaritysearchdialog/relaxbox\">Searches for a term that matches any combination of the similarity search settings.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/similaritysearchdialog/relaxbox\">ຄົ້ນຫາຄຳສັບທີ່ກົງກັບການປະສົມປະສານໃດໜຶ່ງຂອງການຕັ້ງຄ່າການຄົ້ນຫາແບບຄ້າຍຄືກັນ.</ahelp>"

#. CwThK
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id491602292458634\n"
"help.text"
msgid "Using <emph>Combine</emph> better meets a user's expectations from looking at the settings, but may return false positives. Not using <emph>Combine</emph> may match less than expected, but does not return false positives."
msgstr "ການໃຊ້ <emph>ຮວມກັນ</emph> ຈະຕອບສະໜອງຄວາມຄາດຫວັງຂອງຜູ້ໃຊ້ຈາກການຕັ້ງຄ່າໄດ້ດີກວ່າ, ແຕ່ອາດຈະສົ່ງຄືນຜົນການຄົ້ນຫາທີ່ຜິດພາດ (false positives). ການບໍ່ໃຊ້ <emph>ຮວມກັນ</emph> ອາດຈະຈັບຄູ່ໄດ້ໜ້ອຍກວ່າທີ່ຄາດໄວ້, ແຕ່ຈະບໍ່ສົ່ງຄືນຜົນການຄົ້ນຫາທີ່ຜິດພາດ."

#. iffJC
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id401602236795437\n"
"help.text"
msgid "A Weighted Levenshtein Distance (WLD) algorithm is used. If <emph>Combine</emph> is not checked, then settings are treated as an exclusive-OR (strict WLD). If <emph>Combine</emph> is checked, then settings are treated as an inclusive-OR (relaxed WLD)."
msgstr "ມີການໃຊ້ລະບົບໄລຍະຫ່າງ Levenshtein ແບບຖ່ວງນ້ຳໜັກ (Weighted Levenshtein Distance - WLD). ຖ້າບໍ່ໄດ້ໝາຍເລືອກ <emph>ຮວມກັນ</emph>, ການຕັ້ງຄ່າຈະຖືກປະຕິບັດເປັນແບບ exclusive-OR (WLD ແບບເຂັ້ມງວດ). ຖ້າໝາຍເລືອກ <emph>ຮວມກັນ</emph>, ການຕັ້ງຄ່າຈະຖືກປະຕິບັດເປັນແບບ inclusive-OR (WLD ແບບຜ່ອນຜັນ)."

#. eZ2dA
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id371602294412458\n"
"help.text"
msgid "Be careful when using <emph>Replace All</emph> with Similarity Search. Best to be certain first about what will be found."
msgstr "ໃຫ້ລະມັດລະວັງເມື່ອໃຊ້ <emph>ແທນທີ່ທັງໝົດ</emph> ກັບການຄົ້ນຫາແບບຄ້າຍຄືກັນ. ຄວນແນ່ໃຈກ່ອນວ່າຈະພົບສິ່ງໃດ."

#. syUAC
#: 02100100.xhp
msgctxt ""
"02100100.xhp\n"
"par_id561723580819885\n"
"help.text"
msgid "<link href=\"https://en.wikipedia.org/wiki/Levenshtein_distance\">Levenshtein Distance algorithm in Wikipedia</link>"
msgstr "<link href=\"https://en.wikipedia.org/wiki/Levenshtein_distance\">ລະບົບໄລຍະຫ່າງ Levenshtein ໃນ Wikipedia</link>"

