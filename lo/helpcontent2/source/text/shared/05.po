#. 73Gwo
#: new_help.xhp
msgctxt ""
"new_help.xhp\n"
"par_id171534888116942\n"
"help.text"
msgid "%PRODUCTNAME Help pages are displayed in your system default web browser."
msgstr "ໜ້າວິທີໃຊ້ %PRODUCTNAME ຈະຖືກສະແດງຢູ່ໃນເວັບບຣາວເຊີມາດຕະຖານຂອງລະບົບທ່ານ."

#. pCtBo
#: new_help.xhp
msgctxt ""
"new_help.xhp\n"
"par_id3156183\n"
"help.text"
msgid "The Help system for all versions of the software is based on the same source files. Some of the functions described in Help may not be included in this particular distribution. Some features specific to a distribution may not be mentioned in this Help."
msgstr "ລະບົບວິທີໃຊ້ສຳລັບທຸກເວີຊັນຂອງຊອບແວແມ່ນອີງໃສ່ໄຟລ໌ຕົ້ນສະບັບດຽວກັນ. ບາງຟັງຊັນທີ່ອະທິບາຍໃນວິທີໃຊ້ອາດຈະບໍ່ມີຢູ່ໃນຊຸດຕິດຕັ້ງສະເພາະນີ້. ຄຸນສົມບັດບາງຢ່າງທີ່ເປັນຂອງສະເພາະບາງຊຸດຕິດຕັ້ງອາດຈະບໍ່ຖືກກ່າວເຖິງໃນວິທີໃຊ້ນີ້."

#. RuT4t
#: new_help.xhp
msgctxt ""
"new_help.xhp\n"
"par_id3147143\n"
"help.text"
msgid "<ahelp hid=\".uno:HelpOnHelp\" visibility=\"hidden\">Provides an overview of the Help system.</ahelp>"
msgstr "<ahelp hid=\".uno:HelpOnHelp\" visibility=\"hidden\">ໃຫ້ພາບລວມຂອງລະບົບວິທີໃຊ້.</ahelp>"

#. RrKY2
#: new_help.xhp
msgctxt ""
"new_help.xhp\n"
"par_id341534965962279\n"
"help.text"
msgid "Help pages of %PRODUCTNAME Extensions still use the old Help system. The old Help system help pages <link href=\"text/shared/05/00000110.xhp\">are available from here</link>."
msgstr "ໜ້າວິທີໃຊ້ຂອງສ່ວນຂະຫຍາຍ (Extensions) %PRODUCTNAME ຍັງຄົງໃຊ້ລະບົບວິທີໃຊ້ແບບເກົ່າ. ທ່ານສາມາດເຂົ້າເບິ່ງໜ້າວິທີໃຊ້ຂອງລະບົບເກົ່າ <link href=\"text/shared/05/00000110.xhp\">ໄດ້ທີ່ນີ້</link>."

#. HFYrD
