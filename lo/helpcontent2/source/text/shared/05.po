#. pqcge
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10926\n"
"help.text"
msgid "You can copy from the <emph>Help Viewer</emph> to the clipboard on your operating system with standard copy commands. For example:"
msgstr "ທ່ານສາມາດຄັດລອກຈາກ <emph>ບ່ອນສະແດງວິທີໃຊ້</emph> ໄປຍັງຄລິບບອດໃນລະບົບປະຕິບັດການຂອງທ່ານດ້ວຍຄຳສັ່ງຄັດລອກມາດຕະຖານ. ຕົວຢ່າງ:"

#. Ex84y
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN1092C\n"
"help.text"
msgid "On a Help page, select the text that you want to copy."
msgstr "ໃນໜ້າວິທີໃຊ້, ໃຫ້ເລືອກຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການຄັດລອກ."

#. GDeaH
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10930\n"
"help.text"
msgid "Press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+C</emph>."
msgstr "ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+C</emph>."

#. egTH7
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10933\n"
"help.text"
msgid "To search the current Help page:"
msgstr "ເພື່ອຄົ້ນຫາໃນໜ້າວິທີໃຊ້ປັດຈຸບັນ:"

#. j6RmU
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10939\n"
"help.text"
msgid "Click the <emph>Find on this Page</emph> icon."
msgstr "ຄລິກທີ່ໄອຄອນ <emph>ຄົ້ນຫາໃນໜ້ານີ້</emph>."

#. HB6gA
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10940\n"
"help.text"
msgid "The <emph>Find on this Page</emph> dialog opens."
msgstr "ກ່ອງໂຕ້ຕອບ <emph>ຄົ້ນຫາໃນໜ້ານີ້</emph> ຈະຖືກເປີດຂຶ້ນ."

#. L3FYC
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A36\n"
"help.text"
msgid "You can also click in the <emph>Help</emph> page and press <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+F</emph>."
msgstr "ທ່ານຍັງສາມາດຄລິກໃນໜ້າ <emph>ວິທີໃຊ້</emph> ແລ້ວກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline><emph>+F</emph>."

#. F5MsA
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A22\n"
"help.text"
msgid "In the <emph>Search for</emph> box, enter the text that you want to find."
msgstr "ໃນຊ່ອງ <emph>ຄົ້ນຫາ</emph>, ໃຫ້ປ້ອນຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການຫາ."

#. XPQQQ
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A48\n"
"help.text"
msgid "Select the search options that you want to use."
msgstr "ເລືອກຕົວເລືອກການຄົ້ນຫາທີ່ທ່ານຕ້ອງການໃຊ້."

#. dHfJj
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A26\n"
"help.text"
msgid "Click <emph>Find</emph>."
msgstr "ຄລິກ <emph>ຄົ້ນຫາ</emph>."

#. Ck8E6
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10A59\n"
"help.text"
msgid "To find the next occurrence of the search term on the page, click <emph>Find</emph> again."
msgstr "ເພື່ອຄົ້ນຫາຄຳສັບດັ່ງກ່າວໃນຈຸດຖັດໄປຂອງໜ້ານີ້, ໃຫ້ຄລິກ <emph>ຄົ້ນຫາ</emph> ອີກຄັ້ງ."

#. xYwKD
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10906\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/searchterm\" visibility=\"hidden\">Enter the text that you want to search for or select a text entry in the list.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/searchterm\" visibility=\"hidden\">ປ້ອນຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການຄົ້ນຫາ ຫຼື ເລືອກຂໍ້ຄວາມຈາກລາຍການ.</ahelp>"

#. BxuRD
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN10993\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/wholewords\" visibility=\"hidden\">Finds complete words only.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/wholewords\" visibility=\"hidden\">ຄົ້ນຫາສະເພາະຄຳສັບທີ່ກົງກັນທັງໝົດເທົ່ານັ້ນ.</ahelp>"

#. morri
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109AA\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/matchcase\" visibility=\"hidden\">Distinguishes between uppercase text and lowercase text.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/matchcase\" visibility=\"hidden\">ແຍກຄວາມແຕກຕ່າງລະຫວ່າງຕົວອັກສອນໃຫຍ່ ແລະ ຕົວອັກສອນນ້ອຍ.</ahelp>"

#. EDGGQ
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109C1\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/wrap\" visibility=\"hidden\">Searches the entire Help page, starting at the current position of the cursor.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/wrap\" visibility=\"hidden\">ຄົ້ນຫາທົ່ວທັງໜ້າວິທີໃຊ້ ໂດຍເລີ່ມຈາກຕຳແໜ່ງປັດຈຸບັນຂອງເຄີເຊີ.</ahelp>"

#. TQJer
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109D8\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/backwards\" visibility=\"hidden\">Searches backwards from the current position of the cursor.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/backwards\" visibility=\"hidden\">ຄົ້ນຫາຍ້ອນກັບຈາກຕຳແໜ່ງປັດຈຸບັນຂອງເຄີເຊີ.</ahelp>"

#. DFKRX
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_idN109F5\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/searchdialog/search\" visibility=\"hidden\">Finds the next occurrence of the search term.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/searchdialog/search\" visibility=\"hidden\">ຄົ້ນຫາຄຳສັບໃນຈຸດຖັດໄປ.</ahelp>"

#. 9tiYQ
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"hd_id3149202\n"
"help.text"
msgid "Navigation Pane"
msgstr "ຊ່ອງນຳທາງ"

#. cqyrd
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3148673\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontrol/tabcontrol\">The navigation pane of the Help window contains the tab pages <emph>Contents</emph>, <emph>Index</emph>, <emph>Find</emph> and <emph>Bookmarks</emph>.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpcontrol/tabcontrol\">ຊ່ອງນຳທາງຂອງໜ້າຕ່າງວິທີໃຊ້ປະກອບດ້ວຍແຖບໜ້າ <emph>ເນື້ອໃນ</emph>, <emph>ດັດຊະນີ</emph>, <emph>ຄົ້ນຫາ</emph> ແລະ <emph>ບຸກມາກ</emph>.</ahelp>"

#. FkVic
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3159149\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontrol/active\">The list box located at the very top is where you can select other <item type=\"productname\">%PRODUCTNAME</item> Help modules.</ahelp> The <emph>Index</emph> and <emph>Find</emph> tab pages only contain the data for the selected <item type=\"productname\">%PRODUCTNAME</item> module."
msgstr "<ahelp hid=\"sfx/ui/helpcontrol/active\">ກ່ອງລາຍການທີ່ຢູ່ທາງເທິງສຸດແມ່ນບ່ອນທີ່ທ່ານສາມາດເລືອກໂມດູນວິທີໃຊ້ອື່ນໆຂອງ <item type=\"productname\">%PRODUCTNAME</item>.</ahelp> ແຖບໜ້າ <emph>ດັດຊະນີ</emph> ແລະ <emph>ຄົ້ນຫາ</emph> ຈະມີສະເພາະຂໍ້ມູນຂອງໂມດູນ <item type=\"productname\">%PRODUCTNAME</item> ທີ່ຖືກເລືອກໄວ້ເທົ່ານັ້ນ."

#. mxK3r
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3149983\n"
"help.text"
msgid "<link href=\"text/shared/05/00000160.xhp\">Contents</link>"
msgstr "<link href=\"text/shared/05/00000160.xhp\">ເນື້ອໃນ</link>"

#. mDkhN
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3145748\n"
"help.text"
msgid "Displays an index of the main topics of all modules."
msgstr "ສະແດງລາຍການຫົວຂໍ້ຫຼັກຂອງທຸກໂມດູນ."

#. Wh34C
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3155366\n"
"help.text"
msgid "<link href=\"text/shared/05/00000130.xhp\">Index</link>"
msgstr "<link href=\"text/shared/05/00000130.xhp\">ດັດຊະນີ</link>"

#. xsWx8
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3151351\n"
"help.text"
msgid "Displays a list of index keywords for the currently selected %PRODUCTNAME module."
msgstr "ສະແດງລາຍການຄຳຫຼັກຂອງດັດຊະນີສຳລັບໂມດູນ %PRODUCTNAME ທີ່ຖືກເລືອກໃນປັດຈຸບັນ."

#. ihDdx
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3149260\n"
"help.text"
msgid "<link href=\"text/shared/05/00000140.xhp\">Find</link>"
msgstr "<link href=\"text/shared/05/00000140.xhp\">ຄົ້ນຫາ</link>"

#. sb2MP
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3154188\n"
"help.text"
msgid "Allows you to carry out a full-text search. The search will include the entire Help contents of the currently selected <item type=\"productname\">%PRODUCTNAME</item> module."
msgstr "ຊ່ວຍໃຫ້ທ່ານສາມາດຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດ. ການຄົ້ນຫາຈະລວມເອົາເນື້ອໃນວິທີໃຊ້ທັງໝົດຂອງໂມດູນ <item type=\"productname\">%PRODUCTNAME</item> ທີ່ຖືກເລືອກໄວ້."

#. NQRts
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3154985\n"
"help.text"
msgid "<link href=\"text/shared/05/00000150.xhp\">Bookmarks</link>"
msgstr "<link href=\"text/shared/05/00000150.xhp\">ບຸກມາກ</link>"

#. AypHA
#: 00000110.xhp
msgctxt ""
"00000110.xhp\n"
"par_id3156062\n"
"help.text"
msgid "Contains user-defined bookmarks. You can edit or delete bookmarks, or click them to go to the corresponding pages."
msgstr "ປະກອບດ້ວຍບຸກມາກທີ່ຜູ້ໃຊ້ກຳນົດເອງ. ທ່ານສາມາດແກ້ໄຂ ຫຼື ລຶບບຸກມາກ, ຫຼື ຄລິກໃສ່ພວກມັນເພື່ອໄປຫາໜ້າທີ່ກ່ຽວຂ້ອງ."

#. oZkWs
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"tit\n"
"help.text"
msgid "Tips and Extended Tips"
msgstr "ເຄັດລັບ ແລະ ເຄັດລັບເພີ່ມເຕີມ"

#. YfEyC
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"bm_id3150672\n"
"help.text"
msgid "<bookmark_value>Help; Help tips</bookmark_value><bookmark_value>tooltips; help</bookmark_value>"
msgstr "<bookmark_value>ວິທີໃຊ້; ເຄັດລັບວິທີໃຊ້</bookmark_value><bookmark_value>ທູນທິບ; ວິທີໃຊ້</bookmark_value>"

#. iE7DY
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"hd_id3155599\n"
"help.text"
msgid "<variable id=\"00000120\"><link href=\"text/shared/05/00000120.xhp\">Tips and Extended Tips</link></variable>"
msgstr "<variable id=\"00000120\"><link href=\"text/shared/05/00000120.xhp\">ເຄັດລັບ ແລະ ເຄັດລັບເພີ່ມເຕີມ</link></variable>"

#. UWpFA
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_id3148520\n"
"help.text"
msgid "Tips and Extended Tips provide help while you work."
msgstr "ເຄັດລັບ ແລະ ເຄັດລັບເພີ່ມເຕີມໃຫ້ຄວາມຊ່ວຍເຫຼືອໃນຂະນະທີ່ທ່ານເຮັດວຽກ."

#. U4ku2
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"hd_id3149140\n"
"help.text"
msgid "Tips"
msgstr "ເຄັດລັບ"

#. JvD9y
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_id3157896\n"
"help.text"
msgid "<emph>Tips</emph> provide you with the names of toolbar buttons. To display a tip, rest the pointer over a toolbar button until the name of the button appears."
msgstr "<emph>ເຄັດລັບ</emph> ຈະບອກຊື່ຂອງປຸ່ມຕ່າງໆໃນແຖບເຄື່ອງມື. ເພື່ອສະແດງເຄັດລັບ, ໃຫ້ວາງຕົວຊີ້ (pointer) ໄວ້ເທິງປຸ່ມແຖບເຄື່ອງມືຈົນກວ່າຊື່ຂອງປຸ່ມຈະປະກົດຂຶ້ນ."

#. fDBG4
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_id3153910\n"
"help.text"
msgid "<emph>Tips</emph> are also displayed for some elements in a document, such as hyperlinks, fields, and index entries."
msgstr "<emph>ເຄັດລັບ</emph> ຍັງຖືກສະແດງສຳລັບບາງອົງປະກອບໃນເອກະສານ ເຊັ່ນ: ໄຮເປີລິງ, ຟິວ (field), ແລະ ລາຍການດັດຊະນີ."

#. uGgBR
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_id992156\n"
"help.text"
msgid "Tips are always enabled."
msgstr "ເຄັດລັບຖືກເປີດໃຊ້ງານຢູ່ສະເໝີ."

#. nnDi2
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"hd_id3147571\n"
"help.text"
msgid "Extended Tips"
msgstr "ເຄັດລັບເພີ່ມເຕີມ"

#. b9NHj
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_id3149346\n"
"help.text"
msgid "<emph>Extended Tips</emph> provide a brief description about buttons and commands. To display an extended tip, press <item type=\"keycode\">Shift+F1</item>, then point to a button or command."
msgstr "<emph>ເຄັດລັບເພີ່ມເຕີມ</emph> ໃຫ້ຄຳອະທິບາຍສັ້ນໆກ່ຽວກັບປຸ່ມ ແລະ ຄຳສັ່ງ. ເພື່ອສະແດງເຄັດລັບເພີ່ມເຕີມ, ໃຫ້ກົດ <item type=\"keycode\">Shift+F1</item>, ແລ້ວຊີ້ໄປທີ່ປຸ່ມ ຫຼື ຄຳສັ່ງ."

#. KZ5SB
#: 00000120.xhp
msgctxt ""
"00000120.xhp\n"
"par_idN10666\n"
"help.text"
msgid "If you always want extended tips instead of tips, enable the extended tips on <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - %PRODUCTNAME - General</emph>."
msgstr "ຫາກທ່ານຕ້ອງການໃຫ້ສະແດງເຄັດລັບເພີ່ມເຕີມແທນເຄັດລັບທຳມະດາສະເໝີ, ໃຫ້ເປີດໃຊ້ເຄັດລັບເພີ່ມເຕີມໄດ້ທີ່ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - %PRODUCTNAME - General</emph>."

#. RXCzT
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"tit\n"
"help.text"
msgid "Index - Keyword Search in the Help"
msgstr "ດັດຊະນີ - ຄົ້ນຫາດ້ວຍຄຳຫຼັກໃນວິທີໃຊ້"

#. uM8Y5
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"bm_id3149428\n"
"help.text"
msgid "<bookmark_value>Index tab in Help</bookmark_value><bookmark_value>Help; keywords</bookmark_value>"
msgstr "<bookmark_value>ແຖບດັດຊະນີໃນວິທີໃຊ້</bookmark_value><bookmark_value>ວິທີໃຊ້; ຄຳຫຼັກ</bookmark_value>"

#. vEi93
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"hd_id3153884\n"
"help.text"
msgid "<variable id=\"00000130\"><link href=\"text/shared/05/00000130.xhp\">Index - Keyword Search in the Help</link></variable>"
msgstr "<variable id=\"00000130\"><link href=\"text/shared/05/00000130.xhp\">ດັດຊະນີ - ຄົ້ນຫາດ້ວຍຄຳຫຼັກໃນວິທີໃຊ້</link></variable>"

#. vmDfR
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3150960\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpindexpage/HelpIndexPage\" visibility=\"hidden\">Double-click an entry or type the word you want to find in the index.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpindexpage/HelpIndexPage\" visibility=\"hidden\">ດັບເບິນຄລິກທີ່ລາຍການ ຫຼື ພິມຄຳສັບທີ່ທ່ານຕ້ອງການຫາໃນດັດຊະນີ.</ahelp>"

#. vCFZF
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3148668\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpindexpage/display\" visibility=\"hidden\">Click to display the selected topic.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpindexpage/display\" visibility=\"hidden\">ຄລິກເພື່ອສະແດງຫົວຂໍ້ທີ່ຖືກເລືອກ.</ahelp>"

#. HPgqx
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3155934\n"
"help.text"
msgid "You can search for a specific topic by typing a word into the <emph>Search term</emph> text box. The window contains an alphabetical list of index terms."
msgstr "ທ່ານສາມາດຄົ້ນຫາຫົວຂໍ້ສະເພາະໄດ້ໂດຍການພິມຄຳສັບລົງໃນຊ່ອງຂໍ້ຄວາມ <emph>ຄຳຄົ້ນຫາ</emph>. ໜ້າຕ່າງຈະສະແດງລາຍການຄຳສັບໃນດັດຊະນີຕາມລຳດັບຕົວອັກສອນ."

#. wXC7X
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3145669\n"
"help.text"
msgid "If the cursor is in the index list when you type the search term, the display will jump directly to the next match. When you type a word in the <emph>Search term</emph> text box, the focus will jump to the best match in the index list."
msgstr "ຫາກເຄີເຊີຢູ່ໃນລາຍການດັດຊະນີໃນຂະນະທີ່ທ່ານພິມຄຳຄົ້ນຫາ, ລະບົບຈະເລື່ອນໄປຫາຄຳທີ່ກົງກັນທັນທີ. ເມື່ອທ່ານພິມຄຳສັບໃນຊ່ອງ <emph>ຄຳຄົ້ນຫາ</emph>, ລະບົບຈະເລື່ອນໄປຫາຄຳທີ່ກົງກັນທີ່ສຸດໃນລາຍການດັດຊະນີ."

#. AFUH2
#: 00000130.xhp
msgctxt ""
"00000130.xhp\n"
"par_id3147653\n"
"help.text"
msgid "The index and full-text searches always apply to the currently selected <item type=\"productname\">%PRODUCTNAME</item> application. Select the appropriate application using the list box on the help viewer's toolbar."
msgstr "ການຄົ້ນຫາຈາກດັດຊະນີ ແລະ ແບບຂໍ້ຄວາມທັງໝົດຈະນຳໃຊ້ກັບແອັບພລິເຄຊັນ <item type=\"productname\">%PRODUCTNAME</item> ທີ່ຖືກເລືອກໄວ້ເທົ່ານັ້ນ. ເລືອກແອັບພລິເຄຊັນທີ່ຕ້ອງການໂດຍໃຊ້ກ່ອງລາຍການເທິງແຖບເຄື່ອງມືຂອງບ່ອນສະແດງວິທີໃຊ້."

#. MsRLT
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"tit\n"
"help.text"
msgid "Find - The Full-Text Search"
msgstr "ຄົ້ນຫາ - ການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດ"

#. vqRPz
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"bm_id3148532\n"
"help.text"
msgid "<bookmark_value>Find tab in Help</bookmark_value><bookmark_value>Help; full-text search</bookmark_value><bookmark_value>full-text search in Help</bookmark_value>"
msgstr "<bookmark_value>ແຖບຄົ້ນຫາໃນວິທີໃຊ້</bookmark_value><bookmark_value>ວິທີໃຊ້; ການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດ</bookmark_value><bookmark_value>ການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດໃນວິທີໃຊ້</bookmark_value>"

#. x3TUv
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"hd_id3148523\n"
"help.text"
msgid "<variable id=\"00000140\"><link href=\"text/shared/05/00000140.xhp\">Find - The Full-Text Search</link></variable>"
msgstr "<variable id=\"00000140\"><link href=\"text/shared/05/00000140.xhp\">ຄົ້ນຫາ - ການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດ</link></variable>"

#. U7EA6
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155599\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/search\" visibility=\"hidden\">Enter the search term here. The search is not case-sensitive.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/search\" visibility=\"hidden\">ປ້ອນຄຳຄົ້ນຫາທີ່ນີ້. ການຄົ້ນຫາບໍ່ແຍກຕົວອັກສອນໃຫຍ່ນ້ອຍ.</ahelp>"

#. ZY75Y
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3153323\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/find\" visibility=\"hidden\">Click to start a full-text search for the term you entered.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/find\" visibility=\"hidden\">ຄລິກເພື່ອເລີ່ມການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດສຳລັບຄຳສັບທີ່ທ່ານປ້ອນ.</ahelp>"

#. BS7dG
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3150499\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/results\" visibility=\"hidden\">Lists the headings of the pages found in your full-text search. To display a page, double-click its entry.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/results\" visibility=\"hidden\">ສະແດງລາຍການຫົວຂໍ້ຂອງໜ້າຕ່າງໆທີ່ພົບຈາກການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດ. ເພື່ອສະແດງໜ້າໃດໜຶ່ງ, ໃຫ້ດັບເບິນຄລິກທີ່ລາຍການນັ້ນ.</ahelp>"

#. eJLq7
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3156027\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/completewords\" visibility=\"hidden\">Specifies whether to carry out an exact search for the word you entered. Incomplete words will not be found.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/completewords\" visibility=\"hidden\">ກຳນົດວ່າຈະຄົ້ນຫາຄຳສັບທີ່ກົງກັນທັງໝົດຕາມທີ່ທ່ານປ້ອນຫຼືບໍ່. ຄຳສັບທີ່ບໍ່ຄົບຖ້ວນຈະບໍ່ຖືກພົບ.</ahelp>"

#. gbq7L
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155552\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/headings\" visibility=\"hidden\">Specifies whether to only search in document headings for the search term.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/headings\" visibility=\"hidden\">ກຳນົດວ່າຈະຄົ້ນຫາຄຳຄົ້ນຫາສະເພາະໃນຫົວຂໍ້ຂອງເອກະສານເທົ່ານັ້ນຫຼືບໍ່.</ahelp>"

#. cAGcs
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155555\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpsearchpage/display\" visibility=\"hidden\">Displays the entry selected in the list.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpsearchpage/display\" visibility=\"hidden\">ສະແດງລາຍການທີ່ຖືກເລືອກໃນລາຍຊື່.</ahelp>"

#. iBiGG
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3152552\n"
"help.text"
msgid "The full text search function in $[officename] Help allows you to find Help documents that contain any combination of search terms. To do this, type one or more words into the <emph>Search term</emph> text field."
msgstr "ຟັງຊັນການຄົ້ນຫາແບບຂໍ້ຄວາມທັງໝົດໃນວິທີໃຊ້ $[officename] ຊ່ວຍໃຫ້ທ່ານຫາເອກະສານວິທີໃຊ້ທີ່ມີຄຳຄົ້ນຫາຕ່າງໆລວມກັນ. ເພື່ອເຮັດສິ່ງນີ້, ໃຫ້ພິມຄຳສັບໜຶ່ງຄຳ ຫຼື ຫຼາຍກວ່ານັ້ນລົງໃນຊ່ອງຂໍ້ຄວາມ <emph>ຄຳຄົ້ນຫາ</emph>."

#. tZvTM
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3153345\n"
"help.text"
msgid "The <emph>Search term</emph> text field stores the words you entered last. To repeat a previous search, click the arrow icon and select the term from the list."
msgstr "ຊ່ອງຂໍ້ຄວາມ <emph>ຄຳຄົ້ນຫາ</emph> ຈະບັນທຶກຄຳສັບທີ່ທ່ານປ້ອນຄັ້ງຫຼ້າສຸດ. ເພື່ອເຮັດການຄົ້ນຫາຄືນໃໝ່, ໃຫ້ຄລິກທີ່ໄອຄອນລູກສອນແລ້ວເລືອກຄຳສັບຈາກລາຍການ."

#. HUQ6C
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3155941\n"
"help.text"
msgid "After the search has been carried out, the document headings of the results appear in a list. Either double-click an entry, or select it and click <emph>Display</emph> to load the corresponding Help document."
msgstr "ຫຼັງຈາກການຄົ້ນຫາສຳເລັດ, ຫົວຂໍ້ເອກະສານຂອງຜົນການຄົ້ນຫາຈະປະກົດຂຶ້ນໃນລາຍການ. ທ່ານສາມາດດັບເບິນຄລິກທີ່ລາຍການ, ຫຼື ເລືອກມັນແລ້ວຄລິກ <emph>ສະແດງ</emph> ເພື່ອໂຫຼດເອກະສານວິທີໃຊ້ທີ່ກ່ຽວຂ້ອງ."

#. YYczi
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3157958\n"
"help.text"
msgid "Use the check box <emph>Find in headings only</emph> to limit the search to document headings."
msgstr "ໃຊ້ຊ່ອງໝາຍ <emph>ຄົ້ນຫາໃນຫົວຂໍ້ເທົ່ານັ້ນ</emph> ເພື່ອຈຳກັດການຄົ້ນຫາໄວ້ສະເພາະຫົວຂໍ້ຂອງເອກະສານ."

#. TWWt7
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3147210\n"
"help.text"
msgid "The <emph>Complete words only</emph> check box allows you to perform an exact search. If this box is marked, incomplete words will not be found. Do not mark this check box if the search term you enter should also be found as part of a longer word."
msgstr "ຊ່ອງໝາຍ <emph>ຄຳສັບທີ່ກົງກັນທັງໝົດເທົ່ານັ້ນ</emph> ຊ່ວຍໃຫ້ທ່ານຄົ້ນຫາແບບກົງຕົວ. ຫາກໝາຍເອົາຊ່ອງນີ້, ຄຳສັບທີ່ບໍ່ຄົບຖ້ວນຈະບໍ່ຖືກພົບ. ຢ່າໝາຍເອົາຊ່ອງນີ້ຫາກທ່ານຕ້ອງການໃຫ້ຄົ້ນຫາຄຳສັບທີ່ເປັນສ່ວນໜຶ່ງຂອງຄຳທີ່ຍາວກວ່າ."

#. bY5wT
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3146798\n"
"help.text"
msgid "You can enter any combination of search terms, separated by spaces. Searching is not case-sensitive."
msgstr "ທ່ານສາມາດປ້ອນຄຳຄົ້ນຫາຫຼາຍຄຳປະສົມກັນໄດ້ໂດຍແຍກດ້ວຍຍະຫວ່າງ. ການຄົ້ນຫາບໍ່ແຍກຕົວອັກສອນໃຫຍ່ນ້ອຍ."

#. AfnGS
#: 00000140.xhp
msgctxt ""
"00000140.xhp\n"
"par_id3149732\n"
"help.text"
msgid "The index and full-text searches always apply to the currently selected %PRODUCTNAME application. Select the appropriate application using the list box on the help viewer's toolbar."
msgstr "ການຄົ້ນຫາຈາກດັດຊະນີ ແລະ ແບບຂໍ້ຄວາມທັງໝົດຈະນຳໃຊ້ກັບແອັບພລິເຄຊັນ %PRODUCTNAME ທີ່ຖືກເລືອກໄວ້ເທົ່ານັ້ນ. ເລືອກແອັບພລິເຄຊັນທີ່ຕ້ອງການໂດຍໃຊ້ກ່ອງລາຍການເທິງແຖບເຄື່ອງມືຂອງບ່ອນສະແດງວິທີໃຊ້."

#. B6BtZ
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"tit\n"
"help.text"
msgid "Managing Bookmarks"
msgstr "ການຈັດການບຸກມາກ"

#. SkFUB
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"bm_id3153244\n"
"help.text"
msgid "<bookmark_value>Help; bookmarks</bookmark_value><bookmark_value>bookmarks; Help</bookmark_value>"
msgstr "<bookmark_value>ວິທີໃຊ້; ບຸກມາກ</bookmark_value><bookmark_value>ບຸກມາກ; ວິທີໃຊ້</bookmark_value>"

#. jcs4K
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"hd_id3154349\n"
"help.text"
msgid "<variable id=\"doc_title\"><link href=\"text/shared/05/00000150.xhp\">Managing Bookmarks</link></variable>"
msgstr "<variable id=\"doc_title\"><link href=\"text/shared/05/00000150.xhp\">ການຈັດການບຸກມາກ</link></variable>"

#. 4k7H2
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3154840\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/bookmarkdialog/BookmarkDialog\" visibility=\"hidden\">Displays the name of the bookmarked page. You can also type a new name for the bookmark.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/bookmarkdialog/BookmarkDialog\" visibility=\"hidden\">ສະແດງຊື່ຂອງໜ້າທີ່ເຮັດບຸກມາກໄວ້. ທ່ານຍັງສາມາດພິມຊື່ໃໝ່ສຳລັບບຸກມາກໄດ້.</ahelp>"

#. DCXuy
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3149140\n"
"help.text"
msgid "<image src=\"sfx2/res/favourite.png\" id=\"img_id3149549\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149549\">Icon</alt></image>"
msgstr "<image src=\"sfx2/res/favourite.png\" id=\"img_id3149549\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149549\">ໄອຄອນ</alt></image>"

#. EKRD3
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145314\n"
"help.text"
msgid "Use the <emph>Add to Bookmarks</emph> icon to set a <link href=\"text/shared/00/00000005.xhp#bookmark\">bookmark</link> for the current page shown in the Help."
msgstr "ໃຊ້ໄອຄອນ <emph>ເພີ່ມເຂົ້າໃນບຸກມາກ</emph> ເພື່ອກຳນົດ <link href=\"text/shared/00/00000005.xhp#bookmark\">ບຸກມາກ</link> ສຳລັບໜ້າວິທີໃຊ້ທີ່ສະແດງຢູ່ໃນປັດຈຸບັນ."

#. UK7NF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3149827\n"
"help.text"
msgid "You can find the bookmarks on the <emph>Bookmarks</emph> tab page."
msgstr "ທ່ານສາມາດຫາບຸກມາກຕ່າງໆໄດ້ໃນແຖບໜ້າ <emph>ບຸກມາກ</emph>."

#. ygCDN
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145345\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpbookmarkpage/HelpBookmarkPage\" visibility=\"visible\">Double-clicking a bookmark or pressing the <emph>Return</emph> key opens the assigned page in Help. A right-click opens the context menu.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpbookmarkpage/HelpBookmarkPage\" visibility=\"visible\">ການດັບເບິນຄລິກທີ່ບຸກມາກ ຫຼື ກົດປຸ່ມ <emph>Return</emph> ຈະເປັນການເປີດໜ້າວິທີໃຊ້ທີ່ກຳນົດໄວ້. ການຄລິກຂວາຈະເປັນການເປີດເມນູຄຳສັ່ງ.</ahelp>"

#. qqCBe
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3166410\n"
"help.text"
msgid "Use the <item type=\"keycode\">Del</item> key to delete a selected bookmark."
msgstr "ໃຊ້ປຸ່ມ <item type=\"keycode\">Del</item> ເພື່ອລຶບບຸກມາກທີ່ເລືອກໄວ້."

#. QFH6i
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3145382\n"
"help.text"
msgid "The following commands are on the context menu of a bookmark:"
msgstr "ຄຳສັ່ງຕໍ່ໄປນີ້ມີຢູ່ໃນເມນູຄລິກຂວາຂອງບຸກມາກ:"

#. ApGPm
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3147573\n"
"help.text"
msgid "<emph>Display</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_OPEN\" visibility=\"visible\">displays the selected help subject</ahelp>."
msgstr "<emph>ສະແດງ</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_OPEN\" visibility=\"visible\">ສະແດງຫົວຂໍ້ວິທີໃຊ້ທີ່ເລືອກ</ahelp>."

#. KhCTF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3150771\n"
"help.text"
msgid "<emph>Rename</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_RENAME\" visibility=\"visible\">opens a dialog for entering another name for the bookmark</ahelp>."
msgstr "<emph>ປ່ຽນຊື່</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_RENAME\" visibility=\"visible\">ເປີດກ່ອງໂຕ້ຕອບເພື່ອປ່ຽນຊື່ບຸກມາກ</ahelp>."

#. DGdEF
#: 00000150.xhp
msgctxt ""
"00000150.xhp\n"
"par_id3153087\n"
"help.text"
msgid "<emph>Delete</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_DELETE\" visibility=\"visible\">deletes the selected bookmark.</ahelp>"
msgstr "<emph>ລຶບ</emph> - <ahelp hid=\"HID_HELP_BOOKMARKS_DELETE\" visibility=\"visible\">ລຶບບຸກມາກທີ່ເລືອກ.</ahelp>"

#. VqaZD
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"tit\n"
"help.text"
msgid "Contents - The Main Help Topics"
msgstr "ເນື້ອໃນ - ຫົວຂໍ້ວິທີໃຊ້ຫຼັກ"

#. y5FLx
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"bm_id3147090\n"
"help.text"
msgid "<bookmark_value>Help; topics</bookmark_value><bookmark_value>tree view of Help</bookmark_value>"
msgstr "<bookmark_value>ວິທີໃຊ້; ຫົວຂໍ້</bookmark_value><bookmark_value>ມຸມມອງແບບຕົ້ນໄມ້ຂອງວິທີໃຊ້</bookmark_value>"

#. u95Wi
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"hd_id3146856\n"
"help.text"
msgid "<variable id=\"doc_title\"><link href=\"text/shared/05/00000160.xhp\">Contents - The Main Help Topics</link></variable>"
msgstr "<variable id=\"doc_title\"><link href=\"text/shared/05/00000160.xhp\">ເນື້ອໃນ - ຫົວຂໍ້ວິທີໃຊ້ຫຼັກ</link></variable>"

#. 82jUN
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3147000\n"
"help.text"
msgid "<ahelp hid=\"sfx/ui/helpcontentpage/HelpContentPage\">Displays the main help themes, arranged in a similar way to folders in a file manager.</ahelp>"
msgstr "<ahelp hid=\"sfx/ui/helpcontentpage/HelpContentPage\">ສະແດງຫົວຂໍ້ວິທີໃຊ້ຫຼັກ ໂດຍຈັດລຽງໃນຮູບແບບທີ່ຄ້າຍຄືກັບໂຟນເດີໃນຕົວຈັດການໄຟລ໌.</ahelp>"

#. MyKSG
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3151315\n"
"help.text"
msgid "<image id=\"img_id3152924\" src=\"formula/res/fapclose.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3152924\">Icon</alt></image>"
msgstr "<image id=\"img_id3152924\" src=\"formula/res/fapclose.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3152924\">ໄອຄອນ</alt></image>"

#. 87kb7
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3150774\n"
"help.text"
msgid "Double-click a closed folder to open it and display the subfolders and Help pages."
msgstr "ດັບເບິນຄລິກທີ່ໂຟນເດີທີ່ປິດຢູ່ເພື່ອເປີດມັນ ແລະ ສະແດງໂຟນເດີຍ່ອຍ ແລະ ໜ້າວິທີໃຊ້."

#. DCbpB
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3150506\n"
"help.text"
msgid "<image id=\"img_id3156426\" src=\"formula/res/fapopen.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3156426\">Icon</alt></image>"
msgstr "<image id=\"img_id3156426\" src=\"formula/res/fapopen.png\" width=\"0.222inch\" height=\"0.222inch\"><alt id=\"alt_id3156426\">ໄອຄອນ</alt></image>"

#. EWXAu
#: 00000160.xhp
msgctxt ""
"00000160.xhp\n"
"par_id3154749\n"
"help.text"
msgid "Double-click an open folder to close it and hide the subfolders and Help pages."
msgstr "ດັບເບິນຄລິກທີ່ໂຟນເດີທີ່ເປີດຢູ່ເພື່ອປິດມັນ ແລະ ເຊື່ອງໂຟນເດີຍ່ອຍ ແລະ ໜ້າວິທີໃຊ້."

