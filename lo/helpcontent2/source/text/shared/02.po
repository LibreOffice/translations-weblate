#. xr7BN
#: 01170102.xhp
msgctxt ""
"01170102.xhp\n"
"par_idN11140\n"
"help.text"
msgid "Edit field of the combo box is cleared."
msgstr "ຟີວແກ້ໄຂຂອງກ່ອງຄອມໂບຖືກລຶບລ້າງ."

#. h8cut
#: 01170102.xhp
msgctxt ""
"01170102.xhp\n"
"par_idN11147\n"
"help.text"
msgid "Change the contents of the list source range:"
msgstr "ປ່ຽນເນື້ອໃນຂອງຊ່ວງແຫຼ່ງຂໍ້ມູນລາຍການ:"

#. LzcsD
#: 01170102.xhp
msgctxt ""
"01170102.xhp\n"
"par_idN1114D\n"
"help.text"
msgid "Drop-down list items are updated according to the change. The edit field of the combo box and the linked cell are not changed."
msgstr "ລາຍການໃນລາຍຊື່ແບບເລື່ອນລົງຈະຖືກອັບເດດຕາມການປ່ຽນແປງ. ຟີວແກ້ໄຂຂອງກ່ອງຄອມໂບ ແລະ ເຊລທີ່ເຊື່ອມຕໍ່ຈະບໍ່ຖືກປ່ຽນແປງ."

#. Co3kz
