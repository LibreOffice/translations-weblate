msgstr "<image id=\"img_id3154285\" src=\"cmd/lc_graphicfiltersmooth.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3154285\">ໄອຄອນເຮັດໃຫ້ກ້ຽງ</alt></image>"

