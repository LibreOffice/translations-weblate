msgctxt ""
"12100100.xhp\n"
"par_id3159233\n"
"help.text"
msgid "<ahelp hid=\".uno:OrderCrit\">Specifies the data field name whose content will determine the sort order.</ahelp>"
msgstr "<ahelp hid=\".uno:OrderCrit\">ລະບຸຊື່ຟິລຂໍ້ມູນ ເຊິ່ງເນື້ອໃນຂອງມັນຈະເປັນຕົວ ກຳນົດລໍາດັບການຮຽງ.</ahelp>"

#. RGQHu
#: 12100100.xhp
msgctxt ""
"12100100.xhp\n"
"hd_id3150774\n"
"help.text"
msgid "Order"
msgstr "ລໍາດັບ"

#. CSsoL
