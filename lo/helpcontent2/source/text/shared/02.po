"par_id3148983\n"
"help.text"
msgid "<ahelp hid=\".uno:StateZoom\">Specifies the current page display zoom factor.</ahelp>"
msgstr "<ahelp hid=\".uno:StateZoom\">ລະບຸອັດຕາການຊູມຂອງການສະແດງຜົນໜ້າປັດຈຸບັນ.</ahelp>"

#. dfT2m
#: 20030000.xhp
msgctxt ""
"20030000.xhp\n"
"par_id3150935\n"
"help.text"
msgid "Click this field to open the <link href=\"text/shared/01/03010000.xhp\"><emph>Zoom</emph></link> dialog, where you can change the current zoom factor."
msgstr "ຄລິກທີ່ຟີວນີ້ເພື່ອເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/03010000.xhp\"><emph>ຊູມ</emph></link>, ເຊິ່ງທ່ານສາມາດປ່ຽນອັດຕາການຊູມປັດຈຸບັນໄດ້."

#. fyWyi
#: 20030000.xhp
msgctxt ""
"20030000.xhp\n"
"par_id3159194\n"
"help.text"
msgid "Right-click to open the context menu on this field to see a selection of available zoom factors."
msgstr "ຄລິກຂວາທີ່ຟີວນີ້ເພື່ອເປີດເມນູ ແລະ ເບິ່ງຕົວເລືອກອັດຕາການຊູມທີ່ມີໃຫ້ໃຊ້."

#. ty7UE
#: 20040000.xhp
msgctxt ""
"20040000.xhp\n"
"tit\n"
"help.text"
msgid "Insert Mode"
msgstr "ໂໝດແຊກ"

#. KVot3
#: 20040000.xhp
msgctxt ""
"20040000.xhp\n"
"hd_id3149748\n"
"help.text"
msgid "<link href=\"text/shared/02/20040000.xhp\">Insert Mode</link>"
msgstr "<link href=\"text/shared/02/20040000.xhp\">ໂໝດແຊກ</link>"

#. EonG9
#: 20040000.xhp
msgctxt ""
"20040000.xhp\n"
"par_id3152363\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertMode\">Displays the current insert mode. You can toggle between <emph>INSRT</emph> = insert and <emph>OVER</emph> = overwrite.</ahelp><switchinline select=\"appl\"><caseinline select=\"CALC\"> This field is only active if the cursor is in the input line of the formula bar or in a cell.</caseinline></switchinline>"
msgstr "<ahelp hid=\".uno:InsertMode\">ສະແດງໂໝດການແຊກປັດຈຸບັນ. ທ່ານສາມາດສະຫຼັບລະຫວ່າງ <emph>INSRT</emph> = ແຊກ ແລະ <emph>OVER</emph> = ຂຽນທັບ.</ahelp><switchinline select=\"appl\"><caseinline select=\"CALC\"> ຟີວນີ້ຈະເຮັດວຽກກໍຕໍ່ເມື່ອເຄີເຊີຢູ່ໃນແຖບປ້ອນຂໍ້ມູນຂອງແຖບສູດ ຫຼື ຢູ່ໃນຫ້ອງຕາຕະລາງ.</caseinline></switchinline>"

#. 5zzkY
#: 20040000.xhp
msgctxt ""
"20040000.xhp\n"
"par_id3154422\n"
"help.text"
msgid "Click in the field to toggle the modes (except in the $[officename] Basic IDE, where only the <emph>Insert</emph> mode is active). If the cursor is positioned in a text document, you may also use the <emph>Insert</emph> key (if available on your keyboard) to toggle the modes."
msgstr "ຄລິກໃນຟີວເພື່ອສະຫຼັບໂໝດ (ຍົກເວັ້ນໃນ $[officename] Basic IDE, ເຊິ່ງມີພຽງໂໝດ <emph>ແຊກ</emph> ເທົ່ານັ້ນທີ່ເຮັດວຽກ). ຖ້າເຄີເຊີຢູ່ໃນເອກະສານຂໍ້ຄວາມ, ທ່ານຍັງສາມາດໃຊ້ປຸ່ມ <emph>Insert</emph> (ຖ້າມີໃນຄີບອດຂອງທ່ານ) ເພື່ອສະຫຼັບໂໝດໄດ້."

