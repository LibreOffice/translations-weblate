msgctxt ""
"01170202.xhp\n"
"hd_id3147559\n"
"help.text"
msgid "Before update"
msgstr "ກ່ອນການອັບເດດ"

#. cnQdn
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3149669\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>Before update</emph> event occurs before the control content changed by the user is written into the data source.</ahelp> The linked macro can, for example, prevent this action by returning <literal>FALSE</literal>."
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ກ່ອນການອັບເດດ</emph> ເກີດຂຶ້ນກ່ອນທີ່ເນື້ອໃນການຄວບຄຸມທີ່ປ່ຽນແປງໂດຍຜູ້ໃຊ້ຈະຖືກຂຽນລົງໃນແຫຼ່ງຂໍ້ມູນ.</ahelp> ມາກໂຄທີ່ເຊື່ອມຕໍ່ສາມາດ, ຕົວຢ່າງ, ປ້ອງກັນການດຳເນີນການນີ້ໄດ້ໂດຍການສົ່ງຄືນຄ່າ <literal>FALSE</literal>."

#. CF9MK
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3153779\n"
"help.text"
msgid "After update"
msgstr "ຫຼັງການອັບເດດ"

#. zqWHW
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3153360\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>After update</emph> event occurs after the control content changed by the user has been written into the data source.</ahelp>"
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ຫຼັງການອັບເດດ</emph> ເກີດຂຶ້ນຫຼັງຈາກທີ່ເນື້ອໃນການຄວບຄຸມທີ່ປ່ຽນແປງໂດຍຜູ້ໃຊ້ໄດ້ຖືກຂຽນລົງໃນແຫຼ່ງຂໍ້ມູນແລ້ວ.</ahelp>"

#. sbEB8
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"bm_id601600955240219\n"
"help.text"
msgid "<bookmark_value>API;XResetListener</bookmark_value>"
msgstr "<bookmark_value>API;XResetListener</bookmark_value>"

#. vXXSb
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3157909\n"
"help.text"
msgid "Prior to reset"
msgstr "ກ່ອນການຕັ້ງຄ່າໃໝ່"

#. 7bVCy
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3155390\n"
"help.text"
msgid "<ahelp hid=\".\">The <emph>Prior to reset</emph> event occurs before a form is reset.</ahelp> Returning <literal>True</literal> approves the reset, returning <literal>False</literal> cancels the operation."
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ກ່ອນການຕັ້ງຄ່າໃໝ່</emph> ຈະເກີດຂຶ້ນກ່ອນທີ່ຟອມຈະຖືກຕັ້ງຄ່າໃໝ່.</ahelp> ການສົ່ງຄ່າ <literal>True</literal> ແມ່ນການອະນຸມັດການຕັ້ງຄ່າໃໝ່, ສ່ວນການສົ່ງຄ່າ <literal>False</literal> ແມ່ນການຍົກເລີກການດຳເນີນການ."

#. 6sgdu
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3149236\n"
"help.text"
msgid "A form is reset if one of the following conditions is met:"
msgstr "ຟອມຈະຖືກຕັ້ງຄ່າໃໝ່ ຖ້າຫາກກົງກັບເງື່ອນໄຂໃດໜຶ່ງດັ່ງຕໍ່ໄປນີ້:"

#. KxG3F
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3149164\n"
"help.text"
msgid "The user presses an (HTML) button that is defined as a reset button."
msgstr "ຜູ້ໃຊ້ກົດປຸ່ມ (HTML) ທີ່ຖືກກຳນົດໃຫ້ເປັນປຸ່ມຕັ້ງຄ່າໃໝ່ (reset)."

#. Jz96B
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3153666\n"
"help.text"
msgid "A new and empty record is created in a form that is linked to a data source. For example, in the last record, the <emph>Next Record</emph> button may be pressed."
msgstr "ບັນທຶກໃໝ່ທີ່ວ່າງເປົ່າຖືກສ້າງຂຶ້ນໃນຟອມທີ່ເຊື່ອມຕໍ່ກັບແຫຼ່ງຂໍ້ມູນ. ຕົວຢ່າງ: ໃນບັນທຶກສຸດທ້າຍ, ປຸ່ມ <emph>ບັນທຶກຖັດໄປ</emph> ອາດຈະຖືກກົດ."

#. zBNM5
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3156119\n"
"help.text"
msgid "After resetting"
msgstr "ຫຼັງຈາກການຕັ້ງຄ່າໃໝ່"

#. bZ5e7
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3148563\n"
"help.text"
msgid "<ahelp hid=\".\">The<emph> After resetting </emph>event occurs after a form has been reset.</ahelp>"
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ຫຼັງຈາກການຕັ້ງຄ່າໃໝ່</emph> ຈະເກີດຂຶ້ນຫຼັງຈາກຟອມໄດ້ຖືກຕັ້ງຄ່າໃໝ່ແລ້ວ.</ahelp>"

#. vDRh6
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"bm_id361600961200031\n"
"help.text"
msgid "<bookmark_value>API;XSubmitListener</bookmark_value>   <bookmark_value>API;XSubmissionVetoListener</bookmark_value>"
msgstr "<bookmark_value>API;XSubmitListener</bookmark_value>   <bookmark_value>API;XSubmissionVetoListener</bookmark_value>"

#. UXPzb
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3150870\n"
"help.text"
msgid "Before submitting"
msgstr "ກ່ອນການສົ່ງຂໍ້ມູນ"

#. qZFdo
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3159152\n"
"help.text"
msgid "<ahelp hid=\".\">The<emph> Before submitting</emph> event occurs before the form data is sent.</ahelp> Returning <literal>True</literal> approves the submission, <literal>False</literal> stops it."
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ກ່ອນການສົ່ງຂໍ້ມູນ</emph> ຈະເກີດຂຶ້ນກ່ອນທີ່ຂໍ້ມູນໃນຟອມຈະຖືກສົ່ງອອກໄປ.</ahelp> ການສົ່ງຄ່າ <literal>True</literal> ແມ່ນການອະນຸມັດການສົ່ງ, ສ່ວນ <literal>False</literal> ແມ່ນການຢຸດການສົ່ງ."

#. uF4JK
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"bm_id472600961200142\n"
"help.text"
msgid "<bookmark_value>API;XLoadListener</bookmark_value>"
msgstr "<bookmark_value>API;XLoadListener</bookmark_value>"

#. jBWf3
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3149167\n"
"help.text"
msgid "When loading"
msgstr "ເມື່ອກຳລັງໂຫຼດ"

#. GDeGJ
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3156423\n"
"help.text"
msgid "<ahelp hid=\".\">The<emph> When loading </emph>event occurs directly after the form has been loaded.</ahelp>"
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ເມື່ອກຳລັງໂຫຼດ</emph> ຈະເກີດຂຶ້ນທັນທີຫຼັງຈາກທີ່ຟອມໄດ້ຖືກໂຫຼດແລ້ວ.</ahelp>"

#. VgSNu
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"hd_id3148451\n"
"help.text"
msgid "Before reloading"
msgstr "ກ່ອນການໂຫຼດໃໝ່"

#. MPwCE
#: 01170202.xhp
msgctxt ""
"01170202.xhp\n"
"par_id3154218\n"
"help.text"
msgid "<ahelp hid=\".\">The<emph> Before reloading </emph>event occurs before the form is reloaded.</ahelp> The data content has not yet been refreshed."
msgstr "<ahelp hid=\".\">ເຫດການ <emph>ກ່ອນການໂຫຼດໃໝ່</emph> ຈະເກີດຂຶ້ນກ່ອນທີ່ຟອມຈະຖືກໂຫຼດໃໝ່.</ahelp> ເຊິ່ງເນື້ອໃນຂໍ້ມູນຍັງບໍ່ທັນໄດ້ຖືກປັບປຸງໃໝ່ (refresh) ເທື່ອ."

