"par_id3154422\n"
"help.text"
msgid "<image src=\"cmd/sc_dbclearquery.svg\" id=\"img_id3149205\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149205\">Clear Query Icon</alt></image>"
msgstr "<image src=\"cmd/sc_dbclearquery.svg\" id=\"img_id3149205\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3149205\">ໄອຄອນລຶບລ້າງການສອບຖາມ</alt></image>"

#. XxG9y
