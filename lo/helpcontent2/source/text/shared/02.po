msgctxt ""
"14020100.xhp\n"
"tit\n"
"help.text"
msgid "Add Tables"
msgstr "ເພີ່ມຕາຕະລາງ"

#. sEm82
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"bm_id3154788\n"
"help.text"
msgid "<bookmark_value>tables in databases; adding to queries</bookmark_value>"
msgstr "<bookmark_value>ຕາຕະລາງໃນຖານຂໍ້ມູນ; ການເພີ່ມໃສ່ການສອບຖາມ</bookmark_value>"

#. LDKvF
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"hd_id3154788\n"
"help.text"
msgid "Add Tables"
msgstr "ເພີ່ມຕາຕະລາງ"

#. MGWBh
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"par_id3152821\n"
"help.text"
msgid "<variable id=\"tabellehinzufuegentext\"><ahelp hid=\".\" visibility=\"hidden\">Specifies the tables to be inserted into the design window.</ahelp> In the <emph>Add Tables</emph> dialog, select the tables you need for your current task.</variable> When creating a query or a new table presentation, select the corresponding table to which the query or table presentation should refer. When working with relational databases, select the tables between which you want to build relationships."
msgstr "<variable id=\"tabellehinzufuegentext\"><ahelp hid=\".\" visibility=\"hidden\">ລະບຸຕາຕະລາງທີ່ຈະແຊກເຂົ້າໃນໜ້າຕ່າງອອກແບບ.</ahelp> ໃນກ່ອງໂຕ້ຕອບ <emph>ເພີ່ມຕາຕະລາງ</emph>, ໃຫ້ເລືອກຕາຕະລາງທີ່ທ່ານຕ້ອງການສຳລັບໜ້າວຽກປັດຈຸບັນ.</variable> ເມື່ອສ້າງການສອບຖາມ ຫຼື ການນຳສະເໜີຕາຕະລາງໃໝ່, ໃຫ້ເລືອກຕາຕະລາງທີ່ກ່ຽວຂ້ອງທີ່ການສອບຖາມ ຫຼື ການນຳສະເໜີຕາຕະລາງນັ້ນຄວນອ້າງອີງເຖິງ. ເມື່ອເຮັດວຽກກັບຖານຂໍ້ມູນທີ່ມີຄວາມສຳພັນ, ໃຫ້ເລືອກຕາຕະລາງທີ່ທ່ານຕ້ອງການສ້າງຄວາມສຳພັນລະຫວ່າງກັນ."

#. wDQ9d
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"par_id3149760\n"
"help.text"
msgid "The inserted tables appear in a separate window in the query design or relational windows, along with a list of the fields contained in the table. You can determine the size and order of this window."
msgstr "ຕາຕະລາງທີ່ແຊກເຂົ້າໄປຈະປາກົດຢູ່ໃນໜ້າຕ່າງແຍກຕ່າງຫາກໃນສ່ວນອອກແບບການສອບຖາມ ຫຼື ໜ້າຕ່າງຄວາມສຳພັນ, ພ້ອມກັບລາຍຊື່ຟີວທີ່ມີຢູ່ໃນຕາຕະລາງນັ້ນ. ທ່ານສາມາດກຳນົດຂະໜາດ ແລະ ລຳດັບຂອງໜ້າຕ່າງນີ້ໄດ້."

#. psYqn
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"hd_id3154927\n"
"help.text"
msgid "Table"
msgstr "ຕາຕະລາງ"

#. dpFw5
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
"par_id030520091208059\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Shows only tables.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສະແດງສະເພາະຕາຕະລາງ.</ahelp>"

#. s4Mka
#: 14020100.xhp
msgctxt ""
"14020100.xhp\n"
