msgid "<image id=\"img_id3156023\" src=\"cmd/lc_graphicfiltersharpen.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3156023\">Icon Sharpen</alt></image>"
msgstr "<image id=\"img_id3156023\" src=\"cmd/lc_graphicfiltersharpen.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3156023\">ໄອຄອນເຮັດໃຫ້ຄົມຊັດ</alt></image>"

#. GnFaF
