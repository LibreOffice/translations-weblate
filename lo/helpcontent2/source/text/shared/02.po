#. sWoXi
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3156414\n"
"help.text"
msgid "<variable id=\"schriftarttext\"><ahelp hid=\".uno:CharFontName\">Allows you to select a font name from the list or enter a font name directly.</ahelp></variable>"
msgstr "<variable id=\"schriftarttext\"><ahelp hid=\".uno:CharFontName\">ຊ່ວຍໃຫ້ທ່ານສາມາດເລືອກຊື່ຟອນຈາກລາຍຊື່ ຫຼື ປ້ອນຊື່ຟອນໂດຍກົງໄດ້.</ahelp></variable>"

#. xkcMZ
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3153750\n"
"help.text"
msgid "You can enter several fonts, separated by semicolons. $[officename] uses each named font in succession if the previous fonts are not available."
msgstr "ທ່ານສາມາດປ້ອນຫຼາຍຟອນໄດ້ໂດຍການຂັ້ນດ້ວຍເຄື່ອງໝາຍຈ້ຳຈຸດ (;). $[officename] ຈະໃຊ້ແຕ່ລະຟອນຕາມລຳດັບ ຫາກຟອນກ່ອນໜ້ານັ້ນບໍ່ມີຢູ່ໃນລະບົບ."

#. BFU8b
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3153394\n"
"help.text"
msgid "Any font changes apply to the selected text or word in which the cursor is positioned. If no text has been selected, the font applies to text typed afterwards."
msgstr "ການປ່ຽນແປງຟອນໃດໆ ຈະມີຜົນກັບຂໍ້ຄວາມທີ່ເລືອກ ຫຼື ຄຳສັບທີ່ເຄີເຊີວາງຢູ່. ຖ້າບໍ່ມີການເລືອກຂໍ້ຄວາມ, ຟອນຈະມີຜົນກັບຂໍ້ຄວາມທີ່ຈະພິມຕໍ່ຈາກນັ້ນ."

#. G5UAa
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3155941\n"
"help.text"
msgid "The last five font names that have been selected are shown in the top part of the combo box."
msgstr "ຊື່ຟອນຫ້າອັນຫຼ້າສຸດທີ່ຖືກເລືອກຈະສະແດງຢູ່ສ່ວນເທິງຂອງກ່ອງຄອມໂບ."

#. CjJcE
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3145315\n"
"help.text"
msgid "<image id=\"img_id3154810\" src=\"media/helpimg/swh00055.png\" width=\"1.25in\" height=\"0.2398in\"><alt id=\"alt_id3154810\">Icon</alt></image>"
msgstr "<image id=\"img_id3154810\" src=\"media/helpimg/swh00055.png\" width=\"1.25in\" height=\"0.2398in\"><alt id=\"alt_id3154810\">ໄອຄອນ</alt></image>"

#. BaFS2
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3150085\n"
"help.text"
msgid "Font Name"
msgstr "ຊື່ຟອນ"

#. P22wr
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3156024\n"
"help.text"
msgid "In $[officename] you see the available fonts only if a printer is installed as the default printer in your system. In order to install a printer as the default printer please refer to your operating system documentation."
msgstr "ໃນ $[officename] ທ່ານຈະເຫັນຟອນທີ່ມີຢູ່ກໍຕໍ່ເມື່ອມີການຕິດຕັ້ງເຄື່ອງພິມເປັນເຄື່ອງພິມມາດຕະຖານໃນລະບົບຂອງທ່ານເທົ່ານັ້ນ. ສຳລັບການຕິດຕັ້ງເຄື່ອງພິມເປັນເຄື່ອງພິມມາດຕະຖານ ກະລຸນາເບິ່ງເອກະສານຄູ່ມືຂອງລະບົບປະຕິບັດການຂອງທ່ານ."

#. AkdrM
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3148550\n"
"help.text"
msgid "<variable id=\"vorschautext\">You can see the name of the fonts formatted in their respective font if you mark the <emph>Show preview of fonts</emph> field in <link href=\"text/shared/optionen/01010800.xhp\"><emph>$[officename] - View</emph></link> in the <emph>Options</emph> dialog box.</variable>"
msgstr "<variable id=\"vorschautext\">ທ່ານສາມາດເຫັນຊື່ຟອນທີ່ຖືກຈັດຮູບແບບຕາມຟອນນັ້ນໆ ໄດ້ ຖ້າທ່ານໝາຍເອົາຟິວ <emph>ສະແດງຕົວຢ່າງຟອນ</emph> ໃນ <link href=\"text/shared/optionen/01010800.xhp\"><emph>$[officename] - ການເບິ່ງ</emph></link> ໃນກ່ອງຂໍ້ຄວາມ <emph>ຕົວເລືອກ</emph>.</variable>"

#. xFsW2
#: 02020000.xhp
msgctxt ""
"02020000.xhp\n"
"par_id3154125\n"
"help.text"
msgid "If you receive an error message that states that certain fonts have not been found, you can install them with <emph>$[officename] Setup</emph> in the <emph>Repair</emph> mode if it is a $[officename] font."
msgstr "ຖ້າທ່ານໄດ້ຮັບຂໍ້ຄວາມຜິດພາດທີ່ລະບຸວ່າບໍ່ພົບຟອນບາງຢ່າງ, ທ່ານສາມາດຕິດຕັ້ງພວກມັນໄດ້ດ້ວຍ <emph>$[officename] Setup</emph> ໃນໂໝດ <emph>ສ້ອມແປງ (Repair)</emph> ຫາກຟອນນັ້ນເປັນຟອນຂອງ $[officename]."

