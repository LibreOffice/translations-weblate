#. 5Q5FH
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3147588\n"
"help.text"
msgid "<variable id=\"suchentext\"><ahelp hid=\".uno:RecSearch\" visibility=\"hidden\">Searches database tables and forms.</ahelp> In forms or database tables, you can search through data fields, list boxes, and check boxes for specific values.</variable>"
msgstr "<variable id=\"suchentext\"><ahelp hid=\".uno:RecSearch\" visibility=\"hidden\">ຄົ້ນຫາໃນຕາຕະລາງ ແລະ ຟອມຖານຂໍ້ມູນ.</ahelp> ໃນຟອມ ຫຼື ຕາຕະລາງຖານຂໍ້ມູນ, ທ່ານສາມາດຄົ້ນຫາຜ່ານຟິລຂໍ້ມູນ, ກ່ອງລາຍຊື່ ແລະ ກ່ອງໝາຍສຳລັບຄ່າສະເພາະໃດໜຶ່ງໄດ້.</variable>"

#. qqmCw
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149355\n"
"help.text"
msgid "When searching a table, the data fields of the current table are searched. When searching in a form, the data fields of the table linked with the form are searched."
msgstr "ເມື່ອຄົ້ນຫາໃນຕາຕະລາງ, ຟິລຂໍ້ມູນຂອງຕາຕະລາງປັດຈຸບັນຈະຖືກຄົ້ນຫາ. ເມື່ອຄົ້ນຫາໃນຟອມ, ຟິລຂໍ້ມູນຂອງຕາຕະລາງທີ່ເຊື່ອມຕໍ່ກັບຟອມຈະຖືກຄົ້ນຫາ."

#. BNa3a
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153394\n"
"help.text"
msgid "The search described here is carried out by <item type=\"productname\">%PRODUCTNAME</item>. If you want to use the SQL server to search in a database, then you should use the <link href=\"text/shared/02/12110000.xhp\"><emph>Form-based Filters</emph></link> icon on the <link href=\"text/shared/main0213.xhp\"><emph>Form</emph> bar</link>."
msgstr "ການຄົ້ນຫາທີ່ອະທິບາຍຢູ່ບ່ອນນີ້ແມ່ນດໍາເນີນການໂດຍ <item type=\"productname\">%PRODUCTNAME</item>. ຫາກທ່ານຕ້ອງການໃຊ້ SQL server ເພື່ອຄົ້ນຫາໃນຖານຂໍ້ມູນ, ທ່ານຄວນໃຊ້ໄອຄອນ <link href=\"text/shared/02/12110000.xhp\"><emph>ຕົວຕອງຕາມຟອມ</emph></link> ໃນ <link href=\"text/shared/main0213.xhp\"><emph>ແຖບຟອມ</emph></link>."

#. eVvxL
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149095\n"
"help.text"
msgid "The search function is also available for table controls. When calling the search function from a table control, you can search each column of the table control corresponding to the database columns of the linked database table."
msgstr "ຟັງຊັນການຄົ້ນຫາຍັງມີໃຫ້ໃຊ້ສຳລັບການຄວບຄຸມຕາຕະລາງ. ເມື່ອເອີ້ນໃຊ້ຟັງຊັນການຄົ້ນຫາຈາກການຄວບຄຸມຕາຕະລາງ, ທ່ານສາມາດຄົ້ນຫາແຕ່ລະຄໍລໍາຂອງການຄວບຄຸມຕາຕະລາງທີ່ກົງກັບຄໍລໍາຖານຂໍ້ມູນຂອງຕາຕະລາງຖານຂໍ້ມູນທີ່ເຊື່ອມຕໍ່ກັນ."

#. stEwd
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3143267\n"
"help.text"
msgid "Search for"
msgstr "ຄົ້ນຫາສຳລັບ"

#. CpHMt
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153527\n"
"help.text"
msgid "Specifies the type of search."
msgstr "ລະບຸປະເພດຂອງການຄົ້ນຫາ."

#. oCXoc
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3153683\n"
"help.text"
msgid "Text:"
msgstr "ຂໍ້ຄວາມ:"

#. CQo4p
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154823\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForText\">Enter the search term in the box or select it from the list.</ahelp> The text under the cursor is already copied into the <emph>Text</emph> combo box. Note that while running a search in a form, tabs and line breaks cannot be processed."
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForText\">ປ້ອນຄຳຄົ້ນຫາໃນກ່ອງ ຫຼື ເລືອກຈາກລາຍຊື່.</ahelp> ຂໍ້ຄວາມທີ່ຢູ່ກ້ອງເຄີເຊີຈະຖືກສຳເນົາລົງໃນກ່ອງຄອມໂບ <emph>ຂໍ້ຄວາມ</emph> ແລ້ວ. ໝາຍເຫດວ່າໃນຂະນະທີ່ກຳລັງຄົ້ນຫາໃນຟອມ, ປຸ່ມແທັບ ແລະ ການຂຶ້ນແຖວໃໝ່ຈະບໍ່ສາມາດປະມວນຜົນໄດ້."

#. 7YYGz
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148539\n"
"help.text"
msgid "Your search terms will be saved as long as the table or the form document is open. If you are running more than one search and you would like to repeat the search term, you can select a previously used search term from the combo box."
msgstr "ຄຳຄົ້ນຫາຂອງທ່ານຈະຖືກບັນທຶກໄວ້ຕາບໃດທີ່ຕາຕະລາງ ຫຼື ເອກະສານຟອມຍັງເປີດຢູ່. ຫາກທ່ານກຳລັງຄົ້ນຫາຫຼາຍກວ່າໜຶ່ງຄັ້ງ ແລະ ຕ້ອງການໃຊ້ຄຳຄົ້ນຫາເດີມຊ້ຳ, ທ່ານສາມາດເລືອກຄຳຄົ້ນຫາທີ່ເຄີຍໃຊ້ກ່ອນໜ້ານີ້ຈາກກ່ອງຄອມໂບໄດ້."

#. GkrL9
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3153662\n"
"help.text"
msgid "Field content is NULL"
msgstr "ເນື້ອໃນຟິລເປັນຄ່າວ່າງ (NULL)"

#. i8Bma
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153543\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForNull\">Specifies that fields will be found that contain no data.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForNull\">ລະບຸວ່າຈະຄົ້ນຫາຟິລທີ່ບໍ່ມີຂໍ້ມູນ.</ahelp>"

#. cfE8f
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3153717\n"
"help.text"
msgid "Field content is not NULL"
msgstr "ເນື້ອໃນຟິລບໍ່ແມ່ນຄ່າວ່າງ (NULL)"

#. fMFeY
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3143270\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForNotNull\">Specifies that fields will be found that contain data.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/rbSearchForNotNull\">ລະບຸວ່າຈະຄົ້ນຫາຟິລທີ່ມີຂໍ້ມູນ.</ahelp>"

#. nAC6W
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3156153\n"
"help.text"
msgid "Where to search"
msgstr "ຄົ້ນຫາຢູ່ໃສ"

#. r6k7f
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149164\n"
"help.text"
msgid "Specifies the fields for the search."
msgstr "ລະບຸຟິລສຳລັບການຄົ້ນຫາ."

#. jyQYd
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3154564\n"
"help.text"
msgid "Form"
msgstr "ຟອມ"

#. QGBpo
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3159176\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/lbForm\">Specifies the logical form in which you want the search to take place.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/lbForm\">ລະບຸຟອມທາງຕັກກະສາດທີ່ທ່ານຕ້ອງການໃຫ້ການຄົ້ນຫາເກີດຂຶ້ນ.</ahelp>"

#. 2ABGD
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155434\n"
"help.text"
msgid "The<emph> Form </emph>combo box is only visible if the current document is a form document with more than one logical form. It does not appear during a search in tables or queries."
msgstr "ກ່ອງຄອມໂບ <emph>ຟອມ</emph> ຈະສະແດງໃຫ້ເຫັນກໍຕໍ່ເມື່ອເອກະສານປັດຈຸບັນເປັນເອກະສານຟອມທີ່ມີຫຼາຍກວ່າໜຶ່ງຟອມທາງຕັກກະສາດເທົ່ານັ້ນ. ມັນຈະບໍ່ສະແດງໃນລະຫວ່າງການຄົ້ນຫາໃນຕາຕະລາງ ຫຼື ຄຳສັ່ງສອບຖາມ."

#. MJEA3
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151384\n"
"help.text"
msgid "Form documents may contain multiple logical forms. These are individual form components, which are each linked to a table."
msgstr "ເອກະສານຟອມອາດປະກອບດ້ວຍຫຼາຍຟອມທາງຕັກກະສາດ. ເຫຼົ່ານີ້ແມ່ນອົງປະກອບຟອມແຕ່ລະອັນ ເຊິ່ງແຕ່ລະອັນເຊື່ອມຕໍ່ກັບຕາຕະລາງໃດໜຶ່ງ."

#. gE9cC
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3145086\n"
"help.text"
msgid "The <emph>Form</emph> combo box contains the names of all logical forms for which controls exist."
msgstr "ກ່ອງຄອມໂບ <emph>ຟອມ</emph> ປະກອບດ້ວຍຊື່ຂອງທຸກຟອມທາງຕັກກະສາດທີ່ມີການຄວບຄຸມຢູ່."

#. LnNgt
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3159414\n"
"help.text"
msgid "All Fields"
msgstr "ທຸກຟິລ"

#. hVeCi
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153896\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/rbAllFields\">Searches through all fields.</ahelp> If you are running a search in a table, all fields in the table will be searched. If you are running a search in a form, all fields of the logical form (entered under <emph>Form</emph>) will be searched. If you are running a search in a table control field, all columns that are linked to a valid database table field will be searched."
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/rbAllFields\">ຄົ້ນຫາຜ່ານທຸກຟິລ.</ahelp> ຫາກທ່ານກຳລັງຄົ້ນຫາໃນຕາຕະລາງ, ທຸກຟິລໃນຕາຕະລາງຈະຖືກຄົ້ນຫາ. ຫາກທ່ານກຳລັງຄົ້ນຫາໃນຟອມ, ທຸກຟິລຂອງຟອມທາງຕັກກະສາດ (ທີ່ປ້ອນໄວ້ພາຍໃຕ້ <emph>ຟອມ</emph>) ຈະຖືກຄົ້ນຫາ. ຫາກທ່ານກຳລັງຄົ້ນຫາໃນຟິລການຄວບຄຸມຕາຕະລາງ, ທຸກຄໍລໍາທີ່ເຊື່ອມຕໍ່ກັບຟິລຕາຕະລາງຖານຂໍ້ມູນທີ່ຖືກຕ້ອງຈະຖືກຄົ້ນຫາ."

#. yBsBb
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151054\n"
"help.text"
msgid "Note that the fields of the current logical form do not have to be identical to the fields of the form document. If the form document contains fields that point to multiple data sources (that is, multiple logical forms), the <emph>All Fields</emph> option will only search for the fields linked to data sources in the form document."
msgstr "ໝາຍເຫດວ່າ ຟິລຂອງຟອມທາງຕັກກະສາດປັດຈຸບັນບໍ່ຈຳເປັນຕ້ອງຄືກັນກັບຟິລຂອງເອກະສານຟອມ. ຫາກເອກະສານຟອມປະກອບດ້ວຍຟິລທີ່ຊີ້ໄປຫາຫຼາຍແຫຼ່ງຂໍ້ມູນ (ໝາຍເຖິງ ຫຼາຍຟອມທາງຕັກກະສາດ), ຕົວເລືອກ <emph>ທຸກຟິລ</emph> ຈະຄົ້ນຫາສະເພາະຟິລທີ່ເຊື່ອມຕໍ່ກັບແຫຼ່ງຂໍ້ມູນໃນເອກະສານຟອມເທົ່ານັ້ນ."

#. gaLbd
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3150865\n"
"help.text"
msgid "Single field"
msgstr "ຟິລດຽວ"

#. 39GDa
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153360\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/rbSingleField\">Searches through a specified data field.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/rbSingleField\">ຄົ້ນຫາຜ່ານຟິລຂໍ້ມູນທີ່ລະບຸ.</ahelp>"

#. fMxcB
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3154365\n"
"help.text"
msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

#. fCma5
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3158408\n"
"help.text"
msgid "Defines settings to control the search."
msgstr "ກຳນົດການຕັ້ງຄ່າເພື່ອຄວບຄຸມການຄົ້ນຫາ."

#. Ew8au
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3149809\n"
"help.text"
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#. jtqWw
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148673\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/lbPosition\">Specifies the relationship of the search term and the field contents.</ahelp> The following options are available:"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/lbPosition\">ລະບຸຄວາມສຳພັນລະຫວ່າງຄຳຄົ້ນຫາ ແລະ ເນື້ອໃນຟິລ.</ahelp> ຕົວເລືອກຕໍ່ໄປນີ້ມີໃຫ້ໃຊ້:"

#. vSHCF
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156280\n"
"help.text"
msgid "anywhere in the field"
msgstr "ບ່ອນໃດກໍໄດ້ໃນຟິລ"

#. BLsFL
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3145744\n"
"help.text"
msgid "Returns all fields containing the search pattern anywhere in the field."
msgstr "ສົ່ງຄືນທຸກຟິລທີ່ມີຮູບແບບການຄົ້ນຫາຢູ່ບ່ອນໃດກໍໄດ້ໃນຟິລ."

#. eyni9
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148451\n"
"help.text"
msgid "beginning of field"
msgstr "ຕອນຕົ້ນຂອງຟິລ"

#. EUGJE
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155429\n"
"help.text"
msgid "Returns all fields containing the search pattern at the beginning of the field."
msgstr "ສົ່ງຄືນທຸກຟິລທີ່ມີຮູບແບບການຄົ້ນຫາຢູ່ຕອນຕົ້ນຂອງຟິລ."

#. WSBeU
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155131\n"
"help.text"
msgid "end of field"
msgstr "ຕອນທ້າຍຂອງຟິລ"

#. xTte4
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153726\n"
"help.text"
msgid "Returns all fields containing the search pattern at the end of the field."
msgstr "ສົ່ງຄືນທຸກຟິລທີ່ມີຮູບແບບການຄົ້ນຫາຢູ່ຕອນທ້າຍຂອງຟິລ."

#. yGVFU
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3147317\n"
"help.text"
msgid "entire field"
msgstr "ທັງໝົດຟິລ"

#. aQDGK
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154127\n"
"help.text"
msgid "Returns all fields containing the search pattern as an exact match to the contents of the field."
msgstr "ສົ່ງຄືນທຸກຟິລທີ່ມີຮູບແບບການຄົ້ນຫາທີ່ກົງກັບເນື້ອໃນຂອງຟິລທັງໝົດຢ່າງແນ່ນອນ."

#. xCE4q
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3152886\n"
"help.text"
msgid "If the <emph>Wildcard expression</emph> check box is marked, this function is not available."
msgstr "ຫາກກ່ອງໝາຍ <emph>ນິພົດຕົວແທນ (Wildcard)</emph> ຖືກໝາຍໄວ້, ຟັງຊັນນີ້ຈະບໍ່ສາມາດໃຊ້ໄດ້."

#. EtJc4
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3149664\n"
"help.text"
msgid "Apply field format"
msgstr "ນຳໃຊ້ຮູບແບບຟິລ"

#. Z4wux
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3146975\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbUseFormat\">Specifies that all field formats are considered when searching in the current document.</ahelp> Field formats are all visible formats that are created using the following possibilities:"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbUseFormat\">ລະບຸໃຫ້ພິຈາລະນາທຸກຮູບແບບຟິລເມື່ອຄົ້ນຫາໃນເອກະສານປັດຈຸບັນ.</ahelp> ຮູບແບບຟິລແມ່ນຮູບແບບທັງໝົດທີ່ເບິ່ງເຫັນໄດ້ ເຊິ່ງຖືກສ້າງຂຶ້ນໂດຍໃຊ້ຄວາມເປັນໄປໄດ້ດັ່ງຕໍ່ໄປນີ້:"

#. SAzFG
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150103\n"
"help.text"
msgid "in table design mode for field properties,"
msgstr "ໃນໂໝດການອອກແບບຕາຕະລາງສຳລັບຄຸນສົມບັດຟິລ,"

#. vks35
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150488\n"
"help.text"
msgid "in data source view on column formatting,"
msgstr "ໃນມຸມມອງແຫຼ່ງຂໍ້ມູນກ່ຽວກັບການຈັດຮູບແບບຄໍລໍາ,"

#. QHr8t
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3152941\n"
"help.text"
msgid "in forms on control properties."
msgstr "ໃນຟອມກ່ຽວກັບຄຸນສົມບັດການຄວບຄຸມ."

#. nrANt
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156736\n"
"help.text"
msgid "If the <emph>Apply field format</emph> box is marked, the data source view of the table or form is searched using the formatting set there. If the box is not marked, the database is searched using the formatting saved in the database."
msgstr "ຫາກກ່ອງ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ຖືກໝາຍໄວ້, ມຸມມອງແຫຼ່ງຂໍ້ມູນຂອງຕາຕະລາງ ຫຼື ຟອມຈະຖືກຄົ້ນຫາໂດຍໃຊ້ການຈັດຮູບແບບທີ່ຕັ້ງໄວ້ຢູ່ບ່ອນນັ້ນ. ຫາກກ່ອງບໍ່ຖືກໝາຍໄວ້, ຖານຂໍ້ມູນຈະຖືກຄົ້ນຫາໂດຍໃຊ້ການຈັດຮູບແບບທີ່ບັນທຶກໄວ້ໃນຖານຂໍ້ມູນ."

#. XH8Ev
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151280\n"
"help.text"
msgid "Example:"
msgstr "ຕົວຢ່າງ:"

#. yAVFA
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149959\n"
"help.text"
msgid "You have a date field, which is saved in \"<emph>DD.MM.YY</emph>\" format in the database (for example, <emph>17.02.65</emph>). The format of the entry is changed in the data source view to \"<emph>DD MMM YYYY</emph>\" (<emph>17 Feb 1965</emph>). Following this example, a record containing February 17 is only found when the <emph>Apply field format</emph> option is on:"
msgstr "ທ່ານມີຟິລວັນທີ ເຊິ່ງຖືກບັນທຶກໃນຮູບແບບ \"<emph>DD.MM.YY</emph>\" ໃນຖານຂໍ້ມູນ (ຕົວຢ່າງ, <emph>17.02.65</emph>). ຮູບແບບຂອງລາຍການຖືກປ່ຽນໃນມຸມມອງແຫຼ່ງຂໍ້ມູນເປັນ \"<emph>DD MMM YYYY</emph>\" (<emph>17 Feb 1965</emph>). ຕາມຕົວຢ່າງນີ້, ລະບຽນທີ່ມີວັນທີ 17 ກຸມພາ ຈະຖືກຄົ້ນພົບກໍຕໍ່ເມື່ອຕົວເລືອກ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ເປີດຢູ່ເທົ່ານັ້ນ:"

#. X7YDi
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150593\n"
"help.text"
msgid "Apply field format"
msgstr "ນຳໃຊ້ຮູບແບບຟິລ"

#. CDRww
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3145253\n"
"help.text"
msgid "Search pattern"
msgstr "ຮູບແບບການຄົ້ນຫາ"

#. obYnE
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3083279\n"
"help.text"
msgid "on"
msgstr "ເປີດ"

#. CJxhT
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155850\n"
"help.text"
msgid "\"Feb\" is returned, but not \"2\"."
msgstr "ສົ່ງຄືນ \"Feb\", ແຕ່ບໍ່ສົ່ງຄືນ \"2\"."

#. b8pQP
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148590\n"
"help.text"
msgid "off"
msgstr "ປິດ"

#. QA8Bb
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153418\n"
"help.text"
msgid "\"2\" is returned, but not \"Feb\"."
msgstr "ສົ່ງຄືນ \"2\", ແຕ່ບໍ່ສົ່ງຄືນ \"Feb\"."

#. KBaKt
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151321\n"
"help.text"
msgid "It is recommended that you always search using field formatting."
msgstr "ຂໍແນະນຳໃຫ້ທ່ານຄົ້ນຫາໂດຍໃຊ້ການຈັດຮູບແບບຟິລສະເໝີ."

#. paPGm
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149401\n"
"help.text"
msgid "The following examples show possible issues when searching without field formatting. These issues depend on the database used and only occur for certain internal default formatting:"
msgstr "ຕົວຢ່າງຕໍ່ໄປນີ້ສະແດງໃຫ້ເຫັນບັນຫາທີ່ອາດເກີດຂຶ້ນເມື່ອຄົ້ນຫາໂດຍບໍ່ໃຊ້ການຈັດຮູບແບບຟິລ. ບັນຫາເຫຼົ່ານີ້ຂຶ້ນຢູ່ກັບຖານຂໍ້ມູນທີ່ໃຊ້ ແລະ ຈະເກີດຂຶ້ນກັບບາງການຈັດຮູບແບບເລີ່ມຕົ້ນພາຍໃນເທົ່ານັ້ນ:"

#. fmDoR
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3152971\n"
"help.text"
msgid "Search results"
msgstr "ຜົນການຄົ້ນຫາ"

#. GWEAY
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154273\n"
"help.text"
msgid "Cause"
msgstr "ສາເຫດ"

#. uLBeN
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153836\n"
"help.text"
msgid "\"5\" returns \"14:00:00\" as a time."
msgstr "\"5\" ສົ່ງຄືນ \"14:00:00\" ເປັນເວລາ."

#. KvZLA
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156332\n"
"help.text"
msgid "Time fields are not defined for <emph>dBASE</emph> databases and must be simulated. To internally display the time \"<emph>14:00:00</emph>\", a \"<emph>5</emph>\" is necessary."
msgstr "ຟິລເວລາບໍ່ໄດ້ຖືກກຳນົດໄວ້ສຳລັບຖານຂໍ້ມູນ <emph>dBASE</emph> ແລະ ຕ້ອງມີການຈຳລອງຂຶ້ນມາ. ເພື່ອສະແດງເວລາ \"<emph>14:00:00</emph>\" ພາຍໃນ, ຈຳເປັນຕ້ອງໃຊ້ \"<emph>5</emph>\"."

#. jBt2e
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3157965\n"
"help.text"
msgid "\"00:00:00\" returns all records of a standard date field."
msgstr "\"00:00:00\" ສົ່ງຄືນທຸກລະບຽນຂອງຟິລວັນທີມາດຕະຖານ."

#. DSKDA
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3146081\n"
"help.text"
msgid "The database stores a date value internally using a combined date/time field."
msgstr "ຖານຂໍ້ມູນເກັບຄ່າວັນທີພາຍໃນໂດຍໃຊ້ຟິລ ວັນທີ/ເວລາ ຮວມກັນ."

#. VFPQS
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155764\n"
"help.text"
msgid "\"45.79\" does not return \"45.79\" although the <emph>entire field</emph> option is selected under <emph>Position</emph>."
msgstr "\"45.79\" ບໍ່ສົ່ງຄືນ \"45.79\" ເຖິງແມ່ນວ່າຈະເລືອກຕົວເລືອກ <emph>ທັງໝົດຟິລ</emph> ພາຍໃຕ້ <emph>ຕຳແໜ່ງ</emph> ກໍຕາມ."

#. 837PF
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155518\n"
"help.text"
msgid "The view shown does not match what is stored internally. For example, if value \"<emph>45.789</emph>\" is stored in the database as a field of type \"<emph>Number/Double</emph>\" and the shown formatting is set to display only two decimals, \"<emph>45.79</emph>\" is only returned in searches with field formatting."
msgstr "ມຸມມອງທີ່ສະແດງບໍ່ກົງກັບສິ່ງທີ່ເກັບໄວ້ພາຍໃນ. ຕົວຢ່າງ, ຫາກຄ່າ \"<emph>45.789</emph>\" ຖືກເກັບໄວ້ໃນຖານຂໍ້ມູນເປັນຟິລປະເພດ \"<emph>Number/Double</emph>\" ແລະ ການຈັດຮູບແບບທີ່ສະແດງຖືກຕັ້ງໃຫ້ສະແດງທົດສະນິຍົມພຽງສອງຕຳແໜ່ງ, \"<emph>45.79</emph>\" ຈະຖືກສົ່ງຄືນສະເພາະໃນການຄົ້ນຫາດ້ວຍການຈັດຮູບແບບຟິລເທົ່ານັ້ນ."

#. TGqWh
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148481\n"
"help.text"
msgid "In this case, standard formatting is formatting that refers to the internally stored data. It is not always visible to the user, especially if it is used for simulating data types (for example, time fields in dBASE databases). This depends on the database used and the individual data type. Searching with field formatting is appropriate if you only want to find what is actually shown. This includes fields of type Date, Time, Date/Time and Number/Double."
msgstr "ໃນກໍລະນີນີ, ການຈັດຮູບແບບມາດຕະຖານແມ່ນການຈັດຮູບແບບທີ່ອ້າງອີງເຖິງຂໍ້ມູນທີ່ເກັບໄວ້ພາຍໃນ. ມັນບໍ່ໄດ້ເບິ່ງເຫັນໄດ້ໂດຍຜູ້ໃຊ້ສະເໝີໄປ, ໂດຍສະເພາະຫາກມັນຖືກໃຊ້ເພື່ອຈຳລອງປະເພດຂໍ້ມູນ (ຕົວຢ່າງ, ຟິລເວລາໃນຖານຂໍ້ມູນ dBASE). ສິ່ງນີ້ຂຶ້ນຢູ່ກັບຖານຂໍ້ມູນທີ່ໃຊ້ ແລະ ປະເພດຂໍ້ມູນແຕ່ລະອັນ. ການຄົ້ນຫາດ້ວຍການຈັດຮູບແບບຟິລແມ່ນເໝາະສົມຫາກທ່ານຕ້ອງການຄົ້ນຫາສະເພາະສິ່ງທີ່ສະແດງໃຫ້ເຫັນແທ້ໆເທົ່ານັ້ນ. ເຊິ່ງລວມເຖິງຟິລປະເພດ ວັນທີ, ເວລາ, ວັນທີ/ເວລາ ແລະ Number/Double."

#. Fm7KT
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154507\n"
"help.text"
msgid "However, searching without <emph>Apply field format</emph> is appropriate for larger databases with no formatting issues, because it is faster."
msgstr "ຢ່າງໃດກໍຕາມ, ການຄົ້ນຫາໂດຍບໍ່ໃຊ້ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ແມ່ນເໝາະສົມສຳລັບຖານຂໍ້ມູນຂະໜາດໃຫຍ່ທີ່ບໍ່ມີບັນຫາເລື່ອງການຈັດຮູບແບບ, ເພາະວ່າມັນເຮັດວຽກໄດ້ໄວກວ່າ."

#. H6aQK
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153355\n"
"help.text"
msgid "If you are searching the values of check boxes, and <emph>Apply field format</emph> is on, then you will receive a \"1\" for marked check boxes, a \"0\" for unmarked check boxes, and an empty string for undefined (tristate) check boxes. If the search has been carried out with <emph>Apply field format</emph> set to off, you will see the language-dependent default values \"TRUE\" or \"FALSE\"."
msgstr "ຫາກທ່ານກຳລັງຄົ້ນຫາຄ່າຂອງກ່ອງໝາຍ, ແລະ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ເປີດຢູ່, ທ່ານຈະໄດ້ຮັບຄ່າ \"1\" ສຳລັບກ່ອງໝາຍທີ່ໝາຍໄວ້, \"0\" ສຳລັບກ່ອງໝາຍທີ່ບໍ່ໄດ້ໝາຍໄວ້, ແລະ ຂໍ້ຄວາມວ່າງສຳລັບກ່ອງໝາຍທີ່ບໍ່ໄດ້ກຳນົດຄ່າ (tristate). ຫາກການຄົ້ນຫາດໍາເນີນການໂດຍປິດ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ໄວ້, ທ່ານຈະເຫັນຄ່າເລີ່ມຕົ້ນ \"TRUE\" ຫຼື \"FALSE\" ຕາມພາສາທີ່ໃຊ້."

#. AnMv4
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150995\n"
"help.text"
msgid "If you use <emph>Apply field format</emph> when searching in list boxes, you find the text displayed in list boxes. If you do not use <emph>Apply field format,</emph> you will find the contents corresponding to the standard field format."
msgstr "ຫາກທ່ານໃຊ້ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph> ເມື່ອຄົ້ນຫາໃນກ່ອງລາຍຊື່, ທ່ານຈະພົບຂໍ້ຄວາມທີ່ສະແດງໃນກ່ອງລາຍຊື່. ຫາກທ່ານບໍ່ໃຊ້ <emph>ນຳໃຊ້ຮູບແບບຟິລ</emph>, ທ່ານຈະພົບເນື້ອໃນທີ່ກົງກັບຮູບແບບຟິລມາດຕະຖານ."

#. gkCiC
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3150387\n"
"help.text"
msgid "Match case"
msgstr "ກົງກັບຕົວພິມໃຫຍ່/ນ້ອຍ"

#. NpFFF
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3159267\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbCase\">Specifies that upper and lower case are taken into consideration during the search.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbCase\">ລະບຸໃຫ້ພິຈາລະນາຕົວພິມໃຫຍ່ ແລະ ຕົວພິມນ້ອຍໃນລະຫວ່າງການຄົ້ນຫາ.</ahelp>"

#. iQWpN
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3145297\n"
"help.text"
msgid "Search backwards"
msgstr "ຄົ້ນຫາຖອຍຫຼັງ"

#. p3wEU
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151249\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbBackwards\">Specifies that the search process will run in reverse direction, from the last to the first record.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbBackwards\">ລະບຸໃຫ້ຂະບວນການຄົ້ນຫາດໍາເນີນການໃນທິດທາງຢ້ອນກັບ, ຈາກລະບຽນສຸດທ້າຍຫາລະບຽນທຳອິດ.</ahelp>"

#. rYdZG
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3152484\n"
"help.text"
msgid "From top / From bottom"
msgstr "ຈາກເທິງສຸດ / ຈາກລຸ່ມສຸດ"

#. dfzuz
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156316\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbStartOver\">Restarts the search. A forward search restarts with the first record. A backwards search restarts with the last record.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbStartOver\">ເລີ່ມການຄົ້ນຫາໃໝ່. ການຄົ້ນຫາໄປທາງໜ້າຈະເລີ່ມໃໝ່ຈາກລະບຽນທຳອິດ. ການຄົ້ນຫາຖອຍຫຼັງຈະເລີ່ມໃໝ່ຈາກລະບຽນສຸດທ້າຍ.</ahelp>"

#. FYS2w
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3163724\n"
"help.text"
msgid "Wildcard expression"
msgstr "ນິພົດຕົວແທນ (Wildcard)"

#. NELQ5
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149255\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbWildCard\" visibility=\"hidden\">Allows a search with a <emph>*</emph> or <emph>?</emph> wildcard.</ahelp> You can use the following wildcards:"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbWildCard\" visibility=\"hidden\">ອະນຸຍາດໃຫ້ຄົ້ນຫາດ້ວຍຕົວແທນ <emph>*</emph> ຫຼື <emph>?</emph>.</ahelp> ທ່ານສາມາດໃຊ້ຕົວແທນດັ່ງຕໍ່ໄປນີ້:"

#. hPGUD
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3146317\n"
"help.text"
msgid "Wildcards"
msgstr "ຕົວແທນ (Wildcards)"

#. GfoNP
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150298\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. PKRDD
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153919\n"
"help.text"
msgid "Example"
msgstr "ຕົວຢ່າງ"

#. HXCkT
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3158411\n"
"help.text"
msgid "?"
msgstr "?"

#. LCXfC
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148874\n"
"help.text"
msgid "for exactly one arbitrary character"
msgstr "ແທນໜຶ່ງຕົວອັກສອນໃດໆຢ່າງແນ່ນອນ"

#. bVYVp
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150365\n"
"help.text"
msgid "\"?loppy\" returns \"Floppy\""
msgstr "\"?loppy\" ສົ່ງຄືນ \"Floppy\""

#. ANadS
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3166426\n"
"help.text"
msgid "\"M?ller\" returns, for example, Miller and Moller"
msgstr "\"M?ller\" ສົ່ງຄືນ, ຕົວຢ່າງ, Miller ແລະ Moller"

#. kX2jy
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3148803\n"
"help.text"
msgid "*"
msgstr "*"

#. DWWyY
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156138\n"
"help.text"
msgid "for 0 or more arbitrary characters"
msgstr "ແທນ 0 ຫຼື ຫຼາຍຕົວອັກສອນໃດໆ"

#. ngn3S
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3146135\n"
"help.text"
msgid "\"*-*\" returns \"ZIP-Drive\" and \"CD-ROM\""
msgstr "\"*-*\" ສົ່ງຄືນ \"ZIP-Drive\" ແລະ \"CD-ROM\""

#. JZMCA
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3155582\n"
"help.text"
msgid "\"M*er\" returns all entries starting with an \"M\" and ending in \"er\" (for example, Miller, Moller, Mather)"
msgstr "\"M*er\" ສົ່ງຄືນທຸກລາຍການທີ່ເລີ່ມຕົ້ນດ້ວຍ \"M\" ແລະ ລົງທ້າຍດ້ວຍ \"er\" (ຕົວຢ່າງ, Miller, Moller, Mather)"

#. YGsJW
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3145762\n"
"help.text"
msgid "If you want to search for the actual characters <emph>?</emph> or <emph>*</emph>, precede them with a backslash: \"<emph>\\?</emph>\" or \"<emph>\\*</emph>\". However, this is only necessary when <emph>Wildcard expression</emph> is enabled. When the option is not enabled, the wildcard characters are processed like normal characters."
msgstr "ຫາກທ່ານຕ້ອງການຄົ້ນຫາຕົວອັກສອນ <emph>?</emph> ຫຼື <emph>*</emph> ແທ້ໆ, ໃຫ້ວາງ backslash ໄວ້ຂ້າງໜ້າ: \"<emph>\\?</emph>\" ຫຼື \"<emph>\\*</emph>\". ຢ່າງໃດກໍຕາມ, ສິ່ງນີ້ຈຳເປັນກໍຕໍ່ເມື່ອເປີດໃຊ້ງານ <emph>ນິພົດຕົວແທນ (Wildcard)</emph> ເທົ່ານັ້ນ. ເມື່ອຕົວເລືອກບໍ່ໄດ້ເປີດໃຊ້ງານ, ຕົວອັກສອນຕົວແທນຈະຖືກປະມວນຜົນຄືກັບຕົວອັກສອນທຳມະດາ."

#. qrnDV
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3147130\n"
"help.text"
msgid "Regular expression"
msgstr "ນິພົດປົກກະຕິ (Regular expression)"

#. kuF6v
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150982\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/cbRegular\">Searches with regular expressions.</ahelp> The same regular expressions that are supported here are also supported in the <item type=\"productname\">%PRODUCTNAME</item> <link href=\"text/shared/01/02100000.xhp\"><emph>Find & Replace</emph> dialog</link>."
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/cbRegular\">ຄົ້ນຫາດ້ວຍນິພົດປົກກະຕິ (Regular expressions).</ahelp> ນິພົດປົກກະຕິດຽວກັນກັບທີ່ຮອງຮັບຢູ່ນີ້ ກໍໄດ້ຮັບການຮອງຮັບໃນກ່ອງໂຕ້ຕອບ <link href=\"text/shared/01/02100000.xhp\"><emph>ຄົ້ນຫາ ແລະ ແທນທີ່</emph></link> ຂອງ <item type=\"productname\">%PRODUCTNAME</item> ຄືກັນ."

#. NYmii
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154718\n"
"help.text"
msgid "Searching with regular expressions offers more options than searching with wildcard expressions. If you search with regular expressions, the following characters correspond to those used in searches with wildcards:"
msgstr "ການຄົ້ນຫາດ້ວຍນິພົດປົກກະຕິຈະໃຫ້ຕົວເລືອກຫຼາຍກວ່າການຄົ້ນຫາດ້ວຍນິພົດຕົວແທນ. ຫາກທ່ານຄົ້ນຫາດ້ວຍນິພົດປົກກະຕິ, ຕົວອັກສອນຕໍ່ໄປນີ້ຈະກົງກັບຕົວທີ່ໃຊ້ໃນການຄົ້ນຫາດ້ວຍຕົວແທນ:"

#. f2oJT
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153705\n"
"help.text"
msgid "Search with wildcard expression"
msgstr "ຄົ້ນຫາດ້ວຍນິພົດຕົວແທນ"

#. mmLVp
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3149209\n"
"help.text"
msgid "Search with regular expressions"
msgstr "ຄົ້ນຫາດ້ວຍນິພົດປົກກະຕິ"

#. ZBR3z
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151045\n"
"help.text"
msgid "?"
msgstr "?"

#. WuHeR
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150384\n"
"help.text"
msgid "."
msgstr "."

#. FhMtQ
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3153793\n"
"help.text"
msgid "*"
msgstr "*"

#. bxX3B
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3150428\n"
"help.text"
msgid ".*"
msgstr ".*"

#. Fz3Ut
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3150861\n"
"help.text"
msgid "State"
msgstr "ສະຖານະ"

#. EYhyZ
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154477\n"
"help.text"
msgid "The <emph>State</emph> line shows the records returned by the search. If the search reaches the end (or the beginning) of a table, the search is automatically continued at the other end."
msgstr "ແຖວ <emph>ສະຖານະ</emph> ຈະສະແດງລະບຽນທີ່ຖືກສົ່ງຄືນມາຈາກການຄົ້ນຫາ. ຫາກການຄົ້ນຫາໄປຮອດຕອນທ້າຍ (ຫຼື ຕອນຕົ້ນ) ຂອງຕາຕະລາງ, ການຄົ້ນຫາຈະດໍາເນີນການຕໍ່ຈາກອີກສົ້ນໜຶ່ງໂດຍອັດຕະໂນມັດ."

#. PFAAh
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3163720\n"
"help.text"
msgid "In very large databases, finding the record in reverse search order can take some time. In this case, the <emph>status bar</emph> informs you that the records are still being counted."
msgstr "ໃນຖານຂໍ້ມູນທີ່ມີຂະໜາດໃຫຍ່ຫຼາຍ, ການຄົ້ນຫາລະບຽນໃນລໍາດັບຢ້ອນກັບອາດໃຊ້ເວລາບຶດໜຶ່ງ. ໃນກໍລະນີນີ, <emph>ແຖບສະຖານະ</emph> ຈະແຈ້ງໃຫ້ທ່ານຮູ້ວ່າລະບຽນຍັງກຳລັງຖືກນັບຢູ່."

#. DshRy
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3147389\n"
"help.text"
msgid "Search/Cancel"
msgstr "ຄົ້ນຫາ/ຍົກເລີກ"

#. duEJs
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3154368\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/pbSearchAgain\" visibility=\"hidden\">Starts or cancels the search.</ahelp> If the search is successfully completed, the corresponding field in the table is highlighted. You can continue the search by clicking the <emph>Search</emph> button again. You can cancel a search process by clicking the <emph>Cancel</emph> button."
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/pbSearchAgain\" visibility=\"hidden\">ເລີ່ມຕົ້ນ ຫຼື ຍົກເລີກການຄົ້ນຫາ.</ahelp> ຫາກການຄົ້ນຫາສຳເລັດສົມບູນ, ຟິລທີ່ກ່ຽວຂ້ອງໃນຕາຕະລາງຈະຖືກເນັ້ນໃຫ້ເຫັນ. ທ່ານສາມາດຄົ້ນຫາຕໍ່ໄດ້ໂດຍການຄລິກປຸ່ມ <emph>ຄົ້ນຫາ</emph> ອີກຄັ້ງ. ທ່ານສາມາດຍົກເລີກຂະບວນການຄົ້ນຫາໄດ້ໂດຍການຄລິກປຸ່ມ <emph>ຍົກເລີກ</emph>."

#. kxTSj
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"hd_id3145080\n"
"help.text"
msgid "Close"
msgstr "ປິດ"

#. LX6Mt
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3156166\n"
"help.text"
msgid "<ahelp hid=\"cui/ui/fmsearchdialog/close\">Closes the dialog. The settings of the last search will be saved until you quit <item type=\"productname\">%PRODUCTNAME</item>.</ahelp>"
msgstr "<ahelp hid=\"cui/ui/fmsearchdialog/close\">ປິດກ່ອງໂຕ້ຕອບ. ການຕັ້ງຄ່າຂອງການຄົ້ນຫາຫຼ້າສຸດຈະຖືກບັນທຶກໄວ້ຈົນກວ່າທ່ານຈະອອກຈາກ <item type=\"productname\">%PRODUCTNAME</item>.</ahelp>"

#. LRna9
#: 12100200.xhp
msgctxt ""
"12100200.xhp\n"
"par_id3151183\n"
"help.text"
msgid "If several tables or forms are open, you can set different search options for each document. When you close the documents only the search options of the document last closed are saved."
msgstr "ຫາກມີຫຼາຍຕາຕະລາງ ຫຼື ຟອມເປີດຢູ່, ທ່ານສາມາດຕັ້ງຄ່າຕົວເລືອກການຄົ້ນຫາທີ່ແຕກຕ່າງກັນສຳລັບແຕ່ລະເອກະສານໄດ້. ເມື່ອທ່ານປິດເອກະສານ, ຈະມີພຽງແຕ່ຕົວເລືອກການຄົ້ນຫາຂອງເອກະສານທີ່ປິດຫຼ້າສຸດເທົ່ານັ້ນທີ່ຈະຖືກບັນທຶກໄວ້."

#. NB8dh
#: 12110000.xhp
msgctxt ""
"12110000.xhp\n"
"tit\n"
"help.text"
msgid "Form-based Filters"
msgstr "ຕົວຕອງຕາມຟອມ"

#. aCCm7
#: 12110000.xhp
msgctxt ""
"12110000.xhp\n"
"hd_id3147000\n"
"help.text"
msgid "<variable id=\"formfilter\"><link href=\"text/shared/02/12110000.xhp\">Form-based Filters</link></variable>"
msgstr "<variable id=\"formfilter\"><link href=\"text/shared/02/12110000.xhp\">ຕົວຕອງຕາມຟອມ</link></variable>"

#. nJ3CC
#: 12110000.xhp
msgctxt ""
"12110000.xhp\n"
"par_id3154230\n"
"help.text"
msgid "<variable id=\"formfiltertext\"><ahelp hid=\".uno:FormFilter\">Prompts the database server to filter the visible data by specified criteria.</ahelp></variable>"
msgstr "<variable id=\"formfiltertext\"><ahelp hid=\".uno:FormFilter\">ຮ້ອງຂໍໃຫ້ເຊີບເວີຖານຂໍ້ມູນຕອງຂໍ້ມູນທີ່ເບິ່ງເຫັນໄດ້ຕາມເກນທີ່ລະບຸ.</ahelp></variable>"

#. S5YQQ
#: 12110000.xhp
msgctxt ""
"12110000.xhp\n"
"par_id3152918\n"
"help.text"
msgid "Unlike the normal search, which is activated by the <link href=\"text/shared/02/12100200.xhp\"><emph>Find Record</emph></link> icon on the <emph>Form</emph> bar, you can search more quickly by using the form-based filter. Usually a quick database server is charged with the search. Also, you can enter more complex search conditions."
msgstr "ຕ່າງຈາກການຄົ້ນຫາປົກກະຕິ ເຊິ່ງເປີດໃຊ້ງານໂດຍໄອຄອນ <link href=\"text/shared/02/12100200.xhp\"><emph>ຄົ້ນຫາລະບຽນ</emph></link> ໃນແຖບ <emph>ຟອມ</emph>, ທ່ານສາມາດຄົ້ນຫາໄດ້ໄວຂຶ້ນໂດຍການໃຊ້ຕົວຕອງຕາມຟອມ. ໂດຍປົກກະຕິແລ້ວເຊີບເວີຖານຂໍ້ມູນທີ່ວ່ອງໄວຈະເປັນຕົວ ຈັດການການຄົ້ນຫາ. ນອກຈາກນີ້, ທ່ານຍັງສາມາດປ້ອນເງື່ອນໄຂການຄົ້ນຫາທີ່ສັບຊ້ອນກວ່າໄດ້."

