msgctxt ""
"02010000.xhp\n"
"tit\n"
"help.text"
msgid "Set Paragraph Style"
msgstr "ກຳນົດລັກສະນະຍໍ້ໜ້າ"

#. GQRbB
#: 02010000.xhp
msgctxt ""
"02010000.xhp\n"
"hd_id3148520\n"
"help.text"
