"hd_id3153089\n"
"help.text"
msgid "<link href=\"text/shared/02/07060000.xhp\">Reload</link>"
msgstr "<link href=\"text/shared/02/07060000.xhp\">ໂຫຼດຄືນໃໝ່</link>"

#. uFkfV
#: 07060000.xhp
msgctxt ""
"07060000.xhp\n"
"par_id3151315\n"
"help.text"
msgid "<ahelp hid=\".uno:Reload\" visibility=\"visible\">Replaces the current document with the last saved version.</ahelp>"
msgstr "<ahelp hid=\".uno:Reload\" visibility=\"visible\">ແທນທີ່ເອກະສານປັດຈຸບັນດ້ວຍເວີຊັນທີ່ບັນທຶກໄວ້ຫຼ້າສຸດ.</ahelp>"

#. XJkit
#: 07060000.xhp
msgctxt ""
"07060000.xhp\n"
"par_id3159201\n"
"help.text"
msgid "Any changes made after the last save will be lost."
msgstr "ການປ່ຽນແປງໃດໆທີ່ເກີດຂຶ້ນຫຼັງຈາກການບັນທຶກຄັ້ງສຸດທ້າຍຈະຖືກລຶບອອກ."

#. 99xWB
