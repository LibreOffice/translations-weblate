"help.text"
msgid "Operator"
msgstr "ຕົວດໍາເນີນການ"

#. 6iFEc
#: 12090100.xhp
msgctxt ""
"12090100.xhp\n"
"par_id3149177\n"
"help.text"
msgid "<ahelp hid=\".\">For the following arguments, you can choose between the logical operators AND / OR.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບອາກິວເມນຕໍ່ໄປນີ້, ທ່ານສາມາດເລືອກລະຫວ່າງຕົວດໍາເນີນການທາງຕັກກະສາດ AND (ແລະ) / OR (ຫຼື).</ahelp>"

