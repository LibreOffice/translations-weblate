msgstr "<image id=\"img_id3145313\" src=\"cmd/lc_graphicfilterinvert.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3145313\">ໄອຄອນກັບສີ</alt></image>"

#. BBSEC
#: 24010000.xhp
msgctxt ""
"24010000.xhp\n"
"par_id3147275\n"
"help.text"
msgid "Invert"
msgstr "ກັບສີ"

#. ajLUu
