"hd_id3149182\n"
"help.text"
msgid "Field name"
msgstr "ຊື່ຟິລ"

#. DJ4DX
#: 12090100.xhp
msgctxt ""
"12090100.xhp\n"
"par_id3149398\n"
"help.text"
msgid "<ahelp hid=\".\">Specifies the field names from the current table to set them in the argument.</ahelp> You will see the column identifiers if no text is available for the field names."
msgstr "<ahelp hid=\".\">ລະບຸຊື່ຟິລຈາກຕາຕະລາງປັດຈຸບັນເພື່ອຕັ້ງພວກມັນໃນອາກິວເມນ.</ahelp> ທ່ານຈະເຫັນຕົວລະບຸຄໍລໍາຫາກບໍ່ມີຂໍ້ຄວາມສຳລັບຊື່ຟິລ."

#. dEFte
