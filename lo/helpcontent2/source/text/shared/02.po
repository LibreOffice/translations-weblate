#: 01170101.xhp
msgctxt ""
"01170101.xhp\n"
"par_id3153797\n"
"help.text"
msgid "No action occurs."
msgstr "ບໍ່ມີຫຍັງເກີດຂຶ້ນ."

#. gWUK4
