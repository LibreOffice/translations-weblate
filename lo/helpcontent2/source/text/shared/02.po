msgstr "<image id=\"img_id3152924\" src=\"cmd/lc_autopilotmenu.svg\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3152924\">ໄອຄອນຕົວຕອງ</alt></image>"

