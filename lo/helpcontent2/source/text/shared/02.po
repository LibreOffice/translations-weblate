msgctxt ""
"12100100.xhp\n"
"par_id3149177\n"
"help.text"
msgid "<ahelp hid=\".uno:OrderCrit\">Specifies the sort order (either ascending or descending).</ahelp>"
msgstr "<ahelp hid=\".uno:OrderCrit\">ລະບຸລໍາດັບການຮຽງ (ຈາກນ້ອຍຫາໃຫຍ່ ຫຼື ຈາກໃຫຍ່ຫານ້ອຍ).</ahelp>"

#. AjAyh
#: 12100100.xhp
msgctxt ""
"12100100.xhp\n"
"hd_id3147275\n"
"help.text"
msgid "and then"
msgstr "ແລະ ຈາກນັ້ນ"

#. 6WKBJ
