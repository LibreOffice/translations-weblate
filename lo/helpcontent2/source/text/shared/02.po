msgctxt ""
"01170102.xhp\n"
"par_idN11106\n"
"help.text"
msgid "Enter text into the edit field of the combo box, or select an entry from the drop-down list:"
msgstr "ປ້ອນຂໍ້ຄວາມໃນຟີວແກ້ໄຂຂອງກ່ອງຄອມໂບ, ຫຼື ເລືອກລາຍການຈາກລາຍຊື່ແບບເລື່ອນລົງ:"

#. EkH8s
#: 01170102.xhp
msgctxt ""
"01170102.xhp\n"
"par_idN1110C\n"
"help.text"
