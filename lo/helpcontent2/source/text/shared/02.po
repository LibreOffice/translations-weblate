msgctxt ""
"24010000.xhp\n"
"par_id3159399\n"
"help.text"
msgid "<ahelp hid=\".\">Softens or blurs the image by applying a low pass filter.</ahelp>"
msgstr "<ahelp hid=\".\">ເຮັດໃຫ້ຮູບພາບອ່ອນລົງ ຫຼື ເບີໂດຍການນຳໃຊ້ຕົວຕອງແບບ low pass filter.</ahelp>"

#. oxHLM
