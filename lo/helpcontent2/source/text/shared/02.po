msgstr "<link href=\"text/shared/02/12030000.xhp\">ຕົວຕອງອັດຕະໂນມັດ</link>"

#. jkAzj
#: 12030000.xhp
msgctxt ""
"12030000.xhp\n"
"par_id3148983\n"
"help.text"
msgid "<ahelp hid=\".uno:AutoFilter\">Filters the records, based on the content of the currently selected data field.</ahelp>"
msgstr "<ahelp hid=\".uno:AutoFilter\">ຕອງຂໍ້ມູນລະບຽນ, ໂດຍອີງຕາມເນື້ອໃນຂອງຟິລຂໍ້ມູນທີ່ເລືອກໃນປັດຈຸບັນ.</ahelp>"

#. 74YJk
#: 12030000.xhp
