"help.text"
msgid "Snap to Grid"
msgstr "ດູດຕິດກັບເສັ້ນຕາໜ່າງ"

#. Eds8g
#: 01171300.xhp
msgctxt ""
"01171300.xhp\n"
"hd_id3151262\n"
