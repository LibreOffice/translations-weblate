msgctxt ""
"24010000.xhp\n"
"par_id3153760\n"
"help.text"
msgid "<ahelp hid=\".uno:GraphicFilterSharpen\">Sharpens the image by applying a high pass filter.</ahelp>"
msgstr "<ahelp hid=\".uno:GraphicFilterSharpen\">ເຮັດໃຫ້ຮູບພາບຄົມຊັດຂຶ້ນໂດຍການນຳໃຊ້ຕົວຕອງແບບ high pass filter.</ahelp>"

#. RweUD
#: 24010000.xhp
msgctxt ""
"24010000.xhp\n"
"par_id3153480\n"
