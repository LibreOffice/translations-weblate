msgstr "<image id=\"img_id3154515\" src=\"media/helpimg/zellvor.png\" width=\"1.4098inch\" height=\"0.2799inch\" localize=\"true\"><alt id=\"alt_id3154515\">ຮູບແບບຫ້ອງ</alt></image>"

