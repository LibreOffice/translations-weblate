msgid "(Optional) Set the field options for the Text CSV file."
msgstr "(ທາງເລືອກ) ຕັ້ງຄ່າຕົວເລືອກຟິວສຳລັບໄຟລ໌ຂໍ້ຄວາມ CSV."

#. 6KsfG
#: csv_files.xhp
msgctxt ""
"csv_files.xhp\n"
"par_idN1091C\n"
"help.text"
msgid "Select <item type=\"menuitem\">Edit filter settings</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ແກ້ໄຂການຕັ້ງຄ່າຕົວຕອງ</item>."

#. VXtFE
#: csv_files.xhp
msgctxt ""
"csv_files.xhp\n"
"par_idN107ED\n"
"help.text"
msgid "In the <item type=\"menuitem\">Export of text files</item> dialog, select the options that you want."
msgstr "ໃນກ່ອງໂຕ້ຕອບ <item type=\"menuitem\">ການສົ່ງອອກໄຟລ໌ຂໍ້ຄວາມ</item>, ໃຫ້ເລືອກຕົວເລືອກທີ່ທ່ານຕ້ອງການ."

#. HFtDt
#: csv_files.xhp
