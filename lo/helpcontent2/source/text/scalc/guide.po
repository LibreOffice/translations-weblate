msgid "<link href=\"text/shared/01/05020300.xhp\">Format - Cells - Numbers</link>"
msgstr "<link href=\"text/shared/01/05020300.xhp\">ຮູບແບບ - ຫ້ອງ - ຕົວເລກ</link>"

