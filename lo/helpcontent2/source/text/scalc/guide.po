#. chVng
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"tit\n"
"help.text"
msgid "Copying Formulas"
msgstr "ການສຳເນົາສູດ"

#. AKeo5
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"bm_id3151113\n"
"help.text"
msgid "<bookmark_value>formulas; copying and pasting</bookmark_value><bookmark_value>copying; formulas</bookmark_value><bookmark_value>pasting;formulas</bookmark_value>"
msgstr "<bookmark_value>ສູດ; ການສຳເນົາ ແລະ ການວາງ</bookmark_value><bookmark_value>ການສຳເນົາ; ສູດ</bookmark_value><bookmark_value>ການວາງ; ສູດ</bookmark_value>"

#. LVG2x
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"hd_id3151113\n"
"help.text"
msgid "<variable id=\"formula_copy\"><link href=\"text/scalc/guide/formula_copy.xhp\">Copying Formulas</link></variable>"
msgstr "<variable id=\"formula_copy\"><link href=\"text/scalc/guide/formula_copy.xhp\">ການສຳເນົາສູດ</link></variable>"

#. 3ZujS
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3156424\n"
"help.text"
msgid "There are various ways to copy a formula. One suggested method is:"
msgstr "ມີຫຼາຍວິທີໃນການສຳເນົາສູດ. ວິທີໜຶ່ງທີ່ແນະນຳຄື:"

#. ujCBT
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3150439\n"
"help.text"
msgid "Select the cell containing the formula."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ມີສູດ."

#. ZofEF
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3154319\n"
"help.text"
msgid "Choose <emph>Edit - Copy</emph>, or press <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+C to copy it."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ສຳເນົາ</emph>, ຫຼື ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+C ເພື່ອສຳເນົາ."

#. r3npC
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3159155\n"
"help.text"
msgid "Select the cell into which you want the formula to be copied."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ທ່ານຕ້ອງການວາງສູດທີ່ສຳເນົາມາ."

#. BTcCF
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3153728\n"
"help.text"
msgid "Choose <emph>Edit - Paste</emph>, or press <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+V. The formula will be positioned in the new cell."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ວາງ</emph>, ຫຼື ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+V. ສູດຈະຖືກວາງໄວ້ໃນຫ້ອງຕາຕະລາງໃໝ່."

#. atCgW
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3149961\n"
"help.text"
msgid "If you want to copy a formula into multiple cells, there is a quick and easy way to copy into adjacent cell areas:"
msgstr "ຖ້າທ່ານຕ້ອງການສຳເນົາສູດລົງໃນຫຼາຍຫ້ອງຕາຕະລາງ, ມີວິທີທີ່ໄວ ແລະ ງ່າຍໃນການສຳເນົາລົງໃນພື້ນທີ່ຫ້ອງຕາຕະລາງທີ່ຢູ່ຕິດກັນ:"

#. gyrPq
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3149400\n"
"help.text"
msgid "Select the cell containing the formula."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ມີສູດ."

#. fx7Nc
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3154018\n"
"help.text"
msgid "Position the mouse on the bottom right of the highlighted border of the cell, and continue holding down the mouse button until the pointer changes to a cross-hair symbol."
msgstr "ວາງເມົາສ໌ໄວ້ທີ່ມຸມຂວາລຸ່ມຂອງຂອບຫ້ອງຕາຕະລາງທີ່ເລືອກໄວ້, ແລ້ວກົດປຸ່ມເມົາສ໌ຄ້າງໄວ້ຈົນກວ່າຕົວຊີ້ເມົາສ໌ປ່ຽນເປັນເຄື່ອງໝາຍບວກ."

#. BmZDf
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3150749\n"
"help.text"
msgid "With the mouse button pressed, drag it down or to the right over all the cells into which you want to copy the formula."
msgstr "ໃນຂະນະທີ່ກົດປຸ່ມເມົາສ໌ຄ້າງໄວ້, ໃຫ້ລາກເມົາສ໌ລົງລຸ່ມ ຫຼື ໄປທາງຂວາທັບທຸກຫ້ອງຕາຕະລາງທີ່ທ່ານຕ້ອງການສຳເນົາສູດລົງໄປ."

#. 5LuK6
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3153714\n"
"help.text"
msgid "When you release the mouse button, the formula will be copied into the cells and automatically adjusted."
msgstr "ເມື່ອທ່ານປ່ອຍປຸ່ມເມົາສ໌, ສູດຈະຖືກສຳເນົາລົງໃນຫ້ອງຕາຕະລາງ ແລະ ປັບປ່ຽນໃຫ້ໂດຍອັດຕະໂນມັດ."

#. Ajamz
#: formula_copy.xhp
msgctxt ""
"formula_copy.xhp\n"
"par_id3156385\n"
"help.text"
msgid "If you do not want values and texts to be automatically adjusted, then hold down the <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> key when dragging. Formulas, however, are always adjusted accordingly."
msgstr "ຖ້າທ່ານບໍ່ຕ້ອງການໃຫ້ຄ່າ ແລະ ຂໍ້ຄວາມຖືກປັບປ່ຽນໂດຍອັດຕະໂນມັດ, ໃຫ້ກົດປຸ່ມ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> ຄ້າງໄວ້ໃນຂະນະທີ່ລາກ. ເຖິງຢ່າງໃດກໍຕາມ, ສູດຈະຖືກປັບປ່ຽນໃຫ້ເໝາະສົມສະເໝີ."

#. MrTXu
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"tit\n"
"help.text"
msgid "Entering Formulas"
msgstr "ການປ້ອນສູດ"

#. N8kvv
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"bm_id3150868\n"
"help.text"
msgid "<bookmark_value>formula bar; input line</bookmark_value><bookmark_value>input line in formula bar</bookmark_value><bookmark_value>formulas; inputting</bookmark_value><bookmark_value>inserting;formulas</bookmark_value>"
msgstr "<bookmark_value>ແຖບສູດ; ຊ່ອງປ້ອນຂໍ້ມູນ</bookmark_value><bookmark_value>ຊ່ອງປ້ອນຂໍ້ມູນໃນແຖບສູດ</bookmark_value><bookmark_value>ສູດ; ການປ້ອນຂໍ້ມູນ</bookmark_value><bookmark_value>ການແຊກ; ສູດ</bookmark_value>"

#. pfDFF
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"hd_id3150868\n"
"help.text"
msgid "<variable id=\"formula_enter\"><link href=\"text/scalc/guide/formula_enter.xhp\">Entering Formulas</link></variable>"
msgstr "<variable id=\"formula_enter\"><link href=\"text/scalc/guide/formula_enter.xhp\">ການປ້ອນສູດ</link></variable>"

#. H3w2m
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id6848353\n"
"help.text"
msgid "You can enter formulas in several ways: using the icons, or by typing on the keyboard, or by a mixture of both methods."
msgstr "ທ່ານສາມາດປ້ອນສູດໄດ້ຫຼາຍວິທີ: ໂດຍການໃຊ້ໄອຄອນ, ຫຼື ໂດຍການພິມຜ່ານຄີບອດ, ຫຼື ໃຊ້ທັງສອງວິທີປະສົມກັນ."

#. HXqkB
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3145364\n"
"help.text"
msgid "Click the cell in which you want to enter the formula."
msgstr "ຄລິກຫ້ອງຕາຕະລາງທີ່ທ່ານຕ້ອງການປ້ອນສູດ."

#. 269e8
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3150012\n"
"help.text"
msgid "Click the <emph>Formula</emph> icon on the Formula Bar."
msgstr "ຄລິກໄອຄອນ <emph>ສູດ</emph> ໃນແຖບສູດ."

#. jtUAV
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3156441\n"
"help.text"
msgid "You will now see an equals sign in the input line and you can begin to input the formula."
msgstr "ຕອນນີ້ທ່ານຈະເຫັນເຄື່ອງໝາຍເທົ່າກັບໃນຊ່ອງປ້ອນຂໍ້ມູນ ແລະ ທ່ານສາມາດເລີ່ມປ້ອນສູດໄດ້."

#. 6zCUk
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3153726\n"
"help.text"
msgid "After entering the required values, press Enter or click <emph>Accept</emph> to insert the result in the active cell. If you want to clear your entry in the input line, press Escape or click <emph>Cancel</emph>."
msgstr "ຫຼັງຈາກປ້ອນຄ່າທີ່ຕ້ອງການແລ້ວ, ໃຫ້ກົດ Enter ຫຼື ຄລິກ <emph>ຕົກລົງ</emph> ເພື່ອແຊກຜົນໄດ້ຮັບລົງໃນຫ້ອງຕາຕະລາງທີ່ກຳລັງເຮັດວຽກຢູ່. ຖ້າທ່ານຕ້ອງການລຶບສິ່ງທີ່ປ້ອນລົງໃນຊ່ອງປ້ອນຂໍ້ມູນ, ໃຫ້ກົດ Escape ຫຼື ຄລິກ <emph>ຍົກເລີກ</emph>."

#. b4AH4
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3147394\n"
"help.text"
msgid "You can also enter the values and the formulas directly into the cells, even if you cannot see an input cursor. Formulas must always begin with an equals sign."
msgstr "ທ່ານຍັງສາມາດປ້ອນຄ່າ ແລະ ສູດລົງໃນຫ້ອງຕາຕະລາງໂດຍກົງໄດ້, ເຖິງແມ່ນວ່າທ່ານຈະບໍ່ເຫັນຕົວຊີ້ປ້ອນຂໍ້ມູນກໍຕາມ. ສູດຕ້ອງເລີ່ມຕົ້ນດ້ວຍເຄື່ອງໝາຍເທົ່າກັບສະເໝີ."

#. qLCxa
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id4206976\n"
"help.text"
msgid "You can also press the + or - key on the numerical keyboard to start a formula. NumLock must be \"on\". For example, press the following keys in succession:"
msgstr "ທ່ານຍັງສາມາດກົດປຸ່ມ + ຫຼື - ໃນແປ້ນຕົວເລກເພື່ອເລີ່ມສູດ. ປຸ່ມ NumLock ຕ້ອງເປີດຢູ່. ຕົວຢ່າງ: ໃຫ້ກົດປຸ່ມຕໍ່ໄປນີ້ຕາມລຳດັບ:"

#. 7dRd8
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id1836909\n"
"help.text"
msgid "+ 5 0 - 8 Enter"
msgstr "+ 5 0 - 8 Enter"

#. pADVE
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id8171330\n"
"help.text"
msgid "You see the result <item type=\"literal\">42</item> in the cell. The cell contains the formula <item type=\"literal\">=+50-8</item>."
msgstr "ທ່ານຈະເຫັນຜົນໄດ້ຮັບ <item type=\"literal\">42</item> ໃນຫ້ອງຕາຕະລາງ. ຫ້ອງຕາຕະລາງນັ້ນຈະມີສູດ <item type=\"literal\">=+50-8</item>."

#. H7Gc5
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3155764\n"
"help.text"
msgid "If you are editing a formula with references, the references and the associated cells will be highlighted with the same color. You can now resize the reference border using the mouse, and the reference in the formula displayed in the input line also changes. <emph>Show references in color</emph> can be deactivated under <switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - Preferences</caseinline><defaultinline>Tools - Options</defaultinline></switchinline> - <link href=\"text/shared/optionen/01060300.xhp\">%PRODUCTNAME Calc - View</link>."
msgstr "ຖ້າທ່ານກຳລັງແກ້ໄຂສູດທີ່ມີການອ້າງອີງ, ການອ້າງອີງ ແລະ ຫ້ອງຕາຕະລາງທີ່ກ່ຽວຂ້ອງຈະຖືກເນັ້ນດ້ວຍສີດຽວກັນ. ທ່ານສາມາດປັບຂະໜາດຂອບການອ້າງອີງໂດຍໃຊ້ເມົາສ໌, ແລະ ການອ້າງອີງໃນສູດທີ່ສະແດງໃນຊ່ອງປ້ອນຂໍ້ມູນກໍຈະປ່ຽນແປງນຳ. ສາມາດປິດການໃຊ້ງານ <emph>ສະແດງການອ້າງອີງເປັນສີ</emph> ໄດ້ທີ່ <switchinline select=\"sys\"><caseinline select=\"MAC\">%PRODUCTNAME - ການຕັ້ງຄ່າ</caseinline><defaultinline>ເຄື່ອງມື - ຕົວເລືອກ</defaultinline></switchinline> - <link href=\"text/shared/optionen/01060300.xhp\">%PRODUCTNAME Calc - ມຸມມອງ</link>."

#. G2WDH
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3149210\n"
"help.text"
msgid "<variable id=\"tip\">If you would like to view the calculation of individual elements of a formula, select the respective elements and press F9. For example, in the formula =SUM(A1:B12)*SUM(C1:D12) select the section SUM(C1:D12) and press F9 to view the subtotal for this area. </variable>"
msgstr "<variable id=\"tip\">ຖ້າທ່ານຕ້ອງການເບິ່ງການຄິດໄລ່ຂອງແຕ່ລະສ່ວນປະກອບໃນສູດ, ໃຫ້ເລືອກສ່ວນປະກອບນັ້ນໆ ແລ້ວກົດ F9. ຕົວຢ່າງ: ໃນສູດ =SUM(A1:B12)*SUM(C1:D12) ໃຫ້ເລືອກສ່ວນ SUM(C1:D12) ແລ້ວກົດ F9 ເພື່ອເບິ່ງຜົນລວມຍ່ອຍສຳລັບພື້ນທີ່ນີ້.</variable>"

#. UNkCH
#: formula_enter.xhp
msgctxt ""
"formula_enter.xhp\n"
"par_id3150304\n"
"help.text"
msgid "If an error occurs when creating the formula, an <link href=\"text/scalc/05/02140000.xhp\">error message</link> appears in the active cell."
msgstr "ຖ້າເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ສ້າງສູດ, <link href=\"text/scalc/05/02140000.xhp\">ຂໍ້ຄວາມສະແດງຂໍ້ຜິດພາດ</link> ຈະປາກົດຂຶ້ນໃນຫ້ອງຕາຕະລາງທີ່ກຳລັງເຮັດວຽກຢູ່."

