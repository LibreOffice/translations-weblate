#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3159264\n"
"help.text"
msgid "Field contents"
msgstr "ເນື້ອໃນຂອງຊ່ອງ"

#. HbCYq
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3155337\n"
"help.text"
msgid "Effect of clicking the mouse"
msgstr "ຜົນຂອງການຄລິກເມົາສ໌"

#. qCjXD
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3149568\n"
"help.text"
msgid "STD"
msgstr "STD"

#. uCt66
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3148486\n"
"help.text"
msgid "A mouse click selects the cell you have clicked on. Unmarks all marked cells."
msgstr "ການຄລິກເມົາສ໌ຈະເລືອກຫ້ອງຕາຕະລາງທີ່ທ່ານໄດ້ຄລິກໃສ່. ແລະ ຍົກເລີກການໝາຍທຸກຫ້ອງທີ່ໝາຍໄວ້ກ່ອນໜ້າ."

#. HQyai
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3150090\n"
"help.text"
msgid "EXT"
msgstr "EXT"

#. 5FQEV
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3150305\n"
"help.text"
msgid "A mouse click marks a rectangular range from the current cell to the cell you clicked. Alternatively, Shift-click a cell."
msgstr "ການຄລິກເມົາສ໌ຈະໝາຍຊ່ວງຮູບສີ່ແຈສາກຈາກຫ້ອງປັດຈຸບັນຫາຫ້ອງທີ່ທ່ານຄລິກ. ຫຼື ກົດ Shift-ຄລິກ ໃສ່ຫ້ອງຕາຕະລາງ."

#. TBk4P
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3145587\n"
"help.text"
msgid "ADD"
msgstr "ADD"

#. hQCw9
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"par_id3154368\n"
"help.text"
msgid "A mouse click in a cell adds it to the already marked cells. A mouse click in a marked cell unmarks it. Alternatively, <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>-click the cells."
msgstr "ການຄລິກເມົາສ໌ໃນຫ້ອງຕາຕະລາງຈະເພີ່ມມັນເຂົ້າໃນຫ້ອງທີ່ໝາຍໄວ້ແລ້ວ. ການຄລິກໃນຫ້ອງທີ່ໝາຍໄວ້ແລ້ວຈະເປັນການຍົກເລີກການໝາຍ. ຫຼື ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>-ຄລິກ ໃສ່ຫ້ອງຕາຕະລາງ."

#. DEZXm
#: mark_cells.xhp
msgctxt ""
"mark_cells.xhp\n"
"hd_id651754050551864\n"
