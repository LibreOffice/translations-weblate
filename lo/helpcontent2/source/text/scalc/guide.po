#. J3aQ5
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10756\n"
"help.text"
msgid "You can open and save data in the dBASE file format (*.dbf file extension) in $[officename] Base or a spreadsheet. In %PRODUCTNAME Base, a dBASE database is a folder that contains files with the .dbf file extension. Each file corresponds to a table in the database. Formulas and formatting are lost when you open and save a dBASE file from %PRODUCTNAME."
msgstr "ທ່ານສາມາດເປີດ ແລະ ບັນທຶກຂໍ້ມູນໃນຮູບແບບໄຟລ໌ dBASE (ນາມສະກຸນໄຟລ໌ .dbf) ໃນ $[officename] Base ຫຼື ແຜ່ນງານໄດ້. ໃນ %PRODUCTNAME Base, ຖານຂໍ້ມູນ dBASE ແມ່ນໂຟນເດີທີ່ມີໄຟລ໌ນາມສະກຸນ .dbf. ແຕ່ລະໄຟລ໌ຈະກົງກັບຕາຕະລາງໜຶ່ງໃນຖານຂໍ້ມູນ. ສູດ ແລະ ການຈັດຮູບແບບຈະເສຍໄປເມື່ອທ່ານເປີດ ແລະ ບັນທຶກໄຟລ໌ dBASE ຈາກ %PRODUCTNAME."

#. jVz9V
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10759\n"
"help.text"
msgid "To Import a dBASE File Into a Spreadsheet"
msgstr "ວິທີການນຳເຂົ້າໄຟລ໌ dBASE ເຂົ້າໃນແຜ່ນງານ"

#. v3JdV
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10760\n"
"help.text"
msgid "Choose <emph>File - Open</emph>."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ເປີດ</emph>."

#. FmmZC
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN1071F\n"
"help.text"
msgid "Locate the *.dbf file that you want to import."
msgstr "ຊອກຫາໄຟລ໌ *.dbf ທີ່ທ່ານຕ້ອງການນຳເຂົ້າ."

#. cBR6P
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10768\n"
"help.text"
msgid "Click <emph>Open</emph>."
msgstr "ຄລິກ <emph>ເປີດ</emph>."

#. WQGdy
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10730\n"
"help.text"
msgid "The <emph>Import dBASE files</emph> dialog opens."
msgstr "ກ່ອງໂຕ້ຕອບ <emph>ນຳເຂົ້າໄຟລ໌ dBASE</emph> ຈະເປີດຂຶ້ນ."

#. S2JPc
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10774\n"
"help.text"
msgid "Click <emph>OK</emph>."
msgstr "ຄລິກ <emph>ຕົກລົງ</emph>."

#. DBvJH
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10777\n"
"help.text"
msgid "The dBASE file opens as a new Calc spreadsheet."
msgstr "ໄຟລ໌ dBASE ຈະເປີດເປັນແຜ່ນງານ Calc ໃໝ່."

#. pLCMp
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN1074E\n"
"help.text"
msgid "If you want to save the spreadsheet as a dBASE file, do not alter or delete the first row in the imported file. This row contains information that is required by a dBASE database."
msgstr "ຖ້າທ່ານຕ້ອງການບັນທຶກແຜ່ນງານເປັນໄຟລ໌ dBASE, ຫ້າມປ່ຽນແປງ ຫຼື ລຶບແຖວທຳອິດໃນໄຟລ໌ທີ່ນຳເຂົ້ານັ້ນ. ແຖວນີ້ມີຂໍ້ມູນທີ່ຈຳເປັນສຳລັບຖານຂໍ້ມູນ dBASE."

#. 8hyku
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN1077A\n"
"help.text"
msgid "To Import a dBASE File Into a Database Table"
msgstr "ວິທີການນຳເຂົ້າໄຟລ໌ dBASE ເຂົ້າໃນຕາຕະລາງຖານຂໍ້ມູນ"

#. gBiN7
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN1076C\n"
"help.text"
msgid "A %PRODUCTNAME Base database table is actually a link to an existing database."
msgstr "ຕາຕະລາງຖານຂໍ້ມູນ %PRODUCTNAME Base ຄວາມຈິງແລ້ວແມ່ນການເຊື່ອມໂຍງຫາຖານຂໍ້ມູນທີ່ມີຢູ່ແລ້ວ."

#. Z2WYv
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10796\n"
"help.text"
msgid "Choose <item type=\"menuitem\">File - New - Database</item>."
msgstr "ເລືອກ <item type=\"menuitem\">ໄຟລ໌ - ໃໝ່ - ຖານຂໍ້ມູນ</item>."

#. VtptA
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10786\n"
"help.text"
msgid "In the <emph>File name</emph> box of the <emph>Save As</emph> dialog, enter a name for the database."
msgstr "ໃນຫ້ອງ <emph>ຊື່ໄຟລ໌</emph> ຂອງກ່ອງໂຕ້ຕອບ <emph>ບັນທຶກເປັນ</emph>, ໃຫ້ປ້ອນຊື່ສຳລັບຖານຂໍ້ມູນ."

#. KGUEA
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10792\n"
"help.text"
msgid "Click <emph>Save</emph>."
msgstr "ຄລິກ <emph>ບັນທຶກ</emph>."

#. Bz2eB
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN1079A\n"
"help.text"
msgid "In the <emph>Database type </emph>box of the <emph>Database Properties</emph> dialog, select \"dBASE\"."
msgstr "ໃນຫ້ອງ <emph>ປະເພດຖານຂໍ້ມູນ</emph> ຂອງກ່ອງໂຕ້ຕອບ <emph>ຄຸນສົມບັດຖານຂໍ້ມູນ</emph>, ໃຫ້ເລືອກ \"dBASE\"."

#. HjBBj
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107A6\n"
"help.text"
msgid "Click <emph>Next</emph>."
msgstr "ຄລິກ <emph>ຖັດໄປ</emph>."

#. w4Hcx
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107AE\n"
"help.text"
msgid "Click <emph>Browse</emph>."
msgstr "ຄລິກ <emph>ຄົ້ນຫາ</emph>."

#. EyJdW
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107B6\n"
"help.text"
msgid "Locate the directory that contains the dBASE file, and click <emph>OK</emph>."
msgstr "ຊອກຫາໄດເຣັກທໍຣີທີ່ມີໄຟລ໌ dBASE, ແລ້ວຄລິກ <emph>ຕົກລົງ</emph>."

#. 5kG55
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107BE\n"
"help.text"
msgid "Click <emph>Create</emph>."
msgstr "ຄລິກ <emph>ສ້າງ</emph>."

#. rJEHy
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107F1\n"
"help.text"
msgid "To Save a Spreadsheet as a dBASE File"
msgstr "ວິທີການບັນທຶກແຜ່ນງານເປັນໄຟລ໌ dBASE"

#. i2EnS
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107F8\n"
"help.text"
msgid "Choose <emph>File - Save As</emph>."
msgstr "ເລືອກ <emph>ໄຟລ໌ - ບັນທຶກເປັນ</emph>."

#. N4YuB
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10800\n"
"help.text"
msgid "In the <emph>File format</emph> box, select \"dBASE file\"."
msgstr "ໃນຫ້ອງ <emph>ຮູບແບບໄຟລ໌</emph>, ໃຫ້ເລືອກ \"ໄຟລ໌ dBASE\"."

#. rrFCz
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN107F9\n"
"help.text"
msgid "In the <emph>File name</emph> box, type a name for the dBASE file."
msgstr "ໃນຫ້ອງ <emph>ຊື່ໄຟລ໌</emph>, ໃຫ້ພິມຊື່ສຳລັບໄຟລ໌ dBASE."

#. VW7aF
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10801\n"
"help.text"
msgid "Click <emph>Save</emph>."
msgstr "ຄລິກ <emph>ບັນທຶກ</emph>."

#. WF9Ky
#: dbase_files.xhp
msgctxt ""
"dbase_files.xhp\n"
"par_idN10808\n"
"help.text"
msgid "Only the data on the current sheet is exported."
msgstr "ຈະມີພຽງແຕ່ຂໍ້ມູນໃນແຜ່ນງານປັດຈຸບັນເທົ່ານັ້ນທີ່ຖືກສົ່ງອອກ."

#. kzGEG
#: design.xhp
msgctxt ""
"design.xhp\n"
"tit\n"
"help.text"
msgid "Selecting Themes for Sheets"
msgstr "ການເລືອກທີມ (Themes) ສຳລັບແຜ່ນງານ"

#. qMsyD
#: design.xhp
msgctxt ""
"design.xhp\n"
"bm_id3150791\n"
"help.text"
msgid "<bookmark_value>theme selection for sheets</bookmark_value><bookmark_value>layout;spreadsheets</bookmark_value><bookmark_value>cell styles; selecting</bookmark_value><bookmark_value>selecting;formatting themes</bookmark_value><bookmark_value>sheets;formatting themes</bookmark_value><bookmark_value>formats;themes for sheets</bookmark_value><bookmark_value>formatting;themes for sheets</bookmark_value>"
msgstr "<bookmark_value>ການເລືອກທີມສຳລັບແຜ່ນງານ</bookmark_value><bookmark_value>ການຈັດວາງ; ແຜ່ນງານ</bookmark_value><bookmark_value>ຮູບແບບເຊວ; ການເລືອກ</bookmark_value><bookmark_value>ການເລືອກ; ທີມການຈັດຮູບແບບ</bookmark_value><bookmark_value>ແຜ່ນງານ; ທີມການຈັດຮູບແບບ</bookmark_value><bookmark_value>ຮູບແບບ; ທີມສຳລັບແຜ່ນງານ</bookmark_value><bookmark_value>ການຈັດຮູບແບບ; ທີມສຳລັບແຜ່ນງານ</bookmark_value>"

#. qn4Wm
#: design.xhp
msgctxt ""
"design.xhp\n"
"hd_id3150791\n"
"help.text"
msgid "<variable id=\"design\"><link href=\"text/scalc/guide/design.xhp\">Selecting Themes for Sheets</link></variable>"
msgstr "<variable id=\"design\"><link href=\"text/scalc/guide/design.xhp\">ການເລືອກທີມສຳລັບແຜ່ນງານ</link></variable>"

#. axrVR
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3145786\n"
"help.text"
msgid "$[officename] Calc comes with a predefined set of formatting themes that you can apply to your spreadsheets."
msgstr "$[officename] Calc ມາພ້ອມກັບຊຸດທີມການຈັດຮູບແບບທີ່ກຳນົດໄວ້ລ່ວງໜ້າ ເຊິ່ງທ່ານສາມາດນຳໃຊ້ກັບແຜ່ນງານຂອງທ່ານໄດ້."

#. eAC5E
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3154490\n"
"help.text"
msgid "It is not possible to add themes to Calc, and they cannot be modified. However, you can modify their styles after you apply them to a spreadsheet."
msgstr "ມັນບໍ່ສາມາດເພີ່ມທີມເຂົ້າໃນ Calc ໄດ້ ແລະ ພວກມັນກໍບໍ່ສາມາດຖືກແກ້ໄຂໄດ້. ຢ່າງໃດກໍຕາມ, ທ່ານສາມາດແກ້ໄຂຮູບແບບຂອງພວກມັນໄດ້ຫຼັງຈາກທີ່ທ່ານນຳໃຊ້ພວກມັນກັບແຜ່ນງານແລ້ວ."

#. ZD2hJ
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3154757\n"
"help.text"
msgid "Before you format a sheet with a theme, you have to apply at least one custom cell style to the cells on the sheet. You can then change the cell formatting by selecting and applying a theme in the <emph>Theme Selection</emph> dialog."
msgstr "ກ່ອນທີ່ທ່ານຈະຈັດຮູບແບບແຜ່ນງານດ້ວຍທີມ, ທ່ານຈະຕ້ອງນຳໃຊ້ຮູບແບບເຊວທີ່ປັບແຕ່ງເອງຢ່າງໜ້ອຍໜຶ່ງຮູບແບບໃຫ້ກັບເຊວໃນແຜ່ນງານ. ຈາກນັ້ນ ທ່ານສາມາດປ່ຽນການຈັດຮູບແບບເຊວໄດ້ໂດຍການເລືອກ ແລະ ນຳໃຊ້ທີມໃນກ່ອງໂຕ້ຕອບ <emph>ການເລືອກທີມ</emph>."

#. Uwd2e
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3156382\n"
"help.text"
msgid "To apply a custom cell style to a cell, you can open the Styles deck and, in its lower list box, set the Custom Styles view. A list of the existing custom defined cell styles will be displayed. Double click a name from the Styles deck to apply this style to the selected cells."
msgstr ""

#. 6zVVD
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3153963\n"
"help.text"
msgid "To apply a theme to a spreadsheet:"
msgstr "ວິທີການນຳໃຊ້ທີມໃຫ້ກັບແຜ່ນງານ:"

#. FFRn8
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3146920\n"
"help.text"
msgid "Click the <emph>Choose Themes</emph> icon in the <emph>Tools</emph> bar."
msgstr "ຄລິກທີ່ໄອຄອນ <emph>ເລືອກທີມ</emph> ໃນແຖບ <emph>ເຄື່ອງມື</emph>."

#. 8G65u
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3148488\n"
"help.text"
msgid "The <emph>Theme Selection</emph> dialog appears. This dialog lists the available themes for the whole spreadsheet and the Styles deck lists the custom styles for specific cells."
msgstr ""

#. BgEap
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3155114\n"
"help.text"
msgid "In the <emph>Theme Selection </emph>dialog, select the theme that you want to apply to the spreadsheet."
msgstr "ໃນກ່ອງໂຕ້ຕອບ <emph>ການເລືອກທີມ</emph>, ໃຫ້ເລືອກທີມທີ່ທ່ານຕ້ອງການນຳໃຊ້ໃຫ້ກັບແຜ່ນງານ."

#. mhFa5
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3150090\n"
"help.text"
msgid "Click OK"
msgstr "ຄລິກ ຕົກລົງ"

#. QfPpn
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3150201\n"
"help.text"
msgid "As soon as you select another theme in the <emph>Theme Selection</emph> dialog, some of the properties of the custom style will be applied to the current spreadsheet. The modifications will be immediately visible in your spreadsheet."
msgstr "ທັນທີທີ່ທ່ານເລືອກທີມອື່ນໃນກ່ອງໂຕ້ຕອບ <emph>ການເລືອກທີມ</emph>, ຄຸນສົມບັດບາງຢ່າງຂອງຮູບແບບທີ່ປັບແຕ່ງເອງຈະຖືກນຳໃຊ້ກັບແຜ່ນງານປັດຈຸບັນ. ການປ່ຽນແປງຈະເຫັນໄດ້ທັນທີໃນແຜ່ນງານຂອງທ່ານ."

#. CRzqY
#: design.xhp
msgctxt ""
"design.xhp\n"
"par_id3146979\n"
"help.text"
msgid "<link href=\"text/scalc/02/06080000.xhp\">Theme selection</link>"
msgstr "<link href=\"text/scalc/02/06080000.xhp\">ການເລືອກທີມ</link>"

#. t5ETg
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"tit\n"
"help.text"
msgid "Copying to Multiple Sheets"
msgstr "ການຄັດລອກໄປຫາຫຼາຍແຜ່ນງານ"

#. BbCnT
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"bm_id3149456\n"
"help.text"
msgid "<bookmark_value>copying;values, to multiple sheets</bookmark_value><bookmark_value>pasting;values in multiple sheets</bookmark_value><bookmark_value>data;inserting in multiple sheets</bookmark_value><bookmark_value>sheets; simultaneous multiple filling</bookmark_value>"
msgstr "<bookmark_value>ການຄັດລອກ; ຄ່າ, ໄປຫາຫຼາຍແຜ່ນງານ</bookmark_value><bookmark_value>ການວາງ; ຄ່າໃນຫຼາຍແຜ່ນງານ</bookmark_value><bookmark_value>ຂໍ້ມູນ; ການແຊກໃນຫຼາຍແຜ່ນງານ</bookmark_value><bookmark_value>ແຜ່ນງານ; ການຕື່ມຂໍ້ມູນຫຼາຍແຜ່ນງານພ້ອມກັນ</bookmark_value>"

#. 4PAZG
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"hd_id3149456\n"
"help.text"
msgid "<variable id=\"edit_multitables\"><link href=\"text/scalc/guide/edit_multitables.xhp\">Copying to Multiple Sheets</link></variable>"
msgstr "<variable id=\"edit_multitables\"><link href=\"text/scalc/guide/edit_multitables.xhp\">ການຄັດລອກໄປຫາຫຼາຍແຜ່ນງານ</link></variable>"

#. 4sMCm
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"par_id3150868\n"
"help.text"
msgid "In $[officename] Calc, you can insert values, text or formulas that are simultaneously copied to other selected sheets of your document."
msgstr "ໃນ $[officename] Calc, ທ່ານສາມາດແຊກຄ່າ, ຂໍ້ຄວາມ ຫຼື ສູດ ເຊິ່ງຈະຖືກຄັດລອກໄປຫາແຜ່ນງານອື່ນໆທີ່ເລືອກໄວ້ໃນເອກະສານຂອງທ່ານພ້ອມໆກັນ."

#. Z4D7x
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"par_id3153768\n"
"help.text"
msgid "Select all desired sheets by holding down the <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline> key and clicking the corresponding register tabs that are still gray at the bottom margin of the workspace. All selected register tabs are now white."
msgstr "ເລືອກແຜ່ນງານທັງໝົດທີ່ຕ້ອງການໂດຍການກົດປຸ່ມ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline> ຄ້າງໄວ້ ແລະ ຄລິກທີ່ແຖບຊື່ແຜ່ນງານທີ່ຍັງເປັນສີເທົາຢູ່ດ້ານລຸ່ມຂອງພື້ນທີ່ເຮັດວຽກ. ແຖບຊື່ແຜ່ນງານທີ່ຖືກເລືອກທັງໝົດຈະກາຍເປັນສີຂາວ."

#. xSB4o
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"par_idN10614\n"
"help.text"
msgid "You can use <emph>Shift</emph>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline>+<emph>Page Up</emph> or <emph>Page Down</emph> to select multiple sheets using the keyboard."
msgstr "ທ່ານສາມາດໃຊ້ <emph>Shift</emph>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>Command</emph></caseinline><defaultinline><emph>Ctrl</emph></defaultinline></switchinline>+<emph>Page Up</emph> ຫຼື <emph>Page Down</emph> ເພື່ອເລືອກຫຼາຍແຜ່ນງານໂດຍການໃຊ້ຄີບອດ."

#. bwHKS
#: edit_multitables.xhp
msgctxt ""
"edit_multitables.xhp\n"
"par_id3147435\n"
"help.text"
msgid "Now when you insert values, text or formulas into the active sheet, they will also appear in the identical positions in the other selected sheets. For example, data entered in cell \"A1\" of the active sheet is automatically entered into cell \"A1\" of any other selected sheet."
msgstr "ຕອນນີ້ເມື່ອທ່ານແຊກຄ່າ, ຂໍ້ຄວາມ ຫຼື ສູດ ລົງໃນແຜ່ນງານທີ່ກຳລັງໃຊ້ງານຢູ່, ພວກມັນກໍຈະປາກົດໃນຕຳແໜ່ງດຽວກັນໃນແຜ່ນງານອື່ນໆທີ່ເລືອກໄວ້. ຕົວຢ່າງ, ຂໍ້ມູນທີ່ປ້ອນໃນເຊວ \"A1\" ຂອງແຜ່ນງານທີ່ກຳລັງໃຊ້ງານ ຈະຖືກປ້ອນເຂົ້າໃນເຊວ \"A1\" ຂອງແຜ່ນງານອື່ນໆທີ່ເລືອກໄວ້ໂດຍອັດຕະໂນມັດ."

#. ASuDk
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"tit\n"
"help.text"
msgid "Applying Filters"
msgstr "ການນຳໃຊ້ຕົວຕອງ"

#. vAkUj
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"bm_id3153896\n"
"help.text"
msgid "<bookmark_value>filters; applying/removing</bookmark_value>      <bookmark_value>rows;removing/redisplaying with filters</bookmark_value>      <bookmark_value>removing;filters</bookmark_value>"
msgstr "<bookmark_value>ຕົວຕອງ; ການນຳໃຊ້/ການລຶບ</bookmark_value> <bookmark_value>ແຖວ; ການລຶບ/ການສະແດງຄືນໃໝ່ດ້ວຍຕົວຕອງ</bookmark_value> <bookmark_value>ການລຶບ; ຕົວຕອງ</bookmark_value>"

#. WH2qG
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"hd_id3153896\n"
"help.text"
msgid "<variable id=\"filters\"><link href=\"text/scalc/guide/filters.xhp\">Applying Filters</link></variable>"
msgstr "<variable id=\"filters\"><link href=\"text/scalc/guide/filters.xhp\">ການນຳໃຊ້ຕົວຕອງ</link></variable>"

#. d4Uux
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id3150869\n"
"help.text"
msgid "Filters and advanced filters allow you to work on certain filtered rows (records) of a data range. In the spreadsheets in $[officename] there are various possibilities for applying filters."
msgstr "ຕົວຕອງ ແລະ ຕົວຕອງຂັ້ນສູງຊ່ວຍໃຫ້ທ່ານສາມາດເຮັດວຽກກັບແຖວ (ເຣັກຄອດ) ທີ່ຖືກຕອງໄວ້ໃນຊ່ວງຂໍ້ມູນ. ໃນແຜ່ນງານຂອງ $[officename] ມີຄວາມເປັນໄປໄດ້ຫຼາຍຢ່າງໃນການນຳໃຊ້ຕົວຕອງ."

#. XnoBc
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id3155131\n"
"help.text"
msgid "One use for the <emph>AutoFilter</emph> function is to quickly restrict the display to records with identical entries in a data field."
msgstr "ປະໂຫຍດໜຶ່ງຂອງຟັງຊັນ <emph>ຕົວຕອງອັດຕະໂນມັດ (AutoFilter)</emph> ແມ່ນເພື່ອຈຳກັດການສະແດງຜົນໃຫ້ເຫັນສະເພາະເຣັກຄອດທີ່ມີຂໍ້ມູນຄືກັນໃນຟິວຂໍ້ມູນໃດໜຶ່ງໄດ້ຢ່າງວ່ອງໄວ."

#. mbcRS
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id3146119\n"
"help.text"
msgid "In the <emph>Standard Filter</emph> dialog, you can also define ranges which contain the values in particular data fields. You can use the standard filter to connect the conditions with either a logical AND or a logical OR operator."
msgstr "ໃນກ່ອງໂຕ້ຕອບ <emph>ຕົວຕອງມາດຕະຖານ</emph>, ທ່ານຍັງສາມາດກຳນົດຊ່ວງທີ່ມີຄ່າໃນຟິວຂໍ້ມູນສະເພາະໄດ້. ທ່ານສາມາດໃຊ້ຕົວຕອງມາດຕະຖານເພື່ອເຊື່ອມຕໍ່ເງື່ອນໄຂດ້ວຍຕົວດຳເນີນການທາງຕັກກະສາດ AND ຫຼື OR."

#. YtHEq
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id3150010\n"
"help.text"
msgid "The <emph>Advanced filter</emph> allows up to a total of eight filter conditions. With advanced filters you enter the conditions directly into the sheet."
msgstr "<emph>ຕົວຕອງຂັ້ນສູງ</emph> ສາມາດກຳນົດເງື່ອນໄຂການຕອງໄດ້ທັງໝົດເຖິງແປດເງື່ອນໄຂ. ດ້ວຍຕົວຕອງຂັ້ນສູງ ທ່ານສາມາດປ້ອນເງື່ອນໄຂລົງໃນແຜ່ນງານໂດຍກົງ."

#. tffpp
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id9384746\n"
"help.text"
msgid "To remove a filter, so that you see all cells again, click inside the area where the filter was applied, then choose <item type=\"menuitem\">Data - Filter - Reset Filter</item>."
msgstr "ເພື່ອ ລຶບຕົວຕອງອອກ ເພື່ອໃຫ້ທ່ານເຫັນທຸກເຊວອີກຄັ້ງ, ໃຫ້ຄລິກພາຍໃນພື້ນທີ່ທີ່ນຳໃຊ້ຕົວຕອງ, ແລ້ວເລືອກ <item type=\"menuitem\">ຂໍ້ມູນ - ຕົວຕອງ - ຣີເຊັດຕົວຕອງ</item>."

#. E2EfB
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_idN10663\n"
"help.text"
msgid "When you select multiple rows from an area where a filter was applied, then this selection can include rows that are visible and rows that are hidden by the filter. If you then apply formatting, or delete the selected rows, this action then applies only to the visible rows. The hidden rows are not affected."
msgstr "ເມື່ອທ່ານເລືອກຫຼາຍແຖວຈາກພື້ນທີ່ທີ່ມີການນຳໃຊ້ຕົວຕອງ, ການເລືອກນີ້ອາດຈະລວມເອົາທັງແຖວທີ່ເຫັນໄດ້ ແລະ ແຖວທີ່ຖືກເຊື່ອງໄວ້ໂດຍຕົວຕອງ. ຖ້າທ່ານຈັດຮູບແບບ ຫຼື ລຶບແຖວທີ່ເລືອກ, ການດຳເນີນການນີ້ຈະມີຜົນກັບສະເພາະແຖວທີ່ເຫັນໄດ້ເທົ່ານັ້ນ. ແຖວທີ່ຖືກເຊື່ອງໄວ້ຈະບໍ່ໄດ້ຮັບຜົນກະທົບ."

#. LAuWM
#: filters.xhp
msgctxt ""
"filters.xhp\n"
"par_id218817\n"
"help.text"
msgid "This is the opposite to rows that you have hidden manually by the <emph>Format - Rows - Hide Rows</emph> command. Manually hidden rows are deleted when you delete a selection that contains them."
msgstr "ນີ້ແມ່ນສິ່ງທີ່ກົງກັນຂ້າມກັບແຖວທີ່ທ່ານເຊື່ອງໄວ້ດ້ວຍຕົນເອງໂດຍໃຊ້ຄຳສັ່ງ <emph>ຮູບແບບ - ແຖວ - ເຊື່ອງແຖວ</emph>. ແຖວທີ່ຖືກເຊື່ອງດ້ວຍຕົນເອງຈະຖືກລຶບໄປເມື່ອທ່ານລຶບສ່ວນທີ່ເລືອກທີ່ມີແຖວເຫຼົ່ານັ້ນຢູ່."

#. 8sxJn
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"tit\n"
"help.text"
msgid "Finding and Replacing in Calc"
msgstr "ການຄົ້ນຫາ ແລະ ການແທນທີ່ໃນ Calc"

#. qSAcB
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"bm_id3769341\n"
"help.text"
msgid "<bookmark_value>searching, see also finding</bookmark_value><bookmark_value>finding;formulas/values/text/objects</bookmark_value><bookmark_value>replacing; cell contents</bookmark_value><bookmark_value>formatting;multiple cell texts</bookmark_value>"
msgstr "<bookmark_value>ການຄົ້ນຫາ, ເບິ່ງ ການຊອກຫາ ຕື່ມ</bookmark_value><bookmark_value>ການຊອກຫາ; ສູດ/ຄ່າ/ຂໍ້ຄວາມ/ວັດຖຸ</bookmark_value><bookmark_value>ການແທນທີ່; ເນື້ອໃນເຊວ</bookmark_value><bookmark_value>ການຈັດຮູບແບບ; ຂໍ້ຄວາມໃນຫຼາຍເຊວ</bookmark_value>"

#. riEkj
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"hd_id3149204\n"
"help.text"
msgid "<variable id=\"finding\"><link href=\"text/scalc/guide/finding.xhp\">Finding and Replacing in Calc</link></variable>"
msgstr "<variable id=\"finding\"><link href=\"text/scalc/guide/finding.xhp\">ການຄົ້ນຫາ ແລະ ການແທນທີ່ໃນ Calc</link></variable>"

#. uzefv
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id9363689\n"
"help.text"
msgid "In spreadsheet documents you can find words, formulas, and styles. You can navigate from one result to the next, or you can highlight all matching cells at once, then apply another format or replace the cell content by other content."
msgstr "ໃນເອກະສານແຜ່ນງານ ທ່ານສາມາດຄົ້ນຫາຄຳສັບ, ສູດ ແລະ ຮູບແບບໄດ້. ທ່ານສາມາດໄປຫາຜົນການຄົ້ນຫາແຕ່ລະອັນໄດ້, ຫຼື ທ່ານສາມາດເນັ້ນເຊວທີ່ກົງກັນທັງໝົດພ້ອມກັນ, ຈາກນັ້ນກໍຈັດຮູບແບບອື່ນ ຫຼື ແທນທີ່ເນື້ອໃນເຊວດ້ວຍເນື້ອໃນອື່ນ."

#. xm5HB
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"hd_id3610644\n"
"help.text"
msgid "The Find & Replace dialog"
msgstr "ກ່ອງໂຕ້ຕອບ ຄົ້ນຫາ ແລະ ແທນທີ່"

#. iACsJ
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id2224494\n"
"help.text"
msgid "Cells can contain text or numbers that were entered directly as in a text document. But cells can also contain text or numbers as the result of a calculation. For example, if a cell contains the formula =1+2 it displays the result 3. You must decide whether to search for the 1 respective 2, or to search the 3."
msgstr "ເຊວສາມາດມີຂໍ້ຄວາມ ຫຼື ຕົວເລກທີ່ປ້ອນໂດຍກົງຄືກັບໃນເອກະສານຂໍ້ຄວາມ. ແຕ່ເຊວຍັງສາມາດມີຂໍ້ຄວາມ ຫຼື ຕົວເລກທີ່ເປັນຜົນມາຈາກການຄຳນວນໄດ້ນຳ. ຕົວຢ່າງ, ຖ້າເຊວມີສູດ =1+2 ມັນຈະສະແດງຜົນໄດ້ຮັບເປັນ 3. ທ່ານຈະຕ້ອງຕັດສິນໃຈວ່າຈະຄົ້ນຫາເລກ 1 ແລະ 2, ຫຼື ຈະຄົ້ນຫາເລກ 3."

#. tbVVd
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"hd_id2423780\n"
"help.text"
msgid "To find formulas or values"
msgstr "ວິທີການຄົ້ນຫາສູດ ຫຼື ຄ່າ"

#. zstCf
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id2569658\n"
"help.text"
msgid "You can specify in the Find & Replace dialog either to find the parts of a formula or the results of a calculation."
msgstr "ທ່ານສາມາດກຳນົດໃນກ່ອງໂຕ້ຕອບ ຄົ້ນຫາ ແລະ ແທນທີ່ ວ່າຈະຄົ້ນຫາສ່ວນຕ່າງໆຂອງສູດ ຫຼື ຜົນໄດ້ຮັບຂອງການຄຳນວນ."

#. C6cDQ
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id6394238\n"
"help.text"
msgid "Choose <emph>Edit - Find & Replace</emph> to open the Find & Replace dialog."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ຄົ້ນຫາ ແລະ ແທນທີ່</emph> ເພື່ອເປີດກ່ອງໂຕ້ຕອບ ຄົ້ນຫາ ແລະ ແທນທີ່."

#. cAUtG
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id7214270\n"
"help.text"
msgid "Click <emph>More Options</emph> to expand the dialog."
msgstr "ຄລິກ <emph>ຕົວເລືອກເພີ່ມເຕີມ</emph> ເພື່ອຂະຫຍາຍກ່ອງໂຕ້ຕອບ."

#. wX8ZD
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id2186346\n"
"help.text"
msgid "Select \"Formulas\" or \"Values\" in the <emph>Search in</emph> list box."
msgstr "ເລືອກ \"ສູດ\" ຫຼື \"ຄ່າ\" ໃນລາຍການເລືອກ <emph>ຄົ້ນຫາໃນ</emph>."

#. nWDYw
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id1331217\n"
"help.text"
msgid "With \"Formulas\" you will find all parts of the formulas."
msgstr "ດ້ວຍຕົວເລືອກ \"ສູດ\" ທ່ານຈະພົບທຸກສ່ວນຂອງສູດ."

#. iERyD
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id393993\n"
"help.text"
msgid "With \"Values\" you will find the results of the calculations."
msgstr "ດ້ວຍ \"ຄ່າ\" ທ່ານຈະພົບເຫັນຜົນຂອງການຄິດໄລ່."

#. FMaXJ
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id3163853\n"
"help.text"
msgid "Cell contents can be formatted in different ways. For example, a number can be formatted as a currency, to be displayed with a currency symbol. These symbols are included in searches when the Formatted Display search option is activated."
msgstr "ເນື້ອໃນຂອງຫ້ອງຕາຕະລາງສາມາດຈັດຮູບແບບໄດ້ຫຼາຍວິທີ. ຕົວຢ່າງ: ຕົວເລກສາມາດຈັດຮູບແບບເປັນສະກຸນເງິນ ເພື່ອໃຫ້ສະແດງພ້ອມກັບເຄື່ອງໝາຍສະກຸນເງິນ. ເຄື່ອງໝາຍເຫຼົ່ານີ້ຈະຖືກລວມເຂົ້າໃນການຊອກຫາ ເມື່ອເປີດໃຊ້ຕົວເລືອກການຊອກຫາ ການສະແດງຜົນທີ່ຈັດຮູບແບບແລ້ວ."

#. Z4ABm
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"hd_id7359233\n"
"help.text"
msgid "Finding text"
msgstr "ການຊອກຫາຂໍ້ຄວາມ"

#. uf8Kc
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id6549272\n"
"help.text"
msgid "Choose <emph>Edit - Find & Replace</emph> to open the Find & Replace dialog."
msgstr "ເລືອກ <emph>ແກ້ໄຂ - ຊອກຫາ & ປ່ຽນແທນ</emph> ເພື່ອເປີດປ່ອງຢ້ຽມ ຊອກຫາ & ປ່ຽນແທນ."

#. 5DY4k
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id6529740\n"
"help.text"
msgid "Enter the text to find in the <emph>Find</emph> text box."
msgstr "ປ້ອນຂໍ້ຄວາມທີ່ຕ້ອງການຊອກຫາລົງໃນຊ່ອງຂໍ້ຄວາມ <emph>ຊອກຫາ</emph>."

#. pMEpA
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id9121982\n"
"help.text"
msgid "Either click <emph>Find Next</emph> or <emph>Find All</emph>."
msgstr "ຄລິກ <emph>ຊອກຫາຕໍ່ໄປ</emph> ຫຼື <emph>ຊອກຫາທັງໝົດ</emph>."

#. E4Qgi
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id3808404\n"
"help.text"
msgid "When you click <emph>Find Next</emph>, Calc will select the next cell that contains your text. You can watch and edit the text, then click <emph>Find Next</emph> again to advance to the next found cell."
msgstr "ເມື່ອທ່ານຄລິກ <emph>ຊອກຫາຕໍ່ໄປ</emph>, Calc ຈະເລືອກຫ້ອງຕາຕະລາງຖັດໄປທີ່ມີຂໍ້ຄວາມຂອງທ່ານ. ທ່ານສາມາດເບິ່ງ ແລະ ແກ້ໄຂຂໍ້ຄວາມ, ຈາກນັ້ນຄລິກ <emph>ຊອກຫາຕໍ່ໄປ</emph> ອີກຄັ້ງເພື່ອໄປຫາຫ້ອງຕາຕະລາງຖັດໄປທີ່ພົບ."

#. TcnxV
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id2394482\n"
"help.text"
msgid "If you closed the dialog, you can press a key combination (<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+F) to find the next cell without opening the dialog."
msgstr "ຖ້າທ່ານປິດປ່ອງຢ້ຽມໄປແລ້ວ, ທ່ານສາມາດກົດປຸ່ມລັດ (<switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline>+Shift+F) ເພື່ອຊອກຫາຫ້ອງຕາຕະລາງຖັດໄປໂດຍບໍ່ຕ້ອງເປີດປ່ອງຢ້ຽມຄືນໃໝ່."

#. r5FfG
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id631733\n"
"help.text"
msgid "By default, Calc searches the current sheet. Check the <emph>All sheets</emph> box to search through all sheets of the document."
msgstr "ໂດຍຄ່າເລີ່ມຕົ້ນ, Calc ຈະຊອກຫາໃນແຜ່ນວຽກປັດຈຸບັນ. ໝາຍຕິກເອົາຊ່ອງ <emph>ທຸກແຜ່ນວຽກ</emph> ເພື່ອຊອກຫາຜ່ານທຸກແຜ່ນວຽກໃນເອກະສານ."

#. ahmfD
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id7811822\n"
"help.text"
msgid "When you click <emph>Find All</emph>, Calc selects all cells that contain your entry. Now you can for example set all found cells to bold, or apply a Cell Style to all at once."
msgstr "ເມື່ອທ່ານຄລິກ <emph>ຊອກຫາທັງໝົດ</emph>, Calc ຈະເລືອກທຸກຫ້ອງຕາຕະລາງທີ່ມີຂໍ້ມູນຂອງທ່ານ. ຕອນນີ້ທ່ານສາມາດກຳນົດໃຫ້ທຸກຫ້ອງທີ່ພົບນັ້ນເປັນຕົວໜາ, ຫຼື ໃຊ້ຮູບແບບຫ້ອງຕາຕະລາງກັບທຸກຫ້ອງພ້ອມກັນໄດ້ເລີຍ."

#. 2DBXW
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"hd_id8531449\n"
"help.text"
msgid "The Navigator"
msgstr "ຕົວນຳທາງ"

#. FFkBL
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id9183935\n"
"help.text"
msgid "Choose <emph>View - Navigator</emph> to open the Navigator window."
msgstr "ເລືອກ <emph>ມຸມມອງ - ຕົວນຳທາງ</emph> ເພື່ອເປີດປ່ອງຢ້ຽມຕົວນຳທາງ."

#. yAdcD
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id946684\n"
"help.text"
msgid "The Navigator is the main tool for finding and selecting objects."
msgstr "ຕົວນຳທາງແມ່ນເຄື່ອງມືຫຼັກສຳລັບການຊອກຫາ ແລະ ເລືອກວັດຖຸ."

#. 4Ezz7
#: finding.xhp
msgctxt ""
"finding.xhp\n"
"par_id9607226\n"
"help.text"
msgid "Use the Navigator for inserting objects and links within the same document or from other open documents."
msgstr "ໃຊ້ຕົວນຳທາງເພື່ອແຊກວັດຖຸ ແລະ ການເຊື່ອມໂຍງພາຍໃນເອກະສານດຽວກັນ ຫຼື ຈາກເອກະສານອື່ນທີ່ເປີດຢູ່."

#. Zg9uE
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"tit\n"
"help.text"
msgid "Formatting Spreadsheets"
msgstr "ການຈັດຮູບແບບແຜ່ນວຽກ"

#. CuVCu
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"bm_id3154125\n"
"help.text"
msgid "<bookmark_value>text in cells; formatting</bookmark_value><bookmark_value>spreadsheets;formatting</bookmark_value><bookmark_value>backgrounds;cells and pages</bookmark_value><bookmark_value>borders;cells and pages</bookmark_value><bookmark_value>formatting;spreadsheets</bookmark_value><bookmark_value>numbers; formatting options for selected cells</bookmark_value><bookmark_value>cells; number formats</bookmark_value><bookmark_value>currencies;formats</bookmark_value>"
msgstr "<bookmark_value>ຂໍ້ຄວາມໃນຫ້ອງຕາຕະລາງ; ການຈັດຮູບແບບ</bookmark_value><bookmark_value>ແຜ່ນວຽກ; ການຈັດຮູບແບບ</bookmark_value><bookmark_value>ພື້ນຫຼັງ; ຫ້ອງຕາຕະລາງ ແລະ ໜ້າ</bookmark_value><bookmark_value>ຂອບ; ຫ້ອງຕາຕະລາງ ແລະ ໜ້າ</bookmark_value><bookmark_value>ການຈັດຮູບແບບ; ແຜ່ນວຽກ</bookmark_value><bookmark_value>ຕົວເລກ; ຕົວເລືອກການຈັດຮູບແບບສຳລັບຫ້ອງທີ່ເລືອກ</bookmark_value><bookmark_value>ຫ້ອງຕາຕະລາງ; ຮູບແບບຕົວເລກ</bookmark_value><bookmark_value>ສະກຸນເງິນ; ຮູບແບບ</bookmark_value>"

#. eurEF
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"hd_id3154125\n"
"help.text"
msgid "<variable id=\"format_table\"><link href=\"text/scalc/guide/format_table.xhp\">Formatting Spreadsheets</link></variable>"
msgstr "<variable id=\"format_table\"><link href=\"text/scalc/guide/format_table.xhp\">ການຈັດຮູບແບບແຜ່ນວຽກ</link></variable>"

#. WMnGx
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"hd_id3153912\n"
"help.text"
msgid "Formatting Text in a Spreadsheet"
msgstr "ການຈັດຮູບແບບຂໍ້ຄວາມໃນແຜ່ນວຽກ"

#. EG9vg
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3144772\n"
"help.text"
msgid "Select the text you want to format."
msgstr "ເລືອກຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການຈັດຮູບແບບ."

#. dcUPy
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3155268\n"
"help.text"
msgid "Choose the desired text attributes from the <emph>Formatting </emph>Bar. You can also choose <emph>Format - Cells</emph>. The <emph>Format Cells</emph> dialog will appear in which you can choose various text attributes on the <emph>Font</emph> tab page."
msgstr "ເລືອກຄຸນລັກສະນະຂໍ້ຄວາມທີ່ຕ້ອງການຈາກແຖບ <emph>ການຈັດຮູບແບບ</emph>. ທ່ານຍັງສາມາດເລືອກ <emph>ຮູບແບບ - ຫ້ອງຕາຕະລາງ</emph>. ປ່ອງຢ້ຽມ <emph>ຈັດຮູບແບບຫ້ອງຕາຕະລາງ</emph> ຈະປາກົດຂຶ້ນ ເຊິ່ງທ່ານສາມາດເລືອກຄຸນລັກສະນະຂໍ້ຄວາມຕ່າງໆໄດ້ໃນແທັບ <emph>ຕົວອັກສອນ</emph>."

#. 5fukM
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"hd_id3149899\n"
"help.text"
msgid "Formatting Numbers in a Spreadsheet"
msgstr "ການຈັດຮູບແບບຕົວເລກໃນແຜ່ນວຽກ"

#. SjM5x
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3159226\n"
"help.text"
msgid "Select the cells containing the numbers you want to format."
msgstr "ເລືອກຫ້ອງຕາຕະລາງທີ່ມີຕົວເລກທີ່ທ່ານຕ້ອງການຈັດຮູບແບບ."

#. 8qkZC
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3150046\n"
"help.text"
msgid "To format numbers in the default currency format or as percentages, use the icons on the <emph>Formatting </emph>Bar. For other formats, choose <emph>Format - Cells</emph>. You can choose from the preset formats or define your own on the <emph>Numbers</emph> tab page."
msgstr "ເພື່ອຈັດຮູບແບບຕົວເລກເປັນສະກຸນເງິນເລີ່ມຕົ້ນ ຫຼື ເປັນເປີເຊັນ, ໃຫ້ໃຊ້ໄອຄອນໃນແຖບ <emph>ການຈັດຮູບແບບ</emph>. ສຳລັບຮູບແບບອື່ນໆ, ໃຫ້ເລືອກ <emph>ຮູບແບບ - ຫ້ອງຕາຕະລາງ</emph>. ທ່ານສາມາດເລືອກຈາກຮູບແບບທີ່ກຳນົດໄວ້ແລ້ວ ຫຼື ກຳນົດເອງໃນແທັບ <emph>ຕົວເລກ</emph>."

#. QxDDZ
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"hd_id3153483\n"
"help.text"
msgid "Formatting Borders and Backgrounds for Cells and Pages"
msgstr "ການຈັດຮູບແບບຂອບ ແລະ ພື້ນຫຼັງສຳລັບຫ້ອງຕາຕະລາງ ແລະ ໜ້າ"

#. PpEbj
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3154733\n"
"help.text"
msgid "You can assign a format to any group of cells by first selecting the cells (for multiple selection, hold down the <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> key when clicking), and then activating the <emph>Format Cells</emph> dialog in <item type=\"menuitem\">Format - Cells</item>. In this dialog, you can select attributes such as shadows and backgrounds."
msgstr "ທ່ານສາມາດກຳນົດຮູບແບບໃຫ້ກັບກຸ່ມຫ້ອງຕາຕະລາງໃດກໍໄດ້ ໂດຍການເລືອກຫ້ອງເຫຼົ່ານັ້ນກ່ອນ (ສຳລັບການເລືອກຫຼາຍບ່ອນ, ໃຫ້ກົດປຸ່ມ <switchinline select=\"sys\"><caseinline select=\"MAC\">Command</caseinline><defaultinline>Ctrl</defaultinline></switchinline> ຄ້າງໄວ້ໃນຂະນະທີ່ຄລິກ), ຈາກນັ້ນເປີດໃຊ້ປ່ອງຢ້ຽມ <emph>ຈັດຮູບແບບຫ້ອງຕາຕະລາງ</emph> ຜ່ານ <item type=\"menuitem\">ຮູບແບບ - ຫ້ອງຕາຕະລາງ</item>. ໃນປ່ອງຢ້ຽມນີ້, ທ່ານສາມາດເລືອກຄຸນລັກສະນະຕ່າງໆເຊັ່ນ ເງົາ ແລະ ພື້ນຫຼັງ."

#. QyNx2
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3145116\n"
"help.text"
msgid "To apply formatting attributes to an entire sheet, choose <emph>Format - Page Style</emph>. You can define headers and footers, for example, to appear on each printed page."
msgstr "ເພື່ອຈັດຮູບແບບໃຫ້ກັບທັງແຜ່ນວຽກ, ໃຫ້ເລືອກ <emph>ຮູບແບບ - ຮູບແບບໜ້າ</emph>. ທ່ານສາມາດກຳນົດສ່ວນຫົວ ແລະ ສ່ວນລຸ່ມຂອງໜ້າ ເພື່ອໃຫ້ສະແດງຢູ່ໃນທຸກໆໜ້າທີ່ພິມອອກມາ."

#. pGcJA
#: format_table.xhp
msgctxt ""
"format_table.xhp\n"
"par_id3145389\n"
"help.text"
msgid "An image that you have loaded with <item type=\"menuitem\">Format - Page Style - Background</item> is only visible in print or in the print preview. To display a background image on screen as well, insert the graphic image by choosing <item type=\"menuitem\">Insert - Image - From File</item> and arrange the image behind the cells by choosing <item type=\"menuitem\">Format - Arrange - To Background</item>. Use the <link href=\"text/shared/01/navigator.xhp\">Navigator</link> to select the background image."
msgstr "ຮູບພາບທີ່ທ່ານໂຫຼດຜ່ານ <item type=\"menuitem\">ຮູບແບບ - ຮູບແບບໜ້າ - ພື້ນຫຼັງ</item> ຈະເຫັນໄດ້ສະເພາະຕອນພິມ ຫຼື ໃນຕົວຢ່າງກ່ອນພິມເທົ່ານັ້ນ. ເພື່ອໃຫ້ເຫັນຮູບພື້ນຫຼັງໃນໜ້າຈໍນຳ, ໃຫ້ແຊກຮູບພາບໂດຍເລືອກ <item type=\"menuitem\">ແຊກ - ຮູບພາບ - ຈາກໄຟລ໌</item> ແລະ ຈັດວາງຮູບພາບໄວ້ທາງຫຼັງຫ້ອງຕາຕະລາງໂດຍເລືອກ <item type=\"menuitem\">ຮູບແບບ - ຈັດລຽງ - ໄວ້ພື້ນຫຼັງ</item>. ໃຊ້ <link href=\"text/shared/01/navigator.xhp\">ຕົວນຳທາງ</link> ເພື່ອເລືອກຮູບພື້ນຫຼັງ."

