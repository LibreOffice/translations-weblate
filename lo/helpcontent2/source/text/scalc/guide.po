"par_idN106AF\n"
"help.text"
msgid "<image id=\"img_id4829822\" src=\"media/helpimg/sheettabs.png\" width=\"3.3335inch\" height=\"0.7638inch\" localize=\"true\"><alt id=\"alt_id4829822\">Sheet Tabs</alt></image>"
