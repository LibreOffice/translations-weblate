msgctxt ""
"csv_files.xhp\n"
"par_idN1090D\n"
"help.text"
msgid "In the <emph>Filter</emph> box, select \"Text CSV\"."
msgstr "ໃນຫ້ອງ <emph>ຕົວຕອງ</emph>, ໃຫ້ເລືອກ \"Text CSV\"."

#. 2JC8V
#: csv_files.xhp
msgctxt ""
"csv_files.xhp\n"
"par_idN107DD\n"
