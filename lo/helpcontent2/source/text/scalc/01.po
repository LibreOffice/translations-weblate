"help.text"
msgid "ROUND"
msgstr "ROUND"

#. dn5Gv
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3158150\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_RUNDEN\">Rounds a number to a certain number of decimal places.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_RUNDEN\">ປັດເສດຕົວເລກໃຫ້ເປັນຈຳນວນຕຳແໜ່ງທົດສະນິຍົມທີ່ກຳນົດ.</ahelp>"

#. kj4B7
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3158182\n"
"help.text"
msgid "ROUND(Number [; Count])"
msgstr "ROUND(Number [; Count])"

#. yE5Jb
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3158196\n"
"help.text"
msgid "Returns <emph>Number</emph> rounded to <emph>Count</emph> decimal places. If Count is omitted or zero, the function rounds to the nearest integer. If Count is negative, the function rounds to the nearest 10, 100, 1000, etc."
msgstr "ສົ່ງຄ່າ <emph>Number</emph> ທີ່ປັດເສດຕາມ <emph>Count</emph> ຕຳແໜ່ງທົດສະນິຍົມ. ຖ້າບໍ່ໃສ່ Count ຫຼື ເປັນສູນ, ຟັງຊັນຈະປັດເປັນຈຳນວນຖ້ວນທີ່ໃກ້ຄຽງທີ່ສຸດ. ຖ້າ Count ເປັນຄ່າລົບ, ຟັງຊັນຈະປັດເປັນຫຼັກສິບ, ຮ້ອຍ, ພັນ, ແລະ ອື່ນໆ ທີ່ໃກ້ຄຽງ."

#. Qy8eM
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id599688\n"
"help.text"
msgid "This function rounds to the nearest number. See ROUNDDOWN and ROUNDUP for alternatives."
msgstr "ຟັງຊັນນີ້ຈະປັດເປັນຕົວເລກທີ່ໃກ້ຄຽງທີ່ສຸດ. ເບິ່ງ ROUNDDOWN ແລະ ROUNDUP ສຳລັບທາງເລືອກອື່ນ."

#. 3JvSm
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3145876\n"
"help.text"
msgid "<item type=\"input\">=ROUND(2.348;2)</item> returns 2.35"
msgstr "<item type=\"input\">=ROUND(2.348;2)</item> ສົ່ງຄ່າຄືນມາແມ່ນ 2.35"

#. Bv7Ae
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3145899\n"
"help.text"
msgid "<item type=\"input\">=ROUND(-32.4834;3)</item> returns -32.483. Change the cell format to see all decimals."
msgstr "<item type=\"input\">=ROUND(-32.4834;3)</item> ສົ່ງຄ່າຄືນມາແມ່ນ -32.483. ປ່ຽນຮູບແບບຫ້ອງຂໍ້ມູນເພື່ອເບິ່ງທົດສະນິຍົມທັງໝົດ."

#. NSuTv
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id1371501\n"
"help.text"
msgid "<item type=\"input\">=ROUND(2.348;0)</item> returns 2."
msgstr "<item type=\"input\">=ROUND(2.348;0)</item> ສົ່ງຄ່າຄືນມາແມ່ນ 2."

#. nqFjA
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id4661702\n"
"help.text"
msgid "<item type=\"input\">=ROUND(2.5)</item> returns 3."
msgstr "<item type=\"input\">=ROUND(2.5)</item> ສົ່ງຄ່າຄືນມາແມ່ນ 3."

#. kdcKK
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id7868892\n"
"help.text"
msgid "<item type=\"input\">=ROUND(987.65;-2)</item> returns 1000."
msgstr "<item type=\"input\">=ROUND(987.65;-2)</item> ສົ່ງຄ່າຄືນມາແມ່ນ 1000."

#. HBbDL
