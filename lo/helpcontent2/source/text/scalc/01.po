"bm_id3147132\n"
"help.text"
msgid "<bookmark_value>TEXT function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ TEXT</bookmark_value>"

#. xpCVP
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"hd_id3147132\n"
"help.text"
msgid "<variable id=\"text_h1\">          <link href=\"text/scalc/01/func_text.xhp\">TEXT</link>        </variable>"
msgstr "<variable id=\"text_h1\">          <link href=\"text/scalc/01/func_text.xhp\">TEXT</link>        </variable>"

#. J9eEh
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3147213\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_TEXT\">Converts a value into text according to a given format.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_TEXT\">ແປງຄ່າໃຫ້ເປັນຂໍ້ຄວາມຕາມຮູບແບບທີ່ກຳນົດ.</ahelp>"

#. MLPFN
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3147377\n"
"help.text"
msgid "TEXT(Value; Format)"
msgstr "TEXT(Value; Format)"

#. G3VHg
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3147389\n"
"help.text"
msgid "<emph>Value</emph> is the value (numerical or textual) to be converted."
msgstr "<emph>Value</emph> ແມ່ນຄ່າ (ຕົວເລກ ຫຼື ຂໍ້ຄວາມ) ທີ່ຈະຖືກແປງ."

#. DMPEj
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3156167\n"
"help.text"
msgid "<emph>Format</emph> is the text which defines the format. Use decimal and thousands separators according to the language set in the cell format."
msgstr "<emph>Format</emph> ແມ່ນຂໍ້ຄວາມທີ່ກຳນົດຮູບແບບ. ໃຫ້ໃຊ້ຕົວຂັ້ນທົດສະນິຍົມ ແລະ ຕົວຂັ້ນຫຼັກພັນ ຕາມພາສາທີ່ຕັ້ງໄວ້ໃນຮູບແບບເຊວ."

#. qLSGr
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id9044770\n"
"help.text"
msgid "<item type=\"input\">=TEXT(12.34567;\"###.##\")</item> returns the text 12.35"
msgstr "<item type=\"input\">=TEXT(12.34567;\"###.##\")</item> ສົ່ງຄືນຂໍ້ຄວາມ 12.35"

#. 4pYR6
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3674123\n"
"help.text"
msgid "<item type=\"input\">=TEXT(12.34567;\"000.00\")</item> returns the text 012.35"
msgstr "<item type=\"input\">=TEXT(12.34567;\"000.00\")</item> ສົ່ງຄືນຂໍ້ຄວາມ 012.35"

#. MhonF
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3674124\n"
"help.text"
msgid "<item type=\"input\">=TEXT(\"xyz\";\"=== @ ===\")</item> returns the text === xyz ==="
msgstr "<item type=\"input\">=TEXT(\"xyz\";\"=== @ ===\")</item> ສົ່ງຄືນຂໍ້ຄວາມ === xyz ==="

#. GCgms
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id3145364\n"
"help.text"
msgid "See also <link href=\"text/shared/01/05020301.xhp\">Number format codes</link>: custom format codes defined by the user."
msgstr "ເບິ່ງເພີ່ມເຕີມ <link href=\"text/shared/01/05020301.xhp\">ລະຫັດຮູບແບບຕົວເລກ</link>: ລະຫັດຮູບແບບກຳນົດເອງໂດຍຜູ້ໃຊ້."

#. 6C9NA
#: func_text.xhp
msgctxt ""
"func_text.xhp\n"
"par_id701677016652715\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TEXT\">TEXT wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TEXT\">ໜ້າ wiki ຂອງ TEXT</link>."

#. dnR6C
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"tit\n"
"help.text"
msgid "TEXTAFTER function"
msgstr "ຟັງຊັນ TEXTAFTER"

#. yXYYE
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"bm_id581556228060864\n"
"help.text"
msgid "<bookmark_value>TEXTAFTER function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ TEXTAFTER</bookmark_value>"

#. rogfF
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"hd_id451747059635188\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/func_textafter.xhp\">TEXTAFTER</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_textafter.xhp\">TEXTAFTER</link></variable>"

#. sj3QA
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id381747059635191\n"
"help.text"
msgid "Returns the text that occurs after a given substring or delimiter."
msgstr "ສົ່ງຄືນຂໍ້ຄວາມທີ່ປາກົດຫຼັງຈາກຂໍ້ຄວາມຍ່ອຍ ຫຼື ຕົວຂັ້ນທີ່ກຳນົດ."

#. sFgek
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id541556228253979\n"
"help.text"
msgid "TEXTAFTER( Text [; Delimiter [; Instance Number [; Match Mode [; Match End [; If Not Found ]]]]])"
msgstr "TEXTAFTER( Text [; Delimiter [; Instance Number [; Match Mode [; Match End [; If Not Found ]]]]])"

#. zZodV
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id91747066169381\n"
"help.text"
msgid "<emph>Text</emph>: the original text."
msgstr "<emph>Text</emph>: ຂໍ້ຄວາມຕົ້ນສະບັບ."

#. zgsKn
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id221747066174430\n"
"help.text"
msgid "<emph>Delimiter</emph>: (optional) the delimiter. Multiple delimiters can be supplied."
msgstr "<emph>Delimiter</emph>: (ທາງເລືອກ) ຕົວຂັ້ນ. ສາມາດລະບຸໄດ້ຫຼາຍຕົວຂັ້ນ."

#. xprDt
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id821747066179393\n"
"help.text"
msgid "<emph>Instance Number</emph>: (optional) the instance of the delimiter after which to extract text. The default is 1. A negative number starts searching from the end."
msgstr "<emph>Instance Number</emph>: (ທາງເລືອກ) ລຳດັບຂອງຕົວຂັ້ນທີ່ຈະເລີ່ມດຶງຂໍ້ຄວາມ. ຄ່າມາດຕະຖານແມ່ນ 1. ຄ່າລົບຈະເລີ່ມຄົ້ນຫາຈາກສ່ວນທ້າຍ."

#. hhUE8
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id121747066183422\n"
"help.text"
msgid "<emph>Match Mode</emph>: (optional) set to 1 to perform a case-insensitive match. The default is 0."
msgstr "<emph>Match Mode</emph>: (ທາງເລືອກ) ຕັ້ງເປັນ 1 ເພື່ອສົມທຽບແບບບໍ່ຈຳແນກຕົວພິມໃຫຍ່-ນ້ອຍ. ຄ່າມາດຕະຖານແມ່ນ 0."

#. CCWDU
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id201747066188182\n"
"help.text"
msgid "<emph>Match End</emph>: (optional) set to 1 to treat the end of text as a delimiter. The default is 0."
msgstr "<emph>Match End</emph>: (ທາງເລືອກ) ຕັ້ງເປັນ 1 ເພື່ອໃຫ້ຖືວ່າສ່ວນທ້າຍຂອງຂໍ້ຄວາມເປັນຕົວຂັ້ນ. ຄ່າມາດຕະຖານແມ່ນ 0."

#. 8sFSe
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id701747066192253\n"
"help.text"
msgid "<emph>If Not Found</emph>: (optional) the value returned if no match is found. The default is #N/A."
msgstr "<emph>If Not Found</emph>: (ທາງເລືອກ) ຄ່າທີ່ຈະສົ່ງຄືນຫາກບໍ່ພົບສິ່ງທີ່ກົງກັນ. ຄ່າມາດຕະຖານແມ່ນ #N/A."

#. 69LCo
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id21747067698384\n"
"help.text"
msgid "<input>=TEXTAFTER(\"To be or not to be\";\"or\";1;0;0;\"@@@\")</input> returns the string \"not to be\", taking after the delimiter \"or\"."
msgstr "<input>=TEXTAFTER(\"To be or not to be\";\"or\";1;0;0;\"@@@\")</input> ສົ່ງຄືນຂໍ້ຄວາມ \"not to be\", ໂດຍດຶງເອົາຫຼັງຕົວຂັ້ນ \"or\"."

#. EaiEG
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id971747068062071\n"
"help.text"
msgid "<input>=TEXTAFTER(\"To be or not to be\";\"question\";1;0;0;\"@@@\")</input> returns the text \"@@@\" because the delimiter \"question\" is not in the source text."
msgstr "<input>=TEXTAFTER(\"To be or not to be\";\"question\";1;0;0;\"@@@\")</input> ສົ່ງຄືນຂໍ້ຄວາມ \"@@@\" ເພາະວ່າບໍ່ມີຕົວຂັ້ນ \"question\" ໃນຂໍ້ຄວາມຕົ້ນທາງ."

#. UfdCm
#: func_textafter.xhp
msgctxt ""
"func_textafter.xhp\n"
"par_id761677014445916\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TEXTAFTER\">TEXTAFTER wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TEXTAFTER\">ໜ້າ wiki ຂອງ TEXTAFTER</link>."

