"par_id2953274\n"
"help.text"
msgid "Z.TEST(Data; mu [; Sigma])"
msgstr "Z.TEST(Data; mu [; Sigma])"

#. 2peSH
#: 04060182.xhp
msgctxt ""
"04060182.xhp\n"
"par_id2956109\n"
"help.text"
msgid "<emph>Data</emph> is the given sample, drawn from a normally distributed population."
msgstr "<emph>Data</emph> ແມ່ນກຸ່ມຕົວຢ່າງທີ່ໃຫ້ມາ, ເຊິ່ງສຸ່ມມາຈາກປະຊາກອນທີ່ມີການແຈກຢາຍແບບປົກກະຕິ."

#. havEd
#: 04060182.xhp
msgctxt ""
"04060182.xhp\n"
"par_id2949977\n"
