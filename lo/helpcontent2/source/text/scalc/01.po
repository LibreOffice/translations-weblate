#. BFATv
#: 04010100.xhp
msgctxt ""
"04010100.xhp\n"
"par_id3149656\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertRowBreak\">Inserts a row break (horizontal page break) above the selected cell.</ahelp>"
msgstr "<ahelp hid=\".uno:InsertRowBreak\">ແຊກການຕັດແຖວ (ການຕັດໜ້າຕາມແນວນອນ) ໄວ້ຂ້າງເທິງເຊວທີ່ເລືອກ.</ahelp>"

#. wwsXX
#: 04010100.xhp
msgctxt ""
"04010100.xhp\n"
"par_id3156422\n"
"help.text"
msgid "The manual row break is indicated by a dark blue horizontal line."
msgstr "ການຕັດແຖວດ້ວຍມືແມ່ນຖືກສະແດງໂດຍເສັ້ນນອນສີຟ້າເຂັ້ມ."

#. GDRiE
