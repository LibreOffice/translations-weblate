"par_id3153698\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_WECHSELN\">Substitutes new text for old text in a string.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_WECHSELN\">ແທນທີ່ຂໍ້ຄວາມເກົ່າດ້ວຍຂໍ້ຄວາມໃໝ່ໃນຂໍ້ຄວາມ.</ahelp>"

#. WKNe6
#: func_substitute.xhp
