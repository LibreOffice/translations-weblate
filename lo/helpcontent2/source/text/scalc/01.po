#. YgfhC
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"hd_id3150685\n"
"help.text"
msgid "<variable id=\"exact_h1\">          <link href=\"text/scalc/01/func_exact.xhp\">EXACT</link>        </variable>"
msgstr "<variable id=\"exact_h1\">          <link href=\"text/scalc/01/func_exact.xhp\">EXACT</link>        </variable>"

#. kGvM7
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"par_id3158413\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_IDENTISCH\">Compares two text strings and returns TRUE if they are identical.</ahelp> This function is case-sensitive."
msgstr "<ahelp hid=\"HID_FUNC_IDENTISCH\">ປຽບທຽບຂໍ້ຄວາມສອງຊຸດ ແລະ ສົ່ງຄືນຄ່າ TRUE ຖ້າພວກມັນຄືກັນທຸກປະການ.</ahelp> ຟັງຊັນນີ້ຈະແຍກຕົວອັກສອນນ້ອຍ-ໃຫຍ່."

#. Ba7M2
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"par_id3148594\n"
"help.text"
msgid "EXACT(\"Text1\"; \"Text2\")"
msgstr "EXACT(\"ຂໍ້ຄວາມ1\"; \"ຂໍ້ຄວາມ2\")"

#. 7kKd4
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"par_id3153224\n"
"help.text"
msgid "<emph>Text1</emph> refers to the first text to compare."
msgstr "<emph>ຂໍ້ຄວາມ1</emph> ແມ່ນຂໍ້ຄວາມທຳອິດທີ່ຈະປຽບທຽບ."

#. 37PQt
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"par_id3148637\n"
"help.text"
msgid "<emph>Text2</emph> is the second text to compare."
msgstr "<emph>ຂໍ້ຄວາມ2</emph> ແມ່ນຂໍ້ຄວາມທີສອງທີ່ຈະປຽບທຽບ."

#. DPfsN
#: func_exact.xhp
msgctxt ""
"func_exact.xhp\n"
"par_id3156263\n"
"help.text"
msgid "<item type=\"input\">=EXACT(\"microsystems\";\"Microsystems\")</item> returns FALSE."
msgstr "<item type=\"input\">=EXACT(\"microsystems\";\"Microsystems\")</item> ສົ່ງຄືນ FALSE."

#. Aa6eC
#: func_exact.xhp
msgctxt ""
