msgstr "<variable id=\"h1\"><variable id=\"format cells\"><link href=\"text/scalc/01/05020000.xhp\">ຮູບແບບຫ້ອງ</link></variable></variable>"

#. Erm44
#: 05020000.xhp
msgctxt ""
"05020000.xhp\n"
"par_id3150448\n"
"help.text"
msgid "<variable id=\"zellattributetext\"><ahelp hid=\".uno:FormatCellDialog\">Allows you to specify a variety of formatting options and to apply attributes to the selected cells.</ahelp></variable>"
msgstr "<variable id=\"zellattributetext\"><ahelp hid=\".uno:FormatCellDialog\">ອະນຸຍາດໃຫ້ທ່ານລະບຸຕົວເລືອກການຈັດຮູບແບບທີ່ຫຼາກຫຼາຍ ແລະ ນຳໃຊ້ຄຸນລັກສະນະໃຫ້ກັບຫ້ອງທີ່ເລືອກ.</ahelp></variable>"

#. BW9bs
