#. iuVDY
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"bm_id3150791\n"
"help.text"
msgid "<bookmark_value>sheets; defining label ranges</bookmark_value><bookmark_value>label ranges in sheets</bookmark_value>"
msgstr "<bookmark_value>ແຜ່ນງານ; ການກຳນົດຊ່ວງປ້າຍຊື່</bookmark_value><bookmark_value>ຊ່ວງປ້າຍຊື່ໃນແຜ່ນງານ</bookmark_value>"

#. WgBoC
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3150791\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/04070400.xhp\">Define Label Range</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/04070400.xhp\">ກຳນົດຊ່ວງປ້າຍຊື່</link></variable>"

#. sTpBB
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3150868\n"
"help.text"
msgid "<variable id=\"beschtext\"><ahelp hid=\".uno:DefineLabelRange\">Opens a dialog in which you can define a label range.</ahelp></variable>"
msgstr "<variable id=\"beschtext\"><ahelp hid=\".uno:DefineLabelRange\">ເປີດກ່ອງໂຕ້ຕອບທີ່ທ່ານສາມາດກຳນົດຊ່ວງປ້າຍຊື່ໄດ້.</ahelp></variable>"

#. 5KVaz
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3155411\n"
"help.text"
msgid "The cell contents of a label range can be used like names in formulas - $[officename] recognizes these names in the same manner that it does the predefined names of the weekdays and months. These names are automatically completed when typed into a formula. In addition, the names defined by label ranges will have priority over names defined by automatically generated ranges."
msgstr "ເນື້ອໃນຫ້ອງຂອງຊ່ວງປ້າຍຊື່ສາມາດຖືກໃຊ້ຄືກັບຊື່ໃນສູດ - $[officename] ຈະຮັບຮູ້ຊື່ເຫຼົ່ານີ້ໃນຮູບແບບດຽວກັບຊື່ທີ່ກຳນົດໄວ້ລ່ວງໜ້າຂອງມື້ໃນອາທິດ ແລະ ເດືອນ. ຊື່ເຫຼົ່ານີ້ຈະຖືກຕື່ມໃຫ້ອັດຕະໂນມັດເມື່ອພິມລົງໃນສູດ. ນອກຈາກນັ້ນ, ຊື່ທີ່ກຳນົດໂດຍຊ່ວງປ້າຍຊື່ຈະມີລຳດັບຄວາມສຳຄັນສູງກວ່າຊື່ທີ່ກຳນົດໂດຍຊ່ວງທີ່ສ້າງຂຶ້ນໂດຍອັດຕະໂນມັດ."

#. zUV9n
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3147435\n"
"help.text"
msgid "You can set label ranges that contain the same labels on different sheets. $[officename] first searches the label ranges of the current sheet and, following a failed search, the ranges of other sheets."
msgstr "ທ່ານສາມາດຕັ້ງຊ່ວງປ້າຍຊື່ທີ່ມີປ້າຍຊື່ດຽວກັນໃນຊີດທີ່ແຕກຕ່າງກັນໄດ້. $[officename] ຈະຄົ້ນຫາຊ່ວງປ້າຍຊື່ຂອງຊີດປັດຈຸບັນກ່ອນ ແລະ ຖ້າຄົ້ນຫາບໍ່ພົບ, ມັນຈະໄປຄົ້ນຫາໃນຊ່ວງຂອງຊີດອື່ນໆ."

#. BVyD4
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3145801\n"
"help.text"
msgid "Range"
msgstr "ຊ່ວງ"

#. EpVti
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3154731\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/namerangesdialog/edassign\">Displays the cell reference of each label range.</ahelp> In order to remove a label range from the list box, select it and then click <emph>Delete</emph>."
msgstr "<ahelp hid=\"modules/scalc/ui/namerangesdialog/edassign\">ສະແດງການອ້າງອີງຫ້ອງຂອງແຕ່ລະຊ່ວງປ້າຍຊື່.</ahelp> ເພື່ອລົບຊ່ວງປ້າຍຊື່ອອກຈາກລາຍການ, ໃຫ້ເລືອກມັນແລ້ວຄລິກ <emph>ລົບ</emph>."

#. X5AEH
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3149121\n"
"help.text"
msgid "Contains column labels"
msgstr "ມີປ້າຍຊື່ຖັນ"

#. DxBAW
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3150330\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/namerangesdialog/colhead\">Includes column labels in the current label range.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/namerangesdialog/colhead\">ຮວມເອົາປ້າຍຊື່ຖັນເຂົ້າໃນຊ່ວງປ້າຍຊື່ປັດຈຸບັນ.</ahelp>"

#. FCaRd
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3149020\n"
"help.text"
msgid "Contains row labels"
msgstr "ມີປ້າຍຊື່ແຖວ"

#. nCXH5
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3154754\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/namerangesdialog/rowhead\">Includes row labels in the current label range.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/namerangesdialog/rowhead\">ຮວມເອົາປ້າຍຊື່ແຖວເຂົ້າໃນຊ່ວງປ້າຍຊື່ປັດຈຸບັນ.</ahelp>"

#. 6owcC
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3159264\n"
"help.text"
msgid "For data range"
msgstr "ສຳລັບຊ່ວງຂໍ້ມູນ"

#. uPMTB
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3154703\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/namerangesdialog/edassign2\">Sets the data range for which the selected label range is valid. To modify it, click in the sheet and select another range with the mouse.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/namerangesdialog/edassign2\">ກຳນົດຊ່ວງຂໍ້ມູນທີ່ຊ່ວງປ້າຍຊື່ທີ່ເລືອກສາມາດໃຊ້ໄດ້. ເພື່ອແກ້ໄຂມັນ, ໃຫ້ຄລິກໃນຊີດ ແລະ ເລືອກຊ່ວງອື່ນດ້ວຍເມົາສ໌.</ahelp>"

#. JYFUv
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"hd_id3145789\n"
"help.text"
msgid "Add"
msgstr "ເພີ່ມ"

#. 8FenH
#: 04070400.xhp
msgctxt ""
"04070400.xhp\n"
"par_id3147005\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/namerangesdialog/add\">Adds the current label range to the list.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/namerangesdialog/add\">ເພີ່ມຊ່ວງປ້າຍຊື່ປັດຈຸບັນເຂົ້າໃນລາຍການ.</ahelp>"

#. sEQ86
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"tit\n"
"help.text"
msgid "Function List"
msgstr "ລາຍການຟັງຊັນ"

#. MLdGA
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"bm_id3154126\n"
"help.text"
msgid "<bookmark_value>formula list window</bookmark_value>  <bookmark_value>function list window</bookmark_value>  <bookmark_value>inserting functions; function list window</bookmark_value>"
msgstr "<bookmark_value>ວິນໂດລາຍການສູດ</bookmark_value>  <bookmark_value>ວິນໂດລາຍການຟັງຊັນ</bookmark_value>  <bookmark_value>ການແຊກຟັງຊັນ; ວິນໂດລາຍການຟັງຊັນ</bookmark_value>"

#. A28i9
