msgid "Day"
msgstr "ວັນ"

#. RAR4M
#: 02140600.xhp
msgctxt ""
"02140600.xhp\n"
"par_id3148605\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/filldlg/day\">Use the <emph>Date</emph> series type and this option to create a series using all seven days of the week. Unit of <emph>Increment</emph> is day.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/filldlg/day\">ໃຊ້ປະເພດລຳດັບ <emph>ວັນທີ</emph> ແລະ ຕົວເລືອກນີ້ເພື່ອສ້າງລຳດັບໂດຍໃຊ້ທັງເຈັດວັນຂອງອາທິດ. ຫົວໜ່ວຍຂອງ <emph>ຄ່າເພີ່ມ</emph> ແມ່ນ ວັນ.</ahelp>"

#. ErCjH
#: 02140600.xhp
msgctxt ""
"02140600.xhp\n"
"hd_id3144771\n"
"help.text"
msgid "Weekday"
msgstr "ວັນເຮັດວຽກ"

#. HEHGu
