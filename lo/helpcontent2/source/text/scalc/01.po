msgid "<variable id=\"h1\"><link href=\"text/scalc/01/func_wrapcols.xhp\">WRAPCOLS</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_wrapcols.xhp\">WRAPCOLS</link></variable>"

#. 8VCWa
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Converts a single row or column into multiple columns (a 2-dimensional array) by specifying the number of values in each column."
msgstr "ແປງແຖວດຽວ ຫຼື ຖັນດຽວ ໃຫ້ເປັນຫຼາຍຖັນ (ອາເຣ 2 ມິຕິ) ໂດຍການລະບຸຈຳນວນຄ່າໃນແຕ່ລະຖັນ."

#. dCbBM
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id871737825179033\n"
"help.text"
msgid "=WRAPCOLS(Range; Wrap_count [; Pad_with])"
msgstr "=WRAPCOLS(Range; Wrap_count [; Pad_with])"

#. pnet5
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id701737825446850\n"
"help.text"
msgid "<emph>Range</emph>: the range to wrap."
msgstr "<emph>Range</emph>: ຊ່ວງທີ່ຈະນຳມາຫໍ່."

#. A5fZc
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id441737825452403\n"
"help.text"
msgid "<emph>Wrap_count</emph>: the maximum number of values in each column."
msgstr "<emph>Wrap_count</emph>: ຈຳນວນຄ່າສູງສຸດໃນແຕ່ລະຖັນ."

#. c2Mue
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id411737825456380\n"
"help.text"
msgid "<emph>Pad_with</emph>: (optional) a specified value to pad if there are insufficient number of values. By default, it returns #N/A to fill in the cells."
msgstr "<emph>Pad_with</emph>: (ທາງເລືອກ) ຄ່າທີ່ລະບຸເພື່ອຕື່ມໃສ່ຫາກມີຈຳນວນຄ່າບໍ່ພຽງພໍ. ໂດຍມາດຕະຖານແລ້ວ ມັນຈະສົ່ງຄືນ #N/A ເພື່ອຕື່ມໃສ່ໃນເຊວ."

#. eAMgY
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id771738021783517\n"
"help.text"
msgid "The formula <input>{=WRAPCOLS(A1:A15;6)}</input>  returns the array below. The missing values are replaced by #N/A."
msgstr "ສູດ <input>{=WRAPCOLS(A1:A15;6)}</input> ສົ່ງຄືນອາເຣດ້ານລຸ່ມ. ຄ່າທີ່ຂາດຫາຍໄປຈະຖືກແທນທີ່ດ້ວຍ #N/A."

#. gt3gw
#: func_wrapcols.xhp
msgctxt ""
"func_wrapcols.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/WRAPCOLS\">WRAPCOLS wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/WRAPCOLS\">ໜ້າ wiki ຂອງ WRAPCOLS</link>."

