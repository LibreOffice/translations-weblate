msgstr "%PRODUCTNAME ໃຫ້ຜົນໄດ້ຮັບເປັນ 0 ສຳລັບ ATAN2(0;0)."

#. BCKQE
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id5036169\n"
"help.text"
msgid "The function can be used in converting cartesian coordinates to polar coordinates."
msgstr "ຟັງຊັນນີ້ສາມາດໃຊ້ໃນການແປງພິກັດສາກ (cartesian) ເປັນພິກັດຂົ້ວ (polar)."

#. dtCje
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id5036170\n"
"help.text"
msgid "=DEGREES(ATAN2(-8;5)) returns φ =  147.9 degrees"
msgstr "=DEGREES(ATAN2(-8;5)) ສົ່ງຄືນ φ = 147.9 ອົງສາ"

#. hN94X
#: 04060106.xhp
