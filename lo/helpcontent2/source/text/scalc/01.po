msgctxt ""
"05120100.xhp\n"
"par_id831662914760085\n"
"help.text"
msgid "is not equal to"
msgstr "ບໍ່ເທົ່າກັບ"

#. T8x2N
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id301662914760087\n"
"help.text"
msgid "The cell value is not equal (different) to the user defined value in the text box in the right. Use text inside quotes if you compare text values."
msgstr "ຄ່າໃນຫ້ອງບໍ່ເທົ່າກັບ (ແຕກຕ່າງຈາກ) ຄ່າທີ່ຜູ້ໃຊ້ກຳນົດໃນຊ່ອງຂໍ້ຄວາມເບື້ອງຂວາ. ໃຊ້ຂໍ້ຄວາມພາຍໃນເຄື່ອງໝາຍຄຳເວົ້າ ຖ້າທ່ານປຽບທຽບຄ່າຂໍ້ຄວາມ."

