"help.text"
msgid "Formulas"
msgstr "ສູດ"

#. FSnPJ
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"par_id3148485\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecontents/formulas\">Deletes formulas. Text, numbers, formats, dates and times remain unchanged.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecontents/formulas\">ລຶບສູດ. ຂໍ້ຄວາມ, ຕົວເລກ, ຮູບແບບ, ວັນທີ ແລະ ເວລາຍັງຄືເກົ່າ.</ahelp>"

#. aauBW
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"hd_id3150300\n"
"help.text"
msgid "Comments"
msgstr "ຄຳເຫັນ"

#. 2mmCa
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"par_id3154658\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecontents/comments\">Deletes comments added to cells. All other elements remain unchanged.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecontents/comments\">ລຶບຄຳເຫັນທີ່ເພີ່ມໃສ່ເຊວ. ອົງປະກອບອື່ນໆທັງໝົດຍັງຄືເກົ່າ.</ahelp>"

#. RVABB
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"hd_id3155112\n"
"help.text"
msgid "Formats"
msgstr "ຮູບແບບ"

#. 4xCSY
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"par_id3146134\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecontents/formats\">Deletes format attributes applied to cells. All cell content remains unchanged.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecontents/formats\">ລຶບຄຸນລັກສະນະຮູບແບບທີ່ໃຊ້ກັບເຊວ. ເນື້ອໃນເຊວທັງໝົດຍັງຄືເກົ່າ.</ahelp>"

#. 5E6kE
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"hd_id3150088\n"
"help.text"
msgid "Objects"
msgstr "ວັດຖຸ"

#. X9oHZ
#: 02150000.xhp
msgctxt ""
"02150000.xhp\n"
"par_id3152990\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecontents/objects\">Deletes objects. All cell content remains unchanged.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecontents/objects\">ລຶບວັດຖຸ. ເນື້ອໃນເຊວທັງໝົດຍັງຄືເກົ່າ.</ahelp>"

#. v6DRE
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"tit\n"
"help.text"
msgid "Delete Cells"
msgstr "ລຶບເຊວ"

#. MnNVa
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"bm_id3153726\n"
"help.text"
msgid "<bookmark_value>cells; deleting cells</bookmark_value><bookmark_value>columns; deleting</bookmark_value><bookmark_value>rows; deleting</bookmark_value><bookmark_value>spreadsheets; deleting cells</bookmark_value><bookmark_value>deleting;cells/rows/columns</bookmark_value>"
msgstr "<bookmark_value>ເຊວ; ການລຶບເຊວ</bookmark_value><bookmark_value>ຖັນ; ການລຶບ</bookmark_value><bookmark_value>ແຖວ; ການລຶບ</bookmark_value><bookmark_value>ສະເປຣດຊີດ; ການລຶບເຊວ</bookmark_value><bookmark_value>ການລຶບ; ເຊວ/ແຖວ/ຖັນ</bookmark_value>"

#. HFRGE
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3153726\n"
"help.text"
msgid "<link href=\"text/scalc/01/02160000.xhp\">Delete Cells</link>"
msgstr "<link href=\"text/scalc/01/02160000.xhp\">ລຶບເຊວ</link>"

#. 5FoZA
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3154490\n"
"help.text"
msgid "<variable id=\"zellenloeschentext\"><ahelp hid=\".uno:DeleteCell\">Completely deletes selected cells, columns or rows. The cells below or to the right of the deleted cells will fill the space.</ahelp></variable> Note that the selected delete option is stored and reloaded when the dialog is next called."
msgstr "<variable id=\"zellenloeschentext\"><ahelp hid=\".uno:DeleteCell\">ລຶບເຊວ, ຖັນ ຫຼື ແຖວ ທີ່ເລືອກອອກທັງໝົດ. ເຊວທີ່ຢູ່ລຸ່ມ ຫຼື ທາງຂວາຂອງເຊວທີ່ລຶບອອກຈະຕື່ມໃສ່ບ່ອນວ່າງ.</ahelp></variable> ໝາຍເຫດວ່າຕົວເລືອກການລຶບທີ່ເລືອກຈະຖືກເກັບໄວ້ ແລະ ໂຫຼດຄືນໃໝ່ເມື່ອມີການເອີ້ນກ່ອງໂຕ້ຕອບຄັ້ງຕໍ່ໄປ."

#. X7sNR
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3149121\n"
"help.text"
msgid "Selection"
msgstr "ສິ່ງທີ່ເລືອກ"

#. HcQak
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3150751\n"
"help.text"
msgid "This area contains options for specifying how sheets are displayed after deleting cells."
msgstr "ເຂດນີ້ປະກອບດ້ວຍຕົວເລືອກສຳລັບກຳນົດວິທີການສະແດງແຜ່ນງານຫຼັງຈາກລຶບເຊວ."

#. 6eeoi
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3155767\n"
"help.text"
msgid "Shift cells up"
msgstr "ຍ້າຍເຊວຂຶ້ນ"

#. 59eSg
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3153714\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecells/up\">Fills the space produced by the deleted cells with the cells underneath it.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecells/up\">ຕື່ມບ່ອນວ່າງທີ່ເກີດຈາກການລຶບເຊວດ້ວຍເຊວທີ່ຢູ່ລຸ່ມມັນ.</ahelp>"

#. dTPCu
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3156382\n"
"help.text"
msgid "Shift cells left"
msgstr "ຍ້າຍເຊວໄປທາງຊ້າຍ"

#. vH52J
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3154702\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecells/left\">Fills the resulting space by the cells to the right of the deleted cells.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/deletecells/left\">ຕື່ມບ່ອນວ່າງທີ່ເກີດຂຶ້ນດ້ວຍເຊວທີ່ຢູ່ທາງຂວາຂອງເຊວທີ່ລຶບອອກ.</ahelp>"

#. yVEjf
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3146918\n"
"help.text"
msgid "Delete entire row(s)"
msgstr "ລຶບແຖວທັງໝົດ"

#. qxGEH
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3148487\n"
"help.text"
msgid "<ahelp hid=\".uno:DeleteRows\">After selecting at least one cell, deletes the entire row from the sheet.</ahelp>"
msgstr "<ahelp hid=\".uno:DeleteRows\">ຫຼັງຈາກເລືອກຢ່າງໜ້ອຍໜຶ່ງເຊວ, ໃຫ້ລຶບແຖວທັງໝົດອອກຈາກແຜ່ນງານ.</ahelp>"

#. xiEta
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id581702131982105\n"
"help.text"
msgid "This command is equivalent to <embedvar href=\"text/shared/01/DeleteRows.xhp#h1\" markup=\"ignore\"/>."
msgstr "ຄຳສັ່ງນີ້ເທົ່າກັບ <embedvar href=\"text/shared/01/DeleteRows.xhp#h1\" markup=\"ignore\"/>."

#. HFAFf
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"hd_id3155114\n"
"help.text"
msgid "Delete entire column(s)"
msgstr "ລຶບຖັນທັງໝົດ"

#. DpjXh
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3150086\n"
"help.text"
msgid "<ahelp hid=\".uno:DeleteColumns\">After selecting at least one cell, deletes the entire column from the sheet.</ahelp>"
msgstr "<ahelp hid=\".uno:DeleteColumns\">ຫຼັງຈາກເລືອກຢ່າງໜ້ອຍໜຶ່ງເຊວ, ໃຫ້ລຶບຖັນທັງໝົດອອກຈາກແຜ່ນງານ.</ahelp>"

#. REhw6
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id311702131990711\n"
"help.text"
msgid "This command is equivalent to <embedvar href=\"text/shared/01/DeleteColumns.xhp#h1\" markup=\"ignore\"/>."
msgstr "ຄຳສັ່ງນີ້ເທົ່າກັບ <embedvar href=\"text/shared/01/DeleteColumns.xhp#h1\" markup=\"ignore\"/>."

#. 727Hj
#: 02160000.xhp
msgctxt ""
"02160000.xhp\n"
"par_id3166424\n"
"help.text"
msgid "<link href=\"text/scalc/01/02150000.xhp\">Deleting Contents</link>"
msgstr "<link href=\"text/scalc/01/02150000.xhp\">ການລຶບເນື້ອໃນ</link>"

#. Ms7fx
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"tit\n"
"help.text"
msgid "Delete Sheet"
msgstr "ລຶບແຜ່ນງານ"

#. xtKqU
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"bm_id3156424\n"
"help.text"
msgid "<bookmark_value>spreadsheets; deleting</bookmark_value><bookmark_value>sheets; deleting</bookmark_value><bookmark_value>deleting; spreadsheets</bookmark_value>"
msgstr "<bookmark_value>ສະເປຣດຊີດ; ການລຶບ</bookmark_value><bookmark_value>ແຜ່ນງານ; ການລຶບ</bookmark_value><bookmark_value>ການລຶບ; ສະເປຣດຊີດ</bookmark_value>"

#. LUaVy
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"hd_id3156424\n"
"help.text"
msgid "<variable id=\"delete_sheet\"><link href=\"text/scalc/01/02170000.xhp#deletesheet\">Delete Sheet</link></variable>"
msgstr "<variable id=\"delete_sheet\"><link href=\"text/scalc/01/02170000.xhp#deletesheet\">ລຶບແຜ່ນງານ</link></variable>"

#. b3pJB
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3153193\n"
"help.text"
msgid "<variable id=\"tabelleloeschentext\"><ahelp hid=\".uno:Remove\">Deletes the current sheet or selected sheets.</ahelp></variable>"
msgstr "<variable id=\"tabelleloeschentext\"><ahelp hid=\".uno:Remove\">ລຶບແຜ່ນງານປັດຈຸບັນ ຫຼື ແຜ່ນງານທີ່ເລືອກ.</ahelp></variable>"

#. 6JJp6
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id3145801\n"
"help.text"
msgid "You cannot delete a sheet while <emph>Edit - Track Changes - Record</emph> is activated."
msgstr "ທ່ານບໍ່ສາມາດລຶບແຜ່ນງານໃນຂະນະທີ່ <emph>ແກ້ໄຂ - ຕິດຕາມການປ່ຽນແປງ - ບັນທຶກ</emph> ຖືກເປີດໃຊ້ງານຢູ່."

#. 3NVjP
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id921684957633412\n"
"help.text"
msgid "You cannot delete all the sheets of the document. The document must have at least one sheet."
msgstr "ທ່ານບໍ່ສາມາດລຶບແຜ່ນງານທັງໝົດຂອງເອກະສານໄດ້. ເອກະສານຕ້ອງມີຢ່າງໜ້ອຍໜຶ່ງແຜ່ນງານ."

#. TfEAD
#: 02170000.xhp
msgctxt ""
"02170000.xhp\n"
"par_id691684957638352\n"
"help.text"
msgid "A dialog prompts to confirm deletion."
msgstr "ກ່ອງໂຕ້ຕອບຈະປາກົດຂຶ້ນເພື່ອຢືນຢັນການລຶບ."

#. k9Be9
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"tit\n"
"help.text"
msgid "Move or Copy a Sheet"
msgstr "ຍ້າຍ ຫຼື ສຳເນົາແຜ່ນງານ"

#. oozF5
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"bm_id3153360\n"
"help.text"
msgid "<bookmark_value>spreadsheets; moving</bookmark_value><bookmark_value>spreadsheets; copying</bookmark_value><bookmark_value>moving; spreadsheets</bookmark_value><bookmark_value>copying; spreadsheets</bookmark_value>"
msgstr "<bookmark_value>ສະເປຣດຊີດ; ການຍ້າຍ</bookmark_value><bookmark_value>ສະເປຣດຊີດ; ການສຳເນົາ</bookmark_value><bookmark_value>ການຍ້າຍ; ສະເປຣດຊີດ</bookmark_value><bookmark_value>ການສຳເນົາ; ສະເປຣດຊີດ</bookmark_value>"

#. ytArs
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"hd_id3153360\n"
"help.text"
msgid "<variable id=\"movecopy_sheet\"><link href=\"text/scalc/01/02180000.xhp\">Move or Copy a Sheet</link></variable>"
msgstr "<variable id=\"movecopy_sheet\"><link href=\"text/scalc/01/02180000.xhp\">ຍ້າຍ ຫຼື ສຳເນົາແຜ່ນງານ</link></variable>"

#. Rv8oA
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id3154686\n"
"help.text"
msgid "<variable id=\"tabelleverschiebenkopierentext\"><ahelp hid=\".uno:Move\">Moves or copies a sheet to a new location in the document or to a different document.</ahelp></variable>"
msgstr "<variable id=\"tabelleverschiebenkopierentext\"><ahelp hid=\".uno:Move\">ຍ້າຍ ຫຼື ສຳເນົາແຜ່ນງານໄປຫາຕຳແໜ່ງໃໝ່ໃນເອກະສານ ຫຼື ໄປຫາເອກະສານອື່ນ.</ahelp></variable>"

#. Nk5XZ
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id2282479\n"
"help.text"
msgid "When you copy and paste cells containing <link href=\"text/scalc/01/04060102.xhp\">date values</link> between different spreadsheets, both spreadsheet documents must be set to the same date base. If date bases differ, the displayed date values will change!"
msgstr "ເມື່ອທ່ານສຳເນົາ ແລະ ວາງເຊວທີ່ມີ <link href=\"text/scalc/01/04060102.xhp\">ຄ່າວັນທີ</link> ລະຫວ່າງສະເປຣດຊີດທີ່ແຕກຕ່າງກັນ, ທັງສອງເອກະສານສະເປຣດຊີດຕ້ອງຖືກຕັ້ງເປັນຖານວັນທີດຽວກັນ. ຖ້າຖານວັນທີແຕກຕ່າງກັນ, ຄ່າວັນທີທີ່ສະແດງຈະປ່ຽນແປງ!"

#. GHQ6R
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id3720376688484858\n"
"help.text"
msgid "When the <link href=\"text/shared/01/02230100.xhp\"><menuitem>Record Changes</menuitem></link> command is active, you cannot delete or move sheets."
msgstr "ເມື່ອຄຳສັ່ງ <link href=\"text/shared/01/02230100.xhp\"><menuitem>ບັນທຶກການປ່ຽນແປງ</menuitem></link> ເປີດໃຊ້ງານຢູ່, ທ່ານບໍ່ສາມາດລຶບ ຫຼື ຍ້າຍແຜ່ນງານໄດ້."

#. 3DmMC
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"hd_id3163710\n"
"help.text"
msgid "To Document"
msgstr "ໄປຫາເອກະສານ"

#. ayVi2
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id3148645\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/movecopysheet/toDocument\">Indicates where the current sheet is to be moved or copied to.</ahelp> Select <emph>- new document -</emph> if you want to create a new location for the sheet to be moved or copied."
msgstr "<ahelp hid=\"modules/scalc/ui/movecopysheet/toDocument\">ບົ່ງບອກບ່ອນທີ່ແຜ່ນງານປັດຈຸບັນຈະຖືກຍ້າຍ ຫຼື ສຳເນົາໄປຫາ.</ahelp> ເລືອກ <emph>- ເອກະສານໃໝ່ -</emph> ຖ້າທ່ານຕ້ອງການສ້າງຕຳແໜ່ງໃໝ່ສຳລັບແຜ່ນງານທີ່ຈະຖືກຍ້າຍ ຫຼື ສຳເນົາ."

#. zPGQF
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"hd_id3154012\n"
"help.text"
msgid "Insert Before"
msgstr "ແຊກກ່ອນ"

#. 3FSME
#: 02180000.xhp
msgctxt ""
"02180000.xhp\n"
"par_id3145366\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/movecopysheet/insertBefore\">The current sheet is moved or copied in front of the selected sheet.</ahelp> The <emph>- move to end position -</emph> option places the current sheet at the end."
msgstr "<ahelp hid=\"modules/scalc/ui/movecopysheet/insertBefore\">ແຜ່ນງານປັດຈຸບັນຈະຖືກຍ້າຍ ຫຼື ສຳເນົາໄປໄວ້ທາງໜ້າຂອງແຜ່ນງານທີ່ເລືອກ.</ahelp> ຕົວເລືອກ <emph>- ຍ້າຍໄປຕຳແໜ່ງທ້າຍສຸດ -</emph> ຈະວາງແຜ່ນງານປັດຈຸບັນໄວ້ທີ່ຕອນທ້າຍ."

#. WNaqP
