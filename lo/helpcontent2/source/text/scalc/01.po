msgctxt ""
"func_asc.xhp\n"
"par_id701542231253817\n"
"help.text"
msgid "<input>ASC(Text)</input>"
msgstr "<input>ASC(Text)</input>"

#. npFEH
#: func_asc.xhp
msgctxt ""
"func_asc.xhp\n"
"par_id621542232197446\n"
"help.text"
msgid "<emph>Text</emph>: the text string that contains characters to be converted."
msgstr "<emph>Text</emph>: ສາຍຂໍ້ຄວາມທີ່ມີຕົວອັກສອນທີ່ຕ້ອງການແປງ."

#. d9fM4
#: func_asc.xhp
msgctxt ""
"func_asc.xhp\n"
"par_id481637763523789\n"
"help.text"
msgid "Applying the ASC function to a string composed of single-byte characters will return the input string without any modifications."
msgstr "ການນຳໃຊ້ຟັງຊັນ ASC ກັບຂໍ້ຄວາມທີ່ປະກອບດ້ວຍຕົວອັກສອນແບບຊິງເກິນໄບຕ໌ ຈະສົ່ງຄືນຂໍ້ຄວາມເດີມໂດຍບໍ່ມີການປ່ຽນແປງໃດໆ."

#. QXBHB
#: func_asc.xhp
msgctxt ""
"func_asc.xhp\n"
"par_id451628776707264\n"
"help.text"
msgid "<input>=ASC(\"LibreOffice\")</input> returns the string \"LibreOffice\". No modifications were made because all characters are single-byte characters."
msgstr "<input>=ASC(\"LibreOffice\")</input> ສົ່ງຄືນ \"LibreOffice\". ບໍ່ມີການປ່ຽນແປງຍ້ອນວ່າຕົວອັກສອນທັງໝົດເປັນແບບຊິງເກິນໄບຕ໌ແລ້ວ."

#. f8rff
#: func_asc.xhp
msgctxt ""
"func_asc.xhp\n"
"par_id101628778036375\n"
"help.text"
msgid "<input>=ASC(\"ライト\")</input> returns the string \"ﾗｲﾄ\", which is composed of single-byte characters."
msgstr "<input>=ASC(\"ライト\")</input> ສົ່ງຄືນ \"ﾗｲﾄ\", ເຊິ່ງປະກອບດ້ວຍຕົວອັກສອນແບບຊິງເກິນໄບຕ໌."

