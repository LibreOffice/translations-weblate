"par_idN106EC\n"
"help.text"
msgid "More"
msgstr "ເພີ່ມເຕີມ"

#. ZU8Ck
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN106F0\n"
"help.text"
msgid "<ahelp hid=\".\">Expands or reduces the dialog. The <emph>More</emph> button is visible for data fields only.</ahelp>"
msgstr "<ahelp hid=\".\">ຂະຫຍາຍ ຫຼື ຫຍໍ້ກ່ອງໂຕ້ຕອບ. ປຸ່ມ <emph>ເພີ່ມເຕີມ</emph> ຈະສະແດງໃຫ້ເຫັນສະເພາະເຂດຂໍ້ມູນເທົ່ານັ້ນ.</ahelp>"

#. z6EgA
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN106F3\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. 9SdDd
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN106F7\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the <link href=\"text/scalc/01/12090106.xhp\">Data Field Options</link> dialog. The <emph>Options</emph> button is visible for filters and column or row fields only.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/scalc/01/12090106.xhp\">ຕົວເລືອກເຂດຂໍ້ມູນ</link>. ປຸ່ມ <emph>ຕົວເລືອກ</emph> ຈະສະແດງໃຫ້ເຫັນສະເພາະຕົວຕອງ ແລະ ເຂດຂໍ້ມູນຖັນ ຫຼື ແຖວເທົ່ານັ້ນ.</ahelp>"

#. pTDtv
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10708\n"
"help.text"
msgid "If the dialog is expanded by the <emph>More</emph> button, the following items are added to the dialog:"
msgstr "ຫາກກ່ອງໂຕ້ຕອບຖືກຂະຫຍາຍດ້ວຍປຸ່ມ <emph>ເພີ່ມເຕີມ</emph>, ລາຍການຕໍ່ໄປນີ້ຈະຖືກເພີ່ມເຂົ້າໃນກ່ອງໂຕ້ຕອບ:"

#. FQRpT
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1070B\n"
"help.text"
msgid "Displayed value"
msgstr "ຄ່າທີ່ສະແດງ"

#. gRvzK
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1070F\n"
"help.text"
msgid "<ahelp hid=\".\">For each data field, you can select the type of display.</ahelp> For some types you can select additional information for a base field and a base item."
msgstr "<ahelp hid=\".\">ສຳລັບແຕ່ລະເຂດຂໍ້ມູນ, ທ່ານສາມາດເລືອກປະເພດຂອງການສະແດງຜົນໄດ້.</ahelp> ສຳລັບບາງປະເພດ ທ່ານສາມາດເລືອກຂໍ້ມູນເພີ່ມເຕີມສຳລັບເຂດຂໍ້ມູນຫຼັກ ແລະ ລາຍການຫຼັກ."

#. hbGoA
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10712\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. QbxFg
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10716\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafielddialog/type\">Select the type of calculating of the displayed value for the data field.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafielddialog/type\">ເລືອກປະເພດຂອງການຄິດໄລ່ຄ່າທີ່ສະແດງສຳລັບເຂດຂໍ້ມູນ.</ahelp>"

#. YVmxa
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10724\n"
"help.text"
msgid "Type"
msgstr "ປະເພດ"

#. KDdEc
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1072A\n"
"help.text"
msgid "Displayed value"
msgstr "ຄ່າທີ່ສະແດງ"

#. EEKBN
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10731\n"
"help.text"
msgid "Normal"
msgstr "ປົກກະຕິ"

#. EG2GU
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10737\n"
"help.text"
msgid "Results are shown unchanged"
msgstr "ຜົນຮັບຈະຖືກສະແດງໂດຍບໍ່ມີການປ່ຽນແປງ"

#. YjZhA
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1073E\n"
"help.text"
msgid "Difference from"
msgstr "ຜົນຕ່າງຈາກ"

#. 9aYDp
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10744\n"
"help.text"
msgid "From each result, its reference value (see below) is subtracted, and the difference is shown. Totals outside of the base field are shown as empty results."
msgstr "ຈາກແຕ່ລະຜົນຮັບ, ຄ່າອ້າງອີງຂອງມັນ (ເບິ່ງດ້ານລຸ່ມ) ຈະຖືກລົບອອກ, ແລະ ສະແດງຜົນຕ່າງ. ຜົນລວມທີ່ຢູ່ນອກເຂດຂໍ້ມູນຫຼັກຈະຖືກສະແດງເປັນຜົນຮັບທີ່ວ່າງເປົ່າ."

#. UYiPU
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10747\n"
"help.text"
msgid "<emph>Named item</emph>"
msgstr "<emph>ລາຍການທີ່ມີຊື່</emph>"

#. RNBV5
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1074C\n"
"help.text"
msgid "If a base item name is specified, the reference value for a combination of field items is the result where the item in the base field is replaced by the specified base item."
msgstr "ຫາກມີການກຳນົດຊື່ລາຍການຫຼັກ, ຄ່າອ້າງອີງສຳລັບການລວມກັນຂອງລາຍການເຂດຂໍ້ມູນແມ່ນຜົນຮັບທີ່ລາຍການໃນເຂດຂໍ້ມູນຫຼັກຖືກແທນທີ່ດ້ວຍລາຍການຫຼັກທີ່ກຳນົດໄວ້."

#. KNpxB
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1074F\n"
"help.text"
msgid "<emph>Previous item or Next item</emph>"
msgstr "<emph>ລາຍການກ່ອນໜ້າ ຫຼື ລາຍການຖັດໄປ</emph>"

#. btRFU
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10754\n"
"help.text"
msgid "If \"previous item\" or \"next item\" is specified as the base item, the reference value is the result for the next visible member of the base field, in the base field's sort order."
msgstr "ຫາກມີການກຳນົດ \"ລາຍການກ່ອນໜ້າ\" ຫຼື \"ລາຍການຖັດໄປ\" ເປັນລາຍການຫຼັກ, ຄ່າອ້າງອີງແມ່ນຜົນຮັບສຳລັບສະມາຊິກທີ່ສະແດງໃຫ້ເຫັນຖັດໄປຂອງເຂດຂໍ້ມູນຫຼັກ, ຕາມລໍາດັບການຈັດລຽງຂອງເຂດຂໍ້ມູນຫຼັກ."

#. z3mAJ
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1075B\n"
"help.text"
msgid "% Of"
msgstr "% ຂອງ"

#. RDSXy
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10761\n"
"help.text"
msgid "Each result is divided by its reference value. The reference value is determined in the same way as for \"Difference from\". Totals outside of the base field are shown as empty results."
msgstr "ແຕ່ລະຜົນຮັບຈະຖືກຫານດ້ວຍຄ່າອ້າງອີງຂອງມັນ. ຄ່າອ້າງອີງຈະຖືກກຳນົດໃນລັກສະນະດຽວກັນກັບ \"ຜົນຕ່າງຈາກ\". ຜົນລວມທີ່ຢູ່ນອກເຂດຂໍ້ມູນຫຼັກຈະຖືກສະແດງເປັນຜົນຮັບທີ່ວ່າງເປົ່າ."

#. XH2hx
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1076A\n"
"help.text"
msgid "% Difference from"
msgstr "% ຜົນຕ່າງຈາກ"

#. hJ88n
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10770\n"
"help.text"
msgid "From each result, its reference value is subtracted, and the difference is divided by the reference value. The reference value is determined in the same way as for \"Difference from\". Totals outside of the base field are shown as empty results."
msgstr "ຈາກແຕ່ລະຜົນຮັບ, ຄ່າອ້າງອີງຂອງມັນຈະຖືກລົບອອກ, ແລະ ຜົນຕ່າງຈະຖືກຫານດ້ວຍຄ່າອ້າງອີງ. ຄ່າອ້າງອີງຈະຖືກກຳນົດໃນລັກສະນະດຽວກັນກັບ \"ຜົນຕ່າງຈາກ\". ຜົນລວມທີ່ຢູ່ນອກເຂດຂໍ້ມູນຫຼັກຈະຖືກສະແດງເປັນຜົນຮັບທີ່ວ່າງເປົ່າ."

#. nQLwe
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10777\n"
"help.text"
msgid "Running total in"
msgstr "ຜົນລວມສະສົມໃນ"

#. yVMiZ
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1077D\n"
"help.text"
msgid "Each result is added to the sum of the results for preceding items in the base field, in the base field's sort order, and the total sum is shown."
msgstr "ແຕ່ລະຜົນຮັບຈະຖືກເພີ່ມເຂົ້າໃນຜົນລວມຂອງຜົນຮັບສຳລັບລາຍການກ່ອນໜ້າໃນເຂດຂໍ້ມູນຫຼັກ, ຕາມລຳດັບການຈັດລຽງຂອງເຂດຂໍ້ມູນຫຼັກ, ແລະ ສະແດງຜົນລວມທັງໝົດ."

#. 6suFA
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10780\n"
"help.text"
msgid "Results are always summed, even if a different summary function was used to get each result."
msgstr "ຜົນຮັບຈະຖືກລວມເຂົ້າກັນສະເໝີ, ເຖິງແມ່ນວ່າຈະມີການໃຊ້ຟັງຊັນການສະຫຼຸບທີ່ແຕກຕ່າງກັນເພື່ອໃຫ້ໄດ້ແຕ່ລະຜົນຮັບກໍຕາມ."

#. 8tktw
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10787\n"
"help.text"
msgid "% of row"
msgstr "% ຂອງແຖວ"

#. ACFRr
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1078D\n"
"help.text"
msgid "Each result is divided by the total result for its row in the pivot table. If there are several data fields, the total for the result's data field is used. If there are subtotals with manually selected summary functions, the total with the data field's summary function is still used."
msgstr "ແຕ່ລະຜົນຮັບຈະຖືກຫານດ້ວຍຜົນຮັບທັງໝົດສຳລັບແຖວຂອງມັນໃນຕາຕະລາງພິວອດ. ຫາກມີເຂດຂໍ້ມູນຫຼາຍອັນ, ຜົນລວມຂອງເຂດຂໍ້ມູນຂອງຜົນຮັບນັ້ນຈະຖືກນຳໃຊ້. ຫາກມີຜົນລວມຍ່ອຍທີ່ມີຟັງຊັນການສະຫຼຸບທີ່ເລືອກເອງ, ຜົນລວມທີ່ມີຟັງຊັນການສະຫຼຸບຂອງເຂດຂໍ້ມູນນັ້ນຍັງຄົງຖືກນຳໃຊ້ຢູ່."

#. uu4sy
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN10794\n"
"help.text"
msgid "% of column"
msgstr "% ຂອງຖັນ"

#. Hg6TQ
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN1079A\n"
"help.text"
msgid "Same as \"% of row\", but the total for the result's column is used."
msgstr "ຄືກັນກັບ \"% ຂອງແຖວ\", ແຕ່ຈະໃຊ້ຜົນລວມສຳລັບຖັນຂອງຜົນຮັບແທນ."

#. oxTAn
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107A1\n"
"help.text"
msgid "% of total"
msgstr "% ຂອງທັງໝົດ"

#. CZDAT
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107A7\n"
"help.text"
msgid "Same as \"% of row\", but the grand total for the result's data field is used."
msgstr "ຄືກັນກັບ \"% ຂອງແຖວ\", ແຕ່ຈະໃຊ້ຜົນລວມຍອດສຳລັບເຂດຂໍ້ມູນຂອງຜົນຮັບແທນ."

#. CcmCV
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107AE\n"
"help.text"
msgid "Index"
msgstr "ດັດຊະນີ"

#. 9xDeY
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107B4\n"
"help.text"
msgid "The row and column totals and the grand total, following the same rules as above, are used to calculate the following expression:"
msgstr "ຜົນລວມຂອງແຖວ ແລະ ຖັນ ແລະ ຜົນລວມຍອດ, ຕາມກົດເກນດຽວກັນກັບຂ້າງເທິງ, ຈະຖືກນຳໃຊ້ເພື່ອຄິດໄລ່ນິພົດຕໍ່ໄປນີ້:"

#. 4i2FD
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107B7\n"
"help.text"
msgid "( original result * grand total ) / ( row total * column total )"
msgstr "( ຜົນຮັບເດີມ * ຜົນລວມຍອດ ) / ( ຜົນລວມແຖວ * ຜົນລວມຖັນ )"

#. Kfgj3
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107BA\n"
"help.text"
msgid "Base field"
msgstr "ເຂດຂໍ້ມູນຫຼັກ"

#. tk2xE
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107BE\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafielddialog/basefield\">Select the field from which the respective value is taken as base for the calculation.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafielddialog/basefield\">ເລືອກເຂດຂໍ້ມູນທີ່ຈະນຳຄ່າທີ່ກ່ຽວຂ້ອງມາໃຊ້ເປັນຖານສຳລັບການຄິດໄລ່.</ahelp>"

#. hEziA
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107C1\n"
"help.text"
msgid "Base item"
msgstr "ລາຍການຫຼັກ"

#. bUVn6
#: 12090105.xhp
msgctxt ""
"12090105.xhp\n"
"par_idN107C5\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafielddialog/baseitem\">Select the item of the base field from which the respective value is taken as base for the calculation.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafielddialog/baseitem\">ເລືອກລາຍການຂອງເຂດຂໍ້ມູນຫຼັກທີ່ຈະນຳຄ່າທີ່ກ່ຽວຂ້ອງມາໃຊ້ເປັນຖານສຳລັບການຄິດໄລ່.</ahelp>"

#. 5w7xX
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"tit\n"
"help.text"
msgid "Data Field Options"
msgstr "ຕົວເລືອກເຂດຂໍ້ມູນ"

#. nfmEB
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"bm_id711386\n"
"help.text"
msgid "<bookmark_value>hiding;data fields, from calculations in pivot table</bookmark_value><bookmark_value>display options in pivot table</bookmark_value><bookmark_value>sorting;options in pivot table</bookmark_value><bookmark_value>data field options for pivot table</bookmark_value>"
msgstr "<bookmark_value>ການຊ້ອນ;ເຂດຂໍ້ມູນ, ຈາກການຄິດໄລ່ໃນຕາຕະລາງພິວອດ</bookmark_value><bookmark_value>ຕົວເລືອກການສະແດງຜົນໃນຕາຕະລາງພິວອດ</bookmark_value><bookmark_value>ການຈັດລຽງ;ຕົວເລືອກໃນຕາຕະລາງພິວອດ</bookmark_value><bookmark_value>ຕົວເລືອກເຂດຂໍ້ມູນສຳລັບຕາຕະລາງພິວອດ</bookmark_value>"

#. rZueD
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10542\n"
"help.text"
msgid "Data Field Options"
msgstr "ຕົວເລືອກເຂດຂໍ້ມູນ"

#. MeeX5
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10546\n"
"help.text"
msgid "You can specify additional options for column, row, and page data fields in the <link href=\"text/scalc/01/12090105.xhp\">pivot table</link>."
msgstr "ທ່ານສາມາດກຳນົດຕົວເລືອກເພີ່ມເຕີມສຳລັບເຂດຂໍ້ມູນຖັນ, ແຖວ, ແລະ ໜ້າໃນ <link href=\"text/scalc/01/12090105.xhp\">ຕາຕະລາງພິວອດ</link>."

#. ATBoM
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10557\n"
"help.text"
msgid "Sort by"
msgstr "ຈັດລຽງໂດຍ"

#. mHJkA
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1055B\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/sortby\">Select the data field that you want to sort columns or rows by.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/sortby\">ເລືອກເຂດຂໍ້ມູນທີ່ທ່ານຕ້ອງການຈັດລຽງຖັນ ຫຼື ແຖວ.</ahelp>"

#. BXKZ7
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1055E\n"
"help.text"
msgid "Ascending"
msgstr "ຈາກໜ້ອຍໄປຫາຫຼາຍ"

#. jNcNE
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10562\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/ascending\">Sorts the values from the lowest value to the highest value. If the selected field is the field for which the dialog was opened, the items are sorted by name. If a data field was selected, the items are sorted by the resultant value of the selected data field.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/ascending\">ຈັດລຽງຄ່າຈາກຕ່ຳສຸດໄປຫາສູງສຸດ. ຫາກເຂດຂໍ້ມູນທີ່ເລືອກເປັນເຂດຂໍ້ມູນທີ່ເປີດກ່ອງໂຕ້ຕອບນີ້, ລາຍການຈະຖືກຈັດລຽງຕາມຊື່. ຫາກເລືອກເຂດຂໍ້ມູນ, ລາຍການຈະຖືກຈັດລຽງຕາມຄ່າຜົນຮັບຂອງເຂດຂໍ້ມູນທີ່ເລືອກ.</ahelp>"

#. CjwdF
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10565\n"
"help.text"
msgid "Descending"
msgstr "ຈາກຫຼາຍໄປຫາໜ້ອຍ"

#. NFuB8
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10569\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/descending\">Sorts the values descending from the highest value to the lowest value. If the selected field is the field for which the dialog was opened, the items are sorted by name. If a data field was selected, the items are sorted by the resultant value of the selected data field.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/descending\">ຈັດລຽງຄ່າຈາກສູງສຸດລົງໄປຫາຕ່ຳສຸດ. ຫາກເຂດຂໍ້ມູນທີ່ເລືອກເປັນເຂດຂໍ້ມູນທີ່ເປີດກ່ອງໂຕ້ຕອບນີ້, ລາຍການຈະຖືກຈັດລຽງຕາມຊື່. ຫາກເລືອກເຂດຂໍ້ມູນ, ລາຍການຈະຖືກຈັດລຽງຕາມຄ່າຜົນຮັບຂອງເຂດຂໍ້ມູນທີ່ເລືອກ.</ahelp>"

#. 8Q5nS
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1056C\n"
"help.text"
msgid "Manual"
msgstr "ກຳນົດເອງ"

#. nvxFt
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10570\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/manual\">Sorts values alphabetically.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/manual\">ຈັດລຽງຄ່າຕາມຕົວອັກສອນ.</ahelp>"

#. EBKgh
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10585\n"
"help.text"
msgid "Display options"
msgstr "ຕົວເລືອກການສະແດງຜົນ"

#. f4gbc
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10589\n"
"help.text"
msgid "You can specify the display options for all row fields except for the last, innermost row field."
msgstr "ທ່ານສາມາດກຳນົດຕົວເລືອກການສະແດງຜົນສຳລັບເຂດຂໍ້ມູນແຖວທັງໝົດ ຍົກເວັ້ນເຂດຂໍ້ມູນແຖວສຸດທ້າຍທີ່ຢູ່ທາງໃນສຸດ."

#. RY5SV
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1058C\n"
"help.text"
msgid "Layout"
msgstr "ໂຄງຮ່າງ"

#. 4fZs2
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10590\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/layout\">Select the layout mode for the field in the list box.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/layout\">ເລືອກຮູບແບບໂຄງຮ່າງສຳລັບເຂດຂໍ້ມູນໃນລາຍການເລືອກ.</ahelp>"

#. fCEFC
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10593\n"
"help.text"
msgid "Empty line after each item"
msgstr "ແຖວວ່າງຫຼັງຈາກແຕ່ລະລາຍການ"

#. k2Y3R
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN10597\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/emptyline\">Adds an empty row after the data for each item in the pivot table.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/emptyline\">ເພີ່ມແຖວວ່າງຫຼັງຈາກຂໍ້ມູນສຳລັບແຕ່ລະລາຍການໃນຕາຕະລາງພິວອດ.</ahelp>"

#. CoAEB
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1059A\n"
"help.text"
msgid "Show automatically"
msgstr "ສະແດງໂດຍອັດຕະໂນມັດ"

#. LRNWN
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN1059E\n"
"help.text"
msgid "Displays the top or bottom nn items when you sort by a specified field."
msgstr "ສະແດງລາຍການສູງສຸດ ຫຼື ຕ່ຳສຸດຕາມຈຳນວນທີ່ກຳນົດ ເມື່ອທ່ານຈັດລຽງຕາມເຂດຂໍ້ມູນທີ່ລະບຸ."

#. 9BvAe
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN105A1\n"
"help.text"
msgid "Show"
msgstr "ສະແດງ"

#. fb5NP
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN105A5\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/show\">Turns on the automatic show feature.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/show\">ເປີດໃຊ້ງານຄຸນສົມບັດການສະແດງຜົນອັດຕະໂນມັດ.</ahelp>"

