msgctxt ""
"04070200.xhp\n"
"hd_id3153419\n"
"help.text"
msgid "Paste"
msgstr "ວາງ"

#. GYypP
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"par_id3155067\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/insertname/paste\">Inserts the selected named area and the corresponding cell reference at the current cursor position.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/insertname/paste\">ແຊກພື້ນທີ່ທີ່ຕັ້ງຊື່ທີ່ເລືອກ ແລະ ການອ້າງອີງຫ້ອງທີ່ກ່ຽວຂ້ອງລົງໃນຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ.</ahelp>"

#. L8wko
