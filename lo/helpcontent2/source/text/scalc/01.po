msgid "Time"
msgstr "ເວລາ"

#. wiBwp
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id3155066\n"
"help.text"
msgid "All numbers corresponding to the condition. The entered values are formatted accordingly the next time the dialog is called up."
msgstr "ຕົວເລກທັງໝົດທີ່ກົງກັບເງື່ອນໄຂ. ຄ່າທີ່ປ້ອນຈະຖືກຈັດຮູບແບບໃຫ້ເໝາະສົມໃນຄັ້ງຖັດໄປທີ່ເປີດກ່ອງໂຕ້ຕອບ."

#. ZufmJ
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN106A0\n"
"help.text"
msgid "Cell range"
msgstr "ຊ່ວງເຊວ"

#. FbXCC
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN106A5\n"
"help.text"
msgid "Allow only values that are given in a cell range. The cell range can be specified explicitly, or as a named database range, or as a named range. The range may consist of one column or one row of cells. If you specify a range of columns and rows, only the first column is used."
msgstr "ອະນຸຍາດສະເພາະຄ່າທີ່ຢູ່ໃນຊ່ວງເຊວທີ່ກຳນົດ. ຊ່ວງເຊວສາມາດລະບຸໄດ້ໂດຍກົງ, ຫຼື ເປັນຊ່ວງຖານຂໍ້ມູນທີ່ມີຊື່, ຫຼື ຊ່ວງທີ່ມີຊື່. ຊ່ວງດັ່ງກ່າວອາດປະກອບດ້ວຍຖັນດຽວ ຫຼື ແຖວດຽວ. ຫາກທ່ານລະບຸຊ່ວງທີ່ມີທັງຖັນ ແລະ ແຖວ, ຈະມີພຽງແຕ່ຖັນທຳອິດເທົ່ານັ້ນທີ່ຈະຖືກນຳໃຊ້."

#. Sh6bp
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN106AB\n"
"help.text"
msgid "List"
msgstr "ລາຍການ"

#. AHcsu
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN106B0\n"
"help.text"
msgid "Allow only values or strings specified in a list. Strings and values can be mixed. Numbers evaluate to their value, so if you enter the number 1 in the list, the entry 100% is also valid."
msgstr "ອະນຸຍາດສະເພາະຄ່າ ຫຼື ຂໍ້ຄວາມທີ່ລະບຸໃນລາຍການ. ສາມາດປະສົມກັນໄດ້ທັງຂໍ້ຄວາມ ແລະ ຕົວເລກ. ຕົວເລກຈະຖືກປະເມີນຕາມຄ່າຂອງມັນ, ດັ່ງນັ້ນຫາກທ່ານປ້ອນເລກ 1 ໃນລາຍການ, ຄ່າ 100% ກໍຖືວ່າຖືກຕ້ອງເຊັ່ນກັນ."

#. xheF9
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id221603980244052\n"
"help.text"
msgid "Only up to 255 characters are saved when using an Excel format."
msgstr "ຈະມີການບັນທຶກສູງສຸດພຽງ 255 ຕົວອັກສອນເມື່ອໃຊ້ຮູບແບບ Excel."

#. pfATZ
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id3154756\n"
"help.text"
msgid "Text length"
msgstr "ຄວາມຍາວຂໍ້ຄວາມ"

#. i5frz
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id3147339\n"
"help.text"
msgid "Entries whose length corresponds to the condition."
msgstr "ລາຍການທີ່ມີຄວາມຍາວສອດຄ່ອງກັບເງື່ອນໄຂ."

#. zEYdt
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id551607384650484\n"
"help.text"
msgid "Custom"
msgstr "ກຳນົດເອງ"

#. Eejrc
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id101607384677959\n"
"help.text"
msgid "Only allow values that result in the formula entered in the <emph>Formula</emph> box to return <literal>TRUE</literal>, when the formula is calculated with the entered value. The formula can be any expression that evaluates to a boolean value of <literal>TRUE</literal> or <literal>FALSE</literal>, or returns a numerical value, where a nonzero value is interpreted as <literal>TRUE</literal> and <literal>0</literal> is interpreted as <literal>FALSE</literal>."
msgstr "ອະນຸຍາດສະເພາະຄ່າທີ່ເຮັດໃຫ້ສູດທີ່ປ້ອນໃນຊ່ອງ <emph>ສູດ</emph> ສົ່ງຄືນຄ່າ <literal>TRUE</literal>, ເມື່ອຄິດໄລ່ສູດດ້ວຍຄ່າທີ່ປ້ອນເຂົ້າ. ສູດສາມາດເປັນນິພົດໃດໆກໍຕາມທີ່ປະເມີນເປັນຄ່າບູລີນ <literal>TRUE</literal> ຫຼື <literal>FALSE</literal>, ຫຼື ສົ່ງຄືນຄ່າຕົວເລກ, ໂດຍທີ່ຄ່າທີ່ບໍ່ແມ່ນສູນຈະຖືກຕີຄວາມໝາຍເປັນ <literal>TRUE</literal> ແລະ <literal>0</literal> ຈະຖືກຕີຄວາມໝາຍເປັນ <literal>FALSE</literal>."

#. LhCDS
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id461607565255803\n"
"help.text"
msgid "Formulas can use relative referencing. For example, if cells <literal>A1:A4</literal> were selected, the cursor is in cell <literal>A1</literal> and <input>ISODD(A1)</input> is entered into the <emph>Formula</emph> box, then only odd numbers could be entered into cells <literal>A1</literal> through <literal>A4</literal>."
msgstr "ສູດສາມາດໃຊ້ການອ້າງອີງແບບສຳພັນໄດ້. ຕົວຢ່າງ, ຫາກເລືອກເຊວ <literal>A1:A4</literal>, ເຄີເຊີຢູ່ທີ່ເຊວ <literal>A1</literal> ແລະ ປ້ອນ <input>ISODD(A1)</input> ເຂົ້າໃນຊ່ອງ <emph>ສູດ</emph>, ຈະສາມາດປ້ອນໄດ້ພຽງແຕ່ເລກຄີກໃນເຊວ <literal>A1</literal> ຫາ <literal>A4</literal> ເທົ່ານັ້ນ."

#. BoA6a
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id221603980244055\n"
"help.text"
msgid "Only up to 255 characters are saved when using an Excel format."
msgstr "ຈະມີການບັນທຶກສູງສຸດພຽງ 255 ຕົວອັກສອນເມື່ອໃຊ້ຮູບແບບ Excel."

#. apG3s
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"hd_id3154704\n"
"help.text"
msgid "Allow blank cells"
msgstr "ອະນຸຍາດເຊວວ່າງ"

#. kHDGe
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id3153967\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/allowempty\">In conjunction with <emph>Tools - Detective - Mark invalid Data</emph>, this defines that blank cells are shown as invalid data (disabled) or not (enabled).</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/allowempty\">ເມື່ອໃຊ້ຮ່ວມກັບ <emph>ເຄື່ອງມື - ຕົວສືບຄົ້ນ - ໝາຍຂໍ້ມູນທີ່ບໍ່ຖືກຕ້ອງ</emph>, ສິ່ງນີ້ຈະກຳນົດວ່າເຊວວ່າງຈະຖືກສະແດງເປັນຂໍ້ມູນທີ່ບໍ່ຖືກຕ້ອງ (ປິດໃຊ້ງານ) ຫຼື ບໍ່ (ເປີດໃຊ້ງານ).</ahelp>"

#. Fcsnm
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"hd_id901744637984671\n"
"help.text"
msgid "Case Sensitive"
msgstr "ຕົວອັກສອນນ້ອຍ-ໃຫຍ່ມີຄວາມໝາຍຕ່າງກັນ"

#. jHkBh
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_id531744637972520\n"
"help.text"
msgid "Honor upper and lower case for <emph>Cell ranges</emph>, <emph>Lists</emph> and <emph>Custom</emph> values."
msgstr "ກວດສອບຕົວອັກສອນພິມໃຫຍ່ ແລະ ພິມນ້ອຍສຳລັບ <emph>ຊ່ວງເຊວ</emph>, <emph>ລາຍການ</emph> ແລະ ຄ່າ <emph>ກຳນົດເອງ</emph>."

#. knPBu
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN10709\n"
"help.text"
msgid "Show selection list"
msgstr "ສະແດງລາຍການເລືອກ"

#. CMMBv
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN1070D\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/showlist\">Shows a list of all valid strings or values to select from. The list can also be opened by selecting the cell and pressing <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Option+Down Arrow</keycode></caseinline><defaultinline><keycode>Alt+Down Arrow</keycode></defaultinline></switchinline>.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/showlist\">ສະແດງລາຍການຂອງຂໍ້ຄວາມ ຫຼື ຄ່າທີ່ຖືກຕ້ອງທັງໝົດເພື່ອໃຫ້ເລືອກ. ລາຍການຍັງສາມາດເປີດໄດ້ໂດຍການເລືອກເຊວແລ້ວກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Option+ລູກສອນລົງ</keycode></caseinline><defaultinline><keycode>Alt+ລູກສອນລົງ</keycode></defaultinline></switchinline>.</ahelp>"

#. AuAaR
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN10724\n"
"help.text"
msgid "Sort entries ascending"
msgstr "ຈັດລຽງລາຍການຈາກໜ້ອຍໄປຫາຫຼາຍ"

#. FcnYF
#: 12120100.xhp
msgctxt ""
"12120100.xhp\n"
"par_idN10728\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/sortascend\">Sorts the selection list in ascending order and filters duplicates from the list. If not checked, the order from the data source is taken.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/validationcriteriapage/sortascend\">ຈັດລຽງລາຍການເລືອກຕາມລຳດັບຈາກໜ້ອຍໄປຫາຫຼາຍ ແລະ ກັ່ນຕອງລາຍການທີ່ຊ້ຳກັນອອກ. ຫາກບໍ່ໄດ້ໝາຍເລືອກ, ຈະໃຊ້ລຳດັບຕາມແຫຼ່ງຂໍ້ມູນ.</ahelp>"

