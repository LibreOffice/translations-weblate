"hd_id3145252\n"
"help.text"
msgid "Include formats"
msgstr "ລວມຮູບແບບນຳ"

#. VKEvc
#: 12050200.xhp
msgctxt ""
"12050200.xhp\n"
"par_id3147125\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/subtotaloptionspage/formats\">Considers formatting attributes when sorting.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/subtotaloptionspage/formats\">ພິຈາລະນາຄຸນລັກສະນະການຈັດຮູບແບບເມື່ອລຽງລຳດັບ.</ahelp>"

#. 7LP4L
