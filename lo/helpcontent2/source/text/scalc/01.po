"12090400.xhp\n"
"par_idN1057D\n"
"help.text"
msgid "End"
msgstr "ສິ້ນສຸດ"

#. LCoAb
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN10581\n"
"help.text"
