msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615596260\n"
"help.text"
msgid "1 (Monday) through 7 (Sunday)."
msgstr "1 (ວັນຈັນ) ຫາ 7 (ວັນອາທິດ)."

#. Fhihd
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615597630\n"
"help.text"
msgid "0 (Monday) through 6 (Sunday)"
msgstr "0 (ວັນຈັນ) ຫາ 6 (ວັນອາທິດ)"

#. ZKiEn
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615592023\n"
"help.text"
msgid "1 (Monday) through 7 (Sunday)."
msgstr "1 (ວັນຈັນ) ຫາ 7 (ວັນອາທິດ)."

#. BGmPr
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615591349\n"
"help.text"
msgid "1 (Tuesday) through 7 (Monday)."
msgstr "1 (ວັນອັງຄານ) ຫາ 7 (ວັນຈັນ)."

#. QAN6k
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615593664\n"
"help.text"
msgid "1 (Wednesday) through 7 (Tuesday)."
msgstr "1 (ວັນພຸດ) ຫາ 7 (ວັນອັງຄານ)."

#. jrbXZ
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170615599110\n"
"help.text"
msgid "1 (Thursday) through 7 (Wednesday)."
msgstr "1 (ວັນພະຫັດ) ຫາ 7 (ວັນພຸດ)."

#. 6RzFd
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id05022017061600535\n"
"help.text"
msgid "1 (Friday) through 7 (Thursday)."
msgstr "1 (ວັນສຸກ) ຫາ 7 (ວັນພະຫັດ)."

#. gMLHQ
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170616003219\n"
"help.text"
msgid "1 (Saturday) through 7 (Friday)."
msgstr "1 (ວັນເສົາ) ຫາ 7 (ວັນສຸກ)."

#. ypPnV
#: func_weekday.xhp
msgctxt ""
"func_weekday.xhp\n"
"par_id050220170616002095\n"
"help.text"
msgid "1 (Sunday) through 7 (Saturday)."
msgstr "1 (ວັນອາທິດ) ຫາ 7 (ວັນເສົາ)."

#. ETGT2
