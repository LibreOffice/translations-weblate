msgctxt ""
"12090400.xhp\n"
"par_idN10592\n"
"help.text"
msgid "Group by"
msgstr "ຈັດກຸ່ມຕາມ"

#. pW3HW
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN10596\n"
"help.text"
msgid "Specifies the value range by which every group's limits are calculated."
msgstr "ກຳນົດຊ່ວງຂອງຄ່າທີ່ໃຊ້ໃນການຄິດໄລ່ຂີດຈຳກັດຂອງແຕ່ລະກຸ່ມ."

#. zjoAz
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN10599\n"
"help.text"
msgid "Number of days"
msgstr "ຈຳນວນມື້"

#. fB7Xn
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN1059D\n"
"help.text"
msgid "In the case of grouping date values, specifies the number of days to group by."
msgstr "ໃນກໍລະນີຂອງການຈັດກຸ່ມຄ່າວັນທີ, ໃຫ້ກຳນົດຈຳນວນມື້ທີ່ຈະຈັດກຸ່ມ."

#. hTrSc
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN105A0\n"
"help.text"
msgid "Intervals"
msgstr "ໄລຍະຫ່າງ"

#. rNuqi
#: 12090400.xhp
msgctxt ""
"12090400.xhp\n"
"par_idN105A4\n"
"help.text"
msgid "In the case of grouping date values, specifies the intervals to group by."
msgstr "ໃນກໍລະນີຂອງການຈັດກຸ່ມຄ່າວັນທີ, ໃຫ້ກຳນົດໄລຍະຫ່າງທີ່ຈະຈັດກຸ່ມ."

#. BHb4N
