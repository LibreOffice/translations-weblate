msgctxt ""
"02150000.xhp\n"
"par_id3154015\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/deletecontents/text\">Deletes text only. Formats, formulas, numbers and dates are not affected.</ahelp>"
