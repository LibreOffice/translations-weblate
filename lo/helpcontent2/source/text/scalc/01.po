"par_id121708281643207\n"
"help.text"
msgid "<emph>Match Mode</emph>: (optional) specifies the match type. Values can be:"
msgstr "<emph>Match Mode</emph>: (ທາງເລືອກ) ກຳນົດປະເພດການຈັບຄູ່. ຄ່າສາມາດເປັນ:"

#. DDPDt
#: func_xmatch.xhp
msgctxt ""
