"func_right.xhp\n"
"par_id3145375\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_RECHTS\">Returns the last character or characters of a text.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_RECHTS\">ສົ່ງຄືນຕົວອັກສອນສຸດທ້າຍ ຫຼື ຫຼາຍຕົວອັກສອນສຸດທ້າຍຂອງຂໍ້ຄວາມ.</ahelp>"

