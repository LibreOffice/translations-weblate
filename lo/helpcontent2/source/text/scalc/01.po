msgctxt ""
"func_wraprows.xhp\n"
"par_id701737825446850\n"
"help.text"
msgid "<emph>Range</emph>: the range to wrap."
msgstr "<emph>Range</emph>: ຊ່ວງຂໍ້ມູນທີ່ຈະຈັດແຖວ."

#. sDEJU
#: func_wraprows.xhp
msgctxt ""
"func_wraprows.xhp\n"
"par_id441737825452403\n"
"help.text"
msgid "<emph>Wrap_count</emph>: the maximum number of values in each row."
msgstr "<emph>Wrap_count</emph>: ຈຳນວນຄ່າສູງສຸດໃນແຕ່ລະແຖວ."

#. Arfnd
#: func_wraprows.xhp
msgctxt ""
"func_wraprows.xhp\n"
"par_id411737825456380\n"
"help.text"
msgid "<emph>Pad_with</emph>: (optional) a specified value to pad if there are insufficient number of values. By default, it returns #N/A to fill in the cells."
msgstr "<emph>Pad_with</emph>: (ທາງເລືອກ) ຄ່າທີ່ກຳນົດເພື່ອຕື່ມໃສ່ຫາກມີຈຳນວນຄ່າບໍ່ພຽງພໍ. ໂດຍເລີ່ມຕົ້ນ, ມັນຈະສົ່ງຄືນ #N/A ເພື່ອຕື່ມໃສ່ໃນເຊລ."

#. JsK5T
#: func_wraprows.xhp
msgctxt ""
"func_wraprows.xhp\n"
"par_id771738021783517\n"
"help.text"
msgid "The formula <input>{=WRAPROWS(A1:A15;4)}</input>  returns the array below. The missing values are replaced by #N/A."
msgstr "ສູດ <input>{=WRAPROWS(A1:A15;4)}</input> ສົ່ງຄືນອາເຣດ້ານລຸ່ມ. ຄ່າທີ່ຂາດຫາຍໄປຈະຖືກແທນທີ່ດ້ວຍ #N/A."

#. i7yWC
