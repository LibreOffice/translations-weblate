#. pvPPw
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id655232\n"
"help.text"
msgid "<variable id=\"text2columns\">Opens the Text to Columns dialog, where you enter settings to expand the contents of selected cells to multiple cells.</variable>"
msgstr "<variable id=\"text2columns\">ເປີດກ່ອງໂຕ້ຕອບ 'ຂໍ້ຄວາມເປັນຖັນ', ເຊິ່ງທ່ານສາມາດຕັ້ງຄ່າເພື່ອຂະຫຍາຍເນື້ອໃນຂອງຫ້ອງທີ່ເລືອກໄວ້ ອອກເປັນຫຼາຍຫ້ອງ.</variable>"

#. YwdL2
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"hd_id9599597\n"
"help.text"
msgid "To expand cell contents to multiple cells"
msgstr "ວິທີການຂະຫຍາຍເນື້ອໃນຫ້ອງອອກເປັນຫຼາຍຫ້ອງ"

#. z5ESo
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id2021546\n"
"help.text"
msgid "You can expand cells that contain comma separated values (CSV) into multiple cells in the same row."
msgstr "ທ່ານສາມາດຂະຫຍາຍຫ້ອງທີ່ມີຄ່າທີ່ຂັ້ນດ້ວຍຈຸດ (CSV) ອອກເປັນຫຼາຍຫ້ອງໃນແຖວດຽວກັນ."

#. RG9PG
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id2623981\n"
"help.text"
msgid "For example, cell A1 contains the comma separated values <item type=\"literal\">1,2,3,4</item>, and cell A2 contains the text <item type=\"literal\">A,B,C,D</item>."
msgstr "ຕົວຢ່າງ: ຫ້ອງ A1 ມີຄ່າທີ່ຂັ້ນດ້ວຍຈຸດແມ່ນ <item type=\"literal\">1,2,3,4</item>, ແລະ ຫ້ອງ A2 ມີຂໍ້ຄວາມ <item type=\"literal\">A,B,C,D</item>."

#. WeJnJ
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id7242042\n"
"help.text"
msgid "Select the cell or cells that you want to expand."
msgstr "ເລືອກຫ້ອງ ຫຼື ກຸ່ມຫ້ອງທີ່ທ່ານຕ້ອງການຂະຫຍາຍ."

#. UgNFd
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id6999420\n"
"help.text"
msgid "Choose <emph>Data - Text to Columns</emph>."
msgstr "ເລືອກ <emph>ຂໍ້ມູນ - ຂໍ້ຄວາມເປັນຖັນ</emph>."

#. RLZ5H
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id6334116\n"
"help.text"
msgid "You see the Text to Columns dialog."
msgstr "ທ່ານຈະເຫັນກ່ອງໂຕ້ຕອບ 'ຂໍ້ຄວາມເປັນຖັນ'."

#. BpH4f
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id9276406\n"
"help.text"
msgid "Select the separator options. The preview shows how the current cell contents will be transformed into multiple cells."
msgstr "ເລືອກຕົວເລືອກຕົວຂັ້ນ. ຕົວຢ່າງການສະແດງຜົນຈະບອກໃຫ້ຮູ້ວ່າ ເນື້ອໃນຫ້ອງຈະຖືກແຍກອອກເປັນຫຼາຍຫ້ອງແນວໃດ."

#. V77jv
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id8523819\n"
"help.text"
msgid "You can select a fixed width and then click the ruler on the preview to set cell breakup positions."
msgstr "ທ່ານສາມາດເລືອກແບບຄວາມກວ້າງຄົງທີ່ ແລ້ວກົດໃສ່ໄມ້ບັນທັດໃນຕົວຢ່າງເພື່ອຕັ້ງຕຳແໜ່ງການແຍກຫ້ອງ."

#. DjifN
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id1517380\n"
"help.text"
msgid "You can select or enter separator characters to define the positions of breaking points. The separator characters are removed from the resulting cell contents."
msgstr "ທ່ານສາມາດເລືອກ ຫຼື ປ້ອນຕົວອັກສອນຕົວຂັ້ນເພື່ອບອກຕຳແໜ່ງທີ່ຈະແຍກ. ຕົວອັກສອນຕົວຂັ້ນເຫຼົ່ານີ້ຈະຖືກລຶບອອກຈາກເນື້ອໃນຫ້ອງທີ່ໄດ້."

#. Gm2Jy
#: text2columns.xhp
msgctxt ""
"text2columns.xhp\n"
"par_id7110812\n"
"help.text"
msgid "In the example, you select the comma as a delimiter character. Cells A1 and A2 will be expanded to four columns each. A1 contains 1, B1 contains 2, and so on."
msgstr "ໃນຕົວຢ່າງ, ຖ້າທ່ານເລືອກຈຸດເປັນຕົວຂັ້ນ, ຫ້ອງ A1 ແລະ A2 ຈະຖືກຂະຫຍາຍອອກເປັນສີ່ຖັນ. ຫ້ອງ A1 ຈະມີ 1, B1 ຈະມີ 2 ແລະ ຕໍ່ໆໄປ."

#. ABXho
