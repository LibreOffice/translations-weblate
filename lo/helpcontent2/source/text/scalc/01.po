"par_id3154140\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ZW\">Returns the future value of an investment based on periodic, constant payments and a constant interest rate (Future Value).</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ZW\">ສົ່ງຄືນມູນຄ່າໃນອະນາຄົດຂອງການລົງທຶນ ໂດຍອີງໃສ່ການຈ່າຍທີ່ສະໝໍ່າສະເໝີ ແລະ ອັດຕາດອກເບ້ຍຄົງທີ່.</ahelp>"

#. Gnz7u
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3145215\n"
"help.text"
msgid "FV(Rate; NPer; Pmt [ ; [ PV ] [ ; Type ] ])"
msgstr "FV(Rate; NPer; Pmt [ ; [ PV ] [ ; Type ] ])"

#. Y9GP8
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3155136\n"
"help.text"
msgid "<emph>Rate</emph> is the periodic interest rate."
msgstr "<emph>Rate</emph> ແມ່ນອັດຕາດອກເບ້ຍຕໍ່ງວດ."

#. gh3CB
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3156029\n"
"help.text"
msgid "<emph>NPer</emph> is the total number of periods (payment period)."
msgstr "<emph>NPer</emph> ແມ່ນຈຳນວນງວດທັງໝົດ (ໄລຍະເວລາການຈ່າຍ)."

#. HpKNK
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3151322\n"
"help.text"
msgid "<emph>Pmt</emph> is the annuity paid regularly per period."
msgstr "<emph>Pmt</emph> ແມ່ນເງິນງວດທີ່ຈ່າຍຢ່າງສະໝໍ່າສະເໝີໃນແຕ່ລະງວດ."

#. UKiLK
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3145256\n"
"help.text"
msgid "<emph>PV</emph> (optional) is the (present) cash value of an investment."
msgstr "<emph>PV</emph> (ທາງເລືອກ) ແມ່ນມູນຄ່າປັດຈຸບັນຂອງການລົງທຶນ."

#. 8G8EY
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3150999\n"
"help.text"
msgid "<emph>Type</emph> (optional) defines whether the payment is due at the beginning or the end of a period."
msgstr "<emph>Type</emph> (ທາງເລືອກ) ກຳນົດວ່າການຈ່າຍແມ່ນຕົ້ນງວດ ຫຼື ທ້າຍງວດ."

#. CCFRJ
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3146813\n"
"help.text"
msgid "What is the value at the end of an investment if the interest rate is 4% and the payment period is two years, with a periodic payment of 750 currency units. The investment has a present value of 2,500 currency units."
msgstr "ມູນຄ່າເມື່ອສິ້ນສຸດການລົງທຶນແມ່ນເທົ່າໃດ ຖ້າອັດຕາດອກເບ້ຍແມ່ນ 4% ແລະ ໄລຍະເວລາການຈ່າຍແມ່ນສອງປີ, ໂດຍມີການຈ່າຍງວດລະ 750 ຫົວໜ່ວຍເງິນຕາ. ການລົງທຶນນີ້ມີມູນຄ່າປັດຈຸບັນແມ່ນ 2,500 ຫົວໜ່ວຍເງິນຕາ."

#. cDCWj
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3149302\n"
"help.text"
msgid "<input>=FV(4%;2;750;2500)</input> = -4234.00 currency units. The value at the end of the investment is 4234.00 currency units."
msgstr "<input>=FV(4%;2;750;2500)</input> = -4234.00 ຫົວໜ່ວຍເງິນຕາ. ມູນຄ່າເມື່ອສິ້ນສຸດການລົງທຶນແມ່ນ 4234.00 ຫົວໜ່ວຍເງິນຕາ."

#. EGYDn
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"bm_id3155912\n"
"help.text"
msgid "<bookmark_value>FVSCHEDULE function</bookmark_value>  <bookmark_value>future values;varying interest rates</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ FVSCHEDULE</bookmark_value>  <bookmark_value>ມູນຄ່າໃນອະນາຄົດ;ອັດຕາດອກເບ້ຍທີ່ປ່ຽນແປງ</bookmark_value>"

#. PCwSd
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"hd_id3155912\n"
"help.text"
msgid "FVSCHEDULE"
msgstr "FVSCHEDULE"

#. CzFkE
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3163726\n"
"help.text"
msgid "<ahelp hid=\"HID_AAI_FUNC_FVSCHEDULE\">Calculates the accumulated value of the starting capital for a series of periodically varying interest rates.</ahelp>"
msgstr "<ahelp hid=\"HID_AAI_FUNC_FVSCHEDULE\">ຄິດໄລ່ມູນຄ່າສະສົມຂອງເງິນທຶນເລີ່ມຕົ້ນ ສຳລັບຊຸດຂອງອັດຕາດອກເບ້ຍທີ່ປ່ຽນແປງເປັນງວດ.</ahelp>"

#. QrPVq
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3148891\n"
"help.text"
msgid "FVSCHEDULE(Principal; Schedule)"
msgstr "FVSCHEDULE(Principal; Schedule)"

#. MFuL8
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3148904\n"
"help.text"
msgid "<emph>Principal</emph> is the starting capital."
msgstr "<emph>Principal</emph> ແມ່ນເງິນທຶນເລີ່ມຕົ້ນ."

#. BZAvx
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3148562\n"
"help.text"
msgid "<emph>Schedule</emph> is a series of interest rates, for example, as a range H3:H5 or as a (List) (see example)."
msgstr "<emph>Schedule</emph> ແມ່ນຊຸດຂອງອັດຕາດອກເບ້ຍ, ຕົວຢ່າງ: ເປັນຊ່ວງຂໍ້ມູນ H3:H5 ຫຼື ເປັນລາຍການ (ເບິ່ງຕົວຢ່າງ)."

#. 9FnDp
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3148638\n"
"help.text"
msgid "1000 currency units have been invested in for three years. The interest rates were 3%, 4% and 5% per annum. What is the value after three years?"
msgstr "ເງິນ 1000 ຫົວໜ່ວຍເງິນຕາຖືກລົງທຶນເປັນເວລາສາມປີ. ອັດຕາດອກເບ້ຍແມ່ນ 3%, 4% ແລະ 5% ຕໍ່ປີ. ມູນຄ່າຫຼັງຈາກສາມປີແມ່ນເທົ່າໃດ?"

#. KBYvX
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3156358\n"
"help.text"
msgid "<input>=FVSCHEDULE(1000;{0.03;0.04;0.05})</input> returns 1124.76."
msgstr "<input>=FVSCHEDULE(1000;{0.03;0.04;0.05})</input> ສົ່ງຄືນ 1124.76."

#. fi9VS
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"bm_id3156435\n"
"help.text"
msgid "<bookmark_value>calculating;number of payment periods</bookmark_value>  <bookmark_value>payment periods;number of</bookmark_value>  <bookmark_value>number of payment periods</bookmark_value>  <bookmark_value>NPER function</bookmark_value>"
msgstr "<bookmark_value>ການຄິດໄລ່;ຈຳນວນງວດການຈ່າຍ</bookmark_value>  <bookmark_value>ງວດການຈ່າຍ;ຈຳນວນຂອງ</bookmark_value>  <bookmark_value>ຈຳນວນງວດການຈ່າຍ</bookmark_value>  <bookmark_value>ຟັງຊັນ NPER</bookmark_value>"

#. NCCXK
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"hd_id3156435\n"
"help.text"
msgid "NPER"
msgstr "NPER"

#. BDUmA
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3152363\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ZZR\">Returns the number of periods for an investment based on periodic, constant payments and a constant interest rate.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ZZR\">ສົ່ງຄືນຈຳນວນງວດສຳລັບການລົງທຶນ ໂດຍອີງໃສ່ການຈ່າຍທີ່ສະໝໍ່າສະເໝີ ແລະ ອັດຕາດອກເບ້ຍຄົງທີ່.</ahelp>"

#. Fopz2
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3155934\n"
"help.text"
msgid "NPER(Rate; Pmt; PV [ ; [ FV ] [ ; Type ] ])"
msgstr "NPER(Rate; Pmt; PV [ ; [ FV ] [ ; Type ] ])"

#. X44J9
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3155946\n"
"help.text"
msgid "<emph>Rate</emph> is the periodic interest rate."
msgstr "<emph>Rate</emph> ແມ່ນອັດຕາດອກເບ້ຍຕໍ່ງວດ."

#. 7FVrB
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3149042\n"
"help.text"
msgid "<emph>Pmt</emph> is the constant annuity paid in each period."
msgstr "<emph>Pmt</emph> ແມ່ນເງິນງວດຄົງທີ່ທີ່ຈ່າຍໃນແຕ່ລະງວດ."

#. eSocM
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3153134\n"
"help.text"
msgid "<emph>PV</emph> is the present value (cash value) in a sequence of payments."
msgstr "<emph>PV</emph> ແມ່ນມູນຄ່າປັດຈຸບັນ (ມູນຄ່າເງິນສົດ) ຂອງຊຸດການຈ່າຍເງິນ."

#. BqqW6
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3154398\n"
"help.text"
msgid "<emph>FV</emph> (optional) is the future value, which is reached at the end of the last period."
msgstr "<emph>FV</emph> (ທາງເລືອກ) ແມ່ນມູນຄ່າໃນອະນາຄົດ ທີ່ຕ້ອງການໃຫ້ບັນລຸເມື່ອສິ້ນສຸດງວດສຸດທ້າຍ."

#. Cc3zB
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3145127\n"
"help.text"
msgid "<emph>Type</emph> (optional) is the due date of the payment at the beginning or at the end of the period."
msgstr "<emph>Type</emph> (ທາງເລືອກ) ແມ່ນກຳນົດເວລາການຈ່າຍ, ບໍ່ວ່າຈະແມ່ນຕົ້ນງວດ ຫຼື ທ້າຍງວດ."

#. E89kG
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3147378\n"
"help.text"
msgid "How many payment periods does a payment period cover with a periodic interest rate of 6%, a periodic payment of 153.75 currency units and a present cash value of 2.600 currency units."
msgstr "ມີຈຳນວນງວດການຈ່າຍທັງໝົດຈັກງວດ ຖ້າອັດຕາດອກເບ້ຍແມ່ນ 6%, ມີການຈ່າຍງວດລະ 153.75 ຫົວໜ່ວຍເງິນຕາ ແລະ ມູນຄ່າປັດຈຸບັນແມ່ນ 2,600 ຫົວໜ່ວຍເງິນຕາ."

#. xRja3
#: 04060118.xhp
msgctxt ""
"04060118.xhp\n"
"par_id3156171\n"
"help.text"
msgid "<input>=NPER(6%;153.75;2600)</input> = -12,02. The payment period covers 12.02 periods."
msgstr "<input>=NPER(6%;153.75;2600)</input> = -12.02. ດັ່ງນັ້ນໄລຍະເວລາການຈ່າຍແມ່ນ 12.02 ງວດ."

