#. tByUr
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id701665407334603\n"
"help.text"
msgid "<variable id=\"seenotebelow\">See note below.</variable>"
msgstr "<variable id=\"seenotebelow\">ເບິ່ງໝາຍເຫດຂ້າງລຸ່ມ.</variable>"

#. AAKPP
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id421662919561954\n"
"help.text"
msgid "is below average"
msgstr "ຕ່ຳກວ່າຄ່າສະເລ່ຍ"

#. DAPwV
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id661662919561956\n"
"help.text"
msgid "The cell value is strictly less than the average of the cell range values."
msgstr "ຄ່າໃນຫ້ອງແມ່ນໜ້ອຍກວ່າຄ່າສະເລ່ຍຂອງຄ່າໃນຊ່ວງຫ້ອງນັ້ນຢ່າງແທ້ຈິງ."

#. 5cN4q
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id831662919693474\n"
"help.text"
msgid "is above or equal average"
msgstr "ສູງກວ່າ ຫຼື ເທົ່າກັບຄ່າສະເລ່ຍ"

#. dk8XB
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id71662919693475\n"
"help.text"
msgid "The cell value is greater or equal than the average of the cell range values."
msgstr "ຄ່າໃນຫ້ອງແມ່ນຫຼາຍກວ່າ ຫຼື ເທົ່າກັບຄ່າສະເລ່ຍຂອງຄ່າໃນຊ່ວງຫ້ອງນັ້ນ."

#. HuZ9i
