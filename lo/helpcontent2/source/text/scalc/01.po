#. tFAGE
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"tit\n"
"help.text"
msgid "Pivot Table"
msgstr "ຕາຕະລາງພິວອດ"

#. vhUe4
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"bm_id2306894\n"
"help.text"
msgid "<bookmark_value>pivot table function;show details</bookmark_value>         <bookmark_value>pivot table function;drill down</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນຕາຕະລາງພິວອດ;ສະແດງລາຍລະອຽດ</bookmark_value>         <bookmark_value>ຟັງຊັນຕາຕະລາງພິວອດ;ເຈາະລຶກຂໍ້ມູນ</bookmark_value>"

#. n4NPA
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3149165\n"
"help.text"
msgid "Pivot Table"
msgstr "ຕາຕະລາງພິວອດ"

#. eBUzN
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3155922\n"
"help.text"
msgid "<ahelp hid=\".uno:DataPilotExec\">Specify the layout of the table that is generated by the pivot table.</ahelp>"
msgstr "<ahelp hid=\".uno:DataPilotExec\">ກຳນົດຮູບແບບຂອງຕາຕະລາງທີ່ສ້າງຂຶ້ນໂດຍຕາຕະລາງພິວອດ.</ahelp>"

#. 7YRp4
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3148798\n"
"help.text"
msgid "The pivot table displays data fields as buttons which you can drag and drop to define the pivot table."
msgstr "ຕາຕະລາງພິວອດຈະສະແດງຟິວຂໍ້ມູນເປັນປຸ່ມ ເຊິ່ງທ່ານສາມາດລາກ ແລະ ວາງ ເພື່ອກຳນົດຕາຕະລາງພິວອດໄດ້."

#. FCdA2
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3154908\n"
"help.text"
msgid "Layout"
msgstr "ຮູບແບບ"

#. DkMQE
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3150768\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/listbox-fields\">To define the layout of a pivot table, drag and drop data field buttons onto the <emph>Filters, Row Fields, Column Fields</emph> and <emph>Data Fields</emph> areas.</ahelp> You can also use drag and drop to rearrange the data fields on a pivot table."
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/listbox-fields\">ເພື່ອກຳນົດຮູບແບບຂອງຕາຕະລາງພິວອດ, ໃຫ້ລາກ ແລະ ວາງປຸ່ມຟິວຂໍ້ມູນລົງໃນພື້ນທີ່ <emph>ຕົວກັ່ນຕອງ, ຟິວແຖວ, ຟິວຄໍລຳ</emph> ແລະ <emph>ຟິວຂໍ້ມູນ</emph>.</ahelp> ທ່ານຍັງສາມາດໃຊ້ການລາກ ແລະ ວາງ ເພື່ອຈັດລຽງຟິວຂໍ້ມູນໃນຕາຕະລາງພິວອດໃໝ່ໄດ້."

#. GNMGf
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3147229\n"
"help.text"
msgid "$[officename] automatically adds a caption to buttons that are dragged into the <emph>Data Fields</emph>area. The caption contains the name of the data field as well as the formula that created the data."
msgstr "$[officename] ຈະເພີ່ມຄຳອະທິບາຍໃຫ້ກັບປຸ່ມທີ່ຖືກລາກເຂົ້າໄປໃນພື້ນທີ່ <emph>ຟິວຂໍ້ມູນ</emph> ໂດຍອັດຕະໂນມັດ. ຄຳອະທິບາຍຈະປະກອບດ້ວຍຊື່ຂອງຟິວຂໍ້ມູນ ລວມທັງສູດທີ່ສ້າງຂໍ້ມູນນັ້ນຂຶ້ນມາ."

#. cpHDx
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3145749\n"
"help.text"
msgid "To change the function that is used by a data field, double-click a button in the <emph>Data Fields</emph> area to open the <link href=\"text/scalc/01/12090105.xhp\">Data Field</link> dialog. You can also double-click buttons in the <emph>Row Fields</emph> or <emph>Column Fields</emph> areas."
msgstr "ເພື່ອປ່ຽນຟັງຊັນທີ່ໃຊ້ໂດຍຟິວຂໍ້ມູນ, ໃຫ້ກົດສອງຄັ້ງທີ່ປຸ່ມໃນພື້ນທີ່ <emph>ຟິວຂໍ້ມູນ</emph> ເພື່ອເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/scalc/01/12090105.xhp\">ຟິວຂໍ້ມູນ</link>. ທ່ານຍັງສາມາດກົດສອງຄັ້ງທີ່ປຸ່ມໃນພື້ນທີ່ <emph>ຟິວແຖວ</emph> ຫຼື <emph>ຟິວຄໍລຳ</emph> ໄດ້ເຊັ່ນກັນ."

#. xeC2z
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3154944\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

#. ExoJS
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3145647\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/more\">Displays or hides additional options for defining the pivot table.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/more\">ສະແດງ ຫຼື ເເຊື່ອງຕົວເລືອກເພີ່ມເຕີມສຳລັບການກຳນົດຕາຕະລາງພິວອດ.</ahelp>"

#. RE6UY
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3147364\n"
"help.text"
msgid "Ignore empty rows"
msgstr "ບໍ່ສົນໃຈແຖວຫວ່າງ"

#. NqVFr
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3154022\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-ignore-empty-rows\">Ignores empty fields in the data source.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-ignore-empty-rows\">ບໍ່ສົນໃຈຟິວທີ່ຫວ່າງເປົ່າໃນແຫຼ່ງຂໍ້ມູນ.</ahelp>"

#. YtUZx
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3155114\n"
"help.text"
msgid "Identify categories"
msgstr "ລະບຸໝວດໝູ່"

#. 9RtuT
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3145257\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-identify-categories\">Automatically assigns rows without labels to the category of the row above.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-identify-categories\">ກຳນົດແຖວທີ່ບໍ່ມີປ້າຍຊື່ໃຫ້ເຂົ້າໃນໝວດໝູ່ຂອງແຖວທີ່ຢູ່ຂ້າງເທິງໂດຍອັດຕະໂນມັດ.</ahelp>"

#. BBW6E
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3149207\n"
"help.text"
msgid "Show totals column"
msgstr "ສະແດງຄໍລຳຜົນລວມ"

#. n5fSF
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3166426\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-total-columns\">Calculates and displays the grand total of the column calculation.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-total-columns\">ຄຳນວນ ແລະ ສະແດງຜົນລວມທັງໝົດຂອງການຄຳນວນຄໍລຳ.</ahelp>"

#. iUvJB
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"hd_id3150364\n"
"help.text"
msgid "Show totals row"
msgstr "ສະແດງແຖວຜົນລວມ"

#. QazUm
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_id3152583\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-total-rows\">Calculates and displays the grand total of the row calculation.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pivottablelayoutdialog/check-total-rows\">ຄຳນວນ ແລະ ສະແດງຜົນລວມທັງໝົດຂອງການຄຳນວນແຖວ.</ahelp>"

#. D5zQr
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN10897\n"
"help.text"
msgid "Add filter"
msgstr "ເພີ່ມຕົວກັ່ນຕອງ"

#. isFp2
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN1089B\n"
"help.text"
msgid "<ahelp hid=\".\">Adds a Filter button to pivot tables that are based on spreadsheet data.</ahelp>"
msgstr "<ahelp hid=\".\">ເພີ່ມປຸ່ມຕົວກັ່ນຕອງໃຫ້ກັບຕາຕະລາງພິວອດທີ່ອີງຕາມຂໍ້ມູນສະເປຣດຊີດ.</ahelp>"

#. nG8PA
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108B2\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the Filter dialog.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບຕົວກັ່ນຕອງ.</ahelp>"

#. ky7dW
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108C9\n"
"help.text"
msgid "Enable drill to details"
msgstr "ເປີດໃຊ້ການເຈາະລຶກລາຍລະອຽດ"

#. ToMtU
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108CD\n"
"help.text"
msgid "<ahelp hid=\".\">Select this check box and double-click an item label in the table to show or hide details for the item. Clear this check box and double-click a cell in the table to edit the contents of the cell.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກກ່ອງໝາຍນີ້ ແລະ ກົດສອງຄັ້ງທີ່ປ້າຍຊື່ລາຍການໃນຕາຕະລາງເພື່ອສະແດງ ຫຼື ເຊື່ອງລາຍລະອຽດສຳລັບລາຍການ. ຫາກຍົກເລີກການເລືອກກ່ອງໝາຍນີ້ ແລະ ກົດສອງຄັ້ງທີ່ເຊວໃນຕາຕະລາງ ຈະເປັນການແກ້ໄຂເນື້ອໃນຂອງເຊວ.</ahelp>"

#. VeDcj
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108DC\n"
"help.text"
msgid "To examine details inside a pivot table, do one of the following:"
msgstr "ເພື່ອຕວດສອບລາຍລະອຽດພາຍໃນຕາຕະລາງພິວອດ, ໃຫ້ປະຕິບັດຢ່າງໃດຢ່າງໜຶ່ງດັ່ງນີ້:"

#. 4BfPW
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108E6\n"
"help.text"
msgid "Select a range of cells and choose <emph>Data - Group and Outline - Show Details</emph>."
msgstr "ເລືອກຊ່ວງເຊວ ແລະ ເລືອກ <emph>ຂໍ້ມູນ - ຈັດກຸ່ມ ແລະ ເຄົ້າຮ່າງ - ສະແດງລາຍລະອຽດ</emph>."

#. mogzB
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108EE\n"
"help.text"
msgid "Double-click a field in the table."
msgstr "ກົດສອງຄັ້ງທີ່ຟິວໃນຕາຕະລາງ."

#. CaxVm
#: 12090102.xhp
msgctxt ""
"12090102.xhp\n"
"par_idN108F1\n"
"help.text"
msgid "If you double-click a field which has adjacent fields at the same level, the <emph>Show Detail</emph> dialog opens:"
