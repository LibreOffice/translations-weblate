"par_id3150332\n"
"help.text"
msgid "<input>=ODDLPRICE(\"1999-02-07\";\"1999-06-15\";\"1998-10-15\"; 0.0375; 0.0405;100;2;0)</input>  returns 99.87829."
msgstr "<input>=ODDLPRICE(\"1999-02-07\";\"1999-06-15\";\"1998-10-15\"; 0.0375; 0.0405;100;2;0)</input> ສົ່ງຄືນ 99.87829."

