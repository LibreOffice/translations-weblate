msgctxt ""
"04080000.xhp\n"
"hd_id3154126\n"
"help.text"
msgid "<variable id=\"function_list_title\"><link href=\"text/scalc/01/04080000.xhp\">Function List</link></variable>"
msgstr "<variable id=\"function_list_title\"><link href=\"text/scalc/01/04080000.xhp\">ລາຍການຟັງຊັນ</link></variable>"

#. GLKJp
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"par_id3151118\n"
"help.text"
msgid "<variable id=\"function_list_text\"><ahelp hid=\"HID_SC_FUNCTIONLIST\">Opens the Function List deck of the Sidebar, which displays all functions that can be inserted into your document.</ahelp></variable> The <emph>Function List</emph> deck is similar to the <emph>Functions</emph> tab page of the <link href=\"text/scalc/01/04060000.xhp\">Function Wizard</link>. The functions are inserted with placeholders to be replaced with your own values."
msgstr "<variable id=\"function_list_text\"><ahelp hid=\"HID_SC_FUNCTIONLIST\">ເປີດແຜງລາຍການຟັງຊັນຂອງແຖບຂ້າງ, ເຊິ່ງສະແດງຟັງຊັນທັງໝົດທີ່ສາມາດແຊກລົງໃນເອກະສານຂອງທ່ານໄດ້.</ahelp></variable> ແຜງ <emph>ລາຍການຟັງຊັນ</emph> ນີ້ຈະຄ້າຍຄືກັບໜ້າແຖບ <emph>ຟັງຊັນ</emph> ຂອງ <link href=\"text/scalc/01/04060000.xhp\">ຕົວຊ່ວຍສ້າງຟັງຊັນ</link>. ຟັງຊັນຕ່າງໆ ຈະຖືກແຊກພ້ອມກັບຕົວແທນຂໍ້ຄວາມ (placeholder) ເພື່ອໃຫ້ທ່ານປ່ຽນແທນດ້ວຍຄ່າຂອງທ່ານເອງ."

#. J3Ts4
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"par_id3152576\n"
"help.text"
msgid "The <emph>Function List</emph> window is a resizable <link href=\"text/shared/00/00000005.xhp#docking\">dockable window</link>. Use it to quickly enter functions in the spreadsheet. By double-clicking an entry in the functions list, the respective function is directly inserted with all parameters."
msgstr "ໜ້າຕ່າງ <emph>ລາຍການຟັງຊັນ</emph> ແມ່ນ <link href=\"text/shared/00/00000005.xhp#docking\">ໜ້າຕ່າງທີ່ສາມາດຍຶດຕິດໄດ້</link> ແລະ ປັບຂະໜາດໄດ້. ໃຊ້ສິ່ງນີ້ເພື່ອປ້ອນຟັງຊັນລົງໃນສະເປຣດຊີດໄດ້ຢ່າງວ່ອງໄວ. ໂດຍການດັບເບິນຄລິກທີ່ລາຍການໃນລາຍການຟັງຊັນ, ຟັງຊັນນັ້ນຈະຖືກແຊກໂດຍກົງພ້ອມກັບພາຣາມິເຕີທັງໝົດ."

#. tu2NZ
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"hd_id3145799\n"
"help.text"
msgid "Category List"
msgstr "ລາຍການໝວດໝູ່"

#. ep6FT
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"hd_id3153160\n"
"help.text"
msgid "Function List"
msgstr "ລາຍການຟັງຊັນ"

#. pz87U
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"par_id3149412\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/functionpanel/funclist\">Displays the available functions.</ahelp> When you select a function, the area below the list box displays a short description. To insert the selected function double-click it or click the <emph>Insert Function into calculation sheet</emph> icon."
msgstr "<ahelp hid=\"modules/scalc/ui/functionpanel/funclist\">ສະແດງຟັງຊັນທີ່ມີໃຫ້ໃຊ້.</ahelp> ເມື່ອທ່ານເລືອກຟັງຊັນໃດໜຶ່ງ, ພື້ນທີ່ຂ້າງລຸ່ມລາຍການຈະສະແດງຄຳອະທິບາຍສັ້ນໆ. ເພື່ອແຊກຟັງຊັນທີ່ເລືອກ ໃຫ້ດັບເບິນຄລິກທີ່ມັນ ຫຼື ຄລິກໄອຄອນ <emph>ແຊກຟັງຊັນລົງໃນຊີດຄຳນວນ</emph>."

#. iSekQ
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"hd_id3146971\n"
"help.text"
msgid "Insert Function into calculation sheet"
msgstr "ແຊກຟັງຊັນລົງໃນຊີດຄຳນວນ"

#. UPFoX
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"par_id3150043\n"
"help.text"
msgid "<image id=\"img_id3159267\" src=\"sc/res/fx.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3159267\">Icon Insert Function</alt></image>"
msgstr "<image id=\"img_id3159267\" src=\"sc/res/fx.png\" width=\"1cm\" height=\"1cm\"><alt id=\"alt_id3159267\">ໄອຄອນ ແຊກຟັງຊັນ</alt></image>"

#. 4Hfgb
#: 04080000.xhp
msgctxt ""
"04080000.xhp\n"
"par_id3147345\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/functionpanel/insert\">Inserts the selected function into the document.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/functionpanel/insert\">ແຊກຟັງຊັນທີ່ເລືອກລົງໃນເອກະສານ.</ahelp>"

#. fMNek
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"tit\n"
"help.text"
msgid "External Links"
msgstr "ການເຊື່ອມຕໍ່ພາຍນອກ"

#. YRESE
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"hd_id3145785\n"
"help.text"
msgid "<link href=\"text/scalc/01/04090000.xhp\">External Links</link>"
msgstr "<link href=\"text/scalc/01/04090000.xhp\">ການເຊື່ອມຕໍ່ພາຍນອກ</link>"

#. SaAut
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3149262\n"
"help.text"
msgid "<ahelp hid=\".uno:InsertExternalDataSourc\">Inserts data from an HTML, Calc, CSV or Excel file into the current sheet as a link. The data must be located within a named range.</ahelp>"
msgstr "<ahelp hid=\".uno:InsertExternalDataSourc\">ແຊກຂໍ້ມູນຈາກໄຟລ໌ HTML, Calc, CSV ຫຼື Excel ລົງໃນຊີດປັດຈຸບັນໃນຮູບແບບລິ້ງ. ຂໍ້ມູນນັ້ນຕ້ອງຕັ້ງຢູ່ໃນຊ່ວງທີ່ຕັ້ງຊື່ໄວ້.</ahelp>"

#. Fnwpz
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3153192\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/externaldata/browse\" visibility=\"hidden\">Open a file dialog to locate the file containing the data you want to insert.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/externaldata/browse\" visibility=\"hidden\">ເປີດກ່ອງໂຕ້ຕອບໄຟລ໌ເພື່ອຄົ້ນຫາໄຟລ໌ທີ່ມີຂໍ້ມູນທີ່ທ່ານຕ້ອງການແຊກ.</ahelp>"

#. ZYJLh
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"hd_id3146984\n"
"help.text"
msgid "URL of external data source."
msgstr "URL ຂອງແຫຼ່ງຂໍ້ມູນພາຍນອກ."

#. UPCaZ
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3145366\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/externaldata/url\">Enter the URL or the file name that contains the data that you want to insert, and then press Enter.</ahelp> Alternatively, click <emph>Browse</emph> button to select the file name from a file dialog that opens. Only then will the URL be requested from the network or file system."
msgstr "<ahelp hid=\"modules/scalc/ui/externaldata/url\">ປ້ອນ URL ຫຼື ຊື່ໄຟລ໌ທີ່ມີຂໍ້ມູນທີ່ທ່ານຕ້ອງການແຊກ, ຈາກນັ້ນກົດ Enter.</ahelp> ຫຼື ອີກທາງເລືອກໜຶ່ງ, ໃຫ້ຄລິກປຸ່ມ <emph>ເລືອກເບິ່ງ</emph> ເພື່ອເລືອກຊື່ໄຟລ໌ຈາກກ່ອງໂຕ້ຕອບ. ຫຼັງຈາກນັ້ນ URL ຈະຖືກຮ້ອງຂໍຈາກເຄືອຂ່າຍ ຫຼື ລະບົບໄຟລ໌."

#. UBArX
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id621519313666202\n"
"help.text"
msgid "<link href=\"text/shared/00/00000208.xhp\">A dialog for CSV data import</link> appears when linking to external CSV file."
msgstr "<link href=\"text/shared/00/00000208.xhp\">ກ່ອງໂຕ້ຕອບສຳລັບການນຳເຂົ້າຂໍ້ມູນ CSV</link> ຈະປະກົດຂຶ້ນເມື່ອມີການລິ້ງຫາໄຟລ໌ CSV ພາຍນອກ."

#. dEiJ7
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"hd_id3145251\n"
"help.text"
msgid "Available tables/ranges"
msgstr "ຕາຕະລາງ/ຊ່ວງ ທີ່ມີໃຫ້ໃຊ້"

#. RyXiF
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3147397\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/externaldata/ranges\">Select the table or the data range that you want to insert.</ahelp> If the selected Calc or Excel document contains no named range, spreadsheet data cannot be inserted and <emph>OK</emph> button will remain inactive"
msgstr "<ahelp hid=\"modules/scalc/ui/externaldata/ranges\">ເລືອກຕາຕະລາງ ຫຼື ຊ່ວງຂໍ້ມູນທີ່ທ່ານຕ້ອງການແຊກ.</ahelp> ຖ້າເອກະສານ Calc ຫຼື Excel ທີ່ເລືອກບໍ່ມີຊ່ວງທີ່ຕັ້ງຊື່ໄວ້, ຂໍ້ມູນສະເປຣດຊີດຈະບໍ່ສາມາດແຊກໄດ້ ແລະ ປຸ່ມ <emph>ຕົກລົງ</emph> ຈະຍັງຄົງໃຊ້ງານບໍ່ໄດ້."

#. PVMSv
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"hd_id3154492\n"
"help.text"
msgid "Update every"
msgstr "ອັບເດດທຸກໆ"

#. zX8A3
#: 04090000.xhp
msgctxt ""
"04090000.xhp\n"
"par_id3154017\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/externaldata/delay\">Enter the number of seconds to wait before the external data are reloaded into the current document.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/externaldata/delay\">ປ້ອນຈຳນວນວິນາທີທີ່ຈະໃຫ້ລໍຖ້າ ກ່ອນທີ່ຂໍ້ມູນພາຍນອກຈະຖືກໂຫຼດໃໝ່ລົງໃນເອກະສານປັດຈຸບັນ.</ahelp>"

#. sTDFW
