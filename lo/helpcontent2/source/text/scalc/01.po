msgid "Formulas"
msgstr "ສູດ"

#. Poqcs
#: 12060000.xhp
msgctxt ""
"12060000.xhp\n"
"par_id3151073\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/formulas\">Enter the cell references for the cells containing the formulas that you want to use in the multiple operation.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/formulas\">ປ້ອນການອ້າງອີງເຊວສຳລັບເຊວທີ່ມີສູດທີ່ທ່ານຕ້ອງການໃຊ້ໃນການດຳເນີນການຫຼາຍຢ່າງ.</ahelp>"

#. qCM97
#: 12060000.xhp
msgctxt ""
"12060000.xhp\n"
"hd_id3154729\n"
"help.text"
msgid "Row"
msgstr "ແຖວ"

#. CxUyP
#: 12060000.xhp
msgctxt ""
"12060000.xhp\n"
"par_id3148456\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/row\">Enter the input cell reference that you want to use as a variable for the rows in the data table.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/row\">ປ້ອນການອ້າງອີງເຊວຂາເຂົ້າທີ່ທ່ານຕ້ອງການໃຊ້ເປັນຕົວປ່ຽນສຳລັບແຖວໃນຕາຕະລາງຂໍ້ມູນ.</ahelp>"

#. EBLEy
#: 12060000.xhp
msgctxt ""
"12060000.xhp\n"
"hd_id3150718\n"
"help.text"
msgid "Column"
msgstr "ຄໍລຳ"

#. 3Effu
#: 12060000.xhp
msgctxt ""
"12060000.xhp\n"
"par_id3150327\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/col\">Enter the input cell reference that you want to use as a variable for the columns in the data table.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/multipleoperationsdialog/col\">ປ້ອນການອ້າງອີງເຊວຂາເຂົ້າທີ່ທ່ານຕ້ອງການໃຊ້ເປັນຕົວປ່ຽນສຳລັບຄໍລຳໃນຕາຕະລາງຂໍ້ມູນ.</ahelp>"

#. pfxVH
