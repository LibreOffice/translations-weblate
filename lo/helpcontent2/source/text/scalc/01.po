msgctxt ""
"04060185.xhp\n"
"par_id3153976\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_RANG\">Returns the rank of a number in a sample.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_RANG\">ສົ່ງຄືນອັນດັບຂອງຕົວເລກໃນກຸ່ມຕົວຢ່າງ.</ahelp>"

