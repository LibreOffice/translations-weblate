"02140600.xhp\n"
"par_id3149126\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/filldlg/month\">Use the <emph>Date</emph> series type and this option to form a series which unit of <emph>Increment</emph> is month.</ahelp>"
