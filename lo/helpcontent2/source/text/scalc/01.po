"bm_id361708283183878\n"
"help.text"
msgid "<bookmark_value>FILTER function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ FILTER</bookmark_value>"

#. ymoUm
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"hd_id901708806478126\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/func_filter.xhp\">FILTER</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_filter.xhp\">FILTER</link></variable>"

#. dxbQ9
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Filters a data range or array based on specified conditions."
msgstr "ກັ່ນຕອງຊ່ວງຂໍ້ມູນ ຫຼື ອາເຣ ໂດຍອີງໃສ່ເງື່ອນໄຂທີ່ລະບຸ."

#. 3zvtL
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id211708281649651\n"
"help.text"
msgid "=FILTER( Range; Criteria [; Return if empty])"
msgstr "=FILTER( ຊ່ວງຂໍ້ມູນ; ເງື່ອນໄຂ [; ຄ່າທີ່ສົ່ງຄືນຖ້າຫວ່າງເປົ່າ])"

#. SGrA5
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id411709395137111\n"
"help.text"
msgid "<emph>Range</emph>: The array or range to filter."
msgstr "<emph>ຊ່ວງຂໍ້ມູນ</emph>: ອາເຣ ຫຼື ຊ່ວງຂໍ້ມູນທີ່ຈະກັ່ນຕອງ."

#. EELnw
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id471709395141324\n"
"help.text"
msgid "<emph>Criteria</emph>: A boolean array whose height (filtering by columns) or width (filtering by rows) is the same as the array, used to select data from the <emph>Range</emph>."
msgstr "<emph>ເງື່ອນໄຂ</emph>: ອາເຣຄ່າບູລີນ (boolean) ທີ່ມີລວງສູງ (ກັ່ນຕອງຕາມຄໍລຳ) ຫຼື ລວງກວ້າງ (ກັ່ນຕອງຕາມແຖວ) ເທົ່າກັບອາເຣນັ້ນ, ໃຊ້ເພື່ອເລືອກຂໍ້ມູນຈາກ <emph>ຊ່ວງຂໍ້ມູນ</emph>."

#. ZcP2E
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id421709395146863\n"
"help.text"
msgid "<emph>Result if empty</emph>: (optional) the value to return if all values in the <emph>Criteria</emph> array are empty (filter return nothing)."
msgstr "<emph>ຜົນໄດ້ຮັບຖ້າຫວ່າງເປົ່າ</emph>: (ທາງເລືອກ) ຄ່າທີ່ຈະສົ່ງຄືນຖ້າທຸກຄ່າໃນອາເຣ <emph>ເງື່ອນໄຂ</emph> ຫວ່າງເປົ່າ (ກັ່ນຕອງແລ້ວບໍ່ພົບຫຍັງ)."

#. AFtpH
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id21709506838932\n"
"help.text"
msgid "<input>{=FILTER(A2:C13;A2:A13>50)}</input> returns the array containing all grades with Maths grade above 50. Note that this is an <link href=\"text/scalc/01/04060107.xhp#creating_array_formulas\">array formula</link>."
msgstr "<input>{=FILTER(A2:C13;A2:A13>50)}</input> ສົ່ງຄືນອາເຣທີ່ມີຄະແນນທັງໝົດທີ່ມີຄະແນນຄະນິດສາດສູງກວ່າ 50. ໝາຍເຫດ ວ່ານີ້ແມ່ນ <link href=\"text/scalc/01/04060107.xhp#creating_array_formulas\">ສູດອາເຣ</link>."

#. METQ9
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id561709507935610\n"
"help.text"
msgid "<input>{=FILTER(A2:C13;B2:B13>90;\"No results\")}</input>  Returns the string \"No results\", since no grade on Physics is above 90."
msgstr "<input>{=FILTER(A2:C13;B2:B13>90;\"No results\")}</input> ສົ່ງຄືນຂໍ້ຄວາມ \"No results\", ເນື່ອງຈາກບໍ່ມີຄະແນນຟີຊິກໃດທີ່ສູງກວ່າ 90."

#. q34Yg
#: func_filter.xhp
msgctxt ""
"func_filter.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/FILTER\">FILTER wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/FILTER\">ໜ້າ wiki ຂອງ FILTER</link>."

