#. XdnQ3
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3148925\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ERSETZEN\">Replaces part of a text string with a different text string.</ahelp> This function can be used to replace both characters and numbers (which are automatically converted to text). The result of the function is always displayed as text. If you intend to perform further calculations with a number which has been replaced by text, you will need to convert it back to a number using the <link href=\"text/scalc/01/04060110.xhp\">VALUE</link> function."
msgstr "<ahelp hid=\"HID_FUNC_ERSETZEN\">ແທນທີ່ບາງສ່ວນຂອງຂໍ້ຄວາມດ້ວຍຂໍ້ຄວາມອື່ນ.</ahelp> ຟັງຊັນນີ້ສາມາດໃຊ້ເພື່ອແທນທີ່ໄດ້ທັງຕົວອັກສອນ ແລະ ຕົວເລກ (ເຊິ່ງຈະຖືກປ່ຽນເປັນຂໍ້ຄວາມໂດຍອັດຕະໂນມັດ). ຜົນລັດຂອງຟັງຊັນຈະສະແດງເປັນຂໍ້ຄວາມສະເໝີ. ຖ້າທ່ານຕ້ອງການຄິດໄລ່ຕໍ່ດ້ວຍຕົວເລກທີ່ຖືກແທນທີ່ດ້ວຍຂໍ້ຄວາມແລ້ວ, ທ່ານຈະຕ້ອງປ່ຽນມັນກັບມາເປັນຕົວເລກໂດຍໃຊ້ຟັງຊັນ <link href=\"text/scalc/01/04060110.xhp\">VALUE</link>."

#. 2Avev
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3158426\n"
"help.text"
msgid "Any text containing numbers must be enclosed in quotation marks if you do not want it to be interpreted as a number and automatically converted to text."
msgstr "ຂໍ້ຄວາມໃດໆທີ່ມີຕົວເລກຕ້ອງໃສ່ໃນເຄື່ອງໝາຍຄຳເວົ້າ ຖ້າທ່ານບໍ່ຕ້ອງການໃຫ້ມັນຖືກຕີຄວາມໝາຍເປັນຕົວເລກ ແລະ ຖືກປ່ຽນເປັນຂໍ້ຄວາມໂດຍອັດຕະໂນມັດ."

#. gK8Lx
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3147286\n"
"help.text"
msgid "REPLACE(\"Text\"; Position; Length; \"NewText\")"
msgstr "REPLACE(\"ຂໍ້ຄວາມ\"; ຕຳແໜ່ງ; ຄວາມຍາວ; \"ຂໍ້ຄວາມໃໝ່\")"

#. Eactn
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3149797\n"
"help.text"
msgid "<emph>Text</emph> refers to text of which a part will be replaced."
msgstr "<emph>ຂໍ້ຄວາມ</emph> ໝາຍເຖິງຂໍ້ຄວາມທີ່ບາງສ່ວນຈະຖືກແທນທີ່."

#. haBeo
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3166451\n"
"help.text"
msgid "<emph>Position</emph> refers to the position within the text where the replacement will begin."
msgstr "<emph>ຕຳແໜ່ງ</emph> ໝາຍເຖິງຕຳແໜ່ງພາຍໃນຂໍ້ຄວາມທີ່ຈະເລີ່ມການແທນທີ່."

#. XtiHF
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3156040\n"
"help.text"
msgid "<emph>Length</emph> is the number of characters in <emph>Text</emph> to be replaced."
msgstr "<emph>ຄວາມຍາວ</emph> ແມ່ນຈຳນວນຕົວອັກສອນໃນ <emph>ຂໍ້ຄວາມ</emph> ທີ່ຈະຖືກແທນທີ່."

#. 3SvYA
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3159188\n"
"help.text"
msgid "<emph>NewText</emph> refers to the text which replaces <emph>Text</emph>."
msgstr "<emph>ຂໍ້ຄວາມໃໝ່</emph> ໝາຍເຖິງຂໍ້ຄວາມທີ່ຈະມານຳໃຊ້ແທນ <emph>ຂໍ້ຄວາມ</emph> ເດີມ."

#. 6ErbB
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id3154096\n"
"help.text"
msgid "<item type=\"input\">=REPLACE(\"1234567\";1;1;\"444\")</item> returns \"444234567\". One character at position 1 is replaced by the complete <item type=\"literal\">NewText</item>."
msgstr "<item type=\"input\">=REPLACE(\"1234567\";1;1;\"444\")</item> ສົ່ງຄືນ \"444234567\". ຕົວອັກສອນໜຶ່ງຕົວຢູ່ຕຳແໜ່ງທີ 1 ຖືກແທນທີ່ດ້ວຍ <item type=\"literal\">ຂໍ້ຄວາມໃໝ່</item> ທັງໝົດ."

#. AVwGE
#: func_replace.xhp
msgctxt ""
"func_replace.xhp\n"
"par_id701677016652715\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/REPLACE\">REPLACE wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/REPLACE\">ໜ້າ ວິກິ REPLACE</link>."

