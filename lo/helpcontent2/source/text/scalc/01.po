#. mvcz3
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id741727205444930\n"
"help.text"
msgid "The keyword <literal>[#Headers]</literal>  references the row of field names (column labels). It is the first row of the database range."
msgstr "ຄຳສຳຄັນ <literal>[#Headers]</literal> ອ້າງອີງເຖິງແຖວຂອງຊື່ຊ່ອງຂໍ້ມູນ (ປ້າຍຖັນ). ມັນແມ່ນແຖວທຳອິດຂອງຊ່ວງຖານຂໍ້ມູນ."

#. RwqwF
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id701727205544887\n"
"help.text"
msgid "If the database range has no labels row defined (Contains column labels), a #REF!  error is generated."
msgstr "ຖ້າຊ່ວງຖານຂໍ້ມູນບໍ່ມີແຖວປ້າຍທີ່ກຳນົດໄວ້ (ມີປ້າຍຖັນ), ຂໍ້ຜິດພາດ #REF! ຈະຖືກສ້າງຂຶ້ນ."

#. rNQVw
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id161727205452550\n"
"help.text"
msgid "The expression <literal>myData[#Headers]</literal> references the cells <literal>A1:D1</literal>."
msgstr "ນິພົດ <literal>myData[#Headers]</literal> ອ້າງອີງເຖິງຫ້ອງ <literal>A1:D1</literal>."

#. AXxRF
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id451727205608044\n"
"help.text"
msgid "<literal>[#Data]</literal>"
msgstr "<literal>[#Data]</literal>"

#. 8AhTw
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id741727205622598\n"
"help.text"
msgid "The keyword <literal>[#Data]</literal> references the data records of the database range, excluding the column label row and the totals row."
msgstr "ຄຳສຳຄັນ <literal>[#Data]</literal> ອ້າງອີງເຖິງລະບຽບຂໍ້ມູນຂອງຊ່ວງຖານຂໍ້ມູນ, ໂດຍບໍ່ລວມແຖວປ້າຍຖັນ ແລະ ແຖວລວມ."

#. PQxNG
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id601727205675886\n"
"help.text"
msgid "The short form <input>myData[]</input> can be used as well."
msgstr "ສາມາດໃຊ້ຮູບແບບຫຍໍ້ <input>myData[]</input> ໄດ້ເຊັ່ນກັນ."

#. wL8E5
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id481727205632987\n"
"help.text"
msgid "The expression <input>myData[#Data]</input> references the cell rectangle <input>A2:D10</input>."
msgstr "ນິພົດ <input>myData[#Data]</input> ອ້າງອີງເຖິງຂອບເຂດຫ້ອງ <input>A2:D10</input>."

#. ipWW4
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id801727205770281\n"
"help.text"
msgid "<literal>[#Totals]</literal>"
msgstr "<literal>[#Totals]</literal>"

#. tDzMz
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id181727205788642\n"
"help.text"
msgid "The keyword <literal>[#Totals]</literal> references the row of totals. It is the last row of the database range."
msgstr "ຄຳສຳຄັນ <literal>[#Totals]</literal> ອ້າງອີງເຖິງແຖວລວມ. ມັນແມ່ນແຖວສຸດທ້າຍຂອງຊ່ວງຖານຂໍ້ມູນ."

#. kzXVD
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id211727205840457\n"
"help.text"
msgid "If the database range has no line of totals defined (<link href=\"text/scalc/01/12010000.xhp#contains_totals_row\"><menuitem>Contains totals row</menuitem></link>), a #REF! error is generated."
msgstr "ຖ້າຊ່ວງຖານຂໍ້ມູນບໍ່ມີແຖວລວມທີ່ກຳນົດໄວ້ (<link href=\"text/scalc/01/12010000.xhp#contains_totals_row\"><menuitem>ມີແຖວລວມ</menuitem></link>), ຂໍ້ຜິດພາດ #REF! ຈະຖືກສ້າງຂຶ້ນ."

#. RhUsA
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id691727205815586\n"
"help.text"
msgid "The expression <input>myData[#Totals]</input> references the cells <input>A11:D11</input>."
msgstr "ນິພົດ <input>myData[#Totals]</input> ອ້າງອີງເຖິງຫ້ອງ <input>A11:D11</input>."

#. EG9ci
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id311727205884492\n"
"help.text"
msgid "<literal>[#All]</literal>"
msgstr "<literal>[#All]</literal>"

#. CPKPU
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id151727205893803\n"
"help.text"
msgid "The keyword <literal>[#All]</literal> references the entire database range including column labels and totals."
msgstr "ຄຳສຳຄັນ <literal>[#All]</literal> ອ້າງອີງເຖິງຊ່ວງຖານຂໍ້ມູນທັງໝົດ ລວມທັງປ້າຍຖັນ ແລະ ແຖວລວມ."

#. Jy5V9
#: database_table_reference.xhp
msgctxt ""
"database_table_reference.xhp\n"
"par_id311727205907842\n"
"help.text"
msgid "The expression <input>myData[#All]</input> references the cells <input>A1:D11</input>."
msgstr "ນິພົດ <input>myData[#All]</input> ອ້າງອີງເຖິງຫ້ອງ <input>A1:D11</input>."

#. WegDR
