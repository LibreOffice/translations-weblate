#. mUrC8
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id2847492\n"
"help.text"
msgid "<emph>Trials</emph> The total number of trials."
msgstr "<emph>Trials</emph> ຈຳນວນຄັ້ງທັງໝົດຂອງການທົດລອງ."

#. Ydde5
