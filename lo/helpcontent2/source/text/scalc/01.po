msgstr "ຮູບແບບ"

#. GWT5C
#: pastespecialcalc.xhp
msgctxt ""
"pastespecialcalc.xhp\n"
"par_id3125863\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/pastespecial/formats\">Inserts cell format attributes.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/pastespecial/formats\">ແຊກຄຸນສົມບັດຮູບແບບເຊລ.</ahelp>"

#. t58Tx
