#. SAD26
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3145163\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ARCCOS\">Returns the inverse trigonometric cosine of a number.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ARCCOS\">ສົ່ງຄືນຄ່າປີ້ນໂຄຊາຍໄຕມຸມມິຕິຂອງຕົວເລກ.</ahelp>"

#. ntxMG
#: 04060106.xhp
