msgctxt ""
"func_chooserows.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Returns the specified rows from an array."
msgstr "ສົ່ງຄືນແຖວທີ່ລະບຸຈາກອາເຣ."

#. kxCw4
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id601738075517060\n"
"help.text"
msgid "=CHOOSEROWS(Array; Row_1 [; Row_2 [; Row_3 [; ...]]])"
msgstr "=CHOOSEROWS(Array; Row_1 [; Row_2 [; Row_3 [; ...]]])"

#. ckm7y
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id81738076052161\n"
"help.text"
msgid "<emph>Array</emph>: The array containing the rows to be returned in a new array."
msgstr "<emph>Array</emph>: ອາເຣທີ່ມີແຖວທີ່ຈະຖືກສົ່ງຄືນໃນອາເຣໃໝ່."

#. ziFKi
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id191738076047602\n"
"help.text"
msgid "<emph>Row_1</emph>: The index of the first row to be returned. A negative value chooses from the end of the array."
msgstr "<emph>Row_1</emph>: ດັດຊະນີຂອງແຖວທຳອິດທີ່ຈະສົ່ງຄືນ. ຄ່າລົບຈະເລືອກຈາກທ້າຍອາເຣ."

#. VVSCT
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id1001738076043608\n"
"help.text"
msgid "<emph>Row_2; Row_3; ...</emph>: (optional) The list of other row indexes to be returned. A negative value chooses from the end of the array."
msgstr "<emph>Row_2; Row_3; ...</emph>: (ທາງເລືອກ) ລາຍການດັດຊະນີແຖວອື່ນໆທີ່ຈະສົ່ງຄືນ."

#. dbB3u
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id141767192556919\n"
"help.text"
msgid "None of the values of <emph>Row_1; Row_2; ...</emph> can be zero."
msgstr "ຄ່າຂອງ <emph>Row_1; Row_2; ...</emph> ຕ້ອງບໍ່ແມ່ນສູນ."

#. Un6fF
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id301767192606989\n"
"help.text"
msgid "The absolute value of each of <emph>Row_1; Row_2; ...</emph> must be less than or equal to the number of rows of <emph>Array</emph>."
msgstr "ຄ່າສຳບູນຂອງແຕ່ລະ <emph>Row_1; Row_2; ...</emph> ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບຈຳນວນແຖວຂອງ <emph>Array</emph>."

#. DRtRZ
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id481738974778935\n"
"help.text"
msgid "Use the function CHOOSEROWS to reorder the rows of an array. You can also replicate rows by repeating the row index."
msgstr "ໃຊ້ຟັງຊັນ CHOOSEROWS ເພື່ອຈັດລຽງແຖວໃໝ່ ຫຼື ເຮັດຊ້ຳແຖວໂດຍການລະບຸດັດຊະນີຊ້ຳ."

#. C9Vng
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id821738091480292\n"
"help.text"
msgid "The formula <input>{=CHOOSEROWS(A1:E3;2;3)}</input> returns the array below with rows 2 and 3 chosen."
msgstr "ສູດ <input>{=CHOOSEROWS(A1:E3;2;3)}</input> ສົ່ງຄືນອາເຣທີ່ມີແຖວທີ 2 ແລະ 3."

#. NeCWK
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id21738975515099\n"
"help.text"
msgid "The formula <input>=CHOOSEROWS(A1:E3;1;-1)</input> returns the array below with row 1 and row 3 chosen, note that row 3 is chosen from the end of the array."
msgstr "ສູດ <input>=CHOOSEROWS(A1:E3;1;-1)</input> ສົ່ງຄືນອາເຣທີ່ມີແຖວທີ 1 ແລະ 3."

#. kFRgs
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id991767800254154\n"
"help.text"
msgid "CHOOSEROWS(Array; Row<sub>n</sub>) is equivalent to INDEX(Array; Row<sub>n</sub>)."
msgstr "CHOOSEROWS(Array; Row<sub>n</sub>) ມີຄ່າເທົ່າກັບ INDEX(Array; Row<sub>n</sub>)."

#. zEcCF
#: func_chooserows.xhp
msgctxt ""
"func_chooserows.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/CHOOSEROWS\">CHOOSEROWS wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/CHOOSEROWS\">ໜ້າວິກີ CHOOSEROWS</link>."

#. jF3yQ
