msgstr "<bookmark_value>ຟັງຊັນ COUNT</bookmark_value> <bookmark_value>ຕົວເລກ; ການນັບ</bookmark_value>"

#. 572uZ
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3148437\n"
"help.text"
msgid "<variable id=\"count_head\"><link href=\"text/scalc/01/04060181.xhp#count\">COUNT</link></variable>"
msgstr "<variable id=\"count_head\"><link href=\"text/scalc/01/04060181.xhp#count\">COUNT</link></variable>"

#. byWbW
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3150700\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ANZAHL\">Counts how many numbers are in the list of arguments.</ahelp> Text entries are ignored."
msgstr "<ahelp hid=\"HID_FUNC_ANZAHL\">ນັບວ່າມີຕົວເລກຈັກຕົວຢູ່ໃນລາຍການຂອງອາກິວເມນ.</ahelp> ຂໍ້ມູນທີ່ເປັນຂໍ້ຄວາມຈະຖືກລະເລີຍ."

#. aAiFt
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3148585\n"
"help.text"
msgid "COUNT(<embedvar href=\"text/scalc/01/ful_func.xhp#argument255_1\" markup=\"keep\"/>)"
msgstr "COUNT(<embedvar href=\"text/scalc/01/ful_func.xhp#argument255_1\" markup=\"keep\"/>)"

#. C9kWA
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3149953\n"
"help.text"
msgid "The entries 2, 4, 6 and \"eight\" in the Value 1-4 fields are to be counted."
msgstr "ຂໍ້ມູນ 2, 4, 6 ແລະ \"eight\" ໃນຟິວ Value 1-4 ແມ່ນຈະຖືກນັບ."

#. 4J3HX
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3154558\n"
"help.text"
msgid "<item type=\"input\">=COUNT(2;4;6;\"eight\")</item> = 3. The count of numbers is therefore 3."
msgstr "<item type=\"input\">=COUNT(2;4;6;\"eight\")</item> = 3. ດັ່ງນັ້ນ ຈຳນວນຕົວເລກທີ່ນັບໄດ້ແມ່ນ 3."

#. Gx8kb
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"bm_id3149729\n"
"help.text"
msgid "<bookmark_value>COUNTA function</bookmark_value>  <bookmark_value>number of entries</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ COUNTA</bookmark_value> <bookmark_value>ຈຳນວນຂອງຂໍ້ມູນ</bookmark_value>"

#. HCAiK
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3149729\n"
"help.text"
msgid "<variable id=\"counta_head\"><link href=\"text/scalc/01/04060181.xhp#counta\">COUNTA</link></variable>"
msgstr "<variable id=\"counta_head\"><link href=\"text/scalc/01/04060181.xhp#counta\">COUNTA</link></variable>"

#. epCgy
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3150142\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ANZAHL2\">Counts how many values are in the list of arguments.</ahelp> Text entries are also counted, even when they contain an empty string of length 0. If an argument is an array or reference, empty cells within the array or reference are ignored."
msgstr "<ahelp hid=\"HID_FUNC_ANZAHL2\">ນັບວ່າມີຄ່າຈັກຄ່າຢູ່ໃນລາຍການຂອງອາກິວເມນ.</ahelp> ຂໍ້ມູນທີ່ເປັນຂໍ້ຄວາມກໍຖືກນັບຄືກັນ, ເຖິງແມ່ນວ່າພວກມັນຈະມີຂໍ້ຄວາມຫວ່າງທີ່ມີຄວາມຍາວ 0 ກໍຕາມ. ຖ້າອາກິວເມນເປັນອາເຣ ຫຼື ການອ້າງອີງ, ຫ້ອງຫວ່າງພາຍໃນອາເຣ ຫຼື ການອ້າງອີງນັ້ນຈະຖືກລະເລີຍ."

#. BpyMv
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3153111\n"
"help.text"
msgid "COUNTA(<embedvar href=\"text/scalc/01/ful_func.xhp#argument255_1\" markup=\"keep\"/>)"
msgstr "COUNTA(<embedvar href=\"text/scalc/01/ful_func.xhp#argument255_1\" markup=\"keep\"/>)"

#. Xr59x
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3154508\n"
"help.text"
msgid "The entries 2, 4, 6 and \"eight\" in the Value 1-4 fields are to be counted."
msgstr "ຂໍ້ມູນ 2, 4, 6 ແລະ \"eight\" ໃນຟິວ Value 1-4 ແມ່ນຈະຖືກນັບ."

#. 2BTA2
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3158000\n"
"help.text"
msgid "<item type=\"input\">=COUNTA(2;4;6;\"eight\")</item> = 4. The count of values is therefore 4."
msgstr "<item type=\"input\">=COUNTA(2;4;6;\"eight\")</item> = 4. ດັ່ງນັ້ນ ຈຳນວນຄ່າທີ່ນັບໄດ້ແມ່ນ 4."

#. uuPnw
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"bm_id3150896\n"
"help.text"
msgid "<bookmark_value>COUNTBLANK function</bookmark_value>  <bookmark_value>counting;empty cells</bookmark_value>  <bookmark_value>empty cells;counting</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ COUNTBLANK</bookmark_value> <bookmark_value>ການນັບ;ຫ້ອງຫວ່າງ</bookmark_value> <bookmark_value>ຫ້ອງຫວ່າງ;ການນັບ</bookmark_value>"

#. 34Lr6
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3150896\n"
"help.text"
msgid "<variable id=\"countblank_head\"><link href=\"text/scalc/01/04060181.xhp#countblank\">COUNTBLANK</link></variable>"
msgstr "<variable id=\"countblank_head\"><link href=\"text/scalc/01/04060181.xhp#countblank\">COUNTBLANK</link></variable>"

#. HUWNd
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3155260\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ANZAHLLEEREZELLEN\">Returns the number of empty cells.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ANZAHLLEEREZELLEN\">ສົ່ງຄ່າຄືນຈຳນວນຂອງຫ້ອງຫວ່າງ.</ahelp>"

#. e7BZV
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3153931\n"
"help.text"
msgid "COUNTBLANK(Range)"
msgstr "COUNTBLANK(Range)"

#. AQCFv
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3149512\n"
"help.text"
msgid "Returns the number of empty cells in the cell range <emph>Range</emph>."
msgstr "ສົ່ງຄ່າຄືນຈຳນວນຫ້ອງຫວ່າງໃນຊ່ວງຫ້ອງ <emph>Range</emph>."

#. aB6WZ
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3148586\n"
"help.text"
msgid "<item type=\"input\">=COUNTBLANK(A1:B2)</item> returns 4 if cells A1, A2, B1, and B2 are all empty."
msgstr "<item type=\"input\">=COUNTBLANK(A1:B2)</item> ສົ່ງຄ່າຄືນ 4 ຖ້າຫ້ອງ A1, A2, B1, ແລະ B2 ລ້ວນແຕ່ຫວ່າງ."

#. X2EEE
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"bm_id3164897\n"
"help.text"
msgid "<bookmark_value>COUNTIF function</bookmark_value>  <bookmark_value>counting;specified cells</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ COUNTIF</bookmark_value> <bookmark_value>ການນັບ;ຫ້ອງທີ່ລະບຸ</bookmark_value>"

#. WFqfL
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3164897\n"
"help.text"
msgid "<variable id=\"countif_head\"><link href=\"text/scalc/01/04060181.xhp#countif\">COUNTIF</link></variable>"
msgstr "<variable id=\"countif_head\"><link href=\"text/scalc/01/04060181.xhp#countif\">COUNTIF</link></variable>"

#. NbceE
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3164926\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ZAEHLENWENN\">Returns the number of cells that meet with certain criteria within a cell range.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ZAEHLENWENN\">ສົ່ງຄ່າຄືນຈຳນວນຫ້ອງທີ່ກົງກັບເງື່ອນໄຂໃດໜຶ່ງພາຍໃນຊ່ວງຫ້ອງ.</ahelp>"

#. ZS8Ej
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3164967\n"
"help.text"
msgid "COUNTIF(Range; Criterion)"
msgstr "COUNTIF(Range; Criterion)"

#. sxGvB
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3164980\n"
"help.text"
msgid "<emph>Range</emph> is the range to which the criteria are to be applied."
msgstr "<emph>Range</emph> ແມ່ນຊ່ວງທີ່ຈະໃຊ້ເງື່ອນໄຂນັ້ນ."

#. ZpDRv
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3166505\n"
"help.text"
msgid "A1:A10 is a cell range containing the numbers <item type=\"input\">2000</item> to <item type=\"input\">2009</item>. Cell B1 contains the number <item type=\"input\">2006</item>. In cell B2, you enter a formula:"
msgstr "A1:A10 ແມ່ນຊ່ວງຫ້ອງທີ່ມີຕົວເລກ <item type=\"input\">2000</item> ຫາ <item type=\"input\">2009</item>. ຫ້ອງ B1 ມີຕົວເລກ <item type=\"input\">2006</item>. ໃນຫ້ອງ B2, ທ່ານປ້ອນສູດ:"

#. fHBch
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3581652\n"
"help.text"
msgid "<item type=\"input\">=COUNTIF(A1:A10;2006)</item> - this returns 1."
msgstr "<item type=\"input\">=COUNTIF(A1:A10;2006)</item> - ສິ່ງນີ້ຈະສົ່ງຄ່າຄືນ 1."

#. EdMbp
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id708639\n"
"help.text"
msgid "<item type=\"input\">=COUNTIF(A1:A10;B1)</item> - this returns 1."
msgstr "<item type=\"input\">=COUNTIF(A1:A10;B1)</item> - ສິ່ງນີ້ຈະສົ່ງຄ່າຄືນ 1."

#. GRXFA
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id5169225\n"
"help.text"
msgid "<item type=\"input\">=COUNTIF(A1:A10;\">=2006\")</item> - this returns 4."
msgstr "<item type=\"input\">=COUNTIF(A1:A10;\">=2006\")</item> - ສິ່ງນີ້ຈະສົ່ງຄ່າຄືນ 4."

#. ZhuPt
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id2118594\n"
"help.text"
msgid "<item type=\"input\">=COUNTIF(A1:A10;\"<\"&B1)</item> - when B1 contains <item type=\"input\">2006</item>, this returns 6."
msgstr "<item type=\"input\">=COUNTIF(A1:A10;\"<\"&B1)</item> - ເມື່ອ B1 ມີ <item type=\"input\">2006</item>, ສິ່ງນີ້ຈະສົ່ງຄ່າຄືນ 6."

#. Esf3P
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id166020\n"
"help.text"
msgid "<item type=\"input\">=COUNTIF(A1:A10;C2)</item> where cell C2 contains the text <item type=\"input\">>2006</item> counts the number of cells in the range A1:A10 which are >2006."
msgstr "<item type=\"input\">=COUNTIF(A1:A10;C2)</item> ເມື່ອຫ້ອງ C2 ມີຂໍ້ຄວາມ <item type=\"input\">>2006</item> ຈະນັບຈຳນວນຫ້ອງໃນຊ່ວງ A1:A10 ທີ່ມີຄ່າ >2006."

#. z6NgE
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id6386913\n"
"help.text"
msgid "To count only negative numbers: <item type=\"input\">=COUNTIF(A1:A10;\"<0\")</item>"
msgstr "ເພື່ອນັບສະເພາະຕົວເລກລົບ: <item type=\"input\">=COUNTIF(A1:A10;\"<0\")</item>"

#. GWdLd
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"bm_id3150267\n"
"help.text"
msgid "<bookmark_value>B function</bookmark_value>  <bookmark_value>probabilities of samples with binomial distribution</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ B</bookmark_value> <bookmark_value>ຄວາມໜ້າຈະເປັນຂອງກຸ່ມຕົວຢ່າງທີ່ມີການແຈກຢາຍທະວິບົດ</bookmark_value>"

#. NKDUL
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3150267\n"
"help.text"
msgid "B"
msgstr "B"

#. VDC2z
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3156061\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_B\">Returns the probability of a sample with binomial distribution.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_B\">ສົ່ງຄ່າຄືນຄວາມໜ້າຈະເປັນຂອງກຸ່ມຕົວຢ່າງທີ່ມີການແຈກຢາຍທະວິບົດ.</ahelp>"

#. tYKH6
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3148392\n"
"help.text"
msgid "B(Trials; SP; T1 [; T2])"
msgstr "B(Trials; SP; T1 [; T2])"

#. 5gx3q
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3149002\n"
"help.text"
msgid "<emph>Trials</emph> is the number of independent trials."
msgstr "<emph>Trials</emph> ແມ່ນຈຳນວນຄັ້ງຂອງການທົດລອງທີ່ເປັນອິດສະຫຼະ."

#. zLBbF
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3148875\n"
"help.text"
msgid "<emph>SP</emph> is the probability of success on each trial."
msgstr "<emph>SP</emph> ແມ່ນຄວາມໜ້າຈະເປັນທີ່ຈະປະສົບຜົນສຳເລັດໃນແຕ່ລະການທົດລອງ."

#. BJYUG
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3145352\n"
"help.text"
msgid "<emph>T1</emph> defines the lower limit for the number of trials."
msgstr "<emph>T1</emph> ກຳນົດຂີດຈຳກັດຕ່ຳສຸດສຳລັບຈຳນວນຄັ້ງຂອງການທົດລອງ."

#. EqPwz
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3149538\n"
"help.text"
msgid "<emph>T2</emph> (optional) defines the upper limit for the number of trials."
msgstr "<emph>T2</emph> (ທາງເລືອກ) ກຳນົດຂີດຈຳກັດສູງສຸດສຳລັບຈຳນວນຄັ້ງຂອງການທົດລອງ."

#. 4BXFL
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3154633\n"
"help.text"
msgid "What is the probability with ten throws of the dice, that a six will come up exactly twice? The probability of a six (or any other number) is 1/6. The following formula combines these factors:"
msgstr "ຄວາມໜ້າຈະເປັນທີ່ຈະໂຍນໝາກກະລັອກສິບຄັ້ງ ແລ້ວອອກເລກຫົກພໍດີສອງຄັ້ງແມ່ນເທົ່າໃດ? ຄວາມໜ້າຈະເປັນທີ່ຈະອອກເລກຫົກ (ຫຼື ເລກອື່ນໆ) ແມ່ນ 1/6. ສູດຕໍ່ໄປນີ້ຈະລວມປັດໄຈເຫຼົ່ານີ້ເຂົ້າກັນ:"

#. YrQVi
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3149393\n"
"help.text"
msgid "<item type=\"input\">=B(10;1/6;2)</item> returns a probability of 29%."
msgstr "<item type=\"input\">=B(10;1/6;2)</item> ສົ່ງຄ່າຄືນຄວາມໜ້າຈະເປັນ 29%."

#. yxmoz
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"bm_id3158416\n"
"help.text"
msgid "<bookmark_value>RSQ function</bookmark_value>  <bookmark_value>determination coefficients</bookmark_value>  <bookmark_value>regression analysis</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ RSQ</bookmark_value> <bookmark_value>ສຳປະສິດການຕັດສິນໃຈ</bookmark_value> <bookmark_value>ການວິເຄາະການຖອຍຫຼັງ</bookmark_value>"

#. xqMCd
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"hd_id3158416\n"
"help.text"
msgid "RSQ"
msgstr "RSQ"

#. iGuy8
#: 04060181.xhp
msgctxt ""
"04060181.xhp\n"
"par_id3154949\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_BESTIMMTHEITSMASS\">Returns the square of the Pearson correlation coefficient based on the given values.</ahelp> RSQ (also called determination coefficient) is a measure for the accuracy of an adjustment and can be used to produce a regression analysis."
msgstr "<ahelp hid=\"HID_FUNC_BESTIMMTHEITSMASS\">ສົ່ງຄ່າຄືນກຳລັງສອງຂອງສຳປະສິດສະຫະສຳພັນ Pearson ໂດຍອີງໃສ່ຄ່າທີ່ກຳນົດໃຫ້.</ahelp> RSQ (ເອີ້ນອີກຢ່າງໜຶ່ງວ່າ ສຳປະສິດການຕັດສິນໃຈ) ແມ່ນຕົວວັດແທກຄວາມຊັດເຈນຂອງການປັບຕົວ ແລະ ສາມາດໃຊ້ເພື່ອສ້າງການວິເຄາະການຖອຍຫຼັງໄດ້."

