msgctxt ""
"04070000.xhp\n"
"tit\n"
"help.text"
msgid "Named Ranges and Expressions"
msgstr "ຊ່ວງທີ່ຕັ້ງຊື່ ແລະ ນິພົດ"

#. ExSd6
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"hd_id3153951\n"
"help.text"
msgid "<link href=\"text/scalc/01/04070000.xhp\">Named Ranges and Expressions</link>"
msgstr "<link href=\"text/scalc/01/04070000.xhp\">ຊ່ວງທີ່ຕັ້ງຊື່ ແລະ ນິພົດ</link>"

#. zgPoM
#: 04070000.xhp
msgctxt ""
"04070000.xhp\n"
"par_id3145801\n"
"help.text"
msgid "<ahelp hid=\".\">Allows you to name the different sections of your spreadsheet document.</ahelp> By naming the different sections, you can easily <link href=\"text/shared/01/navigator.xhp\">navigate</link> through the spreadsheet documents and find specific information."
msgstr "<ahelp hid=\".\">ອະນຸຍາດໃຫ້ທ່ານຕັ້ງຊື່ສ່ວນຕ່າງໆ ຂອງເອກະສານສະເປຣດຊີດຂອງທ່ານ.</ahelp> ໂດຍການຕັ້ງຊື່ສ່ວນຕ່າງໆ, ທ່ານສາມາດ <link href=\"text/shared/01/navigator.xhp\">ນຳທາງ</link> ຜ່ານເອກະສານສະເປຣດຊີດ ແລະ ຊອກຫາຂໍ້ມູນສະເພາະໄດ້ຢ່າງງ່າຍດາຍ."

#. WoeVL
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"tit\n"
"help.text"
msgid "Define Names"
msgstr "ກຳນົດຊື່"

#. fGnfi
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3156330\n"
"help.text"
msgid "<variable id=\"define_names_h1\"><link href=\"text/scalc/01/04070100.xhp\">Define Names</link></variable>"
msgstr "<variable id=\"define_names_h1\"><link href=\"text/scalc/01/04070100.xhp\">ກຳນົດຊື່</link></variable>"

#. cVATk
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3154366\n"
"help.text"
msgid "<variable id=\"namenfestlegentext\"><ahelp hid=\".uno:DefineName\">Opens a dialog where you can specify a name for a selected area or a name for a formula expression.</ahelp></variable>"
msgstr "<variable id=\"namenfestlegentext\"><ahelp hid=\".uno:DefineName\">ເປີດກ່ອງໂຕ້ຕອບທີ່ທ່ານສາມາດລະບຸຊື່ໃຫ້ກັບພື້ນທີ່ທີ່ເລືອກ ຫຼື ຊື່ສຳລັບນິພົດສູດ.</ahelp></variable>"

#. 5Tu5M
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3154123\n"
"help.text"
msgid "Use the mouse to define ranges or type the reference into the <emph>Define Name </emph>dialog fields."
msgstr "ໃຊ້ເມົາສ໌ເພື່ອ ກຳນົດຊ່ວງ ຫຼື ພິມການອ້າງອີງໃສ່ໃນຊ່ອງຂອງກ່ອງໂຕ້ຕອບ <emph>ກຳນົດຊື່</emph>."

#. QVRkv
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3155131\n"
"help.text"
msgid "The <menuitem>Name Box</menuitem> on the Formula bar contains a list of defined names for the ranges or formula expressions and their scope between parenthesis. Click a name from this box to highlight the corresponding reference on the spreadsheet. Names given formulas or parts of a formula are not listed here."
msgstr "<menuitem>ຊ່ອງຊື່</menuitem> ໃນແຖບສູດຈະມີລາຍຊື່ທີ່ກຳນົດໄວ້ສຳລັບຊ່ວງ ຫຼື ນິພົດສູດ ແລະ ຂອບເຂດຂອງມັນຢູ່ໃນວົງເລັບ. ຄລິກທີ່ຊື່ຈາກຊ່ອງນີ້ເພື່ອເນັ້ນການອ້າງອີງທີ່ກ່ຽວຂ້ອງໃນສະເປຣດຊີດ. ຊື່ທີ່ຕັ້ງໃຫ້ສູດ ຫຼື ສ່ວນຂອງສູດຈະບໍ່ຖືກສະແດງຢູ່ນີ້."

#. wTVgT
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3151118\n"
"help.text"
msgid "Name"
msgstr "ຊື່"

#. UoygM
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3163712\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the name of the area for which you want to define a reference or a formula expression.</ahelp> All area names already defined in the spreadsheet are listed in the text field above. If you click a name on the list, the corresponding reference in the document will be shown with a blue frame. If multiple cell ranges belong to the same area name, they are displayed with different colored frames."
msgstr "<ahelp hid=\".\">ປ້ອນຊື່ຂອງພື້ນທີ່ທີ່ທ່ານຕ້ອງການກຳນົດການອ້າງອີງ ຫຼື ນິພົດສູດ.</ahelp> ຊື່ພື້ນທີ່ທັງໝົດທີ່ກຳນົດໄວ້ແລ້ວໃນສະເປຣດຊີດຈະຖືກສະແດງຢູ່ໃນຊ່ອງຂໍ້ຄວາມຂ້າງເທິງ. ຖ້າທ່ານຄລິກຊື່ໃນລາຍການ, ການອ້າງອີງທີ່ກ່ຽວຂ້ອງໃນເອກະສານຈະຖືກສະແດງດ້ວຍກອບສີຟ້າ. ຖ້າຫຼາຍຊ່ວງຫ້ອງເປັນຂອງຊື່ພື້ນທີ່ດຽວກັນ, ພວກມັນຈະຖືກສະແດງດ້ວຍກອບສີທີ່ແຕກຕ່າງກັນ."

#. CB5A3
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3153728\n"
"help.text"
msgid "Range or formula expression"
msgstr "ຊ່ວງ ຫຼື ນິພົດສູດ"

#. p8ZqC
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3147435\n"
"help.text"
msgid "<ahelp hid=\".\">The reference of the selected area name is shown here as an absolute value.</ahelp>"
msgstr "<ahelp hid=\".\">ການອ້າງອີງຂອງຊື່ພື້ນທີ່ທີ່ເລືອກຈະຖືກສະແດງຢູ່ນີ້ເປັນຄ່າສຳບູນ (absolute value).</ahelp>"

#. TGCQt
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3146986\n"
"help.text"
msgid "To insert a new area reference, place the cursor in this field and use your mouse to select the desired area in any sheet of your spreadsheet document. To insert a new named formula, type the formula expression."
msgstr "ເພື່ອແຊກການອ້າງອີງພື້ນທີ່ໃໝ່, ໃຫ້ວາງເຄີເຊີໃນຊ່ອງນີ້ ແລະ ໃຊ້ເມົາສ໌ເພື່ອເລືອກພື້ນທີ່ທີ່ຕ້ອງການໃນຊີດໃດກໍໄດ້ຂອງເອກະສານສະເປຣດຊີດຂອງທ່ານ. ເພື່ອແຊກສູດທີ່ຕັ້ງຊື່ໃໝ່, ໃຫ້ພິມນິພົດສູດລົງໄປ."

#. eH5Be
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id31547290\n"
"help.text"
msgid "Scope"
msgstr "ຂອບເຂດ"

#. suvgb
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id31547291\n"
"help.text"
msgid "<ahelp hid=\".\">Select the scope of the named range or named formula. Document (Global) means the name is valid for the whole document.</ahelp> Any other sheet name selected will restrict the scope of the named range or formula expression to that sheet."
msgstr "<ahelp hid=\".\">ເລືອກຂອບເຂດຂອງຊ່ວງທີ່ຕັ້ງຊື່ ຫຼື ສູດທີ່ຕັ້ງຊື່. ເອກະສານ (ທົ່ວໄປ) ໝາຍຄວາມວ່າຊື່ນັ້ນໃຊ້ໄດ້ກັບທັງເອກະສານ.</ahelp> ຖ້າເລືອກຊື່ຊີດອື່ນໆ ຈະເປັນການຈຳກັດຂອບເຂດຂອງຊ່ວງທີ່ຕັ້ງຊື່ ຫຼື ນິພົດສູດໄວ້ສະເພາະຊີດນັ້ນ."

#. TGYEi
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3154729\n"
"help.text"
msgid "Range options"
msgstr "ຕົວເລືອກຊ່ວງ"

#. sqSBA
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3149958\n"
"help.text"
msgid "<ahelp hid=\".\">Allows you to specify the <emph>Area type</emph> (optional) for the reference.</ahelp>"
msgstr "<ahelp hid=\".\">ອະນຸຍາດໃຫ້ທ່ານລະບຸ <emph>ປະເພດພື້ນທີ່</emph> (ເລືອກໄດ້) ສຳລັບການອ້າງອີງ.</ahelp>"

#. ZEazY
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3155416\n"
"help.text"
msgid "Defines additional options related to the type of reference area."
msgstr "ກຳນົດຕົວເລືອກເພີ່ມເຕີມທີ່ກ່ຽວຂ້ອງກັບປະເພດຂອງພື້ນທີ່ອ້າງອີງ."

#. KRFQv
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3150716\n"
"help.text"
msgid "Print range"
msgstr "ຊ່ວງການພິມ"

#. yAkWW
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3150751\n"
"help.text"
msgid "<ahelp hid=\".\">Defines the area as a print range.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດພື້ນທີ່ເປັນຊ່ວງການພິມ.</ahelp>"

#. ftU4S
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3153764\n"
"help.text"
msgid "Filter"
msgstr "ຕົວຕອງ"

#. VivTh
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3155766\n"
"help.text"
msgid "<ahelp hid=\".\">Defines the selected area to be used in an <link href=\"text/scalc/01/12040300.xhp\">advanced filter</link>.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດພື້ນທີ່ທີ່ເລືອກເພື່ອໃຊ້ໃນ <link href=\"text/scalc/01/12040300.xhp\">ຕົວຕອງຂັ້ນສູງ</link>.</ahelp>"

#. 2Lddt
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3159267\n"
"help.text"
msgid "Repeat column"
msgstr "ຖັນທີ່ພິມຊ້ຳ"

#. fvRdp
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3149565\n"
"help.text"
msgid "<ahelp hid=\".\">Defines the area as a repeating column.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດພື້ນທີ່ເປັນຖັນທີ່ຈະໃຫ້ພິມຊ້ຳ.</ahelp>"

#. BKDfL
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3153966\n"
"help.text"
msgid "Repeat row"
msgstr "ແຖວທີ່ພິມຊ້ຳ"

#. 3JDTz
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3150300\n"
"help.text"
msgid "<ahelp hid=\".\">Defines the area as a repeating row.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດພື້ນທີ່ເປັນແຖວທີ່ຈະໃຫ້ພິມຊ້ຳ.</ahelp>"

#. nREvG
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"hd_id3155112\n"
"help.text"
msgid "Add"
msgstr "ເພີ່ມ"

#. CsTuJ
#: 04070100.xhp
msgctxt ""
"04070100.xhp\n"
"par_id3159236\n"
"help.text"
msgid "<ahelp hid=\".\">Click the <emph>Add</emph> button to add a new defined name.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກປຸ່ມ <emph>ເພີ່ມ</emph> ເພື່ອເພີ່ມຊື່ທີ່ກຳນົດໃໝ່.</ahelp>"

#. 7YDh3
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"tit\n"
"help.text"
msgid "Paste Names"
msgstr "ວາງຊື່"

#. CPsCv
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"bm_id3153195\n"
"help.text"
msgid "<bookmark_value>cell ranges; inserting named ranges</bookmark_value><bookmark_value>inserting; cell ranges</bookmark_value> <bookmark_value>pasting; cell ranges</bookmark_value>"
msgstr "<bookmark_value>ຊ່ວງຂອງຫ້ອງ; ການແຊກຊ່ວງທີ່ຕັ້ງຊື່ໄວ້</bookmark_value><bookmark_value>ການແຊກ; ຊ່ວງຂອງຫ້ອງ</bookmark_value> <bookmark_value>ການວາງ; ຊ່ວງຂອງຫ້ອງ</bookmark_value>"

#. u79up
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"hd_id3153195\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/04070200.xhp\">Insert Name</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/04070200.xhp\">ແຊກຊື່</link></variable>"

#. 8X9th
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"par_id3150011\n"
"help.text"
msgid "<variable id=\"nameneinfuegentext\"><ahelp hid=\".uno:InsertName\">Inserts a defined named cell range at the current cursor's position with the <emph>Paste Names</emph> dialog.</ahelp></variable>"
msgstr "<variable id=\"nameneinfuegentext\"><ahelp hid=\".uno:InsertName\">ແຊກຊ່ວງຫ້ອງທີ່ຕັ້ງຊື່ໄວ້ແລ້ວລົງໃນຕຳແໜ່ງເຄີເຊີປັດຈຸບັນດ້ວຍກ່ອງໂຕ້ຕອບ <emph>ວາງຊື່</emph>.</ahelp></variable>"

#. ecmkK
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"par_id3149412\n"
"help.text"
msgid "You can only insert a cell area after having defined a name for the area."
msgstr "ທ່ານສາມາດແຊກພື້ນທີ່ຫ້ອງໄດ້ ຫຼັງຈາກທີ່ໄດ້ກຳນົດຊື່ໃຫ້ກັບພື້ນທີ່ນັ້ນແລ້ວເທົ່ານັ້ນ."

#. VPGCX
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"hd_id3153160\n"
"help.text"
msgid "Table area"
msgstr "ພື້ນທີ່ຕາຕະລາງ"

#. aDEGv
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"par_id3154944\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/insertname/ctrl\">Lists all defined cell areas. Double-click an entry to insert the named area into the active sheet at the current cursor position.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/insertname/ctrl\">ສະແດງລາຍຊື່ພື້ນທີ່ຫ້ອງທັງໝົດທີ່ກຳນົດໄວ້. ດັບເບິນຄລິກທີ່ລາຍການເພື່ອແຊກພື້ນທີ່ທີ່ຕັ້ງຊື່ນັ້ນລົງໃນຊີດທີ່ກຳລັງໃຊ້ງານຢູ່ ທີ່ຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ.</ahelp>"

#. ThnuT
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"hd_id3153418\n"
"help.text"
msgid "Paste All"
msgstr "ວາງທັງໝົດ"

#. G2G5Y
#: 04070200.xhp
msgctxt ""
"04070200.xhp\n"
"par_id3155066\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/insertname/pasteall\">Inserts a list of all named areas and the corresponding cell references at the current cursor position.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/insertname/pasteall\">ແຊກລາຍຊື່ຂອງພື້ນທີ່ທີ່ຕັ້ງຊື່ທັງໝົດ ແລະ ການອ້າງອີງຫ້ອງທີ່ກ່ຽວຂ້ອງລົງໃນຕຳແໜ່ງເຄີເຊີປັດຈຸບັນ.</ahelp>"

#. ATm7V
