#. KEWbx
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3154546\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_ABS\">Returns the absolute value of a number.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_ABS\">ສົ່ງຄືນຄ່າສຳບູນຂອງຕົວເລກ.</ahelp>"

#. 3GmDj
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3147475\n"
"help.text"
msgid "ABS(Number)"
msgstr "ABS(ຕົວເລກ)"

#. dVNFx
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3148438\n"
"help.text"
msgid "<emph>Number</emph> is the number whose absolute value is to be calculated. The absolute value of a number is its value without the +/- sign."
msgstr "<emph>ຕົວເລກ</emph> ແມ່ນຕົວເລກທີ່ຕ້ອງການຄິດໄລ່ຄ່າສຳບູນ. ຄ່າສຳບູນຂອງຕົວເລກແມ່ນຄ່າຂອງມັນໂດຍບໍ່ມີເຄື່ອງໝາຍ +/-."

#. R6vZe
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3152787\n"
"help.text"
msgid "<item type=\"input\">=ABS(-56)</item> returns 56."
msgstr "<item type=\"input\">=ABS(-56)</item> ສົ່ງຄືນ 56."

#. c9QEu
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3148752\n"
"help.text"
msgid "<item type=\"input\">=ABS(12)</item> returns 12."
msgstr "<item type=\"input\">=ABS(12)</item> ສົ່ງຄືນ 12."

