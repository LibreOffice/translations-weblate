msgctxt ""
"04060119.xhp\n"
"par_id3147521\n"
"help.text"
msgid "<emph>EffectiveRate</emph> is the effective interest rate"
msgstr "<emph>EffectiveRate</emph> ແມ່ນອັດຕາດອກເບ້ຍທີ່ແທ້ຈິງ"

