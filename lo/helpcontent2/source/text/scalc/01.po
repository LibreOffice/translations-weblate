msgid "<link href=\"text/scalc/01/05020600.xhp\">Cell Protection</link>"
msgstr "<link href=\"text/scalc/01/05020600.xhp\">ການປ້ອງກັນຫ້ອງ</link>"

#. SwYVx
#: 05020600.xhp
msgctxt ""
"05020600.xhp\n"
"par_id3150398\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/cellprotectionpage/CellProtectionPage\">Defines protection options for selected cells.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/cellprotectionpage/CellProtectionPage\">ກຳນົດຕົວເລືອກການປ້ອງກັນສຳລັບຫ້ອງທີ່ເລືອກ.</ahelp>"

#. 66fhc
