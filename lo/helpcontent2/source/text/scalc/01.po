msgctxt ""
"04060106.xhp\n"
"par_id3144906\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_SIN\">Returns the sine of the given angle (in radians).</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_SIN\">ສົ່ງຄ່າຊິນ (sine) ຂອງມຸມທີ່ກຳນົດ (ເປັນຣາດຽນ).</ahelp>"

#. HhouY
