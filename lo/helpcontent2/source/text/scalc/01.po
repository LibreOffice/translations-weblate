msgstr "ຟັງຊັນ CHOOSECOLS"

#. RmBsq
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"bm_id361708283183878\n"
"help.text"
msgid "<bookmark_value>CHOOSECOLS function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ CHOOSECOLS</bookmark_value>"

#. pgEyS
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"hd_id901708806478126\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/func_choosecols.xhp\">CHOOSECOLS</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_choosecols.xhp\">CHOOSECOLS</link></variable>"

#. qxKzH
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Returns the specified columns from an array."
msgstr "ສົ່ງຄືນຄໍລຳທີ່ລະບຸຈາກອາເຣ."

#. yTAFZ
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id601738075517060\n"
"help.text"
msgid "=CHOOSECOLS(Array; Column_1 [; Column_2 [; Column_3 [; ...]]])"
msgstr "=CHOOSECOLS(Array; Column_1 [; Column_2 [; Column_3 [; ...]]])"

#. cvwYJ
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id81738076052161\n"
"help.text"
msgid "<emph>Array</emph>: The array containing the columns to be returned in a new array."
msgstr "<emph>Array</emph>: ອາເຣທີ່ມີຄໍລຳທີ່ຈະຖືກສົ່ງຄືນໃນອາເຣໃໝ່."

#. weToH
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id191738076047602\n"
"help.text"
msgid "<emph>Column_1</emph>: The index of the first column to be returned. A negative value chooses from the end of the array."
msgstr "<emph>Column_1</emph>: ດັດຊະນີຂອງຄໍລຳທຳອິດທີ່ຈະສົ່ງຄືນ. ຄ່າລົບຈະເລືອກຈາກທ້າຍອາເຣ."

#. gUFeT
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id1001738076043608\n"
"help.text"
msgid "<emph>Column_2; Column_3; ...</emph>: (optional) The list of other column indexes to be returned. A negative value chooses from the end of the array."
msgstr "<emph>Column_2; Column_3; ...</emph>: (ທາງເລືອກ) ລາຍການດັດຊະນີຄໍລຳອື່ນໆທີ່ຈະສົ່ງຄືນ."

#. QcE6d
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id141767192556919\n"
"help.text"
msgid "None of the value of <emph>Column_1; Column_2; ...</emph> can be zero."
msgstr "ຄ່າຂອງ <emph>Column_1; Column_2; ...</emph> ຕ້ອງບໍ່ແມ່ນສູນ."

#. SUaAg
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id301767192606989\n"
"help.text"
msgid "The absolute value of each of <emph>Column_1; Column_2; ...</emph> must be less than or equal to the number of columns of <emph>Array</emph>."
msgstr "ຄ່າສົມບູນຂອງແຕ່ລະ <emph>Column_1; Column_2; ...</emph> ຕ້ອງໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ຈຳນວນຖັນຂອງ <emph>Array</emph>."

#. 74pDf
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id481738974778935\n"
"help.text"
msgid "Use the function CHOOSECOLS to reorder the columns of an array. You can also replicate columns by repeating the column index."
msgstr "ໃຊ້ຟັງຊັນ CHOOSECOLS ເພື່ອຈັດລຽງຄໍລຳໃໝ່ ຫຼື ເຮັດຊ້ຳຄໍລຳໂດຍການລະບຸດັດຊະນີຊ້ຳ."

#. uiDSY
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id821738091480292\n"
"help.text"
msgid "The formula <input>{=CHOOSECOLS(A1:E3;2;4;5)}</input> returns the array below with columns 2,4 and 5 chosen."
msgstr "ສູດ <input>{=CHOOSECOLS(A1:E3;2;4;5)}</input> ສົ່ງຄືນອາເຣທີ່ມີຄໍລຳທີ 2, 4 ແລະ 5."

#. MdDNC
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id21738975515099\n"
"help.text"
msgid "The formula <input>=CHOOSECOLS(A1:E3;1;-1)</input> returns the array below with column 1 and column 5 chosen, note that column 5 is chosen from the end of the array."
msgstr "ສູດ <input>=CHOOSECOLS(A1:E3;1;-1)</input> ສົ່ງຄືນອາເຣທີ່ມີຄໍລຳທີ 1 ແລະ 5."

#. Gxu4D
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id991767800254154\n"
"help.text"
msgid "CHOOSECOLS(Array; Column<sub>n</sub>) is equivalent to INDEX(Array; ; Column<sub>n</sub>)."
msgstr "CHOOSECOLS(Array; Column<sub>n</sub>) ມີຄ່າເທົ່າກັບ INDEX(Array; ; Column<sub>n</sub>)."

#. d8LnJ
#: func_choosecols.xhp
msgctxt ""
"func_choosecols.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/CHOOSECOLS\">CHOOSECOLS wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/CHOOSECOLS\">ໜ້າວິກີ CHOOSECOLS</link>."

