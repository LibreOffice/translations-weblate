#. ZDGuA
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2949893\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_FILTERXML\">Apply a XPath expression to a XML document.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_FILTERXML\">ໃຊ້ງານນິພົດ XPath ກັບເອກະສານ XML.</ahelp>"

#. YB99z
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id861752609832284\n"
"help.text"
msgid "XML Path Language (XPath) is a query language that uses path expressions (with a non-XML syntax) to select parts of an XML document."
msgstr "XML Path Language (XPath) ແມ່ນພາສາສຳລັບການສອບຖາມຂໍ້ມູນ ທີ່ໃຊ້ນິພົດເສັ້ນທາງ (ດ້ວຍໄວຍາກອນທີ່ບໍ່ແມ່ນ XML) ເພື່ອເລືອກພາກສ່ວນຕ່າງໆຂອງເອກະສານ XML."

#. VYWTr
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2954844\n"
"help.text"
msgid "FILTERXML(XML Document; XPath expression)"
msgstr "FILTERXML(ເອກະສານ XML; ນິພົດ XPath)"

#. BRRQN
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2947469\n"
"help.text"
msgid "<emph>XML Document (required):</emph> String containing a valid XML stream."
msgstr "<emph>ເອກະສານ XML (ຈຳເປັນ):</emph> ຂໍ້ຄວາມທີ່ມີຂໍ້ມູນ XML ທີ່ຖືກຕ້ອງ."

#. ZaFFe
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2847469\n"
"help.text"
msgid "<emph>XPath expression (required):</emph> String containing a valid XPath expression."
msgstr "<emph>ນິພົດ XPath (ຈຳເປັນ):</emph> ຂໍ້ຄວາມທີ່ມີນິພົດ XPath ທີ່ຖືກຕ້ອງ."

#. os8Uk
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2946142\n"
"help.text"
msgid "<input>=FILTERXML(WEBSERVICE(\"wiki.documentfoundation.org/api.php?hidebots=1&days=7&limit=50&action=feedrecentchanges&feedformat=rss\");\"//lastBuildDate\")</input>"
msgstr "<input>=FILTERXML(WEBSERVICE(\"wiki.documentfoundation.org/api.php?hidebots=1&days=7&limit=50&action=feedrecentchanges&feedformat=rss\");\"//lastBuildDate\")</input>"

#. bHUn3
#: func_filterxml.xhp
msgctxt ""
"func_filterxml.xhp\n"
"par_id2946143\n"
"help.text"
msgid "Returns information <literal>//lastBuildDate</literal> of the XML contents supplied by the WEBSERVICE() function."
msgstr "ສົ່ງຄືນຂໍ້ມູນ <literal>//lastBuildDate</literal> ຂອງເນື້ອໃນ XML ທີ່ໄດ້ມາຈາກຟັງຊັນ WEBSERVICE()."

