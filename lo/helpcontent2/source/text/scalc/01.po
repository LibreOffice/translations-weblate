"12090101.xhp\n"
"par_id3125863\n"
"help.text"
msgid "<ahelp hid=\".\">You can only select databases that are registered in %PRODUCTNAME.</ahelp> To register a data source, choose <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - Preferences</emph></caseinline><defaultinline><emph>Tools - Options</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Base - Databases</emph>."
msgstr "<ahelp hid=\".\">ທ່ານສາມາດເລືອກໄດ້ສະເພາະຖານຂໍ້ມູນທີ່ລົງທະບຽນໃນ %PRODUCTNAME ເທົ່ານັ້ນ.</ahelp> ເພື່ອລົງທະບຽນແຫຼ່ງຂໍ້ມູນ, ໃຫ້ເລືອກ <switchinline select=\"sys\"><caseinline select=\"MAC\"><emph>%PRODUCTNAME - ປັບແຕ່ງ</emph></caseinline><defaultinline><emph>ເຄື່ອງມື - ຕົວເລືອກ</emph></defaultinline></switchinline><emph> - %PRODUCTNAME Base - ຖານຂໍ້ມູນ</emph>."

