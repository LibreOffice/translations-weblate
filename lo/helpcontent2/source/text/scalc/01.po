"05120100.xhp\n"
"par_id451665406273943\n"
"help.text"
msgid "Condition"
msgstr "ເງື່ອນໄຂ"

#. 3BdfG
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id71665406273943\n"
"help.text"
msgid "Description"
msgstr "ຄຳອະທິບາຍ"

#. vFFDn
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id451662919849856\n"
"help.text"
msgid "is error"
msgstr "ແມ່ນຂໍ້ຜິດພາດ"

#. qKYm2
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id911662919849857\n"
"help.text"
msgid "The cell is in the error condition defined in the text box on the right. See <link href=\"text/scalc/05/02140000.xhp\">List of Calc errors</link>."
msgstr "ຫ້ອງນັ້ນຢູ່ໃນສະຖານະຂໍ້ຜິດພາດທີ່ກຳນົດໃນຊ່ອງຂໍ້ຄວາມເບື້ອງຂວາ. ເບິ່ງ <link href=\"text/scalc/05/02140000.xhp\">ລາຍການຂໍ້ຜິດພາດຂອງ Calc</link>."

#. uUxWk
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id961662920774180\n"
"help.text"
msgid "is not error"
msgstr "ບໍ່ແມ່ນຂໍ້ຜິດພາດ"

#. wYckz
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id381662920774181\n"
"help.text"
msgid "The cell is not in the error condition defined in the text box on the right. See <link href=\"text/scalc/05/02140000.xhp\">List of Calc errors</link>"
msgstr "ຫ້ອງນັ້ນບໍ່ໄດ້ຢູ່ໃນສະຖານະຂໍ້ຜິດພາດທີ່ກຳນົດໃນຊ່ອງຂໍ້ຄວາມເບື້ອງຂວາ. ເບິ່ງ <link href=\"text/scalc/05/02140000.xhp\">ລາຍການຂໍ້ຜິດພາດຂອງ Calc</link>"

#. DAG5B
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id61662920733334\n"
"help.text"
msgid "A cell that references another cell with an error condition is not in error itself."
msgstr "ຫ້ອງທີ່ອ້າງອີງເຖິງຫ້ອງອື່ນທີ່ມີສະຖານະຂໍ້ຜິດພາດ ຈະບໍ່ຖືວ່າເປັນຂໍ້ຜິດພາດດ້ວຍຕົວມັນເອງ."

#. 4zHYR
#: 05120200.xhp
msgctxt ""
"05120200.xhp\n"
"tit\n"
"help.text"
msgid "Conditional Formatting - Formula is"
msgstr "ການຈັດຮູບແບບຕາມເງື່ອນໄຂ - ສູດແມ່ນ"

#. go5b8
#: 05120200.xhp
msgctxt ""
"05120200.xhp\n"
"hd_id471662936567369\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/05120200.xhp\">Condition - Formula is</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/05120200.xhp\">ເງື່ອນໄຂ - ສູດແມ່ນ</link></variable>"

#. WwqGv
#: 05120200.xhp
msgctxt ""
"05120200.xhp\n"
"par_id31494139\n"
"help.text"
msgid "Applies the selected style to the cell when the formula expression in the text box in the right is <emph>not</emph> zero."
msgstr "ນຳໃຊ້ສະໄຕລ໌ທີ່ເລືອກໃຫ້ກັບຫ້ອງ ເມື່ອນິພົດສູດໃນຊ່ອງຂໍ້ຄວາມເບື້ອງຂວາ <emph>ບໍ່ແມ່ນ</emph> ສູນ."

#. S3dcs
#: 05120200.xhp
msgctxt ""
"05120200.xhp\n"
"par_id1001662932287796\n"
"help.text"
msgid "The formula is expressed similar to a test condition evaluating to <literal>TRUE</literal> or <literal>FALSE</literal>."
msgstr "ສູດຖືກສະແດງໃນຮູບແບບທີ່ຄ້າຍຄືກັບເງື່ອນໄຂການທົດສອບທີ່ມີຜົນເປັນ <literal>TRUE</literal> ຫຼື <literal>FALSE</literal>."

#. dAQYf
#: 05120200.xhp
msgctxt ""
"05120200.xhp\n"
"par_id111662936728630\n"
"help.text"
msgid "For example, if C29 has a conditional formatting which formula is <input>B1>=(DATE(2015;5;4)+TIME(18;0;0))</input> - a logical expression that evaluates true or false - the style applied to C29 depends on B1 contents."
msgstr "ຕົວຢ່າງ, ຖ້າ C29 ມີການຈັດຮູບແບບຕາມເງື່ອນໄຂເຊິ່ງສູດແມ່ນ <input>B1>=(DATE(2015;5;4)+TIME(18;0;0))</input> - ເຊິ່ງເປັນນິພົດທາງຕັກກະສາດທີ່ມີຜົນເປັນຈິງ ຫຼື ເທັດ - ສະໄຕລ໌ທີ່ນຳໃຊ້ກັບ C29 ຈະຂຶ້ນກັບເນື້ອໃນຂອງ B1."

#. PJRcV
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"tit\n"
"help.text"
msgid "Conditional Formatting - Date is"
msgstr "ການຈັດຮູບແບບຕາມເງື່ອນໄຂ - ວັນທີແມ່ນ"

#. 5GUiU
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"hd_id321662936831682\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/05120300.xhp\">Condition - Date is</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/05120300.xhp\">ເງື່ອນໄຂ - ວັນທີແມ່ນ</link></variable>"

#. eZ8g9
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id31662934883939\n"
"help.text"
msgid "Applies the selected style to the cell when the cell contents is formatted as date and the condition is one of the available date interval in the dropdown list."
msgstr "ນຳໃຊ້ສະໄຕລ໌ທີ່ເລືອກໃຫ້ກັບຫ້ອງ ເມື່ອເນື້ອໃນຫ້ອງຖືກຈັດຮູບແບບເປັນວັນທີ ແລະ ເງື່ອນໄຂກົງກັບຊ່ວງວັນທີທີ່ມີໃຫ້ເລືອກໃນລາຍການແບບດຶງລົງ."

#. FuPW5
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id231662933568615\n"
"help.text"
msgid "<emph>Today</emph>: applies the cell style if the cell date contents is today."
msgstr "<emph>ມື້ນີ້</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງແມ່ນມື້ນີ້."

#. Jp3xf
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id891662933647849\n"
"help.text"
msgid "<emph>Yesterday</emph>: applies the cell style if the cell date contents is yesterday."
msgstr "<emph>ມື້ວານນີ້</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງແມ່ນມື້ວານນີ້."

#. kGKdd
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id701662933702962\n"
"help.text"
msgid "<emph>Tomorrow</emph>: applies the cell style if the cell date contents is tomorrow."
msgstr "<emph>ມື້ອື່ນ</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງແມ່ນມື້ອື່ນ."

#. qiPQc
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id291662933755624\n"
"help.text"
msgid "<emph>Last 7 days</emph>: applies the cell style if the cell date contents is in the last 7 calendar days."
msgstr "<emph>7 ມື້ຜ່ານມາ</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງຢູ່ໃນຮອບ 7 ມື້ປະຕິທິນທີ່ຜ່ານມາ."

#. ReAps
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id151662933849611\n"
"help.text"
msgid "<emph>This week, Last week and Next week</emph>: applies the cell style if the cell date contents is in this week, last week and next week respectively. The start and end of the week is locale dependent."
msgstr "<emph>ອາທິດນີ້, ອາທິດແລ້ວ ແລະ ອາທິດໜ້າ</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງຢູ່ໃນອາທິດນີ້, ອາທິດແລ້ວ ຫຼື ອາທິດໜ້າ ຕາມລຳດັບ. ການເລີ່ມຕົ້ນ ແລະ ສິ້ນສຸດຂອງອາທິດແມ່ນຂຶ້ນກັບການຕັ້ງຄ່າທ້ອງຖິ່ນ (locale)."

#. 6bfmv
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id421662934429482\n"
"help.text"
msgid "<emph>This month, Last month and Next month</emph>: applies the cell style if the cell date contents is in this month, last month and next month respectively."
msgstr "<emph>ເດືອນນີ້, ເດືອນແລ້ວ ແລະ ເດືອນໜ້າ</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງຢູ່ໃນເດືອນນີ້, ເດືອນແລ້ວ ຫຼື ເດືອນໜ້າ ຕາມລຳດັບ."

#. xduEr
#: 05120300.xhp
msgctxt ""
"05120300.xhp\n"
"par_id461662934605639\n"
"help.text"
msgid "<emph>This year, Last year and Next year</emph>: applies the cell style if the cell date contents is in this year, last year and next year respectively."
msgstr "<emph>ປີນີ້, ປີແລ້ວ ແລະ ປີໜ້າ</emph>: ນຳໃຊ້ສະໄຕລ໌ຫ້ອງ ຖ້າວັນທີໃນຫ້ອງຢູ່ໃນປີນີ້, ປີແລ້ວ ຫຼື ປີໜ້າ ຕາມລຳດັບ."

#. ZANZR
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"tit\n"
"help.text"
msgid "Conditional Formatting - All cells"
msgstr "ການຈັດຮູບແບບຕາມເງື່ອນໄຂ - ທຸກໆ ຫ້ອງ"

#. 2J3Dw
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id861662937013389\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/05120400.xhp\">Condition - All cells</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/05120400.xhp\">ເງື່ອນໄຂ - ທຸກໆ ຫ້ອງ</link></variable>"

#. Bstud
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id31662915586650\n"
"help.text"
msgid "Applies the conditional formatting to the set of cells defined in the selected range. The formatting is applied based on the contents of the whole range."
msgstr "ນຳໃຊ້ການຈັດຮູບແບບຕາມເງື່ອນໄຂໃຫ້ກັບກຸ່ມຫ້ອງທີ່ກຳນົດໃນຊ່ວງທີ່ເລືອກ. ການຈັດຮູບແບບຈະຖືກນຳໃຊ້ໂດຍອີງຕາມເນື້ອໃນຂອງທັງຊ່ວງນັ້ນ."

#. EzAUv
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3147394\n"
"help.text"
msgid "<link href=\"text/scalc/01/05120400.xhp#colorscale\">Color Scale</link>"
msgstr "<link href=\"text/scalc/01/05120400.xhp#colorscale\">ເກນສີ</link>"

#. VvAiE
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3155602\n"
"help.text"
msgid "Applies a color scale to a range consisting of displaying a bicolor or tricolor gradient on this range depending on the value of each cell."
msgstr "ນຳໃຊ້ເກນສີໃຫ້ກັບຊ່ວງຫ້ອງ ເຊິ່ງປະກອບດ້ວຍການສະແດງການໄລ່ລະດັບສອງສີ ຫຼື ສາມສີໃນຊ່ວງນີ້ ໂດຍຂຶ້ນກັບຄ່າຂອງແຕ່ລະຫ້ອງ."

#. S9Btk
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id541663598275609\n"
"help.text"
msgid "Conditions"
msgstr "ເງື່ອນໄຂ"

#. zip59
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id231663598294535\n"
"help.text"
msgid "The calculation of the color scale depends on 2 or 3 conditions, defined as follows:"
msgstr "ການຄຳນວນເກນສີແມ່ນຂຶ້ນກັບ 2 ຫຼື 3 ເງື່ອນໄຂ, ເຊິ່ງກຳນົດໄດ້ດັ່ງນີ້:"

#. XKMSV
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id701864449697771\n"
"help.text"
msgid "<emph>Min (Max)</emph>: calculates using the minimum (maximum) values in the range."
msgstr "<emph>ຕ່ຳສຸດ (ສູງສຸດ)</emph>: ຄຳນວນໂດຍໃຊ້ຄ່າຕ່ຳສຸດ (ສູງສຸດ) ໃນຊ່ວງນັ້ນ."

#. eGYev
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id321663440728295\n"
"help.text"
msgid "<emph>Value</emph>: a fixed value. Enter the value in the text box."
msgstr "<emph>ຄ່າ</emph>: ຄ່າຄົງທີ່. ປ້ອນຄ່າໃນຊ່ອງຂໍ້ຄວາມ."

#. DZxAs
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id611663440697270\n"
"help.text"
msgid "<emph>Percentile</emph>: A percentile is each of the 99 values which divide the sorted data in 100 equal parts, so that each part represents 1/100 of the sample population. A percentile return the value for a data series going from the smallest to the largest value in a set of data. For P = 25, the percentile means the first quartile. P = 50 is also the MEDIAN of the data set. Enter the percentile value in the text box. Valid values are from 0 to 100."
msgstr "<emph>ເປີເຊັນທາຍ (Percentile)</emph>: ເປີເຊັນທາຍແມ່ນແຕ່ລະຄ່າໃນ 99 ຄ່າທີ່ແບ່ງຂໍ້ມູນທີ່ຈັດລຳດັບແລ້ວອອກເປັນ 100 ສ່ວນເທົ່າກັນ. P = 25 ໝາຍເຖິງຄວໍໄທທຳອິດ. P = 50 ໝາຍເຖິງຄ່າມັດທະຍະຖານ. ປ້ອນຄ່າເປີເຊັນທາຍໃນຊ່ອງຂໍ້ຄວາມ. ຄ່າທີ່ໃຊ້ໄດ້ແມ່ນແຕ່ 0 ຫາ 100."

#. zwwLa
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id211663440834104\n"
"help.text"
msgid "<emph>Percent</emph>: a fixed value representing the percentage of the minimum (maximum) of the length defined by minimum and maximum values in the range. A minimum of 10% selects the values below 10% of the segment [Min,Max]. A maximum of 80% select values above 80% of the segment [Min,Max]. Valid values are from 0 (zero) to 100. Do not enter a percent (%) sign."
msgstr "<emph>ເປີເຊັນ</emph>: ຄ່າຄົງທີ່ທີ່ສະແດງເຖິງເປີເຊັນຂອງຄ່າຕ່ຳສຸດ (ສູງສຸດ) ຂອງຊ່ວງທີ່ກຳນົດໂດຍຄ່າຕ່ຳສຸດ ແລະ ສູງສຸດ. ຄ່າທີ່ໃຊ້ໄດ້ແມ່ນແຕ່ 0 ຫາ 100. ບໍ່ຕ້ອງໃສ່ເຄື່ອງໝາຍເປີເຊັນ (%)."

#. nF8iD
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id961663440848168\n"
"help.text"
msgid "<emph>Formula</emph>: A formula expression starting with the equal sign (=) that calculates a numeric value. Values can be numbers, dates or time. Enter the formula expression in the text box."
msgstr "<emph>ສູດ</emph>: ນິພົດສູດທີ່ເລີ່ມຕົ້ນດ້ວຍເຄື່ອງໝາຍເທົ່າກັບ (=) ເຊິ່ງຄຳນວນເປັນຄ່າຕົວເລກ. ປ້ອນນິພົດສູດໃນຊ່ອງຂໍ້ຄວາມ."

#. YGTzE
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id991609782427459\n"
"help.text"
msgid "<link href=\"text/scalc/01/05120400.xhp#databar\">Data Bar</link>"
msgstr "<link href=\"text/scalc/01/05120400.xhp#databar\">ແຖບຂໍ້ມູນ</link>"

#. 94FyT
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id41609780964157\n"
"help.text"
msgid "Data bar option fills the cell with solid or gradient color corresponding to the numeric value in the cell."
msgstr "ຕົວເລືອກແຖບຂໍ້ມູນຈະຕື່ມສີພື້ນ ຫຼື ສີໄລ່ລະດັບໃສ່ໃນຫ້ອງ ໂດຍອີງຕາມຄ່າຕົວເລກໃນຫ້ອງນັ້ນ."

#. WHWWc
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id631663449553346\n"
"help.text"
msgid "Conditions"
msgstr "ເງື່ອນໄຂ"

#. CENjM
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id931609781970981\n"
"help.text"
msgid "The calculation of the bar area fill is based on the conditions below:"
msgstr "ການຄຳນວນການຕື່ມສີໃນພື້ນທີ່ແຖບແມ່ນອີງຕາມເງື່ອນໄຂຂ້າງລຸ່ມນີ້:"

#. DzwrN
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id281663449673792\n"
"help.text"
msgid "<emph>Automatic</emph>: calculates using the minimum and maximum values in the range."
msgstr "<emph>ອັດຕະໂນມັດ</emph>: ຄຳນວນໂດຍໃຊ້ຄ່າຕ່ຳສຸດ ແລະ ສູງສຸດໃນຊ່ວງນັ້ນ."

#. 9aPGW
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id701663449697771\n"
"help.text"
msgid "<emph>Min (Max)</emph>: calculates using the minimum (maximum) values in the range."
msgstr "<emph>ຕ່ຳສຸດ (ສູງສຸດ)</emph>: ຄຳນວນໂດຍໃຊ້ຄ່າຕ່ຳສຸດ (ສູງສຸດ) ໃນຊ່ວງນັ້ນ."

#. Yst5U
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id281609781729359\n"
"help.text"
msgid "More Options"
msgstr "ຕົວເລືອກເພີ່ມເຕີມ"

#. wB7B5
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id501663454998977\n"
"help.text"
msgid "The Data Bar dialog opens to add details on the display of data bars."
msgstr "ກ່ອງໂຕ້ຕອບແຖບຂໍ້ມູນຈະເປີດຂຶ້ນເພື່ອເພີ່ມລາຍລະອຽດໃນການສະແດງຜົນຂອງແຖບຂໍ້ມູນ."

#. Xi84x
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id221663453502042\n"
"help.text"
msgid "Entry values"
msgstr "ຄ່າທີ່ປ້ອນ"

#. j4CZx
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id891663453681870\n"
"help.text"
msgid "Same as the conditions above."
msgstr "ຄືກັນກັບເງື່ອນໄຂຂ້າງເທິງ."

#. qYC9D
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id511663453530293\n"
"help.text"
msgid "Bar Colors"
msgstr "ສີຂອງແຖບ"

#. 3WvU9
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id371663453564807\n"
"help.text"
msgid "Choose the color for positive and negative values."
msgstr "ເລືອກສີສຳລັບຄ່າບວກ ແລະ ຄ່າລົບ."

#. F7ADR
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id891663453607961\n"
"help.text"
msgid "Fill"
msgstr "ການຕື່ມ"

#. NK7yv
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id671663453639829\n"
"help.text"
msgid "<emph>Gradient</emph>: set a color scale between the color of positive (negative) values and white."
msgstr "<emph>ໄລ່ສີ</emph>: ຕັ້ງຄ່າລະດັບສີລະຫວ່າງສີຂອງຄ່າບວກ (ຄ່າລົບ) ແລະ ສີຂາວ."

#. UsHFm
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id551663453647462\n"
"help.text"
msgid "<emph>Color</emph>: use the positive (negative) color for the entire data bar, no fade out gradient."
msgstr "<emph>ສີ</emph>: ໃຊ້ສີບວກ (ລົບ) ສຳລັບແຖບຂໍ້ມູນທັງໝົດ, ບໍ່ມີການໄລ່ສີໃຫ້ຈາງລົງ."

#. 3XDGX
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id701663453750779\n"
"help.text"
msgid "Axis"
msgstr "ແກນ"

#. SCFQf
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id691663453763746\n"
"help.text"
msgid "Set the position of the vertical axis for the data bar. Values are"
msgstr "ຕັ້ງຕຳແໜ່ງຂອງແກນຕັ້ງສຳລັບແຖບຂໍ້ມູນ. ຄ່າຕ່າງໆແມ່ນ"

#. 7mCxG
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id381663453792294\n"
"help.text"
msgid "<emph>Automatic:</emph> position the vertical axis in the middle of the maximum and minimum values."
msgstr "<emph>ອັດຕະໂນມັດ:</emph> ວາງຕຳແໜ່ງແກນຕັ້ງໄວ້ເຄິ່ງກາງລະຫວ່າງຄ່າສູງສຸດ ແລະ ຄ່າຕ່ຳສຸດ."

#. u9oCp
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id791663453800602\n"
"help.text"
msgid "<emph>Middle:</emph> set the vertical axis in the middle of the column."
msgstr "<emph>ເຄິ່ງກາງ:</emph> ຕັ້ງແກນຕັ້ງໄວ້ເຄິ່ງກາງຂອງຖັນ."

#. NGqHG
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id461663453808288\n"
"help.text"
msgid "<emph>None:</emph> do not display a vertical axis."
msgstr "<emph>ບໍ່ມີ:</emph> ບໍ່ສະແດງແກນຕັ້ງ."

#. MbcW9
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id511663453851599\n"
"help.text"
msgid "Bar Lengths"
msgstr "ຄວາມຍາວຂອງແຖບ"

#. EcZWp
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id601663453865023\n"
"help.text"
msgid "Sets the minimum (maximum) length of the data bars, as a percentage of the column width."
msgstr "ຕັ້ງຄ່າຄວາມຍາວຕ່ຳສຸດ (ສູງສຸດ) ຂອງແຖບຂໍ້ມູນ, ເປັນເປີເຊັນຂອງຄວາມກວ້າງຂອງຖັນ."

#. 6iAs7
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id211663453914830\n"
"help.text"
msgid "Display bars only"
msgstr "ສະແດງສະເພາະແຖບເທົ່ານັ້ນ"

#. zAE3C
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id561663453936590\n"
"help.text"
msgid "Do not display values in the cell, only the data bars."
msgstr "ບໍ່ສະແດງຄ່າໃນເຊລ, ສະແດງສະເພາະແຖບຂໍ້ມູນເທົ່ານັ້ນ."

#. 3ywDD
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id3153709\n"
"help.text"
msgid "<link href=\"text/scalc/01/05120400.xhp#iconset\">Icon Set</link>"
msgstr "<link href=\"text/scalc/01/05120400.xhp#iconset\">ຊຸດໄອຄອນ</link>"

#. RjnfG
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id3153764\n"
"help.text"
msgid "Add an icon to the cell based on the value relative to the specified thresholds. Several icon sets are available."
msgstr "ເພີ່ມໄອຄອນໃສ່ໃນເຊລໂດຍອີງຕາມຄ່າທີ່ກ່ຽວຂ້ອງກັບເກນທີ່ກຳນົດໄວ້. ມີຊຸດໄອຄອນໃຫ້ເລືອກຫຼາຍແບບ."

#. 5EFt7
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"hd_id191663440362309\n"
"help.text"
msgid "Available Icon Sets"
msgstr "ຊຸດໄອຄອນທີ່ມີໃຫ້ໃຊ້"

#. 8cgd9
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id31494140\n"
"help.text"
msgid "3, 4 or 5 - arrows"
msgstr "3, 4 ຫຼື 5 - ລູກສອນ"

#. Aoquj
#: 05120400.xhp
msgctxt ""
"05120400.xhp\n"
"par_id91663429174806\n"
"help.text"
