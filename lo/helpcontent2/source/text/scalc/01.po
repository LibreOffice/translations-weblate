"help.text"
msgid "Ceiling functions"
msgstr "ຟັງຊັນ Ceiling"

#. M92qb
#: func_ceiling.xhp
msgctxt ""
"func_ceiling.xhp\n"
"bm_id3152518\n"
"help.text"
msgid "<bookmark_value>CEILING function</bookmark_value><bookmark_value>rounding;up to multiples of significance</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ CEILING</bookmark_value><bookmark_value>ການປັດຕົວເລກ;ປັດຂຶ້ນເປັນຜົນຄູນຂອງຄ່າທີ່ກຳນົດ</bookmark_value>"

#. cGa5K
