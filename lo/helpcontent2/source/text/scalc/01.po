msgstr "NOMINAL"

#. ZtXoJ
#: 04060119.xhp
msgctxt ""
"04060119.xhp\n"
"par_id3149596\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_NOMINAL\">Calculates the yearly nominal interest rate, given the effective rate and the number of compounding periods per year.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_NOMINAL\">ຄິດໄລ່ອັດຕາດອກເບ້ຍຕາມກຳນົດປະຈຳປີ, ເມື່ອກຳນົດອັດຕາທີ່ແທ້ຈິງ ແລະ ຈຳນວນງວດທົບຕົ້ນຕໍ່ປີ.</ahelp>"

