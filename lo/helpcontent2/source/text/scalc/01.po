msgid "<link href=\"text/scalc/01/06060200.xhp\">Documents</link>"
msgstr "<link href=\"text/scalc/01/06060200.xhp\">ເອກະສານ</link>"

#. gMgFq
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"tit\n"
"help.text"
msgid "Protecting document"
msgstr "ການປ້ອງກັນເອກະສານ"

#. tbqyE
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"hd_id3150541\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/06060200.xhp#protect spreadsheet structure\">Protect Spreadsheet Structure</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/06060200.xhp#protect spreadsheet structure\">ປ້ອງກັນໂຄງສ້າງສະເປຣດຊີດ</link></variable>"

#. guss3
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3145172\n"
"help.text"
msgid "<variable id=\"dokumenttext\"><ahelp hid=\".uno:ToolProtectionDocument\">Protects the sheet structure of your document from modifications. It is impossible to insert, delete, rename, move or copy sheets.</ahelp></variable>"
msgstr "<variable id=\"dokumenttext\"><ahelp hid=\".uno:ToolProtectionDocument\">ປ້ອງກັນໂຄງສ້າງແຜ່ນງານຂອງເອກະສານຂອງທ່ານຈາກການແກ້ໄຂ. ຈະບໍ່ສາມາດແຊກ, ລຶບ, ປ່ຽນຊື່, ຍ້າຍ ຫຼື ສຳເນົາແຜ່ນງານໄດ້.</ahelp></variable>"

#. GZkqr
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id981695937865582\n"
"help.text"
msgid "Optionally enter a password and click OK."
msgstr "ປ້ອນລະຫັດຜ່ານ (ຫາກຕ້ອງການ) ແລ້ວກົດ ຕົກລົງ."

#. apWXt
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3153188\n"
"help.text"
msgid "The structure of protected spreadsheet documents can be changed only if the <emph>Protect</emph> option is disabled. On the context menus for the spreadsheet tabs at the lower graphic border, only the menu item <emph>Select All Sheets</emph> can be activated. All other menu items are deactivated. To remove the protection, call up the command <emph>Tools - Protect Spreadsheet Structure</emph> again. If no password is assigned, protection is immediately removed. If you were assigned a password, the <emph>Remove Spreadsheet Protection</emph> dialog appears, in which you must enter the password. Only then can you remove the check mark specifying that protection is active."
msgstr "ໂຄງສ້າງຂອງເອກະສານສະເປຣດຊີດທີ່ຖືກປ້ອງກັນສາມາດປ່ຽນແປງໄດ້ກໍຕໍ່ເມື່ອປິດການໃຊ້ງານຕົວເລືອກ <emph>ປ້ອງກັນ</emph>. ໃນເມນູຄລິກຂວາສຳລັບແຖບສະເປຣດຊີດຢູ່ຂອບລຸ່ມ, ຈະມີພຽງແຕ່ລາຍການເມນູ <emph>ເລືອກແຜ່ນງານທັງໝົດ</emph> ເທົ່ານັ້ນທີ່ສາມາດໃຊ້ງານໄດ້. ລາຍການເມນູອື່ນໆທັງໝົດຈະຖືກປິດໄວ້. ເພື່ອຍົກເລີກການປ້ອງກັນ, ໃຫ້ເອີ້ນໃຊ້ຄຳສັ່ງ <emph>ເຄື່ອງມື - ປ້ອງກັນໂຄງສ້າງສະເປຣດຊີດ</emph> ອີກຄັ້ງ. ຫາກບໍ່ມີການກຳນົດລະຫັດຜ່ານ, ການປ້ອງກັນຈະຖືກຍົກເລີກທັນທີ. ຫາກທ່ານໄດ້ກຳນົດລະຫັດຜ່ານໄວ້, ກ່ອງໂຕ້ຕອບ <emph>ຍົກເລີກການປ້ອງກັນສະເປຣດຊີດ</emph> ຈະປະກົດຂຶ້ນ ເຊິ່ງທ່ານຕ້ອງປ້ອນລະຫັດຜ່ານ. ຫຼັງຈາກນັ້ນທ່ານຈຶ່ງສາມາດເອົາເຄື່ອງໝາຍຖືກທີ່ລະບຸວ່າການປ້ອງກັນກຳລັງເຮັດວຽກຢູ່ນັ້ນອອກໄດ້."

#. Y5KBL
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3145750\n"
"help.text"
msgid "A protected document, once saved, can only be saved again with the <emph>File - Save As</emph> menu command."
msgstr "ເອກະສານທີ່ຖືກປ້ອງກັນ, ເມື່ອບັນທຶກແລ້ວ, ຈະສາມາດບັນທຶກໄດ້ອີກຄັ້ງຜ່ານຄຳສັ່ງເມນູ <emph>ໄຟລ໌ - ບັນທຶກເປັນ</emph> ເທົ່ານັ້ນ."

#. HMhys
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"hd_id3152596\n"
"help.text"
msgid "Password (optional)"
msgstr "ລະຫັດຜ່ານ (ຫາກຕ້ອງການ)"

#. k6oA7
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3155412\n"
"help.text"
msgid "<ahelp hid=\"SC_HID_PASSWD_DOC\">You can create a password to protect your document against unauthorized or accidental modifications.</ahelp>"
msgstr "<ahelp hid=\"SC_HID_PASSWD_DOC\">ທ່ານສາມາດສ້າງລະຫັດຜ່ານເພື່ອປ້ອງກັນເອກະສານຂອງທ່ານຈາກການແກ້ໄຂທີ່ບໍ່ໄດ້ຮັບອະນຸຍາດ ຫຼື ໂດຍບັງເອີນ.</ahelp>"

#. TwECw
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3155413\n"
"help.text"
msgid "<ahelp hid=\"SC_HID_PASSWD_DOC_CONFIRM\" visibility=\"hidden\">Re-enter the password.</ahelp>"
msgstr "<ahelp hid=\"SC_HID_PASSWD_DOC_CONFIRM\" visibility=\"hidden\">ປ້ອນລະຫັດຜ່ານຄືນໃໝ່.</ahelp>"

#. kNtVq
#: 06060200.xhp
msgctxt ""
"06060200.xhp\n"
"par_id3150717\n"
"help.text"
msgid "You can completely protect your work by combining the options <emph>Tools - Protect Sheet</emph> and <emph>Tools - Protect Spreadsheet Structure</emph>, including password entry. If you want to prevent the document from being opened by other users, select <emph>Save With Password </emph>and click the <emph>Save</emph> button. The <emph>Enter Password</emph> dialog appears. Consider carefully when choosing a password; if you forget it after you close a document you will be unable to access the document."
msgstr "ທ່ານສາມາດປ້ອງກັນຜົນງານຂອງທ່ານໄດ້ຢ່າງສົມບູນໂດຍການລວມຕົວເລືອກ <emph>ເຄື່ອງມື - ປ້ອງກັນແຜ່ນງານ</emph> ແລະ <emph>ເຄື່ອງມື - ປ້ອງກັນໂຄງສ້າງສະເປຣດຊີດ</emph> ເຂົ້ານຳກັນ, ລວມທັງການປ້ອນລະຫັດຜ່ານ. ຫາກທ່ານຕ້ອງການປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ອື່ນເປີດເອກະສານໄດ້, ໃຫ້ເລືອກ <emph>ບັນທຶກດ້ວຍລະຫັດຜ່ານ</emph> ແລະ ກົດປຸ່ມ <emph>ບັນທຶກ</emph>. ກ່ອງໂຕ້ຕອບ <emph>ປ້ອນລະຫັດຜ່ານ</emph> ຈະປະກົດຂຶ້ນ. ກະລຸນາພິຈາລະນາໃຫ້ຮອບຄອບໃນການເລືອກລະຫັດຜ່ານ; ຫາກທ່ານລືມມັນຫຼັງຈາກປິດເອກະສານແລ້ວ, ທ່ານຈະບໍ່ສາມາດເຂົ້າເຖິງເອກະສານນັ້ນໄດ້."

#. rH4Zz
#: 06070000.xhp
msgctxt ""
"06070000.xhp\n"
"tit\n"
"help.text"
msgid "AutoCalculate"
msgstr "ຄິດໄລ່ອັດຕະໂນມັດ"

#. 6gBgP
#: 06070000.xhp
msgctxt ""
"06070000.xhp\n"
"bm_id3145673\n"
"help.text"
msgid "<bookmark_value>calculating; auto calculating sheets</bookmark_value><bookmark_value>recalculate;auto calculating sheets</bookmark_value><bookmark_value>recalculating;auto calculating sheets</bookmark_value><bookmark_value>AutoCalculate function in sheets</bookmark_value><bookmark_value>correcting sheets automatically</bookmark_value><bookmark_value>formulas;AutoCalculate function</bookmark_value><bookmark_value>cell contents;AutoCalculate function</bookmark_value>"
msgstr "<bookmark_value>ການຄິດໄລ່; ການຄິດໄລ່ແຜ່ນງານອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຄິດໄລ່ຄືນ; ການຄິດໄລ່ແຜ່ນງານອັດຕະໂນມັດ</bookmark_value><bookmark_value>ການຄິດໄລ່ຄືນ; ການຄິດໄລ່ແຜ່ນງານອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຟັງຊັນການຄິດໄລ່ອັດຕະໂນມັດໃນແຜ່ນງານ</bookmark_value><bookmark_value>ການແກ້ໄຂແຜ່ນງານໂດຍອັດຕະໂນມັດ</bookmark_value><bookmark_value>ສູດ; ຟັງຊັນການຄິດໄລ່ອັດຕະໂນມັດ</bookmark_value><bookmark_value>ເນື້ອໃນເຊລ; ຟັງຊັນການຄິດໄລ່ອັດຕະໂນມັດ</bookmark_value>"

#. wfHC9
#: 06070000.xhp
msgctxt ""
"06070000.xhp\n"
"hd_id3145673\n"
"help.text"
msgid "<link href=\"text/scalc/01/06070000.xhp\">AutoCalculate</link>"
msgstr "<link href=\"text/scalc/01/06070000.xhp\">ຄິດໄລ່ອັດຕະໂນມັດ</link>"

#. Wyyhf
#: 06070000.xhp
msgctxt ""
"06070000.xhp\n"
"par_id3148798\n"
"help.text"
msgid "<ahelp hid=\".uno:AutomaticCalculation\">Automatically recalculates all formulas in the document.</ahelp>"
msgstr "<ahelp hid=\".uno:AutomaticCalculation\">ຄິດໄລ່ສູດທັງໝົດໃນເອກະສານຄືນໃໝ່ໂດຍອັດຕະໂນມັດ.</ahelp>"

#. UVFWC
#: 06070000.xhp
msgctxt ""
"06070000.xhp\n"
"par_id3145173\n"
"help.text"
msgid "All cells are recalculated after a sheet cell has been modified. Any charts in the sheet will also be refreshed."
msgstr "ທຸກເຊລຈະຖືກຄິດໄລ່ຄືນໃໝ່ຫຼັງຈາກທີ່ມີການແກ້ໄຂເຊລໃນແຜ່ນງານ. ແຜນພູມຕ່າງໆໃນແຜ່ນງານກໍຈະຖືກຟື້ນຟູຄືນໃໝ່ເຊັ່ນກັນ."

#. Wboju
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"tit\n"
"help.text"
msgid "Recalculate"
msgstr "ຄິດໄລ່ຄືນ"

#. QN44M
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"bm_id3157909\n"
"help.text"
msgid "<bookmark_value>recalculating;all formulas in sheets</bookmark_value><bookmark_value>recalculate;all formulas in sheets</bookmark_value><bookmark_value>formulas; recalculating manually</bookmark_value><bookmark_value>cell contents; recalculating</bookmark_value>"
msgstr "<bookmark_value>ການຄິດໄລ່ຄືນ; ສູດທັງໝົດໃນແຜ່ນງານ</bookmark_value><bookmark_value>ຄິດໄລ່ຄືນ; ສູດທັງໝົດໃນແຜ່ນງານ</bookmark_value><bookmark_value>ສູດ; ການຄິດໄລ່ຄືນດ້ວຍຕົນເອງ</bookmark_value><bookmark_value>ເນື້ອໃນເຊລ; ການຄິດໄລ່ຄືນ</bookmark_value>"

#. 7pNDs
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"hd_id3157909\n"
"help.text"
msgid "<link href=\"text/scalc/01/06080000.xhp\">Recalculate</link>"
msgstr "<link href=\"text/scalc/01/06080000.xhp\">ຄິດໄລ່ຄືນ</link>"

#. CBCeE
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id951584669541929\n"
"help.text"
msgid "Recalculates formula cells."
msgstr "ຄິດໄລ່ເຊລສູດຄືນໃໝ່."

#. tCCr5
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3154758\n"
"help.text"
msgid "<ahelp hid=\".uno:Calculate\">If AutoCalculate is disabled, the Recalculate command recalculates all (so-called dirty) formula cells that depend on changed cell content and their dependents, and formula cells containing volatile functions such as RAND() or NOW() and formula cells that depend on them.</ahelp>"
msgstr "<ahelp hid=\".uno:Calculate\">ຫາກປິດການຄິດໄລ່ອັດຕະໂນມັດໄວ້, ຄຳສັ່ງ ຄິດໄລ່ຄືນ ຈະຄິດໄລ່ທຸກເຊລສູດ (ທີ່ເອີ້ນວ່າ dirty) ທີ່ຂຶ້ນກັບເນື້ອໃນເຊລທີ່ປ່ຽນແປງ ແລະ ເຊລທີ່ກ່ຽວຂ້ອງ, ລວມທັງເຊລສູດທີ່ມີຟັງຊັນທີ່ມີການປ່ຽນແປງຕະຫຼອດເວລາ ເຊັ່ນ RAND() ຫຼື NOW() ແລະ ເຊລສູດທີ່ຂຶ້ນກັບພວກມັນ.</ahelp>"

#. QcG4R
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3154759\n"
"help.text"
msgid "<ahelp hid=\".uno:Calculate\">If AutoCalculate is enabled, the Recalculate command applies only to formula cells containing volatile functions like RAND() or NOW() and formula cells that depend on them.</ahelp>"
msgstr "<ahelp hid=\".uno:Calculate\">ຫາກເປີດການຄິດໄລ່ອັດຕະໂນມັດໄວ້, ຄຳສັ່ງ ຄິດໄລ່ຄືນ ຈະໃຊ້ສະເພາະກັບເຊລສູດທີ່ມີຟັງຊັນທີ່ມີການປ່ຽນແປງຕະຫຼອດເວລາ ເຊັ່ນ RAND() ຫຼື NOW() ແລະ ເຊລສູດທີ່ຂຶ້ນກັບພວກມັນເທົ່ານັ້ນ.</ahelp>"

#. CXEtC
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3154753\n"
"help.text"
msgid "<ahelp hid=\".uno:Calculate\">In either mode, with formula cell(s) selected pressing F9 recalculates the currently selected cells and formula cells that depend on them. This can be useful after reading documents with recalculation disabled and individual cells need recalculation.</ahelp>"
msgstr "<ahelp hid=\".uno:Calculate\">ບໍ່ວ່າຈະຢູ່ໃນໂໝດໃດ, ເມື່ອເລືອກເຊລສູດແລ້ວກົດ F9 ຈະເປັນການຄິດໄລ່ຄືນສະເພາະເຊລທີ່ເລືອກ ແລະ ເຊລສູດທີ່ຂຶ້ນກັບພວກມັນ. ນີ້ມີປະໂຫຍດຫຼັງຈາກເປີດເອກະສານທີ່ປິດການຄິດໄລ່ຄືນໄວ້ ແຕ່ຕ້ອງການຄິດໄລ່ບາງເຊລໂດຍສະເພາະ.</ahelp>"

#. g7GEo
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id315475899\n"
"help.text"
msgid "Press <keycode>F9</keycode> to recalculate. Press <keycode>Shift</keycode>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>F9</keycode> to recalculate all formulas in the document, including Add-In functions and non-volatile functions."
msgstr "ກົດ <keycode>F9</keycode> ເພື່ອຄິດໄລ່ຄືນ. ກົດ <keycode>Shift</keycode>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>F9</keycode> ເພື່ອຄິດໄລ່ສູດທັງໝົດໃນເອກະສານຄືນໃໝ່, ລວມທັງຟັງຊັນ Add-In ແລະ ຟັງຊັນທີ່ບໍ່ມີການປ່ຽນແປງຕະຫຼອດເວລາ."

#. qyZ6P
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id3150799\n"
"help.text"
msgid "After the document has been recalculated, the display is refreshed. All charts are also refreshed."
msgstr "ຫຼັງຈາກເອກະສານຖືກຄິດໄລ່ຄືນໃໝ່ແລ້ວ, ການສະແດງຜົນຈະຖືກຟື້ນຟູ. ແຜນພູມທັງໝົດກໍຈະຖືກຟື້ນຟູຄືນໃໝ່ເຊັ່ນກັນ."

#. EwBpJ
#: 06080000.xhp
msgctxt ""
"06080000.xhp\n"
"par_id641645233417894\n"
"help.text"
msgid "<link href=\"text/shared/optionen/01060900.xhp\">Recalculation options</link>"
msgstr "<link href=\"text/shared/optionen/01060900.xhp\">ຕົວເລືອກການຄິດໄລ່ຄືນ</link>"

#. CWRgk
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"tit\n"
"help.text"
msgid "AutoInput"
msgstr "ປ້ອນຂໍ້ມູນອັດຕະໂນມັດ"

#. SkmZ8
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"bm_id2486037\n"
"help.text"
msgid "<bookmark_value>entering entries with AutoInput function</bookmark_value><bookmark_value>capital letters;AutoInput function</bookmark_value>"
msgstr "<bookmark_value>ການປ້ອນລາຍການດ້ວຍຟັງຊັນປ້ອນຂໍ້ມູນອັດຕະໂນມັດ</bookmark_value><bookmark_value>ຕົວອັກສອນໃຫຍ່; ຟັງຊັນປ້ອນຂໍ້ມູນອັດຕະໂນມັດ</bookmark_value>"

#. iC4yZ
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"hd_id3148492\n"
"help.text"
msgid "<link href=\"text/scalc/01/06130000.xhp\">AutoInput</link>"
msgstr "<link href=\"text/scalc/01/06130000.xhp\">ປ້ອນຂໍ້ມູນອັດຕະໂນມັດ</link>"

#. 8mzpV
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3150793\n"
"help.text"
msgid "<ahelp hid=\".uno:AutoComplete\">Switches the AutoInput function on and off, which automatically completes entries, based on other entries in the same column.</ahelp> The column is scanned up to a maximum of 2000 cells or 200 different strings."
msgstr "<ahelp hid=\".uno:AutoComplete\">ເປີດ ແລະ ປິດຟັງຊັນປ້ອນຂໍ້ມູນອັດຕະໂນມັດ, ເຊິ່ງຈະຊ່ວຍຕື່ມລາຍການໃຫ້ສົມບູນໂດຍອັດຕະໂນມັດ ໂດຍອີງຕາມລາຍການອື່ນໆໃນຖັນດຽວກັນ.</ahelp> ຖັນຈະຖືກກວດສອບສູງສຸດ 2000 ເຊລ ຫຼື 200 ຂໍ້ຄວາມທີ່ແຕກຕ່າງກັນ."

#. DTiAQ
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3156422\n"
"help.text"
msgid "The completion text is highlighted."
msgstr "ຂໍ້ຄວາມທີ່ຖືກຕື່ມໃຫ້ສົມບູນຈະຖືກເນັ້ນ."

#. VzUyV
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_idN1065D\n"
"help.text"
msgid "To accept the completion, press <item type=\"keycode\">Enter</item> or a cursor key."
msgstr "ເພື່ອຍອມຮັບຂໍ້ຄວາມທີ່ຕື່ມໃຫ້, ໃຫ້ກົດ <item type=\"keycode\">Enter</item> ຫຼື ປຸ່ມລູກສອນ."

#. ZDCvA
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_idN10665\n"
"help.text"
msgid "To append text or to edit the completion, press <item type=\"keycode\">F2</item>."
msgstr "ເພື່ອເພີ່ມຂໍ້ຄວາມ ຫຼື ແກ້ໄຂສິ່ງທີ່ຕື່ມໃຫ້, ໃຫ້ກົດ <item type=\"keycode\">F2</item>."

#. iSGKZ
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_idN1066D\n"
"help.text"
msgid "To view more completions, press <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Tab</item> to scroll forward, or <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Shift+Tab</item> to scroll backward."
msgstr "ເພື່ອເບິ່ງລາຍການທີ່ຕື່ມໃຫ້ເພີ່ມເຕີມ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Tab</item> ເພື່ອເລື່ອນໄປທາງໜ້າ, ຫຼື <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Command</item></caseinline><defaultinline><item type=\"keycode\">Ctrl</item></defaultinline></switchinline><item type=\"keycode\">+Shift+Tab</item> ເພື່ອເລື່ອນກັບຄືນ."

#. oxZUt
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_idN10679\n"
"help.text"
msgid "To see a list of all available AutoInput text items for the current column, press <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Option</item></caseinline><defaultinline><item type=\"keycode\">Alt</item></defaultinline></switchinline><item type=\"keycode\">+Down Arrow</item>."
msgstr "ເພື່ອເບິ່ງລາຍການຂໍ້ຄວາມປ້ອນຂໍ້ມູນອັດຕະໂນມັດທັງໝົດທີ່ມີໃນຖັນປັດຈຸບັນ, ໃຫ້ກົດ <switchinline select=\"sys\"><caseinline select=\"MAC\"><item type=\"keycode\">Option</item></caseinline><defaultinline><item type=\"keycode\">Alt</item></defaultinline></switchinline><item type=\"keycode\">+ປຸ່ມລູກສອນລົງ</item>."

#. PEGiD
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3150439\n"
"help.text"
msgid "When typing formulas using characters that match previous entries, a Help tip will appear listing the last ten functions used from <emph>Function Wizard</emph>, from all defined range names, from all database range names, and from the content of all label ranges."
msgstr "ເມື່ອພິມສູດໂດຍໃຊ້ຕົວອັກສອນທີ່ກົງກັບລາຍການກ່ອນໜ້ານີ້, ຄຳແນະນຳຈະປະກົດຂຶ້ນໂດຍສະແດງລາຍຊື່ 10 ຟັງຊັນລ່າສຸດທີ່ໃຊ້ຈາກ <emph>ຕົວຊ່ວຍສ້າງຟັງຊັນ</emph>, ຈາກຊື່ຂອບເຂດທີ່ກຳນົດໄວ້ທັງໝົດ, ຈາກຊື່ຂອບເຂດຖານຂໍ້ມູນທັງໝົດ, ແລະ ຈາກເນື້ອໃນຂອງຂອບເຂດປ້າຍຊື່ທັງໝົດ."

#. ZG6FW
#: 06130000.xhp
msgctxt ""
"06130000.xhp\n"
"par_id3153363\n"
"help.text"
msgid "AutoInput is case-sensitive. If, for example, you have written \"Total\" in a cell, you cannot enter \"total\" in another cell of the same column without first deactivating AutoInput."
msgstr "ການປ້ອນຂໍ້ມູນອັດຕະໂນມັດຈະແຍກຕົວອັກສອນໃຫຍ່ ແລະ ນ້ອຍ. ຕົວຢ່າງ: ຫາກທ່ານໄດ້ຂຽນ \"Total\" ໃນເຊລໜຶ່ງ, ທ່ານຈະບໍ່ສາມາດປ້ອນ \"total\" ໃນເຊລອື່ນຂອງຖັນດຽວກັນໄດ້ ໂດຍບໍ່ປິດການໃຊ້ງານການປ້ອນຂໍ້ມູນອັດຕະໂນມັດກ່ອນ."

#. KPjBn
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"tit\n"
"help.text"
msgid "Split Window"
msgstr "ແຍກໜ້າຕ່າງ"

#. xnsHh
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"bm_id121698508897107\n"
"help.text"
msgid "<bookmark_value>divide window;split</bookmark_value><bookmark_value>split;divide window</bookmark_value><bookmark_value>windows; splitting</bookmark_value>"
msgstr "<bookmark_value>ແບ່ງໜ້າຕ່າງ; ແຍກ</bookmark_value><bookmark_value>ແຍກ; ແບ່ງໜ້າຕ່າງ</bookmark_value><bookmark_value>ໜ້າຕ່າງ; ການແຍກ</bookmark_value>"

#. yDiQC
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"hd_id3163800\n"
"help.text"
msgid "<link href=\"text/scalc/01/07080000.xhp\">Split Window</link>"
msgstr "<link href=\"text/scalc/01/07080000.xhp\">ແຍກໜ້າຕ່າງ</link>"

#. FoS5h
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"par_id3150084\n"
"help.text"
msgid "<ahelp hid=\".\">Divides the current window at the top left corner of the active cell.</ahelp>"
msgstr "<ahelp hid=\".\">ແບ່ງໜ້າຕ່າງປັດຈຸບັນຢູ່ທີ່ມຸມຊ້າຍເທິງຂອງເຊລທີ່ກຳລັງໃຊ້ງານ.</ahelp>"

#. bAPiD
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"par_id3154910\n"
"help.text"
msgid "You can also use the mouse to split the window horizontally or vertically. To do this, drag the thick black line located directly above the vertical scrollbar or directly to the right of the horizontal scrollbar into the window. A thick black line will show where the window is split."
msgstr "ທ່ານຍັງສາມາດໃຊ້ເມົາສ໌ເພື່ອແຍກໜ້າຕ່າງຕາມລວງນອນ ຫຼື ລວງຕັ້ງໄດ້. ເພື່ອເຮັດສິ່ງນີ້, ໃຫ້ລາກເສັ້ນສີດຳເຂັ້ມທີ່ຢູ່ເທິງແຖບເລື່ອນລວງຕັ້ງ ຫຼື ຢູ່ທາງດ້ານຂວາຂອງແຖບເລື່ອນລວງນອນເຂົ້າໄປໃນໜ້າຕ່າງ. ເສັ້ນສີດຳເຂັ້ມຈະສະແດງໃຫ້ເຫັນບ່ອນທີ່ໜ້າຕ່າງຖືກແຍກອອກ."

#. jbFfX
#: 07080000.xhp
msgctxt ""
"07080000.xhp\n"
"par_id3149263\n"
"help.text"
msgid "A split window has its own scrollbars in each partial section; by contrast, <link href=\"text/scalc/01/07090000.xhp\">fixed window sections</link> are not scrollable."
