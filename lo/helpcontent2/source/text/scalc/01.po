"par_id771708806478128\n"
"help.text"
msgid "Transforms an array or range into a single column."
msgstr "ແປງອາເຣ ຫຼື ຊ່ວງໃຫ້ເປັນຖັນດຽວ."

#. h3Kr2
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id851737751444186\n"
"help.text"
msgid "TOCOL(Array [; Ignore [; By_column]])"
msgstr "TOCOL(Array [; Ignore [; By_column]])"

#. DzGBX
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id391737751833481\n"
"help.text"
msgid "<emph>Array</emph>: the array or range to return as a single column."
msgstr "<emph>Array</emph>: ອາເຣ ຫຼື ຊ່ວງທີ່ຈະສົ່ງຄືນເປັນຖັນດຽວ."

#. FCSvz
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id31737751839305\n"
"help.text"
msgid "<emph>Ignore</emph>: (optional) Whether to ignore certain types of values. By default, no values are ignored. Specify one of the following:"
msgstr "<emph>Ignore</emph>: (ທາງເລືອກ) ຕ້ອງການຂ້າມຄ່າບາງປະເພດຫຼືບໍ່. ໂດຍມາດຕະຖານແລ້ວ ຈະບໍ່ຂ້າມຄ່າໃດໆ. ໃຫ້ລະບຸໜຶ່ງໃນຄ່າດັ່ງນີ້:"

#. GDiV2
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id971737751690332\n"
"help.text"
msgid "<emph>0</emph>: Keep all values (default)"
msgstr "<emph>0</emph>: ເກັບທຸກຄ່າໄວ້ (ມາດຕະຖານ)"

#. ySDuV
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id381737751703531\n"
"help.text"
msgid "<emph>1</emph>: Ignore blank cells"
msgstr "<emph>1</emph>: ຂ້າມເຊວຫວ່າງເປົ່າ"

#. qsJVZ
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id931737751715731\n"
"help.text"
msgid "<emph>2</emph>: Ignore cells with errors"
msgstr "<emph>2</emph>: ຂ້າມເຊວທີ່ມີຂໍ້ຜິດພາດ"

#. pEBgh
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id101737751728979\n"
"help.text"
msgid "<emph>3</emph>: Ignore both blank cells and error cells"
msgstr "<emph>3</emph>: ຂ້າມທັງເຊວຫວ່າງເປົ່າ ແລະ ເຊວທີ່ມີຂໍ້ຜິດພາດ"

#. U9F33
#: func_tocol.xhp
msgctxt ""
"func_tocol.xhp\n"
"par_id771737751844889\n"
"help.text"
msgid "<emph>By_column</emph>: (optional) Scan the array by column. By default, the array is scanned by row. Scanning determines whether the values are ordered by row or by column."
msgstr "<emph>By_column</emph>: (ທາງເລືອກ) ກວດສອບອາເຣຕາມຖັນ. ໂດຍມາດຕະຖານແລ້ວ ຈະກວດສອບອາເຣຕາມແຖວ. ການກວດສອບຈະເປັນຕົວຕັດສິນວ່າຄ່າຕ່າງໆຈະຖືກຈັດລຽງຕາມແຖວ ຫຼື ຕາມຖັນ."

#. ffBcv
