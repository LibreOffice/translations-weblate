"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/shared_spreadsheet.xhp\">Share Spreadsheet</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/shared_spreadsheet.xhp\">ແບ່ງປັນສະເປຣດຊີດ</link></variable>"

#. bGC4y
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id9590136\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the Share Document dialog where you can enable or disable collaborative sharing of the document.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງໂຕ້ຕອບ ແບ່ງປັນເອກະສານ ເຊິ່ງທ່ານສາມາດເປີດ ຫຼື ປິດການແບ່ງປັນເອກະສານເພື່ອເຮັດວຽກຮ່ວມກັນໄດ້.</ahelp>"

#. KZGLG
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id551647272004709\n"
"help.text"
msgid "Sharing a spreadsheet allows several users to open the same file for editing at the same time."
msgstr "ການແບ່ງປັນສະເປຣດຊີດຊ່ວຍໃຫ້ຜູ້ໃຊ້ຫຼາຍຄົນສາມາດເປີດໄຟລ໌ດຽວກັນເພື່ອແກ້ໄຂໃນເວລາດຽວກັນໄດ້."

#. 9BuYS
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id211647275285230\n"
"help.text"
msgid "The spreadsheet needs to be on a shared drive, server, website, or similar. Some conditions must be met on operating systems with user permission management:"
msgstr "ສະເປຣດຊີດຕ້ອງຢູ່ໃນໄດຣຟ໌ທີ່ແບ່ງປັນ, ເຊີບເວີ, ເວັບໄຊ, ຫຼື ສິ່ງທີ່ຄ້າຍຄືກັນ. ຕ້ອງປະຕິບັດຕາມບາງເງື່ອນໄຂໃນລະບົບປະຕິບັດການທີ່ມີການຈັດການສິດອະນຸຍາດຜູ້ໃຊ້:"

#. 7Cbn3
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id621647275321672\n"
"help.text"
msgid "The shared file needs to reside in a location which is accessible by all collaborators."
msgstr "ໄຟລ໌ທີ່ແບ່ງປັນຕ້ອງຢູ່ໃນຕຳແໜ່ງທີ່ຜູ້ຮ່ວມມືທັງໝົດສາມາດເຂົ້າເຖິງໄດ້."

#. 6hGDF
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id731647275360618\n"
"help.text"
msgid "The file permissions for both the document and the corresponding lock file need to be set so that all collaborators can create, delete, and change the files."
msgstr "ສິດອະນຸຍາດໄຟລ໌ທັງເອກະສານ ແລະ ໄຟລ໌ລັອກທີ່ກ່ຽວຂ້ອງຕ້ອງຖືກຕັ້ງຄ່າເພື່ອໃຫ້ຜູ້ຮ່ວມມືທັງໝົດສາມາດສ້າງ, ລຶບ, ແລະ ປ່ຽນແປງໄຟລ໌ໄດ້."

#. UhRSD
#: shared_spreadsheet.xhp
msgctxt ""
"shared_spreadsheet.xhp\n"
"par_id631647275500217\n"
"help.text"
msgid "In order to correctly identify the changes, each collaborator should enter their name in <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - Preferences</menuitem></caseinline><defaultinline><menuitem>Tools - Options</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME - User Data</menuitem> on the Menu bar."
msgstr "ເພື່ອລະບຸການປ່ຽນແປງໃຫ້ຖືກຕ້ອງ, ຜູ້ຮ່ວມມືແຕ່ລະຄົນຄວນປ້ອນຊື່ຂອງເຂົາເຈົ້າໃນ <switchinline select=\"sys\"><caseinline select=\"MAC\"><menuitem>%PRODUCTNAME - ຄວາມມັກ</menuitem></caseinline><defaultinline><menuitem>ເຄື່ອງມື - ຕົວເລືອກ</menuitem></defaultinline></switchinline><menuitem> - %PRODUCTNAME - ຂໍ້ມູນຜູ້ໃຊ້</menuitem> ໃນແຖບເມນູ."

