msgctxt ""
"func_sequence.xhp\n"
"par_id211708281649651\n"
"help.text"
msgid "=SEQUENCE(Rows; Columns [; Start [; Step ]])"
msgstr "=SEQUENCE(ແຖວ; ຖັນ [; ເລີ່ມຕົ້ນ [; ຂັ້ນຕອນ ]])"

#. CDwFb
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id601714592655068\n"
"help.text"
msgid "<emph>Rows</emph>: a positive integer. The number of rows to return."
msgstr "<emph>ແຖວ</emph>: ເລກຖ້ວນບວກ. ຈຳນວນແຖວທີ່ຈະສົ່ງຄືນ."

#. G48qz
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id521714592660164\n"
"help.text"
msgid "<emph>Columns</emph>: a positive integer. The number of columns to return."
msgstr "<emph>ຖັນ</emph>: ເລກຖ້ວນບວກ. ຈຳນວນຖັນທີ່ຈະສົ່ງຄືນ."

#. KNGFY
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id171714592664667\n"
"help.text"
msgid "<emph>Start</emph>: optional. The initial value of the sequence. If omitted, default is 1."
msgstr "<emph>ເລີ່ມຕົ້ນ</emph>: ທາງເລືອກ. ຄ່າເລີ່ມຕົ້ນຂອງລຳດັບ. ຖ້າລະເວັ້ນ, ຄ່າເລີ່ມຕົ້ນແມ່ນ 1."

#. CZGrA
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id531714592669635\n"
"help.text"
msgid "<emph>Step</emph>: optional. The increment of each subsequent value in the array. If omitted, default is 1."
msgstr "<emph>ຂັ້ນຕອນ</emph>: ທາງເລືອກ. ຄ່າທີ່ເພີ່ມຂຶ້ນຂອງແຕ່ລະຄ່າຖັດໄປໃນອາເຣ. ຖ້າລະເວັ້ນ, ຄ່າເລີ່ມຕົ້ນແມ່ນ 1."

#. J4cjA
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id821708357634624\n"
"help.text"
msgid "If <emph>Rows</emph> and <emph>Columns</emph> are greater than 1, the SEQUENCE function must be entered as an <link href=\"text/scalc/01/04060107.xhp#creating_array_formulas\">array formula</link>."
msgstr "ຖ້າ <emph>ແຖວ</emph> ແລະ <emph>ຖັນ</emph> ມີຄ່າຫຼາຍກວ່າ 1, ຟັງຊັນ SEQUENCE ຕ້ອງຖືກປ້ອນເປັນ <link href=\"text/scalc/01/04060107.xhp#creating_array_formulas\">ສູດອາເຣ</link>."

#. EmG5r
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id141715790327107\n"
"help.text"
msgid "If <emph>Rows</emph> or <emph>Columns</emph> are references to the content of other cells, the array dimensions do not change when the referenced content changes. The array formula must be deleted and re-entered."
msgstr "ຖ້າ <emph>ແຖວ</emph> ຫຼື <emph>ຖັນ</emph> ເປັນການອ້າງອີງເຖິງເນື້ອຫາຂອງຫ້ອງອື່ນ, ຂະໜາດຂອງອາເຣຈະບໍ່ປ່ຽນແປງເມື່ອເນື້ອຫາທີ່ອ້າງອີງປ່ຽນແປງ. ຕ້ອງລຶບສູດອາເຣແລ້ວປ້ອນໃໝ່."

#. k3KZZ
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id61714595841660\n"
"help.text"
msgid "The array is filled from the first row to the right up to the value of <emph>Columns</emph>, and then down to the number of rows."
msgstr "ອາເຣຈະຖືກຕື່ມຂໍ້ມູນເລີ່ມຈາກແຖວທຳອິດໄປທາງຂວາຈົນຄົບຈຳນວນ <emph>ຖັນ</emph>, ແລ້ວຈຶ່ງລົງມາແຖວຖັດໄປຈົນຄົບຈຳນວນແຖວ."

#. CfrrH
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id201714595986945\n"
"help.text"
msgid "<input>{=SEQUENCE(3; 3; 10; 11)}</input> returns the 3-by-3 array below with an upper-left value of 10 and filling the array to the right and then downward in steps of 11."
msgstr "<input>{=SEQUENCE(3; 3; 10; 11)}</input> ສົ່ງຄືນອາເຣຂະໜາດ 3x3 ໂດຍມີຄ່າເທິງຊ້າຍເລີ່ມຕົ້ນທີ່ 10 ແລະ ຕື່ມຂໍ້ມູນໄປທາງຂວາແລ້ວລົງລຸ່ມ ໂດຍເພີ່ມຂຶ້ນເທື່ອລະ 11."

#. sNE2S
#: func_sequence.xhp
msgctxt ""
"func_sequence.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/SEQUENCE\">SEQUENCE wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/SEQUENCE\">ໜ້າ ວິກິ SEQUENCE</link>."

