msgstr "ລົງທ້າຍດ້ວຍ"

#. Ag7VY
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id801662922600586\n"
"help.text"
msgid "The cell contents ends with the text or number defined in the right text box."
