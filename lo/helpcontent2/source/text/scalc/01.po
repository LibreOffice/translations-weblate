msgctxt ""
"12090106.xhp\n"
"par_idN105BA\n"
"help.text"
msgid "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/using\">Select the data field that you want to sort the data by.</ahelp>"
msgstr "<ahelp hid=\"modules/scalc/ui/datafieldoptionsdialog/using\">ເລືອກເຂດຂໍ້ມູນທີ່ທ່ານຕ້ອງການຈັດລຽງຂໍ້ມູນ.</ahelp>"

#. AcXgp
#: 12090106.xhp
msgctxt ""
"12090106.xhp\n"
"par_idN105BD\n"
