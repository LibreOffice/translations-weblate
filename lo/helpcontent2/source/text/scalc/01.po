msgstr "ຟັງຊັນ TAKE"

#. 7FEnC
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"bm_id361708283183878\n"
"help.text"
msgid "<bookmark_value>TAKE function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ TAKE</bookmark_value>"

#. pB7UF
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"hd_id901708806478126\n"
"help.text"
msgid "<variable id=\"h1\"><link href=\"text/scalc/01/func_take.xhp\">TAKE</link></variable>"
msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_take.xhp\">TAKE</link></variable>"

#. M8amC
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Returns a specified number of contiguous rows or columns from the start or end of an array."
msgstr "ສົ່ງຄືນຈຳນວນແຖວ ຫຼື ຖັນທີ່ຢູ່ຕິດກັນຕາມທີ່ລະບຸ ຈາກສ່ວນເລີ່ມຕົ້ນ ຫຼື ສ່ວນທ້າຍຂອງອາເຣ."

#. hEfgM
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id851737751444186\n"
"help.text"
msgid "=TAKE(Array; Rows [; Columns])"
msgstr "=TAKE(Array; Rows [; Columns])"

#. A2PcT
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id391737751833481\n"
"help.text"
msgid "<emph>Array</emph>: the array or range from which to take rows or columns."
msgstr "<emph>Array</emph>: ອາເຣ ຫຼື ຊ່ວງທີ່ຈະດຶງເອົາແຖວ ຫຼື ຖັນ."

#. VY85L
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id111738104866763\n"
"help.text"
msgid "<emph>Rows</emph>: the number of rows to take. A negative value takes from the end of the array."
msgstr "<emph>Rows</emph>: ຈຳນວນແຖວທີ່ຈະດຶງເອົາ. ຄ່າລົບຈະເປັນການດຶງເອົາຈາກສ່ວນທ້າຍຂອງອາເຣ."

#. MGCkb
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id111738104891522\n"
"help.text"
msgid "<emph>Columns</emph>: (optional) the number of columns to take. A negative value takes from the end of the array."
msgstr "<emph>Columns</emph>: (ທາງເລືອກ) ຈຳນວນຖັນທີ່ຈະດຶງເອົາ. ຄ່າລົບຈະເປັນການດຶງເອົາຈາກສ່ວນທ້າຍຂອງອາເຣ."

#. F6cM9
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id711737758586509\n"
"help.text"
msgid "The formula <input>{=TAKE(A1:E3;;3)}</input> returns the array with 3 rows (default) and 3 columns."
msgstr "ສູດ <input>{=TAKE(A1:E3;;3)}</input> ສົ່ງຄືນອາເຣທີ່ມີ 3 ແຖວ (ຄ່າມາດຕະຖານ) ແລະ 3 ຖັນ."

#. yhCLT
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id351737760079923\n"
"help.text"
msgid "The formula <input>{=TAKE(A1:E3;2;4)}</input> returns the array below with 2 rows and 4 columns."
msgstr "ສູດ <input>{=TAKE(A1:E3;2;4)}</input> ສົ່ງຄືນອາເຣດ້ານລຸ່ມທີ່ມີ 2 ແຖວ ແລະ 4 ຖັນ."

#. BQjC5
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id631738108398030\n"
"help.text"
msgid "The formula <input>{=TAKE(A1:E3;-2;-2)}</input> returns the array below taking 2 rows starting from the last row and 2 columns starting from the last column."
msgstr "ສູດ <input>{=TAKE(A1:E3;-2;-2)}</input> ສົ່ງຄືນອາເຣດ້ານລຸ່ມໂດຍດຶງເອົາ 2 ແຖວເລີ່ມຈາກແຖວສຸດທ້າຍ ແລະ 2 ຖັນເລີ່ມຈາກຖັນສຸດທ້າຍ."

#. yTovP
#: func_take.xhp
msgctxt ""
"func_take.xhp\n"
"par_id701677016751508\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TAKE\">TAKE wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/TAKE\">ໜ້າ wiki ຂອງ TAKE</link>."

