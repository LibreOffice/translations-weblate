msgctxt ""
"04060106.xhp\n"
"par_id3164404\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_WURZEL\">Returns the positive square root of a number.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_WURZEL\">ສົ່ງຄ່າຮາກຂັ້ນສອງທີ່ເປັນບວກຂອງຕົວເລກ.</ahelp>"

#. x7UG6
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164437\n"
"help.text"
msgid "SQRT(Number)"
msgstr "SQRT(Number)"

#. oUAGh
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164451\n"
"help.text"
msgid "Returns the positive square root of <emph>Number</emph>."
msgstr "ສົ່ງຄ່າຮາກຂັ້ນສອງທີ່ເປັນບວກຂອງ <emph>Number</emph>."

#. vpBGF
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id6870021\n"
"help.text"
msgid "Number must be positive."
msgstr "ຕົວເລກຕ້ອງເປັນຄ່າບວກ."

#. o7PWn
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164484\n"
"help.text"
msgid "<item type=\"input\">=SQRT(16)</item> returns 4."
msgstr "<item type=\"input\">=SQRT(16)</item> ສົ່ງຄ່າຄືນມາແມ່ນ 4."

#. W7skD
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3591723\n"
"help.text"
msgid "<item type=\"input\">=SQRT(-16)</item> returns an <item type=\"literal\">invalid argument</item> error."
msgstr "<item type=\"input\">=SQRT(-16)</item> ຈະແຈ້ງຂໍ້ຜິດພາດ <item type=\"literal\">ໂຕ້ແຍ້ງບໍ່ຖືກຕ້ອງ (invalid argument)</item>."

#. ddTG3
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"bm_id3164560\n"
"help.text"
msgid "<bookmark_value>SQRTPI function</bookmark_value>  <bookmark_value>square roots;products of Pi</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ SQRTPI</bookmark_value>  <bookmark_value>ຮາກຂັ້ນສອງ; ຜົນຄູນຂອງຄ່າ Pi</bookmark_value>"

#. 5w2mG
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"hd_id3164560\n"
"help.text"
msgid "SQRTPI"
msgstr "SQRTPI"

#. yYVKB
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164596\n"
"help.text"
msgid "<ahelp hid=\"HID_AAI_FUNC_SQRTPI\">Returns the square root of (PI times a number).</ahelp>"
msgstr "<ahelp hid=\"HID_AAI_FUNC_SQRTPI\">ສົ່ງຄ່າຮາກຂັ້ນສອງຂອງ (ຄ່າ PI ຄູນໃຫ້ຕົວເລກ).</ahelp>"

#. bTULe
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164627\n"
"help.text"
msgid "SQRTPI(Number)"
msgstr "SQRTPI(Number)"

#. pvRg7
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id1501510\n"
"help.text"
msgid "Returns the positive square root of (PI multiplied by <emph>Number</emph>)."
msgstr "ສົ່ງຄ່າຮາກຂັ້ນສອງທີ່ເປັນບວກຂອງ (PI ຄູນໃຫ້ <emph>Number</emph>)."

#. MFKzD
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id9929197\n"
"help.text"
msgid "This is equivalent to <item type=\"literal\">SQRT(PI()*Number)</item>."
msgstr "ຄ່ານີ້ເທົ່າກັບການໃຊ້ສູດ <item type=\"literal\">SQRT(PI()*Number)</item>."

#. kMDdF
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164654\n"
"help.text"
msgid "<item type=\"input\">=SQRTPI(2)</item> returns the squareroot of (2PI), approximately 2.506628."
msgstr "<item type=\"input\">=SQRTPI(2)</item> ສົ່ງຄ່າຮາກຂັ້ນສອງຂອງ (2PI), ເຊິ່ງມີຄ່າປະມານ 2.506628."

#. en4Ae
