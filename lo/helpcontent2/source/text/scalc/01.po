#. AwD6d
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Returns the array of unique values from a range or array of values."
msgstr "ສົ່ງຄືນອາເຣຂອງຄ່າທີ່ບໍ່ຊ້ຳກັນຈາກຊ່ວງ ຫຼື ອາເຣຂອງຄ່າຕ່າງໆ."

#. DmmhA
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id211708281649651\n"
"help.text"
msgid "=UNIQUE(Array [; By col [; Uniqueness] ])"
msgstr "=UNIQUE(Array [; By col [; Uniqueness] ])"

#. DUA7p
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id381715698113514\n"
"help.text"
msgid "<emph>Array</emph>: the range or array from which to return unique values."
msgstr "<emph>Array</emph>: ຊ່ວງ ຫຼື ອາເຣທີ່ຈະໃຊ້ສົ່ງຄືນຄ່າທີ່ບໍ່ຊ້ຳກັນ."

#. ZDyWq
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id311715698119400\n"
"help.text"
msgid "<emph>By col</emph>: (optional) a logical value that indicates how to compare data: TRUE - compares data horizontally for a match of all cells in each column, across all columns. FALSE or omitted (default) - compares data vertically, for a match of all cells of each row, across all rows."
msgstr "<emph>By col</emph>: (ທາງເລືອກ) ຄ່າທາງໂລຊິກທີ່ບອກວິທີສົມທຽບຂໍ້ມູນ: TRUE - ສົມທຽບຂໍ້ມູນຕາມແນວນອນເພື່ອຫາສ່ວນທີ່ກົງກັນຂອງທຸກເຊວໃນແຕ່ລະຖັນ. FALSE ຫຼື ບໍ່ລະບຸ (ມາດຕະຖານ) - ສົມທຽບຂໍ້ມູນຕາມແນວຕັ້ງເພື່ອຫາສ່ວນທີ່ກົງກັນຂອງທຸກເຊວໃນແຕ່ລະແຖວ."

#. DSDnH
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id531715698124705\n"
"help.text"
msgid "<emph>Uniqueness</emph>: (optional) A logical value that defines which values are considered unique. TRUE returns values that occur only once. The default is FALSE or omitted, which returns all distinct values in the range or array."
msgstr "<emph>Uniqueness</emph>: (ທາງເລືອກ) ຄ່າທາງໂລຊິກທີ່ກຳນົດວ່າຄ່າໃດຈະຖືກຖືວ່າບໍ່ຊ້ຳກັນ. TRUE ສົ່ງຄືນຄ່າທີ່ປາກົດພຽງຄັ້ງດຽວເທົ່ານັ້ນ. ຄ່າມາດຕະຖານແມ່ນ FALSE ຫຼື ບໍ່ລະບຸ ເຊິ່ງຈະສົ່ງຄືນທຸກຄ່າທີ່ແຕກຕ່າງກັນໃນຊ່ວງ ຫຼື ອາເຣ."

#. RUvGf
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"par_id471715980557106\n"
"help.text"
msgid "Given the data table below, the examples returns unique occurrences of grades and age."
msgstr "ຈາກຕາຕະລາງຂໍ້ມູນດ້ານລຸ່ມ, ຕົວຢ່າງນີ້ຈະສົ່ງຄືນຄ່າຄະແນນ ແລະ ອາຍຸ ທີ່ບໍ່ຊ້ຳກັນ."

#. Kgeri
#: func_unique.xhp
msgctxt ""
"func_unique.xhp\n"
"hd_id931715984553129\n"
"help.text"
msgid "Example 1"
msgstr "ຕົວຢ່າງ 1"

#. WFCgh
