msgctxt ""
"12040100.xhp\n"
"par_id3148550\n"
"help.text"
msgid "<ahelp hid=\".uno:DataFilterAutoFilter\">Automatically filters the selected cell range, and creates one-row list boxes where you can choose the items that you want to display.</ahelp>"
msgstr "<ahelp hid=\".uno:DataFilterAutoFilter\">ກັ່ນຕອງຂອບເຂດເຊລທີ່ເລືອກໂດຍອັດຕະໂນມັດ, ແລະ ສ້າງກ່ອງລາຍການແບບແຖວດຽວ ເພື່ອໃຫ້ທ່ານສາມາດເລືອກລາຍການທີ່ຕ້ອງການສະແດງ.</ahelp>"

#. c9BGE
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id101621534096986\n"
"help.text"
msgid "Sort Ascending"
msgstr "ຈັດລຽງຈາກນ້ອຍຫາໃຫຍ່"

#. u7XHt
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id31621544435954\n"
"help.text"
msgid "Displays the rows of the cell range in ascending order, based on the values in the cells of the current column."
msgstr "ສະແດງແຖວຂອງຂອບເຂດເຊລລຽງຈາກນ້ອຍຫາໃຫຍ່, ໂດຍອີງຕາມຄ່າໃນເຊລຂອງຖັນປັດຈຸບັນ."

#. 6Q8nn
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id561621534101425\n"
"help.text"
msgid "Sort Descending"
msgstr "ຈັດລຽງຈາກໃຫຍ່ຫານ້ອຍ"

#. CbVJm
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id861621544431393\n"
"help.text"
msgid "Displays the rows of the cell range in descending order, based on the values in the cells of the current column."
msgstr "ສະແດງແຖວຂອງຂອບເຂດເຊລລຽງຈາກໃຫຍ່ຫານ້ອຍ, ໂດຍອີງຕາມຄ່າໃນເຊລຂອງຖັນປັດຈຸບັນ."

#. DGMci
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id391674926239837\n"
"help.text"
msgid "Filter by Color"
msgstr "ຕອງຕາມສີ"

#. s5KFC
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id271621534120995\n"
"help.text"
msgid "Text color"
msgstr "ສີຂໍ້ຄວາມ"

#. CCGqV
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id691621544414646\n"
"help.text"
msgid "Displays only the rows of the cell range for which the text color of the cell in the current column matches the color selected."
msgstr "ສະແດງສະເພາະແຖວຂອງຂອບເຂດເຊລທີ່ສີຂໍ້ຄວາມຂອງເຊລໃນຖັນປັດຈຸບັນກົງກັບສີທີ່ເລືອກ."

#. pdme8
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id151621534125831\n"
"help.text"
msgid "Background color"
msgstr "ສີພື້ນຫຼັງ"

#. dzEhB
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id491621544410605\n"
"help.text"
msgid "Displays only the rows of the cell range for which the background color of the cell in the current column matches the color selected."
msgstr "ສະແດງສະເພາະແຖວຂອງຂອບເຂດເຊລທີ່ສີພື້ນຫຼັງຂອງເຊລໃນຖັນປັດຈຸບັນກົງກັບສີທີ່ເລືອກ."

#. EvRxc
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id771674926517261\n"
"help.text"
msgid "Filter by Condition"
msgstr "ຕອງຕາມເງື່ອນໄຂ"

#. 4oiCy
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id541621534109912\n"
"help.text"
msgid "Empty"
msgstr "ວ່າງເປົ່າ"

#. i3DFZ
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id941621544422352\n"
"help.text"
msgid "Displays only the rows of the cell range that have an empty cell in the current column."
msgstr "ສະແດງສະເພາະແຖວຂອງຂອບເຂດເຊລທີ່ມີເຊລວ່າງເປົ່າໃນຖັນປັດຈຸບັນ."

#. s26iT
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id821621534116893\n"
"help.text"
msgid "Not Empty"
msgstr "ບໍ່ວ່າງເປົ່າ"

#. GCBF5
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id71621544418559\n"
"help.text"
msgid "Displays only the rows of the cell range that have a non-empty cell in the current column."
msgstr "ສະແດງສະເພາະແຖວຂອງຂອບເຂດເຊລທີ່ມີເຊລບໍ່ວ່າງເປົ່າໃນຖັນປັດຈຸບັນ."

#. sHhH3
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id401621534105620\n"
"help.text"
msgid "Top 10"
msgstr "10 ອັນດັບສູງສຸດ"

#. onMjn
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id341621544426925\n"
"help.text"
msgid "Displays the 10 rows of the cell range that contain the largest values in the cells of the current column. If these values are unique then no more than 10 rows will be visible, but if the values are not unique then it is possible for more than 10 rows to be shown."
msgstr "ສະແດງ 10 ແຖວຂອງຂອບເຂດເຊລທີ່ມີຄ່າໃຫຍ່ທີ່ສຸດໃນຖັນປັດຈຸບັນ. ຫາກຄ່າເຫຼົ່ານີ້ບໍ່ຊ້ຳກັນ ຈະມີພຽງ 10 ແຖວທີ່ສະແດງໃຫ້ເຫັນ, ແຕ່ຫາກມີຄ່າຊ້ຳກັນ ກໍເປັນໄປໄດ້ທີ່ຈະສະແດງຫຼາຍກວ່າ 10 ແຖວ."

#. gV63G
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id91674926632440\n"
"help.text"
msgid "Bottom 10"
msgstr "10 ອັນດັບຕ່ຳສຸດ"

#. uWEex
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id791674926643175\n"
"help.text"
msgid "Displays the 10 rows of the cell range that contain the lowest values in the cells of the current column. If these values are unique then no more than 10 rows will be visible, but if the values are not unique then it is possible for more than 10 rows to be shown."
msgstr "ສະແດງ 10 ແຖວຂອງຂອບເຂດເຊລທີ່ມີຄ່າຕ່ຳທີ່ສຸດໃນຖັນປັດຈຸບັນ. ຫາກຄ່າເຫຼົ່ານີ້ບໍ່ຊ້ຳກັນ ຈະມີພຽງ 10 ແຖວທີ່ສະແດງໃຫ້ເຫັນ, ແຕ່ຫາກມີຄ່າຊ້ຳກັນ ກໍເປັນໄປໄດ້ທີ່ຈະສະແດງຫຼາຍກວ່າ 10 ແຖວ."

#. wCDB5
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id851621534131430\n"
"help.text"
msgid "Standard Filter"
msgstr "ຕົວຕອງມາດຕະຖານ"

#. xwADP
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id171621544405886\n"
"help.text"
msgid "Opens the <link href=\"text/shared/02/12090100.xhp\">Standard Filter</link> dialog."
msgstr "ເປີດກ່ອງໂຕ້ຕອບ <link href=\"text/shared/02/12090100.xhp\">ຕົວຕອງມາດຕະຖານ</link>."

#. bbVTh
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id551621534136181\n"
"help.text"
msgid "Search text box"
msgstr "ກ່ອງຄົ້ນຫາຂໍ້ຄວາມ"

#. XeGD3
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id421621544399700\n"
"help.text"
msgid "Search for a specific entry in the list of values found in the current column. As characters are typed in the text box, this list is updated to show only matching entries."
msgstr "ຄົ້ນຫາລາຍການສະເພາະໃນລາຍການຄ່າທີ່ພົບໃນຖັນປັດຈຸບັນ. ໃນຂະນະທີ່ທ່ານພິມຕົວອັກສອນລົງໃນກ່ອງຂໍ້ຄວາມ, ລາຍການນີ້ຈະຖືກອັບເດດເພື່ອສະແດງສະເພາະລາຍການທີ່ກົງກັນ."

#. igezW
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id581621534140892\n"
"help.text"
msgid "All"
msgstr "ທັງໝົດ"

#. F52s3
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id641621544394836\n"
"help.text"
msgid "Click once to select to show all rows and click again to select to hide all rows."
msgstr "ກົດໜຶ່ງຄັ້ງເພື່ອເລືອກໃຫ້ສະແດງທຸກແຖວ ແລະ ກົດອີກຄັ້ງເພື່ອເລືອກໃຫ້ເຊື່ອງທຸກແຖວ."

#. amB7U
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id731621534146408\n"
"help.text"
msgid "Show only current item"
msgstr "ສະແດງສະເພາະລາຍການປັດຈຸບັນ"

#. FURWe
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id71621544390147\n"
"help.text"
msgid "Display only rows containing the value highlighted in the <emph>Value</emph> box."
msgstr "ສະແດງສະເພາະແຖວທີ່ມີຄ່າທີ່ຖືກເນັ້ນໃນກ່ອງ <emph>Value</emph>."

#. 8NmUR
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id11621534151081\n"
"help.text"
msgid "Hide only current item"
msgstr "ເຊື່ອງສະເພາະລາຍການປັດຈຸບັນ"

#. EJgvW
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id491621544384770\n"
"help.text"
msgid "Hide all rows containing the value highlighted in the <emph>Value</emph> box and display all other rows."
msgstr "ເຊື່ອງທຸກແຖວທີ່ມີຄ່າທີ່ຖືກເນັ້ນໃນກ່ອງ <emph>Value</emph> ແລະ ສະແດງແຖວອື່ນໆທັງໝົດ."

#. kVCCi
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"hd_id621621534155662\n"
"help.text"
msgid "Values"
msgstr "ຄ່າ"

#. AzWUy
#: 12040100.xhp
msgctxt ""
"12040100.xhp\n"
"par_id331621544378745\n"
"help.text"
msgid "List of unique values found in the current column."
msgstr "ລາຍການຂອງຄ່າທີ່ບໍ່ຊ້ຳກັນທີ່ພົບໃນຄໍລຳປັດຈຸບັນ."

#. G245J
#: 12040201.xhp
msgctxt ""
"12040201.xhp\n"
"tit\n"
"help.text"
msgid "Options"
msgstr "ຕົວເລືອກ"

