"help.text"
msgid "T Function"
msgstr "ຟັງຊັນ T"

#. CDrDp
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"bm_id3148977\n"
"help.text"
msgid "<bookmark_value>T function</bookmark_value>"
msgstr "<bookmark_value>ຟັງຊັນ T</bookmark_value>"

#. BzaQX
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"hd_id3148977\n"
"help.text"
msgid "<variable id=\"t_h1\">          <link href=\"text/scalc/01/func_t.xhp\">T</link>        </variable>"
msgstr "<variable id=\"t_h1\">          <link href=\"text/scalc/01/func_t.xhp\">T</link>        </variable>"

#. 2ALrG
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id3154359\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_T\">This function returns the target text, or a blank text string if the target is not text.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_T\">ຟັງຊັນນີ້ສົ່ງຄືນຂໍ້ຄວາມເປົ້າໝາຍ, ຫຼື ສົ່ງຄືນຂໍ້ຄວາມຫວ່າງເປົ່າ ຖ້າຫາກເປົ້າໝາຍນັ້ນບໍ່ແມ່ນຂໍ້ຄວາມ.</ahelp>"

#. 6g9XD
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id9115573\n"
"help.text"
msgid "If an error occurs the function returns the error value."
msgstr "ຖ້າເກີດຂໍ້ຜິດພາດ ຟັງຊັນຈະສົ່ງຄືນຄ່າຂໍ້ຜິດພາດ."

#. Eamws
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id3155871\n"
"help.text"
msgid "T(Value)"
msgstr "T(Value)"

#. q6iWf
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id3154726\n"
"help.text"
msgid "If <emph>Value</emph> is a text string or refers to a text string, T returns that text string; otherwise it returns a blank text string."
msgstr "ຖ້າ <emph>Value</emph> ແມ່ນຂໍ້ຄວາມ ຫຼື ອ້າງອີງໃສ່ຂໍ້ຄວາມ, ຟັງຊັນ T ຈະສົ່ງຄືນຂໍ້ຄວາມນັ້ນ; ຖ້າບໍ່ດັ່ງນັ້ນ ມັນຈະສົ່ງຄືນຂໍ້ຄວາມຫວ່າງເປົ່າ."

#. RM638
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id3151062\n"
"help.text"
msgid "<item type=\"input\">=T(12345)</item> returns an empty string."
msgstr "<item type=\"input\">=T(12345)</item> ສົ່ງຄືນຂໍ້ຄວາມຫວ່າງເປົ່າ."

#. CeMCC
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id4650105\n"
"help.text"
msgid "<item type=\"input\">=T(\"12345\")</item> returns the string 12345."
msgstr "<item type=\"input\">=T(\"12345\")</item> ສົ່ງຄືນຂໍ້ຄວາມ 12345."

#. wYFz8
#: func_t.xhp
msgctxt ""
"func_t.xhp\n"
"par_id701677016652715\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/T\">T wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/T\">ໜ້າ wiki ຂອງ T</link>."

