"par_id2956118\n"
"help.text"
msgid "<item type=\"input\">=BETA.DIST(2;8;10;1;1;3)</item> returns the value 0.6854706"
msgstr "<item type=\"input\">=BETA.DIST(2;8;10;1;1;3)</item> ສົ່ງຄ່າຄືນ 0.6854706"

