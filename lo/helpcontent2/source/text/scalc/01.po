msgstr "<variable id=\"h1\"><link href=\"text/scalc/01/func_wraprows.xhp\">WRAPROWS</link></variable>"

#. nnTvF
#: func_wraprows.xhp
msgctxt ""
"func_wraprows.xhp\n"
"par_id771708806478128\n"
"help.text"
msgid "Converts a single row or column into multiple rows (a 2-dimensional array) by specifying the number of values in each row."
msgstr "ປ່ຽນແຖວ ຫຼື ຖັນດຽວໃຫ້ເປັນຫຼາຍແຖວ (ອາເຣ 2 ມິຕິ) ໂດຍການກຳນົດຈຳນວນຄ່າໃນແຕ່ລະແຖວ."

#. wdQ3A
#: func_wraprows.xhp
msgctxt ""
"func_wraprows.xhp\n"
"par_id871737825179033\n"
"help.text"
msgid "=WRAPROWS(Range; Wrap_count [; Pad_with])"
msgstr "=WRAPROWS(Range; Wrap_count [; Pad_with])"

#. xDnxq
