#. Xm32t
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"hd_id3151005\n"
"help.text"
msgid "<variable id=\"search_h1\">          <link href=\"text/scalc/01/func_search.xhp\">SEARCH</link>        </variable>"
msgstr "<variable id=\"search_h1\">          <link href=\"text/scalc/01/func_search.xhp\">SEARCH</link>        </variable>"

#. DjRPF
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3148692\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_SUCHEN\">Returns the position of a text segment within a character string.</ahelp> You can set the start of the search as an option. The search text can be a number or any sequence of characters. The search is not case-sensitive. If the text is not found, returns error 519 (#VALUE)."
msgstr "<ahelp hid=\"HID_FUNC_SUCHEN\">ສົ່ງຄືນຕຳແໜ່ງຂອງສ່ວນຂໍ້ຄວາມພາຍໃນຂໍ້ຄວາມອື່ນ.</ahelp> ທ່ານສາມາດຕັ້ງຈຸດເລີ່ມຕົ້ນຂອງການຊອກຫາໄດ້. ຂໍ້ຄວາມທີ່ຊອກຫາສາມາດເປັນຕົວເລກ ຫຼື ຊຸດຂອງຕົວອັກສອນໃດໆກໍໄດ້. ການຊອກຫາບໍ່ຈຳແນກຕົວພິມໃຫຍ່-ນ້ອຍ. ຖ້າບໍ່ພົບຂໍ້ຄວາມ, ຈະສົ່ງຄືນຂໍ້ຜິດພາດ 519 (#VALUE)."

#. 5enXA
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3154671\n"
"help.text"
msgid "SEARCH(\"FindText\"; \"Text\" [; Position])"
msgstr "SEARCH(\"ຂໍ້ຄວາມທີ່ຈະຊອກ\"; \"ຂໍ້ຄວາມ\" [; ຕຳແໜ່ງ])"

#. oEFQt
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3146080\n"
"help.text"
msgid "<emph>FindText</emph> is the text to be searched for."
msgstr "<emph>ຂໍ້ຄວາມທີ່ຈະຊອກ</emph> ແມ່ນຂໍ້ຄວາມທີ່ຕ້ອງການຊອກຫາ."

#. qUeDD
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3154111\n"
"help.text"
msgid "<emph>Text</emph> is the text where the search will take place."
msgstr "<emph>ຂໍ້ຄວາມ</emph> ແມ່ນຂໍ້ຄວາມທີ່ຈະດຳເນີນການຊອກຫາ."

#. XdBZc
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3149559\n"
"help.text"
msgid "<emph>Position</emph> (optional) is the position in the text where the search is to start."
msgstr "<emph>ຕຳແໜ່ງ</emph> (ທາງເລືອກ) ແມ່ນຕຳແໜ່ງໃນຂໍ້ຄວາມທີ່ຈະເລີ່ມຊອກຫາ."

#. 4ahnd
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id3154564\n"
"help.text"
msgid "<item type=\"input\">=SEARCH(54;998877665544)</item> returns 10."
msgstr "<item type=\"input\">=SEARCH(54;998877665544)</item> ສົ່ງຄືນ 10."

#. MTKU2
#: func_search.xhp
msgctxt ""
"func_search.xhp\n"
"par_id701677016652715\n"
"help.text"
msgid "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/SEARCH\">SEARCH wiki page</link>."
msgstr "<link href=\"https://wiki.documentfoundation.org/Documentation/Calc_Functions/SEARCH\">ໜ້າ ວິກິ SEARCH</link>."

