msgid "is below or equal average"
msgstr "ຕ່ຳກວ່າ ຫຼື ເທົ່າກັບຄ່າສະເລ່ຍ"

#. GRFFh
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"par_id131662919771411\n"
"help.text"
msgid "The cell value is less or equal than the average of the cell range values."
msgstr "ຄ່າໃນຫ້ອງແມ່ນໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບຄ່າສະເລ່ຍຂອງຄ່າໃນຊ່ວງຫ້ອງນັ້ນ."

#. R6uQc
#: 05120100.xhp
msgctxt ""
"05120100.xhp\n"
"hd_id301665406258582\n"
"help.text"
msgid "Conditions on Errors in Cells."
msgstr "ເງື່ອນໄຂສຳລັບ ຂໍ້ຜິດພາດ ໃນຫ້ອງ."

#. PBCMe
