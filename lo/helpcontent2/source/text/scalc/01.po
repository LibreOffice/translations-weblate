msgctxt ""
"04060106.xhp\n"
"par_id3164711\n"
"help.text"
msgid "<ahelp hid=\"HID_AAI_FUNC_RANDBETWEEN\">Returns an integer random number in a specified range.</ahelp>"
msgstr "<ahelp hid=\"HID_AAI_FUNC_RANDBETWEEN\">ສົ່ງຄ່າຕົວເລກສຸ່ມທີ່ເປັນຈຳນວນຖ້ວນໃນຂອບເຂດທີ່ກຳນົດ.</ahelp>"

#. c7jXH
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164758\n"
"help.text"
msgid "RANDBETWEEN(Bottom; Top)"
msgstr "RANDBETWEEN(Bottom; Top)"

#. NjkAg
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id7112338\n"
"help.text"
msgid "Returns an integer random number between integers <emph>Bottom</emph> and <emph>Top</emph> (both inclusive)."
msgstr "ສົ່ງຄ່າຕົວເລກສຸ່ມທີ່ເປັນຈຳນວນຖ້ວນ ລະຫວ່າງຈຳນວນຖ້ວນ <emph>Bottom</emph> (ຕ່ຳສຸດ) ແລະ <emph>Top</emph> (ສູງສຸດ) (ລວມທັງສອງຄ່ານີ້)."

#. kanbM
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id2855616\n"
"help.text"
msgid "This function produces a new random number each time Calc recalculates. To force Calc to recalculate manually press F9."
msgstr "ຟັງຊັນນີ້ຈະສ້າງຕົວເລກສຸ່ມໃໝ່ທຸກຄັ້ງທີ່ Calc ຄຳນວນຄືນ. ເພື່ອບັງຄັບໃຫ້ Calc ຄຳນວນຄືນດ້ວຍມື, ໃຫ້ກົດ F9."

#. BtCGn
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id2091433\n"
"help.text"
msgid "To generate random numbers which never recalculate, copy cells containing this function, and use <item type=\"menuitem\">Edit - Paste Special</item> (with <item type=\"menuitem\">Paste All</item> and <item type=\"menuitem\">Formulas</item> not marked and <item type=\"menuitem\">Numbers</item> marked)."
msgstr "ເພື່ອສ້າງຕົວເລກແບບສຸ່ມທີ່ຈະບໍ່ມີການຄິດໄລ່ຄືນໃໝ່, ໃຫ້ສຳເນົາຫ້ອງທີ່ມີຕຳລານີ້, ແລະ ໃຊ້ <item type=\"menuitem\">ແກ້ໄຂ - ວາງແບບພິເສດ</item> (ໂດຍທີ່ <item type=\"menuitem\">ວາງທັງໝົດ</item> ແລະ <item type=\"menuitem\">ສູດ</item> ບໍ່ໄດ້ໝາຍເລືອກ ແລະ <item type=\"menuitem\">ຕົວເລກ</item> ໄດ້ໝາຍເລືອກ)."

#. bfcug
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id3164785\n"
"help.text"
msgid "<item type=\"input\">=RANDBETWEEN(20;30)</item> returns an integer of between 20 and 30."
msgstr "<item type=\"input\">=RANDBETWEEN(20;30)</item> ສົ່ງຄ່າຕົວເລກສຸ່ມລະຫວ່າງ 20 ຫາ 30."

#. Dmk3R
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"bm_id461590241346526\n"
"help.text"
msgid "<bookmark_value>random numbers non-volatile; between limits</bookmark_value><bookmark_value>RANDBETWEEN.NV function</bookmark_value>"
msgstr "<bookmark_value>ຕົວເລກສຸ່ມແບບບໍ່ປ່ຽນແປງ; ລະຫວ່າງຂອບເຂດ</bookmark_value><bookmark_value>ຟັງຊັນ RANDBETWEEN.NV</bookmark_value>"

#. 873Eh
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"hd_id171590240366277\n"
"help.text"
msgid "<variable id=\"randbetween_nv_1\"><link href=\"text/scalc/01/04060106.xhp#randbetween_nv_1\">RANDBETWEEN.NV</link></variable>"
msgstr "<variable id=\"randbetween_nv_1\"><link href=\"text/scalc/01/04060106.xhp#randbetween_nv_1\">RANDBETWEEN.NV</link></variable>"

#. Akjyr
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id391590240473510\n"
"help.text"
msgid "<ahelp hid=\"HID_FUNC_RANDBETWEEN_NV\">Returns an non-volatile integer random number in a specified range.</ahelp>"
msgstr "<ahelp hid=\"HID_FUNC_RANDBETWEEN_NV\">ສົ່ງຄ່າຕົວເລກສຸ່ມຈຳນວນຖ້ວນແບບບໍ່ປ່ຽນແປງ (non-volatile) ໃນຂອບເຂດທີ່ກຳນົດ.</ahelp>"

#. GTDa4
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id181590240522012\n"
"help.text"
msgid "RANDBETWEEN.NV(Bottom; Top)"
msgstr "RANDBETWEEN.NV(Bottom; Top)"

#. ztiBK
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id91590242400917\n"
"help.text"
msgid "Returns an non-volatile integer random number between integers <emph>Bottom</emph> and <emph>Top</emph> (both inclusive). A non-volatile function is not recalculated at new input events or pressing <keycode>F9</keycode>. However, the function is recalculated when pressing <keycode>F9</keycode> with the cursor on the cell containing the function, when opening the file, when using the <link href=\"text/scalc/01/recalculate_hard.xhp\"><menuitem>Recalculate Hard</menuitem></link> command (<keycode>Shift</keycode>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>F9</keycode>) and when <emph>Top</emph> or <emph>Bottom</emph> are recalculated."
msgstr "ຄືນຄ່າເລກສຸ່ມຈຳນວນຖ້ວນແບບຄົງທີ່ ລະຫວ່າງຈຳນວນຖ້ວນ <emph>ລຸ່ມ</emph> ແລະ <emph>ເທິງ</emph> (ລວມເອົາທັງສອງຄ່າ). ຟັງຊັນແບບຄົງທີ່ຈະບໍ່ຖືກຄິດໄລ່ຄືນໃໝ່ເມື່ອມີການປ້ອນຂໍ້ມູນໃໝ່ ຫຼື ເມື່ອກົດ <keycode>F9</keycode>. ແນວໃດກໍຕາມ, ຟັງຊັນຈະຖືກຄິດໄລ່ຄືນໃໝ່ເມື່ອກົດ <keycode>F9</keycode> ໃນຂະນະທີ່ເຄີເຊີວາງຢູ່ເທິງຫ້ອງທີ່ມີຟັງຊັນນັ້ນ, ເມື່ອເປີດໄຟລ໌, ເມື່ອໃຊ້ຄຳສັ່ງ <link href=\"text/scalc/01/recalculate_hard.xhp\"><menuitem>ຄິດໄລ່ຄືນໃໝ່ທັງໝົດ</menuitem></link> (<keycode>Shift</keycode>+<switchinline select=\"sys\"><caseinline select=\"MAC\"><keycode>Command</keycode></caseinline><defaultinline><keycode>Ctrl</keycode></defaultinline></switchinline>+<keycode>F9</keycode>) ແລະ ເມື່ອ <emph>ເທິງ</emph> ຫຼື <emph>ລຸ່ມ</emph> ຖືກຄິດໄລ່ຄືນໃໝ່."

#. AngvN
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id151590240999839\n"
"help.text"
msgid "<input>=RANDBETWEEN.NV(20;30)</input> returns a non-volatile integer between 20 and 30."
msgstr "<input>=RANDBETWEEN.NV(20;30)</input> ສົ່ງຄ່າຕົວເລກສຸ່ມແບບບໍ່ປ່ຽນແປງລະຫວ່າງ 20 ຫາ 30."

#. cAQDh
#: 04060106.xhp
msgctxt ""
"04060106.xhp\n"
"par_id1001590241005601\n"
"help.text"
msgid "<input>=RANDBETWEEN.NV(A1;30)</input> returns a non-volatile integer between the value of cell A1 and 30. The function is recalculated when the contents of cell A1 change."
msgstr "<input>=RANDBETWEEN.NV(A1;30)</input> ສົ່ງຄ່າຕົວເລກສຸ່ມແບບບໍ່ປ່ຽນແປງ ລະຫວ່າງຄ່າໃນຫ້ອງ A1 ຫາ 30. ຟັງຊັນນີ້ຈະຄຳນວນໃໝ່ກໍຕໍ່ເມື່ອຄ່າໃນຫ້ອງ A1 ປ່ຽນແປງ."

#. odp65
