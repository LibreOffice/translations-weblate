"help.text"
msgid "<ahelp hid=\".\">Select the character set that you want to use to view the database in $[officename].</ahelp> This setting does not affect the database. To use the default character set of your operating system, select \"System\"."
msgstr "<ahelp hid=\".\">ເລືອກຊຸດຕົວອັກສອນທີ່ທ່ານຕ້ອງການໃຊ້ເພື່ອເບິ່ງຖານຂໍ້ມູນໃນ $[officename].</ahelp> ການຕັ້ງຄ່ານີ້ຈະບໍ່ມີຜົນຕໍ່ຖານຂໍ້ມູນ. ເພື່ອໃຊ້ຊຸດຕົວອັກສອນມາດຕະຖານຂອງລະບົບປະຕິບັດການຂອງທ່ານ, ໃຫ້ເລືອກ \"System\"."

#. zvk8A
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10651\n"
"help.text"
msgid "Text and dBASE databases are restricted to character sets with a fixed-size character length, where all characters are encoded with the same number of bytes."
msgstr "ຖານຂໍ້ມູນ Text ແລະ dBASE ແມ່ນຖືກຈຳກັດໃຫ້ໃຊ້ຊຸດຕົວອັກສອນທີ່ມີຄວາມຍາວຄົງທີ່, ເຊິ່ງຕົວອັກສອນທັງໝົດຈະຖືກເຂົ້າລະຫັດດ້ວຍຈຳນວນໄບຕ໌ (bytes) ທີ່ເທົ່າກັນ."

#. VoZcz
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10585\n"
"help.text"
msgid "Oracle JDBC driver class"
msgstr "ຄລາດໄດຣເວີ JDBC ຂອງ Oracle"

#. 7eLFU
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10653\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the name of the JDBC driver for the Oracle database.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຊື່ຂອງໄດຣເວີ JDBC ສຳລັບຖານຂໍ້ມູນ Oracle.</ahelp>"

#. 5KbCC
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10589\n"
"help.text"
msgid "Driver settings"
msgstr "ການຕັ້ງຄ່າໄດຣເວີ"

#. tEiQb
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10672\n"
"help.text"
msgid "<ahelp hid=\".\">Specify additional driver options.</ahelp>"
msgstr "<ahelp hid=\".\">ກຳນົດຕົວເລືອກເພີ່ມເຕີມຂອງໄດຣເວີ.</ahelp>"

#. rh98b
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN1058D\n"
"help.text"
msgid "Use catalog for file-based databases"
msgstr "ໃຊ້ແຄັດຕາລັອກ (catalog) ສຳລັບຖານຂໍ້ມູນແບບໄຟລ໌"

#. TipDh
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10691\n"
"help.text"
msgid "<ahelp hid=\".\">Uses the current data source of the catalog. This option is useful when the ODBC data source is a database server. Do not select this option if the ODBC data source is a dBASE driver.</ahelp>"
msgstr "<ahelp hid=\".\">ໃຊ້ແຫຼ່ງຂໍ້ມູນປັດຈຸບັນຂອງແຄັດຕາລັອກ. ຕົວເລືອກນີ້ມີປະໂຫຍດເມື່ອແຫຼ່ງຂໍ້ມູນ ODBC ເປັນເຊີເວີຖານຂໍ້ມູນ. ຫ້າມເລືອກຕົວເລືອກນີ້ ຖ້າແຫຼ່ງຂໍ້ມູນ ODBC ເປັນໄດຣເວີ dBASE.</ahelp>"

#. d3PBB
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10591\n"
"help.text"
msgid "Base DN"
msgstr "Base DN"

#. UYaFM
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN106B0\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the starting point to search the LDAP database, for example, dc=com.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຈຸດເລີ່ມຕົ້ນເພື່ອຄົ້ນຫາຖານຂໍ້ມູນ LDAP, ຕົວຢ່າງ: dc=com.</ahelp>"

#. bvx2A
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10595\n"
"help.text"
msgid "Maximum number of records"
msgstr "ຈຳນວນຂໍ້ມູນບັນທຶກສູງສຸດ"

#. AUVCH
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN106F3\n"
"help.text"
msgid "<ahelp hid=\".\">Enter the maximum number of records that you want to load when you access the LDAP server.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນຈຳນວນຂໍ້ມູນບັນທຶກສູງສຸດທີ່ທ່ານຕ້ອງການໂຫຼດເມື່ອເຂົ້າເຖິງເຊີເວີ LDAP.</ahelp>"

#. K5mtr
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10599\n"
"help.text"
msgid "Display deleted records as well"
msgstr "ສະແດງຂໍ້ມູນບັນທຶກທີ່ຖືກລຶບນຳ"

#. GENGU
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10700\n"
"help.text"
msgid "<ahelp hid=\".\">Displays all the records in a file, including those marked as deleted. If you select this check box, you cannot delete records.</ahelp>"
msgstr "<ahelp hid=\".\">ສະແດງຂໍ້ມູນບັນທຶກທັງໝົດໃນໄຟລ໌, ລວມທັງຂໍ້ມູນທີ່ຖືກໝາຍວ່າລຶບແລ້ວ. ຖ້າທ່ານເລືອກຫ້ອງນີ້, ທ່ານຈະບໍ່ສາມາດລຶບຂໍ້ມູນບັນທຶກໄດ້.</ahelp>"

#. RAmgF
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10715\n"
"help.text"
msgid "In dBASE format, deleted records remain in the file."
msgstr "ໃນຮູບແບບ dBASE, ຂໍ້ມູນບັນທຶກທີ່ຖືກລຶບຈະຍັງຄົງຢູ່ໃນໄຟລ໌."

#. yPXvG
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10718\n"
"help.text"
msgid "To view changes that you make to the database, close the connection to the database, and then reconnect to the database."
msgstr "ເພື່ອເບິ່ງການປ່ຽນແປງທີ່ທ່ານໄດ້ເຮັດກັບຖານຂໍ້ມູນ, ໃຫ້ປິດການເຊື່ອມຕໍ່ກັບຖານຂໍ້ມູນ, ແລ້ວຈຶ່ງເຊື່ອມຕໍ່ຄືນໃໝ່."

#. 9EL3T
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN1059D\n"
"help.text"
msgid "Indexes"
msgstr "ດັດຊະນີ"

#. EuWB8
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10725\n"
"help.text"
msgid "<ahelp hid=\".\">Opens the Indexes dialog, where you can organize the table indexes in the current dBASE database.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດກ່ອງຂໍ້ຄວາມດັດຊະນີ, ເຊິ່ງທ່ານສາມາດຈັດລະບຽບດັດຊະນີຕາຕະລາງໃນຖານຂໍ້ມູນ dBASE ປັດຈຸບັນໄດ້.</ahelp>"

#. zGqEv
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105B9\n"
"help.text"
msgid "Text contains headers"
msgstr "ຂໍ້ຄວາມມີຫົວຂໍ້"

#. RVLEb
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN107B0\n"
"help.text"
msgid "<ahelp hid=\".\">Select this check box if the first line of the text file contains field names.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກຫ້ອງນີ້ຖ້າແຖວທຳອິດຂອງໄຟລ໌ຂໍ້ຄວາມມີຊື່ຟີວ (field names).</ahelp>"

#. FujFi
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105BD\n"
"help.text"
msgid "Field separator"
msgstr "ຕົວຂັ້ນຟີວ"

#. f85dT
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN107CF\n"
"help.text"
msgid "<ahelp hid=\".\">Enter or select the character that separates data fields in the text file.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນ ຫຼື ເລືອກຕົວອັກສອນທີ່ໃຊ້ຂັ້ນຟີວຂໍ້ມູນໃນໄຟລ໌ຂໍ້ຄວາມ.</ahelp>"

#. 2GiWs
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105C1\n"
"help.text"
msgid "Text separator"
msgstr "ຕົວຂັ້ນຂໍ້ຄວາມ"

#. f9igV
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN107DC\n"
"help.text"
msgid "<ahelp hid=\".\">Enter or select the character that identifies a text field in the text file. You cannot use the same character as the field separator.</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນ ຫຼື ເລືອກຕົວອັກສອນທີ່ລະບຸຟີວຂໍ້ຄວາມໃນໄຟລ໌ຂໍ້ຄວາມ. ທ່ານບໍ່ສາມາດໃຊ້ຕົວອັກສອນດຽວກັນກັບຕົວຂັ້ນຟີວໄດ້.</ahelp>"

#. nPoAN
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105C5\n"
"help.text"
msgid "Decimal separator"
msgstr "ຕົວຂັ້ນທົດສະນິຍົມ"

#. zz9uf
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN107E9\n"
"help.text"
msgid "<ahelp hid=\".\">Enter or select the character that is used as a decimal separator in the text file, for example, a period (0.5) or a comma (0,5).</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນ ຫຼື ເລືອກຕົວອັກສອນທີ່ໃຊ້ເປັນຕົວຂັ້ນທົດສະນິຍົມໃນໄຟລ໌ຂໍ້ຄວາມ, ຕົວຢ່າງ: ຈຸດ (0.5) ຫຼື ຈຸດຈຸດ (0,5).</ahelp>"

#. pxpUk
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105C9\n"
"help.text"
msgid "Thousands separator"
msgstr "ຕົວຂັ້ນຫຼັກພັນ"

#. Z66yU
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN107F6\n"
"help.text"
msgid "<ahelp hid=\".\">Enter or select the character that is used as a thousands separator in the text file, for example a comma (1,000), or a period (1.000).</ahelp>"
msgstr "<ahelp hid=\".\">ປ້ອນ ຫຼື ເລືອກຕົວອັກສອນທີ່ໃຊ້ເປັນຕົວຂັ້ນຫຼັກພັນໃນໄຟລ໌ຂໍ້ຄວາມ, ຕົວຢ່າງ: ຈຸດ (1,000) ຫຼື ເມັດ (1.000).</ahelp>"

#. zF6Wc
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN105CD\n"
"help.text"
msgid "File extension"
msgstr "ນາມສະກຸນໄຟລ໌"

#. 4UxAN
#: dabapropadd.xhp
msgctxt ""
"dabapropadd.xhp\n"
"par_idN10803\n"
"help.text"
msgid "<ahelp hid=\".\">Select the format for the text file.</ahelp> The extension that you select affects some of the default settings in this dialog."
msgstr "<ahelp hid=\".\">ເລືອກຮູບແບບສຳລັບໄຟລ໌ຂໍ້ຄວາມ.</ahelp> ນາມສະກຸນທີ່ທ່ານເລືອກຈະມີຜົນຕໍ່ບາງການຕັ້ງຄ່າມາດຕະຖານໃນກ່ອງຂໍ້ຄວາມນີ້."

#. KEi9S
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"tit\n"
"help.text"
msgid "Connection Type Wizard"
msgstr "ຕົວຊ່ວຍສ້າງປະເພດການເຊື່ອມຕໍ່"

#. tR5Cs
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN1054D\n"
"help.text"
msgid "<link href=\"text/sdatabase/dabapropcon.xhp\">Connection Type Wizard</link>"
msgstr "<link href=\"text/sdatabase/dabapropcon.xhp\">ຕົວຊ່ວຍສ້າງປະເພດການເຊື່ອມຕໍ່</link>"

#. cnXMD
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN10551\n"
"help.text"
msgid "<ahelp hid=\".\">Changes the type of connection for the current database.</ahelp>"
msgstr "<ahelp hid=\".\">ປ່ຽນປະເພດການເຊື່ອມຕໍ່ສຳລັບຖານຂໍ້ມູນປັດຈຸບັນ.</ahelp>"

#. UGEKg
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_id9003875\n"
"help.text"
msgid "In a database window, choose <emph>Edit - Database - Connection Type</emph>"
msgstr "ໃນປ່ອງຢ້ຽມຖານຂໍ້ມູນ, ເລືອກ <emph>ແກ້ໄຂ - ຖານຂໍ້ມູນ - ປະເພດການເຊື່ອມຕໍ່</emph>"

#. nwRC4
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN10569\n"
"help.text"
msgid "The Connection Type Wizard consists of three pages. You cannot transfer all settings from one database type to another."
msgstr "ຕົວຊ່ວຍສ້າງປະເພດການເຊື່ອມຕໍ່ປະກອບມີສາມໜ້າ. ທ່ານບໍ່ສາມາດໂອນການຕັ້ງຄ່າທັງໝົດຈາກຖານຂໍ້ມູນປະເພດໜຶ່ງໄປຫາອີກປະເພດໜຶ່ງໄດ້."

#. htEBY
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN1056C\n"
"help.text"
msgid "For example, you can use the wizard to open a database file that is in a format that is usually not recognized by an installed database."
msgstr "ຕົວຢ່າງ, ທ່ານສາມາດໃຊ້ຕົວຊ່ວຍສ້າງເພື່ອເປີດໄຟລ໌ຖານຂໍ້ມູນທີ່ຢູ່ໃນຮູບແບບທີ່ປົກກະຕິແລ້ວບໍ່ສາມາດລະບຸໄດ້ໂດຍຖານຂໍ້ມູນທີ່ຕິດຕັ້ງໄວ້."

#. GLS4A
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN1056F\n"
"help.text"
msgid "Database type"
msgstr "ປະເພດຖານຂໍ້ມູນ"

#. TAPYr
#: dabapropcon.xhp
msgctxt ""
"dabapropcon.xhp\n"
"par_idN10573\n"
"help.text"
msgid "<ahelp hid=\".\">Select the type of database that you want to connect to.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກປະເພດຂອງຖານຂໍ້ມູນທີ່ທ່ານຕ້ອງການເຊື່ອມຕໍ່.</ahelp>"

#. pr7Ss
#: dabapropgen.xhp
msgctxt ""
"dabapropgen.xhp\n"
"tit\n"
"help.text"
msgid "Advanced Properties"
msgstr "ຄຸນສົມບັດຂັ້ນສູງ"

#. eFAEi
#: dabapropgen.xhp
msgctxt ""
"dabapropgen.xhp\n"
"par_idN1054D\n"
"help.text"
msgid "<link href=\"text/sdatabase/dabapropgen.xhp\">Advanced Properties</link>"
msgstr "<link href=\"text/sdatabase/dabapropgen.xhp\">ຄຸນສົມບັດຂັ້ນສູງ</link>"

#. u6Nh4
#: dabapropgen.xhp
