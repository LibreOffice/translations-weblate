#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3147407\n"
"help.text"
msgid "Condition is satisfied if..."
msgstr "ເງື່ອນໄຂຈະສຳເລັດຖ້າ..."

#. gqkRK
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3153026\n"
"help.text"
msgid "equal to"
msgstr "ເທົ່າກັບ"

#. hw7KZ
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3148895\n"
"help.text"
msgid "... the content of the field is identical to the indicated expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນຄືກັນກັບນິພົດທີ່ລະບຸໄວ້."

#. A8XJU
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3153120\n"
"help.text"
msgid "The operator = will not be displayed in the query fields. If you enter a value without any operator, the = operator is automatically assumed."
msgstr "ຕົວດຳເນີນການ = ຈະບໍ່ຖືກສະແດງໃນເຂດຂໍ້ມູນຄຳຖາມ. ຖ້າທ່ານປ້ອນຄ່າໂດຍບໍ່ໃສ່ຕົວດຳເນີນການໃດໆ, ລະບົບຈະຖືວ່າເປັນຕົວດຳເນີນການ = ໂດຍອັດຕະໂນມັດ."

#. mWwUE
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3145223\n"
"help.text"
msgid "not equal to"
msgstr "ບໍ່ເທົ່າກັບ"

#. Db7BG
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3145635\n"
"help.text"
msgid "... the content of the field does not correspond to the specified expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນບໍ່ກົງກັບນິພົດທີ່ລະບຸໄວ້."

#. dtjkU
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3146815\n"
"help.text"
msgid "greater than"
msgstr "ໃຫຍ່ກວ່າ"

#. gCWug
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3149150\n"
"help.text"
msgid "... the content of the field is greater than the specified expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນໃຫຍ່ກວ່າຂໍ້ມູນທີ່ລະບຸໄວ້."

#. QkAKk
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3147379\n"
"help.text"
msgid "less than"
msgstr "ນ້ອຍກວ່າ"

#. xxPdk
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3150375\n"
"help.text"
msgid "... the content of the field is less than the specified expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນນ້ອຍກວ່າຂໍ້ມູນທີ່ລະບຸໄວ້."

#. 4aJjX
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3150636\n"
"help.text"
msgid "greater than or equal to"
msgstr "ໃຫຍ່ກວ່າ ຫຼື ເທົ່າກັບ"

#. 2rwQm
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154584\n"
"help.text"
msgid "... the content of the field is greater than or equal to the specified expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນໃຫຍ່ກວ່າ ຫຼື ເທົ່າກັບຂໍ້ມູນທີ່ລະບຸໄວ້."

#. ADRZk
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154052\n"
"help.text"
msgid "less than or equal to"
msgstr "ນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ"

#. 9KtmZ
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3157902\n"
"help.text"
msgid "... the content of the field is less than or equal to the specified expression."
msgstr "... ຂໍ້ມູນໃນເຂດຂໍ້ມູນນັ້ນນ້ອຍກວ່າ ຫຼື ເທົ່າກັບຂໍ້ມູນທີ່ລະບຸໄວ້."

#. DBXG9
#: 02010100.xhp
msgctxt ""
