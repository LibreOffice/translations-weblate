msgstr "ຄຳສັ່ງ SQL"

#. pJay6
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154158\n"
"help.text"
msgid "Meaning"
msgstr "ຄວາມໝາຍ"

#. qmaX5
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3149433\n"
"help.text"
msgid "Condition is satisfied if..."
msgstr "ເງື່ອນໄຂຈະສຳເລັດຖ້າ..."

#. do6XQ
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3143236\n"
"help.text"
msgid "is null"
msgstr "ເປັນຄ່າຫວ່າງ (is null)"

#. NPqBL
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154744\n"
"help.text"
msgid "... the field contains no data. For Yes/No fields with three possible states, this command automatically queries the undetermined state (neither Yes nor No)."
msgstr "... ເຂດຂໍ້ມູນບໍ່ມີຂໍ້ມູນຢູ່. ສຳລັບເຂດຂໍ້ມູນ ແມ່ນ/ບໍ່ ທີ່ມີສາມສະຖານະທີ່ເປັນໄປໄດ້, ຄຳສັ່ງນີ້ຈະຄົ້ນຫາສະຖານະທີ່ຍັງບໍ່ໄດ້ກຳນົດໂດຍອັດຕະໂນມັດ (ບໍ່ແມ່ນທັງ ແມ່ນ ຫຼື ບໍ່)."

#. 7Rfbd
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3151229\n"
"help.text"
msgid "is not empty"
msgstr "ບໍ່ວ່າງ"

#. w3Tva
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3145304\n"
"help.text"
msgid "... the field is not empty, i.e it contains data."
msgstr "... ເຂດຂໍ້ມູນບໍ່ວ່າງ, ນັ້ນຄື ມັນມີຂໍ້ມູນຢູ່."

#. GGKUH
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3153891\n"
"help.text"
msgid "placeholder (*) for any number of characters"
msgstr "ຕົວແທນ (*) ສຳລັບຈຳນວນຕົວອັກສອນໃດໆ"

#. gbEWB
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3148887\n"
"help.text"
msgid "placeholder (?) for exactly one character"
msgstr "ຕົວແທນ (?) ສຳລັບໜຶ່ງຕົວອັກສອນພໍດີ"

#. tBQfA
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"bm_id3157985\n"
"help.text"
msgid "<bookmark_value>placeholders; in SQL queries</bookmark_value>"
msgstr "<bookmark_value>ຕົວແທນ; ໃນຄຳຖາມ SQL</bookmark_value>"

#. agxhB
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3157985\n"
"help.text"
msgid "placeholder (%) for any number of characters"
msgstr "ຕົວແທນ (%) ສຳລັບຈຳນວນຕົວອັກສອນໃດໆ"

#. EE9ii
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3147422\n"
"help.text"
msgid "Placeholder (_) for exactly one character"
msgstr "ຕົວແທນ (_) ສຳລັບໜຶ່ງຕົວອັກສອນພໍດີ"

#. za5g2
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154845\n"
"help.text"
msgid "is an element of"
msgstr "ເປັນສ່ວນໜຶ່ງຂອງ"

#. 2Y3zW
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3156130\n"
"help.text"
msgid "... the data field contains the indicated expression. The (*) placeholder indicates whether the expression x occurs at the beginning of (x*), at the end of (*x) or inside the field content (*x*). You can enter as a placeholder in SQL queries either the SQL % character or the familiar (*) file system placeholder in the %PRODUCTNAME interface."
msgstr "... ເຂດຂໍ້ມູນມີນິພົດທີ່ລະບຸໄວ້. ຕົວແທນ (*) ຈະບອກວ່າ x ປາກົດຢູ່ຕອນເລີ່ມຕົ້ນ (x*), ຢູ່ຕອນທ້າຍ (*x) ຫຼື ຢູ່ພາຍໃນຂໍ້ມູນ (*x*). ທ່ານສາມາດປ້ອນຕົວແທນໃນຄຳຖາມ SQL ໄດ້ທັງຕົວອັກສອນ SQL % ຫຼື ຕົວແທນ (*) ທີ່ຄຸ້ນເຄີຍໃນສ່ວນຕິດຕໍ່ຜູ້ໃຊ້ຂອງ %PRODUCTNAME."

#. CPJyr
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3150271\n"
"help.text"
msgid "The (*) or (%) placeholder stands for any number of characters. The question mark (?) in the $[officename] interface or the underscore (_) in SQL queries is used to represent exactly one character."
msgstr "ຕົວແທນ (*) ຫຼື (%) ໃຊ້ແທນຈຳນວນຕົວອັກສອນໃດໆ. ເຄື່ອງໝາຍຖາມ (?) ໃນສ່ວນຕິດຕໍ່ຂອງ $[officename] ຫຼື ເຄື່ອງໝາຍຂີດກ້ອງ (_) ໃນຄຳຖາມ SQL ໃຊ້ແທນໜຶ່ງຕົວອັກສອນພໍດີ."

#. AAEXi
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3159141\n"
"help.text"
msgid "Is not an element of"
msgstr "ບໍ່ແມ່ນສ່ວນໜຶ່ງຂອງ"

#. 9vFBZ
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3161664\n"
"help.text"
msgid "... the field does not contain data having the specified expression."
msgstr "... ເຂດຂໍ້ມູນບໍ່ມີຂໍ້ມູນທີ່ເປັນນິພົດທີ່ລະບຸໄວ້."

#. CD2Ra
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3159184\n"
"help.text"
msgid "falls within the interval [x,y]"
msgstr "ຢູ່ໃນລະຫວ່າງ [x,y]"

#. cDe2u
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154395\n"
"help.text"
msgid "... the field contains a data value that lies between the two values x and y."
msgstr "... ເຂດຂໍ້ມູນມີຄ່າຂໍ້ມູນທີ່ຢູ່ລະຫວ່າງສອງຄ່າ x ແລະ y."

#. KYAXv
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3155498\n"
"help.text"
msgid "Does not fall within the interval [x,y]"
msgstr "ບໍ່ໄດ້ຢູ່ໃນລະຫວ່າງ [x,y]"

#. cVfAF
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3148992\n"
"help.text"
msgid "... the field contains a data value that does not lie between the two values x and y."
msgstr "... ເຂດຂໍ້ມູນມີຄ່າຂໍ້ມູນທີ່ບໍ່ໄດ້ຢູ່ລະຫວ່າງສອງຄ່າ x ແລະ y."

#. DBBQE
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3159167\n"
"help.text"
msgid "Note that semicolons are used as separators in all value lists!"
msgstr "ໝາຍເຫດ: ເຄື່ອງໝາຍຈ້ຳຈຸດ (;) ຖືກໃຊ້ເປັນຕົວແຍກໃນທຸກລາຍການຄ່າ!"

#. evEuh
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3154809\n"
"help.text"
msgid "contains a, b, c..."
msgstr "ບັນຈຸ a, b, c..."

#. eeFC2
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3148399\n"
"help.text"
msgid "... the field name contains one of the specified expressions a, b, c,... Any number of expressions can be specified, and the result of the query is determined by a boolean OR operator. The expressions a, b, c... can be either numbers or characters"
msgstr "... ເຂດຂໍ້ມູນມີໜຶ່ງໃນນິພົດທີ່ລະບຸໄວ້ຄື a, b, c,... ທ່ານສາມາດລະບຸນິພົດໄດ້ຫຼາຍເທົ່າໃດກໍໄດ້ ແລະ ຜົນຂອງຄຳຖາມຈະຖືກກຳນົດດ້ວຍຕົວດຳເນີນການ boolean OR. ນິພົດ a, b, c... ສາມາດເປັນໄດ້ທັງຕົວເລກ ຫຼື ຕົວອັກສອນ"

#. JXq76
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3150679\n"
"help.text"
msgid "does not contain a, b, c..."
msgstr "ບໍ່ໄດ້ບັນຈຸ a, b, c..."

#. U5doB
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3158439\n"
"help.text"
msgid "... the field does not contain one of the specified expressions a, b, c,..."
msgstr "... ເຂດຂໍ້ມູນບໍ່ມີໜຶ່ງໃນນິພົດທີ່ລະບຸໄວ້ຄື a, b, c,..."

#. cECKt
#: 02010100.xhp
msgctxt ""
"02010100.xhp\n"
"par_id3149248\n"
"help.text"
msgid "has the value True"
