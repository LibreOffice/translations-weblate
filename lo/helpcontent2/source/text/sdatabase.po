"par_id301677871783123\n"
"help.text"
msgid "<link href=\"https://www.firebirdsql.org/en/documentation/\">Firebird documentation</link>"
msgstr "<link href=\"https://www.firebirdsql.org/en/documentation/\">ເອກະສານຂອງ Firebird</link>"

