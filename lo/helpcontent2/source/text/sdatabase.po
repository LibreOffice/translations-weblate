msgctxt ""
"dabawiz02.xhp\n"
"par_idN105C6\n"
"help.text"
msgid "<ahelp hid=\".\">Select to display the database file, where you can edit the database structure.</ahelp>"
msgstr "<ahelp hid=\".\">ເລືອກເພື່ອສະແດງໄຟລ໌ຖານຂໍ້ມູນ, ເຊິ່ງທ່ານສາມາດແກ້ໄຂໂຄງສ້າງຂອງຖານຂໍ້ມູນໄດ້.</ahelp>"

