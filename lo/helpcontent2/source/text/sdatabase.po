#. DrUB4
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id8638874\n"
"help.text"
msgid "<ahelp hid=\".\">You can open the Date and Time dialog of the <link href=\"text/sdatabase/rep_main.xhp\">Report Builder</link> by choosing <item type=\"menuitem\">Insert - Date and Time</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ທ່ານສາມາດເປີດກ່ອງໂຕ້ຕອບວັນທີ ແລະ ເວລາ ຂອງ <link href=\"text/sdatabase/rep_main.xhp\">ຕົວສ້າງລາຍງານ</link> ໂດຍເລືອກ <item type=\"menuitem\">ແຊກ - ວັນທີ ແລະ ເວລາ</item>.</ahelp>"

#. tSLyd
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id6278878\n"
"help.text"
msgid "Press <item type=\"keycode\">Shift-F1</item> and point with the mouse at an input box to see a help text for this input box."
msgstr "ກົດ <item type=\"keycode\">Shift-F1</item> ແລະ ຊີ້ເມົາສ໌ໄປທີ່ກ່ອງປ້ອນຂໍ້ມູນເພື່ອເບິ່ງຂໍ້ຄວາມຊ່ວຍເຫຼືອສຳລັບກ່ອງປ້ອນຂໍ້ມູນນັ້ນ."

#. ppg4k
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id393078\n"
"help.text"
msgid "<ahelp hid=\".\">Enable Include Date to insert a date field into the active area of the report. The date field displays the current date when the report is executed.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດໃຊ້ ລວມວັນທີ ເພື່ອແຊກຟິວວັນທີເຂົ້າໃນພື້ນທີ່ທີ່ໃຊ້ງານຂອງລາຍງານ. ຟິວວັນທີຈະສະແດງວັນທີປັດຈຸບັນເມື່ອລາຍງານຖືກເອີ້ນໃຊ້.</ahelp>"

#. 6ued5
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id1271401\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select a format to display the date.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກຮູບແບບເພື່ອສະແດງວັນທີ.</ahelp>"

#. VvPJF
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id8718832\n"
"help.text"
msgid "<ahelp hid=\".\">Enable Include Time to insert a time field into the active area of the report. The time field displays the current time when the report is executed.</ahelp>"
msgstr "<ahelp hid=\".\">ເປີດໃຊ້ ລວມເວລາ ເພື່ອແຊກຟິວເວລາເຂົ້າໃນພື້ນທີ່ທີ່ໃຊ້ງານຂອງລາຍງານ. ຟິວເວລາຈະສະແດງເວລາປັດຈຸບັນເມື່ອລາຍງານຖືກເອີ້ນໃຊ້.</ahelp>"

#. DfCAA
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id8561052\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select a format to display the time.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກຮູບແບບເພື່ອສະແດງເວລາ.</ahelp>"

#. cVAzu
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id5992919\n"
"help.text"
msgid "Click OK to insert the field."
msgstr "ຄລິກ ຕົກລົງ ເພື່ອແຊກຟິວ."

#. WFpF6
#: rep_datetime.xhp
msgctxt ""
"rep_datetime.xhp\n"
"par_id4320810\n"
"help.text"
msgid "You can click the date or time field and drag to another position within the same area, or edit the properties in the Properties window."
msgstr "ທ່ານສາມາດຄລິກທີ່ຟິວວັນທີ ຫຼື ເວລາ ແລ້ວລາກໄປຍັງຕຳແໜ່ງອື່ນພາຍໃນພື້ນທີ່ດຽວກັນ, ຫຼື ແກ້ໄຂຄຸນສົມບັດໃນໜ້າຕ່າງຄຸນສົມບັດ."

#. DCjDN
