"par_idN105C8\n"
"help.text"
msgid "<ahelp hid=\".\">Ignores access privileges that are provided by the database driver.</ahelp>"
msgstr "<ahelp hid=\".\">ລະເລີຍສິດທິການເຂົ້າເຖິງທີ່ໃຫ້ໂດຍໄດເວີຖານຂໍ້ມູນ.</ahelp>"

#. CcsGn
#: dabaadvpropdat.xhp
msgctxt ""
