msgstr "ຢືນຢັນ (ລະຫັດຜ່ານ)"

#. xkB4S
#: 05000003.xhp
msgctxt ""
"05000003.xhp\n"
"par_id3153541\n"
"help.text"
msgid "<ahelp hid=\"dbaccess/ui/password/confirmpassword\">Enter the new password again.</ahelp>"
msgstr "<ahelp hid=\"dbaccess/ui/password/confirmpassword\">ປ້ອນລະຫັດຜ່ານໃໝ່ອີກຄັ້ງ.</ahelp>"

#. NYfPs
