msgctxt ""
"rep_navigator.xhp\n"
"hd_id1821955\n"
"help.text"
msgid "<variable id=\"rep_navigator\"><link href=\"text/sdatabase/rep_navigator.xhp\">Report Navigator</link></variable>"
msgstr "<variable id=\"rep_navigator\"><link href=\"text/sdatabase/rep_navigator.xhp\">ຕົວນຳທາງລາຍງານ</link></variable>"

#. 7hD99
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1150852\n"
"help.text"
msgid "You can open the Report Navigator window of the <link href=\"text/sdatabase/rep_main.xhp\">Report Builder</link> by choosing <item type=\"menuitem\">View - Report Navigator</item>."
msgstr "ທ່ານສາມາດເປີດໜ້າຕ່າງຕົວນຳທາງລາຍງານຂອງ <link href=\"text/sdatabase/rep_main.xhp\">ຕົວສ້າງລາຍງານ</link> ໂດຍເລືອກ <item type=\"menuitem\">ມຸມມອງ - ຕົວນຳທາງລາຍງານ</item>."

#. hBVny
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1111484\n"
"help.text"
msgid "<ahelp hid=\".\">The Report Navigator reveals the structure of the report. You can use the Report Navigator to insert functions into the report.</ahelp>"
msgstr "<ahelp hid=\".\">ຕົວນຳທາງລາຍງານຈະສະແດງໂຄງສ້າງຂອງລາຍງານ. ທ່ານສາມາດໃຊ້ຕົວນຳທາງລາຍງານເພື່ອແຊກຟັງຊັນເຂົ້າໃນລາຍງານ.</ahelp>"

#. LJxNC
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id8314157\n"
"help.text"
msgid "<ahelp hid=\".\">Click an entry in the Report Navigator. The corresponding object or area is selected in the Report Builder view. Right-click an entry to open the context menu.</ahelp>"
msgstr "<ahelp hid=\".\">ຄລິກທີ່ລາຍການໃນຕົວນຳທາງລາຍງານ. ວັດຖຸ ຫຼື ພື້ນທີ່ທີ່ກ່ຽວຂ້ອງຈະຖືກເລືອກໃນມຸມມອງຕົວສ້າງລາຍງານ. ຄລິກຂວາທີ່ລາຍການເພື່ອເປີດເມນູລັດ.</ahelp>"

#. prLAV
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"hd_id2932828\n"
"help.text"
msgid "To enter functions to the report"
msgstr "ວິທີປ້ອນຟັງຊັນເຂົ້າໃນລາຍງານ"

#. CSJFz
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id5091708\n"
"help.text"
msgid "<ahelp hid=\".\">In the context menu of the Report Navigator, you see the same commands as in the Report Builder view, plus additional commands to create new functions or to delete them.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນເມນູລັດຂອງຕົວນຳທາງລາຍງານ, ທ່ານຈະເຫັນຄຳສັ່ງດຽວກັບໃນມຸມມອງຕົວສ້າງລາຍງານ, ບວກກັບຄຳສັ່ງເພີ່ມເຕີມເພື່ອສ້າງຟັງຊັນໃໝ່ ຫຼື ລຶບພວກມັນ.</ahelp>"

#. fA8ue
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id9449446\n"
"help.text"
msgid "Functions can be entered using a syntax as specified by the <link href=\"https://en.wikipedia.org/wiki/OpenFormula\">OpenFormula</link> proposal."
msgstr "ຟັງຊັນສາມາດປ້ອນໄດ້ໂດຍໃຊ້ໄວຍາກອນຕາມທີ່ກຳນົດໂດຍ <link href=\"https://en.wikipedia.org/wiki/OpenFormula\">OpenFormula</link>."

#. N9UtL
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id4095583\n"
"help.text"
msgid "See <link href=\"https://wiki.documentfoundation.org/Database\">Wiki page about Base</link> for some more help regarding the functions in a report."
msgstr "ເບິ່ງ <link href=\"https://wiki.documentfoundation.org/Database\">ໜ້າ Wiki ກ່ຽວກັບ Base</link> ສຳລັບຄວາມຊ່ວຍເຫຼືອເພີ່ມເຕີມກ່ຽວກັບຟັງຊັນໃນລາຍງານ."

#. 2spAx
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"hd_id311593\n"
"help.text"
msgid "To calculate a sum for each client"
msgstr "ວິທີຄິດໄລ່ຍອດລວມສຳລັບລູກຄ້າແຕ່ລະຄົນ"

#. zGU9C
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id3948789\n"
"help.text"
msgid "Open the Report Navigator."
msgstr "ເປີດຕົວນຳທາງລາຍງານ."

#. FSYuv
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id5391399\n"
"help.text"
msgid "Open the Groups entry and the group where you want to calculate the cost."
msgstr "ເປີດລາຍການກຸ່ມ ແລະ ກຸ່ມທີ່ທ່ານຕ້ອງການຄິດໄລ່ຕົ້ນທຶນ."

#. bP94U
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id6989654\n"
"help.text"
msgid "The group has a sub entry called functions."
msgstr "ກຸ່ມມີລາຍການຍ່ອຍທີ່ເອີ້ນວ່າ ຟັງຊັນ."

#. FbfyS
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1803643\n"
"help.text"
msgid "Open the context menu (right click) on the functions entry, choose to create a new function, and select it."
msgstr "ເປີດເມນູລັດ (ຄລິກຂວາ) ທີ່ລາຍການຟັງຊັນ, ເລືອກສ້າງຟັງຊັນໃໝ່, ແລ້ວເລືອກມັນ."

#. hTbw9
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id868251\n"
"help.text"
msgid "In the property browser you see the function."
msgstr "ໃນບຣາວເຊີຄຸນສົມບັດ ທ່ານຈະເຫັນຟັງຊັນນັ້ນ."

#. KBn87
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id6247749\n"
"help.text"
msgid "Change the name to e.g. CostCalc and the formula to [CostCalc] + [enter your cost column name]."
msgstr "ປ່ຽນຊື່ເປັນເຊັ່ນ: CostCalc ແລະ ສູດເປັນ [CostCalc] + [ປ້ອນຊື່ຄໍລຳຕົ້ນທຶນຂອງທ່ານ]."

#. y2cwk
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1565904\n"
"help.text"
msgid "In the initial value enter 0."
msgstr "ໃນຄ່າເລີ່ມຕົ້ນ ໃຫ້ປ້ອນ 0."

#. RkdrZ
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1569261\n"
"help.text"
msgid "Now you can insert a text field and bind it to your [CostCalc] (appears in the data field list box)."
msgstr "ຕອນນີ້ທ່ານສາມາດແຊກຟິວຂໍ້ຄວາມ ແລະ ເຊື່ອມໂຍງກັບ [CostCalc] ຂອງທ່ານ (ຈະສະແດງໃນກ່ອງລາຍການຟິວຂໍ້ມູນ)."

#. utdSG
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id9256874\n"
"help.text"
msgid "Maybe you have to set the initial value to the value of the field like [field]."
msgstr "ບາງທີທ່ານອາດຕ້ອງຕັ້ງຄ່າເລີ່ມຕົ້ນໃຫ້ເປັນຄ່າຂອງຟິວ ເຊັ່ນ [field]."

#. Hp4tF
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id4601886\n"
"help.text"
msgid "If there are blank fields in the cost column, use the following formula to replace the blank fields' content with zero:"
msgstr "ຖ້າມີຟິວຫວ່າງໃນຄໍລຳຕົ້ນທຶນ, ໃຫ້ໃຊ້ສູດຕໍ່ໄປນີ້ເພື່ອປ່ຽນເນື້ອຫາຂອງຟິວຫວ່າງເປັນສູນ:"

#. Dzpam
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id1754509\n"
"help.text"
msgid "[SumCost] + IF(ISBLANK([field]);0;[field])"
msgstr "[SumCost] + IF(ISBLANK([field]);0;[field])"

#. tGCiz
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id8122196\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the formula that defines the function. Use OpenFormula syntax.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນສູດທີ່ກຳນົດຟັງຊັນ. ໃຊ້ໄວຍາກອນ OpenFormula.</ahelp>"

#. mTZGY
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id9909665\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the initial value for the evaluation of the formula. Often this is set to 0 or to 1.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຄ່າເລີ່ມຕົ້ນສຳລັບການປະເມີນສູດ. ສ່ວນຫຼາຍມັກຈະຕັ້ງເປັນ 0 ຫຼື 1.</ahelp>"

#. qEtTN
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id9141819\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">If Deep traversing is enabled, functions are evaluated considering all lower levels of hierarchy. This would be used for instance for line numbering. If Deep traversing is not enabled, only the first level of hierarchy is evaluated.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຖ້າເປີດໃຊ້ງານ Deep traversing, ຟັງຊັນຈະຖືກປະເມີນໂດຍພິຈາລະນາທຸກລະດັບທີ່ຕ່ຳກວ່າໃນລະດັບຊັ້ນ. ສິ່ງນີ້ຈະຖືກໃຊ້ຕົວຢ່າງເຊັ່ນສຳລັບການຕັ້ງເລກແຖວ. ຖ້າບໍ່ເປີດໃຊ້ງານ Deep traversing, ຈະມີພຽງລະດັບທຳອິດຂອງລະດັບຊັ້ນເທົ່ານັ້ນທີ່ຖືກປະເມີນ.</ahelp>"

#. XGkHa
#: rep_navigator.xhp
msgctxt ""
"rep_navigator.xhp\n"
"par_id6354869\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">If Pre evaluation is enabled, functions are evaluated only when the report is finished.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຖ້າເປີດໃຊ້ງານ Pre evaluation, ຟັງຊັນຈະຖືກປະເມີນເມື່ອລາຍງານສຳເລັດແລ້ວເທົ່ານັ້ນ.</ahelp>"

#. nNgrq
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"tit\n"
"help.text"
msgid "Page Numbers"
msgstr "ເລກໜ້າ"

#. nTPmB
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"hd_id3674123\n"
"help.text"
msgid "<variable id=\"rep_pagenumbers\"><link href=\"text/sdatabase/rep_pagenumbers.xhp\">Page Numbers</link></variable>"
msgstr "<variable id=\"rep_pagenumbers\"><link href=\"text/sdatabase/rep_pagenumbers.xhp\">ເລກໜ້າ</link></variable>"

#. oPnyT
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id3424481\n"
"help.text"
msgid "<ahelp hid=\".\">You can open the Page Numbers dialog of the <link href=\"text/sdatabase/rep_main.xhp\">Report Builder</link> by choosing <item type=\"menuitem\">Insert - Page Numbers</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ທ່ານສາມາດເປີດກ່ອງໂຕ້ຕອບເລກໜ້າຂອງ <link href=\"text/sdatabase/rep_main.xhp\">ຕົວສ້າງລາຍງານ</link> ໂດຍເລືອກ <item type=\"menuitem\">ແຊກ - ເລກໜ້າ</item>.</ahelp>"

#. ygaGw
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id1068758\n"
"help.text"
msgid "Press <item type=\"keycode\">Shift-F1</item> and point with the mouse at an input box to see a help text for this input box."
msgstr "ກົດ <item type=\"keycode\">Shift-F1</item> ແລະ ຊີ້ເມົາສ໌ໄປທີ່ກ່ອງປ້ອນຂໍ້ມູນເພື່ອເບິ່ງຂໍ້ຄວາມຊ່ວຍເຫຼືອສຳລັບກ່ອງປ້ອນຂໍ້ມູນນັ້ນ."

#. Cz9Sk
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id1559190\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Page N</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ໜ້າ N</ahelp>"

#. rcaDS
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id9879146\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Page N of M</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ໜ້າ N ຈາກ M</ahelp>"

#. tDDwG
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id9404278\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Top of Page (Header)</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສ່ວນເທິງຂອງໜ້າ (ຫົວໜ້າ)</ahelp>"

#. dvqcL
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id7626880\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Bottom of Page (Footer)</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ສ່ວນລຸ່ມຂອງໜ້າ (ທ້າຍໜ້າ)</ahelp>"

#. XRZPh
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id6124149\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Alignment</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ການຈັດວາງ</ahelp>"

#. horox
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id8257087\n"
"help.text"
msgid "Select the format for the page numbers, either \"Page N\" or \"Page N of M\", where N stands for the current page number, and M for the total number of pages in the report."
msgstr "ເລືອກຮູບແບບສຳລັບເລກໜ້າ, ບໍ່ວ່າຈະເປັນ \"ໜ້າ N\" ຫຼື \"ໜ້າ N ຈາກ M\", ເຊິ່ງ N ແທນເລກໜ້າປັດຈຸບັນ, ແລະ M ແທນຈຳນວນໜ້າທັງໝົດໃນລາຍງານ."

#. 84Dct
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id3479415\n"
"help.text"
msgid "Select to show the page numbers in the Page Header area or in the Page Footer area."
msgstr "ເລືອກເພື່ອສະແດງເລກໜ້າໃນພື້ນທີ່ຫົວໜ້າ ຫຼື ໃນພື້ນທີ່ທ້າຍໜ້າ."

#. GxdrQ
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id4441663\n"
"help.text"
msgid "Select an alignment. By default the page numbers are centered between the left and right margins. You can align the field to the left or right. You can also select Inside to print page number on odd pages on the left side and even page numbers on the right side. Select Outside for the opposite alignment."
msgstr "ເລືອກການຈັດວາງ. ຕາມມາດຕະຖານເລກໜ້າຈະຖືກຈັດໄວ້ກາງລະຫວ່າງຂອບຊ້າຍ ແລະ ຂວາ. ທ່ານສາມາດຈັດວາງຟິວໄວ້ທາງຊ້າຍ ຫຼື ຂວາໄດ້. ທ່ານຍັງສາມາດເລືອກ ທາງໃນ ເພື່ອພິມເລກໜ້າໃນໜ້າຄີກໄວ້ທາງຊ້າຍ ແລະ ໜ້າຄູ່ໄວ້ທາງຂວາ. ເລືອກ ທາງນອກ ສຳລັບການຈັດວາງທີ່ກົງກັນຂ້າມ."

#. MJV32
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id3012176\n"
"help.text"
msgid "When you click OK, a data field for the page numbers is inserted. If no header or footer area exist, the area will be created as needed."
msgstr "ເມື່ອທ່ານຄລິກ ຕົກລົງ, ຟິວຂໍ້ມູນສຳລັບເລກໜ້າຈະຖືກແຊກເຂົ້າມາ. ຖ້າຍັງບໍ່ມີພື້ນທີ່ຫົວໜ້າ ຫຼື ທ້າຍໜ້າ, ພື້ນທີ່ນັ້ນຈະຖືກສ້າງຂຶ້ນຕາມຄວາມຕ້ອງການ."

#. 6QnRv
#: rep_pagenumbers.xhp
msgctxt ""
"rep_pagenumbers.xhp\n"
"par_id8532670\n"
"help.text"
msgid "You can click the data field and drag to another position within the same area, or edit the properties in the Properties window."
msgstr "ທ່ານສາມາດຄລິກທີ່ຟິວຂໍ້ມູນແລ້ວລາກໄປຍັງຕຳແໜ່ງອື່ນພາຍໃນພື້ນທີ່ດຽວກັນ, ຫຼື ແກ້ໄຂຄຸນສົມບັດໃນໜ້າຕ່າງຄຸນສົມບັດ."

#. 7uNv6
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"tit\n"
"help.text"
msgid "Properties"
msgstr "ຄຸນສົມບັດ"

#. CEY5D
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"hd_id8836939\n"
"help.text"
msgid "<variable id=\"rep_prop\"><link href=\"text/sdatabase/rep_prop.xhp\">Properties</link></variable>"
msgstr "<variable id=\"rep_prop\"><link href=\"text/sdatabase/rep_prop.xhp\">ຄຸນສົມບັດ</link></variable>"

#. yQEzY
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id2711264\n"
"help.text"
msgid "The Properties window of the <link href=\"text/sdatabase/rep_main.xhp\">Report Builder</link> always shows the properties of the currently selected object in the Report Builder view."
msgstr "ໜ້າຕ່າງຄຸນສົມບັດຂອງ <link href=\"text/sdatabase/rep_main.xhp\">ຕົວສ້າງລາຍງານ</link> ຈະສະແດງຄຸນສົມບັດຂອງວັດຖຸທີ່ຖືກເລືອກໃນປັດຈຸບັນໃນມຸມມອງຕົວສ້າງລາຍງານສະເໝີ."

#. hiDZo
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1080660\n"
"help.text"
msgid "Press Shift-F1 and point with the mouse at an input box to see a help text for this input box."
msgstr "ກົດ Shift-F1 ແລະ ຊີ້ເມົາສ໌ໄປທີ່ກ່ອງປ້ອນຂໍ້ມູນເພື່ອເບິ່ງຂໍ້ຄວາມຊ່ວຍເຫຼືອສຳລັບກ່ອງປ້ອນຂໍ້ມູນນັ້ນ."

#. WFv9q
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7175817\n"
"help.text"
msgid "On first start of the Report Builder, the Properties window shows the <emph>Data</emph> tab page for the whole report."
msgstr "ເມື່ອເລີ່ມຕົ້ນຕົວສ້າງລາຍງານຄັ້ງທຳອິດ, ໜ້າຕ່າງຄຸນສົມບັດຈະສະແດງແທັບ <emph>ຂໍ້ມູນ</emph> ສຳລັບລາຍງານທັງໝົດ."

#. khEAx
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id9895931\n"
"help.text"
msgid "Select a table from the Contents list, then press Tab or click outside the input box to leave the input box."
msgstr "ເລືອກຕາຕະລາງຈາກລາຍການເນື້ອຫາ, ຈາກນັ້ນກົດ Tab ຫຼື ຄລິກຂ້າງນອກກ່ອງປ້ອນຂໍ້ມູນເພື່ອອອກຈາກກ່ອງນັ້ນ."

#. Shznq
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id3587145\n"
"help.text"
msgid "<ahelp hid=\".\">The <link href=\"text/sdatabase/rep_insertfield.xhp\">Add fields to report</link> window is shown automatically when you have selected a table in the Contents box and leave that box. You can also click the Add Field icon on the toolbar, or choose <item type=\"menuitem\">View - Add Field</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ໜ້າຕ່າງ <link href=\"text/sdatabase/rep_insertfield.xhp\">ເພີ່ມຟິວເຂົ້າໃນລາຍງານ</link> ຈະສະແດງຂຶ້ນໂດຍອັດຕະໂນມັດເມື່ອທ່ານເລືອກຕາຕະລາງໃນກ່ອງເນື້ອຫາແລ້ວອອກຈາກກ່ອງນັ້ນ. ທ່ານຍັງສາມາດຄລິກໄອຄອນ ເພີ່ມຟິວ ໃນແຖບເຄື່ອງມື, ຫຼື ເລືອກ <item type=\"menuitem\">ມຸມມອງ - ເພີ່ມຟິວ</item>.</ahelp>"

#. 5BJS6
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id6993926\n"
"help.text"
msgid "The <emph>General</emph> tab page can be used to change the name of the report, and to disable the Page Header or Page Footer areas, among others."
msgstr "ແທັບ <emph>ທົ່ວໄປ</emph> ສາມາດໃຊ້ເພື່ອປ່ຽນຊື່ຂອງລາຍງານ, ແລະ ເພື່ອປິດໃຊ້ງານພື້ນທີ່ຫົວໜ້າ ຫຼື ທ້າຍໜ້າ, ແລະ ອື່ນໆ."

#. eGuih
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id3729361\n"
"help.text"
msgid "<ahelp hid=\".\">To display the <emph>Data</emph> or <emph>General</emph> tab page for the whole report, choose <item type=\"menuitem\">Edit - Select All - Select Report</item>.</ahelp>"
msgstr "<ahelp hid=\".\">ເພື່ອສະແດງແທັບ <emph>ຂໍ້ມູນ</emph> ຫຼື <emph>ທົ່ວໄປ</emph> ສຳລັບລາຍງານທັງໝົດ, ໃຫ້ເລືອກ <item type=\"menuitem\">ແກ້ໄຂ - ເລືອກທັງໝົດ - ເລືອກລາຍງານ</item>.</ahelp>"

#. r4tre
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1768852\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Groups are kept together by page or by column (default). You must enable Keep Together also.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ກຸ່ມຕ່າງໆຈະຖືກຈັດໄວ້ດ້ວຍກັນຕາມໜ້າ ຫຼື ຕາມຄໍລຳ (ມາດຕະຖານ). ທ່ານຕ້ອງເປີດໃຊ້ງານ ຈັດໄວ້ດ້ວຍກັນ ນຳອີກ.</ahelp>"

#. PFQYf
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id6304818\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Specifies in which context the page header will be printed: on all pages, or not on pages with a report header or footer.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລະບຸວ່າຈະພິມຫົວໜ້າໃນສະພາບການໃດ: ໃນທຸກໆໜ້າ, ຫຼື ບໍ່ພິມໃນໜ້າທີ່ມີຫົວລາຍງານ ຫຼື ທ້າຍລາຍງານ.</ahelp>"

#. 9rAVD
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id401623\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Specifies in which context the page footer will be printed: on all pages, or not on pages with a report header or footer</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລະບຸວ່າຈະພິມທ້າຍໜ້າໃນສະພາບການໃດ: ໃນທຸກໆໜ້າ, ຫຼື ບໍ່ພິມໃນໜ້າທີ່ມີຫົວລາຍງານ ຫຼື ທ້າຍລາຍງານ</ahelp>"

#. rMRex
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id2162236\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Specifies to print repeated values.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລະບຸໃຫ້ພິມຄ່າທີ່ຊ້ຳກັນ.</ahelp>"

#. nCDvW
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7022003\n"
"help.text"
msgid "If you click the Page Header or Page Footer area without selecting any object, you see the <emph>General</emph> tab page for that area."
msgstr "ຖ້າທ່ານຄລິກທີ່ພື້ນທີ່ຫົວໜ້າ ຫຼື ທ້າຍໜ້າໂດຍບໍ່ໄດ້ເລືອກວັດຖຸໃດໆ, ທ່ານຈະເຫັນແທັບ <emph>ທົ່ວໄປ</emph> ສຳລັບພື້ນທີ່ນັ້ນ."

#. xACk2
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7004303\n"
"help.text"
msgid "You can edit some visual properties for the area."
msgstr "ທ່ານສາມາດແກ້ໄຂຄຸນສົມບັດດ້ານການເບິ່ງເຫັນບາງຢ່າງສຳລັບພື້ນທີ່ນັ້ນໄດ້."

#. hPUHN
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id2561723\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Sets the background color for the selected object, both on screen and for printing.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຕັ້ງສີພື້ນຫຼັງສຳລັບວັດຖຸທີ່ເລືອກ, ທັງໃນໜ້າຈໍ ແລະ ສຳລັບການພິມ.</ahelp>"

#. BXnJc
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1064485\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">An invisible object is not shown in the executed report. It is still visible in the Report Builder view.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ວັດຖຸທີ່ບໍ່ເຫັນຈະບໍ່ຖືກສະແດງໃນລາຍງານທີ່ເອີ້ນໃຊ້. ແຕ່ມັນຈະຍັງຄົງເຫັນໄດ້ໃນມຸມມອງຕົວສ້າງລາຍງານ.</ahelp>"

#. Xd2SG
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id2356028\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Defines the height of the selected object.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ກຳນົດຄວາມສູງຂອງວັດຖຸທີ່ເລືອກ.</ahelp>"

#. GXpuh
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1404461\n"
"help.text"
msgid "<ahelp hid=\".\">If the Conditional Print Expression evaluates to TRUE, the selected object will be printed.</ahelp>"
msgstr "<ahelp hid=\".\">ຖ້ານິພົດການພິມແບບມີເງື່ອນໄຂມີຄ່າເປັນ TRUE, ວັດຖຸທີ່ເລືອກຈະຖືກພິມ.</ahelp>"

#. jvkXA
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7404705\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Specifies whether the background of the selected object is transparent or opaque.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລະບຸວ່າພື້ນຫຼັງຂອງວັດຖຸທີ່ເລືອກຈະເປັນແບບໂປ່ງໃສ ຫຼື ທຶບແສງ.</ahelp>"

#. qgLML
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7466963\n"
"help.text"
msgid "If you click the <emph>Detail</emph> area without selecting any object, you see the <emph>General</emph> tab page for that area."
msgstr "ຖ້າທ່ານຄລິກທີ່ພື້ນທີ່ <emph>ລາຍລະອຽດ</emph> ໂດຍບໍ່ໄດ້ເລືອກວັດຖຸໃດໆ, ທ່ານຈະເຫັນແທັບ <emph>ທົ່ວໄປ</emph> ສຳລັບພື້ນທີ່ນັ້ນ."

#. kmEmG
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id3644215\n"
"help.text"
msgid "You can specify some properties to fine-tune the way the records are printed."
msgstr "ທ່ານສາມາດກຳນົດຄຸນສົມບັດບາງຢ່າງເພື່ອປັບແຕ່ງວິທີການພິມລະບຽນຂໍ້ມູນ."

#. cjDLx
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id3148899\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Force New Page specifies whether the current section and/or the next section is printed on a new page.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ບັງຄັບຂຶ້ນໜ້າໃໝ່ ລະບຸວ່າພາກສ່ວນປັດຈຸບັນ ແລະ/ຫຼື ພາກສ່ວນຖັດໄປຈະຖືກພິມໃນໜ້າໃໝ່ຫຼືບໍ່.</ahelp>"

#. CuyG2
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id6164433\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">New Row Or Column specifies, for a multi-column design, whether the current section and/or the next section will be printed on a new row or column.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ແຖວ ຫຼື ຄໍລຳໃໝ່ ລະບຸສຳລັບການອອກແບບແບບຫຼາຍຄໍລຳວ່າ ພາກສ່ວນປັດຈຸບັນ ແລະ/ຫຼື ພາກສ່ວນຖັດໄປຈະຖືກພິມໃນແຖວ ຫຼື ຄໍລຳໃໝ່ຫຼືບໍ່.</ahelp>"

#. nHVy2
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7405011\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Keep Together specifies to print the current object starting on top of a new page if it doesn't fit on the current page.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຈັດໄວ້ດ້ວຍກັນ ລະບຸໃຫ້ພິມວັດຖຸປັດຈຸບັນໂດຍເລີ່ມຕົ້ນທີ່ສ່ວນເທິງຂອງໜ້າໃໝ່ ຫາກມັນບໍ່ພໍດີກັບໜ້າປັດຈຸບັນ.</ahelp>"

#. FjNyy
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1536606\n"
"help.text"
msgid "Insert some data fields into the Detail area, or insert other control fields into any area. When you select an inserted field, you can set the properties in the Properties window."
msgstr "ແຊກຟິວຂໍ້ມູນບາງຢ່າງເຂົ້າໃນພື້ນທີ່ລາຍລະອຽດ, ຫຼື ແຊກຟິວຄວບຄຸມອື່ນໆເຂົ້າໃນພື້ນທີ່ໃດກໍໄດ້. ເມື່ອທ່ານເລືອກຟິວທີ່ແຊກເຂົ້າມາ, ທ່ານສາມາດຕັ້ງຄ່າຄຸນສົມບັດໃນໜ້າຕ່າງຄຸນສົມບັດ."

#. 2LAyX
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id9631641\n"
"help.text"
msgid "For a Label field, you can change the displayed text in the Label input box."
msgstr "ສຳລັບຟິວປ້າຍຊື່, ທ່ານສາມາດປ່ຽນຂໍ້ຄວາມທີ່ສະແດງໃນກ່ອງປ້ອນຂໍ້ມູນປ້າຍຊື່."

#. iy4M5
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7749565\n"
"help.text"
msgid "<ahelp hid=\".\">For a picture, you can specify to either insert the picture as a link to a file or only as an embedded object in the Base file. The embedded option increases the size of the Base file, while the link option is not as portable to other computers.</ahelp>"
msgstr "<ahelp hid=\".\">ສຳລັບຮູບພາບ, ທ່ານສາມາດລະບຸໄດ້ວ່າຈະແຊກຮູບພາບເປັນລິ້ງໄປຫາໄຟລ໌ ຫຼື ເປັນວັດຖຸຝັງຕົວໃນໄຟລ໌ Base ເທົ່ານັ້ນ. ຕົວເລືອກການຝັງຕົວຈະເພີ່ມຂະໜາດຂອງໄຟລ໌ Base, ໃນຂະນະທີ່ຕົວເລືອກລິ້ງຈະບໍ່ສະດວກໃນການຍ້າຍໄປໃຊ້ກັບຄອມພິວເຕີເຄື່ອງອື່ນ.</ahelp>"

#. XKxxX
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id4041871\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Set the X Position for the selected object</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຕັ້ງຕຳແໜ່ງ X ສຳລັບວັດຖຸທີ່ເລືອກ</ahelp>"

#. bvgTD
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id9930722\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Set the Y Position for the selected object</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຕັ້ງຕຳແໜ່ງ Y ສຳລັບວັດຖຸທີ່ເລືອກ</ahelp>"

#. YGfo2
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id5749687\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Sets the width of the selected object.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຕັ້ງຄວາມກວ້າງຂອງວັດຖຸທີ່ເລືອກ.</ahelp>"

#. pwu7Q
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id79348\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select the font for the selected text object.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກຕົວອັກສອນສຳລັບວັດຖຸຂໍ້ຄວາມທີ່ເລືອກ.</ahelp>"

#. r9No9
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id2414014\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Print when group change</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ພິມເມື່ອກຸ່ມມີການປ່ຽນແປງ</ahelp>"

#. 25y9K
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id7617114\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Vert. Alignment</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ການຈັດວາງແນວຕັ້ງ</ahelp>"

#. GXFDE
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1593676\n"
"help.text"
msgid "On the <emph>General</emph> tab page of a data field, you can set the Formatting properties, among others."
msgstr "ໃນແທັບ <emph>ທົ່ວໄປ</emph> ຂອງຟິວຂໍ້ມູນ, ທ່ານສາມາດຕັ້ງຄ່າຄຸນສົມບັດການຈັດຮູບແບບ, ແລະ ອື່ນໆ."

#. LyTPo
#: rep_prop.xhp
msgctxt ""
"rep_prop.xhp\n"
"par_id1243629\n"
"help.text"
msgid "<ahelp hid=\".\">On the Data tab page, you can change the data contents to be shown.</ahelp>"
msgstr "<ahelp hid=\".\">ໃນແທັບ ຂໍ້ມູນ, ທ່ານສາມາດປ່ຽນແປງເນື້ອຫາຂໍ້ມູນທີ່ຈະສະແດງໄດ້.</ahelp>"

#. g3CBB
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"tit\n"
"help.text"
msgid "Sorting and Grouping"
msgstr "ການຈັດລຽງ ແລະ ການຈັດກຸ່ມ"

#. GPUqF
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"hd_id3486434\n"
"help.text"
msgid "<variable id=\"rep_sort\"><link href=\"text/sdatabase/rep_sort.xhp\">Sorting and Grouping</link></variable>"
msgstr "<variable id=\"rep_sort\"><link href=\"text/sdatabase/rep_sort.xhp\">ການຈັດລຽງ ແລະ ການຈັດກຸ່ມ</link></variable>"

#. DCbhT
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id3068636\n"
"help.text"
msgid "<ahelp hid=\".\">In the Sorting and Grouping dialog of <link href=\"text/sdatabase/rep_main.xhp\">Report Builder</link>, you can define the fields that should be sorted in your report, and the fields that should be kept together to form a group.</ahelp> If you group your report by a certain field, all records with the same value of that field will be kept together in one group."
msgstr "<ahelp hid=\".\">ໃນກ່ອງໂຕ້ຕອບການຈັດລຽງ ແລະ ການຈັດກຸ່ມ ຂອງ <link href=\"text/sdatabase/rep_main.xhp\">ຕົວສ້າງລາຍງານ</link>, ທ່ານສາມາດກຳນົດຟິວທີ່ຄວນຈະຈັດລຽງໃນລາຍງານຂອງທ່ານ, ແລະ ຟິວທີ່ຄວນຈະຈັດໄວ້ດ້ວຍກັນເພື່ອສ້າງເປັນກຸ່ມ.</ahelp> ຖ້າທ່ານຈັດກຸ່ມລາຍງານຂອງທ່ານຕາມຟິວໃດໜຶ່ງ, ທຸກລະບຽນຂໍ້ມູນທີ່ມີຄ່າດຽວກັນໃນຟິວນັ້ນຈະຖືກຈັດໄວ້ດ້ວຍກັນໃນກຸ່ມດຽວ."

#. KudoP
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id876186\n"
"help.text"
msgid "The Groups box shows the fields in an order from top to bottom. You can select any field, then click the Move Up or Move Down button to move this field up or down in the list."
msgstr "ກ່ອງກຸ່ມຈະສະແດງຟິວຕ່າງໆຕາມລຳດັບຈາກເທິງຫາລຸ່ມ. ທ່ານສາມາດເລືອກຟິວໃດກໍໄດ້, ແລ້ວຄລິກປຸ່ມ ຍ້າຍຂຶ້ນ ຫຼື ຍ້າຍລົງ ເພື່ອຍ້າຍຟິວນັ້ນຂຶ້ນ ຫຼື ລົງໃນລາຍການ."

#. nG4vM
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id3939634\n"
"help.text"
msgid "The sorting and grouping will be applied in the order of the list from top to bottom."
msgstr "ການຈັດລຽງ ແລະ ການຈັດກຸ່ມຈະຖືກນຳໃຊ້ຕາມລຳດັບຂອງລາຍການຈາກເທິງຫາລຸ່ມ."

#. ZAFvB
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id599688\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Lists the fields that will be used for sorting or grouping. The field at the top has the highest priority, the second field has the second priority, and so on.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລາຍຊື່ຟິວທີ່ຈະຖືກນຳໃຊ້ສຳລັບການຈັດລຽງ ຫຼື ການຈັດກຸ່ມ. ຟິວທີ່ຢູ່ເທິງສຸດຈະມີລຳດັບຄວາມສຳຄັນສູງສຸດ, ຟິວທີສອງຈະມີລຳດັບຄວາມສຳຄັນຮອງລົງມາ, ແລະ ຕໍ່ໆໄປ.</ahelp>"

#. ETyGL
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id1371501\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Click to open a list from which you can select a field.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຄລິກເພື່ອເປີດລາຍການທີ່ທ່ານສາມາດເລືອກຟິວໄດ້.</ahelp>"

#. kEwPE
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id4661702\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Moves the selected field up in the list.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຍ້າຍຟິວທີ່ເລືອກຂຶ້ນໃນລາຍການ.</ahelp>"

#. YmDk5
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id7868892\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Moves the selected field down in the list.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ຍ້າຍຟິວທີ່ເລືອກລົງໃນລາຍການ.</ahelp>"

#. amjzG
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id2188787\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select the sorting order.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກລຳດັບການຈັດລຽງ.</ahelp>"

#. bYX8p
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id5833307\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select to show or hide the Group Header.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກເພື່ອສະແດງ ຫຼື ຊ້ອນຫົວລາຍງານ.</ahelp>"

#. tN76n
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id7726676\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select to show or hide the Group Footer.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກເພື່ອສະແດງ ຫຼື ຊ້ອນທ້າຍລາຍງານ.</ahelp>"

#. Ez4dt
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id3729361\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select to create a new group on each changed value, or on other properties.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກເພື່ອສ້າງກຸ່ມໃໝ່ໃນແຕ່ລະຄ່າທີ່ມີການປ່ຽນແປງ, ຫຼື ຕາມຄຸນສົມບັດອື່ນໆ.</ahelp>"

#. bd2EW
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id0409200922142041\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Removes the selected field from the list.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ລຶບຟິວທີ່ເລືອກອອກຈາກລາຍການ.</ahelp>"

#. CjspM
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id3405560\n"
"help.text"
msgid "By default a new group is created on every changed value of a record from the selected field. You can change this property depending on the type of field:"
msgstr "ຕາມມາດຕະຖານ, ກຸ່ມໃໝ່ຈະຖືກສ້າງຂຶ້ນໃນທຸກໆຄ່າທີ່ປ່ຽນແປງຂອງລະບຽນຂໍ້ມູນຈາກຟິວທີ່ເລືອກ. ທ່ານສາມາດປ່ຽນແປງຄຸນສົມບັດນີ້ໄດ້ໂດຍຂຶ້ນກັບປະເພດຂອງຟິວ:"

#. DD8mt
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id3409527\n"
"help.text"
msgid "For fields of type Text, you can select Prefix Characters and enter a number n of characters in the text box below. The records which are identical in the first n characters will be grouped together."
msgstr "ສຳລັບຟິວປະເພດຂໍ້ຄວາມ, ທ່ານສາມາດເລືອກ ຕົວອັກສອນນຳໜ້າ ແລະ ປ້ອນຈຳນວນ n ຂອງຕົວອັກສອນໃນກ່ອງຂໍ້ຄວາມທາງລຸ່ມ. ລະບຽນຂໍ້ມູນທີ່ມີຕົວອັກສອນ n ຕົວທຳອິດຄືກັນຈະຖືກຈັດເຂົ້າກຸ່ມດຽວກັນ."

#. DFvf2
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id7112338\n"
"help.text"
msgid "For fields of type Date/Time, you can group the records by the same year, quarter, month, week, day, hour, or minute. You can additionally specify an interval for weeks and hours: 2 weeks groups data in biweekly groups, 12 hours groups data in half-day groups."
msgstr "ສຳລັບຟິວປະເພດ ວັນທີ/ເວລາ, ທ່ານສາມາດຈັດກຸ່ມລະບຽນຂໍ້ມູນຕາມ ປີ, ໄຕມາດ, ເດືອນ, ອາທິດ, ວັນ, ຊົ່ວໂມງ, ຫຼື ນາທີ ດຽວກັນໄດ້. ນອກຈາກນັ້ນ, ທ່ານຍັງສາມາດລະບຸໄລຍະຫ່າງສຳລັບອາທິດ ແລະ ຊົ່ວໂມງໄດ້: 2 ອາທິດ ຈະຈັດກຸ່ມຂໍ້ມູນເປັນກຸ່ມລະສອງອາທິດ, 12 ຊົ່ວໂມງ ຈະຈັດກຸ່ມຂໍ້ມູນເປັນກຸ່ມລະເຄິ່ງມື້."

#. BBwXv
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id2855616\n"
"help.text"
msgid "For fields of type AutoNumber, Currency, or Number, you specify an interval."
msgstr "ສຳລັບຟິວປະເພດ ຕົວເລກອັດຕະໂນມັດ, ສະກຸນເງິນ, ຫຼື ຕົວເລກ, ທ່ານຕ້ອງລະບຸໄລຍະຫ່າງ."

#. mjbMU
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id7700430\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Enter the group interval value that records are grouped by.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ປ້ອນຄ່າໄລຍະຫ່າງຂອງກຸ່ມທີ່ໃຊ້ໃນການຈັດກຸ່ມລະບຽນຂໍ້ມູນ.</ahelp>"

#. XmWsa
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id1180455\n"
"help.text"
msgid "<ahelp hid=\".\" visibility=\"hidden\">Select the level of detail by which a group is kept together on the same page.</ahelp>"
msgstr "<ahelp hid=\".\" visibility=\"hidden\">ເລືອກລະດັບຂອງລາຍລະອຽດທີ່ຈະຈັດກຸ່ມໄວ້ດ້ວຍກັນໃນໜ້າດຽວກັນ.</ahelp>"

#. KbCbd
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id2091433\n"
"help.text"
msgid "When you specify to keep together some records on the same page, you have three choices:"
msgstr "ເມື່ອທ່ານກຳນົດໃຫ້ຈັດລະບຽນຂໍ້ມູນບາງຢ່າງໄວ້ດ້ວຍກັນໃນໜ້າດຽວກັນ, ທ່ານມີສາມທາງເລືອກ:"

#. NnDGM
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id5092318\n"
"help.text"
msgid "No - page boundaries are not taken into account."
msgstr "ບໍ່ - ບໍ່ພິຈາລະນາຂອບເຂດຂອງໜ້າ."

#. Zmwag
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id9312417\n"
"help.text"
msgid "Whole Group - prints the group header, detail section, and group footer on the same page."
msgstr "ທັງໝົດກຸ່ມ - ພິມຫົວລາຍງານ, ພາກສ່ວນລາຍລະອຽດ, ແລະ ທ້າຍລາຍງານໃນໜ້າດຽວກັນ."

#. Bzv5z
#: rep_sort.xhp
msgctxt ""
"rep_sort.xhp\n"
"par_id9089022\n"
"help.text"
msgid "With First Detail - prints the group header on a page only if the first detail record also can be printed on the same page."
msgstr "ພ້ອມລາຍລະອຽດທຳອິດ - ພິມຫົວລາຍງານໃນໜ້າໃດໜຶ່ງກໍຕໍ່ເມື່ອລະບຽນຂໍ້ມູນລາຍລະອຽດທຳອິດສາມາດພິມໃນໜ້າດຽວກັນນັ້ນໄດ້."

#. eDFFK
