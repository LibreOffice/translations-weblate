"par_id3153729\n"
"help.text"
msgid "<ahelp hid=\"SID_DRAW\">This command updates the formula in the document window.</ahelp>"
msgstr "<ahelp hid=\"SID_DRAW\">ຄຳສັ່ງນີ້ຈະປັບປຸງສູດໃນໜ້າຕ່າງເອກະສານ.</ahelp>"

#. Ewi9U
#: 03070000.xhp
msgctxt ""
"03070000.xhp\n"
"par_id3145253\n"
"help.text"
msgid "Changes in the <emph>Commands</emph> window are automatically updated if <emph>AutoUpdate Display</emph> is activated."
msgstr "ການປ່ຽນແປງໃນໜ້າຕ່າງ <emph>ຄຳສັ່ງ</emph> ຈະຖືກປັບປຸງໂດຍອັດຕະໂນມັດ ຖ້າ <emph>ປັບປຸງການສະແດງຜົນອັດຕະໂນມັດ</emph> ຖືກເປີດໃຊ້ງານ."

#. GGdNs
#: 03080000.xhp
msgctxt ""
"03080000.xhp\n"
"tit\n"
"help.text"
msgid "AutoUpdate Display"
msgstr "ປັບປຸງການສະແດງຜົນອັດຕະໂນມັດ"

