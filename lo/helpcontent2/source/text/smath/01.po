msgctxt ""
"03050000.xhp\n"
"tit\n"
"help.text"
msgid "Zoom Out"
msgstr "ຂະຫຍາຍອອກ"

#. iTPGG
#: 03050000.xhp
msgctxt ""
"03050000.xhp\n"
"bm_id3147338\n"
"help.text"
msgid "<bookmark_value>views; zooming out $[officename] Math</bookmark_value><bookmark_value>formula display sizes</bookmark_value><bookmark_value>formulas; zooming out</bookmark_value><bookmark_value>zooming out on formula display</bookmark_value>"
msgstr "<bookmark_value>ມຸມມອງ; ຂະຫຍາຍອອກ $[officename] Math</bookmark_value><bookmark_value>ຂະໜາດການສະແດງຜົນສູດ</bookmark_value><bookmark_value>ສູດ; ການຂະຫຍາຍອອກ</bookmark_value><bookmark_value>ຂະຫຍາຍອອກໃນການສະແດງຜົນສູດ</bookmark_value>"

