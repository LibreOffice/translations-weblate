msgid "<variable id=\"limits\"><link href=\"text/smath/guide/limits.xhp\">Working with Limits</link></variable>"
msgstr "<variable id=\"limits\"><link href=\"text/smath/guide/limits.xhp\">ການເຮັດວຽກກັບຂີດຈຳກັດ</link></variable>"

#. Gtt8e
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"hd_id9881893\n"
"help.text"
msgid "How can I define the limits in a Sum or Integral formula?"
msgstr "ຂ້ອຍຈະກຳນົດຂີດຈຳກັດໃນສູດຜົນບວກ ຫຼື ອິນເຕກຣານໄດ້ແນວໃດ?"

#. kFrLC
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id6504409\n"
"help.text"
msgid "You want to insert a summation formula like \"summation of s^k from k = 0 to n\" at the cursor in a Writer text document."
msgstr "ທ່ານຕ້ອງການແຊກສູດຜົນບວກ ເຊັ່ນ \"ຜົນບວກຂອງ s^k ຈາກ k = 0 ຫາ n\" ຢູ່ບ່ອນເຄີເຊີໃນເອກະສານຂໍ້ຄວາມ Writer."

#. qAFch
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id1276589\n"
"help.text"
msgid "You see the Math input window and the Elements pane on the left."
msgstr "ທ່ານຈະເຫັນປ່ອງຢ້ຽມປ້ອນຂໍ້ມູນ Math ແລະ ແຖບລາຍການຢູ່ທາງຊ້າຍ."

#. DZW2c
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id3283791\n"
"help.text"
msgid "From the list on the upper part of the Elements pane, select the <emph>Operators</emph> item."
msgstr "ຈາກລາຍການຢູ່ສ່ວນເທິງຂອງແຖບລາຍການ, ໃຫ້ເລືອກລາຍການ <emph>ຕົວດຳເນີນການ</emph>."

#. r8sVG
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id9734794\n"
"help.text"
msgid "In the lower part of the Elements pane, click the <emph>Sum</emph> icon."
msgstr "ໃນສ່ວນລຸ່ມຂອງແຖບລາຍການ, ໃຫ້ຄລິກໄອຄອນ <emph>ຜົນບວກ</emph>."

#. erGA9
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id9641712\n"
"help.text"
msgid "To enable lower and upper limits, click additionally the <emph>Upper and Lower Limits</emph> icon."
msgstr "ເພື່ອເປີດໃຊ້ຂີດຈຳກັດລຸ່ມ ແລະ ເທິງ, ໃຫ້ຄລິກເພີ່ມເຕີມທີ່ໄອຄອນ <emph>ຂີດຈຳກັດເທິງ ແລະ ລຸ່ມ</emph>."

#. YxM8C
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id3304239\n"
"help.text"
msgid "In the input window, the first placeholder or marker is selected, and you can start to enter the lower limit:"
msgstr "ໃນປ່ອງຢ້ຽມປ້ອນຂໍ້ມູນ, ຕົວສຳຮອງ ຫຼື ເຄື່ອງໝາຍທຳອິດຈະຖືກເລືອກ, ແລະ ທ່ານສາມາດເລີ່ມປ້ອນຂີດຈຳກັດລຸ່ມໄດ້:"

#. szLNG
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id8471327\n"
"help.text"
msgid "Press F4 to advance to the next marker, and enter the upper limit:"
msgstr "ກົດ F4 ເພື່ອໄປຫາເຄື່ອງໝາຍຖັດໄປ, ແລະ ປ້ອນຂີດຈຳກັດເທິງ:"

#. Wh4vB
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id759300\n"
"help.text"
msgid "Press F4 to advance to the next marker, and enter the summand:"
msgstr "ກົດ F4 ເພື່ອໄປຫາເຄື່ອງໝາຍຖັດໄປ, ແລະ ປ້ອນຕົວບວກ:"

#. dJvvn
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id6756187\n"
"help.text"
msgid "Now the formula is complete. Click into your text document outside the formula to leave the formula editor."
msgstr "ຕອນນີ້ສູດສຳເລັດແລ້ວ. ຄລິກໃສ່ເອກະສານຂໍ້ຄວາມຂອງທ່ານຢູ່ນອກສູດເພື່ອອອກຈາກຕົວແກ້ໄຂສູດ."

#. bFFkA
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id9406414\n"
"help.text"
msgid "In the same way, you can enter an Integral formula with limits. When you click an icon from the Elements pane, the assigned text command is inserted in the input window. If you know the text commands, you can enter the commands directly in the input window."
msgstr "ໃນທຳນອງດຽວກັນ, ທ່ານສາມາດປ້ອນສູດອິນເຕກຣານທີ່ມີຂີດຈຳກັດ. ເມື່ອທ່ານຄລິກໄອຄອນຈາກແຖບລາຍການ, ຄຳສັ່ງຂໍ້ຄວາມທີ່ຖືກກຳນົດຈະຖືກແຊກເຂົ້າໃນປ່ອງຢ້ຽມປ້ອນຂໍ້ມູນ. ຖ້າທ່ານຮູ້ຄຳສັ່ງຂໍ້ຄວາມ, ທ່ານສາມາດປ້ອນຄຳສັ່ງໂດຍກົງໃນປ່ອງຢ້ຽມປ້ອນຂໍ້ມູນໄດ້."

#. VAoyi
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id1965697\n"
"help.text"
msgid "Click in the input window and enter the following line:"
msgstr "ຄລິກໃນປ່ອງຢ້ຽມປ້ອນຂໍ້ມູນ ແລະ ປ້ອນແຖວຕໍ່ໄປນີ້:"

#. 7rRJW
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id4651020\n"
"help.text"
msgid "A small gap exists between f(x) and dx, which you can also enter using the Elements pane: select the <emph>Formats</emph> item from the list on the top, then the <emph>Small Gap</emph> icon."
msgstr "ມີຊ່ອງຫວ່າງນ້ອຍໆລະຫວ່າງ f(x) ແລະ dx, ເຊິ່ງທ່ານຍັງສາມາດປ້ອນໄດ້ໂດຍໃຊ້ແຖບລາຍການ: ເລືອກລາຍການ <emph>ຮູບແບບ</emph> ຈາກລາຍການທາງເທິງ, ຈາກນັ້ນເລືອກໄອຄອນ <emph>ຊ່ອງຫວ່າງນ້ອຍ</emph>."

#. FSWqq
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id3877071\n"
"help.text"
msgid "If you don't like the font of the letters f and x, choose <item type=\"menuitem\">Format - Fonts</item> and select other fonts. Click the <emph>Default</emph> button to use the new fonts as default from now on."
msgstr "ຖ້າທ່ານບໍ່ມັກຕົວອັກສອນ f ແລະ x, ໃຫ້ເລືອກ <item type=\"menuitem\">ຮູບແບບ - ຕົວອັກສອນ</item> ແລະ ເລືອກຕົວອັກສອນອື່ນໆ. ຄລິກປຸ່ມ <emph>ເລີ່ມຕົ້ນ</emph> ເພື່ອໃຊ້ຕົວອັກສອນໃໝ່ເປັນຄ່າເລີ່ມຕົ້ນນັບແຕ່ຕອນນີ້ເປັນຕົ້ນໄປ."

#. KBUXj
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id3021332\n"
"help.text"
msgid "If you need the formula within a line of text, the limits increase the line height. You can choose <item type=\"menuitem\">Format - Text Mode</item> to place the limits besides the Sum or Integral symbol, which reduces the line height."
msgstr "ຖ້າທ່ານຕ້ອງການສູດພາຍໃນແຖວຂໍ້ຄວາມ, ຂີດຈຳກັດຈະເພີ່ມຄວາມສູງຂອງແຖວ. ທ່ານສາມາດເລືອກ <item type=\"menuitem\">ຮູບແບບ - ໂໝດຂໍ້ຄວາມ</item> ເພື່ອວາງຂີດຈຳກັດໄວ້ຂ້າງເຄື່ອງໝາຍຜົນບວກ ຫຼື ອິນເຕກຣານ, ເຊິ່ງຈະຊ່ວຍຫຼຸດຄວາມສູງຂອງແຖວລົງ."

#. FMfHG
#: limits.xhp
msgctxt ""
"limits.xhp\n"
"par_id260322\n"
