msgctxt ""
"main_slide.xhp\n"
"par_id781615491497404\n"
"help.text"
msgid "Opens a File Picker to choose an image file to be set as the background of the current slide."
msgstr "ເປີດຕົວເລືອກໄຟລ໌ເພື່ອເລືອກໄຟລ໌ຮູບພາບທີ່ຈະຕັ້ງເປັນພື້ນຫຼັງຂອງສະໄລ້ປັດຈຸບັນ."

#. 92Pku
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id921615489787123\n"
"help.text"
msgid "New Master"
msgstr "ຕົ້ນແບບໃໝ່"

#. kPJER
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id131615493790751\n"
"help.text"
msgid "Creates a new Master Slide. This function is only available in <emph>Master View</emph>."
msgstr "ສ້າງສະໄລ້ຕົ້ນແບບໃໝ່. ຟັງຊັນນີ້ໃຊ້ໄດ້ສະເພາະໃນ <emph>ມຸມມອງຕົ້ນແບບ</emph> ເທົ່ານັ້ນ."

#. Vwom7
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id491615494190854\n"
"help.text"
msgid "To enter the Master View, go to <emph>View - Master Slide</emph>. To exit the Master View, go to <emph>View - Normal</emph>."
msgstr "ເພື່ອເຂົ້າສູ່ມຸມມອງຕົ້ນແບບ, ໃຫ້ໄປທີ່ <emph>ມຸມມອງ - ສະໄລ້ຕົ້ນແບບ</emph>. ເພື່ອອອກຈາກມຸມມອງຕົ້ນແບບ, ໃຫ້ໄປທີ່ <emph>ມຸມມອງ - ປົກກະຕິ</emph>."

#. HQQHh
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id421615489787299\n"
"help.text"
msgid "Delete Master"
msgstr "ລຶບຕົ້ນແບບ"

#. EBxxM
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id661615494028415\n"
"help.text"
msgid "Deletes the currently selected Master Slide. This function is only available in <emph>Master View</emph>"
msgstr "ລຶບສະໄລ້ຕົ້ນແບບທີ່ເລືອກໃນປັດຈຸບັນ. ຟັງຊັນນີ້ໃຊ້ໄດ້ສະເພາະໃນ <emph>ມຸມມອງຕົ້ນແບບ</emph> ເທົ່ານັ້ນ."

#. hXNB7
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id841615489787538\n"
"help.text"
msgid "Master Background"
msgstr "ພື້ນຫຼັງຕົ້ນແບບ"

#. Kf3CF
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id921615494351365\n"
"help.text"
msgid "This option allows to show or hide the background image defined in the master slide."
msgstr "ຕົວເລືອກນີ້ຊ່ວຍໃຫ້ສາມາດສະແດງ ຫຼື ເຊື່ອງຮູບພາບພື້ນຫຼັງທີ່ກຳນົດໄວ້ໃນສະໄລ້ຕົ້ນແບບ."

#. 9GSWp
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id621615489788132\n"
"help.text"
msgid "Master Objects"
msgstr "ວັດຖຸຕົ້ນແບບ"

#. wjDcS
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id541615494644223\n"
"help.text"
msgid "This option allows to show or hide objects defined in the master slide."
msgstr "ຕົວເລືອກນີ້ຊ່ວຍໃຫ້ສາມາດສະແດງ ຫຼື ເຊື່ອງວັດຖຸທີ່ກຳນົດໄວ້ໃນສະໄລ້ຕົ້ນແບບ."

#. BVTEY
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id51615489788356\n"
"help.text"
msgid "Master Elements"
msgstr "ອົງປະກອບຕົ້ນແບບ"

#. GaTGo
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id111615494747246\n"
"help.text"
msgid "Displays a dialog box where the following elements from the master slide can be enabled or disabled:"
