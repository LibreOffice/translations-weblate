msgctxt ""
"submenu_object_shape.xhp\n"
"tit\n"
"help.text"
msgid "Textbox and Shape (Impress)"
msgstr "ກ່ອງຂໍ້ຄວາມ ແລະ ຮູບຊົງ (Impress)"

#. uygwP
