msgid "Footer"
msgstr "ທ້າຍຂັ້ນ"

#. LLGmD
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id401615494904662\n"
"help.text"
msgid "Slide Number"
msgstr "ເລກສະໄລ້"

#. sYXNP
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id851615489788586\n"
"help.text"
msgid "Show Slide"
msgstr "ສະແດງສະໄລ້"

#. 6hQEB
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id321615495037553\n"
"help.text"
msgid "If a slide is hidden, this function makes it visible again."
msgstr "ຖ້າສະໄລ້ຖືກເຊື່ອງໄວ້, ຟັງຊັນນີ້ຈະເຮັດໃຫ້ມັນກັບມາສະແດງອີກຄັ້ງ."

#. FFLV4
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id201615489788874\n"
"help.text"
msgid "Hide Slide"
msgstr "ເຊື່ອງສະໄລ້"

#. jdiSK
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id961615495104794\n"
"help.text"
msgid "If a slide is visible, this function hides it."
msgstr "ຖ້າສະໄລ້ກຳລັງສະແດງຢູ່, ຟັງຊັນນີ້ຈະເຊື່ອງມັນໄວ້."

#. nV23n
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id121615489789140\n"
"help.text"
