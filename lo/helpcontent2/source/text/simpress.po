msgstr "ໄປຫາສະໄລ້ທີ່ແກ້ໄຂຫຼ້າສຸດ"

#. Snoa6
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id741615495336473\n"
"help.text"
msgid "Navigates to the last edited slide in the document."
msgstr "ນຳທາງໄປຫາສະໄລ້ທີ່ຖືກແກ້ໄຂຫຼ້າສຸດໃນເອກະສານ."

#. FA3Ra
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id641615489789548\n"
"help.text"
msgid "Move"
msgstr "ຍ້າຍ"

#. GBPvF
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id371615495363225\n"
"help.text"
msgid "Shows a list of move operations that can be applied to the current slide:"
msgstr "ສະແດງລາຍການການຍ້າຍທີ່ສາມາດນຳໃຊ້ກັບສະໄລ້ປັດຈຸບັນ:"

#. TF4iz
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id711615495448201\n"
"help.text"
msgid "<emph>Slide to Start:</emph> Moves the current slide to the first position."
msgstr "<emph>ສະໄລ້ໄປຫາຈຸດເລີ່ມຕົ້ນ:</emph> ຍ້າຍສະໄລ້ປັດຈຸບັນໄປຫາຕຳແໜ່ງທຳອິດ."

#. uAt25
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id101615495452464\n"
"help.text"
msgid "<emph>Slide Up:</emph> Moves the current slide one position up in the presentation."
msgstr "<emph>ສະໄລ້ຂຶ້ນ:</emph> ຍ້າຍສະໄລ້ປັດຈຸບັນຂຶ້ນໜຶ່ງຕຳແໜ່ງໃນການນຳສະເໜີ."

#. PdEMy
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id761615495456499\n"
"help.text"
msgid "<emph>Slide Down:</emph> Moves the current slide one position down in the presentation."
msgstr "<emph>ສະໄລ້ລົງ:</emph> ຍ້າຍສະໄລ້ປັດຈຸບັນລົງໜຶ່ງຕຳແໜ່ງໃນການນຳສະເໜີ."

#. ESDFM
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id321615495459372\n"
"help.text"
msgid "<emph>Slide to End:</emph> Moves the current slide to the last position."
msgstr "<emph>ສະໄລ້ໄປຫາຈຸດສິ້ນສຸດ:</emph> ຍ້າຍສະໄລ້ປັດຈຸບັນໄປຫາຕຳແໜ່ງສຸດທ້າຍ."

#. AsscG
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"hd_id301615489789755\n"
"help.text"
msgid "Navigate"
msgstr "ການນຳທາງ"

#. 62VZA
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id941615558050553\n"
"help.text"
msgid "Shows a list of functions that can be used to navigate through the slides:"
msgstr "ສະແດງລາຍການຟັງຊັນທີ່ສາມາດໃຊ້ເພື່ອການນຳທາງລະຫວ່າງສະໄລ້:"

#. Mdi6Y
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id381615558169403\n"
"help.text"
msgid "<emph>To First Slide:</emph> Selects the first slide in the presentation."
msgstr "<emph>ໄປຫາສະໄລ້ທຳອິດ:</emph> ເລືອກສະໄລ້ທຳອິດໃນການນຳສະເໜີ."

#. bYEak
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id131615558173437\n"
"help.text"
msgid "<emph>To Previous Slide:</emph> Navigates to the previous slide with respect to the currently selected slide."
msgstr "<emph>ໄປຫາສະໄລ້ກ່ອນໜ້າ:</emph> ນຳທາງໄປຫາສະໄລ້ກ່ອນໜ້າຂອງສະໄລ້ທີ່ເລືອກໃນປັດຈຸບັນ."

#. YXD3o
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id941615558176178\n"
"help.text"
msgid "<emph>To Next Slide:</emph> Navigates to the next slide with respect to the currently selected slide."
msgstr "<emph>ໄປຫາສະໄລ້ຖັດໄປ:</emph> ນຳທາງໄປຫາສະໄລ້ຖັດໄປຂອງສະໄລ້ທີ່ເລືອກໃນປັດຈຸບັນ."

#. dspAA
#: main_slide.xhp
msgctxt ""
"main_slide.xhp\n"
"par_id91615558179041\n"
"help.text"
msgid "<emph>To Last Slide:</emph> Selects the last slide in the presentation."
msgstr "<emph>ໄປຫາສະໄລ້ສຸດທ້າຍ:</emph> ເລືອກສະໄລ້ສຸດທ້າຍໃນການນຳສະເໜີ."

#. A8xE3
